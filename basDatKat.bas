Public Sub F_Mov(ByVal IdxNr As Long, ByVal Flag As Boolean)
On Error GoTo LiErr
'Verschiebt den Eintrag in der Kette

Dim KeyNr As Long
Dim RowNr As Long
Dim KeySt As String
Dim Krit1 As String
Dim BoMar As Variant 'Bookmark
Dim SoNr1 As Integer 'Sortiernummer
Dim SoNr2 As Integer 'Sortiernummer
Dim SQL1 As String
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmFragen
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows

If RpSel.Count = 0 Then Exit Sub

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qryKat08B WHERE IDSub = " & IdxNr & " ORDER BY Sorter" 'Fragebogen
Else
    SQL1 = "SELECT * FROM qryKat08B WHERE [IDSub] = " & IdxNr & " ORDER BY [Sorter];" 'Fragebogen
End If

Set RS136 = New ADODB.Recordset
With RS136
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With

For Each RpRow In RpSel
    Set RpCol = RpCls.Find(0)
    KeyNr = RpRow.Record(RpCol.ItemIndex).Value
    Krit1 = "[ID6]=" & KeyNr
    RS136.Find Criteria:=Krit1, SkipRecords:=0, SearchDirection:=adSearchForward
    If Not (RS136.BOF Or RS136.EOF) Then
        If RS136.Supports(adBookmark) Then
            BoMar = RS136.Bookmark
            SoNr1 = RS136.Fields("Sorter").Value
            If Flag = True Then
                RS136.MovePrevious
                If Not RS136.BOF Then
                    SoNr2 = RS136.Fields("Sorter").Value
                    RS136.Fields("Sorter").Value = SoNr1
                    RS136.Bookmark = BoMar
                    RS136.Fields("Sorter").Value = SoNr2
                    RS136.Update
                End If
            Else
                RS136.MoveNext
                If Not RS136.EOF Then
                    SoNr2 = RS136.Fields("Sorter").Value
                    RS136.Fields("Sorter").Value = SoNr1
                    RS136.Bookmark = BoMar
                    RS136.Fields("Sorter").Value = SoNr2
                    RS136.Update
                End If
            End If
        End If
    End If
Next RpRow

RS136.Close
Set RS136 = Nothing

Set RpSel = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "F_Mov " & Err.Number
Resume Next

End Sub
