Public Sub K_AnEi(ByVal EngTy As Integer)
On Error GoTo GrErr
'Fügt Parameter ein

Dim KatNr As Long
Dim GesZa As Long
Dim IdxNr As Long
Dim SQL1 As String
Dim KyStr As String
Dim TmpSt As String
Dim SuStr As String
Dim EiTex As String
Dim Posit As Integer
Dim EinZu As Boolean
Dim TxIdx As VB.TextBox

Set FM = frmKaEdit
Set CmZif = FM.cmbZiffe
Set CmBez = FM.cmbBezei
Set TxIdx = FM.txtIdxNr

KyStr = Left$(GlNod, 1)

KatNr = Mid$(GlNod, 2, Len(GlNod) - 1)

If TxIdx.Text <> vbNullString Then
    IdxNr = CLng(TxIdx.Text)
Else
    Exit Sub
End If

Select Case EngTy
Case 1:
        TmpSt = CmZif.Text
        Posit = InStr(1, TmpSt, Chr$(32), 1)
        If Posit > 0 Then
            TmpSt = Left$(TmpSt, Posit - 1)
        End If
        If InStr(1, TmpSt, ",", 1) > 0 Then
            SuStr = Replace(TmpSt, ",", ".")
        Else
            SuStr = TmpSt
        End If
Case 2:
        TmpSt = CmBez.Text
        SuStr = TmpSt
End Select

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qryAnKa5 WHERE ID0 = " & IdxNr 'Gebührenkataloge
Else
    SQL1 = "SELECT * FROM qryAnKa5 WHERE [ID0] = " & IdxNr & ";" 'Gebührenkataloge
End If

Set RS123 = New ADODB.Recordset
With RS123
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenForwardOnly
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With

If RS123.Supports(adAddNew) Then
    Set RS128 = New ADODB.Recordset
    RS128.CursorLocation = adUseClient
    Select Case EngTy
    Case 1: Set RS128 = DBCmRe2("qryKat01M", "@IdxNr", "@IdStr", KatNr, SuStr)
    Case 2: Set RS128 = DBCmRe2("qryKat01N", "@IdxNr", "@IdStr", KatNr, SuStr)
    End Select
    GesZa = RS128.RecordCount
    If GesZa > 0 Then
        Select Case EngTy
        Case 1: EiTex = RS128.Fields("GOID").Value
                RS123.Filter = "[GOID] = '" & EiTex & "'"
        Case 2: EiTex = RS128.Fields("IDKurz").Value
                RS123.Filter = "[IDKurz] Like '*" & EiTex & "*'"
        End Select
        If RS123.RecordCount > 0 Then
            EinZu = False
        Else
            EinZu = True
        End If
        RS123.Filter = adFilterNone
        If EinZu = True Then
            RS123.AddNew
            RS123.Fields("ID0").Value = IdxNr
            RS123.Fields("ID2").Value = RS128.Fields("ID0").Value
            RS123.Fields("ID3").Value = RS128.Fields("ID3").Value
            If RS128.Fields("GOID").Value <> vbNullString Then RS123.Fields("GOID").Value = RS128.Fields("GOID").Value
            If RS128.Fields("IDKurz").Value <> vbNullString Then RS123.Fields("IDKurz").Value = Left$(RS128.Fields("IDKurz").Value, 150)
            If RS128.Fields("Preis1").Value <> vbNullString Then RS123.Fields("Preis1").Value = RS128.Fields("Preis1").Value
            RS123.Fields("Selekt").Value = 0
            RS123.Fields("x").Value = 1
            RS123.Fields("ResTag").Value = -1 'WICHTIG!
            RS123.Update
        End If
    End If
    RS128.Close
    Set RS128 = Nothing
End If

RS123.Close
Set RS123 = Nothing

If KyStr = "A" Then
    KaSpr
    K_AnLa IdxNr
End If

CmZif.Text = vbNullString
CmBez.Text = vbNullString

If EngTy = 1 Then
    CmZif.SetFocus
ElseIf EngTy = 2 Then
    CmBez.SetFocus
End If

Exit Sub

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_AnEi " & Err.Number
Resume Next

End Sub

