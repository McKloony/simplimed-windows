                    Set RpCol = RpCl7.Find(Buh_Sachkontenbez)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        KtBeS = RpRow.Record(RpCol.ItemIndex).Value
                    End If
    
                    If KtNrH = 0 Then
                         If BuAus = "ja" Then 'Ausgabe
                            KtNrH = GlGeK(GeKto + 1, 2)
                        Else
                            KtNrH = 0
                        End If
                    End If
                    KtStH = SBuFo(KtNrH) 'Sachkontenformatierung
            
                    If KtIdS = 0 Then
                         If BuAus = "nein" Then 'Einnhame
                            KtIdS = GlGeK(GeKto + 1, 2)
                        Else
                            KtIdS = 0
                        End If
                    End If
                    KtStS = SBuFo(KtIdS) 'Sachkontenformatierung
    
                    If KtBeH = vbNullString Then
                        If BuAus = "ja" Then 'Ausgabe
                            KtBeH = GlGeK(GeKto + 1, 1)
                        End If
                    End If
                    
                    If KtBeS = vbNullString Then
                        If BuAus = "nein" Then 'Einnhame
                            KtBeS = GlGeK(GeKto + 1, 1)
                        End If
                    End If

                    TxIdx.Text = IdxWe
                    TxKtS.Text = KtStS & Space$(1) & KtBeS
                    TxKtH.Text = KtStH & Space$(1) & KtBeH
                    TxNrS.Text = KtStS
                    TxNrH.Text = KtStH
                    TxBeS.Text = KtBeS
                    TxBeH.Text = KtBeH
    
                    For AktZa = 1 To UBound(GlStu)
                        If CSng(GlStu(AktZa, 1)) = KoStu Then
                            CmSte.ListIndex = AktZa - 1
                            Exit For
                        End If
                    Next AktZa
                    CmWar.ListIndex = IdWar
                End If

                If BuTex <> vbNullString Then
                    If KoTex <> vbNullString Then
                        CmBuT.Text = BuTex & " | " & KoTex
                    Else
                        CmBuT.Text = BuTex
                    End If
                ElseIf KoTex <> vbNullString Then
                    If KoTex <> vbNullString Then
                        CmBuT.Text = KoTex
                    Else
                        CmBuT.Text = "kein Buchtext"
                    End If
                End If
                
                If GlBut = RibTab_HomeBanki Then
                    TxBuD.Enabled = False
                    UpCo1.Enabled = False
                    PuBu1.Enabled = False
                End If

                If BuSpl = False Then
                    TxBuB.Enabled = False
                End If

                CmGek.Enabled = False
                CmTyp.Enabled = False
                DoEvents
                
                If ReStr = vbNullString Then
                    clFen.FenDsk 2
                
                    Unload frmBaAbl
                    DoEvents
                    If BuAbg = False Then
                        If BuSpl = True Then
                            frmBuEdit.BaBet = Round(BaBet, 2)
                            frmBuEdit.GeBet = Round(GeBet, 2)
                            frmBuEdit.BaGui = BaGui
                        End If
                        frmBuEdit.Show
                    End If
                    
                    clFen.FenDsk 3
                Else
                    SPopu "Buchung Ableiten", "Dieser Umsatz ist bereits dem Patienten: " & PatSt & " zugeordnet.", IC48_Information
                End If
            End If
        End If
    End If
End If

Screen.MousePointer = vbNormal

Set RpSl1 = Nothing
Set RpSl7 = Nothing

Set RpCo1 = Nothing
Set RpCo7 = Nothing

Set clFen = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_BuVs " & Err.Number
Resume Next

End Sub

Private Function K_CmA(ByVal Combo As Control, ByVal IdxWe As Integer) As Long
On Error GoTo DoErr
'Gibt die Indexnummer eines Combowertes zurück

Dim IdxNr As Long
Dim GesZa As Integer
Dim Vorha As Boolean

GesZa = Combo.ListCount

For IdxNr = 0 To GesZa - 1
    If Combo.ItemData(IdxNr) = IdxWe Then
        Vorha = True
        Exit For
    End If
Next IdxNr

If Vorha = True Then
    K_CmA = IdxNr
Else
    K_CmA = -1
End If

Exit Function

DoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_CmA " & Err.Number
Resume Next
    
End Function

