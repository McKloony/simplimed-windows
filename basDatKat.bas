    ElseIf TreKy = "R" Then
        Set RpItm = RpRec.AddItem(vbNullString)
        RpItm.HasCheckbox = True
        RpItm.Checked = GlKeM
        RpItm.Alignment = xtpAlignmentIconCenter
        Set RpItm = RpRec.AddItem(RS140.Fields("ID4").Value)
        Set RpItm = RpRec.AddItem(RS140.Fields("Farbe").Value)
        Set RpItm = RpRec.AddItem(RS140.Fields("Betreff").Value)
