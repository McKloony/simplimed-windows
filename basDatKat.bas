Public Sub S_KtSa(ByVal NeuDa As Boolean, Optional ByVal SuStr As String)
On Error GoTo KoErr
'Speichert die Änderungen im Kontenplan

Dim SQL1 As String
Dim IdxNr As Long
Dim RowNr As Long
Dim ReStu As Single
Dim AktZa As Integer
Dim StuZa As Integer
Dim KntRm As Integer
Dim KnTyp As Integer
Dim Mld1, Tit1 As String
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmRam As XtremeCommandBars.CommandBarComboBox
Dim CmTyp As XtremeCommandBars.CommandBarComboBox
Dim RpCon As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmBuKont
Set RpCon = FM.repCont1
Set CmBrs = FM.comBar02
Set CmKto = FM.cmbBuStu
Set RpCls = RpCon.Columns
Set RpSel = RpCon.SelectedRows

Set CmRam = CmBrs.FindControl(CmRam, KA_SuCo1, , True)
Set CmTyp = CmBrs.FindControl(CmTyp, KA_SuCo2, , True)

KntRm = CmRam.ListIndex
KnTyp = CmTyp.ListIndex

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        RowNr = RpRow.Index
        Set RpCol = RpCls.Find(Kon_IDI)
        IdxNr = RpRow.Record(RpCol.ItemIndex).Value
    
        If GlTyp < 2 Then
            If NeuDa = True Then
                SQL1 = "SELECT * FROM dbo.qrySimBuKto ORDER BY IDI"
            Else
                SQL1 = "SELECT * FROM dbo.qrySimBuKto WHERE (IDI = " & IdxNr & ")"
            End If
        Else
            If NeuDa = True Then
                SQL1 = "SELECT * FROM qrySimBuKto ORDER BY [IDI];"
            Else
                SQL1 = "SELECT * FROM qrySimBuKto WHERE ([IDI] = " & IdxNr & ");"
            End If
        End If

        If FM.txtKonto.Text <> vbNullString Then
            Set RS128 = New ADODB.Recordset
            With RS128
                .CursorLocation = adUseClient
                .Source = SQL1
                .ActiveConnection = DB1
                .CursorType = adOpenDynamic
                .LockType = adLockOptimistic
                .Open Options:=adCmdText
            End With
            
            If NeuDa = True Then
                If RS128.Supports(adAddNew) Then
                    RS128.AddNew
                End If
            Else
                If RS128.RecordCount = 0 Then
                    Exit Sub
                End If
            End If
            If FM.txtKonto.Text <> vbNullString Then RS128.Fields("IDK").Value = CLng(Val(FM.txtKonto.Text))
            If FM.txtBezei.Text <> vbNullString Then RS128.Fields("IDKurz").Value = RTrim$(Left$(FM.txtBezei.Text, 50))
            If FM.cmbBuTex.Text <> vbNullString Then RS128.Fields("Buchtext").Value = RTrim$(Left$(FM.cmbBuTex.Text, 50))
            RS128.Fields("IDA").Value = FM.cmbBuTyp.ItemData(FM.cmbBuTyp.ListIndex)
            RS128.Fields("IDB").Value = FM.cmbGegen.ItemData(FM.cmbGegen.ListIndex)
            RS128.Fields("IDR").Value = KntRm
            If CmKto.ListIndex >= 0 Then
                StuZa = CmKto.ItemData(CmKto.ListIndex)
                For AktZa = 1 To UBound(GlStu)
                    If GlStu(AktZa, 0) = StuZa Then
                        ReStu = CDec(GlStu(AktZa, 1))
                        If ReStu > 0 And ReStu < 1 Then
                            ReStu = ReStu * 100
                        End If
                        RS128.Fields("Steuer").Value = ReStu
                        Exit For
                    End If
                Next AktZa
            End If
            If FM.chkGewEr.Value = 1 Then
                RS128.Fields("Selekt").Value = -1
            Else
                RS128.Fields("Selekt").Value = 0
            End If
            If FM.chkGldKo.Value = 1 Then
                RS128.Fields("Geldkonto").Value = -1
            Else
                RS128.Fields("Geldkonto").Value = 0
            End If
            If FM.chkSteKo.Value = 1 Then
                RS128.Fields("Steuerkonto").Value = -1
            Else
                RS128.Fields("Steuerkonto").Value = 0
            End If
            RS128.Update
            RS128.Close
            Set RS128 = Nothing
            
            If KnTyp = 5 Then
                If GlJet = True Then SDBSav
    
                If NeuDa = True Then
                    S_KtLa
                Else
                    If SuStr = vbNullString Then
                        S_KtLa RowNr
                    Else
                        S_KtFi SuStr, RowNr
                    End If
                End If
                S_KtPo
            Else
                S_KtTy RowNr
            End If
            
            DoEvents
            S_Ary2
        End If
    Else
        Mld1 = "Sie müssen erst eine gültige Kontonummer eingeben"
        Tit1 = "Keine Kontonummer"
        WindowMess Mld1, Dial3, Tit1, FM.hwnd
    End If
End If

Set CmBrs = Nothing
Set RpSel = Nothing
Set RpRow = Nothing
Set RpRws = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCon = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KtSa " & Err.Number
Resume Next

End Sub
