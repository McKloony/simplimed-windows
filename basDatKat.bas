Public Sub K_AnSu()
On Error GoTo LiErr
'Durchsucht das Diagnosefeld

Dim DatNr As Long
Dim AnzLe As Long
Dim ReNum As Long
Dim AnDia As Long
Dim DiGrp As Long
Dim IdStr As String
Dim SuStr As String
Dim ReDia As Integer
Dim Mld1, Tit1 As String
Dim CmBrs As XtremeCommandBars.CommandBars
Dim RpCo7 As XtremeReportControl.ReportControl
Dim RpCo3 As XtremeReportControl.ReportControl
