Public Function S_Wega(ByVal IdxNr As Long) As String
On Error GoTo LiErr
'Exporiert die Adressen

Dim TmpSt As String
Dim AnzAd As Integer

If IdxNr > 0 Then
    DBCmEx0 "qryAdrMark"
    DBCmEx2 "qryAdrKo4", "@IdDru", "@IdxNr", -1, IdxNr
    DoEvents
    
    Set RS122 = New ADODB.Recordset
    With RS122
        .CursorLocation = adUseClient
        .Source = "qrySimAdDru"
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdTableDirect
    End With
    AnzAd = RS122.RecordCount

    If AnzAd > 0 Then
        Set RS126 = New ADODB.Recordset 'Felderdefinition
        RS126.CursorLocation = adUseClient

        RS126.Fields.Append "ID0", adInteger
        RS126.Fields.Append "TreKey", adVariant
        RS126.Fields.Append "Firma1", adVariant
        RS126.Fields.Append "Anrede", adVariant
        RS126.Fields.Append "Titel", adVariant
        RS126.Fields.Append "Name", adVariant
        RS126.Fields.Append "Vorname", adVariant
        RS126.Fields.Append "Straße", adVariant
        RS126.Fields.Append "PLZ", adVariant
        RS126.Fields.Append "Ort", adVariant
        RS126.Fields.Append "Land", adVariant
        RS126.Fields.Append "Telefon1", adVariant
        RS126.Fields.Append "Telefon2", adVariant
        RS126.Fields.Append "Telefon3", adVariant
        RS126.Fields.Append "Geschlecht", adVariant
        RS126.Fields.Append "Geboren", adVariant
        RS126.Fields.Append "Größe", adVariant
        RS126.Fields.Append "Gewicht", adVariant
        RS126.Fields.Append "Bemerkung", adVariant
        
        If RS126.State = adStateClosed Then RS126.Open

        If RS126.Supports(adAddNew) Then 'Adressen
            Do
            RS126.AddNew
            For Each FL101 In RS126.Fields
                If FL101.Type <> adBinary Then
                    If RS122.Fields(FL101.Name).Value <> vbNullString Then
                        RS126.Fields(FL101.Name).Value = RS122.Fields(FL101.Name).Value
                    End If
                End If
            Next FL101
            RS122.MoveNext
            Loop Until RS122.EOF
            RS126.Update
        End If
        
        DBCmEx0 "qryAdrMark"
        
        If RS126.RecordCount > 0 Then
            For Each FL101 In RS126.Fields
                If TmpSt = vbNullString Then
                    TmpSt = Chr$(34) & FL101.Name & Chr$(34) & Chr$(59)
                Else
                    TmpSt = TmpSt & Chr$(34) & FL101.Name & Chr$(34) & Chr$(59)
                End If
            Next FL101
            TmpSt = TmpSt & vbCrLf
            RS126.MoveFirst
            Do
            For Each FL101 In RS126.Fields
                TmpSt = TmpSt & Chr$(34) & FL101.Value & Chr$(34) & Chr$(59)
            Next FL101
            TmpSt = TmpSt & vbCrLf
            RS126.MoveNext
            Loop Until RS126.EOF
            DoEvents
            S_Wega = TmpSt
        End If
        RS126.Close
        Set RS126 = Nothing
    End If
    
    RS122.Close
    Set RS122 = Nothing
End If

Exit Function

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_Wega " & Err.Number
Resume Next

End Function
