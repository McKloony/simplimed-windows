Set FM = frmMain
Set TrLi2 = FM.trvList2
Set RpCo8 = FM.repCont8
Set CoDia = FM.comDialo
Set RpCls = RpCo8.Columns
Set RpRws = RpCo8.Rows

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

Const BlGro = 100

ZeiUm = CBool(IniGetVal("System", "PADZei"))
Umlau = CBool(IniGetVal("System", "PADUml"))
KatNr = Mid$(GlNod, 2, Len(GlNod) - 1)
KeySt = Left$(GlNod, 1)

If GlMaV = True Then 'Mandanten vorhanden
    AnIKN = GlMan(GlSMa, 7)
Else
    AnIKN = GlThe(1, 15)
End If

If AnIKN = vbNullString Then
    AnIKN = GlPhk
End If

If ImTyp = 1 Then 'Exportieren
    If TrLi2.SelectedItem.Text <> vbNullString Then
        DaNam = SUmw(TrLi2.SelectedItem.Text, True, True, True, True) & ".txt"
    Else
        DaNam = "Fragebogen"
    End If

    With CoDia
        .CancelError = True
        .DialogStyle = 1
        .DefaultExt = "*.txt"
        .DialogTitle = "Bitte Name und Ordner der Exportdatei angeben"
        .FileName = GlEPf & DaNam
        .Filter = "Acsii Textdatei (*.txt)|*.txt|Alle Dateien (*.*)|*.*"
        .InitDir = GlEPf
        .ShowSave
        FiNam = .FileName
        If .FileTitle = vbNullString Then
            Set CoDia = Nothing
            Set RpCol = Nothing
            Set RpCls = Nothing
            Set RpCo8 = Nothing
            Set clFil = Nothing
            Exit Sub
        End If
    End With
    If Right$(FiNam, 4) <> ".txt" Then
        FiNam = FiNam & ".txt"
    End If
    
    With clFil
        .FilPfa FiNam
        If .FilVor(FiNam) = True Then
            .DaLoe = FiNam & vbNullChar
            .FilLoe
        End If
    End With

    Set RS135 = New ADODB.Recordset
    RS135.CursorLocation = adUseClient
    Select Case KeySt
    Case "A": Set RS135 = DBCmRe1("qryKat01D", "@IdxNr", KatNr) 'Gebührenkataloge
    Case "C": Set RS135 = DBCmRe1("qryKat03Q", "@IdxNr", KatNr) 'Diagnosekataloge
    Case "D": Set RS135 = DBCmRe1("qryKat01H", "@IdxNr", KatNr) 'Gebührenketten
    Case "F": Set RS135 = DBCmRe1("qryKat03H", "@IdxNr", KatNr) 'Diagnoseketten
    Case "G": Set RS135 = DBCmRe1("qryKat02D", "@IdxNr", KatNr) 'Laborparameter
    Case "H": Set RS135 = DBCmRe1("qryKat02H", "@IdxNr", KatNr) 'Laborketten
    Case "I": Set RS135 = DBCmRe1("qryKat04G", "@IdxNr", KatNr) 'Arzneimittel
    Case "J": Set RS135 = DBCmRe1("qryKat04H", "@IdxNr", KatNr) 'Arzneiketten
    Case "K": Set RS135 = DBCmRe1("qryKat02D", "@IdxNr", KatNr) 'Begründungen
    Case "L": Set RS135 = DBCmRe1("qryKat02D", "@IdxNr", KatNr) 'Anamnesetexte
    Case "M": Set RS135 = DBCmRe0("qryKon01E")                  'Terminbetreffs
    Case "N": Set RS135 = DBCmRe1("qryKat08I", "@IdxNr", KatNr) 'Fragebogen
    Case "O": Set RS135 = DBCmRe1("qryKat04H", "@IdxNr", KatNr) 'Textphrasen
    Case "P": Set RS135 = DBCmRe1("qryKat12G", "@IdxNr", KatNr) 'Artikelkatalog
    Case "R": Set RS135 = DBCmRe0("qryKon02A")                  'Terminketten
    Case "Q": Set RS135 = DBCmRe1("qryKat12H", "@IdxNr", KatNr) 'Artikelketten
    End Select
    GesZa = RS135.RecordCount

    If GesZa > 0 Then
        frmStatus.Show
        DoEvents
        frmStatus.Caption = "Katalogexport"
        Set PrBr1 = frmStatus.prbStat1
        Set PrBr2 = frmStatus.prbStat2
        Set TxDum = frmStatus.txtDummy
    
        KaAry = RS135.GetRows 'Zuweisen der Einträge
        DoEvents

        For Each FL101 In RS135.Fields 'Überschriften
            If TmStr = vbNullString Then
                TmStr = FL101.Name & Chr$(59)
            Else
                TmStr = TmStr & FL101.Name & Chr$(59)
            End If
        Next FL101
        If ZeiUm = True Then
            TmStr = TmStr & vbCrLf
        Else
            TmStr = TmStr & "|"
        End If

        KaGes = UBound(KaAry, 2)
        KaSpa = UBound(KaAry, 1)

        If KaGes > BlGro Then
            BloZa = Fix(KaGes / BlGro) + 1
            ReDim TmAry(BloZa)
            AktZa = 0
            PrBr1.Min = 0
            PrBr1.Max = BlGro
            PrBr2.Min = 0
            PrBr2.Max = BloZa + 1

            For AkBlo = 0 To BloZa
                ParNr = KaAry(0, AkBlo)
                PrBr2.Value = AkBlo + 1
                For AkZei = 0 To BlGro 'Zeilen
                    For AkSpa = 0 To KaSpa 'Spalten
                        If AktZa <= KaGes Then
                            If AkSpa = 9 Then
                                KaAry(AkSpa, AkZei) = vbNullString
                            End If
                            If KaAry(AkSpa, AktZa) <> vbNullString Then
                                If Len(KaAry(AkSpa, AktZa)) > 250 Then
                                    TmAry(AkBlo) = TmAry(AkBlo) & SUmw(Left$(KaAry(AkSpa, AktZa), 250), False, Umlau) & Chr$(59)
                                Else
                                    TmAry(AkBlo) = TmAry(AkBlo) & SUmw(KaAry(AkSpa, AktZa), False, Umlau) & Chr$(59)
                                End If
                            Else
                                TmAry(AkBlo) = TmAry(AkBlo) & Space$(1) & Chr$(59)
                            End If
                        End If
                    Next AkSpa
                    AktZa = AktZa + 1
                    If ZeiUm = True Then
                        TmAry(AkBlo) = TmAry(AkBlo) & vbCrLf
                    Else
                        If TmAry(AkBlo) <> vbNullString Then
                            If Right$(TmAry(AkBlo), 2) <> "||" Then
                                TmAry(AkBlo) = TmAry(AkBlo) & "|"
                            End If
                        End If
                    End If
                    DoEvents
                    If TxDum.Text = "B" Then Exit For 'Abbrechen
                    PrBr1.Value = AkZei
                Next AkZei
                If TmStr = vbNullString Then
                    TmStr = TmAry(AkBlo)
                Else
                    TmStr = TmStr & TmAry(AkBlo)
                End If
            Next AkBlo
        Else
            PrBr1.Min = 0
            PrBr1.Max = KaGes
