Case "J": 'Arzneiketten
    Select Case GlSuN.SuIdx
    Case 0: Set RS153 = DBCmRe1("qryKat04H", "@IdxNr", IdxNr)
    Case 1: Set RS153 = DBCmRe0("SELECT * FROM qryKat04B WHERE [ID3]=" & IdxNr & " AND [IDKurz] Like '%" & GlSuN.SuStr & "%'", True)
    Case 2: Set RS153 = DBCmRe0("SELECT * FROM qryKat04B WHERE [ID3]=" & IdxNr & " AND [GOID] Like '" & GlSuN.SuStr & "%'", True)
    Case 3: Set RS153 = DBCmRe0("SELECT * FROM qryKat04B WHERE [ID3]=" & IdxNr & " AND [Preis1]" & GlSuN.SUpRe & GlSuN.SuStr, True)
    Case 4: Set RS153 = DBCmRe0("SELECT * FROM qryKat04B WHERE [ID3]=" & IdxNr & " AND [IDKurz] Like '" & GlSuN.SuStr & "%'", True)
    Case 5: Set RS153 = DBCmRe1("qryKat04I", "@IdxNr", IdxNr)
    End Select
Case "H": 'Laborketten
    Select Case GlSuN.SuIdx
    Case 0: Set RS153 = DBCmRe1("qryKat02H", "@IdxNr", IdxNr)
    Case 1: Set RS153 = DBCmRe0("SELECT * FROM qryKat02B WHERE [ID3]=" & IdxNr & " AND [IDKurz] Like '%" & GlSuN.SuStr & "%'", True)
    Case 2: Set RS153 = DBCmRe0("SELECT * FROM qryKat02B WHERE [ID3]=" & IdxNr & " AND [GOID] Like '" & GlSuN.SuStr & "%'", True)
    Case 3: Set RS153 = DBCmRe0("SELECT * FROM qryKat02B WHERE [ID3]=" & IdxNr & " AND [Preis1]" & GlSuN.SUpRe & GlSuN.SuStr, True)
    Case 4: Set RS153 = DBCmRe0("SELECT * FROM qryKat02B WHERE [ID3]=" & IdxNr & " AND [IDKurz] Like '" & GlSuN.SuStr & "%'", True)
    Case 5: Set RS153 = DBCmRe1("qryKat02I", "@IdxNr", IdxNr)
    End Select
Case "M": 'Terminbetreffs
    Select Case GlSuE.SuIdx
    Case 0: Set RS153 = DBCmRe0("qryKon01E")
    Case 1: Set RS153 = DBCmRe1("qryKon01B", "@IdStr", "%" & GlSuE.SuStr & "%")
    Case 2: Set RS153 = DBCmRe1("qryKon01C", "@IdMin", GlSuE.SuStr) 'Zeit
    Case 3: Set RS153 = DBCmRe1("qryKon01C", "@IdMin", GlSuE.SuStr) 'Zeit
    Case 4: Set RS153 = DBCmRe1("qryKon01B", "@IdStr", GlSuE.SuStr & "%")
    Case 5: Set RS153 = DBCmRe1("qryKon01C", "@IdMin", 0) 'Zeit
    End Select
Case "N": 'Fragebogen
    If GlTyp < 2 Then
        SQL1 = "SELECT * FROM dbo.qryKat08 ORDER BY IDKurz"
    Else
        SQL1 = "SELECT * FROM qryKat08 ORDER BY [IDKurz];"
    End If
    Select Case GlSuG.SuIdx
    Case 0: Set RS153 = DBCmRe1("qryKat08I", "@IdxNr", IdxNr)
    Case 1: Set RS153 = DBCmRe2("qryKat08E", "@IdxNr", "@IdStr", IdxNr, "%" & GlSuG.SuStr & "%")
    Case 2: Set RS153 = DBCmRe2("qryKat08E", "@IdxNr", "@IdStr", IdxNr, GlSuG.SuStr & "%")
    Case 4: Set RS153 = DBCmRe2("qryKat08E", "@IdxNr", "@IdStr", IdxNr, GlSuG.SuStr & "%")
    Case 5: Set RS153 = DBCmRe0(SQL1, True)
    End Select
Case "O": 'Textphrasen
    Select Case GlSuE.SuIdx
    Case 0: Set RS153 = DBCmRe1("qryKat04G", "@IdxNr", IdxNr)
    Case 1: Set RS153 = DBCmRe2("qryKat04N", "@IdxNr", "@IdStr", IdxNr, "%" & GlSuE.SuStr & "%")
    Case 2: Set RS153 = DBCmRe2("qryKat04M", "@IdxNr", "@IdStr", IdxNr, GlSuE.SuStr & "%")
    Case 3: Set RS153 = DBCmRe2("qryKat04P", "@IdxNr", "@IdStr", IdxNr, GlSuE.SUpRe & GlSuE.SuStr)
    Case 4: Set RS153 = DBCmRe2("qryKat04N", "@IdxNr", "@IdStr", IdxNr, GlSuE.SuStr & "%")
    Case 5: Set RS153 = DBCmRe1("qryKat04F", "@IdxNr", IdxNr)
    End Select
Case "P": 'Artikelliste
    Select Case GlSuE.SuIdx
    Case 0: Set RS153 = DBCmRe1("qryKat12G", "@IdxNr", IdxNr)
    Case 1: Set RS153 = DBCmRe2("qryKat12N", "@IdxNr", "@IdStr", IdxNr, "%" & GlSuE.SuStr & "%")
    Case 2: Set RS153 = DBCmRe2("qryKat12M", "@IdxNr", "@IdStr", IdxNr, GlSuE.SuStr & "%")
    Case 3: Set RS153 = DBCmRe2("qryKat12P", "@IdxNr", "@IdStr", IdxNr, GlSuE.SUpRe & GlSuE.SuStr)
    Case 4: Set RS153 = DBCmRe2("qryKat12N", "@IdxNr", "@IdStr", IdxNr, GlSuE.SuStr & "%")
    Case 5: Set RS153 = DBCmRe1("qryKat12F", "@IdxNr", IdxNr)
    End Select
Case "R": 'Terminketten
    Select Case GlSuN.SuIdx
    Case 0: Set RS153 = DBCmRe0("qryKon02A")
    Case 1: Set RS153 = DBCmRe1("qryKon02T", "@IdStr", "%" & GlSuN.SuStr & "%")
    Case 2: Set RS153 = DBCmRe1("qryKon02B", "@IdStr", GlSuN.SuStr & "%")
    Case 3: Set RS153 = DBCmRe1("qryKon02T", "@IdStr", GlSuN.SuStr & "%")
    Case 4: Set RS153 = DBCmRe1("qryKon02T", "@IdStr", GlSuN.SuStr & "%")
    Case 5: Set RS153 = DBCmRe0("qryKon02A")
    End Select
Case "Q": 'Artikelketten
    Select Case GlSuN.SuIdx
    Case 0: Set RS153 = DBCmRe1("qryKat12H", "@IdxNr", IdxNr)
    Case 1: Set RS153 = DBCmRe0("SELECT * FROM qryKat12B WHERE [ID3] = " & IdxNr & " AND [IDKurz] Like '%" & GlSuN.SuStr & "%'", True)
    Case 2: Set RS153 = DBCmRe0("SELECT * FROM qryKat12B WHERE [ID3] = " & IdxNr & " AND [GOID] Like '" & GlSuN.SuStr & "%'", True)
    Case 3: Set RS153 = DBCmRe0("SELECT * FROM qryKat12B WHERE [ID3] = " & IdxNr & " AND [Preis1]" & GlSuN.SUpRe & GlSuN.SuStr, True)
    Case 4: Set RS153 = DBCmRe0("SELECT * FROM qryKat12B WHERE [ID3] = " & IdxNr & " AND [IDKurz] Like '" & GlSuN.SuStr & "%'", True)
    Case 5: Set RS153 = DBCmRe1("qryKat12I", "@IdxNr", IdxNr)
    End Select
End Select

GesZa = RS153.RecordCount

If GesZa > 0 Then
    K_Rec RS153, TreKy, KetMe, GrVor
End If

RS153.Close
Set RS153 = Nothing

With RpCo8
    If KetMe = False Then
        If GlGrG = True Then 'Gruppierung Kataloge
            If GrVor = True Then
                .SortOrder.Add .Columns(Kat_Gruppe)
                .GroupsOrder.Add .Columns(Kat_Gruppe)
                .GroupsOrder(0).SortAscending = True
            End If
        End If
    End If
End With

If GesZa > 0 Then
    RpCo8.Populate
    DoEvents
    Set RpRws = RpCo8.Rows
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            Set RpGrw = RpRow
            Set ChRws = RpGrw.Childs
            GrAnz = ChRws.Count
            For Each ChRow In ChRws
                If IsNumeric(ChRow.Record.Item(Kat_Preis1).Value) Then
                    GrPre = GrPre + ChRow.Record.Item(Kat_Preis1).Value
                End If
            Next ChRow
        End If
        GrPre = 0
    Next RpRow
End If

SMark

Set RpRws = Nothing
Set RpCo8 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_LiSu " & Err.Number
Resume Next

End Sub

Public Sub K_Loe()
On Error GoTo OrErr
'Löscht die selektierten Einträge

Dim RowNr As Long
Dim AnzPo As Long
Dim IdxNr As Long
Dim KeySt As String
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCo8 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo8 = FM.repCont8
Set RpCls = RpCo8.Columns
Set RpSel = RpCo8.SelectedRows

KeySt = Left$(GlNod, 1)
Tit1 = "Einträge entfernen"
AnzPo = RpSel.Count
If AnzPo > 1 Then
    Mld1 = "Möchten Sie die " & AnzPo & " markierten Einträge wirklich entfernen?"
Else
    Mld1 = "Möchten Sie den aktuellen Eintrag wirklich entfernen?"
End If

If GlRch(0, 19) = 0 Then
    WindowMess "Sie besitzen keine Berechtigung für diesen Vorgang", Dial3, Tit1, FM.hwnd
    Exit Sub
End If

If AnzPo > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then

        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                Set RpCol = RpCls.Find(Kat_ID0)
                IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                Select Case KeySt
                Case "A": DBCmEx1 "qryKat01L", "@IdxNr", IdxNr 'Gebührenkatalog
                Case "C": DBCmEx1 "qryKat03L", "@IdxNr", IdxNr 'Diagnosekatalog
                Case "D": DBCmEx1 "qryKat01K", "@IdxNr", IdxNr 'Gebührenketten
                Case "F": DBCmEx1 "qryKat03K", "@IdxNr", IdxNr 'Diagnoseketten
                Case "G": DBCmEx1 "qryKat02L", "@IdxNr", IdxNr 'Laborparameter
                Case "H": DBCmEx1 "qryKat02K", "@IdxNr", IdxNr 'Laborprofile
                Case "I": DBCmEx1 "qryKat04L", "@IdxNr", IdxNr 'Arzneikatalog
                Case "J": DBCmEx1 "qryKat04K", "@IdxNr", IdxNr 'Arzneiketten
                Case "K": DBCmEx1 "qryKat02L", "@IdxNr", IdxNr 'Begründungen
                Case "L": DBCmEx1 "qryKat02L", "@IdxNr", IdxNr 'Anamnesetexte
                Case "M": DBCmEx1 "qryKon01L", "@IdxNr", IdxNr 'Terminbetreffs
                Case "N": DBCmEx1 "qryKat08L", "@IdxNr", IdxNr 'Fragebogen
                Case "O": DBCmEx1 "qryKat04L", "@IdxNr", IdxNr 'Textphrasen
                Case "P": DBCmEx1 "qryKat12L", "@IdxNr", IdxNr 'Artikelkatalog
                Case "R": DBCmEx1 "qryKon02L", "@IdxNr", IdxNr 'Terminketten
                Case "Q": DBCmEx1 "qryKat12K", "@IdxNr", IdxNr 'Artikelketten
                End Select
            End If
        Next RpRow

        DoEvents
        GlNeK = GlKoX 'Protokolleintrag
        With GlNeK
            .PatNr = GlMan(GlSMa, 2)
            .IdxNr = 0
            .EiDat = Format$(Date, "dd.mm.yyyy")
            .EiZei = TimeValue(Now)
            .EiTyp = 104
            Select Case KeySt
            Case "A": .TeStr = "Gebühreneintrag gelöscht"
            Case "C": .TeStr = "Diagnoseeintrag gelöscht"
            Case "D": .TeStr = "Gebühreneintrag gelöscht"
            Case "F": .TeStr = "Diagnoseeintrag gelöscht"
            Case "G": .TeStr = "Laboreintrag gelöscht"
            Case "H": .TeStr = "Laboreintrag gelöscht"
            Case "I": .TeStr = "Arzneimitteleintrag gelöscht"
            Case "J": .TeStr = "Arzneimitteleintrag gelöscht"
            Case "K": .TeStr = "Begründungseintrag gelöscht"
            Case "L": .TeStr = "Anamneseeintrag gelöscht"
            Case "M": .TeStr = "Termineintrag gelöscht"
            Case "N": .TeStr = "Fragebogeneintrag gelöscht"
            Case "O": .TeStr = "Textphraseneintrag gelöscht"
            Case "P": .TeStr = "Artikeleintrag gelöscht"
            Case "Q": .TeStr = "Artikeleintrag gelöscht"
            End Select
            .ZiStr = Format$(Now, "hh:mm") & " Uhr"
            .NeuEi = True
            .KeiAk = True
            .Mitar = GlMiA(GlSmI, 2)
        End With
        S_Prot

        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            RowNr = RpRow.Index
            KUpKa RowNr
        End If
    End If
End If

Set RpSel = Nothing
Set RpRow = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo8 = Nothing

Exit Sub

OrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_Loe " & Err.Number
Resume Next

End Sub
Private Sub K_Rec(ByRef RST As ADODB.Recordset, ByVal TreKy As String, Optional ByVal KetMe As Boolean = False, Optional ByVal GrVor As Boolean = False)
On Error GoTo LiErr
'Füllt die Tabelle mit Daten

Dim FaRGB As tRGB
Dim EkPre As String
Dim VKPre As String
Dim Multi As Single
Dim FakPr As Boolean
Dim CmBrs As XtremeCommandBars.CommandBars
Dim RpCo8 As XtremeReportControl.ReportControl

Set FM = frmMain
Set RpCo8 = FM.repCont8
Set CmBrs = FM.comBar01
Set RpRcs = RpCo8.Records
Set CmSta = CmBrs.StatusBar

Do
If KetMe = True Then
    Set RpRec = RpRcs.Add()
    Set RpItm = RpRec.AddItem(RST.Fields("ID1").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("GOID").Value)
    RpItm.Icon = IC16_Link_Norm
    Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
    Set RpItm = RpRec.AddItem(0) 'Gruppe
    If TreKy = "F" Then 'Diagnoseketten
        Set RpItm = RpRec.AddItem(0)
    ElseIf TreKy = "R" Then 'Terminketten
        Set RpItm = RpRec.AddItem(Format$(RST.Fields("Zeit").Value, "000") & " Min")
        RpItm.Alignment = xtpAlignmentCenter
    Else
        VKPre = Format$(RST.Fields("Preis").Value, GlWa1)
        Set RpItm = RpRec.AddItem(VKPre)
    End If
    Set RpItm = RpRec.AddItem(0)
Else
    If TreKy = "M" Then 'Terminbetreffs
        If RST.Fields("Farbe").Value > 0 Then
            FaRGB = WindowRGB(RST.Fields("Farbe").Value)
        End If
        Set RpRec = RpRcs.Add()
        Set RpItm = RpRec.AddItem(RST.Fields("ID4").Value)
        Set RpItm = RpRec.AddItem(vbNullString)
        Set RpItm = RpRec.AddItem(RST.Fields("Betreff").Value)
        RpItm.Icon = IC16_Doc_Time
        Set RpItm = RpRec.AddItem(vbNullString)
        Set RpItm = RpRec.AddItem(Format$(RST.Fields("Zeit").Value, "000") & " Min")
        RpItm.Alignment = xtpAlignmentCenter
        Set RpItm = RpRec.AddItem(vbNullString)
        If RST.Fields("Farbe").Value > 0 Then
            RpItm.BackColor = RGB(FaRGB.rot, FaRGB.grün, FaRGB.blau)
        End If
        If RST.Fields("Kommentar").Value <> vbNullString Then
            RpRec.PreviewText = RST.Fields("Kommentar").Value
        End If
    ElseIf TreKy = "N" Then 'Fragebogen
        If RST.Fields("IDSub").Value = 0 Then 'keine Unterfragen
            Set RpRec = RpRcs.Add()
            Set RpItm = RpRec.AddItem(RST.Fields("ID6").Value)
            Set RpItm = RpRec.AddItem(vbNullString)
            Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
            If CBool(RST.Fields("Pflicht").Value) = True Then
                RpItm.Icon = IC16_Doc_Check
            Else
                RpItm.Icon = IC16_Doc_Norm
            End If
            If GrVor = True Then
                If IsNull(RST.Fields("Gruppe").Value) = True Then
                    Set RpItm = RpRec.AddItem("<<< keine Gruppe >>>")
                ElseIf (RST.Fields("Gruppe").Value) = vbNullString Then
                    Set RpItm = RpRec.AddItem("<<< keine Gruppe >>>")
                Else
                    Set RpItm = RpRec.AddItem(RST.Fields("Gruppe").Value)
                End If
            Else
                Set RpItm = RpRec.AddItem(vbNullString)
            End If
            If Len(RST.Fields("Type").Value) <> vbNullString Then
                Set RpItm = RpRec.AddItem(GlFrT(RST.Fields("Type").Value))
            Else
                Set RpItm = RpRec.AddItem(0)
            End If
            Set RpItm = RpRec.AddItem(RST.Fields("Sorter").Value)
            If RST.Fields("Kommentar").Value <> vbNullString Then
                RpRec.PreviewText = RST.Fields("Kommentar").Value
            End If
        End If
    Else
        Set RpRec = RpRcs.Add()
        Set RpItm = RpRec.AddItem(RST.Fields("ID0").Value)
        
        Select Case TreKy
        Case "K": 'Begründungen
            Set RpItm = RpRec.AddItem(RST.Fields("GOIK").Value)
            RpItm.Icon = IC16_Doc_Norm
            Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
        Case Else:
            Set RpItm = RpRec.AddItem(RST.Fields("GOID").Value)
            RpItm.Icon = IC16_Doc_Norm
            Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
        End Select
        If GrVor = True Then
            If Len(RST.Fields("Gruppe").Value) > 0 Then
                Set RpItm = RpRec.AddItem(RST.Fields("Gruppe").Value)
            Else
                Set RpItm = RpRec.AddItem(vbNullString)
            End If
        Else
            Set RpItm = RpRec.AddItem(vbNullString)
        End If
        Select Case TreKy
        Case "C": 'Diagnosen
            Set RpItm = RpRec.AddItem(0)
        Case "M": 'Terminbetreffs
            Set RpItm = RpRec.AddItem(RST.Fields("Zeit").Value)
        Case "L": 'Anamnese
            Set RpItm = RpRec.AddItem(0)
        Case Else:
            FakPr = False
            If IsNull(RST.Fields("Einheit").Value) = False Then
                If RST.Fields("Einheit").Value <> vbNullString Then
                    If RST.Fields("Einheit").Value = "1" Then
                        FakPr = True
                    End If
                End If
            End If
            If IsNull(RST.Fields("Multi").Value) = False Then
                If RST.Fields("Multi").Value > 0 Then
                    Multi = RST.Fields("Multi").Value
                Else
                    Multi = 1
                End If
            Else
                Multi = 1
            End If
            If FakPr = True Then
                Set RpItm = RpRec.AddItem(Format$(RST.Fields("Preis2").Value, GlWa1))
            Else
                Set RpItm = RpRec.AddItem(Format$(WinRound(RST.Fields("Preis1").Value * Multi, 2), GlWa1))
            End If
        End Select
        Select Case TreKy
        Case "G": 'Laborparameter
            Set RpItm = RpRec.AddItem(RST.Fields("GOIK").Value)
        Case "I": 'Arzneikatalog
            EkPre = RST.Fields("Preis3").Value
            Set RpItm = RpRec.AddItem(Format$(EkPre, GlWa1))
        Case "P": 'Artikelkatalog
            If RST.Fields("Bestand_Soll").Value <> vbNullString Then
                EkPre = RST.Fields("Bestand_Soll").Value
            Else
                EkPre = 0
            End If
            Set RpItm = RpRec.AddItem(Format$(EkPre, GlWa1))
        Case Else:
            Set RpItm = RpRec.AddItem(0)
        End Select
        RpItm.Alignment = xtpAlignmentRight
        If TreKy = "A" Then 'Gebühren
            Set RpItm = RpRec.AddItem(RST.Fields("IDT").Value)
        End If
        If RST.Fields("Kommentar").Value <> vbNullString Then
            RpRec.PreviewText = RST.Fields("Kommentar").Value
        End If
    End If
End If
RST.MoveNext
Loop Until RST.EOF

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCo8 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_Rec " & Err.Number
Resume Next

End Sub
Private Sub K_RecF(ByVal PaRec As XtremeReportControl.ReportRecord, ByVal SubNr As Long, Optional ByVal GrVor As Boolean = False)
On Error GoTo LiErr
'Füllt die Tabelle mit Daten

Dim CmBrs As XtremeCommandBars.CommandBars
Dim RpCo8 As XtremeReportControl.ReportControl

Set FM = frmMain
Set RpCo8 = FM.repCont8
Set CmBrs = FM.comBar01
Set RpRcs = RpCo8.Records
Set CmSta = CmBrs.StatusBar

Set RS154 = New ADODB.Recordset
RS154.CursorLocation = adUseClient
Set RS154 = DBCmRe1("qryKat08J", "@IdxNr", SubNr)
If RS154.RecordCount > 0 Then
    Do
    Set RpRec = PaRec.Childs.Add()
    Set RpItm = RpRec.AddItem(RS154.Fields("ID6").Value)
    Set RpItm = RpRec.AddItem(vbNullString)
    Set RpItm = RpRec.AddItem(RS154.Fields("IDKurz").Value)
    RpItm.Icon = IC16_Doc_Norm
    If GrVor = True Then
        If Len(RS154.Fields("Gruppe").Value) > 0 Then
            Set RpItm = RpRec.AddItem(RS154.Fields("Gruppe").Value)
        Else
            Set RpItm = RpRec.AddItem(vbNullString)
        End If
    Else
        Set RpItm = RpRec.AddItem(vbNullString)
    End If
    If Len(RS154.Fields("Type").Value) <> vbNullString Then
        Set RpItm = RpRec.AddItem(GlFrT(RS154.Fields("Type").Value))
    Else
        Set RpItm = RpRec.AddItem(0)
    End If
    Set RpItm = RpRec.AddItem(RS154.Fields("Sorter").Value)
    If RS154.Fields("Kommentar").Value <> vbNullString Then
        RpRec.PreviewText = RS154.Fields("Kommentar").Value
    End If
    RS154.MoveNext
    Loop Until RS154.EOF
End If
RS154.Close
Set RS154 = Nothing

PaRec.Expanded = True

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCo8 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_RecF " & Err.Number
Resume Next

End Sub
Public Function K_ReNe(ByVal ReStr As String, ByVal FDatu As Date, ByVal PatNr As Long, Optional ByVal MasTe As Long, Optional ByVal ReTyp As String, Optional ByVal ManNr As Long = 0, Optional ByVal MitNr As Long = 0, Optional ByVal AuDia As Boolean = False, Optional ByVal ReDia As Boolean = True, Optional ByVal KrDia As Boolean = False, Optional ByVal ArzNr As Long) As Long
On Error GoTo SuErr
'Legt eine neue Rechnung an

Dim RetWe As Long
Dim LetRe As Long
Dim NeuRe As Long
Dim StMit As Long
Dim DiGrp As Long
Dim DiRef As Long
Dim LetDa As Date
Dim DiDat As Date
Dim RecSt As String
Dim LeReD As String 'manuelle Rechnungsdiagnose
Dim KraDi As String
Dim CoStr As String
Dim KuStr As String
Dim GuiID As String
Dim ReStu As Single
Dim PaDia As Variant 'Patientendiagnose
Dim AktZa As Integer
Dim Posit As Integer
Dim DiaEi As Boolean
    
Set FM = frmMain
Set CmTyp = FM.cmbTypen

If GlTza = True Then 'Testzeit abgelaufen
    SPopu "Lizenzierung erforderlich!", "Es ist keine bzw. keine gültige Seriennummer vorhanden oder die Testzeit ist abgelaufen.", IC48_Forbidden
    Exit Function
End If

StMit = GlMiA(GlSmI, 2)

GuiID = CreateID("R")

Posit = InStrRev(ReStr, "-", -1, 1)
If Posit > 0 Then
    RecSt = Format$(Mid$(ReStr, Posit + 1, Len(ReStr)), "00000000")
Else
    RecSt = ReStr
End If

GlReT = ReTyp 'Standardbelegtyp

Set RS121 = New ADODB.Recordset
RS121.CursorLocation = adUseClient
Set RS121 = DBCmRe1("qrySimRePa", "@IdxNr", PatNr)
If RS121.RecordCount > 0 Then
    If AuDia = True Then
        PaDia = RS121.Fields("Diagnose").Value
    Else
        PaDia = vbNullString
    End If
    
    Set RS122 = New ADODB.Recordset
    RS122.CursorLocation = adUseClient
    Set RS122 = DBCmRe1("qrySimAbReD", "@IdxNr", PatNr)
    If RS122.RecordCount > 0 Then
        LetRe = RS122.Fields("ID1").Value
        If RS122.Fields("Diagnose").Value <> vbNullString Then
            LeReD = RS122.Fields("Diagnose").Value
            LetDa = RS122.Fields("Datum").Value
        Else
            LeReD = vbNullString
            LetDa = Date
        End If
    Else
        LeReD = vbNullString
        LetDa = Date
        LetRe = 0
    End If
    RS122.Close
    Set RS122 = Nothing

    Set RS120 = New ADODB.Recordset
    With RS120
        .CursorLocation = adUseClient
        .Source = "qrySimReTop"
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdTableDirect
    End With

    If RS120.Supports(adAddNew) Then
        RS120.AddNew
        RS120.Fields("ID0").Value = PatNr
        RS120.Fields("RechNr").Value = ReStr
        RS120.Fields("PLZ").Value = RecSt
        RS120.Fields("ID3").Value = RS121.Fields("ID3").Value
        RS120.Fields("IDZ").Value = RS121.Fields("IDZ").Value
        If RS121.Fields("Mahnbar").Value <> vbNullString Then
            RS120.Fields("Mahnbar").Value = RS121.Fields("Mahnbar").Value
        Else
            For AktZa = 1 To UBound(GlZah)
                If GlZah(AktZa, 0) = GlStZ Then 'Standardzahlungsziel
                    RS120.Fields("Mahnbar").Value = GlZah(AktZa, 3)
                    Exit For
                End If
            Next AktZa
        End If
        If RS121.Fields("Ziel").Value <> vbNullString Then
            RS120.Fields("Ziel").Value = RS121.Fields("Ziel").Value
        Else
            For AktZa = 1 To UBound(GlZah)
                If GlZah(AktZa, 0) = GlStZ Then 'Standardzahlungsziel
                    RS120.Fields("Ziel").Value = GlZah(AktZa, 2)
                    Exit For
                End If
            Next AktZa
        End If
        If RS121.Fields("Intervall").Value <> vbNullString Then
            RS120.Fields("Intervall").Value = RS121.Fields("Intervall").Value
        Else
            For AktZa = 1 To UBound(GlZah)
                If GlZah(AktZa, 0) = GlStZ Then 'Standardzahlungsziel
                    RS120.Fields("Intervall").Value = GlZah(AktZa, 4)
                    Exit For
                End If
            Next AktZa
        End If
        RS120.Fields("Datum").Value = FDatu
        
        For AktZa = 1 To UBound(GlStu)
            If GlStu(AktZa, 0) = GlStS Then 'Standardsteuersatz
                ReStu = CSng(GlStu(AktZa, 1))
                If ReStu > 0 And ReStu < 1 Then
                    ReStu = ReStu * 100
                End If
                RS120.Fields("Steuer").Value = ReStu
                Exit For
            End If
        Next AktZa

        If RS121.Fields("Mahnbar").Value = -1 Then
            RS120.Fields("Fallig").Value = FDatu + RS121.Fields("Ziel").Value
        Else
            RS120.Fields("Fallig").Value = FDatu
        End If
        If RS121.Fields("Währung").Value <> vbNullString Then
            If RS121.Fields("Währung").Value > 0 Then
                RS120.Fields("Währung").Value = RS121.Fields("Währung").Value
            Else
                RS120.Fields("Währung").Value = GlWar(GlStW, 0)  'Standardwährung
            End If
        Else
            RS120.Fields("Fallig").Value = GlWar(GlStW, 0)  'Standardwährung
        End If
        RS120.Fields("GesBetrag").Value = 0
        RS120.Fields("WVBetrag").Value = 0
        RS120.Fields("Anzahlung").Value = 0
        RS120.Fields("Offen").Value = 0
        RS120.Fields("Type").Value = ReTyp
        RS120.Fields("Grund").Value = 0 'Behandlungsgrund
        RS120.Fields("Beendet").Value = 0
        RS120.Fields("Versand").Value = RS121.Fields("Versand").Value
        RS120.Fields("Gruppe").Value = 0
        If RS121.Fields("GebTyp").Value <> vbNullString Then
            RS120.Fields("PKU").Value = RS121.Fields("GebTyp").Value
        Else
            Select Case GlStP
            Case 0: RS120.Fields("PKU").Value = "PI"
            Case 1: RS120.Fields("PKU").Value = "PE"
            Case 2: RS120.Fields("PKU").Value = "PA"
            Case 3: RS120.Fields("PKU").Value = "GI"
            Case 4: RS120.Fields("PKU").Value = "GE"
            Case 5: RS120.Fields("PKU").Value = "GA"
            End Select
        End If
        If MasTe > 0 Then
            RS120.Fields("IDT").Value = MasTe
        End If
        If ManNr > 0 Then
            RS120.Fields("IDP").Value = ManNr
        Else
            If RS121.Fields("IDP").Value > 0 Then
                RS120.Fields("IDP").Value = RS121.Fields("IDP").Value
            Else
                RS120.Fields("IDP").Value = 0
            End If
        End If
        If MitNr > 0 Then
            RS120.Fields("IDM").Value = MitNr
        Else
            RS120.Fields("IDM").Value = StMit
        End If
        If ArzNr > 0 Then
            RS120.Fields("IDO").Value = ArzNr
        Else
            RS120.Fields("IDO").Value = 0
        End If
        If RS121.Fields("Kopien").Value = 0 Then
            RS120.Fields("Kopie").Value = 1
        Else
            RS120.Fields("Kopie").Value = RS121.Fields("Kopien").Value
        End If
        RS120.Fields("GuiID").Value = GuiID

        If PaDia <> vbNullString Then
            If ReDia = True Then
                If KraDi <> vbNullString Then
                    RS120.Fields("Diagnose").Value = LeReD & ", " & PaDia & "; " & KraDi
                Else
                    RS120.Fields("Diagnose").Value = LeReD & ", " & PaDia
                End If
            Else
                If KraDi <> vbNullString Then
                    RS120.Fields("Diagnose").Value = PaDia & "; " & KraDi
                Else
                    RS120.Fields("Diagnose").Value = PaDia
                End If
            End If
        Else
            If ReDia = True Then
                If KraDi <> vbNullString Then
                    RS120.Fields("Diagnose").Value = LeReD & ", " & KraDi
                Else
                    RS120.Fields("Diagnose").Value = LeReD
                End If
            Else
                If KraDi <> vbNullString Then
                    RS120.Fields("Diagnose").Value = KraDi
                Else
                    RS120.Fields("Diagnose").Value = vbNullString
                End If
            End If
        End If
        RS120.Update

    End If
    RS120.Close
    Set RS120 = Nothing
End If
RS121.Close
Set RS121 = Nothing

DoEvents
Set RS128 = New ADODB.Recordset
RS128.CursorLocation = adUseClient
Set RS128 = DBCmRe1("qrySimReGui", "@IdStr", GuiID)
If RS128.RecordCount > 0 Then
    NeuRe = RS128.Fields("ID1").Value
Else
    NeuRe = 0
End If
RS128.Close
Set RS128 = Nothing

DoEvents 'Übertrag ID1 Feld in IDR
DBCmEx2 "qrySimReSet", "@IdNum", "@IdxNr", NeuRe, NeuRe
DoEvents

Set RS115 = New ADODB.Recordset 'alle Positionen dieser Rechnung
RS115.CursorLocation = adUseClient
Set RS115 = DBCmRe1("qrySimAbIdx", "@IdxNr", NeuRe)
If RS115.RecordCount > 0 Then
    DBCmEx1 "qrySimAbLoR", "@IdxNr", NeuRe
End If
RS115.Close
Set RS115 = Nothing
DoEvents

If NeuRe > 0 Then
    If LetRe > 0 Then
        If ReDia = True Then 'vorherige Rechnungsdiagnosen ünernehmen
            Set RS125 = New ADODB.Recordset
            RS125.CursorLocation = adUseClient
            If GlDSo = True Then 'Katalogdiagnosen alphabetisch sortieren
                Set RS125 = DBCmRe1("qrySimAbDiag", "@IdxNr", LetRe)
            Else
                Set RS125 = DBCmRe1("qrySimAbDia5", "@IdxNr", LetRe)
            End If
            If RS125.RecordCount > 0 Then
            
            Do
            If RS125.Fields("IDKurz").Value <> vbNullString Then
                CoStr = RS125.Fields("GOID").Value
                KuStr = RS125.Fields("IDKurz").Value
                If RS125.Fields("ID1").Value > 0 Then
                    DiGrp = RS125.Fields("ID1").Value
                Else
                    DiGrp = 0
                End If
                If RS125.Fields("IDS").Value > 0 Then
                    DiRef = RS125.Fields("IDS").Value
                Else
                    DiRef = 0
                End If
                If RS125.Fields("Datum").Value <> vbNullString Then
                    DiDat = RS125.Fields("Datum").Value
                    DBCmEx7 "qrySimAbDiA4", "@PatNr", "@IdxNr", "@IdCod", "@IdStr", "@IdDat", "@IdGrp", "@IdRef", PatNr, NeuRe, CoStr, KuStr, DiDat, DiGrp, DiRef
                Else
                    DBCmEx6 "qrySimAbDiA1", "@PatNr", "@IdxNr", "@IdCod", "@IdStr", PatNr, "@IdGrp", "@IdRef", NeuRe, CoStr, KuStr, DiGrp, DiRef
                End If
            End If
            RS125.MoveNext
            Loop Until RS125.EOF

            End If
            RS125.Close
            Set RS125 = Nothing
        End If
    End If

    If AuDia = True Then 'Aufnahmediagnosen übernehmen
        Set RS125 = New ADODB.Recordset
        RS125.CursorLocation = adUseClient 'aktuelle Aufnahmediagnosen
        Set RS125 = DBCmRe1("qrySimAbDiPa", "@IdxNr", PatNr)
        If RS125.RecordCount > 0 Then
            Do
            If RS125.Fields("IDKurz").Value <> vbNullString Then
                CoStr = RS125.Fields("GOID").Value
                KuStr = RS125.Fields("IDKurz").Value
                DiDat = RS125.Fields("Datum").Value
                If LetRe > 0 Then
                    Set RS130 = New ADODB.Recordset 'ist Katalogdiagnose bereits in letzter Rechnung enthlaten
                    RS130.CursorLocation = adUseClient
                    Set RS130 = DBCmRe2("qrySimAbDiSu", "@IdxNr", "@IdStr", LetRe, "%" & CoStr & "%")
                    If RS130.RecordCount > 0 Then
                        If ReDia = True Then
                            DiaEi = False
                        Else
                            DiaEi = True
                        End If
                    Else
                        DiaEi = True
                    End If
                    RS130.Close
                    Set RS130 = Nothing
                Else
                    DiaEi = True
                End If
            Else
                CoStr = vbNullString
                KuStr = vbNullString
                DiaEi = False
            End If
            If DiaEi = True Then
                If RS125.Fields("Datum").Value <> vbNullString Then
                    DBCmEx7 "qrySimAbDiA4", "@PatNr", "@IdxNr", "@IdCod", "@IdStr", "@IdDat", "@IdGrp", "@IdRef", PatNr, NeuRe, CoStr, KuStr, DiDat, DiGrp, DiRef
                Else
                    DBCmEx6 "qrySimAbDiA1", "@PatNr", "@IdxNr", "@IdCod", "@IdStr", PatNr, "@IdGrp", "@IdRef", NeuRe, CoStr, KuStr, DiGrp, DiRef
                End If
            End If
            RS125.MoveNext
            Loop Until RS125.EOF
        End If
        RS125.Close
        Set RS125 = Nothing
    End If
End If
DoEvents

K_ReNe = NeuRe

If GlStS > 1 Then
    RetWe = SendMessage(CmTyp.hwnd, CB_SETCURSEL, 8, ByVal 0&)
End If

GlNeK = GlKoX 'Protokolleintrag
With GlNeK
    .PatNr = PatNr
    .IdxNr = 0
    .EiDat = Format$(Date, "dd.mm.yyyy")
    .EiZei = TimeValue(Now)
    .EiTyp = 104
    .TeStr = "Rechnung hinzugefügt - " & ReStr
    .ZiStr = Format$(Now, "hh:mm") & " Uhr"
    .NeuEi = True
    .KeiAk = True
    .Mitar = GlMiA(GlSmI, 2)
End With
S_Prot

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_ReNe " & Err.Number
Resume Next

End Function
Public Function K_RePr(ByVal AlZal As Integer, NeZal As Integer) As Boolean
On Error GoTo GrErr
'Regelprüfung

Dim EiDat As Date
Dim ReNum As Long
Dim PaNum As Long
Dim IdxNr As Long
Dim GebZi As String
Dim ResZu As Boolean 'Einfügen zulassen
Dim KrTyp As Integer
Dim AnzL1 As Integer
Dim AnzL2 As Integer
Dim RePru As Integer
Dim Mld4, Mld5, Mld6 As String
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo4 = FM.repCont4
Set RpCo6 = FM.repCont6

Set RpCls = RpCo4.Columns
Set RpSel = RpCo4.SelectedRows

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        Set RpCol = RpCls.Find(Rec_ID1)
        ReNum = RpRow.Record(RpCol.ItemIndex).Value
        Set RpCol = RpCls.Find(Rec_ID0)
        PaNum = RpRow.Record(RpCol.ItemIndex).Value
    Else
        ResZu = True
        K_RePr = ResZu
        Exit Function
    End If
Else
    ResZu = True
    K_RePr = ResZu
    Exit Function
End If

Set RpCls = RpCo6.Columns
Set RpSel = RpCo6.SelectedRows

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        Set RpCol = RpCls.Find(Kra_Ziffer)
        GebZi = RpRow.Record(RpCol.ItemIndex).Value
        Set RpCol = RpCls.Find(Kra_Datum)
        EiDat = RpRow.Record(RpCol.ItemIndex).Value
        Set RpCol = RpCls.Find(Kra_KrTyp)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            If IsNumeric(RpRow.Record(RpCol.ItemIndex).Value) = True Then
                KrTyp = RpRow.Record(RpCol.ItemIndex).Value
            Else
                KrTyp = 0
            End If
        Else
            KrTyp = 0
        End If
        Set RpCol = RpCls.Find(Kra_ID4)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            If IsNumeric(RpRow.Record(RpCol.ItemIndex).Value) = True Then
                IdxNr = RpRow.Record(RpCol.ItemIndex).Value
            Else
                IdxNr = 0
            End If
        Else
            IdxNr = 0
        End If
    Else
        ResZu = True
        K_RePr = ResZu
        Exit Function
    End If
Else
    ResZu = True
    K_RePr = ResZu
    Exit Function
End If

If KrTyp <> 2 Then
    ResZu = True
    K_RePr = ResZu
    Exit Function
End If

If GlRsP = True Then 'Regelprüfung durchführen?
    Set RS128 = New ADODB.Recordset
    RS128.CursorLocation = adUseClient
    Set RS128 = DBCmRe1("qryKat01A", "@IdxNr", IdxNr)
    If RS128.RecordCount > 0 Then
        If Not IsNull(RS128.Fields("ResTaAn").Value) Then
            If RS128.Fields("ResTaAn").Value <> vbNullString Then
                AnzL1 = RS128.Fields("ResTaAn").Value
            Else
                AnzL1 = 0
            End If
        Else
            AnzL1 = 0
        End If
        If Not IsNull(RS128.Fields("ResTaRe").Value) Then
            If RS128.Fields("ResTaRe").Value <> vbNullString Then
                AnzL2 = RS128.Fields("ResTaRe").Value
            Else
                AnzL2 = 0
            End If
        Else
            AnzL2 = 0
        End If
        If RS128.Fields("ResTag").Value = -1 Then
            RePru = 1
        ElseIf RS128.Fields("ResRec").Value = -1 Then
            RePru = 2
        ElseIf RS128.Fields("ResSol").Value = -1 Then
            RePru = 3
        End If
    End If
    RS128.Close
    Set RS128 = Nothing

    If RePru = 1 Then
        If AnzL1 > 0 Then
            Mld4 = "Die Ziffer " & GebZi & " sollte am " & EiDat & " nicht mehr als " & AnzL1 & "-mal abgerechnet werden"
            Mld5 = "Es wurde festgestellt, dass beabsichtigt wird, die Ziffer " & GebZi & " insgesamt " & NeZal & "–mal am " & EiDat & " abzurechnen. Dieses verstößt gegen eine Gebührenregel, welche dieser Ziffer zugeordnet ist. Soll die Ziffer " & GebZi & " trotzdem " & NeZal & "-mal am " & EiDat & " abgerechnet werden?"
            Mld6 = "HINWEIS! Die Regelprüfung kann jederzeit unter dem Menüpunkt: Anzeigeoptionen aus- und eingeschaltet werden."
            If NeZal > AnzL1 Then
                SMeFr "Regelverstoß", Mld4, Mld5, Mld6, False, IC32_Hand, False, FM.hwnd
                If GlMes <> 33565 Then
                    ResZu = False
                Else
                    ResZu = True
                End If
            Else
                ResZu = True
            End If
        Else
            ResZu = True
        End If
    ElseIf RePru = 2 Then
        If AnzL2 > 0 Then
            Mld4 = "Die Ziffer " & GebZi & " sollte in dieser Rechnung nicht mehr als " & AnzL2 & "-mal abgerechnet werden"
            Mld5 = "Es wurde festgestellt, dass beabsichtiigt wird, die Ziffer " & GebZi & " insgesamt " & NeZal & "–mal in dieser Rechnung abzurechnen. Dieses verstößt gegen eine Gebührenregel, welche dieser Ziffer zugeordnet ist. Soll die Ziffer " & GebZi & " trotzdem " & NeZal & "-mal in dieser Rechnung abgerechnet werden?"
            Mld6 = "HINWEIS! Die Regelprüfung kann jederzeit unter dem Menüpunkt: Anzeigeoptionen aus- und eingeschaltet werden."
            If NeZal > AnzL2 Then
                SMeFr "Regelverstoß", Mld4, Mld5, Mld6, False, IC32_Hand, False, FM.hwnd
                If GlMes <> 33565 Then
                    ResZu = False
                Else
                    ResZu = True
                End If
            Else
                ResZu = True
            End If
        Else
            ResZu = True
        End If
    Else
        ResZu = True
    End If
Else
    ResZu = True
End If

K_RePr = ResZu
DoEvents

RpCo6.SetFocus

Set RpRws = Nothing
Set RpCls = Nothing
Set RpSel = Nothing
Set RpCo4 = Nothing
Set RpCo6 = Nothing

Exit Function

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_RePr " & Err.Number
Resume Next

End Function
Public Sub K_RcLo(ByVal TabId As Long)
On Error GoTo LiErr

Dim IdxNr As Long
Dim AnzPo As Integer
Dim RowNr As Integer
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCo7 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmKatRC
Set RpCo7 = FM.repCont7
Set RpCls = RpCo7.Columns
Set RpSel = RpCo7.SelectedRows

AnzPo = RpSel.Count

Tit1 = "Einträge entfernen"
If AnzPo > 1 Then
    Mld1 = "Möchten Sie die " & AnzPo & " markierten Einträge wirklich entfernen?"
Else
    Mld1 = "Möchten Sie den markierten Eintrag wirklich entfernen?"
End If

If AnzPo > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then
        Screen.MousePointer = vbHourglass
        DoEvents

        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                RowNr = RpRow.Index
                Set RpCol = RpCls.Find(Ter_ID2)
                IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                DBCmEx1 "qryTerLoe", "@IdxNr", IdxNr
                DBCmEx1 "qryAnKa1g", "@IdxNr", IdxNr
            End If
        Next RpRow
        
        DoEvents
        P_List "ReSe", 0, 1

        DoEvents
        Screen.MousePointer = vbNormal
    End If
End If

Set RpCo7 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_RcLo " & Err.Number
Resume Next

End Sub
Public Sub K_RzEi(ByVal PaFrm As String, Optional ByVal KetMe As Boolean, Optional ByVal DroFe As Integer)
On Error GoTo GrErr
'Fügt Parameter ein

Dim ParNr As Long 'Parameternummer
Dim RowNr As Long
Dim KatNr As Long
Dim RezNr As Long
Dim PatNr As Long
Dim LetRe As Long
Dim RetWe As Long
Dim TmStr As String
Dim MeTex As String
Dim CoStr As String
Dim KuStr As String
Dim DiaSu As String
Dim DiaNr As Integer
Dim Mld1, Tit1 As String
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmEd1 As XtremeCommandBars.CommandBarEdit
Dim CmEd2 As XtremeCommandBars.CommandBarEdit
Dim CmEd3 As XtremeCommandBars.CommandBarEdit
Dim CmEd4 As XtremeCommandBars.CommandBarEdit
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCo7 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmKatRE
Set CmBrs = FM.comBar02
Set RpCo7 = FM.repCont7
Set TxReT = frmMain.txtReTex
Set RpCo5 = frmMain.repCont5
Set RpCls = RpCo5.Columns
Set RpSel = RpCo5.SelectedRows

Set CmEd1 = CmBrs.FindControl(CmEd1, SY_DoMor, , True)
Set CmEd2 = CmBrs.FindControl(CmEd2, SY_DoMit, , True)
Set CmEd3 = CmBrs.FindControl(CmEd3, SY_DoAbe, , True)
Set CmEd4 = CmBrs.FindControl(CmEd4, SY_DoNac, , True)

If RpSel.Count = 0 Then Exit Sub

Set RpRow = RpSel(0)
MeTex = TxReT.Text

Set RpCls = RpCo5.Columns
Set RpSel = RpCo5.SelectedRows
If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        RowNr = RpRow.Index
        Set RpCol = RpCls.Find(Rzp_ID1)
        If RpRow.Record(RpCol.ItemIndex).Value < 0 Then
            Mld1 = "Es wurde noch kein Beleg angelegt"
            Tit1 = "Kein Beleg"
            WindowMess Mld1, Dial2, Tit1, FM.hwnd
            Exit Sub
        Else
            Set RpCol = RpCls.Find(Rzp_ID0)
            PatNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rzp_ID1)
            RezNr = RpRow.Record(RpCol.ItemIndex).Value
