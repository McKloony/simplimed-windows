Public Sub ABD_Filt(ByVal SuStr As String, ByVal SuTyp As Integer, Optional ByVal IdxNr As Long)
On Error GoTo LiErr
'Weißt dem ReportControl die gefilterten Adressen zu

Dim AkAry As Long
Dim VKPre As Single
Dim AktZa As Integer
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow
Dim Mld1, Tit1 As String

Set FM = frmMedik
Set RpCo1 = FM.repCont1
Set RpRcs = RpCo1.Records

Screen.MousePointer = vbHourglass

If SuStr = vbNullString Then
    SuStr = Format$(CStr(IdxNr), "000000")
End If

Set RS147 = New ADODB.Recordset
RS147.CursorLocation = adUseClient
Select Case SuTyp
Case 1: Set RS147 = ABDmRe1("qryArtNam", "@IdStr", SuStr & "%")
Case 2: Set RS147 = ABDmRe1("qryArtPZN", "@IdStr", SuStr)
Case 3: Set RS147 = ABDmRe1("qryArtAnb", "@IdxNr", IdxNr)
Case 4: Set RS147 = ABDmRe1("qryArtWks", "@IdStr", SuStr)
Case 5: Set RS147 = ABDmRe1("qryArtInd", "@IdxNr", IdxNr)
End Select
GlAbP = RS147.RecordCount

If GlAbP > 100000 Then
    Tit1 = "Produktesuche"
    Mld1 = "Zu der gestellten Suchanfrage wurden " & GlAbP & " passende Ergebnisse gefunden. Bitte grenzen Sie die Suche weiter ein."
    RS147.Close
    Set RS147 = Nothing
    Set RpRec = Nothing
    Set RpCo1 = Nothing
    GlAbP = 0
    Screen.MousePointer = vbNormal
    WindowMess Mld1, Dial2, Tit1, FM.hwnd
    Exit Sub
End If

If GlAbP > 0 Then
    With RpCo1
        .EditItem Nothing, Nothing
        If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
        If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
        If .Records.Count > 0 Then .Records.DeleteAll
        .Populate
    End With
    
    AbAry = RS147.GetRows 'Array Füllen
    DoEvents
    
    For AkAry = 0 To GlAbP - 1
        If AbAry(ABDA_ApoPreis, AkAry) > 0 Then
            VKPre = AbAry(ABDA_ApoPreis, AkAry) / 100
        Else
            VKPre = 0
        End If
        AbAry(ABDA_ApoPreis, AkAry) = Format$(VKPre, "#,##0.00")
        
        Select Case AbAry(ABDA_ApoPflicht, AkAry)
        Case "0": AbAry(ABDA_ApoPflicht, AkAry) = "kA"
        Case "1": AbAry(ABDA_ApoPflicht, AkAry) = "nein"
        Case "2": AbAry(ABDA_ApoPflicht, AkAry) = "ja"
        Case "3": AbAry(ABDA_ApoPflicht, AkAry) = "AR"
        End Select

        Select Case AbAry(ABDA_Einstufung, AkAry)
        Case "0": AbAry(ABDA_Einstufung, AkAry) = "kA"
        Case "1": AbAry(ABDA_Einstufung, AkAry) = "nb"
        Case "2": AbAry(ABDA_Einstufung, AkAry) = "kP"
        Case "3": AbAry(ABDA_Einstufung, AkAry) = "N1"
        Case "4": AbAry(ABDA_Einstufung, AkAry) = "N2"
        Case "5": AbAry(ABDA_Einstufung, AkAry) = "N3"
        End Select
        
        Select Case AbAry(ABDA_Vertriebsstatus, AkAry)
        Case "0": AbAry(ABDA_Vertriebsstatus, AkAry) = "kA"
        Case "1": AbAry(ABDA_Vertriebsstatus, AkAry) = "aV"
        Case "2": AbAry(ABDA_Vertriebsstatus, AkAry) = "iV"
        Case "3": AbAry(ABDA_Vertriebsstatus, AkAry) = "Zu"
        End Select
    Next AkAry

    RpCo1.SetVirtualMode GlAbP
    DoEvents

    Set RpRec = RpCo1.Records(0)
    For AktZa = 0 To 16 'WICHTIG!
        Set RpItm = RpRec.AddItem(vbNullString)
    Next AktZa

    DoEvents
    With RpCo1
        .Populate
        .SetCustomDraw xtpCustomBeforeDrawRow
    End With
    
    Set RpRws = RpCo1.Rows
    RpRws.Row(0).Selected = True
    Set RpRow = RpRws(0)
Else
    GlAbP = 0
    If GlAbP > 0 Then
        Erase AbAry
    End If
    RpCo1.SetVirtualMode 0
    
    DoEvents
    With RpCo1
        .Populate
        .SetCustomDraw xtpCustomBeforeDrawRow
    End With
    
    SPopu "Keine Einträge gefunden", "Es wurden keine Adressen gefunden, die dem Suchkriterium entsprechen", IC48_Information
End If

RS147.Close
Set RS147 = Nothing

Set RpRec = Nothing
Set RpCo1 = Nothing

Screen.MousePointer = vbNormal

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_AbFil " & Err.Number
Resume Next

End Sub
Public Sub ABD_Kat(ByVal GesPo As Long)
On Error GoTo LiErr
'Fügt die markierten Produkte in den Arzneikatalog ein

Dim SQL1 As String
Dim SQL2 As String
Dim SQL3 As String
Dim AktPo As Long
Dim RowNr As Long
Dim RowFi As Long
Dim HerID As Long
Dim Einhe As String
Dim Menge As String
Dim PrStr As String
Dim Darre As String
Dim EiPre As Single
Dim NeuHe As Boolean
Dim Posit As Integer
Dim Anzal As Integer
Dim Lbl08 As XtremeSuiteControls.Label
Dim Lbl09 As XtremeSuiteControls.Label
Dim RpCo8 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo8 = FM.repCont8
Set RpRws = RpCo8.Rows
Set RpCls = RpCo8.Columns
Set RpSel = RpCo8.SelectedRows
Set Lbl08 = frmMedik.lblLab08
Set Lbl09 = frmMedik.lblLab09
Set PrBr1 = frmMedik.prbStat1
Set PrBr2 = frmMedik.prbStat2

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    RowNr = RpRow.Index
End If

If GlTyp < 2 Then
    SQL1 = "SELECT TOP 5 * FROM dbo.qryKat04C"
Else
    SQL1 = "SELECT TOP 5 * FROM qryKat04C;"
End If
Set RS120 = New ADODB.Recordset
With RS120
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With
If RS120.Supports(adAddNew) Then
    For AktPo = 0 To GesPo - 1

        PrBr1.Min = 0
        PrBr1.Max = GesPo
    
        If GlTyp < 2 Then
            SQL2 = "SELECT * FROM dbo.qryKat04 WHERE IDKurz Like '" & GlClp(AktPo, ABDA_Firmenname) & "'"
        Else
            SQL2 = "SELECT * FROM qryKat04 WHERE [IDKurz] Like '" & GlClp(AktPo, ABDA_Firmenname) & "';"
        End If
        Set RS121 = New ADODB.Recordset
        With RS121 'Ist Hersteller schon vorhanden?
            .CursorLocation = adUseClient
            .Source = SQL2
            .ActiveConnection = DB1
            .CursorType = adOpenDynamic
            .LockType = adLockOptimistic
            .Open Options:=adCmdText
        End With

        If RS121.RecordCount = 0 Then
            If RS121.Supports(adAddNew) Then
                RS121.AddNew
                RS121.Fields("IDKurz").Value = GlClp(AktPo, ABDA_Firmenname)
                RS121.Update
                NeuHe = True
            End If
        Else
            HerID = RS121.Fields("ID3").Value
        End If
        RS121.Close
        Set RS121 = Nothing
        
        If NeuHe = True Then 'Neuer Hersteller wird angelegt
            Set RS122 = New ADODB.Recordset
            With RS122
                .CursorLocation = adUseClient
                .Source = SQL2
                .ActiveConnection = DB1
                .CursorType = adOpenDynamic
                .LockType = adLockOptimistic
                .Open Options:=adCmdText
            End With
            If RS122.RecordCount > 0 Then
                HerID = RS122.Fields("ID3").Value
            Else
                HerID = 0
            End If
            RS122.Close
            Set RS122 = Nothing
        End If
        DoEvents
                
        If HerID > 0 Then
            If GlClp(AktPo, ABDA_Darreichung_Kurz) <> vbNullString Then
                Darre = LCase(GlClp(AktPo, ABDA_Darreichung_Kurz))
            Else
                Darre = vbNullString
            End If
            If GlClp(AktPo, ABDA_Menge) <> vbNullString Then
                LCase (Menge = GlClp(AktPo, ABDA_Menge))
            Else
                Menge = vbNullString
            End If
            If GlClp(AktPo, ABDA_Einheit) <> vbNullString Then
                Einhe = GlClp(AktPo, ABDA_Einheit)
            Else
                Einhe = vbNullString
            End If

            If Menge <> vbNullString Then
                If Einhe <> vbNullString Then
                    PrStr = GlClp(AktPo, ABDA_IDLang) & " " & Menge & " " & Einhe
                Else
                    PrStr = GlClp(AktPo, ABDA_IDLang) & " " & Menge
                End If
            Else
                PrStr = GlClp(AktPo, ABDA_IDLang)
            End If
            
            If Darre Like "amp." Or Darre Like "ilo." Or Darre Like "pul." Or Darre Like "inf." Or Darre Like "inlsg." Then
                Posit = InStr(1, Menge, "x", 1)
                If Posit > 0 Then
                    Anzal = CInt(Mid$(Menge, 1, Posit - 1))
                Else
                    Anzal = Val(Menge)
                End If
                If GlClp(AktPo, ABDA_ApoPreis) > 0 Then
                    If Anzal > 0 Then
                        EiPre = CSng(GlClp(AktPo, ABDA_ApoPreis)) / Anzal
                    Else
                        EiPre = CSng(GlClp(AktPo, ABDA_ApoPreis))
                    End If
                Else
                    EiPre = 0
                End If
            Else
                EiPre = CSng(GlClp(AktPo, ABDA_ApoPreis))
            End If
    
            If GlTyp < 2 Then
                SQL3 = "SELECT * FROM dbo.qryKat04C WHERE ID3=" & HerID & " AND GOID Like '" & GlClp(AktPo, ABDA_PZN) & "'"
            Else
                SQL3 = "SELECT * FROM qryKat04C WHERE [ID3]=" & HerID & " AND [GOID] Like '" & GlClp(AktPo, ABDA_PZN) & "';"
            End If
            Set RS123 = New ADODB.Recordset
            With RS123
                .CursorLocation = adUseClient
                .Source = SQL3
                .ActiveConnection = DB1
                .CursorType = adOpenDynamic
                .LockType = adLockOptimistic
                .Open Options:=adCmdText
            End With

            If RS123.RecordCount = 0 Then
                RS120.AddNew
                RS120.Fields("ID3").Value = HerID
                RS120.Fields("GOID").Value = Format$(GlClp(AktPo, ABDA_PZN), "0000000")
                RS120.Fields("IDKurz").Value = PrStr
                RS120.Fields("Preis1").Value = CSng(GlClp(AktPo, ABDA_ApoPreis))
                RS120.Fields("Preis3").Value = EiPre
                RS120.Fields("Multi").Value = 1
                RS120.Fields("Sorter").Value = AktPo + 1
                RS120.Update
            Else
                RS123.Fields("GOID").Value = Format$(GlClp(AktPo, ABDA_PZN), "0000000")
                RS123.Fields("IDKurz").Value = GlClp(AktPo, ABDA_IDLang)
                RS123.Fields("Preis1").Value = CSng(GlClp(AktPo, ABDA_ApoPreis))
                RS123.Fields("Preis3").Value = EiPre
                RS123.Update
            End If
            RS123.Close
            Set RS123 = Nothing
            
            If GlTyp < 2 Then
                SQL3 = "SELECT * FROM dbo.qryKat04C WHERE ID3=" & 1 & " AND GOID Like '" & GlClp(AktPo, ABDA_PZN) & "'"
            Else
                SQL3 = "SELECT * FROM qryKat04C WHERE [ID3]=" & 1 & " AND [GOID] Like '" & GlClp(AktPo, ABDA_PZN) & "';"
            End If
            Set RS123 = New ADODB.Recordset
            With RS123
                .CursorLocation = adUseClient
                .Source = SQL3
                .ActiveConnection = DB1
                .CursorType = adOpenDynamic
                .LockType = adLockOptimistic
                .Open Options:=adCmdText
            End With
            If RS123.RecordCount = 0 Then
                RS120.AddNew
                RS120.Fields("ID3").Value = 1
                RS120.Fields("GOID").Value = Format$(GlClp(AktPo, ABDA_PZN), "0000000")
                RS120.Fields("IDKurz").Value = GlClp(AktPo, ABDA_IDLang)
                RS120.Fields("Preis1").Value = CSng(GlClp(AktPo, ABDA_ApoPreis))
                RS120.Fields("Preis3").Value = EiPre
                RS120.Fields("Multi").Value = 1
                RS120.Fields("Sorter").Value = AktPo + 1
                RS120.Update
            Else
                RS123.Fields("GOID").Value = Format$(GlClp(AktPo, ABDA_PZN), "0000000")
                RS123.Fields("IDKurz").Value = GlClp(AktPo, ABDA_IDLang)
                RS123.Fields("Preis1").Value = CSng(GlClp(AktPo, ABDA_ApoPreis))
                RS123.Fields("Preis3").Value = EiPre
                RS123.Update
            End If
            RS123.Close
            Set RS123 = Nothing
        End If
        
        Lbl08.Caption = GlClp(AktPo, ABDA_IDLang)
        PrBr1.Value = AktPo
        DoEvents
    Next AktPo
End If
RS120.Close
Set RS120 = Nothing

Erase GlClp
ClKop = False
DoEvents

KList

Set RpCo8 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "ABD_Kat " & Err.Number
Resume Next

End Sub
