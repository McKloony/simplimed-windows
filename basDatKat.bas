Public Function T_KoDa(ByVal DaStr As String, Optional ByVal VerNu As Long) As String
On Error Resume Next
'Kovertiert das Datum

Dim AkJah As Integer
Dim Posit As Integer
Dim JahZa As Integer

AkJah = Year(Date)
DaStr = Trim$(DaStr)
Posit = InStr(1, DaStr, "?")

If Len(DaStr) = 8 Then
    If DaStr = "00000000" Then
        T_KoDa = "01.01.1900"
    Else
        If VerNu >= 1014 Then
            If Left$(DaStr, 4) = AkJah Then
                T_KoDa = Right$(DaStr, 2) & "." & Mid$(DaStr, 5, 2) & "." & Left$(DaStr, 4)
            ElseIf Left$(DaStr, 4) = AkJah - 1 Then
                T_KoDa = Right$(DaStr, 2) & "." & Mid$(DaStr, 5, 2) & "." & Left$(DaStr, 4)
            ElseIf Left$(DaStr, 4) = AkJah - 2 Then
                T_KoDa = Right$(DaStr, 2) & "." & Mid$(DaStr, 5, 2) & "." & Left$(DaStr, 4)
            ElseIf Right$(DaStr, 4) = AkJah Then
                T_KoDa = Left$(DaStr, 2) & "." & Mid$(DaStr, 3, 2) & "." & Right$(DaStr, 4)
            ElseIf Right$(DaStr, 4) = AkJah - 1 Then
                T_KoDa = Left$(DaStr, 2) & "." & Mid$(DaStr, 3, 2) & "." & Right$(DaStr, 4)
            Else
                T_KoDa = Right$(DaStr, 2) & "." & Mid$(DaStr, 5, 2) & "." & Left$(DaStr, 4)
            End If
        Else
            If Right$(DaStr, 4) = AkJah Then
                T_KoDa = Left$(DaStr, 2) & "." & Mid$(DaStr, 3, 2) & "." & Right$(DaStr, 4)
            ElseIf Right$(DaStr, 4) = AkJah - 1 Then
                T_KoDa = Left$(DaStr, 2) & "." & Mid$(DaStr, 3, 2) & "." & Right$(DaStr, 4)
            ElseIf Right$(DaStr, 4) = AkJah - 2 Then
                T_KoDa = Left$(DaStr, 2) & "." & Mid$(DaStr, 3, 2) & "." & Right$(DaStr, 4)
            ElseIf Left$(DaStr, 4) = AkJah Then
                T_KoDa = Right$(DaStr, 2) & "." & Mid$(DaStr, 5, 2) & "." & Left$(DaStr, 4)
            ElseIf Left$(DaStr, 4) = AkJah - 1 Then
                T_KoDa = Right$(DaStr, 2) & "." & Mid$(DaStr, 5, 2) & "." & Left$(DaStr, 4)
            Else
                T_KoDa = Left$(DaStr, 2) & "." & Mid$(DaStr, 3, 2) & "." & Right$(DaStr, 4)
            End If
        End If
    End If
ElseIf Len(DaStr) = 6 Then
    If (Posit >= 1) Or (Len(DaStr) < 6) Or (Left$(DaStr, 2) = "00") Then
        T_KoDa = "01.01.1900"
    Else
        If Len(DaStr) = 5 Then
            DaStr = "0" & DaStr
        End If
        If Len(DaStr) = 7 Then
            DaStr = "0" & DaStr
        End If
        If Len(DaStr) = 6 Then
            JahZa = Val(Mid$(DaStr, 5, 2))
            If JahZa >= 80 Then
                DaStr = Left$(DaStr, 4) & "19" & Right$(DaStr, 2)
            Else
                DaStr = Left$(DaStr, 4) & "20" & Right$(DaStr, 2)
            End If
        End If
        T_KoDa = Left(DaStr, 2) & "." & Mid$(DaStr, 3, 2) & "." & Right$(DaStr, 4)
    End If
Else
    T_KoDa = "01.01.1900"
End If

End Function
Public Function T_KoSt(ByVal TxStr As String) As Variant
On Error GoTo ErErr
'Konvertiert bestimmte Werte aus Wertetabelle

Select Case TxStr
Case "Eigenbefund": T_KoSt = "E"
Case "Endbefund": T_KoSt = "E"
Case "Teilbefund": T_KoSt = "T"
Case "Vorbefund": T_KoSt = "V"
Case "Archivbefund": T_KoSt = "A"
Case "Nachforderung": T_KoSt = "N"
Case "Urlaub": T_KoSt = "T"
Case "M": T_KoSt = "1"
Case "W": T_KoSt = "2"
Case "K": T_KoSt = "3"
Case "m": T_KoSt = "1"
Case "w": T_KoSt = "2"
Case "k": T_KoSt = "3"
Case LCase("männlich"): T_KoSt = "1"
Case LCase("weiblich"): T_KoSt = "2"
Case LCase("kind"): T_KoSt = "3"
Case LCase("kind, männlich"): T_KoSt = "1"
Case LCase("kind, weiblich"): T_KoSt = "2"
End Select

Exit Function

ErErr:
If GlDbg = True Then MsgBox Err.Description, 48, "T_KoSt " & Err.Number
Resume Next

End Function
Public Function T_KoZe(ByVal DaStr As String) As String
On Error Resume Next
'Kovertiert die Uhrzeit

Dim Posit As Integer

DaStr = Trim$(DaStr)
Posit = InStr(1, DaStr, "?")

If (Posit >= 1) Or (Len(DaStr) < 4) Then
    T_KoZe = "00:00:00"
Else
    If Left$(DaStr, 2) = "24" Then
        DaStr = "00" & Right$(DaStr, 2)
    End If
    T_KoZe = Left(DaStr, 2) & ":" & Right$(DaStr, 2) & ":00"
End If

End Function
