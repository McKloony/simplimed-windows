Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCo1 = Nothing
Set RpCo2 = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_WoLa " & Err.Number
Resume Next

End Sub
Public Sub S_WoSa()
On Error GoTo KoErr
'Lädt den Kontenplan und die Gegenkonten

Dim SQL1 As String
Dim TmTag As String
Dim RpCon As XtremeReportControl.ReportControl

Set FM = frmAdrWord
Set RpCon = FM.repCont1
Set RpRcs = RpCon.Records

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qrySimKrTyp ORDER BY [IDT]"
Else
    SQL1 = "SELECT * FROM qrySimKrTyp ORDER BY [IDT];"
End If

Set RS155 = New ADODB.Recordset
With RS155
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With
If RS155.RecordCount > 0 Then
    If RS155.Supports(adUpdate) Then
        RS155.MoveFirst
        For Each RpRec In RpRcs
            For Each RpItm In RpRec
                If Left$(RpItm.Tag, 1) = "@" Then
                    TmTag = Mid$(RpItm.Tag, 2, Len(RpItm.Tag) - 1)
                    If RpItm.HasCheckbox = True Then
                        RS155.Fields(TmTag).Value = RpItm.Checked
                    Else
                        RS155.Fields(TmTag).Value = RpItm.Value
                    End If
                End If
            Next RpItm
            RS155.Update
            RS155.MoveNext
        Next RpRec
    End If
End If
RS155.Close
Set RS155 = Nothing

If GlJet = True Then SDBSav

Set RpRec = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCon = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_WoSa " & Err.Number
Resume Next

End Sub
