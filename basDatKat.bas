Public Sub K_List()
On Error GoTo LiErr
'Füllt die Tabelle mit Daten

Dim GesZa As Long
Dim IdxNr As Long
Dim SubNr As Long
Dim GrPre As Single
Dim TreKy As String
Dim GrCap As String
Dim TypSt As String
Dim LiGrp As Boolean
Dim KetMe As Boolean
Dim ZeiUm As Boolean
Dim GrVor As Boolean
Dim GrAnz As Integer
Dim AktZa As Integer
Dim RpCo8 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo8 = FM.repCont8

TreKy = Left$(GlNod, 1)

IdxNr = Mid$(GlNod, 2, Len(GlNod) - 1)

With RpCo8
    .EditItem Nothing, Nothing
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    If .Records.Count > 0 Then .Records.DeleteAll
    .Populate
End With

If IdxNr = 0 Then Exit Sub

Select Case TreKy
Case "A": GrVor = True
Case "C": GrVor = True
Case "D": KetMe = True
Case "F": KetMe = True
Case "G": GrVor = True
Case "H": KetMe = True
Case "I": GrVor = False
Case "J": KetMe = True
Case "K": GrVor = False
Case "L": GrVor = False
Case "M": GrVor = False
Case "N": GrVor = True
Case "O": GrVor = False
Case "P": GrVor = False
Case "R": KetMe = True
Case "Q": KetMe = True
End Select

Set RS153 = New ADODB.Recordset
RS153.CursorLocation = adUseClient

Select Case TreKy
Case "A": Set RS153 = DBCmRe1("qryKat01D", "@IdxNr", IdxNr) 'Gebührenkatalog
Case "C":
    If GlGrG = True Then 'Gruppierung Kataloge
        Set RS153 = DBCmRe1("qryKat03E", "@IdxNr", IdxNr) 'Diagnosekatalog
    Else
        Set RS153 = DBCmRe1("qryKat03Q", "@IdxNr", IdxNr) 'Diagnosekatalog
    End If
Case "D": Set RS153 = DBCmRe1("qryKat01H", "@IdxNr", IdxNr) 'Gebührenketten
Case "F": Set RS153 = DBCmRe1("qryKat03H", "@IdxNr", IdxNr) 'Diagnoseketten
Case "G": Set RS153 = DBCmRe1("qryKat02D", "@IdxNr", IdxNr) 'Laborparameter
Case "H": Set RS153 = DBCmRe1("qryKat02H", "@IdxNr", IdxNr) 'Laborketten
Case "I": Set RS153 = DBCmRe1("qryKat04G", "@IdxNr", IdxNr) 'Arzneikatalog
Case "J": Set RS153 = DBCmRe1("qryKat04H", "@IdxNr", IdxNr) 'Arzneiketten
Case "K": Set RS153 = DBCmRe1("qryKat02D", "@IdxNr", IdxNr) 'Begründungen
Case "L": Set RS153 = DBCmRe1("qryKat02D", "@IdxNr", IdxNr) 'Anamnesetexte
Case "M": Set RS153 = DBCmRe0("qryKon01E")                  'Terminbetreffs
Case "N": Set RS153 = DBCmRe1("qryKat08I", "@IdxNr", IdxNr) 'Fragebogen
Case "O": Set RS153 = DBCmRe1("qryKat04G", "@IdxNr", IdxNr) 'Textphrasen
Case "P": Set RS153 = DBCmRe1("qryKat12G", "@IdxNr", IdxNr) 'Artikelkatalog
Case "R": Set RS153 = DBCmRe0("qryKon02A")                  'Terminketten
Case "Q": Set RS153 = DBCmRe1("qryKat12H", "@IdxNr", IdxNr) 'Artikelketten
End Select

GesZa = RS153.RecordCount

If GesZa > 0 Then
    K_Rec RS153, TreKy, KetMe, GrVor
End If

RS153.Close
Set RS153 = Nothing

If GlBut = RibTab_Kat_Frage Then
    RpCo8.Populate
    DoEvents
    Set RpRcs = RpCo8.Records
    For Each RpRec In RpRcs
        If RpRec.Item(Kat_ID0).Value <> vbNullString Then
            SubNr = RpRec.Item(Kat_ID0).Value
        Else
            SubNr = 0
        End If
        If RpRec.Item(Kat_Preis1).Value <> vbNullString Then
            TypSt = RpRec.Item(Kat_Preis1).Value
        Else
            TypSt = vbNullString
        End If
        If SubNr > 0 Then
            K_RecF RpRec, SubNr, GrVor
        End If
    Next RpRec
End If

With RpCo8
    If KetMe = False Then
        If GlGrG = True Then 'Gruppierung Kataloge
            If GrVor = True Then
                .SortOrder.Add .Columns(Kat_Gruppe)
                .GroupsOrder.Add .Columns(Kat_Gruppe)
                .GroupsOrder(0).SortAscending = True
            End If
        End If
    End If
End With

If GesZa > 0 Then
    RpCo8.Populate
    DoEvents
    Set RpRws = RpCo8.Rows
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            Set RpGrw = RpRow
            Set ChRws = RpGrw.Childs
            GrAnz = ChRws.Count
            For Each ChRow In ChRws
                If IsNumeric(ChRow.Record.Item(Kat_Preis1).Value) Then
                    GrPre = GrPre + ChRow.Record.Item(Kat_Preis1).Value
                End If
            Next ChRow
        End If
        GrPre = 0
    Next RpRow
End If

SMark

Set RpRws = Nothing
Set RpCo8 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then SErLog Err.Description & " K_List " & Err.Number
Resume Next

End Sub
