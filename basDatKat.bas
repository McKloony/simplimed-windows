Dim ReTyp As String
Dim ArStr As String
Dim WärFa As Single
Dim ReBet As Single
Dim FeMul As Single
Dim FeEin As Double
Dim Multi As Single
Dim ReRab As Single
Dim NeReB As Double
Dim BesSo As Single
Dim BesMe As Single
Dim ReStu As Single
Dim ReStr As String
Dim SuStr As String
Dim EiTex As String
Dim TmpSt As String
Dim KrGui As String
Dim GebZi As String
Dim DiaSu As String
Dim CoStr As String
Dim KuStr As String
Dim MaStr As String
Dim PaStr As String
Dim KaStr As String
Dim FoWär As Integer
