                    BuAus = LCase(RpRow.Record(RpCol.ItemIndex).Value)
                Else
                    BuAus = "ja"
                End If
                If BuAus = "ja" Then
                    CmTyp.ListIndex = 0
                Else
                    CmTyp.ListIndex = 1
                End If
                Set RpCol = RpCl1.Find(Ban_KoBetrag)
                If IsNumeric(RpRow.Record(RpCol.ItemIndex).Value) = True Then
                    BaBet = CDbl(RpRow.Record(RpCol.ItemIndex).Value)
                    If BuAus = "ja" Then 'Ausgabe mit Minuszeichen
                        BaBet = Mid$(BaBet, 2, Len(BaBet) - 1)
                    End If
                    If GeBet > 0 Then
                        TxBuB.Text = Format$(GeBet, GlWa1)
                    Else
                        TxBuB.Text = Format$(BaBet, GlWa1)
                    End If
                Else
                    TxBuB.Text = Format$(0, GlWa1)
                End If
                Set RpCol = RpCl1.Find(Ban_IDB)
                GeKto = RpRow.Record(RpCol.ItemIndex).Value
                For AktZa = 1 To UBound(GlGeK)
                    If GlGeK(AktZa, 0) = GeKto Then
                        GeKId = GlGeK(AktZa, 6)
                        Exit For
                    End If
                Next AktZa
                If GeKId > 0 Then
                    If CmGek.ListCount > 0 Then
                        CmGek.ListIndex = AktZa - 1
                    End If
                Else
                    CmGek.ListIndex = 0
                End If
                If GeKId = 0 Then
                    GeKId = 1 'WICHTIG!
                End If
                If GlBuc = False Then 'einfache Buchhaltung verwenden
                    For AktZa = 1 To UBound(GlSaK) 'Sachkonten mit Geldkontenzuordnung
                        If GlSaK(AktZa, 6) = GeKId Then
                            TmStr = GlSaK(AktZa, 1)
                            KtStH = GlSaK(AktZa, 2)
                            KtBeH = GlSaK(AktZa, 3)
                            Exit For
                        End If
                    Next AktZa
                    If BuAus = "ja" Then
                        TxKtH.Text = TmStr
                        TxNrH.Text = KtStH
                        TxBeH.Text = KtBeH
                    Else
                        TxKtS.Text = TmStr
                        TxNrS.Text = KtStH
                        TxBeS.Text = KtBeH
                    End If
                End If
                
                Set RpCol = RpCl1.Find(Ban_IDP)
                If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
