                    Set RS129 = DBCmRe1("qryKat08G", "@IdStr", TmGui)
                    If RS129.RecordCount > 0 Then
                        IdxNr = RS129.Fields("ID6").Value
                    End If
                    RS129.Close
                    Set RS129 = Nothing
                    
                    RS127.Fields("IDSub").Value = IdxNr
                    RS127.Fields("Kommentar").Value = vbNullString
                    RS127.Update
                End If
            End If
            RS127.MoveNext
            Loop Until RS127.EOF
        End If
        RS127.Close
        Set RS127 = Nothing
        DoEvents
    End If
    
'---
    
    DoEvents
    Unload frmStatus
    DoEvents
    
    If ImTyp = 3 Then
        TrLi2.Nodes.Clear
        GlNod = KeySt & KatNr
        K_GrLa
        KTree
        K_List
    Else
        K_List
    End If
        
    RS125.Close
    Set RS125 = Nothing
End If

Set CoDia = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo8 = Nothing

Set clFil = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_ExIm " & Err.Number
Exit Sub

End Sub
Public Sub K_GrLa()
On Error GoTo FiErr
'Lädt das Arry für die Gebührenkataloge neu

Dim TreKy As String
Dim AktZa As Integer
Dim GesZa As Integer

TreKy = Left$(GlNod, 1)

If TreKy = "A" Or TreKy = "D" Then   'Gebührenkataloge
    AktZa = 1
    ReDim GlGKa(0)
    Set RS151 = New ADODB.Recordset
    With RS151
        .CursorLocation = adUseClient
        .Source = "qryKatVers"
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdTableDirect
    End With
    GesZa = RS151.RecordCount
    If GesZa > 0 Then
        ReDim GlGKa(GesZa, 5)
        Do
        GlGKa(AktZa, 0) = RS151.Fields("ID3").Value
        If RS151.Fields("Versicherer").Value <> vbNullString Then
            GlGKa(AktZa, 1) = RS151.Fields("Versicherer").Value
        Else
            GlGKa(AktZa, 1) = vbNullString
        End If
        If RS151.Fields("IDV").Value <> vbNullString Then
            GlGKa(AktZa, 2) = RS151.Fields("IDV").Value
        Else
            GlGKa(AktZa, 2) = vbNullString
        End If
        If RS151.Fields("Farbe").Value <> vbNullString Then
            GlGKa(AktZa, 3) = RS151.Fields("Farbe").Value
        Else
            GlGKa(AktZa, 3) = vbBlack
        End If
        If RS151.Fields("IDKey").Value <> vbNullString Then
            GlGKa(AktZa, 4) = RS151.Fields("IDKey").Value
        Else
            GlGKa(AktZa, 4) = vbNullString
        End If
        AktZa = AktZa + 1
        RS151.MoveNext
        Loop Until RS151.EOF
    Else
        ReDim GlGKa(30, 4)
        For AktZa = 1 To 30
            GlGKa(AktZa, 0) = AktZa
            GlGKa(AktZa, 1) = "Katalog " & AktZa
            GlGKa(AktZa, 2) = AktZa
            GlGKa(AktZa, 3) = vbBlack
            GlGKa(AktZa, 4) = vbNullString
        Next AktZa
    End If
    RS151.Close
    Set RS151 = Nothing
ElseIf TreKy = "C" Or TreKy = "F" Then 'Diagnosekataloge
    AktZa = 1
    ReDim GlDia(0)
    Set RS151 = New ADODB.Recordset
    With RS151
        .CursorLocation = adUseClient
        .Source = "qryKat03"
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdTableDirect
    End With
    GesZa = RS151.RecordCount
    If GesZa > 0 Then
        ReDim GlDia(GesZa, 2)
        Do Until RS151.EOF
        GlDia(AktZa, 0) = RS151.Fields("ID3").Value
        GlDia(AktZa, 1) = RS151.Fields("IDKurz").Value
        AktZa = AktZa + 1
        RS151.MoveNext
        Loop
    Else
        ReDim GlDia(1, 2)
        GlDia(1, 0) = 1
        GlDia(1, 1) = " Meine Diagnoseauswahl"
    End If
    RS151.Close
    Set RS151 = Nothing
ElseIf TreKy = "I" Or TreKy = "J" Then 'Arzneigruppen
    AktZa = 1
    ReDim GlMed(0)
    Set RS153 = New ADODB.Recordset '
    With RS153
        .CursorLocation = adUseClient
        .Source = "qryKat04"
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdTableDirect
    End With
    GesZa = RS153.RecordCount
    If GesZa > 0 Then
        ReDim GlMed(GesZa, 2)
        Do Until RS153.EOF
        GlMed(AktZa, 0) = RS153.Fields("ID3").Value
        GlMed(AktZa, 1) = RS153.Fields("IDKurz").Value
        AktZa = AktZa + 1
        RS153.MoveNext
        Loop
    Else
        ReDim GlMed(1, 2)
        GlMed(1, 0) = 1
        GlMed(1, 1) = " Meine Arzneiauswahl"
    End If
    RS153.Close
    Set RS153 = Nothing
ElseIf TreKy = "G" Or TreKy = "H" Then 'Laborkataloge
    AktZa = 1
    ReDim GlLab(0)
    Set RS151 = New ADODB.Recordset
    With RS151
        .CursorLocation = adUseClient
        .Source = "qryKat09"
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdTableDirect
    End With
    GesZa = RS151.RecordCount
    If GesZa > 0 Then
        ReDim GlLab(GesZa, 2)
        Do Until RS151.EOF
        GlLab(AktZa, 0) = RS151.Fields("ID3").Value
        GlLab(AktZa, 1) = RS151.Fields("IDKurz").Value
        AktZa = AktZa + 1
        RS151.MoveNext
        Loop
    Else
        ReDim GlLab(1, 2)
        GlLab(1, 0) = 6
        GlLab(1, 1) = "Laborkatalog"
    End If
    RS151.Close
    Set RS151 = Nothing
ElseIf TreKy = "K" Then 'Begründungen
    Exit Sub
ElseIf TreKy = "L" Then 'Anamnesetexte
    AktZa = 1
    ReDim GlAnG(0) 'Fragebogengruppen
    Set RS151 = New ADODB.Recordset
    With RS151
        .CursorLocation = adUseClient
        .Source = "qryKat05"
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdTableDirect
    End With
    GesZa = RS151.RecordCount
    If GesZa > 0 Then
        ReDim GlAnG(GesZa, 2)
        Do Until RS151.EOF
        GlAnG(AktZa, 0) = RS151.Fields("ID3").Value
        GlAnG(AktZa, 1) = RS151.Fields("IDKurz").Value
        AktZa = AktZa + 1
        RS151.MoveNext
        Loop
    Else
        ReDim GlAnG(1, 2)
        GlAnG(1, 0) = 6
        GlAnG(1, 1) = "Fragebogengruppe"
    End If
    RS151.Close
    Set RS151 = Nothing
ElseIf TreKy = "M" Then 'Terminbetreffs
    Exit Sub
ElseIf TreKy = "N" Then 'Fragebogen
    AktZa = 1
    ReDim GlFrB(0)
    Set RS151 = New ADODB.Recordset
    With RS151
        .CursorLocation = adUseClient
        .Source = "qryKat10"
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdTableDirect
    End With
    GesZa = RS151.RecordCount
    GlBoV = GesZa
    If GesZa > 0 Then
        ReDim GlFrB(GesZa, 4)
        Do Until RS151.EOF
        GlFrB(AktZa, 0) = RS151.Fields("ID3").Value
        GlFrB(AktZa, 1) = RS151.Fields("IDKurz").Value
        GlFrB(AktZa, 2) = RS151.Fields("GuiID").Value
        GlFrB(AktZa, 3) = RS151.Fields("Weblink").Value
        GlFrB(AktZa, 4) = RS151.Fields("WebID").Value
        AktZa = AktZa + 1
        RS151.MoveNext
        Loop
    Else
        ReDim GlFrB(1, 3)
        GlFrB(1, 0) = 1
        GlFrB(1, 1) = "Fragebogengruppe"
    End If
    RS151.Close
    Set RS151 = Nothing
ElseIf TreKy = "O" Then 'Textphrasen
    Exit Sub
ElseIf TreKy = "P" Or TreKy = "Q" Then 'Artikelgruppen
    AktZa = 1
    ReDim GlArt(0)
    Set RS153 = New ADODB.Recordset '
    With RS153
        .CursorLocation = adUseClient
        .Source = "qryKat12"
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdTableDirect
    End With
    GesZa = RS153.RecordCount
    If GesZa > 0 Then
        ReDim GlArt(GesZa, 2)
        Do Until RS153.EOF
        GlArt(AktZa, 0) = RS153.Fields("ID3").Value
        GlArt(AktZa, 1) = RS153.Fields("IDKurz").Value
        AktZa = AktZa + 1
        RS153.MoveNext
        Loop
    Else
        ReDim GlArt(1, 2)
        GlArt(1, 0) = 1
        GlArt(1, 1) = "_Meine Artikelauswahl"
    End If
    RS153.Close
    Set RS153 = Nothing
End If

Exit Sub

FiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_GrLa " & Err.Number
Resume Next

End Sub
Public Sub K_GrLo()
On Error GoTo LiErr
'Löscht eine Gruppe

Dim SQL1 As String
Dim TreKy As String
Dim IdxNr As Long
Dim Frage As Integer
Dim Mld1, Tit1 As String

Set FM = frmMain
Set TrLi2 = FM.trvList2

Tit1 = "Gruppe Entfernen"
Mld1 = "Möchten Sie diesen Katalog wirklich löschen?"
IdxNr = Mid$(GlNod, 2, Len(GlNod) - 1)

If GlRch(0, 19) = 0 Then
    WindowMess "Sie besitzen keine Berechtigung für diesen Vorgang", Dial3, Tit1, FM.hwnd
    Exit Sub
End If

If IdxNr = 0 Then Exit Sub

TreKy = Left$(GlNod, 1)

Select Case TreKy
Case "A": SQL1 = "qryKat01Lo" 'Gebührenkataloge
Case "C": SQL1 = "qryKat03Lo" 'Diagnosekataloge
Case "D": SQL1 = "qryKat01Lo" 'Gebührenketten
Case "F": SQL1 = "qryKat03Lo" 'Diagnoseketten
