If ChAdr.Value = xtpChecked Then
    AdrVe = True
End If

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        If RpRow.Record(17).Value <> vbNullString Then
            PatNr = RpRow.Record(17).Value '[ID0]
            If PatNr = 0 Then
                Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
                If Frage = 6 Then
                    TmGui = CreateID("A")
                    VerNr = Left$(RpRow.Record(3).Value, 1)
                    PaGes = RpRow.Record(4).Value
                    PaVor = RpRow.Record(5).Value
                    PaNam = RpRow.Record(6).Value
                    PaGeb = RpRow.Record(7).Value
                    PaEma = RpRow.Record(8).Value
                    PaTel = RpRow.Record(9).Value
                    PaPLZ = RpRow.Record(10).Value
                    PaOrt = RpRow.Record(11).Value
                    PaStr = RpRow.Record(12).Value
                    PaLan = RpRow.Record(13).Value
                    ReGes = RpRow.Record(21).Value 'WICHTIG! ab 21
                    ReVor = RpRow.Record(22).Value
                    ReNam = RpRow.Record(23).Value
                    ReGeb = RpRow.Record(24).Value
                    ReStr = RpRow.Record(25).Value
                    RePLZ = RpRow.Record(26).Value
                    ReOrt = RpRow.Record(27).Value
                    
                    If ReGes = "-" Then ReGes = PaGes
                    If ReGeb = "-" Then ReGeb = PaGeb
                    If ReVor = "-" Then ReVor = PaVor
                    If ReNam = "-" Then ReNam = PaNam
                    If ReStr = "-" Then ReStr = PaStr
                    If RePLZ = "-" Then RePLZ = PaPLZ
                    If ReOrt = "-" Then ReOrt = PaOrt

                    If ReGes = vbNullString Then ReGes = PaGes
                    If ReGeb = vbNullString Then ReGeb = PaGeb
                    If ReVor = vbNullString Then ReVor = PaVor
                    If ReNam = vbNullString Then ReNam = PaNam
                    If ReStr = vbNullString Then ReStr = PaStr
                    If RePLZ = vbNullString Then RePLZ = PaPLZ
                    If ReOrt = vbNullString Then ReOrt = PaOrt

                    Select Case GlAdK 'Format der Adressenkurzbezeichnung
                    Case 0:
                        If PaGeb <> vbNullString Then
                            If IsDate(PaGeb) = True Then
                                PaKur = PaNam & ", " & PaVor & ", (" & Format$(PaGeb, "dd.mm.yyyy") & ")"
                            Else
                                PaKur = PaNam & ", " & PaVor
                            End If
                        End If
                    Case 1:
                        PaKur = PaNam & ", " & PaVor
                    Case 2:
                        If PaOrt <> vbNullString Then
                            PaKur = PaNam & ", " & PaVor & ", (" & PaOrt & ")"
                        Else
                            PaKur = PaNam & ", " & PaVor
                        End If
                    End Select

                    If LCase(Left$(PaGes, 1)) = "m" Then
                        GeTyp = 2
                        Gesch = "männlich"
                        PaAnr = "Herrn"
                        PaBrf = "Sehr geehrter Herr " & PaNam
                    ElseIf LCase(Left$(PaGes, 1)) = "w" Then
                        GeTyp = 3
                        Gesch = "weiblich"
                        PaAnr = "Frau"
                        PaBrf = "Sehr geehrte Frau " & PaNam
                    Else
                        GeTyp = 1
                        Gesch = "weiblich"
                        PaAnr = "Frau"
                        PaBrf = "Sehr geehrte Frau " & PaNam
                    End If
                    
                    If LCase(Left$(ReGes, 1)) = "m" Then
                        ReAnr = "Herrn"
                        ReBrf = "Sehr geehrter Herr " & PaNam
                    ElseIf LCase(Left$(ReGes, 1)) = "w" Then
                        ReAnr = "Frau"
                        ReBrf = "Sehr geehrte Frau " & PaNam
                    Else
                        ReAnr = "Frau"
                        ReBrf = "Sehr geehrte Frau " & PaNam
                    End If

                    If Adr_Dop(PaKur) = True Then 'Adresse bereits vorhanden?
                        Frage = WindowMess(Mld2, Dial1, Tit1, FM.hwnd)
                        If Frage = 6 Then
                            DoSav = True
                        End If
                    Else
                        DoSav = True
                    End If

                    If DoSav = True Then
                        Set RS100 = New ADODB.Recordset
                        With RS100
                            .CursorLocation = adUseClient
                            .Source = "qryAdrNeu"
                            .ActiveConnection = DB1
                            .CursorType = adOpenKeyset
                            .LockType = adLockOptimistic
                            .Open Options:=adCmdTableDirect
                        End With
                        If RS100.Supports(adAddNew) Then
                            AdPIN = Adr_Let()
                            DoEvents
                        
                            RS100.AddNew
                            RS100.Fields("Anrede").Value = PaAnr
                            RS100.Fields("Vorname").Value = PaVor
                            RS100.Fields("Name").Value = PaNam
                            RS100.Fields("Straße").Value = PaStr
                            RS100.Fields("PLZ").Value = PaPLZ
                            RS100.Fields("Ort").Value = PaOrt
                            RS100.Fields("Land").Value = PaLan
                            RS100.Fields("Geboren").Value = PaGeb
                            RS100.Fields("Briefanrede").Value = PaBrf
                            RS100.Fields("IDKurz").Value = PaKur
                            RS100.Fields("Telefon1").Value = PaTel
                            RS100.Fields("Telefon5").Value = PaEma
                            RS100.Fields("R_Anrede").Value = ReAnr
                            RS100.Fields("R_Vorname").Value = ReVor
                            RS100.Fields("R_Name").Value = ReNam
                            RS100.Fields("R_Straße").Value = ReStr
                            RS100.Fields("R_PLZ").Value = RePLZ
                            RS100.Fields("R_Ort").Value = ReOrt
                            RS100.Fields("R_Land").Value = PaLan
                            RS100.Fields("R_Geboren").Value = ReGeb
                            RS100.Fields("R_Briefanrede").Value = ReBrf
                            RS100.Fields("Datum").Value = Date
                            RS100.Fields("Geändert").Value = Date
                            RS100.Fields("GuiID").Value = TmGui
                            RS100.Fields("Kopien").Value = GlKop
                            RS100.Fields("ID3").Value = GlGKa(GlStK, 0) 'Standardgebührenkatalog
                            RS100.Fields("IDZ").Value = GlZah(GlStZ, 0) 'Standardzahlungsziel
                            RS100.Fields("IDP").Value = GlMan(GlSMa, 2)
                            RS100.Fields("Geschlecht").Value = Gesch
                            RS100.Fields("GeschlTyp").Value = GeTyp
                            RS100.Fields("Abteilung").Value = VerNr
                            RS100.Fields("Versicherung").Value = "Adresse des Leistungsträgers"
                            If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                                RS100.Fields("Replicated").Value = 1
                                RS100.Fields("DAVChange").Value = 1
                                RS100.Fields("LastModification").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                                RS100.Fields("DAVDate").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                            Else
                                RS100.Fields("Replicated").Value = 0
                                RS100.Fields("DAVChange").Value = 0
                            End If
                            RS100.Fields("Mandant").Value = Format$(AdPIN, "000000")
                            RS100.Update
                        End If
                        RS100.Close
                        Set RS100 = Nothing
                        DoEvents

                        Adr_Er1 TmGui
                        DoEvents

                        PatNr = S_AdGui(TmGui, "ID0")
                        PaKur = S_AdGui(TmGui, "IDKurz")
                        DoEvents
                                                                        
                        RpRow.Record(16).Value = PaKur
                        RpRow.Record(17).Value = PatNr
                        RpCo1.Populate
                        DoEvents
                    End If
                End If
            End If
        Else
            SPopu "Neuer Patient", "Es wurde bereits ein Patient zugeordnet.", IC48_Forbidden
        End If
    End If
Else
    SPopu "Neuer Patient", "Es wurde kein Fragebogenbericht markiert,", IC48_Forbidden
End If
DoEvents

If DoSav = True Then
    GlNeK = GlKoX 'Protokolleintrag
    With GlNeK
        .PatNr = PatNr
        .IdxNr = 0
        .EiDat = Format$(Date, "dd.mm.yyyy")
        .EiZei = TimeValue(Now)
        .EiTyp = 104
        .TeStr = "Adresse hinzugefügt - " & PaKur
        .ZiStr = Format$(Now, "hh:mm") & " Uhr"
        .NeuEi = True
        .KeiAk = True
        .Mitar = GlMiA(GlSmI, 2)
    End With
    S_Prot
    SPopu "Adresse hinzugefügt", "Adresse hinzugefügt - " & PaKur, IC48_Information
End If

Set RpSel = Nothing
Set RpCo1 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "F_An3 " & Err.Number
Resume Next

End Sub
Public Sub F_An4()
On Error GoTo LiErr
'Aktualisiert oder übernimmt die neuen Adressendaten

Dim PatNr As Long
Dim AdVer As Long
Dim SQL1 As String
Dim AdGui As String
Dim Gesch As String
Dim PaGes As String
Dim PaNam As String
Dim PaGeb As String
Dim PaVor As String
Dim PaAnr As String
Dim PaTel As String
Dim PaEma As String
Dim PaStr As String
Dim PaPLZ As String
Dim PaOrt As String
Dim PaLan As String
Dim AdKur As String
Dim TmStr As String
Dim PaVer As Integer
Dim PaTyp As Integer
Dim RpRow As XtremeReportControl.ReportRow
Dim RpRws As XtremeReportControl.ReportRows
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmZuord
Set RpCo1 = FM.repCont1
Set RpRws = RpCo1.Rows

For Each RpRow In RpRws
    If RpRow.GroupRow = False Then
        If RpRow.Record(19).CheckboxState = 0 Then 'Wenn nicht gelöscht werden soll
            If RpRow.Record(17).Value <> vbNullString Then
                PatNr = RpRow.Record(17).Value '[ID0]
                If PatNr > 0 Then
                    PaVer = Left$(RpRow.Record(3).Value, 1)
                    PaGes = Trim$(RpRow.Record(4).Value)
                    PaVor = Trim$(RpRow.Record(5).Value)
                    PaNam = Trim$(RpRow.Record(6).Value)
                    PaGeb = Trim$(RpRow.Record(7).Value)
                    PaEma = Trim$(RpRow.Record(8).Value)
                    PaTel = Trim$(RpRow.Record(9).Value)
                    PaPLZ = Trim$(RpRow.Record(10).Value)
                    PaOrt = Trim$(RpRow.Record(11).Value)
                    PaStr = Trim$(RpRow.Record(12).Value)
                    PaLan = Trim$(RpRow.Record(13).Value)
                    If RpRow.Record(20).Value <> vbNullString Then
                        TmStr = RpRow.Record(20).Value
                    End If
                    If PaVer = 0 Then
                        PaVer = 1
                    End If
                        
                    If LCase(Left$(PaGes, 1)) = "m" Then
                        PaTyp = 2
                        Gesch = "männlich"
                        PaAnr = "Herrn"
                    ElseIf LCase(Left$(PaGes, 1)) = "w" Then
                        PaTyp = 3
                        Gesch = "weiblich"
                        PaAnr = "Frau"
                    Else
                        PaTyp = 1
                        Gesch = "weiblich"
                        PaAnr = "Frau"
                    End If

                    S_AdDe PatNr 'Adressendetails
                    With GlADt
                        AdVer = .AdVty
                        AdGui = .AdGui
                        AdKur = .AdKur
                    End With
                    DoEvents

                    If GlTyp < 2 Then
                        SQL1 = "SELECT * FROM dbo.qryAdress WHERE ID0 = " & PatNr
                    Else
                        SQL1 = "SELECT * FROM qryAdress WHERE [ID0] = " & PatNr & ";"
                    End If
                    Set RS114 = New ADODB.Recordset
                    With RS114
                        .CursorLocation = adUseClient
                        .Source = SQL1
                        .ActiveConnection = DB1
                        .CursorType = adOpenKeyset
                        .LockType = adLockOptimistic
                        .Open Options:=adCmdText
                    End With
                    If RS114.RecordCount > 0 Then
                        If RS114.Supports(adUpdate) Then

                            If Mid$(TmStr, 1, 1) = "1" Then
                                RS114.Fields("Vorname").Value = PaVor
                            End If
                            If Mid$(TmStr, 2, 1) = "1" Then
                                RS114.Fields("Name").Value = PaNam
                            End If
                            If Mid$(TmStr, 3, 1) = "1" Then
                                RS114.Fields("Geboren").Value = PaGeb
                            End If
                            If Mid$(TmStr, 4, 1) = "1" Then
                                RS114.Fields("Straße").Value = PaStr
                            End If
                            If Mid$(TmStr, 5, 1) = "1" Then
                                RS114.Fields("PLZ").Value = PaPLZ
                            End If
                            If Mid$(TmStr, 6, 1) = "1" Then
                                RS114.Fields("Ort").Value = PaOrt
                            End If
                            If Mid$(TmStr, 7, 1) = "1" Then
                                RS114.Fields("Land").Value = PaLan
                            End If
                            If Mid$(TmStr, 8, 1) = "1" Then
                                RS114.Fields("Telefon5").Value = PaEma
                            End If
                            If Mid$(TmStr, 9, 1) = "1" Then
                                RS114.Fields("Telefon1").Value = PaTel
                            End If
                            If Mid$(TmStr, 10, 1) = "1" Then
                                RS114.Fields("Geschlecht").Value = Gesch
                                RS114.Fields("GeschlTyp").Value = PaTyp
                            End If
                            If Mid$(TmStr, 11, 1) = "1" Then
                                RS114.Fields("Abteilung").Value = PaVer
                            End If
                            RS114.Fields("Anrede").Value = PaAnr
                            RS114.Update
                            
                        End If
                    End If
                     RS114.Close
                    Set RS114 = Nothing
                    DoEvents
                    Adr_Er1 AdGui
                    DoEvents

                    GlNeK = GlKoX 'Protokolleintrag
                    With GlNeK
                        .PatNr = PatNr
                        .IdxNr = 0
                        .EiDat = Format$(Date, "dd.mm.yyyy")
                        .EiZei = TimeValue(Now)
                        .EiTyp = 104
                        .TeStr = "Adresse aktualisiert - " & AdKur
                        .ZiStr = Format$(Now, "hh:mm") & " Uhr"
                        .NeuEi = True
                        .KeiAk = True
                        .Mitar = GlMiA(GlSmI, 2)
                    End With
                    S_Prot
                    SPopu "Adresse aktualisiert", "Adresse aktualisiert - " & AdKur, IC48_Information

                End If
            End If
        End If
    End If
Next RpRow

Set RpSel = Nothing
Set RpCo1 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "F_An4 " & Err.Number
Resume Next

End Sub
