                                                RS121.Fields(FldNa).Value = Left$(FeInh, 50)
                                            Else
                                                RS121.Fields(FldNa).Value = FeInh
                                            End If
                                        End If
                                Case "Telefon4":
                                        If FeInh <> vbNullString Then
                                            If Len(FeInh) > 50 Then
                                                RS121.Fields(FldNa).Value = Left$(FeInh, 50)
                                            Else
                                                RS121.Fields(FldNa).Value = FeInh
                                            End If
                                        End If
                                Case "Telefon5":
                                        If FeInh <> vbNullString Then
                                            If Len(FeInh) > 50 Then
                                                RS121.Fields(FldNa).Value = Left$(FeInh, 50)
                                            Else
                                                RS121.Fields(FldNa).Value = FeInh
                                            End If
                                        End If
                                Case Else:
                                    If FeInh <> vbNullString Then
                                        If FldNa <> vbNullString Then
                                        
                                            RS121.Fields(FldNa).Value = FeInh
                                        End If
                                    End If
                                End Select
                            Case 1:
                                If Len(FeInh) > 7 Then
