                                Case "Diagnose":
                                    If TmDia <> vbNullString Then RS121.Fields(FldNa).Value = TmDia
                                Case "Geschlecht":
                                    RS121.Fields(FldNa).Value = FeInh
                                    RS121.Fields("Anrede").Value = TmAnr
                                Case "Entfernung":
                                Case "Briefanrede":
                                    If FeInh <> vbNullString Then
                                        If Len(FeInh) > 50 Then
                                            RS121.Fields(FldNa).Value = Left$(FeInh, 50)
                                        Else
                                            RS121.Fields(FldNa).Value = FeInh
                                        End If
                                    End If
                                Case "AbrTyp":
                                    If FeInh <> vbNullString Then
                                        RS121.Fields(FldNa).Value = Left$(FeInh, 10)
                                    End If
                                Case "Telefon1":
                                        If FeInh <> vbNullString Then
                                            If Len(FeInh) > 50 Then
