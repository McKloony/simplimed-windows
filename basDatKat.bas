                RS123.Fields("GesBetrag").Value = 0
            End If
            If GlNeK.Akont > 0 Then
                RS123.Fields("WVBetrag").Value = GlNeK.Akont
            Else
                RS123.Fields("WVBetrag").Value = 0
            End If
            RS123.Update
        Case RibTab_Bildmodul:
            If Len(GlNeK.TeStr) > 250 Then
                TeStr = Left$(LTrim$(GlNeK.TeStr), 250)
            Else
                TeStr = LTrim$(GlNeK.TeStr)
            End If
            RS123.Fields("Kommentar").Value = KoStr
            If GlNeK.TeStr <> vbNullString Then
                RS123.Fields("IDKurz").Value = TeStr
            End If
            RS123.Update
        Case RibTab_Abrechnung:
            RS123.Fields("Kommentar").Value = KoStr
            RS123.Fields("IDM").Value = GlNeK.Mitar
            RS123.Update
        End Select
    Else
        If Len(GlNeK.TeStr) > 250 Then
            TeStr = Left$(LTrim$(GlNeK.TeStr), 250)
        Else
            TeStr = LTrim$(GlNeK.TeStr)
        End If
        RS123.AddNew
        RS123.Fields("ID3").Value = SorNr
        RS123.Fields("ID0").Value = GlNeK.PatNr
        RS123.Fields("Kommentar2").Value = GlNeK.KoGui
        RS123.Fields("Währung").Value = FoWar
        RS123.Fields("ID1").Value = GlNeK.EiTyp
        RS123.Fields("Datum").Value = GlNeK.EiDat & Space$(1) & GlNeK.EiZei
        RS123.Fields("Druckdatum").Value = GlNeK.EiDat & Space$(1) & GlNeK.EiZei
        RS123.Fields("IDKurz").Value = TeStr
        RS123.Fields("Kommentar").Value = KoStr
        RS123.Fields("IDM").Value = GlNeK.Mitar
        If GlNeK.FoStr <> vbNullString Then
            RS123.Fields("Provision").Value = GlNeK.FoStr
        End If
        RS123.Update
        DoEvents
        RS123.Requery
    End If
End If

DoEvents
RS123.Close
Set RS123 = Nothing

If GlBut = RibTab_Krankenbla Or GlBut = RibTab_Abrechnung Then
    If GlNeK.KeiAk = False Then
        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            KrRow = RpRow.Index
            If GlNeK.NeuEi = True Then
                Select Case GlBut
                Case RibTab_Krankenbla: RetWe = S_KrPk(GlNeK.KoGui)
                Case RibTab_Abrechnung: RetWe = S_KrPo(GlNeK.KoGui)
                End Select
            Else
                Select Case GlBut
                Case RibTab_Krankenbla: SUpKr KrRow
                Case RibTab_Abrechnung: SUpAb RowNr, KrRow, GlNeK.KoGui
                End Select
            End If
        Else
            Select Case GlBut
            Case RibTab_Krankenbla: RetWe = S_KrPk(GlNeK.KoGui)
            Case RibTab_Abrechnung: RetWe = S_KrPo(GlNeK.KoGui)
            End Select
        End If
    End If
End If

Select Case GlBut
Case RibTab_Krankenbla: RpCoK.SetFocus
Case RibTab_Abrechnung: RpCo6.SetFocus
End Select

Set RpCls = Nothing
Set RpSle = Nothing
Set RpSel = Nothing
Set RpCo3 = Nothing
Set RpCo6 = Nothing
Set RpCoK = Nothing

GlAkt = False

K_Einf = True
Exit Function

LiErr:
K_Einf = False
If GlDbg = True Then MsgBox Err.Description, 48, "K_Einf " & Err.Number
On Error Resume Next
If Not RS123 Is Nothing Then
    If RS123.State = adStateOpen Then RS123.Close
    Set RS123 = Nothing
End If
If Not RS122 Is Nothing Then
    If RS122.State = adStateOpen Then RS122.Close
    Set RS122 = Nothing
End If
Set RpCls = Nothing
Set RpSle = Nothing
Set RpSel = Nothing
Set RpCo3 = Nothing
Set RpCo6 = Nothing
Set RpCoK = Nothing
GlAkt = False

End Function
Public Sub K_Eing(ByVal EngTy As Integer, Optional ByVal EiKli As Boolean = False, Optional ByVal EiIdx As Long = 0)
On Error GoTo LiErr
'Fügt Daten in das Krankenblatt ein

Dim RowNr As Long
Dim RowFi As Long
Dim PosNr As Long
Dim PatNr As Long
Dim ReNum As Long
Dim KetNr As Long
Dim KatNr As Long
Dim SorNr As Long
Dim IdxNr As Long
Dim MaNum As Long
