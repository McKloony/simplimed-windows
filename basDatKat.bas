Public Function ABDmRe1(ByVal Abfra As String, ByVal PaNam As String, ByVal PaWer As Variant) As ADODB.Recordset
On Error GoTo DaErr
'Öffnet eine Parameterabfrage und weißt diese einem Recordset zu

Dim AnzPo As Long

Set RS101 = New ADODB.Recordset
Set CM101 = New ADODB.Command

If GlMyp < 2 Then
    With CM101
        Set .ActiveConnection = DB2
        .CommandTimeout = 15
        .CommandType = adCmdStoredProc
        .CommandText = Abfra
        .Parameters.Refresh
        .Parameters(PaNam).Value = PaWer
        Set RS101 = .Execute(RecordsAffected:=AnzPo)
    End With
Else
    With CM101
        Set .ActiveConnection = DB2
        .CommandTimeout = 15
        .CommandType = adCmdText
        .CommandText = Abfra
        .Properties("Jet OLEDB:Stored Query") = True
        Set RS101 = .Execute(RecordsAffected:=AnzPo, Parameters:=PaWer)
    End With
End If

Set ABDmRe1 = RS101.Clone

RS101.Close
Set RS101 = Nothing

Exit Function

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "ABDmRe1 " & Err.Number
Resume Next

End Function
