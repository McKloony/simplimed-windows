        End If
        Set RpCol = RpCls.Find(Buh_Kommentar)
        Set RpCol = RpCls.Find(Buh_Ermittlung)
        If RpRow.Record(RpCol.ItemIndex).Checked = True Then
            ChErl.Value = xtpChecked
        End If
    Else
        TxKtS.Text = vbNullString
        TxBeS.Text = vbNullString
        TxBuB.Text = GlWa2
        CmSte.ListIndex = GlStS - 1
        CmTyp.ListIndex = 0
        CmGek.ListIndex = 0
        ChErl.Value = 0
        CmMan.ListIndex = GlSMa - 1
        CmMit.ListIndex = GlSmI - 1
    End If
End If

Set RpCls = Nothing
Set RpSel = Nothing
Set RpCo7 = Nothing

