    If GlKeN = True Then
        Select Case TreKy
        Case "D": SQL1 = "SELECT * FROM qryKet01a WHERE [ID1] = -1;" 'Gebührenketten
        Case "F": SQL1 = "SELECT * FROM qryKet03a WHERE [ID1] = -1;" 'Diagnoseketten
        Case "H": SQL1 = "SELECT * FROM qryKet02a WHERE [ID1] = -1;" 'Laborprofile
        Case "J": SQL1 = "SELECT * FROM qryKet04a WHERE [ID1] = -1;" 'Arzeikennetn
        Case "J": SQL1 = "SELECT * FROM qryKon02A WHERE [ID1] = -1;" 'Terminketten
        Case "Q": SQL1 = "SELECT * FROM qryKet12a WHERE [ID1] = -1;" 'Artikelketten
        End Select
    Else
        Select Case TreKy
        Case "D": SQL1 = "SELECT * FROM qryKet01a WHERE [ID1] = " & KetNr & ";" 'Gebührenketten
        Case "F": SQL1 = "SELECT * FROM qryKet03a WHERE [ID1] = " & KetNr & ";" 'Diagnoseketten
        Case "H": SQL1 = "SELECT * FROM qryKet02a WHERE [ID1] = " & KetNr & ";" 'Laborprofile
        Case "J": SQL1 = "SELECT * FROM qryKet04a WHERE [ID1] = " & KetNr & ";" 'Arzeikennetn
        Case "J": SQL1 = "SELECT * FROM qryKon02A WHERE [ID1] = " & KetNr & ";" 'Terminketten
        Case "Q": SQL1 = "SELECT * FROM qryKet12a WHERE [ID1] = " & KetNr & ";" 'Artikelketten
        End Select
    End If
End If

Set RS136 = New ADODB.Recordset
With RS136
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With

If GlKeN = True Then
    If RS136.Supports(adAddNew) Then
        RS136.AddNew
        If TreKy <> "R" Then
            RS136.Fields("ID3").Value = GrpNr
        End If
        RS136.Fields("GOID").Value = KetKu
        RS136.Fields("IDKurz").Value = KetNa
        RS136.Update
        KetNr = RS136.Fields("ID1").Value
        TxDum.Text = KetNr
    End If
Else
    If RS136.Supports(adUpdate) Then
        RS136.Fields("GOID").Value = KetKu
        RS136.Fields("IDKurz").Value = KetNa
        RS136.Update
    End If
End If

RS136.Close
Set RS136 = Nothing

If GlJet = True Then SDBSav

GlKeN = False

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "E_Sav " & Err.Number
Resume Next

End Sub
Public Sub E_Sor()
On Error GoTo LiErr
'Verschiebt den Eintrag in der Kette

Dim IdxNr As Long
Dim KeySt As String
Dim RoId1 As Integer
Dim RoId2 As Integer
Dim SorNr As Integer
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmKetten
Set RpCo5 = FM.repCont5
Set RpRws = RpCo5.Rows
Set RpCls = RpCo5.Columns
Set RpSel = RpCo5.SelectedRows

KeySt = Left$(GlNod, 1)

RpCo5.Populate
DoEvents

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    RoId1 = RpRow.Index
    For Each RpRow In RpRws
        If RpRow.GroupRow = False Then
            If RpRow.Record(Ket_IDA).Value <> vbNullString Then
                RoId2 = RpRow.Index
                If RoId2 <> RoId1 Then
                    IdxNr = RpRow.Record(Ket_IDA).Value '[IDA]
                    SorNr = SorNr + 1
                    Select Case KeySt
                    Case "D": DBCmEx2 "qryKet01S", "@IdSor", "@IdxNr", SorNr, IdxNr 'Leistungsketten
                    Case "F": DBCmEx2 "qryKet03S", "@IdSor", "@IdxNr", SorNr, IdxNr 'Diagnoseketten
                    Case "H": DBCmEx2 "qryKet02S", "@IdSor", "@IdxNr", SorNr, IdxNr 'Laborprofile
                    Case "J": DBCmEx2 "qryKet04S", "@IdSor", "@IdxNr", SorNr, IdxNr 'Arzneiketten
                    Case "R": DBCmEx2 "qryKon02S", "@IdSor", "@IdxNr", SorNr, IdxNr 'Terminketten
                    Case "Q": DBCmEx2 "qryKet12S", "@IdSor", "@IdxNr", SorNr, IdxNr 'Artikelketten
                    End Select
                End If
            End If
        End If
    Next RpRow
End If

Set RpSel = Nothing
Set RpRws = Nothing
Set RpCls = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "E_Sor " & Err.Number
Resume Next

End Sub
Public Sub F_Act(Optional ByVal Actua As Boolean = False)
On Error GoTo ReErr
'Speicher und Aktualisieren

Dim IdxNr As Long
Dim GesZa As Long
Dim SQL1 As String
Dim TmTag As String
Dim TypNr As Integer
Dim TxIdx As XtremeSuiteControls.FlatEdit
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmCom As XtremeCommandBars.CommandBarComboBox
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmFragen
Set CmBrs = FM.comBar02
Set TxIdx = FM.txtIdxNr
Set RpCo1 = FM.repCont1

Set CmCom = CmBrs.FindControl(CmCom, SY_SuCm1, , True)

TypNr = CmCom.ListIndex

If Actua = True Then
    RpCo1.Redraw
End If

If TxIdx.Text <> vbNullString Then
    If IsNumeric(TxIdx.Text) Then
        If CLng(TxIdx.Text) > 0 Then
            IdxNr = CLng(TxIdx.Text)
        Else
            IdxNr = 0
        End If
    Else
        IdxNr = 0
    End If
Else
    IdxNr = 0
End If

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qryKat08B WHERE IDSub = " & IdxNr & " ORDER BY Sorter" 'Fragebogen
Else
    SQL1 = "SELECT * FROM qryKat08B WHERE [IDSub] = " & IdxNr & " ORDER BY [Sorter];" 'Fragebogen
End If

Set RS129 = New ADODB.Recordset
With RS129
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With
GesZa = RS129.RecordCount

If GesZa > 0 Then
    If RS129.Supports(adUpdate) Then
        RS129.MoveFirst
        Set RpRcs = RpCo1.Records
        For Each RpRec In RpRcs
            For Each RpItm In RpRec
                If Left$(RpItm.Tag, 1) = "@" Then
                    TmTag = Mid$(RpItm.Tag, 2, Len(RpItm.Tag) - 1)
                    If RpItm.HasCheckbox = True Then
                        RS129.Fields(TmTag).Value = RpItm.Checked
                    Else
                        If RpItm.Value <> vbNullString Then
                            If TypNr = 3 Then 'Ankreuzfeld
                                If RpItm.Index = 2 Then
                                    If LCase(RpItm.Value) = "ja" Or LCase(RpItm.Value) = "nein" Then
                                        RS129.Fields(TmTag).Value = RpItm.Value
                                    Else
                                        SPopu "Falsche Antwortvorgabe", "Die Antworten für Ankreuzfelder sind auf 'Ja' oder 'Nein' begrenzt!", IC48_Forbidden
                                    End If
                                Else
                                    RS129.Fields(TmTag).Value = RpItm.Value
                                End If
                            Else
                                RS129.Fields(TmTag).Value = RpItm.Value
                            End If
                        End If
                    End If
                End If
            Next RpItm
            RS129.Update
            RS129.MoveNext
        Next RpRec
    End If
End If
RS129.Close
Set RS129 = Nothing

If GlJet = True Then SDBSav

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCo1 = Nothing

Exit Sub

ReErr:
If GlDbg = True Then MsgBox Err.Description, 48, "F_Act " & Err.Number
Resume Next
        
End Sub
Public Function F_An1() As Integer
On Error GoTo LiErr
'Befüllt das Grid mit den Fragebögen

Dim FrgNr As Long
Dim PatNr As Long
Dim BogNr As Long
Dim BoGui As String
Dim EmAdr As String
Dim PaVor As String
Dim PaNam As String
Dim PaGeb As String
Dim PaOrt As String
Dim PaLnd As String
Dim PaKur As String
Dim ReVor As String
Dim ReNam As String
Dim ReGeb As String
Dim ReOrt As String
Dim ReLnd As String
Dim SuStr As String
Dim BoTyp As String
Dim GesZe As Integer
Dim FraUn As Integer
Dim AnzDo As Integer

Dim VerNr As Integer
Dim RpCo1 As XtremeReportControl.ReportControl

Set FM = frmZuord
Set RpCo1 = FM.repCont1
Set RpRcs = RpCo1.Records

Set RS160 = FM.FoRST

GesZe = RS160.RecordCount

With RpCo1
    .EditItem Nothing, Nothing
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    If .Records.Count > 0 Then .Records.DeleteAll
    .Populate
End With

If GesZe > 0 Then
    RS160.MoveFirst
    Do
    PatNr = 0
    AnzDo = 0
    BoTyp = "F"
    BoGui = RS160.Fields("FormId").Value
    FrgNr = CLng(RS160.Fields("QuestionNumber").Value)
    SuStr = vbNullString
    PaKur = vbNullString
    BogNr = Val(S_AnBoF(BoGui, "ID3")) 'Fragebogennummer

    Select Case FrgNr
    Case 1: 'Datum
        Set RpRec = RpRcs.Add()
        If BogNr = 0 Then
            FraUn = FraUn + 1
            Set RpItm = RpRec.AddItem(vbNullString)
        Else
            Set RpItm = RpRec.AddItem(BoGui)
        End If
        If IsDate(RS160.Fields(5).Value) = True Then
            Set RpItm = RpRec.AddItem(Format$(RS160.Fields(5).Value, "dd.mm.yyyy"))
        Else
            Set RpItm = RpRec.AddItem(RS160.Fields(5).Value)
        End If
    Case 2: 'Uhrzeit
        If IsDate(RS160.Fields(5).Value) = True Then
            Set RpItm = RpRec.AddItem(Format$(RS160.Fields(5).Value, "hh:mm"))
        Else
            Set RpItm = RpRec.AddItem(RS160.Fields(5).Value)
        End If
    Case 3: 'Versicherungsstatus
        If RS160.Fields(5).Value <> vbNullString Then
            If IsNumeric(RS160.Fields(5).Value) = True Then
                VerNr = RS160.Fields(5).Value
            Else
                VerNr = 0
            End If
        Else
            VerNr = 0
        End If
        Set RpItm = RpRec.AddItem(VerNr)
    Case 4: 'Geschlecht
        If RS160.Fields(5).Value <> vbNullString Then
            Set RpItm = RpRec.AddItem(RS160.Fields(5).Value)
        Else
            Set RpItm = RpRec.AddItem(vbNullString)
        End If
    Case 5: 'Vorname
        If RS160.Fields(5).Value <> vbNullString Then
            PaVor = SUmw(RS160.Fields(5).Value, False, False, True)
        Else
            PaVor = vbNullString
        End If
        Set RpItm = RpRec.AddItem(PaVor)
    Case 6: 'Name
        If RS160.Fields(5).Value <> vbNullString Then
            PaNam = SUmw(RS160.Fields(5).Value, False, False, True)
        Else
            PaNam = vbNullString
        End If
        Set RpItm = RpRec.AddItem(PaNam)
    Case 7: 'Geburtsdatum
        If RS160.Fields(5).Value <> vbNullString Then
            If IsDate(RS160.Fields(5).Value) = True Then
                PaGeb = Format$(RS160.Fields(5).Value, "dd.mm.yyyy")
            Else
                PaGeb = vbNullString
            End If
        Else
            PaGeb = vbNullString
        End If
        Set RpItm = RpRec.AddItem(PaGeb)
    Case 8: 'Emailadresse
        If RS160.Fields(5).Value <> vbNullString Then
            EmAdr = RS160.Fields(5).Value
            Set RpItm = RpRec.AddItem(EmAdr)
        Else
            Set RpItm = RpRec.AddItem("Emailadresse")
        End If
    Case 9: 'Telefon
        If RS160.Fields(5).Value <> vbNullString Then
            Set RpItm = RpRec.AddItem(RS160.Fields(5).Value)
        Else
            Set RpItm = RpRec.AddItem(vbNullString)
        End If
    Case 10: 'PLZ
        If RS160.Fields(5).Value <> vbNullString Then
            Set RpItm = RpRec.AddItem(RS160.Fields(5).Value)
        Else
            Set RpItm = RpRec.AddItem(vbNullString)
        End If
    Case 11: 'Ort
        If RS160.Fields(5).Value <> vbNullString Then
            PaOrt = SUmw(RS160.Fields(5).Value, False, False, True)
        Else
            PaOrt = vbNullString
        End If
        Set RpItm = RpRec.AddItem(PaOrt)
    Case 12: 'Straße
        If RS160.Fields(5).Value <> vbNullString Then
            Set RpItm = RpRec.AddItem(RS160.Fields(5).Value)
        Else
            Set RpItm = RpRec.AddItem(vbNullString)
        End If
    Case 13: 'Land
        If RS160.Fields(5).Value <> vbNullString Then
            PaLnd = RS160.Fields(5).Value
        Else
            PaLnd = vbNullString
        End If
        Set RpItm = RpRec.AddItem(PaLnd)
        Set RpItm = RpRec.AddItem(RS160.Fields("FormSubmissionId").Value)
    Case 14: 'Dokumentenupload
        If RS160.Fields(5).Value <> vbNullString Then
            AnzDo = Val(RS160.Fields(5).Value)
        End If
        If AnzDo = 0 Then
            RpRec.Item(1).Icon = IC16_Folder_Close
        Else
            RpRec.Item(1).Icon = IC16_Folder_Paper
        End If
    Case 15: 'Warteliste
        Set RpItm = RpRec.AddItem(vbNullString)
        RpItm.HasCheckbox = True
        RpItm.Alignment = xtpAlignmentCenter
        RpItm.Editable = True
        If RS160.Fields(5).Value <> vbNullString Then
            If LCase(RS160.Fields(5).Value) = "true" Then
                RpItm.Checked = True
            ElseIf RS160.Fields(5).Value = "1" Then
                RpItm.Checked = True
            Else
                RpItm.Checked = False
            End If
        End If
    Case 16: 'Neuaufnahme oder Fragebogen
        If RS160.Fields(5).Value <> vbNullString Then
            BoTyp = RS160.Fields(5).Value
            If BoTyp = "N" Then
                FraUn = FraUn - 1
                RpRec.Item(0).Value = "FN"
            End If
        End If

        If PaNam <> vbNullString Then
            If PaVor <> vbNullString Then
                If PaGeb <> vbNullString Then
                    SuStr = PaNam & ", " & PaVor & ", (" & PaGeb & ")"
                ElseIf PaOrt <> vbNullString Then
                    SuStr = PaNam & ", " & PaVor & ", (" & PaOrt & ")"
                End If
            End If
        End If
        
        If SuStr <> vbNullString Then
            Set RS120 = New ADODB.Recordset
            RS120.CursorLocation = adUseClient
            Set RS120 = DBCmRe1("qrySimAdKur", "@IdStr", "%" & SuStr & "%")
            If RS120.RecordCount > 0 Then
                PatNr = RS120.Fields("ID0").Value
                PaKur = RS120.Fields("IDKurz").Value
            Else
                Set RS140 = New ADODB.Recordset
                RS140.CursorLocation = adUseClient
                Set RS140 = DBCmRe1("qrySimAdEma", "@IdStr", "%" & EmAdr & "%")
                If RS140.RecordCount > 0 Then
                    PatNr = RS140.Fields("ID0").Value
                    PaKur = RS140.Fields("IDKurz").Value
                End If
                RS140.Close
                Set RS140 = Nothing
            End If
            RS120.Close
            Set RS120 = Nothing
        End If

        If PatNr > 0 Then
            Set RpItm = RpRec.AddItem(PaKur) '16 Zuordnung
            Set RpItm = RpRec.AddItem(PatNr) '17 PatNr
            Set RpItm = RpRec.AddItem(0) '18 BogenNr
        Else
            Set RpItm = RpRec.AddItem("?") '16 Zuordnung
            Set RpItm = RpRec.AddItem(0) '17 PatNr
            Set RpItm = RpRec.AddItem(0) '18 BogenNr
        End If

        Set RpItm = RpRec.AddItem(vbNullString) '19 Löschen
        With RpItm
            .HasCheckbox = True
            .Alignment = xtpAlignmentCenter
            .Editable = True
        End With
        
        Set RpItm = RpRec.AddItem(vbNullString) '20 Übernehmen
    
    Case 17: 'R_Geschlecht (21)
        If RS160.Fields(5).Value <> vbNullString Then
            Set RpItm = RpRec.AddItem(RS160.Fields(5).Value)
        Else
            Set RpItm = RpRec.AddItem(vbNullString)
        End If
    Case 18: 'R_Vorname (22)
        If RS160.Fields(5).Value <> vbNullString Then
            ReVor = SUmw(RS160.Fields(5).Value, False, False, True)
        Else
            ReVor = vbNullString
        End If
        Set RpItm = RpRec.AddItem(ReVor)
    Case 19: 'R_Name (23)
        If RS160.Fields(5).Value <> vbNullString Then
            ReNam = SUmw(RS160.Fields(5).Value, False, False, True)
        Else
            ReNam = vbNullString
        End If
        Set RpItm = RpRec.AddItem(ReNam)
    Case 20: 'R_Geburtsdatum (24)
        If RS160.Fields(5).Value <> vbNullString Then
            If IsDate(RS160.Fields(5).Value) = True Then
                ReGeb = Format$(RS160.Fields(5).Value, "dd.mm.yyyy")
            Else
                ReGeb = vbNullString
            End If
        Else
            ReGeb = vbNullString
        End If
        Set RpItm = RpRec.AddItem(ReGeb)
    Case 21: 'R_Straße (25)
        If RS160.Fields(5).Value <> vbNullString Then
            Set RpItm = RpRec.AddItem(RS160.Fields(5).Value)
        Else
            Set RpItm = RpRec.AddItem(vbNullString)
        End If
    Case 22: 'R_PLZ (26)
        If RS160.Fields(5).Value <> vbNullString Then
            Set RpItm = RpRec.AddItem(RS160.Fields(5).Value)
        Else
            Set RpItm = RpRec.AddItem(vbNullString)
        End If
    Case 23: 'R_Ort (27)
        If RS160.Fields(5).Value <> vbNullString Then
            ReOrt = SUmw(RS160.Fields(5).Value, False, False, True)
        Else
            ReOrt = vbNullString
        End If
        Set RpItm = RpRec.AddItem(ReOrt)
    Case 24: 'R_Land (28)
        If RS160.Fields(5).Value <> vbNullString Then
            ReLnd = RS160.Fields(5).Value
        Else
            ReLnd = vbNullString
        End If
        Set RpItm = RpRec.AddItem(ReLnd)
    End Select

    RS160.MoveNext
    Loop Until RS160.EOF
End If

RpCo1.Populate

F_An1 = FraUn

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCo1 = Nothing

Exit Function

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "F_An1 " & Err.Number
Resume Next

End Function
