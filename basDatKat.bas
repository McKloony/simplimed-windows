Dim EinZu As Boolean
Dim MaEin As Boolean
Dim ResZu As Boolean
Dim FakPr As Boolean
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim Mld2, Mld3 As String
Dim LiVw1 As XtremeSuiteControls.ListView
Dim LiItm As XtremeSuiteControls.ListViewItem
Dim LiIts As XtremeSuiteControls.ListViewItems
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCoK As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo3 = FM.repCont3
Set RpCo4 = FM.repCont4
Set RpCo6 = FM.repCont6
Set RpCoK = FM.repContK
Set TxDa1 = FM.txtDatu1
Set TxAnz = FM.txtAnzal
Set TxMul = FM.txtMulti
Set TxEin = FM.txtEinze
Set CmMit = FM.cmbMitar
Set CmTyp = FM.cmbTypen
Set CmZif = FM.cmbZiffe
Set CmBez = FM.cmbBezei
Set DaPi4 = FM.dtpDatu4
Set TxDe7 = FM.txtDeta7
Set RpRws = RpCo3.Rows
Set RpCls = RpCo3.Columns
Set RpSel = RpCo3.SelectedRows

GlAkt = True
Mld3 = "Sie können auch Einträge in die Abrechnung einfügen, die nicht in einem der Kataloge hinteröegt sind. Evtl. haben Sie sich aber auch verschrieben."

Set clFen = New clsFenster
clFen.hwnd = frmMain.hwnd

CoIdx = CmTyp.ListIndex + 1
If IsDate(TxDa1.Text) Then
    EiDat = Format$(TxDa1.Text, "dd.mm.yyyy")
Else
    EiDat = Format$(DaPi4.Selection.Blocks(0).DateBegin, "dd.mm.yyyy")
End If

LabNr = GlLab(GlStL, 0) 'StandardLaborkatalog

Select Case GlReT 'Standardbelegtyp
Case "R": ReTyp = "R"
Case "V": ReTyp = "R"
Case "L": ReTyp = "L"
Case "A": ReTyp = "A"
Case "U": ReTyp = "R"
Case "M": ReTyp = "M"
Case "G": ReTyp = "G"
Case "I": ReTyp = "I"
Case Else: ReTyp = "R"
End Select

ReStu = CSng(GlStu(GlStS, 1))
If ReStu > 0 And ReStu < 1 Then
    ReStu = ReStu * 100
End If

Select Case EngTy
Case 1:
        If EiKli = True Then
            TmpSt = GlEi1(CmZif.ListIndex)
        Else
            TmpSt = CmZif.Text
        End If
        Posit = InStr(1, TmpSt, Chr$(32), 1)
        If Posit > 0 Then
            TmpSt = Left$(TmpSt, Posit - 1)
        End If
        If InStr(1, TmpSt, Chr$(44), 1) > 0 Then
            SuStr = Replace(TmpSt, Chr$(44), Chr$(46))
        Else
            SuStr = TmpSt
        End If
Case 2:
        If EiKli = True Then
            TmpSt = GlEi2(CmBez.ListIndex)
        Else
            TmpSt = CmBez.Text
        End If
        SuStr = TmpSt
Case 3:
        If IsNull(TxMul.Text) Then
            FeMul = CSng(Format$(1, GlWa1))
        ElseIf IsNumeric(TxMul.Text) = False Then
            FeMul = CSng(Format$(1, GlWa1))
        Else
            FeMul = CSng(Format$(TxMul.Text, GlWa1))
        End If
        If IsNull(TxEin.Text) Then
            FeEin = Format$(0, GlWa1)
        ElseIf IsNumeric(TxEin.Text) = False Then
            FeEin = Format$(0, GlWa1)
        Else
            FeEin = Format$(TxEin.Text, GlWa1)
        End If
        If IsNull(TxAnz.Text) Then
            FeAnz = 1
        ElseIf IsNumeric(TxAnz.Text) = False Then
            FeAnz = 1
        Else
            FeAnz = CInt(TxAnz.Text)
        End If
        If CmZif.Text <> vbNullString Then
            If EiKli = True Then
                TmpSt = GlEi1(CmZif.ListIndex)
            Else
                TmpSt = CmZif.Text
            End If
            Posit = InStr(1, TmpSt, Chr$(32), 1)
            If Posit > 0 Then
                TmpSt = Left$(TmpSt, Posit - 1)
            End If
            If InStr(1, TmpSt, ",", 1) > 0 Then
                SuStr = Replace(TmpSt, ",", ".")
            Else
                SuStr = TmpSt
            End If
            EngTy = 1
        Else
            If EiKli = True Then
                TmpSt = GlEi2(CmBez.ListIndex)
            Else
                TmpSt = CmBez.Text
            End If
            SuStr = TmpSt
            EngTy = 2
        End If
        MaEin = True
Case 4:
        SuStr = "-"
Case Else:
        Exit Sub
End Select

If SuStr <> vbNullString Then
    'Parameter der Rechnung auslesen
    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        RowNr = RpRow.Index
        If RpRow.GroupRow = False Then
            Set RpCol = RpCls.Find(Rec_ID0)
            PatNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_ID1)
            ReNum = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_ID3)
            KatNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_IDKurz)
            PaStr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_IDP)
            If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                MaNum = RpRow.Record(RpCol.ItemIndex).Value
            Else
                MaNum = GlMan(GlSMa, 2)
            End If
            Set RpCol = RpCls.Find(Rec_IDM)
            If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                MitNr = RpRow.Record(RpCol.ItemIndex).Value
            Else
                MitNr = GlMiA(GlSmI, 2)
            End If
            Set RpCol = RpCls.Find(Rec_IDO)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                ArzNr = RpRow.Record(RpCol.ItemIndex).Value
            Else
                ArzNr = 0
            End If
            Set RpCol = RpCls.Find(Rec_Betrag)
            ReBet = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_RechNr)
            ReStr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Faktor)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                WärFa = RpRow.Record(RpCol.ItemIndex).Value
            Else
                WärFa = 1
            End If
            Set RpCol = RpCls.Find(Rec_Wahrung)
            FoWär = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Selekt)
            ReAbg = CBool(RpRow.Record(RpCol.ItemIndex).Value)
            Set RpCol = RpCls.Find(Rec_Rabatt)
            ReRab = Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1)
        Else
            Exit Sub
        End If
    Else
        RowNr = 1
        PatNr = GlAdr
        KatNr = CLng(TxDe7.Text)
        MaNum = S_AdIdx(PatNr, "IDP")
        MitNr = GlMiA(GlSmI, 2)
        ReStr = S_ReVo(Date, ReTyp, MaNum, MitNr, GlReN)
        ReNum = K_ReNe(ReStr, Date, PatNr, 0, ReTyp, 0, 0, False, True, False, ArzNr)
        FoWär = 2
        WärFa = 1
        ReBet = 0
        ReAbg = False
        ReRab = 0
        DoEvents
        S_KrLi
    End If
    
    For AktZa = 1 To UBound(GlThe) 'Mandanten
        If MaNum = GlThe(AktZa, 0) Then
            MaStr = GlThe(AktZa, 13)
            Exit For
        End If
    Next AktZa
    WärFa = Round(WärFa, 2)
    
    If ReAbg = True Then 'Bei Bedarf neue Rechnung anlegen
        If GlAuR = True Then 'Neue Rechnung anlegen
            ReStr = S_ReVo(Date, ReTyp, MaNum, MitNr, GlReN)
            SMeFr "Rechnung Hinzufügen", "Soll jetzt eine neue Rechnung mit der Nummer: " & ReStr & " hinzugefügt werden?", "Die markierte Rechnung wurde bereits abgeschlossen! Soll nun eine neue Rechnung für den Mandanten: " & MaStr & " hinzugefügt werden?", "Bestätigen Sie mir Ja, um eine neue Rechnung für den Mandanten: " & MaStr & " und den Patienten: " & PaStr & " hinzuzufügen.", False, 0, False, FM.hwnd
            If GlMes = 33565 Then
                ReNum = K_ReNe(ReStr, Date, PatNr, 0, ReTyp, 0, 0, False, True, False, ArzNr)
                ReBet = 0
                ReAbg = False
                ReRab = 0
                DoEvents
                S_KrLi
            Else
                Set RpSel = Nothing
                Set RpRow = Nothing
                Set RpRws = Nothing
                Set RpCls = Nothing
                Set RpCo3 = Nothing
                Set RpCo4 = Nothing
                Set RpCo6 = Nothing
                Set RpCoK = Nothing
                Set clFen = Nothing
                GlAkt = False
                Exit Sub
            End If
        Else
            SMeFr "Einträge Einfügen", "Diese Rechnung wurde bereits abgeschlossen!", "Die Rechnung " & ReStr & " wurde bereits abgeschlossen. Um diese Rechnung zu verändern, muss diese zuerst entriegelt werden.", "Um eine Rechnung zu entriegeln markieren Sie diese bitte mit der rechten Maustaste und wählen die gleichnamige Funktion.", False, 1, True, FM.hwnd
            Set RpSel = Nothing
            Set RpRow = Nothing
            Set RpRws = Nothing
            Set RpCls = Nothing
            Set RpCo3 = Nothing
            Set RpCo4 = Nothing
            Set RpCo6 = Nothing
            Set RpCoK = Nothing
            Set clFen = Nothing
            GlAkt = False
            Exit Sub
        End If
    End If

    If GlTyp < 2 Then
        Select Case GlSoA 'Sortierung Datum
        Case 1: 'Datum Absteigend
            Select Case GlSoZ
            Case 3: SQL1 = "SELECT * FROM dbo.qrySimAbSav WHERE IDR = " & ReNum & " ORDER BY Sorter DESC, ID3 DESC" 'Sorter absteigend
            Case 4: SQL1 = "SELECT * FROM dbo.qrySimAbSav WHERE IDR = " & ReNum & " ORDER BY Sorter DESC, ID3" 'Sorter absteigend
            End Select
        Case 2: 'Datum Aufsteigend
            Select Case GlSoZ
            Case 3: SQL1 = "SELECT * FROM dbo.qrySimAbSav WHERE IDR = " & ReNum & " ORDER BY Sorter, ID3 DESC" 'Sorter aufsteigend
            Case 4: SQL1 = "SELECT * FROM dbo.qrySimAbSav WHERE IDR = " & ReNum & " ORDER BY Sorter, ID3" 'Sorter aufsteigend
            End Select
        End Select
    Else
        Select Case GlSoA 'Sortierung Datum
        Case 1: 'Datum Absteigend
            Select Case GlSoZ
            Case 3: SQL1 = "SELECT * FROM qrySimAbSav WHERE [IDR] = " & ReNum & " ORDER BY [Sorter] DESC, [ID3] DESC;" 'Sorter absteigend
            Case 4: SQL1 = "SELECT * FROM qrySimAbSav WHERE [IDR] = " & ReNum & " ORDER BY [Sorter] DESC, [ID3];" 'Sorter absteigend
            End Select
        Case 2: 'Datum Aufsteigend
            Select Case GlSoZ
            Case 3: SQL1 = "SELECT * FROM qrySimAbSav WHERE [IDR] = " & ReNum & " ORDER BY [Sorter], [ID3] DESC;" 'Sorter aufsteigend
            Case 4: SQL1 = "SELECT * FROM qrySimAbSav WHERE [IDR] = " & ReNum & " ORDER BY [Sorter], [ID3];" 'Sorter aufsteigend
            End Select
        End Select
    End If

    Set RS123 = New ADODB.Recordset
    With RS123
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With

    Set RS129 = New ADODB.Recordset
    RS129.CursorLocation = adUseClient
    Set RS129 = DBCmRe2("qrySimAbFil", "@IdxNr", "@IdDat", ReNum, EiDat)
    If RS129.RecordCount > 0 Then
        If RS129.Fields("ID3").Value <> vbNullString Then
            SorNr = RS129.Fields("ID3").Value
        Else
            SorNr = 0
        End If
    End If

    Select Case CoIdx
    Case 1: 'Diagnosen
            Set RS128 = New ADODB.Recordset
            RS128.CursorLocation = adUseClient
            Select Case EngTy
            Case 1: Set RS128 = DBCmRe2("qryKat03M", "@IdxNr", "@IdStr", 1, SuStr)
            Case 2: Set RS128 = DBCmRe2("qryKat03P", "@IdxNr", "@IdStr", 1, SuStr)
            End Select
            GesZa = RS128.RecordCount
            If GesZa > 0 Then
                If GlDau = True Then
                    DiaLa = True
                    DiRef = RS128.Fields("ID0").Value
                    CoStr = RS128.Fields("GOID").Value
                    KuStr = RS128.Fields("IDKurz").Value
                    If RS128.Fields("ID1").Value > 0 Then
                        DiGrp = RS128.Fields("ID1").Value
                    Else
                        DiGrp = 0
                    End If
                    DoEvents
                    DBCmEx7 "qrySimAbDiA4", "@PatNr", "@IdxNr", "@IdCod", "@IdStr", "@IdDat", "@IdGrp", "@IdRef", PatNr, ReNum, CoStr, KuStr, EiDat, DiGrp, DiRef
                Else
                    Select Case EngTy
                    Case 1: EiTex = RS128.Fields("GOID").Value
                            RS129.Filter = "[GONr] = '" & EiTex & "'"
                    Case 2: EiTex = RS128.Fields("IDKurz").Value
                            RS129.Filter = "[IDKurz] Like '*" & EiTex & "*'"
                    End Select
                    Tit1 = EiDat & " bereits belegt!"
                    Mld3 = EiTex & " existiert bereits am " & EiDat & "."
                    If RS129.RecordCount > 0 Then
                        SPopu Tit1, Mld3, IC48_Warning
                        EinZu = False
                    Else
                        EinZu = True
                    End If
                    RS129.Filter = adFilterNone
                    '---
                    If EinZu = True Then
                        KrGui = CreateID("K")
                        SorNr = SorNr + 1
                        RS123.AddNew
                        RS123.Fields("ID0").Value = PatNr
                        RS123.Fields("IDR").Value = ReNum
                        RS123.Fields("ID3").Value = SorNr
                        RS123.Fields("ID1").Value = CoIdx
                        RS123.Fields("RechNr").Value = "ICD10"
                        RS123.Fields("ID4").Value = RS128.Fields("ID0").Value
                        RS123.Fields("Datum").Value = EiDat & Space$(1) & TimeValue(Now)
                        RS123.Fields("Druckdatum").Value = EiDat & Space$(1) & TimeValue(Now)
                        RS123.Fields("GONr").Value = RS128.Fields("GOID").Value
                        RS123.Fields("IDKurz").Value = Left$(RS128.Fields("IDKurz").Value, 250)
                        RS123.Fields("Kommentar").Value = RS128.Fields("Zusatztext").Value
                        RS123.Fields("Kommentar2").Value = KrGui
                        If Not IsNull(RS128.Fields("PAD").Value) Then RS123.Fields("PAD").Value = RS128.Fields("PAD").Value
                        RS123.Fields("Währung").Value = FoWär
                        RS123.Fields("IDM").Value = CmMit.ItemData(CmMit.ListIndex)
                        If ReAbg = True Then RS123.Fields("Gedruckt").Value = -1
                        RS123.Update
                    End If
                End If
            Else
                Set RS124 = New ADODB.Recordset
                RS124.CursorLocation = adUseClient
                Set RS124 = DBCmRe2("qryKat03O", "@IdxNr", "@IdStr", 1, SuStr) 'Diagnoseketten
                GesZa = RS124.RecordCount
                If GesZa > 0 Then
                    KetNr = RS124.Fields("ID1").Value
                    Set RS125 = New ADODB.Recordset
                    RS125.CursorLocation = adUseClient
                    Set RS125 = DBCmRe1("qryKet03E", "@IdxNr", KetNr)
                    If RS125.RecordCount > 0 Then
                        Do
                        If GlDau = True Then
                            DiaLa = True
                            DiRef = RS125.Fields("ID0").Value
                            CoStr = RS125.Fields("GOID").Value
                            KuStr = RS125.Fields("IDKurz").Value
                            If RS125.Fields("ID1").Value > 0 Then
                                DiGrp = RS125.Fields("ID1").Value
                            Else
                                DiGrp = 0
                            End If
                            DBCmEx7 "qrySimAbDiA4", "@PatNr", "@IdxNr", "@IdCod", "@IdStr", "@IdDat", "@IdGrp", "@IdRef", PatNr, ReNum, CoStr, KuStr, EiDat, DiGrp, DiRef
                        Else
                            Select Case EngTy
                            Case 1: EiTex = RS125.Fields("GOID").Value
                                    RS129.Filter = "[GONr] = '" & EiTex & "'"
                            Case 2: EiTex = RS125.Fields("IDKurz").Value
                                    RS129.Filter = "[IDKurz] Like '*" & EiTex & "*'"
                            End Select
                            Tit1 = EiDat & " bereits belegt!"
                            Mld3 = EiTex & " existiert bereits am " & EiDat & "."
                            If RS129.RecordCount > 0 Then
                                SPopu Tit1, Mld3, IC48_Warning
                                EinZu = False
                            Else
                                EinZu = True
                            End If
                            RS129.Filter = adFilterNone
                            '---
                            If EinZu = True Then
                                KrGui = CreateID("K")
                                SorNr = SorNr + 1
                                RS123.AddNew
                                RS123.Fields("ID0").Value = PatNr
                                RS123.Fields("IDR").Value = ReNum
                                RS123.Fields("ID3").Value = SorNr
                                RS123.Fields("ID1").Value = CoIdx
                                RS123.Fields("RechNr").Value = "ICD10"
                                RS123.Fields("ID4").Value = RS125.Fields("ID0").Value
                                RS123.Fields("Datum").Value = EiDat & Space$(1) & TimeValue(Now)
                                RS123.Fields("Druckdatum").Value = EiDat & Space$(1) & TimeValue(Now)
                                RS123.Fields("GONr").Value = RS125.Fields("GOID").Value
                                RS123.Fields("IDKurz").Value = RS125.Fields("IDKurz").Value
                                RS123.Fields("Kommentar").Value = RS125.Fields("Zusatztext").Value
                                RS123.Fields("Kommentar2").Value = KrGui
                                If Not IsNull(RS125.Fields("PAD").Value) Then RS123.Fields("PAD").Value = RS125.Fields("PAD").Value
                                RS123.Fields("Währung").Value = FoWär
                                RS123.Fields("IDM").Value = CmMit.ItemData(CmMit.ListIndex)
                                If ReAbg = True Then RS123.Fields("Gedruckt").Value = -1
                                RS123.Update
                            End If
                        End If
                        RS125.MoveNext
                        Loop Until RS125.EOF
                    End If
                    RS125.Close
                    Set RS125 = Nothing
                Else
                    Tit1 = "Eintrag kann nicht gefunden werden"
                    Mld1 = SuStr & " kann im zugeordneten Katalog nicht gefunden werden, trotzdem einfügen?"
                    Mld2 = "Der von Ihnen eingegebene Eintrag " & SuStr & " könnte im Katalog nicht gefunden werden. Soll dieser trotzdem eingefügt werden?"
                    SMeFr Tit1, Mld1, Mld2, Mld3, False, 0, False, FM.hwnd
                    If GlMes = 33565 Then
                        KrGui = CreateID("K")
