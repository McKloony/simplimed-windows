With RS124
    .CursorLocation = adUseClient
    .Source = "qryTerNeu"
    .ActiveConnection = DB1
    .CursorType = adOpenStatic
    .LockType = adLockOptimistic
    .Open Options:=adCmdTableDirect
End With

If RS124.Supports(adAddNew) Then
    Do
    FldNa = vbNullString
    TypNr = 0
    If RS157.Fields("Feldkennung").Value <> vbNullString Then
        If RS157.Fields("Feldinhalt").Value <> vbNullString Then
            FeKen = RS157.Fields("Feldkennung").Value
            FeInh = Trim$(RS157.Fields("Feldinhalt").Value)

            Select Case FeInh
            Case "0085": 'Termminkalender
                RS157.MoveNext
                RS157.MoveNext
                FeKen = RS157.Fields("Feldkennung").Value
                FeInh = Trim$(RS157.Fields("Feldinhalt").Value)
                DoEvents
                '--------------------------------------------------------------------------------
                If RS157.AbsolutePosition > 0 Then
                    Do
                    RS157.MoveNext
                    If Not RS157.EOF Then
                        FldNa = vbNullString
                        TypNr = 0
                        FeKen = RS157.Fields("Feldkennung").Value
                        FeInh = Trim$(RS157.Fields("Feldinhalt").Value)
                        Select Case FeKen
                        Case 6200: 'Datum
                                TmDat = T_KoDa(CStr(FeInh), VerNu)
                                If IsDate(TmDat) = False Then
                                    TmDat = "01.01." & Year(Date)
                                ElseIf Year(TmDat) < 1900 Then
                                    TmDat = "02.01." & Year(Date)
                                ElseIf Year(TmDat) > Year(TmDat) + 5 Then
                                    TmDat = "03.01." & Year(Date)
                                End If
                                With RS124
                                    .AddNew
                                    .Fields("VonDat").Value = TmDat
                                    .Fields("BisDat").Value = TmDat
                                    .Fields("IDM").Value = GlMiA(GlSmI, 2)
                                    .Fields("IDP").Value = GlMan(GlSMa, 2)
                                    .Fields("IDR").Value = GlRmu(1, 0)
                                    .Fields("IDSer").Value = AktZa
                                End With
                        Case 6201: 'Von-Zeit
                                FldNa = "ZeiVon"
                                TypNr = 5
                        Case 6202: 'Bis-Zeit
                                FldNa = "ZeiBis"
                                TypNr = 5
                        Case 3000: 'Patientennummer
                                FldNa = "BDT_ID"
                                TypNr = 6
                        Case 7201: 'Name
                                FldNa = "Patient"
                                TypNr = 8
                        Case 7202: 'Text
                                FldNa = "IDKurz"
                                TypNr = 8
                        End Select
                        If FldNa <> vbNullString Then
                            Select Case TypNr
                            Case 5: 'Datum / Uhrzeit
                                RS124.Fields(FldNa).Value = T_KoZe(FeInh)
                            Case 6:
                                If IsNumeric(FeInh) = True Then
                                    RS124.Fields(FldNa).Value = CLng(FeInh)
                                Else
                                    RS124.Fields(FldNa).Value = Val(FeInh)
                                End If
                            Case 8:
                                If FeInh <> vbNullString Then
                                    RS124.Fields(FldNa).Value = FeInh
                                End If
                            End Select
                        End If
                    End If
                        
                    DoEvents
                    AktZa = AktZa + 1
                    If AktZa < GesZa Then PrBr1.Value = AktZa
                    If TxDum.Text = "B" Then Exit Do 'Abbrechen
                    Loop Until FeKen = 8000 Or AktZa > GesZa
                End If
                '--------------------------------------------------------------------------------
                RS124.Update
                RS157.MovePrevious

            End Select
            DoEvents
        End If
    End If

    AktZa = AktZa + 1
    If AktZa < GesZa Then PrBr2.Value = AktZa
    If TxDum.Text = "B" Then Exit Do 'Abbrechen
    RS157.MoveNext
    Loop Until RS157.EOF
