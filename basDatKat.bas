Public Sub E_Filt(ByVal FilTy As Integer, Optional ByVal SuStr As String, Optional ByVal SuPar As String)
On Error GoTo LiErr
'Weist GridEx eine bestimmte Filterung zu

Dim GesZa As Long
Dim IdxNr As Long
Dim SQL1 As String
Dim GrPre As Single
Dim TreKy As String
Dim GrCap As String
Dim LiGrp As Boolean
Dim GrAnz As Integer
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmKetten
Set RpCo4 = FM.repCont4
Set RpRcs = RpCo4.Records

TreKy = Left$(GlNod, 1)

IdxNr = Mid$(GlNod, 2, Len(GlNod) - 1)

If IdxNr = 0 Then Exit Sub

With RpCo4
    .EditItem Nothing, Nothing
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    If .Records.Count > 0 Then .Records.DeleteAll
    .Populate
End With

Set RS138 = New ADODB.Recordset
RS138.CursorLocation = adUseClient
If TreKy = "A" Or TreKy = "D" Then   'Gebührenkataloge
    Select Case FilTy
    Case 0: Set RS138 = DBCmRe1("qryKat01D", "@IdxNr", IdxNr)
    Case 1: Set RS138 = DBCmRe2("qryKat01N", "@IdxNr", "@IdStr", IdxNr, "%" & SuStr & "%")
    Case 2: Set RS138 = DBCmRe2("qryKat01M", "@IdxNr", "@IdStr", IdxNr, SuStr)
    Case 3: Set RS138 = DBCmRe2("qryKat01P", "@IdxNr", "@IdStr", IdxNr, SuPar & SuStr)
    Case 4: Set RS138 = DBCmRe2("qryKat01N", "@IdxNr", "@IdStr", IdxNr, SuStr & "%")
    Case 5: Set RS138 = DBCmRe1("qryKat01F", "@IdxNr", IdxNr)
    End Select
ElseIf TreKy = "C" Or TreKy = "F" Then 'Diagnosekataloge
    Select Case FilTy
    Case 0: Set RS138 = DBCmRe1("qryKat03Q", "@IdxNr", IdxNr)
    Case 1: Set RS138 = DBCmRe1("qryKat03D", "@IdStr", "%" & SuStr & "%")
    Case 2: Set RS138 = DBCmRe2("qryKat03M", "@IdxNr", "@IdStr", IdxNr, SuStr)
    Case 4: Set RS138 = DBCmRe2("qryKat03P", "@IdxNr", "@IdStr", IdxNr, SuStr & "%")
    Case 5: Set RS138 = DBCmRe1("qryKat03F", "@IdxNr", IdxNr)
    End Select
ElseIf TreKy = "G" Or TreKy = "H" Then 'Laborparameter
    Select Case FilTy
    Case 0: Set RS138 = DBCmRe1("qryKat02D", "@IdxNr", IdxNr)
    Case 1: Set RS138 = DBCmRe2("qryKat02N", "@IdxNr", "@IdStr", IdxNr, "%" & SuStr & "%")
    Case 2: Set RS138 = DBCmRe2("qryKat02M", "@IdxNr", "@IdStr", IdxNr, SuStr)
    Case 3: Set RS138 = DBCmRe2("qryKat02P", "@IdxNr", "@IdStr", IdxNr, SuPar & SuStr)
    Case 4: Set RS138 = DBCmRe2("qryKat02N", "@IdxNr", "@IdStr", IdxNr, SuStr & "%")
    Case 5: Set RS138 = DBCmRe1("qryKat02F", "@IdxNr", IdxNr)
    End Select
ElseIf TreKy = "I" Or TreKy = "J" Then 'Arzneimittel
    Select Case FilTy
    Case 0: Set RS138 = DBCmRe1("qryKat04G", "@IdxNr", IdxNr)
    Case 1: Set RS138 = DBCmRe1("qryKat04D", "@IdStr", "%" & SuStr & "%")
    Case 2: Set RS138 = DBCmRe2("qryKat04M", "@IdxNr", "@IdStr", IdxNr, SuStr)
    Case 3: Set RS138 = DBCmRe2("qryKat04P", "@IdxNr", "@IdStr", IdxNr, SuPar & SuStr)
    Case 4: Set RS138 = DBCmRe2("qryKat04N", "@IdxNr", "@IdStr", IdxNr, SuStr & "%")
    Case 5: Set RS138 = DBCmRe1("qryKat04F", "@IdxNr", IdxNr)
    End Select
ElseIf TreKy = "K" Or TreKy = "L" Then 'Begründungen / Anamnesetexte /
    Select Case FilTy
    Case 0: Set RS138 = DBCmRe1("qryKat02D", "@IdxNr", IdxNr)
    Case 1: Set RS138 = DBCmRe2("qryKat02N", "@IdxNr", "@IdStr", IdxNr, "%" & SuStr & "%")
    Case 2: Set RS138 = DBCmRe2("qryKat02M", "@IdxNr", "@IdStr", IdxNr, SuStr)
    Case 4: Set RS138 = DBCmRe2("qryKat02N", "@IdxNr", "@IdStr", IdxNr, SuStr & "%")
    Case 5: Set RS138 = DBCmRe1("qryKat02F", "@IdxNr", IdxNr)
    End Select
ElseIf TreKy = "M" Or TreKy = "R" Then 'Terminbetreffs
    Select Case FilTy
    Case 0: Set RS138 = DBCmRe0("qryKon01E")
    Case 1: Set RS138 = DBCmRe1("qryKon01B", "@IdStr", "%" & SuStr & "%")
    Case 2: Set RS138 = DBCmRe1("qryKon01C", "@IdMin", SuStr) 'Zeit
    Case 3: Set RS138 = DBCmRe1("qryKon01C", "@IdMin", SuStr) 'Zeit
    Case 4: Set RS138 = DBCmRe1("qryKon01B", "@IdStr", SuStr & "%")
    Case 5: Set RS138 = DBCmRe1("qryKon01C", "@IdMin", 0) 'Zeit
    End Select
ElseIf TreKy = "N" Then 'Fragebogen
    If GlTyp < 2 Then
        SQL1 = "SELECT * FROM dbo.qryKat08B ORDER BY Gruppe, Sorter"
    Else
        SQL1 = "SELECT * FROM qryKat08B ORDER BY [Gruppe], [Sorter];"
    End If
    Select Case FilTy
    Case 0: Set RS138 = DBCmRe1("qryKat08I", "@IdxNr", IdxNr)
    Case 1: Set RS138 = DBCmRe2("qryKat08E", "@IdxNr", "@IdStr", IdxNr, "%" & SuStr & "%")
    Case 2: Set RS138 = DBCmRe2("qryKat08E", "@IdxNr", "@IdStr", IdxNr, "%" & SuStr & "%")
    Case 4: Set RS138 = DBCmRe2("qryKat08E", "@IdxNr", "@IdStr", IdxNr, "%" & SuStr & "%")
    Case 5: Set RS138 = DBCmRe0(SQL1, True)
    End Select
End If

GesZa = RS138.RecordCount

If GesZa > 0 Then
    E_Rec RS138, TreKy
    RpCo4.Populate
    Set RpRws = RpCo4.Rows
    RpRws.Row(0).Selected = True
End If
RS138.Close
Set RS138 = Nothing

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpRws = Nothing
Set RpCo4 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "E_Filt " & Err.Number
Resume Next

End Sub
