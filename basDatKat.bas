Private Sub S_KtAn(ByVal PaFrm As String)
On Error GoTo LiErr
'Lädt den Kontenplan

Dim KtoNr As Long
Dim IdxNr As Long
Dim GesZa As Long
Dim KtoSt As String
Dim KoStr As String
Dim AktZa As Integer
Dim Lange As Integer
Dim FLis1 As XtremeSuiteControls.ListBox

Set RS127 = New ADODB.Recordset
RS127.CursorLocation = adUseClient
Set RS127 = DBCmRe1("qrySimBuKtR", "@IdxNr", GlKtR)
GesZa = RS127.RecordCount

If GesZa > 1 Then
    Set RS163 = New ADODB.Recordset 'neues Recordset erstellen
    With RS163
        .CursorLocation = adUseClient
        .CursorType = adOpenForwardOnly
        .LockType = adLockBatchOptimistic
    End With

    For Each FL101 In RS127.Fields
        RS163.Fields.Append FL101.Name, FL101.Type, FL101.DefinedSize
    Next FL101
    If RS163.State = adStateClosed Then RS163.Open
    
    Do Until RS127.EOF
        RS163.AddNew
        For Each FL101 In RS163.Fields
            If IsNull(RS127.Fields(FL101.Name).Value) = False Then
                If FL101.Name = "IDK" Then
                    If RS127.Fields("IDK").Value <> vbNullString Then
                        If RS127.Fields("IDK").Value > 0 Then
                            KtoNr = RS127.Fields("IDK").Value
                            KtoSt = SBuFo(KtoNr) 'Sachkontenformatierung
                            RS163.Fields("IDK").Value = KtoSt
                        End If
                    End If
                Else
                    RS163.Fields(FL101.Name).Value = RS127.Fields(FL101.Name).Value
                End If
            End If
        Next FL101
        RS127.MoveNext
    Loop
    RS163.UpdateBatch
    
    RS163.MoveFirst
    RS163.Sort = "IDK ASC"
    DoEvents

    Set FM = frmBuKoV
    FM.PaFrm = PaFrm
    Load FM
    DoEvents
    Set FLis1 = FM.lstList1
    FM.Show
    DoEvents

    AktZa = 0
    FLis1.Clear
    DoEvents

    Do Until RS163.EOF
    IdxNr = RS163.Fields("IDI").Value
    KtoNr = RS163.Fields("IDK").Value
    KoStr = RS163.Fields("IDKurz").Value
    KtoSt = SBuFo(KtoNr) 'Sachkontenformatierung
    FLis1.AddItem KtoSt & " " & KoStr
    FLis1.ItemData(AktZa) = IdxNr
    RS163.MoveNext
    AktZa = AktZa + 1
    Loop
    
    RS163.Close
    Set RS163 = Nothing
    
    DoEvents
    If FLis1.ListCount > 0 Then
        FLis1.Selected(0) = True
        FLis1.SetFocus
    End If
End If

RS127.Close
Set RS127 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KtAn " & Err.Number
Resume Next

End Sub
Public Sub S_KtCm()
