            ReSto = CBool(RS154.Fields("Storniert").Value)
        Else
            ReSto = False
        End If
        If RS154.Fields("Bezahlt").Value > 0 Then
            Diffe = RS154.Fields("Betrag").Value - RS154.Fields("Bezahlt").Value
