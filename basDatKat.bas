        DaSt2 = DatePart("yyyy", GlTag(1) + 1) & "-" & DatePart("m", GlTag(1) + 1) & "-" & DatePart("d", GlTag(1) + 1) & " 00:00:00"
    Else
        DaSt1 = DatePart("m", GlTag(1)) & "/" & DatePart("d", GlTag(1)) & "/" & DatePart("yyyy", GlTag(1))
    End If
    
    If GlTyp < 2 Then
        SQL1 = "SELECT * FROM dbo.qrySimAbSav WHERE ((ID0 = " & GlAdr & " ) AND (ID1 = 107) AND (Datum >= CONVERT(DATETIME, '" & DaSt1 & "', 102)) AND (Datum <= CONVERT(DATETIME, '" & DaSt2 & "', 102)))"
    Else
        SQL1 = "SELECT * FROM qrySimAbSav WHERE (([ID0] = " & GlAdr & " ) AND ([Datum] = #" & DaSt1 & "#) AND ([ID1] = 107));"
    End If
    
    Set RS120 = New ADODB.Recordset
    With RS120
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With
    If RS120.Supports(adAddNew) Then
        For AktPo = 0 To GesPo - 1
    
            If GlClp(AktPo, ABDA_Darreichung_Kurz) Like "Amp." Or GlClp(AktPo, ABDA_Darreichung_Kurz) Like "Ilo." Or GlClp(AktPo, ABDA_Darreichung_Kurz) Like "Pul." Or GlClp(AktPo, ABDA_Darreichung_Kurz) Like "Inf." Then
                Posit = InStr(1, GlClp(AktPo, ABDA_Menge), "X", 1)
                If Posit > 0 Then
                    Anzal = CInt(Mid$(GlClp(AktPo, ABDA_Menge), 1, Posit - 1))
                Else
                    Anzal = Val(GlClp(AktPo, ABDA_Menge))
                End If
                If GlClp(AktPo, ABDA_ApoPreis) > 0 Then
                    If Anzal > 0 Then
                        EiPre = CSng(GlClp(AktPo, ABDA_ApoPreis)) / Anzal
                    Else
                        EiPre = CSng(GlClp(AktPo, ABDA_ApoPreis))
                    End If
                Else
                    EiPre = 0
                End If
            Else
                EiPre = CSng(GlClp(AktPo, ABDA_ApoPreis))
            End If
    
            RS120.AddNew
            RS120.Fields("ID0").Value = GlAdr
            RS120.Fields("ID1").Value = 107
            RS120.Fields("Datum").Value = GlTag(1) & Space$(1) & TimeValue(Now)
            RS120.Fields("Druckdatum").Value = GlTag(1) & Space$(1) & TimeValue(Now)
            RS120.Fields("GONr").Value = Format$(GlClp(AktPo, ABDA_PZN), "0000000")
            RS120.Fields("Kommentar").Value = GlClp(AktPo, ABDA_IDLang) & " (PZN: " & Format$(GlClp(AktPo, ABDA_PZN), "0000000") & ")"
            RS120.Fields("Multi").Value = 1
            RS120.Fields("x").Value = 1
            RS120.Fields("Betrag").Value = EiPre
            RS120.Fields("GesBetrag").Value = EiPre
            RS120.Fields("Währung").Value = 1
            RS120.Update
        Next AktPo
    End If
    RS120.Close
    Set RS120 = Nothing
    
    DBCmEx0 "qryWarAbPos" 'Übertragen [ID2] auf [ID3]
End If

Erase GlClp
ClKop = False
DoEvents

RetWe = S_KrPk()

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "ABD_Kra " & Err.Number
Resume Next

End Sub
Public Sub ABD_Rez(ByVal GesPo As Long, Optional ByVal SamLi As Boolean = False)
On Error GoTo LiErr
'Fügt die markierten Produkte in das Rezept ein

Dim SQL1 As String
Dim AktPo As Long
Dim PatNr As Long
Dim RzNum As Long
Dim RowNr As Long
Dim TmStr As String
Dim MeTex As String
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo5 = FM.repCont5
Set RpRws = RpCo5.Rows
Set RpCls = RpCo5.Columns
Set RpSel = RpCo5.SelectedRows

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    RowNr = RpRow.Index
    If RpRow.GroupRow = False Then
        Set RpCol = RpCls.Find(Rzp_ID1)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            Set RpCol = RpCls.Find(Rzp_ID0)
            PatNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rzp_ID1)
            RzNum = RpRow.Record(RpCol.ItemIndex).Value
        End If
    End If
End If

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qrySimRez WHERE ID1 = " & RzNum
Else
    SQL1 = "SELECT * FROM qrySimRez WHERE [ID1] = " & RzNum & ";"
End If
Set RS120 = New ADODB.Recordset
With RS120
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With
If RS120.RecordCount > 0 Then
    If RS120.Fields("Rezepttext").Value <> vbNullString Then
        MeTex = RS120.Fields("Rezepttext").Value
    End If
    For AktPo = 0 To GesPo - 1
        If TmStr = vbNullString Then
            If GlPzn = True Then
                TmStr = "(" & GlClp(AktPo, ABDA_PZN) & ") " & GlClp(AktPo, ABDA_IDLang) & " " & GlClp(AktPo, ABDA_Menge) & " " & GlClp(AktPo, ABDA_Einheit)
            Else
                TmStr = GlClp(AktPo, ABDA_IDLang) & " " & GlClp(AktPo, ABDA_Menge) & " " & GlClp(AktPo, ABDA_Einheit)
            End If
        Else
            If GlPzn = True Then
                TmStr = TmStr & vbCrLf & "(" & GlClp(AktPo, ABDA_PZN) & ") " & GlClp(AktPo, ABDA_IDLang) & " " & GlClp(AktPo, ABDA_Menge) & " " & GlClp(AktPo, ABDA_Einheit)
            Else
                TmStr = TmStr & vbCrLf & GlClp(AktPo, ABDA_IDLang) & " " & GlClp(AktPo, ABDA_Menge) & " " & GlClp(AktPo, ABDA_Einheit)
            End If
        End If
        If SamLi = True Then
            If GlClp(AktPo, ABDA_MO) > 0 Then
                TmStr = TmStr & vbCrLf & "Morgens: " & GlClp(AktPo, ABDA_MO)
            End If
            If GlClp(AktPo, ABDA_VM) > 0 Then
                TmStr = TmStr & vbCrLf & "Vormittags: " & GlClp(AktPo, ABDA_VM)
            End If
            If GlClp(AktPo, ABDA_MI) > 0 Then
                TmStr = TmStr & vbCrLf & "Mittags: " & GlClp(AktPo, ABDA_MI)
            End If
            If GlClp(AktPo, ABDA_NM) > 0 Then
                TmStr = TmStr & vbCrLf & "Nachmittags: " & GlClp(AktPo, ABDA_NM)
            End If
            If GlClp(AktPo, ABDA_AB) > 0 Then
                TmStr = TmStr & vbCrLf & "Abends: " & GlClp(AktPo, ABDA_AB)
            End If
            If GlClp(AktPo, ABDA_NA) > 0 Then
                TmStr = TmStr & vbCrLf & "Nachts: " & GlClp(AktPo, ABDA_NA)
            End If
        End If
    Next AktPo
    If MeTex = vbNullString Then
        MeTex = TmStr
    Else
        MeTex = MeTex & vbCrLf & TmStr
    End If
    If RS120.Supports(adUpdate) Then
        RS120.Fields("Rezepttext").Value = MeTex
        RS120.Update
    End If
End If
RS120.Close
Set RS120 = Nothing

Erase GlClp
ClKop = False
DoEvents

If RzNum > 0 Then
    DoEvents
    SUpRz RowNr
End If

Set RpCo5 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "ABD_Rez " & Err.Number
Resume Next

End Sub
