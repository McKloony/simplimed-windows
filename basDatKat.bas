Select Case PaFrm
Case "BuVo":
    Set CmBrs = frmKatBU.comBar02
    Set RpCo7 = frmKatBU.repCont7
Case "BuSe":
    Set CmBrs = frmKatBU.comBar02
    Set RpCo7 = frmKatBU.repCont7
Case "BaVo":
    Set CmBrs = frmKatBV.comBar02
    Set RpCo7 = frmKatBV.repCont7
