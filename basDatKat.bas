                                    If RS160.Fields(FL101.Name).Value <> vbNullString Then
                                        RS127.Fields("ID1").Value = RS160.Fields(FL101.Name).Value
                                    End If
                            Case "Gruppe":
                            Case "IDKey":
                            Case "GuiID":
                                    RS127.Fields(FL101.Name).Value = GuiFr
                            Case "Feldname":
                                    RS127.Fields(FL101.Name).Value = GuiFr
                            Case "IDKurz":
                                    TmpSt = vbNullString
                                    If KatWe > 0 Then
                                        If KatWe = KatNr Then
                                            TmpSt = "(Kopie) " & FL101.Value
                                            If Len(TmpSt) > 250 Then
                                                TmpSt = Left$(TmpSt, 250)
