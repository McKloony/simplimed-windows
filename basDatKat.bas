Public Sub S_KtTy(Optional ByVal RowNr As Long)
On Error GoTo KoErr
'Lädt den Kontenplan gefiltert nach Typen

Dim GesZa As Long
Dim RowFi As Long
Dim KtoNr As Long
Dim IdxNr As Long
Dim KtoSt As String
Dim KntRm As Integer
Dim KnTyp As Integer
Dim Lange As Integer
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmRam As XtremeCommandBars.CommandBarComboBox
Dim CmTyp As XtremeCommandBars.CommandBarComboBox
Dim RpCon As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmBuKont
Set CmBrs = FM.comBar02
Set RpCon = FM.repCont1
Set RpRcs = RpCon.Records
Set RpRws = RpCon.Rows

Set CmRam = CmBrs.FindControl(CmRam, KA_SuCo1, , True)
Set CmTyp = CmBrs.FindControl(CmTyp, KA_SuCo2, , True)

KntRm = CmRam.ListIndex
KnTyp = CmTyp.ListIndex

If RowNr > 0 Then
    If RpRws.Count > 0 Then
        RowFi = RpCon.TopRowIndex
    End If
End If

Screen.MousePointer = vbHourglass
DoEvents

With RpCon
    .EditItem Nothing, Nothing
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    If .Records.Count > 0 Then .Records.DeleteAll
    .Populate
End With

Set RS130 = New ADODB.Recordset
RS130.CursorLocation = adUseClient
If KnTyp = 5 Then
    Set RS130 = DBCmRe1("qrySimBuKtR", "@IdxNr", KntRm)
ElseIf KnTyp = 6 Then
    Set RS130 = DBCmRe2("qrySimBuKtG", "@IdGel", "@IdxNr", -1, KntRm)
ElseIf KnTyp = 7 Then
    Set RS130 = DBCmRe2("qrySimBuKtU", "@IdStu", "@IdxNr", -1, KntRm)
Else
    Set RS130 = DBCmRe2("qrySimBuKtt", "@IdTyp", "@IdxNr", KnTyp, KntRm)
End If
GesZa = RS130.RecordCount

If GesZa > 0 Then
    Set RS163 = New ADODB.Recordset 'neues Recordset erstellen
    With RS163
        .CursorLocation = adUseClient
        .CursorType = adOpenForwardOnly
        .LockType = adLockBatchOptimistic
    End With

    For Each FL101 In RS130.Fields
        RS163.Fields.Append FL101.Name, FL101.Type, FL101.DefinedSize
    Next FL101
    If RS163.State = adStateClosed Then RS163.Open

    Do Until RS130.EOF
        RS163.AddNew
        For Each FL101 In RS163.Fields
            If IsNull(RS130.Fields(FL101.Name).Value) = False Then
                If FL101.Name = "IDK" Then
                    If RS130.Fields("IDK").Value <> vbNullString Then
                        If RS130.Fields("IDK").Value > 0 Then
                            KtoNr = RS130.Fields("IDK").Value
                            KtoSt = SBuFo(KtoNr) 'Sachkontenformatierung
                            RS163.Fields("IDK").Value = KtoSt
                        End If
                    End If
                Else
                    RS163.Fields(FL101.Name).Value = RS130.Fields(FL101.Name).Value
                End If
            End If
        Next FL101
        RS130.MoveNext
    Loop
    RS163.UpdateBatch
    
    RS163.MoveFirst
    RS163.Sort = "IDK ASC"

    Do
    IdxNr = RS163.Fields("IDI").Value
    Set RpRec = RpRcs.Add()
    Set RpItm = RpRec.AddItem(RS163.Fields("IDK").Value)
    RpItm.Icon = IC16_Doc_Norm
    Set RpItm = RpRec.AddItem(RS163.Fields("IDKurz").Value)
    Set RpItm = RpRec.AddItem(RS163.Fields("IDA").Value)
    Set RpItm = RpRec.AddItem(RS163.Fields("Bank").Value)
    Set RpItm = RpRec.AddItem(RS163.Fields("IDA").Value)
    Set RpItm = RpRec.AddItem(RS163.Fields("IDB").Value)
    Set RpItm = RpRec.AddItem(RS163.Fields("Buchtext").Value)
    Set RpItm = RpRec.AddItem(Format$(RS163.Fields("Steuer").Value, GlWa1))
    Set RpItm = RpRec.AddItem(RS163.Fields("Privat").Value)
    Set RpItm = RpRec.AddItem(RS163.Fields("IDArt").Value)
    Set RpItm = RpRec.AddItem(RS163.Fields("IDBank").Value)
    Set RpItm = RpRec.AddItem(RS163.Fields("Selekt").Value)
    Set RpItm = RpRec.AddItem(KtoNr)
    Set RpItm = RpRec.AddItem(Format$(IdxNr, "0000"))
    RS163.MoveNext
    Loop Until RS163.EOF
    
    RS163.Close
    Set RS163 = Nothing
End If
RS130.Close
Set RS130 = Nothing

RpCon.Populate

If GesZa > 0 Then
    Set RpRws = RpCon.Rows
    If RowNr > 0 Then
        If RowNr >= RpRws.Count Then
            RowNr = RpRws.Count - 1
        End If
        RpCon.TopRowIndex = RowFi
        RpRws.Row(0).Selected = False
        RpRws.Row(RowNr).EnsureVisible
        RpRws.Row(RowNr).Selected = True
        If GlFoc = True Then
            Set RpCon.FocusedRow = RpRws.Row(RowNr)
        End If
    Else
        RpRws.Row(0).Selected = True
    End If
End If

Screen.MousePointer = vbNormal

DoEvents
S_KtPo

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpRws = Nothing
Set RpCon = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KtTy " & Err.Number
Resume Next

End Sub

Public Sub S_KoMa(ByVal FoTyp As Integer, ByVal ManNr As Long, Optional ByVal StaGe As Long = 0)
On Error GoTo DaErr
'Füllt Comboboxen mit Daten

Dim KonNr As Long
Dim KonEr As Long
Dim KonGe As Long
Dim KonSt As Long
Dim GesZa As Long
Dim KtoSt As String
Dim KonRa As Integer
Dim AkKto As Integer
Dim AkGld As Integer
Dim AkStu As Integer
Dim AktZa As Integer
Dim CmKto As XtremeSuiteControls.ComboBox
Dim CmGeg As XtremeSuiteControls.ComboBox
Dim CmStk As XtremeSuiteControls.ComboBox

Select Case FoTyp
Case 1: Set FM = frmAnzahl
Case 2: Set FM = frmOPAusg
Case 3: Set FM = frmDruck
Case 4: Set FM = frmReAbs
End Select

Set CmGeg = FM.cmbGegen
Set CmKto = FM.cmbKonto

If FoTyp = 2 Then
    Set CmStk = FM.cmbStKto
End If

For AktZa = 1 To UBound(GlMan)
    If ManNr = GlMan(AktZa, 2) Then
        If GlMan(AktZa, 25) <> vbNullString Then
            KonRa = GlMan(AktZa, 25)
        Else
            KonRa = GlKtR 'Standardkontenrahmen
        End If
        If GlMan(AktZa, 37) > 0 Then
            KonSt = GlMan(AktZa, 37)
        Else
            KonSt = GlSKo 'Standardsteuerkonto
        End If
        If FoTyp = 1 Or FoTyp = 3 Then
            If GlMan(AktZa, 26) > 0 Then
                KonEr = GlMan(AktZa, 27)
            Else
                KonEr = GlSE1 'Standarderlöskonto Kasse
            End If
            If GlMan(AktZa, 28) > 0 Then
                KonGe = GlMan(AktZa, 29)
            Else
                KonGe = GlGkK 'Standardgeldkonto Kasse
            End If
        Else
            If GlMan(AktZa, 26) > 0 Then
                KonEr = GlMan(AktZa, 26)
            Else
                KonEr = GlSE2 'Standarderlöskonto Bank
            End If
            If GlMan(AktZa, 28) > 0 Then
                KonGe = GlMan(AktZa, 28)
            Else
                KonGe = GlGkB 'Standardgeldkonto Bank
            End If
        End If
        Exit For
    End If
Next AktZa

'-------------------- Erlöskonten --------------------

AktZa = 1
CmKto.Clear
DoEvents

Set RS103 = New ADODB.Recordset 'Erlöskonten
RS103.CursorLocation = adUseClient
Set RS103 = DBCmRe2("qrySimBuKtt", "@IdTyp", "@IdxNr", 2, KonRa)
GesZa = RS103.RecordCount
If GesZa > 0 Then
    Set RS104 = New ADODB.Recordset 'neues Recordset erstellen
    With RS104
        .CursorLocation = adUseClient
        .CursorType = adOpenKeyset
        .LockType = adLockOptimistic
    End With

    For Each FL101 In RS103.Fields
        RS104.Fields.Append FL101.Name, FL101.Type, FL101.DefinedSize
    Next FL101
    If RS104.State = adStateClosed Then RS104.Open
    
    Do Until RS103.EOF
        RS104.AddNew
        For Each FL101 In RS104.Fields
            If IsNull(RS103.Fields(FL101.Name).Value) = False Then
                If FL101.Name = "IDK" Then
                    If RS103.Fields("IDK").Value <> vbNullString Then
                        If RS103.Fields("IDK").Value > 0 Then
                            KonNr = RS103.Fields("IDK").Value
                            KtoSt = SBuFo(KonNr) 'Sachkontenformatierung
                            RS104.Fields("IDK").Value = KtoSt
                        End If
                    End If
                Else
                    RS104.Fields(FL101.Name).Value = RS103.Fields(FL101.Name).Value
                End If
            End If
        Next FL101
        RS103.MoveNext
    Loop
    RS104.UpdateBatch
    
    RS104.MoveFirst
    RS104.Sort = "IDK ASC"

    Do Until RS104.EOF
    If RS104.Fields("IDK").Value > 0 Then
        With CmKto
            .AddItem RS104.Fields("IDK").Value & Chr$(32) & RS104.Fields("IDKurz").Value
            .ItemData(AktZa - 1) = RS104.Fields("IDK").Value '[IDK]
        End With
        If RS104.Fields("IDI").Value = KonEr Then '[IDI]
            AkKto = AktZa
        End If
        AktZa = AktZa + 1
    End If
    RS104.MoveNext
    Loop
    
    RS104.Close
    Set RS104 = Nothing
End If
RS103.Close
Set RS103 = Nothing

CmKto.ListIndex = AkKto - 1

'-------------------- Steuerkonten --------------------

If FoTyp = 2 Then
    AktZa = 1
    CmStk.Clear
    DoEvents
    Set RS102 = New ADODB.Recordset 'Steuerkonten
    RS102.CursorLocation = adUseClient
    Set RS102 = DBCmRe2("qrySimBuKtU", "@IdStu", "@IdxNr", -1, KonRa)
    GesZa = RS102.RecordCount
    If GesZa > 0 Then
        Do Until RS102.EOF
        With CmStk
            .AddItem Format$(RS102.Fields("IDK").Value, "000000") & Chr$(32) & RS102.Fields("IDKurz").Value
            .ItemData(AktZa - 1) = RS102.Fields("IDK").Value '[IDK]
        End With
        If RS102.Fields("IDI").Value = KonSt Then '[IDI]
            AkStu = AktZa
        End If
        AktZa = AktZa + 1
        RS102.MoveNext
        Loop
    End If
    RS102.Close
    Set RS102 = Nothing
    CmStk.ListIndex = AkStu - 1
End If

'-------------------- Geldkonten --------------------

If GlBuc = True Then 'einfache Buchhaltung verwenden
    If StaGe = 0 Then
        StaGe = SCmb(CmGeg, KonGe) 'Standardgeldkonto Bank / Kasse
        If StaGe >= 0 Then
            If CmGeg.ListCount > 0 Then
                CmGeg.ListIndex = StaGe
            End If
        Else
            CmGeg.ListIndex = 0
        End If
    Else
        StaGe = SCmb(CmGeg, StaGe)
        If CmGeg.ListCount > 0 Then
            CmGeg.ListIndex = StaGe
        End If
    End If
Else
    AktZa = 1
    CmGeg.Clear
    DoEvents
    Set RS105 = New ADODB.Recordset 'Sachkonten mit Geldkontenzuordnung
    RS105.CursorLocation = adUseClient
    Set RS105 = DBCmRe2("qrySimBuKtE", "@IdGel", "@IdxNr", -1, KonRa)
    GesZa = RS105.RecordCount
    If GesZa > 0 Then
        Do Until RS105.EOF
        With CmGeg
            .AddItem Format$(RS105.Fields("IDK").Value, "000000") & Chr$(32) & RS105.Fields("IDKurz").Value
            .ItemData(AktZa - 1) = RS105.Fields("IDB").Value '[IDB]
        End With
        If RS105.Fields("IDI").Value = KonGe Then
            AkGld = AktZa
        End If
        AktZa = AktZa + 1
        RS105.MoveNext
        Loop
    End If
    RS105.Close
    Set RS105 = Nothing
    CmGeg.ListIndex = AkGld - 1
End If

Exit Sub

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KoMa " & Err.Number
Resume Next

End Sub
