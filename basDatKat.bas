        Case "C": SQL1 = "SELECT * FROM dbo.qryKat03C WHERE ID0 = -1" 'Diagnosekatalog
        Case "G": SQL1 = "SELECT * FROM dbo.qryKat02C WHERE ID0 = -1" 'Laborparameter
        Case "I": SQL1 = "SELECT * FROM dbo.qryKat04C WHERE ID0 = -1" 'Arzneikatalog
        Case "K": SQL1 = "SELECT * FROM dbo.qryKat02C WHERE ID0 = -1" 'Begründungen
        Case "L": SQL1 = "SELECT * FROM dbo.qryKat02C WHERE ID0 = -1" 'Anamnesetexte
        Case "M": SQL1 = "SELECT * FROM dbo.qryKon01E WHERE ID4 = -1" 'Terminbetreffs
        Case "N": SQL1 = "SELECT * FROM dbo.qryKat08B WHERE ID6 = -1" 'Fragebogen
        Case "O": SQL1 = "SELECT * FROM dbo.qryKat04C WHERE ID0 = -1" 'Textphrasen
        Case "P": SQL1 = "SELECT * FROM dbo.qryKat12C WHERE ID0 = -1" 'Artikelkatalog
        End Select
    Else
        Select Case KeySt
        Case "A": SQL1 = "SELECT * FROM qryKat01C WHERE [ID0] = -1;" 'Gebührenkatalog
        Case "C": SQL1 = "SELECT * FROM qryKat03C WHERE [ID0] = -1;" 'Diagnosekatalog
        Case "G": SQL1 = "SELECT * FROM qryKat02C WHERE [ID0] = -1;" 'Laborparameter
        Case "I": SQL1 = "SELECT * FROM qryKat04C WHERE [ID0] = -1;" 'Arzneikatalog
        Case "K": SQL1 = "SELECT * FROM qryKat02C WHERE [ID0] = -1;" 'Begründungen
        Case "L": SQL1 = "SELECT * FROM qryKat02C WHERE [ID0] = -1;" 'Anamnesetexte
        Case "M": SQL1 = "SELECT * FROM qryKon01E WHERE [ID4] = -1;" 'Terminbetreffs
        Case "N": SQL1 = "SELECT * FROM qryKat08B WHERE [ID6] = -1;" 'Fragebogen
        Case "O": SQL1 = "SELECT * FROM qryKat04C WHERE [ID0] = -1;" 'Textphrasen
        Case "P": SQL1 = "SELECT * FROM qryKat12C WHERE [ID0] = -1;" 'Artikelkatalog
        End Select
    End If
    
    Set RS127 = New ADODB.Recordset
    With RS127
        .ActiveConnection = DB1
        .CursorLocation = adUseClient
        .CursorType = adOpenStatic
        .LockType = adLockBatchOptimistic
        .Source = SQL1
        .Open Options:=adCmdText
        Set .ActiveConnection = Nothing
    End With
    
    AnzFe = RS127.Fields.Count + 1
    ReDim FldWe(AnzFe)

    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            Set RpCol = RpCls.Find(Kat_ID0)
            ParNr = RpRow.Record(RpCol.ItemIndex).Value

            Set RS128 = New ADODB.Recordset
            RS128.CursorLocation = adUseClient
            Select Case KeySt
            Case "A":  Set RS128 = DBCmRe1("qryKat01A", "@IdxNr", ParNr) 'Gebührenkatalog
            Case "C":  Set RS128 = DBCmRe1("qryKat03A", "@IdxNr", ParNr) 'Diagnosekatalog
            Case "G":  Set RS128 = DBCmRe1("qryKat02A", "@IdxNr", ParNr) 'Laborparameter
            Case "I":  Set RS128 = DBCmRe1("qryKat04A", "@IdxNr", ParNr) 'Arzneikatalog
            Case "K":  Set RS128 = DBCmRe1("qryKat02A", "@IdxNr", ParNr) 'Begründungen
            Case "L":  Set RS128 = DBCmRe1("qryKat02A", "@IdxNr", ParNr) 'Anamnesetexte
            Case "M":  Set RS128 = DBCmRe1("qryKon01A", "@IdxNr", ParNr) 'Terminbetreffs
            Case "N":  Set RS128 = DBCmRe1("qryKat08A", "@IdxNr", ParNr) 'Fragebogen
            Case "O":  Set RS128 = DBCmRe1("qryKat04A", "@IdxNr", ParNr) 'Textphrasen
            Case "P":  Set RS128 = DBCmRe1("qryKat12A", "@IdxNr", ParNr) 'Artikelkatalog
            End Select

            If RS128.RecordCount > 0 Then
                FldNr = 1
                AnzDa = RS128.Fields.Count
                For Each FL101 In RS128.Fields
                    If Not IsNull(FL101.Value) Then
                        If FL101.Type = adBoolean Then
                            If FL101.Value = True Then
                                FldWe(FldNr) = -1
                            Else
                                FldWe(FldNr) = 0
                            End If
                        Else
                            If FL101.Name = "upsize_ts" Then
                            
                            ElseIf FL101.Name = "Preis" Then
                                FldWe(FldNr) = Replace(Round(FL101.Value, 2), ",", ".")
                            ElseIf FL101.Name = "Preis1" Then
                                FldWe(FldNr) = Replace(Round(FL101.Value, 2), ",", ".")
                            ElseIf FL101.Name = "Preis3" Then
                                FldWe(FldNr) = Replace(Round(FL101.Value, 2), ",", ".")
                            ElseIf FL101.Name = "Einzelpreis" Then
                                FldWe(FldNr) = Replace(Round(FL101.Value, 2), ",", ".")
                            ElseIf FL101.Name = "Multi" Then
                                FldWe(FldNr) = Replace(Round(FL101.Value, 2), ",", ".")
                            Else
                                If FL101.Value <> vbNullString Then FldWe(FldNr) = FL101.Value
                            End If
                        End If
                    End If
                    FldNr = FldNr + 1
                    If FldNr > AnzDa Then
                        Exit For
                    End If
                Next FL101
                    
                If Right$(KeyNe, 2) <> "00" Then
                    KatWe = CLng(Mid$(KeyNe, 2, Len(KeyNe) - 1))
                    FldNr = 1
                    If RS127.Supports(adAddNew) Then
                        RS127.AddNew
                        For Each FL101 In RS128.Fields
                            Select Case FL101.Name
                            Case "ID0":
                            Case "ID6":
                            Case "ID1":
                                    If FldWe(FldNr) <> vbNullString Then RS127.Fields("ID1").Value = FldWe(FldNr)
                            Case "Gruppe":
                            Case "IDKey":
                            Case "ID3":
                                    If KatWe <> 0 Then
                                        RS127.Fields(FL101.Name).Value = KatWe
                                    Else
                                        If Not FldWe(FldNr) = vbNullString Then RS127.Fields(FL101.Name).Value = FldWe(FldNr)
                                    End If
                            Case Else:
                                    If Not FL101.Type = 128 Then
                                        If Not FldWe(FldNr) = vbNullString Then
                                            RS127.Fields(FL101.Name).Value = FldWe(FldNr)
                                        End If
                                    End If
                            End Select
                            FldNr = FldNr + 1
                        Next FL101
                    End If
                End If
            End If
        End If
    Next RpRow
    
    If RS127.Supports(adUpdateBatch) Then
        Set RS127.ActiveConnection = DB1
        RS127.UpdateBatch
        Set RS127.ActiveConnection = Nothing
    End If
    
    RS127.Close
    Set RS127 = Nothing
End If

Set RpSel = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo8 = Nothing

Exit Sub

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_Kop2 " & Err.Number
Resume Next

End Sub
Private Sub K_Kop3(ByVal PaFrm As String)
