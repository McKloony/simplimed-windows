        Case 0: Set RS137 = DBCmRe0("qryKon02A")
        Case 1: Set RS137 = DBCmRe1("qryKon02T", "@IdStr", "%" & GlSuE.SuStr & "%")
        Case 2: Set RS137 = DBCmRe1("qryKon02B", "@IdStr", GlSuE.SuStr & "%")
        Case 3: Set RS137 = DBCmRe1("qryKon02T", "@IdStr", GlSuE.SuStr & "%")
        Case 4: Set RS137 = DBCmRe1("qryKon02T", "@IdStr", GlSuE.SuStr & "%")
        Case 5: Set RS137 = DBCmRe0("qryKon02A")
        End Select
    Case 2:
