Set RS126 = New ADODB.Recordset
RS126.CursorLocation = adUseClient
Set RS126 = DBCmRe1("qrySimBuKID", "@IdxNr", IdxNr)
GesZa = RS126.RecordCount

If GesZa > 0 Then
    If RS126.EOF = False Then
        KtoNr = RS126.Fields("IDK").Value
        KoStr = RS126.Fields("IDKurz").Value
        KoStu = Format$(RS126.Fields("Steuer").Value, GlWa1)
        FM.txtIdxNr.Text = IdxNr
        If GlBuF <= 4 Then 'Buchungsdialog
            If KoStr <> vbNullString Then
                FM.txtBezei.Text = KoStr
            Else
                FM.txtBezei.Text = vbNullString
            End If
            If KtoNr > 0 Then
                FM.txtKtoNr.Text = KtoNr
            Else
                FM.txtKtoNr.Text = 0
            End If
        Else
            If KoStr <> vbNullString Then
                FM.txtBezHa.Text = KoStr
            Else
                FM.txtBezHa.Text = vbNullString
            End If
            If KtoNr > 0 Then
                FM.txtKtoHa.Text = KtoNr
            Else
                FM.txtKtoHa.Text = 0
            End If
        End If
        KtoSt = SBuFo(KtoNr) 'Sachkontenformatierung
        If Len(KoStr) > 40 Then
            KoStr = Left$(KoStr, 40) & "..."
        End If
        If GlBuF <= 4 Then 'Buchungsdialog
            TxKto.Text = KtoSt & " " & KoStr
        Else
            TxHab.Text = KtoSt & " " & KoStr
        End If
        If RS126.Fields("Buchtext").Value <> vbNullString Then
            If FM.cmbBuTex.Text = vbNullString Then
                FM.cmbBuTex.Text = RS126.Fields("Buchtext").Value
            End If
        End If
        
        If GlNeB = True Then 'neue Buchung
            For AktZa = 1 To UBound(GlStu) 'Steuersätze
                If CSng(GlStu(AktZa, 1)) = KoStu Then
                    FM.cmbBuStu.ListIndex = AktZa - 1
                    Exit For
                End If
            Next AktZa
            If RS126.Fields("IDA").Value <> vbNullString Then
                TmpNr = RS126.Fields("IDA").Value
                If TmpNr > 2 Then TmpNr = 1
                LiIdx = SCmb(FM.cmbBuTyp, TmpNr)
                If GlBut <> RibTab_HomeBanki Then
                    FM.cmbBuTyp.ListIndex = LiIdx
                End If
            End If
            If GlBut <> RibTab_HomeBanki Then
                If RS126.Fields("IDB").Value <> vbNullString Then
                    LiIdx = SCmb(FM.cmbGegen, RS126.Fields("IDB").Value)
                    If CmGlk.ListIndex = CmGlk.ListCount Then
                        FM.cmbGegen.ListIndex = LiIdx
                    Else
                        FM.cmbGegen.ListIndex = CmGlk.ListIndex - 1
                    End If
                End If
            End If
            If RS126.Fields("Selekt").Value = -1 Then
                ChErw.Value = xtpChecked
            Else
                ChErw.Value = xtpUnchecked
            End If
        End If

    End If
End If
RS126.Close
Set RS126 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KtSe " & Err.Number
Resume Next

End Sub
