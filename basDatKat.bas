        Set RpItm = RpRec.AddItem(RS154.Fields("Ziel").Value)
        Set RpItm = RpRec.AddItem(RS154.Fields("Kommentar").Value)
        Set RpItm = RpRec.AddItem(RS154.Fields("IDP").Value)
        Set RpItm = RpRec.AddItem(RS154.Fields("Berichtdatum").Value)
