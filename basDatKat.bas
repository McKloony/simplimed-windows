            Case "G": DBCmEx1 "qryAnKa2a", "@PosNr", PosNr 'Laborparameter
            Case "I": DBCmEx1 "qryAnKa3a", "@PosNr", PosNr 'Arzneikataloge
            Case "K": DBCmEx1 "qryAnKa4a", "@PosNr", PosNr 'Begründungen
            Case "L": DBCmEx1 "qryAnKa4a", "@PosNr", PosNr 'Anamnesetexte
            Case "M": DBCmEx1 "qryAnKa2a", "@PosNr", PosNr 'Terminbetreffs
            Case "N": Exit Sub
            Case "O": DBCmEx1 "qryAnKa3a", "@PosNr", PosNr 'Textphrasen
            End Select
        End If
    Next RpRow

    If KeySt = "A" Then
        KaSpr
        K_AnLa IdxNr
    End If
End If

Set RpSel = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCon = Nothing

Exit Sub

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_AnLo " & Err.Number
Resume Next

End Sub
