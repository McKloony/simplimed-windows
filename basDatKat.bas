            If RpRec.Item(Ket_Fakto).Value <> vbNullString Then
                If RpRec.Item(Ket_Fakto).Value > 1 Then
                    Multi = CSng(RpRec.Item(Ket_Fakto).Value)
                Else
                    Multi = 1
                End If
            Else
                Multi = 1
            End If
            TmPre = (WinRound((EiPre * Multi), 2) * Anza1)
            GePre = GePre + TmPre
        End If
    Next RpRec
Else
    GePre = 0
    GeMin = 0
End If

If TreKy = "R" Then
