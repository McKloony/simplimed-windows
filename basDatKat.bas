Public Sub F_Loe()
On Error GoTo OrErr
'Löscht die selektierten Einträge

Dim RowNr As Long
Dim AnzPo As Long
Dim IdxNr As Long
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCo8 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo8 = FM.repCont8
Set RpCls = RpCo8.Columns
Set RpSel = RpCo8.SelectedRows

Tit1 = "Frage Entfernen"
AnzPo = RpSel.Count
If AnzPo > 1 Then
    Mld1 = "Möchten Sie die " & AnzPo & " markierten Fragen wirklich löschen?"
Else
    Mld1 = "Möchten Sie die aktuelle Frage wirklich löschen?"
End If

If GlRch(0, 19) = 0 Then
    WindowMess "Sie besitzen keine Berechtigung für diesen Vorgang", Dial3, Tit1, FM.hwnd
    Exit Sub
End If

If AnzPo > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then

        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                Set RpCol = RpCls.Find(Kat_ID0)
                IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                DBCmEx1 "qryKat08Ls", "@IdxNr", IdxNr 'Subitems
                DBCmEx1 "qryKat08L", "@IdxNr", IdxNr 'Fragebogen
            End If
        Next RpRow

        DoEvents
        GlNeK = GlKoX 'Protokolleintrag
        With GlNeK
            .PatNr = GlMan(GlSMa, 2)
            .IdxNr = 0
            .EiDat = Format$(Date, "dd.mm.yyyy")
            .EiZei = TimeValue(Now)
            .EiTyp = 104
            .TeStr = "Fragebogeneintrag gelöscht"
            .ZiStr = Format$(Now, "hh:mm") & " Uhr"
            .NeuEi = True
            .KeiAk = True
            .Mitar = GlMiA(GlSmI, 2)
        End With
        S_Prot

        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            RowNr = RpRow.Index
            KUpKa RowNr
        End If
    End If
End If

Set RpSel = Nothing
Set RpRow = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo8 = Nothing

Exit Sub

OrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "F_Loe " & Err.Number
Resume Next

