Public Sub K_KrEd(ByVal FoTyp As Integer, ByVal SuFel As Integer)
On Error GoTo PoErr
'Sucheingabe im Krankenblatteingebedialog

Dim SuStr As String
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmCm1 As XtremeCommandBars.CommandBarComboBox
Dim CmCm2 As XtremeCommandBars.CommandBarComboBox
Dim FTex1 As XtremeSuiteControls.FlatEdit

Set FM = frmKraEd
Set CmBrs = FM.comBar02
Set CmAcs = CmBrs.Actions
Set FTex1 = FM.txtKomme

Set CmCm1 = CmBrs.FindControl(CmCm1, SY_SuCm1, , True)
Set CmCm2 = CmBrs.FindControl(CmCm2, SY_SuCm2, , True)

Select Case SuFel
Case 1:
    If CmCm1.Text <> vbNullString Then
        SuStr = CmCm1.Text & "%"
        Set RS155 = New ADODB.Recordset
        RS155.CursorLocation = adUseClient
        Set RS155 = DBCmRe2("qryKat04M", "@IdxNr", "@IdStr", 9, SuStr)
        If RS155.RecordCount > 0 Then
            If FTex1.Text <> vbNullString Then
                FTex1.Text = FTex1.Text & Chr$(32) & RS155.Fields("Zusatztext").Value
            Else
                FTex1.Text = RS155.Fields("Zusatztext").Value
            End If
        End If
        RS155.Close
        Set RS155 = Nothing
        With FTex1
            If GlCur = True Then 'Cursorplatzierung bei Bearbeiten eines Eintrags
                .SelStart = Len(.Text)
            Else
                .SelStart = 1
            End If
            .SelLength = 0
            'Kein SetFocus
        End With
    End If
Case 2:
    If CmCm2.Text <> vbNullString Then
        SuStr = CmCm2.Text & "%"
        Set RS155 = New ADODB.Recordset
        RS155.CursorLocation = adUseClient
        Set RS155 = DBCmRe2("qryKat04N", "@IdxNr", "@IdStr", 9, SuStr)
        If RS155.RecordCount > 0 Then
            If FTex1.Text <> vbNullString Then
                FTex1.Text = FTex1 & Chr$(32) & RS155.Fields("Zusatztext").Value
            Else
                FTex1.Text = RS155.Fields("Zusatztext").Value
            End If
        End If
        RS155.Close
        Set RS155 = Nothing
        With FTex1
            If GlCur = True Then 'Cursorplatzierung bei Bearbeiten eines Eintrags
                .SelStart = Len(.Text)
            Else
                .SelStart = 1
            End If
            .SelLength = 0
            'Kein SetFocus
        End With
    End If
Case 3:
    If CmCm1.ListCount = 0 Then
        Set RS155 = New ADODB.Recordset
        RS155.CursorLocation = adUseClient
        Set RS155 = DBCmRe1("qryKat04G", "@IdxNr", 9)
        If RS155.RecordCount > 0 Then
            Do
            CmCm1.AddItem RS155.Fields("GOID").Value
            CmCm2.AddItem RS155.Fields("IDKurz").Value
            RS155.MoveNext
            Loop Until RS155.EOF
        End If
        RS155.Close
        Set RS155 = Nothing
    End If
    With FTex1
        If GlCur = True Then 'Cursorplatzierung bei Bearbeiten eines Eintrags
            .SelStart = Len(.Text)
        Else
            .SelStart = 0
        End If
        .SelLength = 0
        'Kein SetFocus
    End With
End Select

Set CmAcs = Nothing
Set CmBrs = Nothing

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_KrEd " & Err.Number
Resume Next

End Sub
