Public Sub K_Diag()
On Error GoTo OrErr
'Ordnen den Leistungen die Diagnosen zu

Dim AnzGe As Long
Dim AnzDi As Long
Dim IdxNr As Long
Dim GruNr As Long
Dim DiGrp As Long
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCo8 As XtremeReportControl.ReportControl
Dim RpCon As XtremeReportControl.ReportControl
Dim RpSe1 As XtremeReportControl.ReportSelectedRows
Dim RpSe2 As XtremeReportControl.ReportSelectedRows
Dim RpCl1 As XtremeReportControl.ReportColumns
Dim RpCl2 As XtremeReportControl.ReportColumns
Dim RpCo1 As XtremeReportControl.ReportColumn
Dim RpCo2 As XtremeReportControl.ReportColumn
Dim RpRw1 As XtremeReportControl.ReportRow
Dim RpRw2 As XtremeReportControl.ReportRow

Set FM = frmMain
Set FK = frmTerKat
Set RpCo8 = FM.repCont8
Set RpCon = FK.repCont9
Set RpCl1 = RpCo8.Columns
Set RpSe1 = RpCo8.SelectedRows
Set RpCl2 = RpCon.Columns
Set RpSe2 = RpCon.SelectedRows

Tit1 = "Diagnosen Zuordnen"
AnzGe = RpSe1.Count
AnzDi = RpSe2.Count

If AnzGe > 1 Then
    If AnzDi > 1 Then
        Mld1 = "Möchten Sie den " & AnzGe & " markierten Gebühreneinträgen die " & AnzDi & " markierten Diagnosegruppen zuordnen?"
    Else
        Mld1 = "Möchten Sie den " & AnzGe & " markierten Gebühreneinträgen die markierte Diagnosegruppe zuordnen?"
    End If
Else
    If AnzDi > 1 Then
        Mld1 = "Möchten Sie dem markierten Gebühreneintrag die " & AnzDi & " markierten Diagnosegruppen zuordnen?"
    Else
        Mld1 = "Möchten Sie dem markierten Gebühreneintrag die markierte Diagnosegruppe zuordnen?"
    End If
End If

If GlRch(0, 19) = 0 Then
    WindowMess "Sie besitzen keine Berechtigung für diesen Vorgang", Dial3, Tit1, FM.hwnd
    Exit Sub
End If

If AnzGe > 0 Then
    If AnzDi > 0 Then
        Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
        If Frage = 6 Then
            Set Lbl01 = frmStatus.lblLab01
            Set PrBr1 = frmStatus.prbStat1
            Set PrBr2 = frmStatus.prbStat2
            Set TxDum = frmStatus.txtDummy
            
            Lbl01.Caption = "Bitte warten..."
            frmStatus.Caption = "Zuordnen"
            frmStatus.Show
            DoEvents
                    
            PrBr1.Min = 0
            PrBr1.Max = AnzGe
            PrBr2.Min = 0
            PrBr2.Max = AnzDi

            For Each RpRw1 In RpSe1
                If RpRw1.GroupRow = False Then
                    Set RpCo1 = RpCl1.Find(Kat_ID0)
                    IdxNr = RpRw1.Record(RpCo1.ItemIndex).Value
                    PrBr1.Value = RpRw1.Index
                                    
                    For Each RpRw2 In RpSe2
                        If RpRw1.GroupRow = False Then
                            Set RpCo2 = RpCl2.Find(Kat_ID0)
                            DiGrp = RpRw2.Record(RpCo2.ItemIndex).Value
                            PrBr2.Value = RpRw2.Index
                            DBCmEx3 "qryKat07D", "@IdxNr", "@IdDia", "@GruNr", IdxNr, DiGrp, DiGrp
                        End If
                    Next RpRw2
                End If
                DoEvents
                If TxDum.Text = "B" Then Exit For 'Abbrechen
            Next RpRw1
    
            Unload frmStatus
            DoEvents
            Unload FK
            DoEvents
        End If
    End If
End If

Set RpCo8 = Nothing
Set RpCon = Nothing

Exit Sub

OrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_Diag " & Err.Number
Resume Next

End Sub
