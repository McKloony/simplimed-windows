Public Sub ABD_Ab1()
On Error GoTo LiErr
'Gleicht den eigenen Arzneikatalog ab

Dim SQL1 As String
Dim AktPo As Long
Dim KatNr As Long
Dim KatNa As String
Dim HeStr As String
Dim EiPre As Single
Dim NeuHe As Boolean
Dim Posit As Integer
Dim KatZa As Integer
Dim AktZa As Integer
Dim Lbl08 As XtremeSuiteControls.Label

Set FM = frmMedik
Set Lbl08 = FM.lblLab08
Set PrBr1 = FM.prbStat1
Set PrBr2 = FM.prbStat2

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qryKat04 ORDER BY IDKurz"
Else
    SQL1 = "SELECT * FROM qryKat04 ORDER BY [IDKurz];"
End If

Set RS121 = New ADODB.Recordset
With RS121
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With
If RS121.RecordCount > 0 Then
    KatZa = RS121.RecordCount
    PrBr1.Min = 0
    PrBr1.Max = KatZa
    
    Do
    KatNr = RS121.Fields("ID3").Value
    KatNa = RS121.Fields("IDKurz").Value
    Lbl08.Caption = KatNa
    DoEvents
    HeStr = ABD_Ab2(KatNr)
    DoEvents
    
    If KatNr > 1 Then
        If HeStr <> vbNullString Then
            RS121.Fields("IDKurz").Value = HeStr
        End If
    End If
    RS121.Update
    DoEvents
    
    AktZa = AktZa + 1
    PrBr1.Value = AktZa
    DoEvents
    RS121.MoveNext
    Loop Until RS121.EOF
    
End If
RS121.Close
Set RS121 = Nothing

DoEvents
KList

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "ABD_Ab1 " & Err.Number
Resume Next

End Sub
Private Function ABD_Ab2(ByVal KatNr As Long) As String
On Error GoTo DaErr
'Liest alle Einträge eines bestimmten Kataloges ein

Dim SQL2 As String
Dim AktZa As Long
Dim GesZa As Long
Dim VKPre As Single
Dim EiPre As Single
Dim Darre As String
Dim Menge As String
Dim Einhe As String
Dim SuStr As String
Dim PrStr As String
Dim HeStr As String
Dim Posit As Integer
Dim Anzal As Integer
Dim Lbl09 As XtremeSuiteControls.Label

Set FM = frmMedik
Set Lbl09 = FM.lblLab09
Set PrBr1 = FM.prbStat1
Set PrBr2 = FM.prbStat2

If GlTyp < 2 Then
    SQL2 = "SELECT * FROM dbo.qryKat04C WHERE ID3 = " & KatNr
Else
    SQL2 = "SELECT * FROM qryKat04C WHERE [ID3] = " & KatNr & ";"
End If

Set RS124 = New ADODB.Recordset
With RS124
    .CursorLocation = adUseClient
    .Source = SQL2
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With
If RS124.RecordCount > 0 Then
    RS124.MoveLast
    GesZa = RS124.RecordCount

    PrBr2.Min = 0
    PrBr2.Max = GesZa
    DoEvents
    RS124.MoveFirst
    
    Do
    If RS124.Fields("GOID").Value <> vbNullString Then
        SuStr = RS124.Fields("GOID").Value
    Else
        SuStr = vbNullString
    End If
    If RS124.Fields("IDKurz").Value <> vbNullString Then
        Lbl09.Caption = RS124.Fields("IDKurz").Value
    Else
        Lbl09.Caption = "keine Produktbezeichnung"
    End If
            
    SuStr = Val(SuStr)
    SuStr = Format$(SuStr, "00000000")
    
    Set RS125 = New ADODB.Recordset
    RS125.CursorLocation = adUseClient
    Set RS125 = ABDmRe1("qryArtPZN", "@IdStr", SuStr)
    If RS125.RecordCount > 0 Then
        If RS125.Fields("Firmenname").Value <> vbNullString Then
            HeStr = RS125.Fields("Firmenname").Value
        Else
            HeStr = vbNullString
        End If
        If RS125.Fields("Darreichung_Kurz").Value <> vbNullString Then
            Darre = LCase(RS125.Fields("Darreichung_Kurz").Value)
        Else
            Darre = vbNullString
        End If
        If RS125.Fields("Menge").Value <> vbNullString Then
            Menge = LCase(RS125.Fields("Menge").Value)
        Else
            Menge = vbNullString
        End If
        If RS125.Fields("Einheit").Value <> vbNullString Then
            Einhe = RS125.Fields("Einheit").Value
        Else
            Einhe = vbNullString
        End If
        If RS125.Fields("IDLang").Value <> vbNullString Then
            If Menge <> vbNullString Then
                If Einhe <> vbNullString Then
                    PrStr = RS125.Fields("IDLang").Value & " " & Menge & " " & Einhe
                Else
                    PrStr = RS125.Fields("IDLang").Value & " " & Menge
                End If
            Else
                PrStr = RS125.Fields("IDLang").Value
            End If
        Else
            PrStr = vbNullString
        End If
        If RS125.Fields("ApoPreis").Value > 0 Then
            VKPre = Format$(CSng(RS125.Fields("ApoPreis").Value) / 100, "#,##0.00")
        Else
            VKPre = 0
        End If

        If Darre Like "amp." Or Darre Like "ilo." Or Darre Like "pul." Or Darre Like "inf." Or Darre Like "inlsg" Then
            Posit = InStr(1, Menge, "x", 1)
            If Posit > 0 Then
                Anzal = CInt(Mid$(Menge, 1, Posit - 1))
            Else
                Anzal = Val(Menge)
            End If
            If VKPre > 0 Then
                If Anzal > 0 Then
                    EiPre = VKPre / Anzal
                Else
                    EiPre = VKPre
                End If
            Else
                EiPre = 0
            End If
        Else
            EiPre = VKPre
        End If
    
        RS124.Fields("GOID").Value = SuStr
        RS124.Fields("IDKurz").Value = PrStr
        RS124.Fields("Preis1").Value = VKPre
        RS124.Fields("Preis3").Value = EiPre
        RS124.Update
    End If
    RS125.Close
    Set RS125 = Nothing
    
    AktZa = AktZa + 1
    PrBr2.Value = AktZa
    DoEvents
    RS124.MoveNext
    Loop Until RS124.EOF

End If
RS124.Close
Set RS124 = Nothing

ABD_Ab2 = HeStr

Exit Function

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "ABD_Ab2 " & Err.Number
Resume Next

End Function

Public Sub ABD_Abr(ByVal GesPo As Long)
On Error GoTo LiErr
'Fügt die markierten Produkte in die Rechnung ein

Dim SQL1 As String
Dim AktPo As Long
Dim PatNr As Long
Dim ReNum As Long
Dim RowNr As Long
Dim RowFi As Long
Dim ReBet As Single
Dim ReRab As Single
Dim EiPre As Single
Dim NeReB As Double
Dim ReAbg As Boolean
Dim RetWe As Boolean
Dim Posit As Integer
Dim Anzal As Integer
Dim Mld1, Tit1 As String
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo3 = FM.repCont3
Set RpCo4 = FM.repCont4
Set RpRws = RpCo3.Rows
Set RpCls = RpCo3.Columns
Set RpSel = RpCo3.SelectedRows

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    RowNr = RpRow.Index
    If RpRow.GroupRow = False Then
        Set RpCol = RpCls.Find(Rec_ID1)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            Set RpCol = RpCls.Find(Rec_ID0)
            PatNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_ID1)
            ReNum = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Betrag)
            ReBet = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Selekt)
            ReAbg = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Rabatt)
            ReRab = Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1)
        End If
    End If
End If

If ReAbg = True Then
    Erase GlClp
    ClKop = False
    Set RpCo3 = Nothing
    Set RpCo4 = Nothing
    Tit1 = "Rechnung Abgeschlossen"
    Mld1 = "Diese Rechnung wurde bereits abgeschlossen"
    WindowMess Mld1, Dial2, Tit1, FM.hwnd
    Exit Sub
End If

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qrySimAbSav WHERE IDR = " & ReNum
Else
    SQL1 = "SELECT * FROM qrySimAbSav WHERE [IDR] = " & ReNum & ";"
End If
Set RS120 = New ADODB.Recordset
With RS120
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With
If RS120.Supports(adAddNew) Then
    For AktPo = 0 To GesPo - 1
     
        If GlClp(AktPo, ABDA_Darreichung_Kurz) Like "Amp." Or GlClp(AktPo, ABDA_Darreichung_Kurz) Like "Ilo." Or GlClp(AktPo, ABDA_Darreichung_Kurz) Like "Pul." Or GlClp(AktPo, ABDA_Darreichung_Kurz) Like "Inf." Then
            Posit = InStr(1, GlClp(AktPo, ABDA_Menge), "X", 1)
            If Posit > 0 Then
                Anzal = CInt(Mid$(GlClp(AktPo, ABDA_Menge), 1, Posit - 1))
            Else
                Anzal = Val(GlClp(AktPo, ABDA_Menge))
            End If
            If GlClp(AktPo, ABDA_ApoPreis) > 0 Then
                If Anzal > 0 Then
                    EiPre = CSng(GlClp(AktPo, ABDA_ApoPreis)) / Anzal
                Else
                    EiPre = CSng(GlClp(AktPo, ABDA_ApoPreis))
                End If
            Else
                EiPre = 0
            End If
        Else
            EiPre = CSng(GlClp(AktPo, ABDA_ApoPreis))
        End If
    
        RS120.AddNew
        RS120.Fields("ID0").Value = PatNr
        RS120.Fields("IDR").Value = ReNum
        RS120.Fields("ID1").Value = 4
        RS120.Fields("Datum").Value = GlTag(1) & Space$(1) & TimeValue(Now)
        RS120.Fields("Druckdatum").Value = GlTag(1) & Space$(1) & TimeValue(Now)
        RS120.Fields("GONr").Value = Format$(GlClp(AktPo, ABDA_PZN), "0000000")
        RS120.Fields("IDKurz").Value = GlClp(AktPo, ABDA_IDLang) & " (PZN: " & Format$(GlClp(AktPo, ABDA_PZN), "0000000") & ")"
        RS120.Fields("Multi").Value = 1
        RS120.Fields("x").Value = 1
        RS120.Fields("Betrag").Value = EiPre
        RS120.Fields("GesBetrag").Value = EiPre
        RS120.Fields("Währung").Value = 1
        RS120.Update
    Next AktPo
End If
RS120.Close
Set RS120 = Nothing

DBCmEx0 "qryWarAbPos" 'Übertragen [ID2] auf [ID3]

Erase GlClp
ClKop = False
DoEvents

RetWe = S_KrPo()
NeReB = S_ReBet(ReNum, Round(ReBet, 2), ReAbg, ReRab)
RowFi = RpCo3.TopRowIndex
S_KrLi
If RowNr > 0 Then
    If RpRws.Count > 0 Then
        If RowNr >= RpRws.Count Then
            RowNr = RpRws.Count - 1
        End If
        RpCo3.TopRowIndex = RowFi
        RpRws.Row(0).Selected = False
        RpRws.Row(RowNr).EnsureVisible
        RpRws.Row(RowNr).Selected = True
    End If
End If

Set RpSel = RpCo4.SelectedRows
If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    RowNr = RpRow.Index
    SUpRe RowNr
End If

Set RpCo3 = Nothing
Set RpCo4 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "ABD_Abr " & Err.Number
Resume Next

End Sub
Public Sub ABD_Anb(ByVal SuStr As String, ByVal SuTyp As Integer)
On Error GoTo LiErr
'Weißt dem ReportControl die gefilterten Einträge zu

Dim AkAry As Long
Dim VKPre As Single
Dim AktZa As Integer
Dim RpCo2 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMedik
Set RpCo2 = FM.repCont2
Set RpRcs = RpCo2.Records

Screen.MousePointer = vbHourglass

Set RS148 = New ADODB.Recordset
RS148.CursorLocation = adUseClient
Select Case SuTyp
Case 3: Set RS148 = ABDmRe1("qryAnbNam", "@IdStr", "%" & SuStr & "%")
Case 4: Set RS148 = ABDmRe1("qryWksNam", "@IdStr", "%" & SuStr & "%")
Case 5: Set RS148 = ABDmRe1("qryIndNam", "@IdStr", "%" & SuStr & "%")
End Select
GlAbA = RS148.RecordCount

If GlAbA > 0 Then
    With RpCo2
        .EditItem Nothing, Nothing
        If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
        If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
        If .Records.Count > 0 Then .Records.DeleteAll
        .Populate
    End With
    
    AnAry = RS148.GetRows 'Array Füllen
    DoEvents
    
    If SuTyp = 3 Then
        For AkAry = 0 To GlAbA - 1
            If AnAry(ABAN_Strasse, AkAry) <> vbNullString Then
                If AnAry(ABAN_Hausnr_von, AkAry) <> vbNullString Then
                    If AnAry(ABAN_Hausnr_bis, AkAry) <> vbNullString Then
                        AnAry(ABAN_Strasse, AkAry) = AnAry(ABAN_Strasse, AkAry) & " " & AnAry(ABAN_Hausnr_von, AkAry) & " - " & AnAry(ABAN_Hausnr_bis, AkAry)
                    End If
                Else
                    AnAry(ABAN_Strasse, AkAry) = AnAry(ABAN_Strasse, AkAry) & " " & AnAry(ABAN_Hausnr_von, AkAry)
                End If
            End If
        Next AkAry
    End If

    RpCo2.SetVirtualMode GlAbA
    DoEvents

    Set RpRec = RpCo2.Records(0)
    Select Case SuTyp
    Case 3:
        For AktZa = 0 To 9 'WICHTIG!
            Set RpItm = RpRec.AddItem(vbNullString)
        Next AktZa
    Case 4:
        For AktZa = 0 To 1 'WICHTIG!
            Set RpItm = RpRec.AddItem(vbNullString)
        Next AktZa
    Case 5:
        For AktZa = 0 To 1 'WICHTIG!
            Set RpItm = RpRec.AddItem(vbNullString)
        Next AktZa
    End Select

    DoEvents
    With RpCo2
        .Populate
        .SetCustomDraw xtpCustomBeforeDrawRow
    End With
    
    Set RpRws = RpCo2.Rows
    RpRws.Row(0).Selected = True
    Set RpRow = RpRws(0)
Else
    GlAbA = 0
    If GlAbA > 0 Then
        Erase AnAry
    End If
    RpCo2.SetVirtualMode 0
    
    DoEvents
    With RpCo2
        .Populate
        .SetCustomDraw xtpCustomBeforeDrawRow
    End With
    
    SPopu "Keine Einträge gefunden", "Es wurden keine Adressen gefunden, die dem Suchkriterium entsprechen", IC48_Information
End If

RS148.Close
Set RS148 = Nothing

Set RpRec = Nothing
Set RpCo2 = Nothing

Screen.MousePointer = vbNormal

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_AbFil " & Err.Number
Resume Next

End Sub
