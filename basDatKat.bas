Private Sub P_RecH(ByRef RST As ADODB.Recordset, ByVal KetMe As Boolean)
On Error GoTo LiErr
'Füllt die Tabelle mit Daten

Dim ManNr As Long
Dim Diffe As Double
Dim ReStu As Single
Dim ReSto As Boolean
Dim EinOk As Boolean
Dim CmBrs As XtremeCommandBars.CommandBars
Dim RpCon As XtremeReportControl.ReportControl

Set FM = frmKatBA
Set RpCon = FM.repCont7
Set RpRcs = RpCon.Records

Set CmBrs = frmMain.comBar01
Set CmSta = CmBrs.StatusBar

If KetMe = False Then
    Do
    If RST.Fields("IDP").Value <> vbNullString Then
        ManNr = CLng(RST.Fields("IDP").Value)
    Else
        ManNr = GlMan(GlSMa, 2)
    End If
    If RST.Fields("Steuer").Value <> vbNullString Then
        ReStu = CSng(RST.Fields("Steuer").Value)
    Else
        ReStu = 0
    End If
    If ReStu > 0 And ReStu < 1 Then
        ReStu = ReStu * 100
    End If
    
    If GlRst = False Then 'Mandantenbezogene Datenbegrenzung
        EinOk = True
    Else
        If ManNr = GlReM Then 'Standardmandant Mandantenrestriktionen
            EinOk = True
        Else
            If ManNr = 0 Then
                EinOk = True
            Else
                EinOk = False
            End If
        End If
    End If
    
    If EinOk = True Then
        Set RpRec = RpRcs.Add()
        Set RpItm = RpRec.AddItem(RST.Fields("ID1").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("RechNr").Value)
        If RST.Fields("Mahnbar").Value = 0 Then
            RpItm.Icon = IC16_Pin_Gray
        Else
            If RST.Fields("Mahnfrist").Value < Date Then
                RpItm.Icon = IC16_Pin_Red
            Else
                RpItm.Icon = IC16_Pin_Green
            End If
        End If
        Set RpItm = RpRec.AddItem(Format$(RST.Fields("Offen").Value, GlWa1))
        RpItm.Alignment = xtpAlignmentRight
        Set RpItm = RpRec.AddItem(RST.Fields("Stufe").Value)
        RpItm.Alignment = xtpAlignmentCenter
        Set RpItm = RpRec.AddItem(RST.Fields("Patient").Value)
        Set RpItm = RpRec.AddItem(Format$(RST.Fields("Betrag").Value, GlWa1))
        RpItm.Alignment = xtpAlignmentRight
        Set RpItm = RpRec.AddItem(Format$(RST.Fields("Bezahlt").Value, GlWa1))
        RpItm.Alignment = xtpAlignmentRight
        Set RpItm = RpRec.AddItem(Format$(RST.Fields("Gebuehr").Value, GlWa1))
        RpItm.Alignment = xtpAlignmentRight
        Set RpItm = RpRec.AddItem(RST.Fields("W").Value)
        RpItm.Alignment = xtpAlignmentCenter
        Set RpItm = RpRec.AddItem(RST.Fields("Datum").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("Fällig").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("Einzahlung").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("Mahnfrist").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("IDW").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("Mahnbar").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("Intervall").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("ID0").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("Währung").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("IDR").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("Beleg").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("Selekt").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("IDP").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("Kommentar").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("Berichtdatum").Value)
        RpItm.Alignment = xtpAlignmentCenter
        Set RpItm = RpRec.AddItem(Format$(ReStu, GlWa1))
        Set RpItm = RpRec.AddItem(RST.Fields("Mahnung1").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("Mahnung2").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("Mahnung3").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("Mahnung4").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("Mahnung5").Value)
        Set RpItm = RpRec.AddItem(Month(DateValue(RST.Fields("Datum").Value)))
        Set RpItm = RpRec.AddItem(RST.Fields("Konto").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("BLZ").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("IDT").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("IBAN").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("BIC").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("GuiID").Value)
        If RST.Fields("Versand").Value <> vbNullString Then
            Select Case CInt(RST.Fields("Versand").Value)
            Case 1: Set RpItm = RpRec.AddItem("M")
            Case 2: Set RpItm = RpRec.AddItem("D")
            Case Else: Set RpItm = RpRec.AddItem(vbNullString)
            End Select
        Else
            Set RpItm = RpRec.AddItem(vbNullString)
        End If
        If RST.Fields("Kommentar").Value <> vbNullString Then
            RpRec.PreviewText = RST.Fields("Kommentar").Value
        End If
    End If
    RST.MoveNext
    Loop Until RST.EOF
Else
    Do
    If RST.Fields("Storniert").Value <> vbNullString Then
        ReSto = CBool(RST.Fields("Storniert").Value)
    Else
        ReSto = False
    End If
    If RST.Fields("IDP").Value <> vbNullString Then
        ManNr = CLng(RST.Fields("IDP").Value)
    Else
        ManNr = GlMan(GlSMa, 2)
    End If
    ReStu = CSng(RST.Fields("Steuer").Value)
    If ReStu > 0 And ReStu < 1 Then
        ReStu = ReStu * 100
    End If
    If RST.Fields("Bezahlt").Value > 0 Then
        Diffe = RST.Fields("Betrag").Value - RST.Fields("Bezahlt").Value
    Else
        Diffe = 0
    End If
    
    If ReSto = False Then
        If GlRst = False Then 'Mandantenbezogene Datenbegrenzung
            EinOk = True
        Else
            If ManNr = GlReM Then 'Standardmandant Mandantenrestriktionen
                EinOk = True
            Else
                If ManNr = 0 Then
                    EinOk = True
                Else
                    EinOk = False
                End If
            End If
        End If
    Else
        EinOk = False
    End If

    If EinOk = True Then
        Set RpRec = RpRcs.Add()
        Set RpItm = RpRec.AddItem(RST.Fields("ID1").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("ID0").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("RechNr").Value)
        If RST.Fields("Selekt").Value = 0 Then
            RpItm.Icon = IC16_Mail_Open
        Else
            RpItm.Icon = IC16_Mail_Close
        End If
        Set RpItm = RpRec.AddItem(Left$(RST.Fields("Datum").Value, 10))
        Set RpItm = RpRec.AddItem(RST.Fields("Selekt").Value)
