    End If
    If RS160.Fields("Value").Value <> vbNullString Then
        FrgWe = RS160.Fields("Value").Value
    Else
        FrgWe = vbNullString
    End If

    If WebID = WeGui Then
        If FrgNr > 23 Then 'WICHTIG!
            FraTx = S_AnBoG(FrgNr, "IDKurz")
            BogTx = S_AnBoF(BogID, "IDKurz")
            If FraTx = vbNullString Then
                FraTx = "Unbekannte Frage"
            End If
            If BogTx = vbNullString Then
                BogTx = "Unbekannter Fragebogen"
            End If
            Set RpRec = RpRcs.Add()
            Set RpItm = RpRec.AddItem(FrgNr)
            Set RpItm = RpRec.AddItem(FrgID)
            Set RpItm = RpRec.AddItem(FrgTy)
            Set RpItm = RpRec.AddItem(BogTx)
            Set RpItm = RpRec.AddItem(FraTx)
            Set RpItm = RpRec.AddItem(FrgWe)
            Set RpItm = RpRec.AddItem(WebID)
        End If
    End If
    
    RS160.MoveNext
    Loop Until RS160.EOF
End If

RpCo2.Populate

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCo1 = Nothing
Set RpCo2 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "F_An2 " & Err.Number
Resume Next

End Sub
Public Sub F_An3()
On Error GoTo LiErr
'Fügt einen neuen Patienten hinzu

Dim PatNr As Long
Dim AdPIN As Long
Dim TmGui As String
Dim Gesch As String
Dim PaGes As String
Dim PaNam As String
Dim PaVor As String
Dim PaGeb As String
Dim PaKur As String
Dim PaAnr As String
Dim PaBrf As String
Dim PaTel As String
Dim PaEma As String
Dim PaStr As String
Dim PaPLZ As String
Dim PaOrt As String
Dim PaLan As String
Dim ReGes As String
Dim ReVor As String
Dim ReNam As String
Dim ReGeb As String
Dim ReStr As String
Dim RePLZ As String
Dim ReOrt As String
Dim ReAnr As String
Dim ReBrf As String
