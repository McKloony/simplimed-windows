    Case 1: Set RS137 = DBCmRe1("qryTerNam5", "@IdStr", "%" & GlSuE.SuStr & "%")
    Case 2: Set RS137 = DBCmRe1("qryTerBet5", "@IdStr", "%" & GlSuE.SuStr & "%")
    End Select
Case "BaPo":
    Select Case SuTyp
    Case 1:
        Select Case GlSuE.SuIdx
        Case 0: Exit Sub
        Case 1: Set RS137 = DBCmRe1("qrySimOPNum2", "@IdStr", "%" & GlSuE.SuStr & "%")
        Case 2: Set RS137 = DBCmRe1("qrySimOPKur2", "@IdStr", "%" & GlSuE.SuStr & "%")
        Case 3: Set RS137 = DBCmRe1("qrySimOPDat2", "@IdDat", GlSuE.SuDat)
        Case 4: Set RS137 = DBCmRe1("qrySimOPBet2", "@IdBet", GlSuE.SuBet)
        End Select
    Case 5:
        Select Case GlSuE.SuIdx
        Case 0: Exit Sub
        Case 1:
            Select Case GlSuE.SuTyp
            Case "X": Set RS137 = DBCmRe1("qrySimReNum", "@IdStr", "%" & GlSuE.SuStr & "%")
            Case "Y": Set RS137 = DBCmRe1("qrySimReNu1", "@IdStr", "%" & GlSuE.SuStr & "%")
            Case Else: Set RS137 = DBCmRe2("qrySimReNu2", "@IdStr", "@IdTyp", "%" & GlSuE.SuStr & "%", GlSuE.SuTyp)
            End Select
        Case 2:
            Select Case GlSuE.SuTyp
            Case "X": Set RS137 = DBCmRe1("qrySimReKur", "@IdStr", "%" & GlSuE.SuStr & "%")
            Case "Y": Set RS137 = DBCmRe1("qrySimReKu3", "@IdStr", "%" & GlSuE.SuStr & "%")
            Case Else: Set RS137 = DBCmRe2("qrySimReKu4", "@IdStr", "@IdTyp", "%" & GlSuE.SuStr & "%", GlSuE.SuTyp)
            End Select
        Case 3:
            Select Case GlSuE.SuTyp
            Case "X": Set RS137 = DBCmRe1("qrySimReDat", "@IdDat", GlSuE.SuDat)
            Case "Y": Set RS137 = DBCmRe1("qrySimReDt1", "@IdDat", GlSuE.SuDat)
            Case Else: Set RS137 = DBCmRe2("qrySimReDt2", "@IdDat", "@IdTyp", GlSuE.SuDat, GlSuE.SuTyp)
            End Select
        Case 4: Exit Sub
        End Select
    End Select
Case "ArLi":  'Artikelkatalog
    Select Case SuTyp
    Case 1:
        Select Case GlSuE.SuIdx
        Case 0: Set RS137 = DBCmRe1("qryKat12G", "@IdxNr", IdxNr)
        Case 1: Set RS137 = DBCmRe2("qryKat12N", "@IdxNr", "@IdStr", IdxNr, "%" & GlSuE.SuStr & "%")
        Case 2: Set RS137 = DBCmRe2("qryKat12M", "@IdxNr", "@IdStr", IdxNr, GlSuE.SuStr & "%")
        Case 3: Set RS137 = DBCmRe2("qryKat12P", "@IdxNr", "@IdStr", IdxNr, GlSuE.SUpRe & GlSuE.SuStr)
        Case 4: Set RS137 = DBCmRe2("qryKat12N", "@IdxNr", "@IdStr", IdxNr, GlSuE.SuStr & "%")
        Case 5: Set RS137 = DBCmRe1("qryKat12F", "@IdxNr", IdxNr)
        End Select
    Case 2:
        Select Case GlSuN.SuIdx
        Case 0: Set RS137 = DBCmRe1("qryKat12H", "@IdxNr", IdxNr)
        Case 1: Set RS137 = DBCmRe0("SELECT * FROM qryKat12B WHERE [ID3]=" & IdxNr & " AND [IDKurz] Like '%" & GlSuN.SuStr & "%'", True)
        Case 2: Set RS137 = DBCmRe0("SELECT * FROM qryKat12B WHERE [ID3]=" & IdxNr & " AND [GOID] Like '" & GlSuN.SuStr & "%'", True)
        Case 3: Set RS137 = DBCmRe0("SELECT * FROM qryKat12B WHERE [ID3]=" & IdxNr & " AND [Preis1]" & GlSuN.SUpRe & GlSuN.SuStr, True)
        Case 4: Set RS137 = DBCmRe0("SELECT * FROM qryKat12B WHERE [ID3]=" & IdxNr & " AND [IDKurz] Like '" & GlSuN.SuStr & "%'", True)
        Case 5: Set RS137 = DBCmRe1("qryKat12I", "@IdxNr", IdxNr)
        End Select
    End Select
End Select

GesZa = RS137.RecordCount

Select Case PaFrm
Case "GbEi": GrVor = True
Case "KrDi": GrVor = True
Case "DiEi": GrVor = True
Case Else: GrVor = False
End Select

If SuTyp = 2 Then
    KetMe = True
ElseIf SuTyp = 5 Then
    KetMe = True
End If

If GesZa > 0 Then
    Select Case PaFrm
    Case "ReSe": P_RecW RS137
    Case "BaPo": P_RecH RS137, KetMe
    Case "TxPh": P_RecT RS137, KetMe
    Case Else: P_RecA RS137, PaFrm, KetMe, GrVor
    End Select
End If

RS137.Close
Set RS137 = Nothing

With RpCon
    If KetMe = False Then
        Select Case PaFrm
        Case "KrDi":
            If GlGrD = True Then
                If GrVor = True Then
                    .SortOrder.Add .Columns(Kat_Gruppe)
                    .GroupsOrder.Add .Columns(Kat_Gruppe)
                    .GroupsOrder(0).SortAscending = True
                End If
            End If
        Case "DiEi":
            If GlGrD = True Then
                If GrVor = True Then
                    .SortOrder.Add .Columns(Kat_Gruppe)
                    .GroupsOrder.Add .Columns(Kat_Gruppe)
                    .GroupsOrder(0).SortAscending = True
                End If
            End If
        Case "GbEi":
            If GlKaG = True Then
                If GrVor = True Then
                    .SortOrder.Add .Columns(Kat_Gruppe)
                    .GroupsOrder.Add .Columns(Kat_Gruppe)
                    .GroupsOrder(0).SortAscending = True
                End If
            End If
        End Select
    End If
End With

If GesZa > 0 Then
    RpCon.Populate
    Set RpRws = RpCon.Rows
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            Set RpGrw = RpRow
            Set ChRws = RpGrw.Childs
            GrAnz = ChRws.Count
            For Each ChRow In ChRws
                If IsNumeric(ChRow.Record.Item(Kat_Preis1).Value) Then
                    GrPre = GrPre + ChRow.Record.Item(Kat_Preis1).Value
                End If
            Next ChRow
            If Len(RpGrw.GroupCaption) > 8 Then
                GrCap = Right$(RpGrw.GroupCaption, Len(RpGrw.GroupCaption) - 8)
                RpGrw.GroupCaption = GrCap & " (" & GrAnz & ")"
            End If
        End If
        GrPre = 0
    Next RpRow
    If RowNr > 0 Then
        If RowNr >= RpRws.Count Then
            RowNr = RpRws.Count - 1
        End If
        RpCon.TopRowIndex = RowFi
        RpRws.Row(0).Selected = False
        RpRws.Row(RowNr).EnsureVisible
        RpRws.Row(RowNr).Selected = True
        If GlFoc = True Then
            Set RpCon.FocusedRow = RpRws.Row(RowNr)
        End If
    Else
        RpRws.Row(0).Selected = True
    End If
End If

Set RpRws = Nothing
Set RpCon = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "P_LiSu " & Err.Number
Resume Next

End Sub
Private Sub P_RecA(ByRef RST As ADODB.Recordset, ByVal PaFrm As String, Optional ByVal KetMe As Boolean = False, Optional ByVal GrVor As Boolean = False)
On Error GoTo LiErr
'Füllt die Tabelle mit Daten

Dim MitNr As Long
Dim ManNr As Long
Dim MaStr As String
Dim Multi As Single
Dim Prior As Integer
Dim AktZa As Integer
Dim FakPr As Boolean
Dim CmBrs As XtremeCommandBars.CommandBars
Dim RpCon As XtremeReportControl.ReportControl

Select Case PaFrm
Case "AnEi": Set FM = frmKatAE
             Set RpCon = FM.repCont7
Case "KrDi": Set FM = frmKatKD
             Set RpCon = FM.repCont7
Case "KrMe": Set FM = frmKatKM
             Set RpCon = FM.repCont7
Case "BeEi": Set FM = frmKatBE
             Set RpCon = FM.repCont7
Case "DiEi": Set FM = frmKatDE
             Set RpCon = FM.repCont7
Case "GbEi": Set FM = frmKatGE
             Set RpCon = FM.repCont7
Case "LaEi": Set FM = frmKatLE
             Set RpCon = FM.repCont7
Case "LaPa": Set FM = frmKatPE
             Set RpCon = FM.repCont7
Case "MeEi": Set FM = frmKatME
             Set RpCon = FM.repCont7
Case "ReEi": Set FM = frmKatRE
             Set RpCon = FM.repCont7
Case "TeDe": Set FM = frmKatTE
             Set RpCon = FM.repCont7
Case "TxPh": Set FM = frmKatTX
             Set RpCon = FM.repCont7
Case "ReSe": Set FM = frmKatRC
             Set RpCon = FM.repCont7
Case "ArLi": Set FM = frmKatAR
             Set RpCon = FM.repCont7
End Select

Set RpRcs = RpCon.Records

Set CmBrs = frmMain.comBar01
Set CmSta = CmBrs.StatusBar

Do
Set RpRec = RpRcs.Add()
If KetMe = True Then 'Ketten
    Select Case PaFrm
    Case "TeDe":
        If RST.Fields("IDP").Value <> vbNullString Then
            ManNr = RST.Fields("IDP").Value
        Else
            ManNr = 0
        End If
        If RST.Fields("IDM").Value <> vbNullString Then
            MitNr = RST.Fields("IDM").Value
        Else
            MitNr = 0
        End If
        If RST.Fields("Priorität").Value <> vbNullString Then
            Prior = RST.Fields("Priorität").Value
        Else
            Prior = 0
        End If
        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
            For AktZa = 1 To UBound(GlMiT)
                If MitNr = GlMiT(AktZa, 2) Then
                    If GlMiT(AktZa, 27) <> vbNullString Then
                        MaStr = GlMiT(AktZa, 27)
                    Else
                        MaStr = GlMiT(AktZa, 1)
                    End If
                    Exit For
                End If
            Next AktZa
        Else
            For AktZa = 1 To UBound(GlMaT)
                If ManNr = GlMaT(AktZa, 2) Then
                    If GlMaT(AktZa, 1) <> vbNullString Then
                        MaStr = GlMaT(AktZa, 1)
                    Else
                        MaStr = GlMaT(AktZa, 1)
                    End If
                    Exit For
                End If
            Next AktZa
        End If
        Set RpItm = RpRec.AddItem(RST.Fields("ID0").Value)
        Set RpItm = RpRec.AddItem(MitNr)
        Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
        If Prior > 0 Then
            Select Case Prior
            Case 1: RpItm.Icon = IC16_Calendar_Add
            Case 2: RpItm.Icon = IC16_IDCard_Norm
            Case 3: RpItm.Icon = IC16_Calendar_Clock
            Case 4: RpItm.Icon = IC16_Phone_Mobil
            End Select
        Else
            RpItm.Icon = IC16_IDCard_Norm
        End If
        Set RpItm = RpRec.AddItem(MaStr)
        Set RpItm = RpRec.AddItem(ManNr)
        Set RpItm = RpRec.AddItem(Format$(RST.Fields("Geändert").Value, "dd.mm.yyyy"))
    Case "TxPh":
        Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
        RpItm.Icon = IC16_Doc_Norm
    Case Else:
        Set RpItm = RpRec.AddItem(RST.Fields("ID1").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("GOID").Value)
        RpItm.Icon = IC16_Link_Norm
        Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
    End Select
    Select Case PaFrm
    Case "KrDi":
        Set RpItm = RpRec.AddItem(0) 'Gruppe
        Set RpItm = RpRec.AddItem(0)
        Set RpItm = RpRec.AddItem(0)
    Case "DiEi":
        Set RpItm = RpRec.AddItem(0) 'Gruppe
        Set RpItm = RpRec.AddItem(0)
        Set RpItm = RpRec.AddItem(0)
    Case "TeDe":
        Set RpItm = RpRec.AddItem(0) 'Gruppe
        Set RpItm = RpRec.AddItem(0)
        Set RpItm = RpRec.AddItem(0)
    Case Else:
        Set RpItm = RpRec.AddItem(0) 'Gruppe
        Set RpItm = RpRec.AddItem(Format$(RST.Fields("Preis").Value, GlWa1))
        Set RpItm = RpRec.AddItem(0)
    End Select
    Select Case PaFrm
    Case "GbEi":
        Set RpItm = RpRec.AddItem(0)
    Case "TeDe":
        If RST.RecordCount > 0 Then
            If RST.Fields("Hinweis").Value <> vbNullString Then
                RpRec.PreviewText = RST.Fields("Hinweis").Value
            End If
        End If
    End Select
Else
    Select Case PaFrm
    Case "BeEi":
        Set RpItm = RpRec.AddItem(RST.Fields("ID0").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("GOIK").Value)
        RpItm.Icon = IC16_Doc_Norm
        Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
    Case "TeDe":
        Set RpItm = RpRec.AddItem(RST.Fields("ID1").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("GOID").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
        RpItm.Icon = IC16_Link_Norm
    Case "TxPh":
        If GlPzn = True Then
            Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value & " (" & RST.Fields("GOID").Value & ")")
        Else
            Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
        End If
        RpItm.Icon = IC16_Doc_Norm
    Case Else:
        Set RpItm = RpRec.AddItem(RST.Fields("ID0").Value)
        Set RpItm = RpRec.AddItem(RST.Fields("GOID").Value)
        RpItm.Icon = IC16_Doc_Norm
        Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
    End Select
    If GrVor = True Then
        If Len(RST.Fields("Gruppe").Value) > 0 Then
            Set RpItm = RpRec.AddItem(RST.Fields("Gruppe").Value)
        Else
            Set RpItm = RpRec.AddItem(vbNullString)
        End If
    Else
        If PaFrm <> "TxPh" Then
            Set RpItm = RpRec.AddItem(vbNullString)
        End If
    End If
    Select Case PaFrm
    Case "KrDi":
        Set RpItm = RpRec.AddItem(0)
    Case "DiEi":
        Set RpItm = RpRec.AddItem(0)
    Case "MeEi":
        Set RpItm = RpRec.AddItem(Format$(RST.Fields("Preis3").Value, GlWa1))
    Case "KrMe":
        Set RpItm = RpRec.AddItem(Format$(RST.Fields("Preis3").Value, GlWa1))
    Case "ArLi":
        Set RpItm = RpRec.AddItem(Format$(RST.Fields("Preis3").Value, GlWa1))
    Case "TeDe":
        Set RpItm = RpRec.AddItem(Format$(RST.Fields("Zeit").Value, "000" & " Min"))
    Case Else:
        FakPr = False
        If IsNull(RST.Fields("Einheit").Value) = False Then
            If RST.Fields("Einheit").Value <> vbNullString Then
                If RST.Fields("Einheit").Value = "1" Then
                    FakPr = True
                End If
            End If
        End If
        If IsNull(RST.Fields("Multi").Value) = False Then
            If RST.Fields("Multi").Value > 0 Then
                Multi = RST.Fields("Multi").Value
            Else
                Multi = 1
            End If
        Else
            Multi = 1
        End If
        If FakPr = True Then
            Set RpItm = RpRec.AddItem(Format$(RST.Fields("Preis2").Value, GlWa1))
        Else
            Set RpItm = RpRec.AddItem(Format$(WinRound(RST.Fields("Preis1").Value * Multi, 2), GlWa1))
        End If
    End Select
    RpItm.Alignment = xtpAlignmentCenter
    Set RpItm = RpRec.AddItem(0)
    Select Case PaFrm
    Case "GbEi":
        Set RpItm = RpRec.AddItem(RST.Fields("IDT").Value)
    Case "TeDe":
    Case Else:
        If GrVor = True Then
            If RST.Fields("Kommentar").Value <> vbNullString Then
                RpRec.PreviewText = RST.Fields("Kommentar").Value
            End If
        End If
    End Select
End If

RST.MoveNext
Loop Until RST.EOF

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCon = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "P_RecA " & Err.Number
Resume Next

End Sub
Private Sub P_RecB(ByRef RST As ADODB.Recordset, ByVal PaFrm As String, Optional ByVal KetMe As Boolean = False)
On Error GoTo LiErr
'Füllt die Tabelle mit Daten

Dim KtoNr As Long
Dim GeKNr As Long
Dim ManNr As Long
Dim BetBu As Double
Dim Koste As Single
Dim WaStr As String
Dim KtoBe As String
Dim GktBe As String
Dim KtBeS As String
Dim KtBeH As String
Dim GegSt As String
Dim GegKt As String
Dim GeKId As Integer
Dim BuWar As Integer
Dim BuTyp As Integer
Dim Lange As Integer
Dim AktZa As Integer
Dim RpCon As XtremeReportControl.ReportControl

Select Case PaFrm
Case "BuVo": Set FM = frmKatBU
             Set RpCon = FM.repCont7
Case "BuSe": Set FM = frmKatBU
             Set RpCon = FM.repCont7
Case "BaAb": Set FM = frmBaAbl
             Set RpCon = FM.repCont7
End Select

Set RpRcs = RpCon.Records

Do
BuTyp = RST.Fields("IDA").Value
BuWar = RST.Fields("Währung").Value
