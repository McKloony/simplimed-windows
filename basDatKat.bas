Public Function K_BePr(NeZal As Single) As Single
On Error GoTo GrErr
'Bestandsprüfung

Dim ReNum As Long
Dim IdxNr As Long
Dim ArStr As String
Dim BesSo As Single
Dim BesMe As Single
Dim BeNeu As Single
Dim KrTyp As Integer
Dim Anzal As Integer
Dim RpRow As XtremeReportControl.ReportRow
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmMain
Set RpCo3 = FM.repCont3
Set RpCo6 = FM.repCont6

Set RpCls = RpCo3.Columns
Set RpSel = RpCo3.SelectedRows
    
If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        Set RpCol = RpCls.Find(Rec_ID1)
        ReNum = RpRow.Record(RpCol.ItemIndex).Value
    Else
        ReNum = 0
    End If
Else
    ReNum = 0
End If

Set RpCls = RpCo6.Columns
Set RpSel = RpCo6.SelectedRows

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        Set RpCol = RpCls.Find(Kra_KrTyp)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            If IsNumeric(RpRow.Record(RpCol.ItemIndex).Value) = True Then
                KrTyp = RpRow.Record(RpCol.ItemIndex).Value
            Else
                KrTyp = 0
            End If
        Else
            KrTyp = 0
        End If
        Set RpCol = RpCls.Find(Kra_ID4)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            If IsNumeric(RpRow.Record(RpCol.ItemIndex).Value) = True Then
                IdxNr = RpRow.Record(RpCol.ItemIndex).Value
            Else
                IdxNr = 0
            End If
        Else
            IdxNr = 0
        End If
        Set RpCol = RpCls.Find(Kra_Anz)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            If IsNumeric(RpRow.Record(RpCol.ItemIndex).Value) = True Then
                Anzal = RpRow.Record(RpCol.ItemIndex).Value
            Else
                Anzal = 0
            End If
        Else
            Anzal = 0
        End If

        If KrTyp = 9 Then 'Artikel
            If Anzal > 0 Then
                If IdxNr > 0 Then
                    Set RS116 = New ADODB.Recordset
                    RS116.CursorLocation = adUseClient
                    Set RS116 = DBCmRe1("qryKat12A", "@IdxNr", IdxNr)
                    If RS116.RecordCount > 0 Then
                        If RS116.Fields("Bestand_Soll").Value <> vbNullString Then
                            BesSo = RS116.Fields("Bestand_Soll").Value 'Sollbestabd
                        Else
                            BesSo = 0
                        End If
                        If RS116.Fields("Bestand_Melde").Value <> vbNullString Then
                            BesMe = RS116.Fields("Bestand_Melde").Value 'Meldebestand
                        Else
                            BesMe = 0
                        End If
                        If RS116.Fields("IDKurz").Value <> vbNullString Then
                            ArStr = RS116.Fields("IDKurz").Value
                        Else
                            ArStr = vbNullString
                        End If
                        If BesSo > 0 Then
                            BeNeu = BesSo - NeZal
                            If BeNeu <= BesMe Then
                                SPopu "Meldebestand erreicht", "Für " & ArStr & " wurde der Meldebestand erreicht oder unterschritten.", IC48_Warning
                            End If
                        Else
                            BeNeu = NeZal
                        End If
                    End If
                    RS116.Close
                    Set RS116 = Nothing
                End If
            End If
        End If
    End If
End If

K_BePr = BeNeu

Set RpCls = Nothing
Set RpSel = Nothing
Set RpCo3 = Nothing
Set RpCo6 = Nothing

Exit Function

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_BePr " & Err.Number
Resume Next

End Function
Public Sub K_Bere()
On Error GoTo OrErr
'Berechnet die Summe der Kette

Dim RowNr As Long
Dim AnzPo As Long
Dim IdxNr As Long
Dim TreKy As String
Dim Multi As Single
Dim EiPre As Double
Dim GePre As Double
Dim KePre As Double
Dim KeMin As Integer
Dim GeMin As Integer
Dim Anzal As Integer
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCo8 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo8 = FM.repCont8
Set RpCls = RpCo8.Columns
Set RpSel = RpCo8.SelectedRows

TreKy = Left$(GlNod, 1)
Tit1 = "Kette Aktualisieren"
AnzPo = RpSel.Count
If AnzPo > 1 Then
    Mld1 = "Möchten Sie die " & AnzPo & " markierten Ketten aktualisieren?"
Else
    Mld1 = "Möchten Sie die markierte Kette aktualisieren?"
End If

If AnzPo > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then

        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                Set RpCol = RpCls.Find(Kat_ID0)
                IdxNr = RpRow.Record(RpCol.ItemIndex).Value

                Select Case TreKy
                Case "D": DBCmEx1 "qryKetAnL", "@IdxNr", IdxNr 'Gebührenketten
                Case "F": DBCmEx1 "qryKetAnS", "@IdxNr", IdxNr 'Diagnoseketten
                Case "H": DBCmEx1 "qryKetAnO", "@IdxNr", IdxNr 'Laborprofile
                Case "J": DBCmEx1 "qryKetAnR", "@IdxNr", IdxNr 'Arzneiketten
                Case "R": DBCmEx1 "qryKon02R", "@IdxNr", IdxNr 'Terminketten
                Case "Q": DBCmEx1 "qryKetAnP", "@IdxNr", IdxNr 'Artikelketten
                End Select
                DoEvents

                Set RS155 = New ADODB.Recordset
                RS155.CursorLocation = adUseClient
                Select Case TreKy
                Case "D": Set RS155 = DBCmRe1("qryKetAk01", "@IdxNr", IdxNr) 'Gebührenketten
                Case "F": Set RS155 = DBCmRe1("qryKetAk03", "@IdxNr", IdxNr) 'Diagnoseketten
                Case "H": Set RS155 = DBCmRe1("qryKetAk04", "@IdxNr", IdxNr) 'Laborprofile
                Case "J": Set RS155 = DBCmRe1("qryKetAk02", "@IdxNr", IdxNr) 'Arzneiketten
                Case "R": Set RS155 = DBCmRe1("qryKon02E", "@IdxNr", IdxNr)  'Terminketten
                Case "Q": Set RS155 = DBCmRe1("qryKetAk05", "@IdxNr", IdxNr) 'Artikelketten
                End Select
                If RS155.RecordCount > 0 Then
                    If TreKy = "R" Then
                        KeMin = 0
                        Do
                        If RS155.Fields("Zeit").Value <> vbNullString Then
                            GeMin = RS155.Fields("Zeit").Value
                        Else
                            GeMin = 0
                        End If
                        RS155.MoveNext
                        KeMin = KeMin + GeMin
                        Loop Until RS155.EOF
                    Else
                        KePre = 0
                        Do
                        If RS155.Fields("Preis").Value <> vbNullString Then
                            If RS155.Fields("Preis").Value > 0 Then
                                EiPre = Format$(RS155.Fields("Preis").Value, GlWa1)
                            Else
                                EiPre = 0
                            End If
                        Else
                            EiPre = 0
                        End If
                        If RS155.Fields("x").Value <> vbNullString Then
                            If RS155.Fields("x").Value > 0 Then
                                Anzal = RS155.Fields("x").Value
                            Else
                                Anzal = 1
                            End If
                        Else
                            Anzal = 1
                        End If
                        If TreKy = "D" Then
                            If RS155.Fields("Multi").Value <> vbNullString Then
                                If RS155.Fields("Multi").Value > 0 Then
                                    Multi = RS155.Fields("Multi").Value
                                Else
                                    Multi = 1
                                End If
                            Else
                                If RS155.Fields("Multi2").Value <> vbNullString Then
                                    If RS155.Fields("Multi2").Value > 0 Then
                                        Multi = RS155.Fields("Multi2").Value
                                    Else
                                        Multi = 1
                                    End If
                                Else
                                    Multi = 1
                                End If
                            End If
                            GePre = WinRound(((EiPre * Multi) * Anzal), 2)
                        Else
                            GePre = WinRound((EiPre * Anzal), 2)
                        End If
                        KePre = KePre + GePre
                        RS155.MoveNext
                        Loop Until RS155.EOF
                    End If
                Else
                    GePre = 0
                    GeMin = 0
                End If
                RS155.Close
                Set RS155 = Nothing
                DoEvents

                Select Case TreKy
                Case "D": DBCmEx2 "qryKetAkL", "@IdSum", "@IdxNr", KePre, IdxNr 'Gebührenketten
                Case "F": DBCmEx2 "qryKetAkS", "@IdSum", "@IdxNr", KePre, IdxNr 'Diagnoseketten
                Case "H": DBCmEx2 "qryKetAkO", "@IdSum", "@IdxNr", KePre, IdxNr 'Laborprofile
                Case "J": DBCmEx2 "qryKetAkR", "@IdSum", "@IdxNr", KePre, IdxNr 'Arzneiketten
                Case "R": DBCmEx2 "qryKon02Z", "@IdMin", "@IdxNr", KeMin, IdxNr 'Terminketten
                Case "Q": DBCmEx2 "qryKetAkP", "@IdSum", "@IdxNr", KePre, IdxNr 'Artikelketten
                End Select
                DoEvents
            End If
        Next RpRow

        GlNeK = GlKoX 'Protokolleintrag
        With GlNeK
            .PatNr = GlMan(GlSMa, 2)
            .IdxNr = 0
            .EiDat = Format$(Date, "dd.mm.yyyy")
            .EiZei = TimeValue(Now)
            .EiTyp = 104
            Select Case TreKy
            Case "D": .TeStr = "Gebührenketten neu berechnet"
            Case "F": .TeStr = "Diagnoseketten neu berechnet"
            Case "H": .TeStr = "Laborprofile neu berechnet"
            Case "J": .TeStr = "Arzneiketten neu berechnet"
            Case "R": .TeStr = "Terminketten neu berechnet"
            Case "Q": .TeStr = "Artikelketten neu berechnet"
            End Select
            .ZiStr = Format$(Now, "hh:mm") & " Uhr"
            .NeuEi = True
            .KeiAk = True
            .Mitar = GlMiA(GlSmI, 2)
        End With
        S_Prot

        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            RowNr = RpRow.Index
            KUpKa RowNr
        End If
    End If
End If

Set RpSel = Nothing
Set RpRow = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo8 = Nothing

Exit Sub

OrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_Bere " & Err.Number
Resume Next

End Sub

