                    End If
                    If KtoNr > 0 Then
                        FM.txtKtoHa.Text = KtoNr
                    Else
                        FM.txtKtoHa.Text = 0
                    End If
                End If
                KtoSt = SBuFo(KtoNr) 'Sachkontenformatierung
                If GlBuF <= 4 Then
                    TxKto.Text = KtoSt & " " & KoStr
                ElseIf GlBuF <= 8 Then
                    TxHab.Text = KtoSt & " " & KoStr
                ElseIf GlBuF = 9 Then
                    TxKto.Text = KtoSt & " " & KoStr
                ElseIf GlBuF = 10 Then
                    TxHab.Text = KtoSt & " " & KoStr
                End If
                If RS128.Fields("Buchtext").Value <> vbNullString Then
                    If FM.cmbBuTex.Text = vbNullString Then
                        FM.cmbBuTex.Text = RS128.Fields("Buchtext").Value
                    End If
                End If
                
                If GlNeB = True Then 'neue Buchung
                    For AktZa = 1 To UBound(GlStu) 'Steuersätze
                        If CSng(GlStu(AktZa, 1)) = KoStu Then
                            FM.cmbBuStu.ListIndex = AktZa - 1
                            Exit For
                        End If
                    Next AktZa
                    If RS128.Fields("IDA").Value <> vbNullString Then
                        TmpNr = RS128.Fields("IDA").Value
                        If TmpNr > 2 Then TmpNr = 1
                        LiIdx = SCmb(FM.cmbBuTyp, TmpNr)
                        If GlBut <> RibTab_HomeBanki Then
                            FM.cmbBuTyp.ListIndex = LiIdx
                        End If
                    End If
                    If GlBut <> RibTab_HomeBanki Then
                        If RS128.Fields("IDB").Value <> vbNullString Then
