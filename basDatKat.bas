Set RpCls = RpCo7.Columns
Set RpRws = RpCo7.Rows

If RpRws.Count > 0 Then
    Set RpSel = RpCo7.SelectedRows
        If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
    End If
End If

Select Case PaFrm
Case "BuVo": Set FM = frmBuEdVo
Case "BuSe": Set FM = frmBuEdVo
Case "BaVo": Set FM = frmBaEdVo
End Select

Set CmSte = FM.cmbBuStu
Set CmTyp = FM.cmbBuTyp
Set CmMan = FM.cmbManda
Set CmMit = FM.cmbMitar
Set ChErl = FM.chkGewEr
Set PuBu1 = FM.cmdWeite

Mld1 = "Möchten Sie den Eintrag jetzt speichern?"
Tit1 = "Eintrag Speichern"

If FM.txtBuBet.Text <> vbNullString Then
    If IsNumeric(FM.txtBuBet.Text) = True Then
        BuBet = CDbl(FM.txtBuBet.Text)
    Else
        BuBet = 0
    End If
Else
    BuBet = 0
End If

If FM.txtIdxNr.Text <> vbNullString Then IdxWe = CLng(FM.txtIdxNr.Text)
If FM.txtKtoNr.Text <> vbNullString Then KtIdS = CLng(FM.txtKtoNr.Text)
If FM.txtKtoHa.Text <> vbNullString Then KtNrH = CLng(FM.txtKtoHa.Text)
If FM.txtBezei.Text <> vbNullString Then KtBeS = CStr(FM.txtBezei.Text)
If FM.txtBezHa.Text <> vbNullString Then KtBeH = CStr(FM.txtBezHa.Text)
If FM.cmbBuTex.Text <> vbNullString Then BuTex = CStr(FM.cmbBuTex.Text)

BuTyp = CmTyp.ItemData(CmTyp.ListIndex)
GeKto = FM.cmbGegen.ItemData(FM.cmbGegen.ListIndex)

If GlNeB = True Then 'neue Buchung
    TmGui = CreateID("V")
    If GlTyp < 2 Then
        SQL1 = "SELECT * FROM dbo.qrySimBuVoNe"
    Else
        SQL1 = "SELECT * FROM qrySimBuVoNe;"
    End If
Else
    If RpRow.GroupRow = False Then
        Set RpCol = RpCls.Find(Buh_ID0)
        IdxNr = RpRow.Record(RpCol.ItemIndex).Value
    Else
        IdxNr = 0
    End If
    If GlTyp < 2 Then
        SQL1 = "SELECT * FROM dbo.qrySimBuVoSu WHERE ID0 = " & IdxNr
    Else
        SQL1 = "SELECT * FROM qrySimBuVoSu WHERE [ID0] = " & IdxNr & ";"
    End If
End If

If IdxWe = 0 Then
    Set RS130 = New ADODB.Recordset
    RS130.CursorLocation = adUseClient
    Set RS130 = DBCmRe2("qrySimBuKtS", "@IdxNr", "@RamNr", KtIdS, GlKtR)
    If RS130.RecordCount > 0 Then
        IdxWe = RS130.Fields("IDI").Value
    End If
    RS130.Close
    Set RS130 = Nothing
End If

Set RS125 = New ADODB.Recordset
With RS125
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With

If GlNeB = True Then 'neue Buchung
    If RS125.Supports(adAddNew) Then
        RS125.AddNew
        RS125.Fields("IDR").Value = GlKtR
        RS125.Fields("GuiID").Value = TmGui
    End If
Else
    If RS125.RecordCount = 0 Then
        RS125.Close
        Set RS125 = Nothing
        Exit Sub
    End If
End If

RS125.Fields("IDP").Value = IdxWe
RS125.Fields("IDK").Value = KtIdS
RS125.Fields("IDKurz").Value = KtBeS
RS125.Fields("IDGegen").Value = KtBeH
RS125.Fields("IDB").Value = GeKto
RS125.Fields("Währung").Value = 1
If GlBuc = True Then 'einfache Buchhaltung verwenden
    RS125.Fields("IDG").Value = 0
    Select Case BuTyp
    Case 1: RS125.Fields("Ausgabe").Value = BuBet
            RS125.Fields("Einnahme").Value = 0
    Case 2: RS125.Fields("Einnahme").Value = BuBet
            RS125.Fields("Ausgabe").Value = 0
    End Select
Else
    RS125.Fields("IDG").Value = KtNrH
    RS125.Fields("Einnahme").Value = BuBet
    RS125.Fields("Ausgabe").Value = 0
    RS125.Fields("Doppelt").Value = -1
End If
If CmMan.ListIndex >= 0 Then
    RS125.Fields("IDT").Value = CmMan.ItemData(CmMan.ListIndex)
End If
If CmMit.ListIndex >= 0 Then
    RS125.Fields("IDM").Value = CmMit.ItemData(CmMit.ListIndex)
End If
If CmSte.ListIndex >= 0 Then
    StuZa = CmSte.ItemData(CmSte.ListIndex)
    For AktZa = 1 To UBound(GlStu)
        If GlStu(AktZa, 0) = StuZa Then
            Steue = CSng(GlStu(AktZa, 1))
            If Steue > 0 And Steue < 1 Then
                Steue = Steue * 100
            End If
            RS125.Fields("Steuer").Value = Steue
            Exit For
        End If
    Next AktZa
End If

RS125.Fields("Datum").Value = Date
RS125.Fields("Buchtext").Value = BuTex
RS125.Fields("IDA").Value = CmTyp.ItemData(CmTyp.ListIndex)
If ChErl.Value = 1 Then
    RS125.Fields("Ermittlung").Value = -1
End If

RS125.Update
RS125.Close
Set RS125 = Nothing

If GlNeB = False Then 'neue Buchung
    DoEvents
    GlNeK = GlKoX 'Protokolleintrag
    With GlNeK
        .PatNr = GlMan(GlSMa, 2)
        .IdxNr = 0
        .EiDat = Format$(Date, "dd.mm.yyyy")
        .EiZei = TimeValue(Now)
        .EiTyp = 104
        .TeStr = "Buchungsvorlage geändert - (" & Date & ") - " & BuTex
        .ZiStr = Format$(Now, "hh:mm") & " Uhr"
        .NeuEi = True
        .KeiAk = True
        .Mitar = GlMiA(GlSmI, 2)
    End With
    S_Prot
End If

Set RpCo7 = Nothing

Select Case RbTab.id
Case RibTab_Kat_EinBuc: P_List PaFrm, 0, 1
Case RibTab_Kat_KetBuc: P_List PaFrm, 0, 2
End Select

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_BuSa " & Err.Number
Resume Next

End Sub
