Public Sub S_BDT0(ByVal FiNam As String, ByVal ErwIm As Boolean, Optional ByVal MuSel As Boolean = False, Optional ByVal XBDaT As Boolean = False)
On Error GoTo LiErr
'BDT Datei öffnen

Dim Gefun As Long   'Gefundene Position
Dim StaWe As Long   'Startwert der Textsuche
Dim BerAr As Long   'Berichtart
Dim FldKn As Long   'Feldkennung
Dim FldLa As Long   'Feldlänge
Dim GesZa As Long
Dim AktZa As Long
Dim GesFi As Long
Dim AktFi As Long
Dim VerNu As Long
Dim AkZei As String 'Aktuelle Zeile
Dim FldIn As String 'FeldInhalt
Dim ImDat As String
Dim DaPfa As String
Dim DaNam As String
Dim NeuNa As String
Dim AryDa() As String
Dim AryIt() As String
Dim StLab As XtremeSuiteControls.Label

Set FM = frmMain
Set CoDia = FM.comDialo

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

AktFi = 1

If MuSel = True Then
    AryIt = Split(FiNam, ";")
    GesFi = UBound(AryIt)
Else
    GesFi = 1
End If

DBCmExT "qrySimBDTLo"
DoEvents

For AktFi = 1 To GesFi
    If MuSel = True Then
        clFil.FilPfa AryIt(AktFi)
    Else
        clFil.FilPfa FiNam
    End If
    
    DaNam = clFil.DaNam
    DaPfa = clFil.DaPfa & "\"
    NeuNa = DaPfa & "_" & DaNam
    DoEvents
    ImDat = clFil.FilReSt
    DoEvents

    frmStatus.Show
    DoEvents
    Set PrBr1 = frmStatus.prbStat1
    Set PrBr2 = frmStatus.prbStat2
    Set TxDum = frmStatus.txtDummy
    Set StLab = frmStatus.lblLab01
        
    Set RS154 = New ADODB.Recordset
    With RS154
        .CursorLocation = adUseClient
        .Source = "qrySimBDT"
        .ActiveConnection = DB1
        .CursorType = adOpenKeyset
        .LockType = adLockOptimistic
        .Open Options:=adCmdTableDirect
    End With
    
    AryDa = Split(ImDat, Chr$(13) + Chr$(10))
    DoEvents
    GesZa = UBound(AryDa)
    StaWe = 1
    PrBr1.Min = 0
    PrBr1.Max = GesZa
    frmStatus.Caption = "Einlesen der BDT-Datei..."
    
    For AktZa = 0 To GesZa - 1
        AkZei = AryDa(AktZa)
        If Len(AkZei) > 3 Then
            If Left$(AkZei, 1) <> Chr$(32) Then
                FldIn = Trim$(Mid$(AkZei, 8, Len(AkZei) - 7))
                If FldIn <> vbNullString Then
                    FldIn = Trim$(Mid$(AkZei, 8, Len(AkZei) - 8))
                    If GlIFo = "X2" Then FldIn = SZech(FldIn, True)
                    If IsNumeric(Mid$(AkZei, 4, 4)) Then FldKn = CLng(Mid$(AkZei, 4, 4))
                    If FldKn = 8000 Then BerAr = Val(Trim$(FldIn))
                    If IsNumeric(Left$(AkZei, 3)) Then
                        If FldIn <> vbNullString Then
                            If Len(FldIn) > 250 Then FldIn = Left$(FldIn, 250)
                            RS154.AddNew
                            FldLa = CLng(Left$(AkZei, 3))
                            RS154.Fields("Länge").Value = FldLa
                            RS154.Fields("Feldkennung").Value = FldKn
                            RS154.Fields("Feldinhalt").Value = FldIn
                            RS154.Fields("Berichtsart").Value = BerAr
                            RS154.Update
                        End If
                    End If
                End If
            End If
        End If
        DoEvents
        PrBr1.Value = AktZa
        StLab.Caption = FldIn
        If TxDum.Text = "B" Then Exit For 'Abbrechen
    Next AktZa
    RS154.Close
    Set RS154 = Nothing
    
    Unload frmStatus
    DoEvents

    S_BDT1 XBDaT
    DoEvents
    S_BDT2 XBDaT
    DoEvents
    
    If ErwIm = True Then
        S_BDT3 XBDaT
        DoEvents
        S_BDT4 XBDaT
        DoEvents
        S_BDT5 XBDaT
        DoEvents
    End If
    
    DBCmEx0 "qrySimBDT2"
    DoEvents
    DBCmEx0 "qrySimBDT3"
    DoEvents

    If MuSel = True Then
        clFil.DaCop = AryIt(AktFi) & ";" & NeuNa & vbNullChar
    Else
        clFil.DaCop = FiNam & ";" & NeuNa & vbNullChar
    End If
    clFil.FilCop 3
    DoEvents
Next AktFi

If GlLog = False Then 'General Logging
    DBCmExT "qrySimBDTLo"
    DoEvents
End If

Set clFil = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BDT0 " & Err.Number
Exit Sub

End Sub
