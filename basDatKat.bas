Set RpRcs = RpCo7.Records
Set TxDe6 = frmMain.txtDeta6
Set LiVw1 = frmMain.lstView1
Set RpCo3 = frmMain.repCont3
Set RpCls = RpCo3.Columns
Set RpSel = RpCo3.SelectedRows
Set CmAcs = CmBrs.Actions

AnzLe = RpRcs.Count

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    Set RpCol = RpCls.Find(Rec_ID1)
    ReNum = RpRow.Record(RpCol.ItemIndex).Value
Else
    ReNum = 0
End If

If AnzLe > 0 Then
    If ReNum > 0 Then
        Set RS125 = New ADODB.Recordset
        RS125.CursorLocation = adUseClient
        If GlDSo = True Then 'Katalogdiagnosen alphabetisch sortieren
            Set RS125 = DBCmRe1("qrySimAbDiag", "@IdxNr", ReNum)
        Else
            Set RS125 = DBCmRe1("qrySimAbDia5", "@IdxNr", ReNum)
        End If
        ReDia = RS125.RecordCount
        
        If ReDia > 0 Then
            Do
            If IsNull(RS125.Fields("IDKurz").Value) = False Then
                If RS125.Fields("IDKurz").Value <> vbNullString Then
                    If RS125.Fields("ID1").Value > 0 Then
                        DiGrp = RS125.Fields("ID1").Value
                    Else
                        DiGrp = 0
                    End If
                
                    Set RS128 = New ADODB.Recordset
                    RS128.CursorLocation = adUseClient
                    Set RS128 = DBCmRe1("qryKat07B", "@IdxNr", DiGrp)
                    AnDia = RS128.RecordCount
                    
                    If AnDia > 0 Then
                        Do
                        IdStr = LCase(RS128.Fields("GOID").Value)
    
                        For Each RpRec In RpRcs
                            DatNr = RpRec.Index + 1
                            SuStr = LCase(RpRec.Item(1).Value)
                            
                            If SuStr = IdStr Then
                                GlKaE = True 'Expertensystem
                                ReDim Preserve GlKPo(DatNr)
                                GlKPo(DatNr) = DatNr
                            End If
                            
                        Next RpRec
                        RS128.MoveNext
                        Loop Until RS128.EOF
                        
                    End If
                    RS128.Close
                    Set RS128 = Nothing
                        
                End If
            End If
            RS125.MoveNext
            Loop Until RS125.EOF
            
        End If
        RS125.Close
        Set RS125 = Nothing
    End If
End If

If GlKaE = True Then 'Expertensystem
    CmAcs(KA_Eint_Vollst).Enabled = True
End If

Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCo3 = Nothing
Set RpCo7 = Nothing
Set CmBrs = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_AnSu " & Err.Number
Resume Next

End Sub
Public Sub K_AnVo(ByVal IdxNr As Long)
On Error GoTo LiErr
'Füllt die Detailansicht mit Informationen

Dim AktZa As Integer
Dim RpCo2 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmKaEdit
Set RpCo2 = FM.repCont2
Set RpRcs = RpCo2.Records

With RpCo2
    .EditItem Nothing, Nothing
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    If .Records.Count > 0 Then .Records.DeleteAll
    .Populate
End With

If IdxNr > 0 Then
    Set RS128 = New ADODB.Recordset
    RS128.CursorLocation = adUseClient
    Set RS128 = DBCmRe1("qryKat07C", "@IdxNr", IdxNr)
    GlADi = RS128.RecordCount
    If GlADi > 0 Then
        With RpCo2
            .EditItem Nothing, Nothing
            If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
            If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
            If .Records.Count > 0 Then .Records.DeleteAll
            .Populate
        End With

        GlDiy = RS128.GetRows 'Array Füllen
        DoEvents
        
        RpCo2.SetVirtualMode GlADi
        DoEvents
        
        Set RpRec = RpCo2.Records(0)
        For AktZa = 0 To 3
            Set RpItm = RpRec.AddItem(vbNullString)
        Next AktZa
    
        DoEvents
        With RpCo2
            .Populate
            .SetCustomDraw xtpCustomBeforeDrawRow
        End With
    Else
        Erase GlDiy
        RpCo2.SetVirtualMode 0
                            
        DoEvents
        With RpCo2
            .Populate
            .SetCustomDraw xtpCustomBeforeDrawRow
        End With
    End If
    RS128.Close
    Set RS128 = Nothing
    
    If GlADi > 0 Then
        RpCo2.Populate
        Set RpRws = RpCo2.Rows
        RpRws.Row(0).Selected = True
    End If
End If

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpRws = Nothing
Set RpCo2 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_AnVo " & Err.Number
Resume Next

End Sub
Private Function K_BaLi(ByVal inputText As String) As String
On Error GoTo LiErr
'Entfernt , zwischen den ".."

Dim ReStr As String
Dim ZeiVo As Boolean
Dim AktZa As Integer
Dim AkZei As String

ReStr = ""
ZeiVo = False

For AktZa = 1 To Len(inputText)
    AkZei = Mid$(inputText, AktZa, 1)

    If AkZei = """" Then
        ZeiVo = Not ZeiVo
        ReStr = ReStr & AkZei
    ElseIf ZeiVo And AkZei = "," Then
        ' Do nothing
    Else
        ReStr = ReStr & AkZei
    End If
Next AktZa

K_BaLi = ReStr

Exit Function

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_BaLi " & Err.Number
Exit Function

End Function
