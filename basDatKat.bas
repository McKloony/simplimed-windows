Public Sub K_Such()
On Error GoTo LiErr
'Füllt die Tabelle mit Daten

Dim GesZa As Long
Dim IdxNr As Long
Dim GrPre As Single
Dim TreKy As String
Dim GrCap As String
Dim LiGrp As Boolean
Dim KetMe As Boolean
Dim ZeiUm As Boolean
Dim GrVor As Boolean
Dim GrAnz As Integer
Dim AktZa As Integer
Dim CmBrs As XtremeCommandBars.CommandBars
Dim RpCo8 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set CmBrs = FM.comBar01
Set RpCo8 = FM.repCont8
Set CmAcs = CmBrs.Actions

TreKy = UCase(Left$(GlNod, 1))
IdxNr = Mid$(GlNod, 2, Len(GlNod) - 1)

If IdxNr = 0 Then
    Exit Sub
End If

With RpCo8
    .EditItem Nothing, Nothing
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    If .Records.Count > 0 Then .Records.DeleteAll
    .Populate
End With

Set RS153 = New ADODB.Recordset
RS153.CursorLocation = adUseClient
Select Case TreKy
Case "C": 'Diagnosen
    If IdxNr = 1 Then 'Meine Diagnoseauswahl
        Select Case GlSuE.SuIdx
        Case 1: Set RS153 = DBCmRe1("qryKat03D", "@IdStr", "%" & GlSuE.SuStr & "%")
        Case 2: Set RS153 = DBCmRe1("qryKat03G", "@IdStr", GlSuE.SuStr & "%")
        Case 4: Set RS153 = DBCmRe2("qryKat03P", "@IdxNr", "@IdStr", IdxNr, GlSuE.SuStr & "%")
        End Select
    Else
        Select Case GlSuE.SuIdx
        Case 1: Set RS153 = DBCmRe2("qryKat03N", "@IdxNr", "@IdStr", IdxNr, "%" & GlSuE.SuStr & "%")
        Case 2: Set RS153 = DBCmRe2("qryKat03M", "@IdxNr", "@IdStr", IdxNr, GlSuE.SuStr & "%")
        Case 4: Set RS153 = DBCmRe2("qryKat03P", "@IdxNr", "@IdStr", IdxNr, GlSuE.SuStr & "%")
        End Select
    End If
Case "I": 'Arzneimittel
    Select Case GlSuE.SuIdx
    Case 1: Set RS153 = DBCmRe1("qryKat04D", "@IdStr", "%" & GlSuE.SuStr & "%")
    Case 2: Set RS153 = DBCmRe1("qryKat04Q", "@IdStr", GlSuE.SuStr & "%")
    Case 4: Set RS153 = DBCmRe2("qryKat04N", "@IdxNr", "@IdStr", IdxNr, GlSuE.SuStr & "%")
    End Select
Case "N": 'Fragebogen
    Select Case GlSuE.SuIdx
    Case 1: Set RS153 = DBCmRe1("qryKat08D", "@IdStr", "%" & GlSuE.SuStr & "%")
    Case 2: Set RS153 = DBCmRe2("qryKat08E", "@IdxNr", "@IdStr", IdxNr, GlSuE.SuStr & "%")
    Case 4: Set RS153 = DBCmRe2("qryKat08E", "@IdxNr", "@IdStr", IdxNr, GlSuE.SuStr & "%")
    End Select
Case "P": 'Artikelliste
    Select Case GlSuE.SuIdx
    Case 1: Set RS153 = DBCmRe1("qryKat12D", "@IdStr", "%" & GlSuE.SuStr & "%")
    Case 2: Set RS153 = DBCmRe2("qryKat12M", "@IdxNr", "@IdStr", IdxNr, GlSuE.SuStr & "%")
    Case 4: Set RS153 = DBCmRe2("qryKat12N", "@IdxNr", "@IdStr", IdxNr, GlSuE.SuStr & "%")
    End Select
End Select

GesZa = RS153.RecordCount

If GesZa > 0 Then
    K_Rec RS153, TreKy
End If

RS153.Close
Set RS153 = Nothing

With RpCo8
    If KetMe = False Then
        If GlGrG = True Then 'Gruppierung Kataloge
            If GrVor = True Then
                .SortOrder.Add .Columns(Kat_Gruppe)
                .GroupsOrder.Add .Columns(Kat_Gruppe)
                .GroupsOrder(0).SortAscending = True
            End If
        End If
    End If
End With

If GesZa > 0 Then
    RpCo8.Populate
    Set RpRws = RpCo8.Rows
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            Set RpGrw = RpRow
            Set ChRws = RpGrw.Childs
            GrAnz = ChRws.Count
            For Each ChRow In ChRws
                If IsNumeric(ChRow.Record.Item(Kat_Preis1).Value) Then
                    GrPre = GrPre + ChRow.Record.Item(Kat_Preis1).Value
                End If
            Next ChRow
            If Len(RpGrw.GroupCaption) > 8 Then
                GrCap = Right$(RpGrw.GroupCaption, Len(RpGrw.GroupCaption) - 8)
                RpGrw.GroupCaption = GrCap & " (" & GrAnz & ")"
            End If
        End If
        GrPre = 0
    Next RpRow
End If

SMark

Set CmBrs = Nothing
Set RpRws = Nothing
Set RpCo8 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_Such " & Err.Number
Resume Next

End Sub
Public Sub M_MaEd(ByVal SuFel As Integer)
On Error GoTo PoErr
'Sucheingabe im Maildialog

Dim SuStr As String
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmCm1 As XtremeCommandBars.CommandBarComboBox
Dim CmCm2 As XtremeCommandBars.CommandBarComboBox

Set FM = frmMaiView
Set CmBrs = FM.comBar02
Set CmAcs = CmBrs.Actions
Set TxCoN = FM.TexCont3

Set CmCm1 = CmBrs.FindControl(CmCm1, SY_SuCm1, , True)
Set CmCm2 = CmBrs.FindControl(CmCm2, SY_SuCm2, , True)

Select Case SuFel
Case 1:
    If CmCm1.Text <> vbNullString Then
        SuStr = CmCm1.Text & "%"
        Set RS155 = New ADODB.Recordset
        RS155.CursorLocation = adUseClient
        Set RS155 = DBCmRe2("qryKat04M", "@IdxNr", "@IdStr", 9, SuStr)
        If RS155.RecordCount > 0 Then
            If RS155.Fields("Zusatztext").Value <> vbNullString Then
                TxCoN.SelText = RS155.Fields("Zusatztext").Value
            End If
        End If
        RS155.Close
        Set RS155 = Nothing
        With CmCm1
            .SetFocus
            .Execute
        End With
    End If
Case 2:
    If CmCm2.Text <> vbNullString Then
        SuStr = CmCm2.Text & "%"
        Set RS155 = New ADODB.Recordset
        RS155.CursorLocation = adUseClient
        Set RS155 = DBCmRe2("qryKat04N", "@IdxNr", "@IdStr", 9, SuStr)
        If RS155.RecordCount > 0 Then
            If RS155.Fields("Zusatztext").Value <> vbNullString Then
                TxCoN.SelText = RS155.Fields("Zusatztext").Value
            End If
        End If
        RS155.Close
        Set RS155 = Nothing
        With CmCm2
            .SetFocus
            .Execute
        End With
    End If
Case 3:
    If CmCm1.ListCount = 0 Then
        Set RS155 = New ADODB.Recordset
        RS155.CursorLocation = adUseClient
        Set RS155 = DBCmRe1("qryKat04G", "@IdxNr", 9)
        If RS155.RecordCount > 0 Then
            Do
            CmCm1.AddItem RS155.Fields("GOID").Value
            CmCm2.AddItem RS155.Fields("IDKurz").Value
            RS155.MoveNext
            Loop Until RS155.EOF
        End If
        RS155.Close
        Set RS155 = Nothing
    End If
End Select

Set CmAcs = Nothing
Set CmBrs = Nothing

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "M_MaEd " & Err.Number
Resume Next

End Sub
