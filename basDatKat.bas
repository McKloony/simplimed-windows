Public Function K_GrNe(Optional ByVal TmpSt As String) As Long
On Error GoTo LiErr
'Legt eine neue Gruppe an

Dim SQL1 As String
Dim IdxNr As Long
Dim IdKey As String
Dim NeStr As String
Dim Krit1 As String

Select Case Left$(GlNod, 1)
Case "A": SQL1 = "qryKatVers" 'Gebührenkataloge
Case "C": SQL1 = "qryKat03"   'Diagnosekataloge
Case "D": SQL1 = "qryKatVers" 'Gebührenketten
Case "F": SQL1 = "qryKat03"   'Diagnoseketten
Case "G": SQL1 = "qryKat09"   'Laborparameter
Case "H": SQL1 = "qryKat09"   'Laborparameter
Case "I": SQL1 = "qryKat04"   'Arzneimittel
Case "J": SQL1 = "qryKat04"   'Arzneiketten
Case "K": Exit Function       'Begründungen
Case "L": SQL1 = "qryKat05"   'Anamnesetexte
Case "M": Exit Function       'Terminbetreffs
Case "N": SQL1 = "qryKat10"   'Fragebogen
Case "O": Exit Function       'Textphrasen
Case "P": SQL1 = "qryKat12"   'Artikelliste
Case "R": Exit Function       'Terminketten
Case "Q": SQL1 = "qryKat12"   'Artikelketten
End Select

If TmpSt <> vbNullString Then
    NeStr = TmpSt
Else
    NeStr = "Neuer Eintrag"
End If

If Left$(GlNod, 1) = "A" Or Left$(GlNod, 1) = "D" Then
    IdKey = 1
Else
    IdKey = 2
End If

Set RS135 = New ADODB.Recordset
With RS135
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdTableDirect
End With
If RS135.Supports(adAddNew) Then
    RS135.AddNew
    Select Case Left$(GlNod, 1)
    Case "A":
        RS135.Fields("Versicherer").Value = NeStr
        RS135.Fields("IdKey").Value = IdKey
    Case "D":
        RS135.Fields("Versicherer").Value = NeStr
        RS135.Fields("IdKey").Value = IdKey
    Case "N":
        RS135.Fields("IDKurz").Value = NeStr
        RS135.Fields("GuiID").Value = CreateID("G")
    Case Else:
        RS135.Fields("IDKurz").Value = NeStr
        RS135.Fields("IdKey").Value = IdKey
    End Select
    RS135.Update
End If
RS135.Close
Set RS135 = Nothing
DoEvents

Set RS134 = New ADODB.Recordset
With RS134
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenForwardOnly
    .LockType = adLockReadOnly
    .Open Options:=adCmdTableDirect
End With
If RS134.RecordCount > 0 Then
    Select Case Left$(GlNod, 1)
    Case "A": Krit1 = "[Versicherer] = '" & NeStr & "'"
    Case "D": Krit1 = "[Versicherer] = '" & NeStr & "'"
    Case Else: Krit1 = "[IDKurz] = '" & NeStr & "'"
    End Select
    RS134.Find Criteria:=Krit1, SkipRecords:=0, SearchDirection:=adSearchForward
    If Not (RS134.BOF Or RS134.EOF) Then
        IdxNr = RS134.Fields("ID3").Value
    End If
End If
RS134.Close
Set RS134 = Nothing

K_GrNe = IdxNr

Exit Function

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_GrNe " & Err.Number
Resume Next

End Function
Public Sub K_GrUm(ByVal NeuSt As String)
On Error GoTo LiErr
'Benennt die Gruppe um

Dim SQL1 As String
Dim KeySt As String
Dim Krit1 As String

KeySt = Left$(GlNod, 1)

Select Case KeySt
Case "A": SQL1 = "qryKatVers" 'Gebührenkataloge
Case "C": SQL1 = "qryKat03" 'Diagnosekataloge
Case "D": SQL1 = "qryKatVers" 'Gebührenketten
Case "F": SQL1 = "qryKat03" 'Diagnoseketten
Case "G": SQL1 = "qryKat09" 'Laborparameter
Case "H": SQL1 = "qryKat09" 'Laborparameter
Case "I": SQL1 = "qryKat04" 'Arzneikatalog
Case "J": SQL1 = "qryKat04" 'Arzneiketten
Case "K": Exit Sub          'Begründungen
Case "L": SQL1 = "qryKat05" 'Anamnesetexte
Case "M": Exit Sub          'Terminbetreffs
Case "N": SQL1 = "qryKat10" 'Fragebogen
Case "O": SQL1 = "qryKat04" 'Textphrasen
Case "P": SQL1 = "qryKat12" 'Artikelkatalog
Case "R": Exit Sub          'Terminketten
Case "Q": SQL1 = "qryKat12" 'Artikelketten
End Select

Set RS135 = New ADODB.Recordset
With RS135
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdTableDirect
End With
If KeySt <> "Z" Then
    Krit1 = "[ID3]=" & Mid$(GlNod, 2, Len(GlNod) - 1)
    If RS135.RecordCount > 0 Then
        RS135.Find Criteria:=Krit1, SkipRecords:=0, SearchDirection:=adSearchForward
        If Not (RS135.BOF Or RS135.EOF) Then
            Select Case Left$(GlNod, 1)
            Case "A": RS135.Fields("Versicherer").Value = NeuSt
            Case "D": RS135.Fields("Versicherer").Value = NeuSt
            Case Else: RS135.Fields("IDKurz").Value = NeuSt
            End Select
            RS135.Update
        End If
    End If
End If
RS135.Close
Set RS135 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_GrUm " & Err.Number
Resume Next

End Sub

Public Sub K_Inp()
On Error GoTo LiErr
'Fügt Daten in das Krankenblatt ein

Dim EiDat As Date
Dim KatNr As Long
Dim PosNr As Long
Dim FoFak As Single
Dim SuStr As String
Dim GesZa As Integer
Dim EiAnz As Integer
Dim KraTy As Integer
Dim LabNr As Integer
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCoK As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo3 = FM.repCont3
Set RpCo6 = FM.repCont6
Set RpCoK = FM.repContK
Set CmBez = FM.cmbBezei
Set TxDe7 = FM.txtDeta7
Set RpSel = RpCo3.SelectedRows
Set RpCls = RpCo3.Columns

GlAkt = True

Select Case GlFri
Case 1: LabNr = 2 'Arzt (GOÄ)
Case 2: LabNr = 1 'Heilpraktiker (GebüH)
Case 3: LabNr = 2 'Zahnarzt (GOZ)
Case 4: LabNr = 2 'Veterinär (GOT)
Case 5: LabNr = 1 'Naturheilpraktiker (Tarif 590)
Case 6: LabNr = 1 'Physiotherapeut
Case 7: LabNr = 1 'Wahlarzt (AT)
End Select

KatNr = TxDe7.Text

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        Set RpCol = RpCls.Find(Rec_Faktor)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            FoFak = RpRow.Record(RpCol.ItemIndex).Value
        Else
            FoFak = 1
        End If
        
        Select Case GlBut
        Case RibTab_Krankenbla:
                    Set RpSel = RpCoK.SelectedRows
                    Set RpCls = RpCoK.Columns
        Case RibTab_Abrechnung:
                    Set RpSel = RpCo6.SelectedRows
                    Set RpCls = RpCo6.Columns
        End Select

        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            If RpRow.GroupRow = False Then
                Set RpCol = RpCls.Find(Kra_Ziffer)
                SuStr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Kra_Typ)
                KraTy = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Kra_Anz)
                EiAnz = RpRow.Record(RpCol.ItemIndex).Value
            End If
        End If
    End If
Else
    Exit Sub
End If

CmBez.Text = vbNullString
If SuStr <> vbNullString Then
    Select Case KraTy
    Case 1: 'Diagnosen
            Set RS128 = New ADODB.Recordset
            RS128.CursorLocation = adUseClient
            Set RS128 = DBCmRe2("qryKat03M", "@IdxNr", "@IdStr", 1, SuStr)
            GesZa = RS128.RecordCount
            If GesZa > 0 Then
                Set RpCol = RpCls.Find(Kra_Ziffer)
                RpRow.Record(RpCol.ItemIndex).Value = RS128.Fields("GOID").Value
                RpRow.Record(RpCol.ItemIndex).Tag = "@Ziffer" 'Tag geändert
                Set RpCol = RpCls.Find(Kra_Bezeichnung)
                RpRow.Record(RpCol.ItemIndex).Value = RS128.Fields("IDKurz").Value
                RpRow.Record(RpCol.ItemIndex).Tag = "@Bezeichnung"
                Set RpCol = RpCls.Find(Kra_Betrag)
                RpRow.Record(RpCol.ItemIndex).Value = 0
                RpRow.Record(RpCol.ItemIndex).Tag = "@Betrag"
                Set RpCol = RpCls.Find(Kra_Faktor)
                RpRow.Record(RpCol.ItemIndex).Value = 0
                RpRow.Record(RpCol.ItemIndex).Tag = "@Faktor"
                Set RpCol = RpCls.Find(Kra_GesBetrag)
                RpRow.Record(RpCol.ItemIndex).Value = 0
                RpRow.Record(RpCol.ItemIndex).Tag = "@GesBetrag"
            End If
            RS128.Close
            Set RS128 = Nothing
    Case 2: 'Gebühren
            Set RS128 = New ADODB.Recordset
            RS128.CursorLocation = adUseClient
            Set RS128 = DBCmRe2("qryKat01M", "@IdxNr", "@IdStr", KatNr, SuStr)
            GesZa = RS128.RecordCount
            If GesZa > 0 Then
                Set RpCol = RpCls.Find(Kra_Ziffer)
                RpRow.Record(RpCol.ItemIndex).Value = RS128.Fields("GOID").Value
                RpRow.Record(RpCol.ItemIndex).Tag = "@Ziffer"
                Set RpCol = RpCls.Find(Kra_Bezeichnung)
                RpRow.Record(RpCol.ItemIndex).Value = RS128.Fields("IDKurz").Value
                RpRow.Record(RpCol.ItemIndex).Tag = "@Bezeichnung"
                Set RpCol = RpCls.Find(Kra_Betrag)
                RpRow.Record(RpCol.ItemIndex).Value = Format$(Round(RS128.Fields("Preis1").Value, 2), GlWa1)
                RpRow.Record(RpCol.ItemIndex).Tag = "@Betrag"
                Set RpCol = RpCls.Find(Kra_Faktor)
                RpRow.Record(RpCol.ItemIndex).Value = Format$(Round(RS128.Fields("Multi").Value, 2), GlWa1)
