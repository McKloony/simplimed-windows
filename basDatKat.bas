        Set RpCol = RpCls.Find(Buh_Gegenkonto)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                KtNrH = CLng(RpRow.Record(RpCol.ItemIndex).Value)
            End If
        End If
        
        Set RpCol = RpCls.Find(Buh_Sachkonto)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                KtIdS = CLng(RpRow.Record(RpCol.ItemIndex).Value)
            End If
        End If
        
        Set RpCol = RpCls.Find(Buh_Geldkontenbez)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            KtBeH = RpRow.Record(RpCol.ItemIndex).Value
        End If
        
        Set RpCol = RpCls.Find(Buh_Sachkontenbez)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            KtBeS = RpRow.Record(RpCol.ItemIndex).Value
        End If

        If KtNrH = 0 Then
            If BuTyp = 0 Then 'Ausgabe
                KtNrH = GlGeK(IdGeg + 1, 2)
            Else
                KtNrH = 0
            End If
        End If
        KtStH = SBuFo(KtNrH) 'Sachkontenformatierung

        If KtIdS = 0 Then
            If BuTyp = 1 Then 'Einnahme
                KtIdS = GlGeK(IdGeg + 1, 2)
            Else
                KtIdS = 0
            End If
        End If
        KtStS = SBuFo(KtIdS) 'Sachkontenformatierung
        
        If KtBeH = vbNullString Then
            If BuTyp = 0 Then 'Ausgabe
                KtBeH = GlGeK(IdGeg + 1, 1)
            End If
        End If
        
        If KtBeS = vbNullString Then
            If BuTyp = 1 Then 'Einnhame
                KtBeS = GlGeK(IdGeg + 1, 1)
            End If
        End If

        TxKtS.Text = KtStS & " " & KtBeS
        TxKtH.Text = KtStH & " " & KtBeH
        TxNrS.Text = KtStS
        TxNrH.Text = KtStH
