Private Function K_KatR(ByRef RST As ADODB.Recordset, ByVal RsPru As Integer, ByVal AnzL1 As Integer, ByVal AnzL2 As Integer, ByVal GebZi As String, ByVal EiDat As Date, ByVal ReNum As Long, ByVal IdxNr As Long) As Boolean
On Error GoTo GrErr
'Regelprüfung

Dim Datu1 As String
Dim GoStr As String
Dim ResZu As Boolean 'Einfügen zulassen
Dim Lange As Integer
Dim Mld4, Mld5, Mld6 As String

Datu1 = DatePart("m", EiDat) & "/" & DatePart("d", EiDat) & "/" & DatePart("yyyy", EiDat)

If GlRsP = True Then 'Regelprüfung durchführen?
    If RsPru = 1 Then
        If AnzL1 > 0 Then
            Mld4 = "Die Ziffer " & GebZi & " sollte am " & EiDat & " nicht mehr als " & AnzL1 & "-mal abgerechnet werden"
            Mld5 = "Es wurde festgestellt, dass die Ziffer " & GebZi & " bereits " & AnzL1 & "–mal am " & EiDat & " abgerechnet wurde. Dieses verstößt gegen eine Gebührenregel, welche dieser Ziffer zugeordnet ist. Soll die Ziffer " & GebZi & " trotzdem ein weiteres Mal am " & EiDat & " abgerechnet werden?"
            Mld6 = "HINWEIS! Die Regelprüfung kann jederzeit unter dem Menüpunkt: Anzeigeoptionen aus- und eingeschaltet werden."
            Set RS131 = New ADODB.Recordset
            RS131.CursorLocation = adUseClient
            Set RS131 = DBCmRe3("qrySimAbRS1", "@IdxNr", "@IdDat", "@IdStr", ReNum, EiDat, GebZi)
            If RS131.RecordCount > 0 Then
                If RS131.Fields("Anzahl").Value >= AnzL1 Then
                    SMeFr "Regelverstoß", Mld4, Mld5, Mld6, False, IC32_Hand, False, FM.hwnd
                    If GlMes <> 33565 Then
                        ResZu = False
                    Else
                        ResZu = True
                    End If
                Else
                    ResZu = True
                End If
            Else
                ResZu = True
            End If
            RS131.Close
            Set RS131 = Nothing
        Else
            ResZu = True
        End If
    ElseIf RsPru = 2 Then
        If AnzL2 > 0 Then
            Mld4 = "Die Ziffer " & GebZi & " sollte in dieser Rechnung nicht mehr als " & AnzL2 & "-mal abgerechnet werden"
            Mld5 = "Es wurde festgestellt, dass die Ziffer " & GebZi & " bereits " & AnzL2 & "–mal in dieser Rechnung abgerechnet wurde. Dieses verstößt gegen eine Gebührenregel, welche dieser Ziffer zugeordnet ist. Soll die Ziffer " & GebZi & " trotzdem ein weiteres Mal in dieser Rechnung abgerechnet werden?"
            Mld6 = "HINWEIS! Die Regelprüfung kann jederzeit unter dem Menüpunkt: Anzeigeoptionen aus- und eingeschaltet werden."
            Set RS131 = New ADODB.Recordset
            RS131.CursorLocation = adUseClient
            Set RS131 = DBCmRe2("qrySimAbRS2", "@IdxNr", "@IdStr", ReNum, GebZi)
            If RS131.RecordCount > 0 Then
                If RS131.Fields("Anzahl").Value >= AnzL2 Then
                    SMeFr "Regelverstoß", Mld4, Mld5, Mld6, False, IC32_Hand, False, FM.hwnd
                    If GlMes <> 33565 Then
                        ResZu = False
                    Else
                        ResZu = True
                    End If
                Else
                    ResZu = True
                End If
            Else
                ResZu = True
            End If
            RS131.Close
            Set RS131 = Nothing
        Else
            ResZu = True
        End If
    ElseIf RsPru = 3 Then
        Mld4 = "Die Ziffer " & GebZi & " sollte am " & EiDat & " nur als alleinige Leistung abgerechnet werden"
        Mld5 = "Es wurde festgestellt, dass die Ziffer " & GebZi & " nicht als alleinige Leistung am " & EiDat & " abgerechnet werden soll. Dieses verstößt gegen eine Gebührenregel, welche dieser Ziffer zugeordnet ist. Soll die Ziffer " & GebZi & " trotzdem am " & EiDat & " abgerechnet werden?"
        Mld6 = "HINWEIS! Die Regelprüfung kann jederzeit unter dem Menüpunkt: Anzeigeoptionen aus- und eingeschaltet werden."
        Set RS131 = New ADODB.Recordset
        RS131.CursorLocation = adUseClient
        Set RS131 = DBCmRe2("qrySimAbRS3", "@IdxNr", "@IdDat", ReNum, EiDat)
        If RS131.RecordCount > 0 Then
            If RS131.Fields("Anzahl").Value > 0 Then
                SMeFr "Regelverstoß", Mld4, Mld5, Mld6, False, IC32_Hand, False, FM.hwnd
                If GlMes <> 33565 Then
                    ResZu = False
                Else
                    ResZu = True
                End If
            Else
                ResZu = True
            End If
        Else
            ResZu = True
        End If
        RS131.Close
        Set RS131 = Nothing
    Else
        ResZu = True
    End If
    'Erweiterte Regelprüfung
    Set RS132 = New ADODB.Recordset
    RS132.CursorLocation = adUseClient
    Set RS132 = DBCmRe1("qryAnKa1r", "@IdxNr", IdxNr)
    If RS132.RecordCount > 0 Then
        Do
        GoStr = RS132.Fields("GOID").Value
        Mld4 = "Die Ziffer " & GebZi & " sollte am " & EiDat & " nicht zusammen mit der Ziffer " & GoStr & " abgerechnet werden"
        Mld5 = "Es wurde festgestellt, dass die Ziffer " & GebZi & " am " & EiDat & " zusammen mit der Ziffer " & GoStr & " abgerechnet werden soll. Dieses verstößt gegen eine Gebührenregel, welche dieser Ziffer zugeordnet ist. Soll die Ziffer " & GebZi & " trotzdem am " & EiDat & " abgerechnet werden?"
        Mld6 = "HINWEIS! Die Regelprüfung kann jederzeit unter dem Menüpunkt: Anzeigeoptionen aus- und eingeschaltet werden."
        RST.Filter = "[GONr] Like '" & GoStr & "'"
        If RST.RecordCount > 0 Then
            SMeFr "Regelverstoß", Mld4, Mld5, Mld6, False, IC32_Hand, False, FM.hwnd
            If GlMes <> 33565 Then
                ResZu = False
            Else
                ResZu = True
            End If
            Exit Do
        End If
        RST.Filter = adFilterNone
        RS132.MoveNext
        Loop Until RS132.EOF
    End If
    RS132.Close
    Set RS132 = Nothing
Else
    ResZu = True
End If

K_KatR = ResZu

Exit Function

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_KatR " & Err.Number
Resume Next

End Function
