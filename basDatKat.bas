                            End If
                            DoEvents
                        End If

                        RS127.AddNew
                        For Each FL101 In RS160.Fields
                            Select Case FL101.Name
                            Case "ID0":
                            Case "ID6":
                                    If RS160.Fields(FL101.Name).Value <> vbNullString Then
                                        FrgNr = RS160.Fields(FL101.Name).Value
                                    End If
                            Case "IDV":
