        Set RpCol = RpCls.Find(Buh_Einnahme)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                TxBuB.Text = Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1)
            End If
        End If
        Set RpCol = RpCls.Find(Buh_Ausgabe)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                TxBuB.Text = Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1)
            End If
        End If
        If TxBuB.Text = vbNullString Then
            TxBuB.Text = Format$(0, GlWa1)
        End If
        For AktZa = 1 To UBound(GlStu)
            If CSng(GlStu(AktZa, 1)) = KoStu Then
                CmSte.ListIndex = AktZa - 1
                Exit For
            End If
        Next AktZa
        Set RpCol = RpCls.Find(Buh_Buchtext)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            CmBuT.Text = RpRow.Record(RpCol.ItemIndex).Value
        Else
            CmBuT.Text = vbNullString
        End If
        Set RpCol = RpCls.Find(Buh_Kommentar)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            TxBuK.Text = RpRow.Record(RpCol.ItemIndex).Value
        Else
            TxBuK.Text = vbNullString
        End If
        Set RpCol = RpCls.Find(Buh_Ermittlung)
        If RpRow.Record(RpCol.ItemIndex).Checked = True Then
            ChErl.Value = xtpChecked
        End If
    End If
    DoEvents

    frmBuEdit.Show
Else
    SPopu "Buchungsvorlage wählen", "Es wurde keine Buchungsvorlage ausgewählt", IC48_Information
End If

Set RpCo7 = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "K_BuPs " & Err.Number
Resume Next

End Sub
Public Sub K_BuSa(ByVal PaFrm As String)
On Error GoTo LiErr
'Speichern einer Buchungsvorlage

Dim SQL1 As String
Dim KtIdS As Long
