                FM.txtBezHa.Text = vbNullString
                FM.txtKtoHa.Text = 0
                FM.txtHaben.SetFocus
            End If
            SPopu Tit1, Mld1, IC48_Warning

        End If
        
    Else 'Alphanumerisch

        Set RS128 = New ADODB.Recordset
