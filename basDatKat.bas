                                                RS121.Fields(FldNa).Value = Left$(FeInh, 50)
                                            Else
                                                RS121.Fields(FldNa).Value = FeInh
                                            End If
                                        End If
                                Case Else:
                                    If FeInh <> vbNullString Then
                                        If FldNa <> vbNullString Then
                                            RS121.Fields(FldNa).Value = FeInh
                                        End If
                                    End If
                                End Select
                            Case 1:
                                If Len(FeInh) > 7 Then
                                    If IsDate(T_KoDa(CStr(FeInh), VerNu)) = True Then
                                        RS121.Fields(FldNa).Value = T_KoDa(CStr(FeInh), VerNu)
                                    End If
                                End If
                            Case 2:
                                If IsNumeric(FeInh) = True Then
                                    RS121.Fields(FldNa).Value = CLng(FeInh)
                                Else
                                    RS121.Fields(FldNa).Value = Val(FeInh)
                                End If
                            Case 3:
                                RS121.Fields(FldNa).Value = Left$(FeInh, 2) & ":" & Right$(FeInh, 2)
                            End Select
                        End If
                    End If
                End If
            End If

            DoEvents
            AkZa1 = AkZa1 + 1
            If AkZa1 <= GesZa Then PrBr2.Value = AkZa1
            If TxDum.Text = "B" Then Exit Do 'Abbrechen
            Loop Until FeKen = 8000 Or AkZa1 > GesZa
            '--------------------------------------------------------------------------------
            If PaNeu = True Then RS121.Update

            RS157.MovePrevious
            TmPLZ = vbNullString
            TmOrt = vbNullString
            TmPat = 0

            DoEvents
        End If
    End If
    
    AkZa2 = AkZa2 + 1
    If AkZa2 <= GesZa Then PrBr1.Value = AkZa2
    If TxDum.Text = "B" Then Exit Do 'Abbrechen
    RS157.MoveNext
    Loop Until RS157.EOF
End If

If RS121.State = adStateOpen Then
    RS121.Close
    Set RS121 = Nothing
End If

If RS157.State = adStateOpen Then
    RS157.Close
    Set RS157 = Nothing
End If

Unload frmStatus
    
Set CmBrs = Nothing

Exit Sub

LiErr:
If GlDbg = True Then
    MsgBox Err.Description, 48, "S_BDT1 " & Err.Number
    Resume Next
End If
Exit Sub

End Sub
