            IdGeg = SCmX(CmGek, RpRow.Record(RpCol.ItemIndex).Value)
        Else
            IdGeg = 0
        End If
        Set RpCol = RpCls.Find(Buh_IDA)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BuTyp = RpRow.Record(RpCol.ItemIndex).Value - 1
        Else
            BuTyp = 0
        End If
        
        Set RpCol = RpCls.Find(Buh_IDT)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                BehNr = RpRow.Record(RpCol.ItemIndex).Value
                ManNr = SCmX(CmMan, BehNr)
            Else
                ManNr = 0
            End If
        Else
            ManNr = 0
        End If
        
        Set RpCol = RpCls.Find(Buh_IDM)
