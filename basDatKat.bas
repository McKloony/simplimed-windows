                If FL101.Name = "IDK" Then
                    If RS155.Fields("IDK").Value <> vbNullString Then
                        If RS155.Fields("IDK").Value > 0 Then
                            KtoNr = RS155.Fields("IDK").Value
                            KtoSt = SBuFo(KtoNr) 'Sachkontenformatierung
                            RS163.Fields("IDK").Value = KtoSt
                        End If
                    End If
                Else
                    RS163.Fields(FL101.Name).Value = RS155.Fields(FL101.Name).Value
                End If
            End If
        Next FL101
        RS155.MoveNext
    Loop
    RS163.UpdateBatch
    
    RS163.MoveFirst
    RS163.Sort = "IDK ASC"
    
    AktZa = 0
    Do Until RS163.EOF
        If RS163.Fields("IDK").Value > 0 Then
            CmKto.AddItem RS163.Fields("IDK").Value & Chr$(32) & RS163.Fields("IDKurz").Value
            CmKto.ItemData(AktZa) = RS163.Fields("IDK").Value
            If GlBuc = False Then 'einfache Buchhaltung verwenden
                CmGeg.AddItem RS163.Fields("IDK").Value & Chr$(32) & RS163.Fields("IDKurz").Value
                If CBool(RS163.Fields("Geldkonto").Value) = True Then
                    CmGeg.ItemData(AktZa) = RS163.Fields("IDB").Value '[IDB]
                Else
                    CmGeg.ItemData(AktZa) = RS163.Fields("IDB").Value '[IDK]
                End If
            End If
            AktZa = AktZa + 1
        End If
        RS163.MoveNext
    Loop
    
    RS163.Close
    Set RS163 = Nothing
    
    CmKto.ListIndex = 0
    If GlBuc = False Then 'einfache Buchhaltung verwenden
        CmGeg.ListIndex = 0
    End If
End If
RS155.Close
Set RS155 = Nothing

Exit Sub

