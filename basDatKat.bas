        End If
        
        .MoveNext
        Loop Until .EOF
    End If
End With

T_Exp = LdtSt

RS128.Close
Set RS128 = Nothing

Exit Function

LdErr:
If GlDbg = True Then MsgBox Err.Description, 48, "T_Exp " & Err.Number
Resume Next

End Function
Public Sub T_FeA()
On Error GoTo TeErr
'Fügt fehlende Parameter an

Dim AktZa As Long
Dim GesZa As Long
Dim KatNr As Long
Dim BerNr As Long
Dim SuStr As String
Dim SQL1 As String
Dim SQL2 As String

Set FM = frmZuord
Set PrBr1 = FM.prbStat1

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qryKat02C WHERE ID0 = -1" 'Laborparameter
    SQL2 = "SELECT * FROM dbo.qryLdtPa2 ORDER BY ID0 DESC" 'Berichte welche fehlende Parameter haben
Else
    SQL1 = "SELECT * FROM qryKat02C WHERE [ID0] = -1;" 'Laborparameter
    SQL2 = "SELECT * FROM qryLdtPa2 ORDER BY [ID0] DESC;" 'Berichte welche fehlende Parameter haben
End If

Set RS128 = New ADODB.Recordset
With RS128
    .CursorLocation = adUseClient
    .Source = SQL2
    .ActiveConnection = DB1
    .CursorType = adOpenForwardOnly
    .LockType = adLockReadOnly
    .Open Options:=adCmdText
End With
GesZa = RS128.RecordCount

If GesZa > 0 Then
    Screen.MousePointer = vbHourglass
    DoEvents

    PrBr1.Min = 0
    PrBr1.Max = GesZa

    Set RS129 = New ADODB.Recordset 'Testdaten
    With RS129
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With
    If RS129.Supports(adAddNew) = True Then
    
        Do
        BerNr = RS128.Fields("ID0").Value
        KatNr = RS128.Fields("ID3").Value
        
        Set RS130 = New ADODB.Recordset
        RS130.CursorLocation = adUseClient
        Set RS130 = DBCmRe1("qryLdtPa3", "@IdxNr", BerNr)
                        
        If RS130.RecordCount > 0 Then
            RS130.MoveFirst

            Do
            SuStr = RS130.Fields("Ident").Value
            Set RS131 = New ADODB.Recordset
            Set RS131 = DBCmRe2("qryKat02M", "@IdxNr", "@IdStr", KatNr, SuStr)
                                    
            If RS131.RecordCount = 0 Then
                RS129.AddNew
                RS129.Fields("ID3").Value = KatNr
                RS129.Fields("GOIK").Value = RS130.Fields("Ident").Value
                RS129.Fields("IDKurz").Value = RS130.Fields("Testbezeichnung").Value
                RS129.Fields("Einheit").Value = RS130.Fields("Einheit").Value
                RS129.Fields("GOID").Value = RS130.Fields("GONr").Value
                RS129.Fields("Preis1").Value = RS130.Fields("Betrag").Value
                RS129.Fields("Multi").Value = RS130.Fields("Multi").Value
                RS129.Update
            End If
            RS131.Close
            Set RS131 = Nothing
            
            RS130.MoveNext
            Loop Until RS130.EOF
        End If
        RS130.Close
        Set RS130 = Nothing
        
        PrBr1.Value = AktZa + 1
        DoEvents
        
        RS128.MoveNext
        Loop Until RS128.EOF
        
    End If
    RS129.Close
    Set RS129 = Nothing
    
    DoEvents
    Screen.MousePointer = vbNormal
End If
RS128.Close
Set RS128 = Nothing

Exit Sub

TeErr:
If GlDbg = True Then MsgBox Err.Description, 48, "T_FeA " & Err.Number
Resume Next

End Sub
