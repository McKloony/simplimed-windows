Resume Next

End Sub
Public Sub E_Kop(ByVal KetNr As Long)
On Error GoTo LiErr
'Fügt Einträge in die Kette ein

Dim KeyNr As Long
Dim RowNr As Long
Dim Farbe As Long
Dim SQL1 As String
Dim TreKy As String
Dim Krit1 As String
Dim Kurzb As String  'Kurzbezeichung
Dim ArPre As Double  'Preise
Dim Einfu As Boolean 'Einfügen
Dim SorNr As Integer 'Sortiernummer
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmKetten
Set RpCo4 = FM.repCont4
Set RpCls = RpCo4.Columns
Set RpSel = RpCo4.SelectedRows

SorNr = 1
Tit1 = "Eintrag bereits vorhanden"

TreKy = Left$(GlNod, 1)

If GlTyp < 2 Then
    Select Case TreKy
    Case "D": SQL1 = "SELECT * FROM dbo.qryKet01 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Gebührenketten
    Case "F": SQL1 = "SELECT * FROM dbo.qryKet03 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Diagnoseketten
    Case "H": SQL1 = "SELECT * FROM dbo.qryKet02 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Laborprofile
    Case "J": SQL1 = "SELECT * FROM dbo.qryKet04 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Arzneimittel
    Case "R": SQL1 = "SELECT * FROM dbo.qryKon02 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Terminketten
    Case "Q": SQL1 = "SELECT * FROM dbo.qryKet12 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Artikelliste
    End Select
Else
    Select Case TreKy
    Case "D": SQL1 = "SELECT * FROM qryKet01 WHERE [ID1] = " & KetNr & " ORDER BY [ID2];" 'Gebührenketten
    Case "F": SQL1 = "SELECT * FROM qryKet03 WHERE [ID1] = " & KetNr & " ORDER BY [ID2];" 'Diagnoseketten
    Case "H": SQL1 = "SELECT * FROM qryKet02 WHERE [ID1] = " & KetNr & " ORDER BY [ID2];" 'Laborprofile
    Case "J": SQL1 = "SELECT * FROM qryKet04 WHERE [ID1] = " & KetNr & " ORDER BY [ID2];" 'Arzneimittel
    Case "R": SQL1 = "SELECT * FROM qryKon02 WHERE [ID1] = " & KetNr & " ORDER BY [ID2];" 'Terminketten
    Case "Q": SQL1 = "SELECT * FROM qryKet12 WHERE [ID1] = " & KetNr & " ORDER BY [ID2];" 'Artikelliste
    End Select
End If

If RpSel.Count > 0 Then
    Set RS136 = New ADODB.Recordset
    With RS136
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With

    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            Set RpCol = RpCls.Find(Ket_ID0)
            KeyNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Ket_GOID)
            Kurzb = RpRow.Record(RpCol.ItemIndex).Value
            If TreKy <> "R" Then
                Set RpCol = RpCls.Find(Ket_Preis)
                ArPre = Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1)
            End If
            
            Einfu = True
            If RS136.RecordCount > 0 Then
                RS136.MoveLast
                If RS136.Fields("ID2").Value > 0 Then
                    SorNr = RS136.Fields("ID2").Value + 1
                Else
                    SorNr = 1
                End If
                RS136.MoveFirst
                If TreKy = "R" Then
                    Krit1 = "[ID4]=" & KeyNr
                Else
                    Krit1 = "[ID0]=" & KeyNr
                End If
                RS136.Find Criteria:=Krit1, SkipRecords:=0, SearchDirection:=adSearchForward
                If Not (RS136.BOF Or RS136.EOF) Then
                    Mld1 = "Der Eintrag " & Kurzb & " ist bereits Bestandteil dieser Kette. Soll er erneut eingefügt werden?"
                    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
                    If Frage <> 6 Then
                        Einfu = False
                    End If
                End If
            End If
            If Einfu = True Then
                RS136.AddNew
                If TreKy = "R" Then
                    RS136.Fields("ID4").Value = KeyNr
                Else
                    RS136.Fields("ID0").Value = KeyNr
                End If
                RS136.Fields("ID1").Value = KetNr
                RS136.Fields("ID2").Value = SorNr
                If TreKy <> "R" Then
                    RS136.Fields("x").Value = 1
                    RS136.Fields("Preis").Value = ArPre
                End If
                RS136.Update
            End If
        End If
    Next RpRow
    
    RS136.Close
    Set RS136 = Nothing
End If

Set RpSel = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo4 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "E_Kop " & Err.Number
Resume Next

End Sub
Public Sub E_Mov(ByVal KetNr As Long, Richt As Boolean)
On Error GoTo LiErr
'Verschiebt den Eintrag in der Kette

Dim IdxNr As Long
Dim IdxWe As Long
Dim IdNum As Long
Dim KeySt As String
Dim RoIdx As Integer
Dim SorNr As Integer
Dim SorWe As Integer
Dim GesZa As Integer
Dim DoSor As Boolean
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmKetten
Set RpCo5 = FM.repCont5
Set RpRws = RpCo5.Rows
Set RpCls = RpCo5.Columns
Set RpSel = RpCo5.SelectedRows

KeySt = Left$(GlNod, 1)

GesZa = RpRws.Count

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    RoIdx = RpRow.Index
    IdNum = RpRow.Record(Ket_ID0).Value '[ID0]
    IdxWe = RpRow.Record(Ket_IDA).Value '[IDA]
    If Richt = True Then
        If (RoIdx - 1) >= 0 Then
            Set RpRow = RpRws(RoIdx - 1)
            IdxNr = RpRow.Record(Ket_IDA).Value '[IDA]
            SorNr = RoIdx + 1
            SorWe = RoIdx
            DoSor = True
        End If
    Else
        If (RoIdx + 1) < GesZa Then
            Set RpRow = RpRws(RoIdx + 1)
            IdxNr = RpRow.Record(Ket_IDA).Value '[IDA]
            SorNr = RoIdx
            SorWe = RoIdx + 2
            DoSor = True
        End If
    End If

    If DoSor = True Then
        Select Case KeySt
        Case "D": DBCmEx2 "qryKet01S", "@IdSor", "@IdxNr", SorWe, IdxWe 'Leistungsketten
                  DBCmEx2 "qryKet01S", "@IdSor", "@IdxNr", SorNr, IdxNr 'Leistungsketten
        Case "F": DBCmEx2 "qryKet03S", "@IdSor", "@IdxNr", SorWe, IdxWe 'Diagnoseketten
                  DBCmEx2 "qryKet03S", "@IdSor", "@IdxNr", SorNr, IdxNr 'Diagnoseketten
        Case "H": DBCmEx2 "qryKet02S", "@IdSor", "@IdxNr", SorWe, IdxWe 'Laborprofile
                  DBCmEx2 "qryKet02S", "@IdSor", "@IdxNr", SorNr, IdxNr 'Laborprofile
        Case "J": DBCmEx2 "qryKet04S", "@IdSor", "@IdxNr", SorWe, IdxWe 'Arzneiketten
                  DBCmEx2 "qryKet04S", "@IdSor", "@IdxNr", SorNr, IdxNr 'Arzneiketten
        Case "R": DBCmEx2 "qryKon02S", "@IdSor", "@IdxNr", SorWe, IdxWe 'Terminketten
                  DBCmEx2 "qryKon02S", "@IdSor", "@IdxNr", SorNr, IdxNr 'Terminketten
        Case "Q": DBCmEx2 "qryKet12S", "@IdSor", "@IdxNr", SorWe, IdxWe 'Artikelketten
                  DBCmEx2 "qryKet12S", "@IdSor", "@IdxNr", SorNr, IdxNr 'Artikelketten
        End Select
    End If
End If

Set RpSel = Nothing
Set RpRws = Nothing
Set RpCls = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "E_Mov " & Err.Number
Resume Next

End Sub
