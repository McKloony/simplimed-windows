                                        If FrgNr = CLng(RS159.Fields("IDSub").Value) Then
                                            GuiSu = CreateID("S")
                                            RS127.AddNew
                                            
                                            For Each FL101 In RS159.Fields
                                                Select Case FL101.Name
                                                Case "ID6":
                                                Case "Gruppe":
                                                Case "IDKey":
                                                Case "IDSub":
                                                        If SubNr > 0 Then
                                                            RS127.Fields(FL101.Name).Value = SubNr
                                                        End If
                                                Case "GuiID":
                                                        If RS159.Fields("ID3").Value <> vbNullString Then
                                                            If RS159.Fields("ID3").Value > 0 Then
                                                                RS127.Fields(FL101.Name).Value = GuiFr
                                                            Else
                                                                RS127.Fields(FL101.Name).Value = GuiSu
                                                            End If
                                                        Else
                                                            RS127.Fields(FL101.Name).Value = GuiSu
                                                        End If
                                                Case "Feldname":
                                                        If RS159.Fields("ID3").Value <> vbNullString Then
                                                            If RS159.Fields("ID3").Value > 0 Then
                                                                RS127.Fields(FL101.Name).Value = GuiFr
                                                            Else
                                                                RS127.Fields(FL101.Name).Value = GuiSu
                                                            End If
                                                        Else
                                                            RS127.Fields(FL101.Name).Value = GuiSu
                                                        End If
                                                Case "IDKurz":
                                                        TmpSt = vbNullString
                                                        If KatWe > 0 Then
                                                            If KatWe = KatNr Then
                                                                TmpSt = "(Kopie) " & FL101.Value
                                                                If Len(TmpSt) > 250 Then
                                                                    TmpSt = Left$(TmpSt, 250)
                                                                End If
                                                                RS127.Fields(FL101.Name).Value = TmpSt
                                                            Else
                                                                RS127.Fields(FL101.Name).Value = RS159.Fields(FL101.Name).Value
                                                            End If
                                                        Else
                                                            RS127.Fields(FL101.Name).Value = RS159.Fields(FL101.Name).Value
                                                        End If
                                                Case "Sorter":
                                                        If KatWe > 0 Then
                                                            If KatWe = KatNr Then
                                                                If RS159.Fields(FL101.Name).Value <> vbNullString Then
                                                                    RS127.Fields(FL101.Name).Value = CLng(RS159.Fields(FL101.Name).Value) + 1
                                                                Else
                                                                    RS127.Fields(FL101.Name).Value = 1
                                                                End If
                                                            Else
                                                                RS127.Fields(FL101.Name).Value = RS159.Fields(FL101.Name).Value
                                                            End If
                                                        Else
                                                            RS127.Fields(FL101.Name).Value = RS159.Fields(FL101.Name).Value
                                                        End If
                                                Case "ID3":
                                                        If RS159.Fields(FL101.Name).Value > 0 Then
                                                            If KatWe > 0 Then
                                                                RS127.Fields(FL101.Name).Value = KatWe
                                                            Else
                                                                RS127.Fields(FL101.Name).Value = 0
                                                            End If
                                                        Else
                                                            RS127.Fields(FL101.Name).Value = 0
                                                        End If
