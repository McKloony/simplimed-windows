                    End If
                    If CBool(RS128.Fields("Selekt").Value) = True Then
                        ChErw.Value = xtpChecked
                    Else
                        ChErw.Value = xtpUnchecked
                    End If
                End If
                DoEvents

                If GlBuc = True Then 'einfache Buchhaltung verwenden
                    CmBez.SetFocus
                Else
                    If GlBuF <= 4 Then
                        FM.txtHaben.SetFocus
                    ElseIf GlBuF <= 7 Then
                        FM.cmbBuTyp.SetFocus
                    ElseIf GlBuF = 8 Then
                        FM.cmbBehan.SetFocus
                    End If
                End If
            End If
        Else
            Posit = InStr(1, SuStr, Chr$(32), 1)
            If Posit = 0 Then

                If GlBuF <= 4 Then
                    FM.txtKonto.Text = vbNullString
                    FM.txtBezei.Text = vbNullString
                    FM.txtKtoNr.Text = 0
                    FM.txtKonto.SetFocus
                ElseIf GlBuF <= 8 Then
                    FM.txtHaben.Text = vbNullString
                    FM.txtBezHa.Text = vbNullString
                    FM.txtKtoHa.Text = 0
                    FM.txtHaben.SetFocus
                ElseIf GlBuF = 9 Then
                    FM.txtKonto.Text = vbNullString
                    FM.txtBezei.Text = vbNullString
                    FM.txtKtoNr.Text = 0
                    FM.txtKonto.SetFocus
                ElseIf GlBuF = 10 Then
                    FM.txtHaben.Text = vbNullString
                    FM.txtBezHa.Text = vbNullString
                    FM.txtKtoHa.Text = 0
                    FM.txtHaben.SetFocus
                End If
                SPopu Tit1, Mld1, IC48_Warning

