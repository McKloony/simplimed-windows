        If GlBut <> RibTab_Kat_Ketten Then
            RpItm.Focusable = False
        End If
        Set RpItm = RpRec.AddItem(Format$(RS140.Fields("Preis").Value, GlWa1))
        RpItm.Tag = "_Preis"
            If GlBut <> RibTab_Kat_Ketten Then
        RpItm.Focusable = False
        End If
        Set RpItm = RpRec.AddItem(RS140.Fields("ID2").Value)
        Set RpItm = RpRec.AddItem(RS140.Fields("IDA").Value)
