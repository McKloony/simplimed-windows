Public Sub E_Akt(ByVal KetNr As Long, Optional ByVal PrSav As Boolean = False)
On Error GoTo LiErr
'Aktulisiert die Kettenübersicht

Dim GrpNr As Long
Dim SQL1 As String
Dim TreKy As String
Dim Multi As Single
Dim EiPre As Double
Dim GePre As Double
Dim KePre As Double
Dim TmMin As Integer
Dim GeMin As Integer
Dim Anza1 As Integer
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmKetten
Set RpCo5 = FM.repCont5
Set RpRcs = RpCo5.Records

TreKy = Left$(GlNod, 1)
GrpNr = Mid$(GlNod, 2, Len(GlNod) - 1)

If GlTyp < 2 Then
    Select Case TreKy
    Case "D": SQL1 = "SELECT * FROM dbo.qryKet01A WHERE ID1 = " & KetNr 'Gebührenketten
    Case "F": SQL1 = "SELECT * FROM dbo.qryKet03A WHERE ID1 = " & KetNr 'Diagnoseketten
    Case "H": SQL1 = "SELECT * FROM dbo.qryKet02A WHERE ID1 = " & KetNr 'Laborketten
    Case "J": SQL1 = "SELECT * FROM dbo.qryKet04A WHERE ID1 = " & KetNr 'Arzneiketten
    Case "R": SQL1 = "SELECT * FROM dbo.qryKon02A WHERE ID1 = " & KetNr 'Terminketten
    Case "Q": SQL1 = "SELECT * FROM dbo.qryKet12A WHERE ID1 = " & KetNr 'Artikelketten
    End Select
Else
    Select Case TreKy
    Case "D": SQL1 = "SELECT * FROM qryKet01A WHERE [ID1] = " & KetNr & ";" 'Gebührenketten
    Case "F": SQL1 = "SELECT * FROM qryKet03A WHERE [ID1] = " & KetNr & ";" 'Diagnoseketten
    Case "H": SQL1 = "SELECT * FROM qryKet02A WHERE [ID1] = " & KetNr & ";" 'Laborketten
    Case "J": SQL1 = "SELECT * FROM qryKet04A WHERE [ID1] = " & KetNr & ";" 'Arzneiketten
    Case "R": SQL1 = "SELECT * FROM qryKon02A WHERE [ID1] = " & KetNr & ";" 'Terminketten
    Case "Q": SQL1 = "SELECT * FROM qryKet12A WHERE [ID1] = " & KetNr & ";" 'Artikelketten
    End Select
End If

If RpRcs.Count > 0 Then
    For Each RpRec In RpRcs
        If TreKy = "R" Then
            If RpRec.Item(Ket_Preis).Value <> vbNullString Then
                TmMin = Left$(RpRec.Item(Ket_Preis).Value, 3)
            Else
                TmMin = 0
            End If
            GeMin = GeMin + TmMin
        Else
            If RpRec.Item(Ket_Preis).Value <> vbNullString Then
                If IsNumeric(RpRec.Item(Ket_Preis).Value) = True Then
                    EiPre = Format$(RpRec.Item(Ket_Preis).Value, GlWa1)
                Else
                    EiPre = 0
                End If
            Else
                EiPre = 0
            End If
            If RpRec.Item(Ket_Anz).Value <> vbNullString Then
                If RpRec.Item(Ket_Anz).Value > 1 Then
                    Anza1 = RpRec.Item(Ket_Anz).Value
                Else
                    Anza1 = 1
                End If
            Else
                Anza1 = 1
            End If
            If RpRec.Item(Ket_Fakto).Value <> vbNullString Then
                If RpRec.Item(Ket_Fakto).Value > 1 Then
                    Multi = Format$(RpRec.Item(Ket_Fakto).Value, GlWa1)
                Else
                    Multi = 1
                End If
            Else
                Multi = 1
            End If
            GePre = WinRound(((EiPre * Multi) * Anza1), 2)
            KePre = KePre + GePre
        End If
    Next RpRec
Else
    KePre = 0
End If

If PrSav = True Then
    Set RS136 = New ADODB.Recordset
    With RS136
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With
    
    If RS136.Supports(adUpdate) Then
        If TreKy = "R" Then
            RS136.Fields("Zeit").Value = GeMin
        Else
            KePre = WinRound(KePre, 2)
            RS136.Fields("Preis").Value = KePre
        End If
        RS136.Update
    End If
    RS136.Close
    Set RS136 = Nothing
End If

Set RpRcs = Nothing
Set RpCo5 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "E_Akt " & Err.Number
Resume Next

End Sub

Public Sub E_Anz(ByVal KetNr As Long)
On Error GoTo LiErr
'Ändert die Anzahl der Einträge in der Kette

Dim TmpMu As String
Dim TmpPr As String
Dim TmTag As String
Dim KeySt As String
Dim SQL1 As String
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmKetten
Set RpCo5 = FM.repCont5
Set RpRcs = RpCo5.Records

KeySt = Left$(GlNod, 1)

If GlTyp < 2 Then
    Select Case KeySt
    Case "D": SQL1 = "SELECT * FROM dbo.qryKetBe1 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Leistungsketten
    Case "F": SQL1 = "SELECT * FROM dbo.qryKetBe2 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Diagnoseketten
    Case "H": SQL1 = "SELECT * FROM dbo.qryKetBe3 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Laborprofile
    Case "J": SQL1 = "SELECT * FROM dbo.qryKetBe4 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Arzneiketten
    Case "Q": SQL1 = "SELECT * FROM dbo.qryKetBe5 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Artikelketten
    End Select
Else
    Select Case KeySt
    Case "D": SQL1 = "SELECT * FROM qryKetBe1 WHERE [ID1] = " & KetNr & " ORDER BY [ID2];" 'Leistungsketten
    Case "F": SQL1 = "SELECT * FROM qryKetBe2 WHERE [ID1] = " & KetNr & " ORDER BY [ID2];" 'Diagnoseketten
    Case "H": SQL1 = "SELECT * FROM qryKetBe3 WHERE [ID1] = " & KetNr & " ORDER BY [ID2];" 'Laborprofile
    Case "J": SQL1 = "SELECT * FROM qryKetBe4 WHERE [ID1] = " & KetNr & " ORDER BY [ID2];" 'Arzneiketten
    Case "Q": SQL1 = "SELECT * FROM qryKetBe5 WHERE [ID1] = " & KetNr & " ORDER BY [ID2];" 'Artikelketten
    End Select
End If

Set RS137 = New ADODB.Recordset
With RS137
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With
If RS137.RecordCount > 0 Then
    If RS137.Supports(adUpdate) Then
        RS137.MoveFirst
        For Each RpRec In RpRcs
            For Each RpItm In RpRec
                If Left$(RpItm.Tag, 1) = "@" Then
                    TmTag = Mid$(RpItm.Tag, 2, Len(RpItm.Tag) - 1)
                    If RpItm.HasCheckbox = True Then
                        RS137.Fields(TmTag).Value = RpItm.Checked
                    Else
                        Select Case TmTag
                        Case "x":
                                If RpItm.Value > 0 Then
                                    RS137.Fields(TmTag).Value = WinRound(RpItm.Value, 0) 'Aufrunden
                                Else
                                    RpItm.Value = 1
                                End If
                        Case "Multi":
                                If InStr(1, RpItm.Value, ".", 1) > 0 Then
                                    TmpMu = Replace(RpItm.Value, ".", vbNullString, 1)
                                    TmpMu = Mid$(TmpMu, 1, Len(TmpMu) - 3) & "." & Right$(TmpMu, 2)
                                    RS137.Fields(TmTag).Value = TmpMu
                                Else
                                    If InStr(1, RpItm.Value, ",", 1) > 0 Then
                                        TmpMu = Replace(RpItm.Value, ",", ".", 1)
                                        RS137.Fields(TmTag).Value = TmpMu
                                    Else
                                        RS137.Fields(TmTag).Value = RpItm.Value
                                    End If
                                End If
                        Case "Preis":
                                If InStr(1, RpItm.Value, ".", 1) > 0 Then
                                    TmpPr = Replace(RpItm.Value, ".", vbNullString, 1)
                                    TmpPr = Mid$(TmpPr, 1, Len(TmpPr) - 3) & "." & Right$(TmpPr, 2)
                                    RS137.Fields(TmTag).Value = TmpPr
                                Else
                                    If InStr(1, RpItm.Value, ",", 1) > 0 Then
                                        TmpPr = Replace(RpItm.Value, ",", ".", 1)
                                        RS137.Fields(TmTag).Value = TmpPr
                                    Else
                                        RS137.Fields(TmTag).Value = RpItm.Value
                                    End If
                                End If
                        Case Else:
                                RS137.Fields(TmTag).Value = RpItm.Value
                        End Select
                    End If
                End If
            Next RpItm
            RS137.Update
            RS137.MoveNext
        Next RpRec
    End If
End If
RS137.Close
Set RS137 = Nothing

If GlJet = True Then SDBSav

Set RpRcs = Nothing
Set RpCol = Nothing
Set RpCo5 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "E_Anz " & Err.Number
Resume Next

End Sub
