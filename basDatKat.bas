                Case 4: SQL1 = "SELECT * FROM qrySimAbLei1 WHERE [IDR] = " & ReNum & " ORDER BY [Sorter], [ID3];" 'Sorter aufsteigend
                End Select
            End Select
        End If

        Set RS124 = New ADODB.Recordset 'Abrechnungen
