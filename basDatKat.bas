Public Sub S_KtLo()
On Error GoTo GrErr
'Löscht die markierten Einträge

Dim IdxNr As Long
Dim ReNum As Long
Dim GesZa As Long
Dim RowNr As Long
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmCom As XtremeCommandBars.CommandBarComboBox
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpCon As XtremeReportControl.ReportControl
Dim RpRow As XtremeReportControl.ReportRow

Tit1 = "Eintrag Entfernen"

Set FM = frmBuKont
Set CmBrs = FM.comBar02
Set RpCon = FM.repCont1
Set RpCls = RpCon.Columns
Set RpSel = RpCon.SelectedRows

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

GesZa = RpSel.Count

If GesZa = 0 Then
    Exit Sub
ElseIf GesZa = 1 Then
    Mld1 = "Möchten Sie den markierten Eintrag wirklich löschen?"
ElseIf GesZa > 1 Then
    Mld1 = "Möchten Sie die " & GesZa & " markierten Einträge wirklich löschen?"
End If

Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
If Frage = 6 Then
    Screen.MousePointer = vbHourglass
    clFen.FenDsk 2

    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            RowNr = RpRow.Index
            Set RpCol = RpCls.Find(Kon_IDI)
            IdxNr = RpRow.Record(RpCol.ItemIndex).Value
