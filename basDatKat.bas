Public Sub E_KeKo(ByVal TreKy As String)
On Error GoTo GrErr
'Kopiert eine Kette

Dim RowNr As Long
Dim ParNr As Long    'Parameternummer
Dim KetNr As Long    'Kettennummer
Dim KeNum As Long    'Kettennummer
Dim AkKat As Long    'Katalognummer
Dim KatNr As Long    'Aktueller Katalog
Dim EiPre As Double  'Parameterpreis
Dim GePre As Double  'Parametersumme
Dim KePre As Double
Dim Multi As Single
Dim SQL4 As String
Dim SQL5 As String
Dim SumSt As String  'Summenstring
Dim KeBez As String  'Kettenbezeichnung
Dim KetKu As String  'Kettenkürzel
Dim PaKur As String  'Parameterkürzel
Dim NeKur As String  'Neues Kürzel
Dim PaSor As Integer 'Sortiernummer
Dim Anzal As Integer
Dim AnSel As Integer
Dim AnzKe As Integer
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCo8 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo8 = FM.repCont8
Set RpCls = RpCo8.Columns
Set RpSel = RpCo8.SelectedRows
Set TrLi1 = frmKaKop.trvList1

Select Case TreKy
Case "D":
Case "H":
Case Else: Exit Sub
End Select

AnSel = RpSel.Count
Tit1 = "Eintrag kopieren"
If AnSel > 1 Then
    Mld1 = "Möchten Sie die " & AnSel & " markierten Ketten in die anderen Kataloge kopieren? Dieser Vorgang kann einige Minuten in Anspruch nehmen."
Else
    Mld1 = "Möchten Sie die markierte Kette wirklich in die anderen Kataloge kopieren? Dieser Vorgang kann einige Minuten in Anspruch nehmen."
End If

If AnSel > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then
                
        KatNr = Mid$(GlNod, 2, Len(GlNod) - 1)

        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                AnzKe = AnzKe + 1
                Set RpCol = RpCls.Find(Kat_ID0)
                KeNum = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Kat_GOID)
                KetKu = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Kat_IDKurz)
                KeBez = RpRow.Record(RpCol.ItemIndex).Value
                NeKur = KetKu & Format$(AnzKe, "000")  'Neues Kürzel

                Set RS139 = New ADODB.Recordset
                RS139.CursorLocation = adUseClient
                Select Case TreKy
                Case "D": Set RS139 = DBCmRe1("qryKet01K", "@IdxNr", KeNum) 'Gebührenketten
                Case "F":                                                   'Diagnoseketten
                Case "H": Set RS139 = DBCmRe1("qryKet02K", "@IdxNr", KeNum) 'Laborketten
                Case "J":                                                   'Arzneiketten
                Case "R":                                                   'Terminketten
                Case "Q":                                                   'Artikelketten
                End Select

                If RS139.RecordCount > 0 Then
                    For Each Knote In TrLi1.Nodes
                        If Knote.Checked = True Then
                            If Right$(Knote.Key, 2) <> "00" Then
                                AkKat = CLng(Mid$(Knote.Key, 2, Len(Knote.Key) - 1))
                                KetNr = 0

                                If GlTyp < 2 Then
                                    Select Case TreKy
                                    Case "D": SQL4 = "SELECT * FROM dbo.qryKat01B WHERE ID3 = -1" 'Gebührenketten
                                    Case "F":                                                     'Diagnoseketten
                                    Case "H": SQL4 = "SELECT * FROM dbo.qryKat02B WHERE ID3 = -1" 'Laborketten
                                    Case "J":                                                     'Arzneiketten
                                    Case "R":                                                     'Terminketten
                                    Case "Q":                                                     'Artikelketten
                                    End Select
                                Else
                                    Select Case TreKy
                                    Case "D": SQL4 = "SELECT * FROM qryKat01B WHERE [ID3] = -1;" 'Gebührenketten
                                    Case "F":                                                    'Diagnoseketten
                                    Case "H": SQL4 = "SELECT * FROM qryKat02B WHERE [ID3] = -1;" 'Laborketten
                                    Case "J":                                                    'Arzneiketten
                                    Case "R":                                                    'Terminketten
                                    Case "Q":                                                    'Artikelketten
                                    End Select
                                End If
                                Set RS137 = New ADODB.Recordset
                                With RS137
                                    .ActiveConnection = DB1
                                    .CursorLocation = adUseClient
                                    .CursorType = adOpenDynamic
                                    .LockType = adLockOptimistic
                                    .Source = SQL4
                                    .Open Options:=adCmdText
                                End With
                                If RS137.Supports(adAddNew) Then
                                    RS137.AddNew
                                    RS137.Fields("ID3").Value = AkKat
                                    RS137.Fields("IDKurz").Value = KeBez
                                    If KatNr <> AkKat Then
                                        RS137.Fields("GOID").Value = KetKu
                                    Else
                                        RS137.Fields("GOID").Value = NeKur
                                    End If
                                    RS137.Update
                                End If
                                RS137.Close
                                Set RS137 = Nothing
                                
                                Set RS140 = New ADODB.Recordset
                                RS140.CursorLocation = adUseClient
                                Set RS140 = New ADODB.Recordset 'Neue Kettennummer ermitteln
                                RS140.CursorLocation = adUseClient
                                If KatNr <> AkKat Then
                                    Select Case TreKy
                                    Case "D": Set RS140 = DBCmRe2("qryKet01b", "@IdxNr", "@IdStr", AkKat, KetKu) 'Gebührenketten
                                    Case "H": Set RS140 = DBCmRe2("qryKet02b", "@IdxNr", "@IdStr", AkKat, KetKu) 'Laborketten
                                    End Select
                                Else
                                    Select Case TreKy
                                    Case "D": Set RS140 = DBCmRe2("qryKet01b", "@IdxNr", "@IdStr", AkKat, NeKur) 'Gebührenketten
                                    Case "H": Set RS140 = DBCmRe2("qryKet02b", "@IdxNr", "@IdStr", AkKat, NeKur) 'Laborketten
                                    End Select
                                End If
                                If RS140.RecordCount > 0 Then
                                    KetNr = RS140.Fields("ID1").Value
                                End If
                                RS140.Close
                                Set RS140 = Nothing
                                
                                If KetNr > 0 Then
                                    If GlTyp < 2 Then
                                        Select Case TreKy
                                        Case "D": SQL5 = "SELECT * FROM dbo.qryKetBe1 WHERE ID1 = -1" 'Gebührenketten
                                        Case "F":                                                     'Diagnoseketten
                                        Case "H": SQL5 = "SELECT * FROM dbo.qryKetBe3 WHERE ID1 = -1" 'Laborketten
                                        Case "J":                                                     'Arzneiketten
                                        Case "R":                                                     'Terminketten
                                        Case "Q":                                                     'Artikelketten
                                        End Select
                                    Else
                                        Select Case TreKy
                                        Case "D": SQL5 = "SELECT * FROM qryKetBe1 WHERE [ID1] = -1;" 'Gebührenketten
                                        Case "F":                                                    'Diagnoseketten
                                        Case "H": SQL5 = "SELECT * FROM qryKetBe3 WHERE [ID1] = -1;" 'Laborketten
                                        Case "J":                                                    'Arzneiketten
                                        Case "R":                                                    'Terminketten
                                        Case "Q":                                                    'Artikelketten
                                        End Select
                                    End If
                                    
                                    Set RS136 = New ADODB.Recordset
                                    With RS136
                                        .ActiveConnection = DB1
                                        .CursorLocation = adUseClient
                                        .CursorType = adOpenDynamic
                                        .LockType = adLockOptimistic
                                        .Source = SQL5
                                        .Open Options:=adCmdText
                                    End With
                                    
                                    If RS136.Supports(adAddNew) Then
                                        RS139.MoveFirst
                                        GePre = 0
                                        
                                        Do 'Jeden Parameter der Kette durchlaufen
                                        PaKur = RS139.Fields("GOID").Value
                                        PaSor = RS139.Fields("ID2").Value
                                        Anzal = RS139.Fields("x").Value
                                        If TreKy = "D" Then 'Gebührenketten
                                            If RS139.Fields("Multi").Value > 0 Then
                                                Multi = RS139.Fields("Multi").Value
                                            Else
                                                Multi = 1
                                            End If
                                        Else
                                            Multi = 1
                                        End If
                                        Set RS138 = New ADODB.Recordset
                                        RS138.CursorLocation = adUseClient
                                        Select Case TreKy
                                        Case "D": Set RS138 = DBCmRe2("qryKat01G", "@IdxNr", "@IdStr", AkKat, PaKur) 'Gebührenketten
                                        Case "F":                                                                    'Diagnoseketten
                                        Case "H": Set RS138 = DBCmRe2("qryKat02G", "@IdxNr", "@IdStr", AkKat, PaKur) 'Laborketten
                                        Case "J":                                                                    'Arzneiketten
                                        Case "R":                                                                    'Terminketten
                                        Case "Q":                                                                    'Artikelketten
                                        End Select
                                        
                                        If RS138.RecordCount > 0 Then
                                            ParNr = RS138.Fields("ID0").Value
                                            EiPre = Format$(RS138.Fields("Preis1").Value, GlWa1)
                                            GePre = WinRound((EiPre * Multi) * Anzal, 2)
                                            KePre = KePre + GePre
                                            
                                            RS136.AddNew
                                            RS136.Fields("ID0").Value = ParNr
                                            RS136.Fields("ID1").Value = KetNr
                                            RS136.Fields("ID2").Value = PaSor
                                            RS136.Fields("ID3").Value = AkKat
                                            RS136.Fields("Preis").Value = EiPre
                                            RS136.Fields("x").Value = Anzal
                                            If TreKy = "D" Then 'Gebührenketten
                                                RS136.Fields("Multi").Value = Multi
                                            End If
                                            RS136.Update
                                        End If
                                        
                                        RS138.Close
                                        Set RS138 = Nothing
                                        RS139.MoveNext
                                        Loop Until RS139.EOF
                                        
                                        KePre = WinRound(KePre, 2)
                                        DBCmEx2 "qryKetAkL", "@IdSum", "@IdxNr", KePre, KetNr 'Kettenpreis aktualisieren
                                    End If
                                    RS136.Close
                                    Set RS136 = Nothing
                                End If
                                
                            End If
                        End If
                    Next Knote
                End If
                
                RS139.Close
                Set RS139 = Nothing
            End If
        Next RpRow
    End If
End If

DoEvents
KUpKa

Set RpSel = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo8 = Nothing

Exit Sub

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "E_KeKo " & Err.Number
Resume Next

End Sub
Public Sub E_KeSa(ByVal KetNr As Long)
On Error GoTo LiErr
'Fügt Einträge in die Kette ein

Dim KeyNr As Long
Dim SorNr As Long 'Sortiernummer
Dim NeSor As Long 'Sortiernummer
Dim SQL1 As String
Dim SQL2 As String
Dim TreKy As String
Dim Krit1 As String
Dim Kurzb As String  'Kurzbezeichung
Dim EiPre As Double  'Preise
Dim Multi As Single
Dim Einfu As Boolean 'Einfügen
Dim Mld1, Tit1 As String
Dim Frage As Integer
Dim RpCo5 As XtremeReportControl.ReportControl

Set FM = frmKetten
Set RpCo5 = FM.repCont5
Set RpRcs = RpCo5.Records

TreKy = Left$(GlNod, 1)

RpCo5.Populate
DoEvents

If GlTyp < 2 Then
    Select Case TreKy
    Case "D": SQL1 = "SELECT * FROM dbo.qryKet01 WHERE ID1 = " & KetNr  'Gebührenketten
              SQL2 = "SELECT * FROM dbo.qryKet01M WHERE ID1 = " & KetNr
    Case "F": SQL1 = "SELECT * FROM dbo.qryKet03 WHERE ID1 = " & KetNr  'Diagnoseketten
              SQL2 = "SELECT * FROM dbo.qryKet03M WHERE ID1 = " & KetNr
    Case "H": SQL1 = "SELECT * FROM dbo.qryKet02 WHERE ID1 = " & KetNr  'Laborprofile
              SQL2 = "SELECT * FROM dbo.qryKet02M WHERE ID1 = " & KetNr
    Case "J": SQL1 = "SELECT * FROM dbo.qryKet04 WHERE ID1 = " & KetNr  'Arzneiketten
              SQL2 = "SELECT * FROM dbo.qryKet04M WHERE ID1 = " & KetNr
    Case "R": SQL1 = "SELECT * FROM dbo.qryKon02 WHERE ID1 = " & KetNr  'Terminketten
              SQL2 = "SELECT * FROM dbo.qryKon02M WHERE ID1 = " & KetNr
    Case "Q": SQL1 = "SELECT * FROM dbo.qryKet12 WHERE ID1 = " & KetNr  'Artikelketten
              SQL2 = "SELECT * FROM dbo.qryKet12M WHERE ID1 = " & KetNr
    End Select
Else
    Select Case TreKy
    Case "D": SQL1 = "SELECT * FROM qryKet01 WHERE [ID1] = " & KetNr & ";" 'Gebührenketten
              SQL2 = "SELECT * FROM qryKet01M WHERE [ID1] = " & KetNr & ";"
    Case "F": SQL1 = "SELECT * FROM qryKet03 WHERE [ID1] = " & KetNr & ";" 'Diagnoseketten
              SQL2 = "SELECT * FROM qryKet03M WHERE [ID1] = " & KetNr & ";"
    Case "H": SQL1 = "SELECT * FROM qryKet02 WHERE [ID1] = " & KetNr & ";" 'Laborprofile
              SQL2 = "SELECT * FROM qryKet02M WHERE [ID1] = " & KetNr & ";"
    Case "J": SQL1 = "SELECT * FROM qryKet04 WHERE [ID1] = " & KetNr & ";" 'Arzneiketten
              SQL2 = "SELECT * FROM qryKet04M WHERE [ID1] = " & KetNr & ";"
    Case "R": SQL1 = "SELECT * FROM qryKon02 WHERE [ID1] = " & KetNr & ";" 'Terminketten
              SQL2 = "SELECT * FROM qryKon02M WHERE [ID1] = " & KetNr & ";"
    Case "Q": SQL1 = "SELECT * FROM qryKet12 WHERE [ID1] = " & KetNr & ";" 'Artikelketten
              SQL2 = "SELECT * FROM qryKet12M WHERE [ID1] = " & KetNr & ";"
    End Select
End If

If RpRcs.Count > 0 Then
    Set RS136 = New ADODB.Recordset
    With RS136
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With
    
    NeSor = 1
    For Each RpRec In RpRcs
        Einfu = True
        KeyNr = RpRec.Item(Ket_ID0).Value
        Kurzb = RpRec.Item(Ket_IDKurz).Value
        SorNr = RpRec.Item(Ket_ID2).Value
        If TreKy <> "R" Then
            EiPre = Format$(RpRec.Item(Ket_Preis).Value, GlWa1)
            Multi = Format$(RpRec.Item(Ket_Fakto).Value, GlWa1)
        End If
                
        If SorNr = 0 Then 'neue Einträge werden mit SorNr 0 eingetragen
            If RS136.RecordCount > 0 Then
                RS136.MoveFirst
                If TreKy = "R" Then
                    Krit1 = "[ID4]=" & KeyNr
                Else
                    Krit1 = "[ID0]=" & KeyNr
                End If
                RS136.Find Criteria:=Krit1, SkipRecords:=0, SearchDirection:=adSearchForward
                If Not (RS136.BOF Or RS136.EOF) Then
                    Mld1 = "Der Eintrag " & Kurzb & " ist bereits Bestandteil dieser Kette. Soll er erneut eingefügt werden?"
                    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
                    If Frage <> 6 Then
                        Einfu = False
                    End If
                End If
            End If
            If Einfu = True Then
                RS136.AddNew
                If TreKy = "R" Then
                    RS136.Fields("ID4").Value = KeyNr
                Else
                    RS136.Fields("ID0").Value = KeyNr
                End If
                RS136.Fields("ID1").Value = KetNr
                RS136.Fields("ID2").Value = NeSor
                If TreKy <> "R" Then
                    RS136.Fields("x").Value = 1
                    RS136.Fields("Preis").Value = EiPre
                End If
                RS136.Update
            End If
        End If
        NeSor = NeSor + 1
    Next RpRec
    RS136.Close
    Set RS136 = Nothing

    Set RS139 = New ADODB.Recordset
    With RS139
        .CursorLocation = adUseClient
        .Source = SQL2
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With
    If RS139.RecordCount > 0 Then
        If RS139.Supports(adUpdate) Then
            NeSor = 1 'alle Einträge werden neu durchnumeriert
            For Each RpRec In RpRcs
                KeyNr = RpRec.Item(Ket_ID0).Value
                RS139.MoveFirst
                If TreKy = "R" Then
                    Krit1 = "[ID4]=" & KeyNr
                Else
                    Krit1 = "[ID0]=" & KeyNr
                End If
                RS139.Find Criteria:=Krit1, SkipRecords:=0, SearchDirection:=adSearchForward
                If Not (RS139.BOF Or RS139.EOF) Then
                    RS139.Fields("ID2").Value = NeSor
                    RS139.Update
                End If
                NeSor = NeSor + 1
            Next RpRec
        End If
    End If
    RS139.Close
    Set RS139 = Nothing
    
    If GlJet = True Then SDBSav
End If

Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCo5 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "E_KeSa " & Err.Number
Resume Next

End Sub
Public Sub E_Ket(ByVal KetNr As Long, Optional ByVal IdxNr As Long)
On Error GoTo LiErr
'Listet die Einträge einer Kette

Dim RowNr As Long
Dim RowFi As Long
Dim GesZa As Long
Dim SQL1 As String
Dim TreKy As String
Dim MulAn As String
Dim Multi As Single
Dim EiPre As Double
Dim TmPre As Double
Dim GePre As Double
Dim GeMin As Integer
Dim TmMin As Integer
Dim Anza1 As Integer
Dim CmBrs As XtremeCommandBars.CommandBars
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmKetten
Set RpCo5 = FM.repCont5
Set CmBrs = FM.comBar02
Set RpRcs = RpCo5.Records
Set CmAcs = CmBrs.Actions
Set CmSta = CmBrs.StatusBar

TreKy = Left$(GlNod, 1)

If GlTyp < 2 Then
    Select Case TreKy
    Case "D": SQL1 = "SELECT * FROM dbo.qryKet01 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Gebührenketten
    Case "F": SQL1 = "SELECT * FROM dbo.qryKet03 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Diagnoseketten
    Case "H": SQL1 = "SELECT * FROM dbo.qryKet02 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Laborprofile
    Case "J": SQL1 = "SELECT * FROM dbo.qryKet04 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Arzneiketten
    Case "R": SQL1 = "SELECT * FROM dbo.qryKon02 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Terminketten
    Case "Q": SQL1 = "SELECT * FROM dbo.qryKet12 WHERE ID1 = " & KetNr & " ORDER BY ID2" 'Artikelketten
    End Select
Else
    Select Case TreKy
    Case "D": SQL1 = "SELECT * FROM qryKet01 WHERE [ID1] = " & KetNr & " ORDER BY [ID2];" 'Gebührenketten
    Case "F": SQL1 = "SELECT * FROM qryKet03 WHERE [ID1] = " & KetNr & " ORDER BY [ID2];" 'Diagnoseketten
    Case "H": SQL1 = "SELECT * FROM qryKet02 WHERE [ID1] = " & KetNr & " ORDER BY [ID2];" 'Laborprofile
    Case "J": SQL1 = "SELECT * FROM qryKet04 WHERE [ID1] = " & KetNr & " ORDER BY [ID2];" 'Arzneiketten
    Case "R": SQL1 = "SELECT * FROM qryKon02 WHERE [ID1] = " & KetNr & " ORDER BY [ID2];" 'Terminketten
