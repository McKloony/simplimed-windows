                            Case "txtBisZe": AktCo.Text = Format$(RS40.Fields(TagWe).Value, "hh:mm")
                            Case "txtRefNr": AktCo.Text = Format$(RS40.Fields(TagWe).Value, "000000")
                            Case "txtRzNum": AktCo.Text = Format$(RS40.Fields(TagWe).Value, "000000")
                            Case "txtRzAnz": AktCo.Text = Format$(RS40.Fields(TagWe).Value, "000")
                            Case "txtZeiAn": AktCo.Text = Format$(RS40.Fields("ZeiAn").Value, "hh:mm") & " - " & Format$(RS40.Fields("ZeiAb").Value, "hh:mm")
                            Case "txtNotZe": AktCo.Text = Format$(RS40.Fields(TagWe).Value, "hh:mm")
                            Case "txtNoTim": AktCo.Text = Format$(RS40.Fields(TagWe).Value, "hh:mm")
                            Case "txtNotZe": AktCo.Text = Format$(RS40.Fields(TagWe).Value, "hh:mm")
                            Case "txtNoDat": AktCo.Text = Format$(RS40.Fields(TagWe).Value, "dd.mm.yyyy")
                            Case "txtNotDa": AktCo.Text = Format$(RS40.Fields(TagWe).Value, "dd.mm.yyyy")
                            Case "txtOnBuD": AktCo.Text = Format$(RS40.Fields(TagWe).Value, "dd.mm.yyyy")
                            Case "txtOnSyD": AktCo.Text = Format$(RS40.Fields(TagWe).Value, "dd.mm.yyyy")
                            Case "txtOnBuT": AktCo.Text = Format$(RS40.Fields("OnlBook").Value, "hh:mm")
                            Case "txtOnSyT": AktCo.Text = Format$(RS40.Fields("OnlSync").Value, "hh:mm")
                            Case Else: AktCo.Text = RS40.Fields(TagWe).Value
                                       AktCo.Tag = 0 & TagWe
                            End Select
                        End If
            Case "cmb": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                        If RS40.Fields(TagWe).Value <> vbNullString Then
                            If AktCo.Name = "cmbS4F11" Then
                                BrStr = RS40.Fields(TagWe).Value
                            Else
                                IdxWe = Val(RS40.Fields(TagWe).Value) - 1
                                Select Case AktCo.Name
                                Case "cmbBehan": IdxNr = Adr_Cm(AktCo, RS40.Fields(TagWe).Value)
                                Case "cmbMitar": IdxNr = Adr_Cm(AktCo, RS40.Fields(TagWe).Value)
                                Case "cmbArzNr": IdxNr = Adr_Cm(AktCo, RS40.Fields(TagWe).Value)
