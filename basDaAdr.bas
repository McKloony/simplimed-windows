Set FM = frmOutlook
Set PrBr1 = FM.prbStat1
Set PrBr2 = FM.prbStat2
Set TxDmy = FM.txtDummy
Set Labl7 = FM.lblLab07
Set RpCo1 = FM.repCont1
Set RpRcs = RpCo1.Records

Select Case ExTyp
Case 2:
    TeTit = "Outlook Kontakte Entfernen"
    TeMai = "Möchten Sie jetzt wirklich alle Outlook Kontakte löschen?"
    TeInh = "Wenn Sie mit Ja bestätigen, werden unwiderruflich alle Outlook Kontakte gelöscht. Fertigen Sie gegebenenfalls vor dem Löschen eine Sicherung Ihrer Outlook Datenbankdate, bzw. Exchange Datenbankdatei an."
    TeFus = "Das Löschen aller Outlook Kontakte kann dann hilfreich sein, wenn es bei der Synchronisation zu Problemen gekommen ist und alle eigenen Adresseinträge erneut an Outlook übertragen werden sollen."
Case 3:
    TeTit = "Outlook Termine Entfernen"
    TeMai = "Möchten Sie jetzt wirklich alle Outlook Termine löschen?"
    TeInh = "Wenn Sie mit Ja bestätigen, werden unwiderruflich alle Outlook Termine gelöscht. Fertigen Sie gegebenenfalls vor dem Löschen eine Sicherung Ihrer Outlook Datenbankdate, bzw. Exchange Datenbankdatei an."
    TeFus = "Das Löschen aller Outlook Termine kann dann hilfreich sein, wenn es bei der Synchronisation zu Problemen gekommen ist und alle eigenen Termineinträge erneut an Outlook übertragen werden sollen."
End Select

SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, False, FM.hwnd

GesZa = RpRcs.Count

If GesZa > 0 Then
    If GlMes = 33565 Then
        SOuOp 'Outlook öffnen

        Set NaSpa = OutOb.GetNamespace("MAPI") 'NameSpace
        
        If GlMaF = True Then
            Select Case ExTyp
            Case 0: Set MapFo = NaSpa.GetDefaultFolder(olFolderContacts)
            Case 1: Set MapFo = NaSpa.GetDefaultFolder(olFolderCalendar)
            Case 2: Set MapFo = NaSpa.GetDefaultFolder(olFolderContacts)
            Case 3: Set MapFo = NaSpa.GetDefaultFolder(olFolderCalendar)
            End Select
        Else
            Set MapFo = NaSpa.PickFolder
        End If
            
        Select Case ExTyp
        Case 2:
            If TypeName(MapFo) = "Nothing" Then
                Exit Sub
            ElseIf MapFo.DefaultItemType <> olContactItem Then
                Exit Sub
            End If
        Case 3:
            If TypeName(MapFo) = "Nothing" Then
                Exit Sub
            ElseIf MapFo.DefaultItemType <> olAppointmentItem Then
                Exit Sub
            End If
        End Select
        
        Set KoIts = MapFo.Items
    
        PrBr1.Min = 0
        PrBr2.Min = 0
        PrBr1.Max = GesZa
        PrBr2.Max = GesZa

        Select Case ExTyp
        Case 2:
            For AktZa = KoIts.Count To 1 Step -1
                Set KoItm = KoIts.Item(AktZa)
                KoItm.Delete
                DoEvents
                If TxDmy.Text = "B" Then Exit For 'Abbrechen
                PrBr1.Value = AktZa
                PrBr2.Value = AktZa
                Labl7.Caption = Format$(AktZa, "00000") & " von " & Format$(GesZa, "00000")
            Next AktZa
        Case 3:
            For AktZa = KoIts.Count To 1 Step -1
                Set KoItm = KoIts.Item(AktZa)
                KoItm.Delete
                DoEvents
                If TxDmy.Text = "B" Then Exit For 'Abbrechen
                PrBr1.Value = AktZa
                PrBr2.Value = AktZa
                Labl7.Caption = Format$(AktZa, "00000") & " von " & Format$(GesZa, "00000")
            Next AktZa
        End Select
    
        Set KoItm = Nothing
        Set NaSpa = Nothing
        Set MapFo = Nothing
        Set KoIts = Nothing
        Set OutOb = Nothing
    End If
End If

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRws = Nothing
Set RpCo1 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Out_Del " & Err.Number
Exit Sub

End Sub
