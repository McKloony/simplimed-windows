                                Case "cmbTeTyp": IdxNr = Adr_Cm(AktCo, RS40.Fields(TagWe).Value)
                                Case "cmbNotVa": IdxNr = Adr_Cm(AktCo, RS40.Fields(TagWe).Value)
                                Case "cmbOnlTe": IdxNr = Adr_Cm(AktCo, RS40.Fields(TagWe).Value)
                                Case "cmbS4F12":
                                        LaStr = RS40.Fields(TagWe).Value
                                        For AktZa = 1 To UBound(GlLan)
                                            If GlLan(AktZa, 1) = LaStr Then
                                                IdxNr = AktZa - 1
                                                Exit For
                                            End If
                                        Next AktZa
                                Case Else:
                                        If IdxWe < 0 Then
                                            IdxNr = 0
                                        Else
                                            IdxNr = IdxWe
                                        End If
                                End Select
                                If AktCo.ListCount > 0 Then
                                    RetWe = SendMessage(AktCo.hwnd, CB_SETCURSEL, IdxNr, ByVal 0&)
                                End If
                                AktCo.Tag = 0 & TagWe
                            End If
                        End If
            Case "chk": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                        If RS40.Fields(TagWe).Value = -1 Then
                            AktCo.Value = 1
                            AktCo.Tag = 0 & TagWe
                        End If
