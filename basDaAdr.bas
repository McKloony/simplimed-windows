                        If RS31.Fields("PTel").Value <> vbNullString Then If Len(FeTe2.Text) < 9 Then FeTe2.Text = "(" & RS31.Fields("PTel").Value & ") "
                        If RS31.Fields("PTel").Value <> vbNullString Then If Len(FeTe3.Text) < 9 Then FeTe3.Text = "(" & RS31.Fields("PTel").Value & ") "
                    End If
                    
