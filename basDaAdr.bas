Public Function GrMa_Ord(ByVal NeGru As String) As Long
On Error GoTo LoErr
'Ordnet den Emails eine Gruppe per OLEDrag zu

Dim IdxNr As Long
Dim RowNr As Long
Dim MitNr As Long
Dim AnzPo As Integer
Dim AktZa As Integer
Dim GruNr As Integer
Dim GruSt As String
Dim CmCom As XtremeCommandBars.CommandBarComboBox
Dim RpCo0 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmMain
