Public Sub GrAd_Ent()
On Error GoTo LoErr
'Entfernt Einträge aus der Gruppe

Dim GruNr As Long
Dim AnzPo As Long
Dim IdxNr As Long
Dim SQL1 As String
Dim GruSt As String
Dim DatKy As String
Dim Mld1, Tit1 As String
Dim Frage As Integer
Dim RpCo2 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmMain
Set TrLi1 = FM.trvList1
Set RpCo2 = FM.repCont2
Set RpCls = RpCo2.Columns
Set RpSel = RpCo2.SelectedRows

Tit1 = "Aus Gruppe entfernen"
AnzPo = RpSel.Count

GruNr = Mid$(GlPaK, 2, Len(GlPaK) - 1)
GruSt = "o" & GruNr & "o"

If AnzPo > 1 Then
    Mld1 = "Möchten Sie die " & AnzPo & " Adressen aus der Gruppe " & TrLi1.SelectedItem.Text & " entfernen?"
Else
    Mld1 = "Möchten Sie die Adresse aus der Gruppe " & TrLi1.SelectedItem.Text & " entfernen?"
End If

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qryAdress WHERE [TreKey] Like '%" & GruSt & "%'"
Else
    SQL1 = "SELECT * FROM qryAdress WHERE [TreKey] Like '%" & GruSt & "%';"
End If

Set RS50 = New ADODB.Recordset
With RS50
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenStatic
    .LockType = adLockBatchOptimistic
    .Open Options:=adCmdText
    .ActiveConnection = Nothing
End With
If RS50.RecordCount > 0 Then
    RS50.MoveFirst
    Do Until RS50.EOF
    DatKy = Replace(RS50.Fields("TreKey").Value, GruSt, "o", 1)
    RS50.Fields("TreKey").Value = DatKy
    RS50.MoveNext
    Loop
End If
If RS50.Supports(adUpdateBatch) Then
    Set RS50.ActiveConnection = DB1
    RS50.UpdateBatch
End If
RS50.Close
Set RS50 = Nothing

Set RpSel = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo2 = Nothing

Exit Sub

LoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "GrAd_Ent " & Err.Number
Resume Next

End Sub
Public Sub GrAd_Lad()
On Error GoTo PeErr
'Lädt die Gruppen in das TreeView

Dim SQL1 As String
Dim AkPos As Long
Dim AltPo As Long
Dim AktZa As Long
Dim GesZa As Long
Dim AktBe As Long
Dim LauZa As Long
Dim DatKy As String
Dim VorKy As String
Dim KnoKy As String
Dim TmpKy As String
Dim GrGef As Boolean

Set FM = frmMain
Set TrLi1 = FM.trvList1

TmpKy = GlPaK
AktBe = 1
AktZa = TrLi1.Nodes.Count + 1

For LauZa = 1 To UBound(GlPaG)
    If GlPaG(LauZa, 2) <> vbNullString Then
        DatKy = GlPaG(LauZa, 2)
    Else
        DatKy = 0
    End If
    KnoKy = "G" & GlPaG(LauZa, 0)
    AkPos = InStrRev(DatKy, ".", Len(DatKy), 1)
    If AkPos > 0 Then
        If AkPos > AltPo Then
            VorKy = TrLi1.Nodes(AktZa - 1).Key
        ElseIf AkPos < AltPo Then
            VorKy = TrLi1.Nodes(AktZa - 1).Parent.Parent.Key
        End If
    Else
        VorKy = "P801"
    End If
    If GlPaG(LauZa, 1) <> vbNullString Then
        Set Knote = TrLi1.Nodes.Add(VorKy, 4, KnoKy, GlPaG(LauZa, 1), IC16_Folder_Close)
    Else
        Set Knote = TrLi1.Nodes.Add(VorKy, 4, KnoKy, "-", IC16_Folder_Close)
    End If
    If Knote.Key = TmpKy Then
        Knote.Selected = True
        GrGef = True
    End If
    If GrGef = False Then TrLi1.Nodes("P801").Selected = True
    AltPo = AkPos
    AktZa = AktZa + 1
Next LauZa

TrLi1.Nodes("P800").Expanded = True
TrLi1.Nodes("P801").Expanded = True

If GlExp = True Then
    For Each Knote In TrLi1.Nodes
        If Left$(Knote.Key, 1) = "G" Then
            Knote.Expanded = True
        End If
    Next Knote
End If

Exit Sub

PeErr:
If GlDbg = True Then SErLog Err.Description & " GrAd_Lad " & Err.Number
Resume Next

End Sub
