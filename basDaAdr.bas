Private Function Ter_FeR(ByVal StaDa As Date, ByVal WunZe As Date, ByVal AdMin As Integer, ByVal RmuNr As Long, Optional ByVal ZwZei As String, Optional ByVal ZwEnd As String, Optional ByVal Behin As Integer, Optional ByVal BehNr As Long) As Boolean
On Error GoTo LoErr
'Im Wunschraum nichts gefunden, andere Räume prüfen

Dim ArSta As Date
Dim ArEnd As Date
Dim StaZe As Date
Dim EndZe As Date
Dim NeSta As Date
Dim NeEnd As Date
Dim DatSt As Date
Dim DatEn As Date
Dim DifMi As Integer
Dim AktZa As Integer
Dim GnzTa As Boolean

Ter_FeR = False

DatSt = StaDa & " 00:00:00" 'Kompatibilität zu SQL Server
DatEn = StaDa & " 23:59:00"

If ZwZei <> vbNullString Then
    ArSta = TimeValue(ZwZei)
    ArEnd = TimeValue(IniGetVal("TerSys", "EndZei"))
    WunZe = ArSta
ElseIf ZwEnd <> vbNullString Then
    ArSta = TimeValue(IniGetVal("TerSys", "StaZei"))
    ArEnd = TimeValue(ZwEnd)
Else
    ArSta = TimeValue(IniGetVal("TerSys", "StaZei"))
    ArEnd = TimeValue(IniGetVal("TerSys", "EndZei"))
End If

Set RS35 = New ADODB.Recordset
RS35.CursorLocation = adUseClient
Set RS35 = DBCmRe3("qryTerTag02", "@IdSta", "@IdEnd", "@IdxNr", DatSt, DatEn, RmuNr)
If RS35.RecordCount > 0 Then
    StaZe = TimeValue(RS35.Fields("ZeiVon").Value)
    EndZe = TimeValue(RS35.Fields("ZeiBis").Value)
    NeSta = TimeValue(DateAdd("n", -AdMin, StaZe))
    GnzTa = CBool(RS35.Fields("Selekt").Value)
    
    If GlGaT = False Then
        If GnzTa = True Then
            Exit Function
        End If
    End If
    
    If TimeValue(NeSta) >= TimeValue(ArSta) Then
        With TeFre
            .StaDa = TimeValue(NeSta)
            .RmuNr = RmuNr
            .Gefun = True
        End With
        Ter_FeR = True
        Exit Function
    End If
    
    If Not RS35.EOF And Not Not RS35.BOF Then
        RS35.MoveNext 'Nächster Termin
    End If

    Do
    StaZe = TimeValue(RS35.Fields("ZeiVon").Value)
    NeEnd = TimeValue(DateAdd("n", AdMin, EndZe))
    GnzTa = CBool(RS35.Fields("Selekt").Value)
    DifMi = DateDiff("n", TimeValue(EndZe), TimeValue("23:59:00"))
    
    If GlGaT = False Then
        If GnzTa = True Then
            Exit Function
        End If
    End If

    If AdMin > DifMi Then
        Exit Function
    ElseIf TimeValue(NeEnd) >= TimeValue(ArEnd) Then
        Exit Function
    ElseIf TimeValue(NeEnd) <= TimeValue(StaZe) Then
        If ZwZei <> vbNullString Then
            If TimeValue(NeEnd) > TimeValue(ArSta) Then
                With TeFre
                    .StaDa = TimeValue(EndZe)
                    .RmuNr = RmuNr
                    .Gefun = True
                End With
                Ter_FeR = True
                Exit Function
            End If
        ElseIf ZwEnd <> vbNullString Then
            If TimeValue(NeEnd) <= TimeValue(ArEnd) Then
                With TeFre
                    .StaDa = TimeValue(EndZe)
                    .RmuNr = RmuNr
                    .Gefun = True
                End With
                Ter_FeR = True
                Exit Function
            End If
        Else
            With TeFre
                .StaDa = TimeValue(EndZe)
                .RmuNr = RmuNr
                .Gefun = True
            End With
            Ter_FeR = True
            Exit Function
        End If
    End If
    EndZe = TimeValue(RS35.Fields("ZeiBis").Value)
    
    RS35.MoveNext
    Loop Until RS35.EOF

    NeEnd = TimeValue(DateAdd("n", AdMin, EndZe))
    If TimeValue(NeEnd) <= TimeValue(ArEnd) Then
        With TeFre
            .StaDa = TimeValue(EndZe)
            .RmuNr = RmuNr
            .Gefun = True
        End With
        Ter_FeR = True
        Exit Function
    End If

Else

    If TimeValue(WunZe) >= TimeValue(ArSta) Then
        With TeFre
            .StaDa = TimeValue(WunZe)
            .RmuNr = RmuNr
            .Gefun = True
        End With
        Ter_FeR = True
    Else
        With TeFre
            .StaDa = TimeValue(ArSta)
            .RmuNr = RmuNr
            .Gefun = True
        End With
        Ter_FeR = True
    End If

End If
RS35.Close
Set RS35 = Nothing

Exit Function

LoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_FeR " & Err.Number
Resume Next

End Function
