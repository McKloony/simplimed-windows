Set ZyMe3 = FM.cmbMona3
Set ZyJa1 = FM.cmoJahr1
Set ZyJa2 = FM.cmoJahr2
Set ZyJa3 = FM.cmoJahr3
Set ZyJa4 = FM.cmoJahr4
Set ZyJe1 = FM.cmbJahr1
Set ChMon = FM.choTaMon
Set ChDin = FM.choTaDin
Set ChMit = FM.choTaMit
Set ChDon = FM.choTaDon
Set ChFre = FM.choTaFre
Set ChSam = FM.choTaSam
Set ChSon = FM.choTaSon
Set ChDop = FM.chkDopTe

StaZe = TimeValue(TxZeV.Text)
EndZe = TimeValue(TxZeB.Text)
AdMin = DateDiff("n", TimeValue(StaZe), TimeValue(EndZe))

If ChDop.Value = xtpChecked Then
    ZwTer = True
End If
If ZweZe.Text <> vbNullString Then
    ZwZei = TimeValue(ZweZe.Text)
Else
    ZwZei = TimeValue(StaZe)
End If
ZwEnd = DateAdd("n", AdMin, ZwZei)
AnwDa = CDate(TxDa3.Text)
EndDa = CDate(TxDa4.Text)
StaDa = CDate(TxDa5.Text)
AnzTe = ZyEnT.ItemData(ZyEnT.ListIndex)

If ZwTer = True Then 'zwei Termine pro Tag berechnen
    AnzTe = AnzTe * 2
End If

If ZyEn2.Value = True Then
    DaEnd = False
    ReDim VoDat(AnzTe)
    ReDim VoZei(AnzTe)
    ReDim VoFar(AnzTe)
    ReDim VoRau(AnzTe)
Else
    If ZwTer = True Then 'zwei Termine pro Tag berechnen
        AktTe = 2
    Else
        AktTe = 1
    End If
    DaEnd = True
    ReDim Preserve VoDat(AktTe)
    ReDim Preserve VoZei(AktTe)
    ReDim Preserve VoFar(AktTe)
    ReDim Preserve VoRau(AktTe)
End If

If MoZy1.Value = True Then
    DifMo = ZyMe2.ItemData(ZyMe2.ListIndex)
    StaTa = ZyMe1.ItemData(ZyMe1.ListIndex)
    StaDa = Ter_Mon(StaDa, StaTa)
    If KeiBe = False Then 'keine belegten Termine berücksichtigen
        TeVor = Ter_Pru(StaDa, StaZe, EndZe, RmuNr, Behin, BehNr)
    Else
        TeVor = False
    End If
    VoDat(1) = StaDa
    If TeVor = True Then
        If GlSpP = True Then 'Überprüfung der Sprechzeiten
            Ter_FrS StaDa, StaZe, AdMin, RmuNr, , , Behin, BehNr
        Else
            Ter_Fre StaDa, StaZe, AdMin, RmuNr, , , Behin, BehNr
        End If
        If TeFre.Gefun = True Then
            VoZei(1) = TeFre.StaDa
            VoRau(1) = TeFre.RmuNr
            VoFar(1) = FaAng
        Else
            VoZei(1) = StaZe
            VoRau(1) = RmuNr
            VoFar(1) = FaNeg
        End If
    Else
        VoZei(1) = StaZe
        VoRau(1) = RmuNr
        VoFar(1) = vbWhite
    End If
    If DaEnd = True Then
        Do
        AktTe = AktTe + 1
        StaDa = DateAdd("m", DifMo, StaDa)
        StaDa = Ter_Mon(StaDa, StaTa)
        If StaDa >= EndDa Then Exit Do
        ReDim Preserve VoDat(AktTe)
        ReDim Preserve VoZei(AktTe)
        ReDim Preserve VoRau(AktTe)
        ReDim Preserve VoFar(AktTe)
        VoDat(AktTe) = StaDa
        If KeiBe = False Then 'keine belegten Termine berücksichtigen
            TeVor = Ter_Pru(StaDa, StaZe, EndZe, RmuNr, Behin, BehNr)
        Else
            TeVor = False
        End If
        If TeVor = True Then
            If GlSpP = True Then 'Überprüfung der Sprechzeiten
                Ter_FrS StaDa, StaZe, AdMin, RmuNr, , , Behin, BehNr
            Else
                Ter_Fre StaDa, StaZe, AdMin, RmuNr, , , Behin, BehNr
            End If
            If TeFre.Gefun = True Then
                VoZei(AktTe) = TeFre.StaDa
                VoRau(AktTe) = TeFre.RmuNr
                VoFar(AktTe) = FaAng
            Else
                VoZei(AktTe) = StaZe
                VoRau(AktTe) = RmuNr
                VoFar(AktTe) = FaNeg
            End If
        Else
            VoZei(AktTe) = StaZe
            VoRau(AktTe) = RmuNr
            VoFar(AktTe) = vbWhite
        End If
        Loop Until StaDa >= EndDa
    Else
        For AktTe = 2 To AnzTe
            StaDa = DateAdd("m", DifMo, StaDa)
            StaDa = Ter_Mon(StaDa, StaTa)
            VoDat(AktTe) = StaDa
            If KeiBe = False Then 'keine belegten Termine berücksichtigen
                TeVor = Ter_Pru(StaDa, StaZe, EndZe, RmuNr, Behin, BehNr)
            Else
                TeVor = False
            End If
            If TeVor = True Then
                If GlSpP = True Then 'Überprüfung der Sprechzeiten
                    Ter_FrS StaDa, StaZe, AdMin, RmuNr, , , Behin, BehNr
                Else
                    Ter_Fre StaDa, StaZe, AdMin, RmuNr, , , Behin, BehNr
                End If
                If TeFre.Gefun = True Then
                    VoZei(AktTe) = TeFre.StaDa
                    VoRau(AktTe) = TeFre.RmuNr
                    VoFar(AktTe) = FaAng
                Else
                    VoZei(AktTe) = StaZe
                    VoRau(AktTe) = RmuNr
                    VoFar(AktTe) = FaNeg
                End If
            Else
                VoZei(AktTe) = StaZe
                VoRau(AktTe) = RmuNr
                VoFar(AktTe) = vbWhite
            End If
