Dim KAnre As String
Dim KTite As String
Dim KName As String
Dim KVorn As String
Dim KStra As String
Dim KPost As String
Dim KOrte As String
Dim KLand As String
Dim KBrif As String
Dim KTel5 As String
Dim TmGui As String

Set RS39 = New ADODB.Recordset
RS39.CursorLocation = adUseClient
Set RS39 = DBCmRe1("qryAdrIdx", "@IdxNr", PatNr)
    If RS39.RecordCount > 0 Then
        If RS39.Fields("IDKurz").Value <> vbNullString Then
            KIDKu = RS39.Fields("IDKurz").Value
        End If
        If RS39.Fields("Firma1").Value <> vbNullString Then
            KFirm = RS39.Fields("Firma1").Value
        End If
        
        If RS39.Fields("Anrede").Value <> vbNullString Then
            KAnre = RS39.Fields("Anrede").Value
        End If
        If RS39.Fields("Titel").Value <> vbNullString Then
            KTite = RS39.Fields("Titel").Value
        End If
        If RS39.Fields("Name").Value <> vbNullString Then
            KName = RS39.Fields("Name").Value
        End If
        If RS39.Fields("Vorname").Value <> vbNullString Then
            KVorn = RS39.Fields("Vorname").Value
        End If
        If RS39.Fields("Straße").Value <> vbNullString Then
            KStra = RS39.Fields("Straße").Value
        End If
        If RS39.Fields("PLZ").Value <> vbNullString Then
            KPost = RS39.Fields("PLZ").Value
        End If
        If RS39.Fields("Ort").Value <> vbNullString Then
            KOrte = RS39.Fields("Ort").Value
        End If
        If RS39.Fields("Land").Value <> vbNullString Then
            KLand = RS39.Fields("Land").Value
        End If
        If RS39.Fields("Geboren").Value <> vbNullString Then
            KGebo = RS39.Fields("Geboren").Value
        End If
        If RS39.Fields("Briefanrede").Value <> vbNullString Then
            KBrif = RS39.Fields("Briefanrede").Value
        End If
        If EmAdr = vbNullString Then
            If RS39.Fields("Telefon5").Value <> vbNullString Then
                KTel5 = RS39.Fields("Telefon5").Value
            Else
                KTel5 = vbNullString
            End If
        Else
            KTel5 = EmAdr
        End If
        ManNr = RS39.Fields("IDP").Value

        TmGui = CreateID("A")
        Set RS40 = New ADODB.Recordset
        With RS40
            .CursorLocation = adUseClient
            .Source = "qryMailAdAdd"
            .ActiveConnection = DB1
            .CursorType = adOpenKeyset
            .LockType = adLockOptimistic
            .Open Options:=adCmdTableDirect
        End With
        If RS40.Supports(adAddNew) Then
            RS40.AddNew
            RS40.Fields("ID0").Value = PatNr
            RS40.Fields("Firma1").Value = KFirm
            RS40.Fields("Anrede").Value = KAnre
            RS40.Fields("Titel").Value = KTite
            RS40.Fields("Vorname").Value = KVorn
            RS40.Fields("Name").Value = KName
            RS40.Fields("Straße").Value = KStra
            RS40.Fields("PLZ").Value = KPost
            RS40.Fields("Ort").Value = KOrte
            RS40.Fields("Land").Value = KLand
            RS40.Fields("Briefanrede").Value = KBrif
            RS40.Fields("IDKurz").Value = KIDKu
            RS40.Fields("Telefon5").Value = KTel5
            RS40.Fields("Kommentar").Value = EmBet
            If KGebo <> vbNullString Then
                If IsDate(KGebo) = True Then
                    RS40.Fields("Geboren").Value = CDate(KGebo)
                End If
            End If
            RS40.Fields("Datum").Value = Date
            RS40.Fields("Geändert").Value = Date
            RS40.Fields("GuiID").Value = TmGui
            RS40.Update
            Adr_ZuMa = True
            GlAzN = False 'Neue Zugeordnete anlegen
        End If
        RS40.Close
        Set RS40 = Nothing
    End If
RS39.Close
Set RS39 = Nothing

If GlAId = -1 Then
    GlNeK = GlKoX 'Protokolleintrag
    With GlNeK
        .PatNr = ManNr
        .IdxNr = 0
        .EiDat = Format$(Date, "dd.mm.yyyy")
        .EiZei = TimeValue(Now)
        .EiTyp = 104
        .TeStr = "Zugehöriger hinzugefügt - " & KIDKu
        .ZiStr = Format$(Now, "hh:mm") & " Uhr"
        .NeuEi = True
        .KeiAk = True
        .Mitar = GlMiA(GlSmI, 2)
    End With
    S_Prot
End If

Exit Function

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Adr_ZuMa " & Err.Number
Resume Next
    
End Function
Public Function Adr_ZuSa(Optional ByVal ZuNeu As Boolean = False) As Boolean
On Error GoTo DaErr
'Speichert den Inhalt des Adressformulars bei Neuanlage einer Adresse

Dim GebDa As Date
Dim ManNr As Long
Dim IdxNr As Long
Dim SQL1 As String
Dim TmGui As String
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpCo5 As XtremeReportControl.ReportControl

Set FM = frmAdress
Set FeKur = FM.txtS4F19
Set TxGeb = FM.txtS4F18
Set CmMan = FM.cmbS2F10
Set RpCo5 = FM.repCont5
Set RpCls = RpCo5.Columns
Set RpSel = RpCo5.SelectedRows

ManNr = CmMan.ItemData(CmMan.ListIndex)

If FeKur.Text <> vbNullString Then
    If ZuNeu = True Then
        Set RS40 = New ADODB.Recordset
        With RS40
            .CursorLocation = adUseClient
            .Source = "qryMailAdAdd"
            .ActiveConnection = DB1
            .CursorType = adOpenKeyset
            .LockType = adLockOptimistic
            .Open Options:=adCmdTableDirect
        End With
        If RS40.Supports(adAddNew) Then
            RS40.AddNew
            RS40.Fields("ID0").Value = GlAId
            RS40.Fields("Firma1").Value = FM.txtS4F01.Text
            RS40.Fields("Anrede").Value = FM.txtS4F02.Text
            RS40.Fields("Titel").Value = FM.txtS4F03.Text
            RS40.Fields("Vorname").Value = FM.txtS4F04.Text
            RS40.Fields("Name").Value = FM.txtS4F05.Text
            RS40.Fields("Straße").Value = FM.txtS4F06.Text
            RS40.Fields("PLZ").Value = FM.txtS4F08.Text
            RS40.Fields("Ort").Value = FM.txtS4F09.Text
            RS40.Fields("Land").Value = FM.cmbS4F12.Text
            RS40.Fields("Briefanrede").Value = FM.cmbS4F11.Text
            RS40.Fields("IDKurz").Value = FM.txtS4F19.Text
            RS40.Fields("Telefon1").Value = FM.txtS4F15.Text
            RS40.Fields("Telefon5").Value = FM.txtS4F16.Text
            RS40.Fields("Kommentar").Value = FM.txtS4F17.Text
            If FM.txtS4F18.Text <> vbNullString Then
                If IsDate(FM.txtS4F18.Text) = True Then
                    GebDa = CDate(FM.txtS4F18.Text)
                    RS40.Fields("Geboren").Value = GebDa
                End If
            End If
            RS40.Fields("Datum").Value = Date
            RS40.Fields("Geändert").Value = Date
            RS40.Fields("GuiID").Value = GlAzG
            RS40.Update
            GlAzN = False 'Neue Zugeordnete anlegen
        End If
        RS40.Close
        Set RS40 = Nothing
    Else
        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            Set RpCol = RpCls.Find(Adr_ID0)
            IdxNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Adr_GuiID)
            TmGui = RpRow.Record(RpCol.ItemIndex).Value

            If GlTyp < 2 Then
                SQL1 = "SELECT * FROM dbo.qryMailAdress WHERE IDA = " & IdxNr
            Else
                SQL1 = "SELECT * FROM qryMailAdress WHERE [IDA]=" & IdxNr & ";"
            End If

            Set RS40 = New ADODB.Recordset
            With RS40
                .CursorLocation = adUseClient
                .Source = SQL1
                .ActiveConnection = DB1
                .CursorType = adOpenKeyset
                .LockType = adLockOptimistic
                .Open Options:=adCmdText
            End With
            If RS40.RecordCount > 0 Then
                If RS40.Supports(adUpdate) Then
                    RS40.Fields("ID0").Value = GlAId
                    RS40.Fields("Firma1").Value = FM.txtS4F01.Text
                    RS40.Fields("Anrede").Value = FM.txtS4F02.Text
                    RS40.Fields("Titel").Value = FM.txtS4F03.Text
                    RS40.Fields("Vorname").Value = FM.txtS4F04.Text
                    RS40.Fields("Name").Value = FM.txtS4F05.Text
                    RS40.Fields("Straße").Value = FM.txtS4F06.Text
                    RS40.Fields("PLZ").Value = FM.txtS4F08.Text
                    RS40.Fields("Ort").Value = FM.txtS4F09.Text
                    RS40.Fields("Land").Value = FM.cmbS4F12.Text
                    RS40.Fields("Briefanrede").Value = FM.cmbS4F11.Text
                    RS40.Fields("IDKurz").Value = FM.txtS4F19.Text
                    RS40.Fields("Telefon1").Value = FM.txtS4F15.Text
                    RS40.Fields("Telefon5").Value = FM.txtS4F16.Text
                    RS40.Fields("Kommentar").Value = FM.txtS4F17.Text
                    If FM.txtS4F18.Text <> vbNullString Then
                        If IsDate(FM.txtS4F18.Text) = True Then
                            GebDa = CDate(FM.txtS4F18.Text)
                            RS40.Fields("Geboren").Value = GebDa
                        End If
                    End If
                    RS40.Fields("Geändert").Value = Date
                    RS40.Update
                End If
            End If
        End If
    End If
End If

If GlJet = True Then SDBSav

If GlAId = -1 Then
    GlNeK = GlKoX 'Protokolleintrag
    With GlNeK
        .PatNr = ManNr
        .IdxNr = 0
        .EiDat = Format$(Date, "dd.mm.yyyy")
        .EiZei = TimeValue(Now)
        .EiTyp = 104
        If ZuNeu = True Then
            .TeStr = "Zugehöriger hinzugefügt - " & FeKur.Text
        Else
            .TeStr = "Zugehöriger geändert - " & FeKur.Text
        End If
        .ZiStr = Format$(Now, "hh:mm") & " Uhr"
        .NeuEi = True
        .KeiAk = True
        .Mitar = GlMiA(GlSmI, 2)
    End With
    S_Prot
End If

Adr_ZuSa = True

Exit Function

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Adr_ZuSa " & Err.Number
Resume Next
    
End Function
