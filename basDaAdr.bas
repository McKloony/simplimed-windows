Public Function Ter_AdI() As Long
On Error GoTo DaErr
'Importiert die Adresse aus der Termineingabemaske in die Adresendatenbank

Dim PatNr As Long
Dim AdPIN As Long
Dim KIDKu As String
Dim TmGui As String
Dim KGebo As String
Dim KFirm As String
Dim KAnre As String
Dim KTite As String
Dim KName As String
Dim KVorn As String
Dim KStra As String
Dim KPost As String
Dim KOrte As String
Dim KLand As String
Dim KBrif As String
Dim KTel1 As String
Dim KTel5 As String
Dim RAnsh As String
Dim TagWe As String
Dim DoSav As Boolean
Dim Gesch As Integer
Dim Frage As Integer
Dim Mld1, Mld2, Tit1 As String

Set FM = frmTermin
Set TxPIN = FM.txtS4F20

KFirm = FM.txtS4F01.Text
KAnre = FM.txtS4F02.Text
KTite = FM.txtS4F03.Text
KVorn = FM.txtS4F04.Text
KName = FM.txtS4F05.Text
KStra = FM.txtS4F06.Text
KPost = FM.txtS4F08.Text
KOrte = FM.txtS4F09.Text
KLand = FM.cmbS4F12.Text
KGebo = FM.txtS4F18.Text
KBrif = FM.cmbS4F11.Text
KTel1 = FM.txtS4F15.Text
KTel5 = FM.txtS4F16.Text

Tit1 = "Adresse Importieren"
Mld1 = "Soll diese Adresse importiert werden?"
Mld2 = "Diese Adresse existiert bereits. Soll diese trotzdem importiert werden?"

Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
If Frage = 6 Then
    Screen.MousePointer = vbHourglass
    DoEvents

    TmGui = CreateID("A")
    KIDKu = AErZu(2) 'Kurzbezeichnung erstellen
    DoEvents
    TerAd 'Generiert die Anschrift
    DoEvents
    RAnsh = FM.txtS3F01.Text

    If KAnre = "Herrn" Then
        Gesch = 2
    ElseIf KAnre = "Frau" Then
        Gesch = 3
    Else
        Gesch = 1
    End If
    
    If Adr_Dop(KIDKu) = True Then 'Adresse bereits vorhanden?
        Frage = WindowMess(Mld2, Dial1, Tit1, FM.hwnd)
        If Frage = 6 Then
            DoSav = True
        End If
    Else
        DoSav = True
    End If

    If DoSav = True Then
        If TxPIN.Text = vbNullString Then
            AdPIN = Adr_Let()
            TxPIN.Text = Format$(AdPIN, "000000")
            DoEvents
        ElseIf IsNumeric(TxPIN.Text) = False Then
            AdPIN = Adr_Let()
            TxPIN.Text = Format$(AdPIN, "000000")
            DoEvents
        ElseIf CLng(TxPIN.Text) = 0 Then
            AdPIN = Adr_Let()
            TxPIN.Text = Format$(AdPIN, "000000")
            DoEvents
        Else
            AdPIN = TxPIN.Text
        End If

        Set RS40 = New ADODB.Recordset
        With RS40
            .CursorLocation = adUseClient
            .Source = "qryAdrNeu"
            .ActiveConnection = DB1
            .CursorType = adOpenKeyset
            .LockType = adLockOptimistic
            .Open Options:=adCmdTableDirect
        End With
        If RS40.Supports(adAddNew) Then
            RS40.AddNew
            RS40.Fields("Firma1").Value = KFirm
            RS40.Fields("Anrede").Value = KAnre
            RS40.Fields("Titel").Value = KTite
            RS40.Fields("Vorname").Value = KVorn
            RS40.Fields("Name").Value = KName
            RS40.Fields("Straße").Value = KStra
            RS40.Fields("PLZ").Value = KPost
            RS40.Fields("Ort").Value = KOrte
            RS40.Fields("Land").Value = KLand
            RS40.Fields("Briefanrede").Value = KBrif
            RS40.Fields("IDKurz").Value = KIDKu
            RS40.Fields("Telefon1").Value = KTel1
            RS40.Fields("Telefon5").Value = KTel5
            'RS40.Fields("Kommentar").Value = EmBet
            If KGebo <> vbNullString Then
                If IsDate(KGebo) = True Then
                    RS40.Fields("Geboren").Value = CDate(KGebo)
                    RS40.Fields("R_Geboren").Value = CDate(KGebo)
                End If
            End If
            RS40.Fields("R_Firma1").Value = KFirm
            RS40.Fields("R_Anrede").Value = KAnre
            RS40.Fields("R_Titel").Value = KTite
            RS40.Fields("R_Vorname").Value = KVorn
            RS40.Fields("R_Name").Value = KName
            RS40.Fields("R_Straße").Value = KStra
            RS40.Fields("R_PLZ").Value = KPost
            RS40.Fields("R_Ort").Value = KOrte
            RS40.Fields("R_Land").Value = KLand
            RS40.Fields("R_Briefanrede").Value = KBrif
            RS40.Fields("Datum").Value = Date
            RS40.Fields("Geändert").Value = Date
            RS40.Fields("GuiID").Value = TmGui
            RS40.Fields("Kopien").Value = GlKop
            RS40.Fields("Anschrift").Value = RAnsh
            RS40.Fields("ID3").Value = GlGKa(GlStK, 0) 'Standardgebührenkatalog
            RS40.Fields("IDZ").Value = GlZah(GlStZ, 0) 'Standardzahlungsziel
            RS40.Fields("IDP").Value = GlMan(GlSMa, 2)
            RS40.Fields("Mandant").Value = Format$(AdPIN, "000000")
            RS40.Fields("GeschlTyp").Value = Gesch
            RS40.Fields("Versicherung").Value = "Adresse des Leistungsträgers"
            If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                RS40.Fields("Replicated").Value = 1
                RS40.Fields("DAVChange").Value = 1
                RS40.Fields("LastModification").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                RS40.Fields("DAVDate").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
            Else
                RS40.Fields("Replicated").Value = 0
                RS40.Fields("DAVChange").Value = 0
            End If
            RS40.Update
        End If
        RS40.Close
        Set RS40 = Nothing
        
        DoEvents
        PatNr = S_AdGui(TmGui, "ID0")
        DoEvents
        DBCmEx2 "qryTerAdGu", "@IdPat", "@IdGui", PatNr, TmGui
        DoEvents

        If GlAId = -1 Then
            GlNeK = GlKoX 'Protokolleintrag
            With GlNeK
                .PatNr = 0
                .IdxNr = 0
                .EiDat = Format$(Date, "dd.mm.yyyy")
                .EiZei = TimeValue(Now)
                .EiTyp = 104
                .TeStr = "Adresse hinzugefügt - " & KIDKu
                .ZiStr = Format$(Now, "hh:mm") & " Uhr"
                .NeuEi = True
                .KeiAk = True
                .Mitar = GlMiA(GlSmI, 2)
            End With
            S_Prot
            SPopu "Adresse hinzugefügt", "Adresse hinzugefügt - " & KIDKu, IC48_Warning
        End If
    End If
    
    DoEvents
    Screen.MousePointer = vbNormal
End If

Ter_AdI = PatNr

Exit Function

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_AdI " & Err.Number
Resume Next
    
End Function
