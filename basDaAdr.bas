Public Sub Adr_Er1(Optional ByVal GuiSt As String, Optional ByVal PatNr As Long = 0, Optional ByVal Wartu As Boolean = False)
On Error GoTo ReErr
'Erstellung der Adressen und Briefanreden

Dim SQL1 As String
Dim AktZa As Long
Dim GesZa As Long
Dim TxDum As VB.TextBox

Set FM = frmStatus

If GuiSt <> vbNullString Then
    If GlTyp < 2 Then
        SQL1 = "SELECT * FROM dbo.qryAdress WHERE GuiID Like '" & GuiSt & "'"
    Else
        SQL1 = "SELECT * FROM qryAdress WHERE [GuiID] Like '" & GuiSt & "';"
    End If
ElseIf PatNr > 0 Then
    If GlTyp < 2 Then
        SQL1 = "SELECT * FROM dbo.qryAdress WHERE ID0 = " & PatNr
    Else
        SQL1 = "SELECT * FROM qryAdress WHERE [ID0] = " & PatNr & ";"
    End If
Else
    If GlTyp < 2 Then
        SQL1 = "SELECT * FROM dbo.qryAdress ORDER BY ID0"
    Else
        SQL1 = "SELECT * FROM qryAdress ORDER BY [ID0];"
    End If
End If

Set RS46 = New ADODB.Recordset
With RS46
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenKeyset
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With

GesZa = RS46.RecordCount

If GesZa > 0 Then
    If GuiSt <> vbNullString Then
        Adr_Er2 RS46
    Else
        If Wartu = False Then
            Load FM
            FM.Show
            DoEvents
        End If
        Set Lbl01 = FM.lblLab01
        Set PrBr1 = FM.prbStat1
        Set PrBr2 = FM.prbStat2
        Set TxDum = FM.txtDummy
        DoEvents
        RS46.MoveFirst
        DoEvents
        PrBr2.Min = 0
        PrBr2.Max = GesZa
        Lbl01.Caption = "Anschriftenprüfung..."
        DoEvents
        
        Do
        Adr_Er2 RS46
        DoEvents
        If TxDum.Text = "B" Then Exit Do 'Abbrechen
        PrBr2.Value = AktZa
        AktZa = AktZa + 1
        RS46.MoveNext
        Loop Until RS46.EOF
        If Wartu = False Then
            Unload FM
        End If
    End If
End If

RS46.Close
Set RS46 = Nothing

Set FM = Nothing

Exit Sub

ReErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Adr_Er1 " & Err.Number
Resume Next

End Sub
