    ElseIf TimeValue(NeEnd) <= TimeValue(StaZe) Then
        If ZwZei <> vbNullString Then
            If TeVoBe(StaDa, NeSta, NeEnd, ManNr) = False Then 'Sprechzeitenprüfung
                If TimeValue(NeEnd) > TimeValue(ArSta) Then
                    With TeFre
                        .StaDa = TimeValue(EndZe)
                        .RmuNr = RmuNr
                        .Gefun = True
                    End With
                    Ter_FrR = True
                    Exit Function
                End If
            End If
        ElseIf ZwEnd <> vbNullString Then
            If TeVoBe(StaDa, NeSta, NeEnd, ManNr) = False Then 'Sprechzeitenprüfung
                If TimeValue(NeEnd) <= TimeValue(ArEnd) Then
                    With TeFre
                        .StaDa = TimeValue(EndZe)
                        .RmuNr = RmuNr
                        .Gefun = True
                    End With
                    Ter_FrR = True
                    Exit Function
                End If
            End If
        Else
            If TeVoBe(StaDa, NeSta, NeEnd, ManNr) = False Then 'Sprechzeitenprüfung
                With TeFre
                    .StaDa = TimeValue(EndZe)
                    .RmuNr = RmuNr
                    .Gefun = True
                End With
                Ter_FrR = True
                Exit Function
            End If
        End If
    End If
    EndZe = TimeValue(RS35.Fields("ZeiBis").Value)
    
    RS35.MoveNext
    Loop Until RS35.EOF

    NeEnd = TimeValue(DateAdd("n", AdMin, EndZe))
    
    If TeVoBe(StaDa, NeSta, NeEnd, ManNr) = False Then 'Sprechzeitenprüfung
        If TimeValue(NeEnd) <= TimeValue(ArEnd) Then
            With TeFre
                .StaDa = TimeValue(EndZe)
                .RmuNr = RmuNr
                .Gefun = True
            End With
            Ter_FrR = True
            Exit Function
        End If
    End If

Else
    NeEnd = TimeValue(DateAdd("n", AdMin, WunZe))
    
    If TeVoBe(StaDa, WunZe, NeEnd, ManNr) = False Then 'Sprechzeitenprüfung
        If TimeValue(WunZe) >= TimeValue(ArSta) Then
            With TeFre
                .StaDa = TimeValue(WunZe)
                .RmuNr = RmuNr
                .Gefun = True
            End With
            Ter_FrR = True
        Else
            With TeFre
                .StaDa = TimeValue(ArSta)
                .RmuNr = RmuNr
                .Gefun = True
            End With
            Ter_FrR = True
        End If
    End If

End If
RS35.Close
Set RS35 = Nothing

Exit Function

LoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_FrR " & Err.Number
Resume Next

End Function
Private Sub Ter_FrS(ByVal StaDa As Date, ByVal WunZe As Date, ByVal AdMin As Integer, Optional ByVal RmuNr As Long, Optional ByVal ZwZei As String, Optional ByVal ZwEnd As String, Optional ByVal Behin As Integer, Optional ByVal ManNr As Long)
On Error GoTo LoErr
