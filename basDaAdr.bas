                        Else
                            Set RpItm = RpRec.AddItem(vbNullString)
                        End If
                    End If
                    RS31.MoveNext
                    Loop Until RS31.EOF
                    RpCon.Populate
                Else
                    If RS31.Fields("HOrt").Value <> vbNullString Then FeOrt.Text = RS31.Fields("HOrt").Value
                    If GlInt = True Then
                        If RS31.Fields("PTel").Value <> vbNullString Then If Len(FeTe1.Text) < 9 Then FeTe1.Text = "+49 (" & RS31.Fields("PTel").Value & ") "
                        If RS31.Fields("PTel").Value <> vbNullString Then If Len(FeTe2.Text) < 9 Then FeTe2.Text = "+49 (" & RS31.Fields("PTel").Value & ") "
                        If RS31.Fields("PTel").Value <> vbNullString Then If Len(FeTe3.Text) < 9 Then FeTe3.Text = "+49 (" & RS31.Fields("PTel").Value & ") "
