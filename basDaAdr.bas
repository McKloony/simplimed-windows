Public Sub GrMa_Lad(Optional ByVal ReLoa As Boolean = False)
On Error GoTo PeErr
'Lädt die Gruppen in das TreeView

Dim SQL1 As String
Dim DatKy As String
Dim VorKy As String
Dim KnoKy As String
Dim TmpKy As String
Dim AkPos As Integer
Dim AltPo As Integer
Dim AktZa As Integer
Dim LauZa As Integer
Dim GrGef As Boolean

Set FM = frmMain
Set TrLi3 = FM.trvList3

TmpKy = GlMaK

If ReLoa = True Then
    With TrLi3
        .Nodes.Clear
        Set Knote = .Nodes.Add(, xtpTreeViewFirst, "P800", "Emailgruppen", IC16_Mailbox)
        Knote.Bold = True
        Set Knote = .Nodes.Add("P800", 4, "P801", "Emailhauptordner", IC16_Folder_View)
        Set Knote = .Nodes.Add("P800", 4, "P802", "Mitarbeiter", IC16_Folder_Edit)
        Set Knote = .Nodes.Add("P800", 4, "P803", "Rechnungen", IC16_Folder_Check)
        Set Knote = .Nodes.Add("P800", 4, "P804", "Telefaxe", IC16_Folder_Paper)
        .Nodes("P800").Expanded = True
    End With
    DoEvents
End If

AktZa = TrLi3.Nodes.Count + 1

For LauZa = 1 To UBound(GlEmG) 'Emailgruppen
    If GlEmG(LauZa, 2) <> vbNullString Then
        DatKy = GlEmG(LauZa, 2)
    Else
        DatKy = 0
    End If
    KnoKy = "G" & GlEmG(LauZa, 0)
    AkPos = InStrRev(DatKy, ".", Len(DatKy), 1)
    If AkPos > 0 Then
        If AkPos > AltPo Then
            VorKy = TrLi3.Nodes(AktZa - 1).Key
        ElseIf AkPos < AltPo Then
            VorKy = TrLi3.Nodes(AktZa - 1).Parent.Parent.Key
        End If
    Else
        VorKy = "P801"
    End If
    If GlEmG(LauZa, 1) <> vbNullString Then
        Set Knote = TrLi3.Nodes.Add(VorKy, 4, KnoKy, GlEmG(LauZa, 1), IC16_Folder_Close)
    Else
        Set Knote = TrLi3.Nodes.Add(VorKy, 4, KnoKy, "-", IC16_Folder_Close)
    End If
    If Knote.Key = TmpKy Then
        Knote.Selected = True
        GrGef = True
    End If
    If GrGef = False Then TrLi3.Nodes("P801").Selected = True
    AltPo = AkPos
    AktZa = AktZa + 1
Next LauZa

For AktZa = 1 To UBound(GlMiK) 'Mitarbeiter
    Set Knote = TrLi3.Nodes.Add("P802", 4, "G" & Format$(AktZa + 900, "000"), GlMiK(AktZa, 1), IC16_Folder_Close)
Next AktZa

With TrLi3
    .Nodes("P800").Expanded = True
    .Nodes("P801").Expanded = True
    .Nodes("P802").Expanded = GlMOr
End With

If GlExp = True Then
    For Each Knote In TrLi3.Nodes
        If Left$(Knote.Key, 1) = "G" Then
            Knote.Expanded = True
        End If
    Next Knote
End If

Exit Sub

PeErr:
If GlDbg = True Then SErLog Err.Description & " GrMa_Lad " & Err.Number
Resume Next

End Sub
