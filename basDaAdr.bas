Private Function Adr_Rec(ByRef RST As ADODB.Recordset, ByVal LiTyp As Integer) As Long
On Error GoTo LiErr
'fügt der Rechnungstabelle die Datensätze an

Dim KtoNr As Long
Dim ManNr As Long
Dim KtoSt As String
Dim GegKt As String
Dim GegSt As String
Dim BuStr As String
Dim ReStu As Single
Dim BetEi As Double
Dim BetAu As Double
Dim BetBu As Double
Dim AktZa As Integer
Dim GeKto As Integer
Dim Lange As Integer
Dim ReSto As Boolean
Dim RpCo2 As XtremeReportControl.ReportControl
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCo5 As XtremeReportControl.ReportControl

Set FM = frmAdress
Set RpCo2 = FM.repCont2
Set RpCo3 = FM.repCont3
Set RpCo4 = FM.repCont4
Set RpCo5 = FM.repCont5

Select Case LiTyp
Case 2:
    Set RpRcs = RpCo2.Records
    Do
    If RST.Fields("Storniert").Value <> vbNullString Then
        ReSto = CBool(RST.Fields("Storniert").Value)
    Else
        ReSto = False
    End If
    If RST.Fields("Konto").Value <> vbNullString Then
        KtoNr = RST.Fields("Konto").Value
    Else
        KtoNr = 0
    End If
    If RST.Fields("IDB").Value <> vbNullString Then
        GeKto = RST.Fields("IDB").Value
    Else
        GeKto = 0
    End If
    If RST.Fields("IDT").Value <> vbNullString Then
        ManNr = CLng(RST.Fields("IDT").Value)
    Else
        ManNr = GlMan(GlSMa, 2)
    End If
    If RST.Fields("Steuer").Value <> vbNullString Then
        ReStu = CSng(RST.Fields("Steuer").Value)
    Else
        ReStu = 0
    End If
    If ReStu > 0 And ReStu < 1 Then
        ReStu = ReStu * 100
    End If
    For AktZa = 1 To UBound(GlGeK)
        If GlGeK(AktZa, 0) = GeKto Then
            GegSt = GlGeK(AktZa, 1)
            GegKt = GlGeK(AktZa, 2)
            Exit For
        End If
    Next AktZa
    KtoSt = SBuFo(KtoNr) 'Sachkontenformatierung
    If GlBuc = True Then 'einfache Buchhaltung verwenden
        If RST.Fields("Einnahme").Value <> vbNullString Then
            If RST.Fields("Einnahme").Value > 0 Then
                BetEi = CDbl(RST.Fields("Einnahme").Value)
                BetAu = 0
            Else
                If RST.Fields("Ausgabe").Value <> vbNullString Then
                    If RST.Fields("Ausgabe").Value > 0 Then
                        BetEi = 0
                        BetAu = CDbl(RST.Fields("Ausgabe").Value)
                    Else
                        BetEi = 0
                        BetAu = 0
                    End If
                Else
                    BetEi = 0
                    BetAu = 0
                End If
            End If
        ElseIf RST.Fields("Ausgabe").Value <> vbNullString Then
            If RST.Fields("Ausgabe").Value > 0 Then
                BetEi = 0
                BetAu = CDbl(RST.Fields("Ausgabe").Value)
            Else
                BetEi = 0
                BetAu = 0
            End If
        Else
            BetEi = 0
            BetAu = 0
        End If
    Else
        If RST.Fields("Einnahme").Value <> vbNullString Then
            If RST.Fields("Einnahme").Value > 0 Then
                BetBu = CDbl(RST.Fields("Einnahme").Value)
            Else
                If RST.Fields("Ausgabe").Value <> vbNullString Then
                    If RST.Fields("Ausgabe").Value > 0 Then
                        BetBu = CDbl(RST.Fields("Ausgabe").Value)
                    Else
                        BetBu = 0
                    End If
                Else
                    BetBu = 0
                End If
            End If
        ElseIf RST.Fields("Ausgabe").Value <> vbNullString Then
            If RST.Fields("Ausgabe").Value > 0 Then
                BetBu = CDbl(RST.Fields("Ausgabe").Value)
            Else
                BetBu = 0
            End If
        Else
            BetBu = 0
        End If
    End If
        
    Set RpRec = RpRcs.Add()
    Set RpItm = RpRec.AddItem(RST.Fields("ID0").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Datum").Value)
    If RST.Fields("IDB").Value = 2 Then
        RpItm.Icon = IC16_Doc_Line
    Else
        RpItm.Icon = IC16_Doc_Norm
