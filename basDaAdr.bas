'Überprüfen ob Wunschtermin belegt ist

Dim DatSt As Date
Dim DatEn As Date
Dim AktZa As Integer
Dim RmuId As Integer

DatSt = StaDa & " 00:00:00" 'Kompatibilität zu SQL Server
DatEn = StaDa & " 23:59:00"

For AktZa = 1 To UBound(GlRmu)
    If GlRmu(AktZa, 2) = RmuNr Then
        RmuId = GlRmu(AktZa, 3)
        Exit For
    End If
Next AktZa

If Behin > 0 Then
    If RmuId > 0 Then
        If GlBeG(Behin, 0) > RmuId Then
            Ter_Pru = True
            Exit Function
        End If
    End If
End If

Set RS34 = New ADODB.Recordset
RS34.CursorLocation = adUseClient

If ManNr > 0 Then
    If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
        Set RS34 = DBCmRe3("qryTerTag05", "@IdSta", "@IdEnd", "@IdxNr", DatSt, DatEn, ManNr)
    Else
        Set RS34 = DBCmRe3("qryTerTag01", "@IdSta", "@IdEnd", "@IdxNr", DatSt, DatEn, ManNr)
    End If
ElseIf RmuNr > 0 Then
    If GlTS1 = False Then 'Sortierung Terminliste Aufsteigend
        Set RS34 = DBCmRe3("qryTerTag02", "@IdSta", "@IdEnd", "@IdxNr", DatSt, DatEn, RmuNr)
    Else
        Set RS34 = DBCmRe3("qryTerTag04", "@IdSta", "@IdEnd", "@IdxNr", DatSt, DatEn, RmuNr)
    End If
Else
    If GlTS1 = False Then 'Sortierung Terminliste Aufsteigend
        Set RS34 = DBCmRe2("qryTerTag07", "@IdSta", "@IdEnd", DatSt, DatEn)
    Else
        Set RS34 = DBCmRe2("qryTerTag08", "@IdSta", "@IdEnd", DatSt, DatEn)
    End If
End If

If RS34.RecordCount > 0 Then
    Do
    If CBool(RS34.Fields("Selekt").Value) = True Then 'Ganztagstermin
        If GlGaT = False Then 'Ganztagstermin nicht berücksichtigen
            Ter_Pru = True
        Else
            If TimeValue(StaZe) = TimeValue(RS34.Fields("ZeiVon").Value) Then
                Ter_Pru = True
            ElseIf TimeValue(StaZe) > TimeValue(RS34.Fields("ZeiVon").Value) Then
                If TimeValue(StaZe) < TimeValue(RS34.Fields("ZeiBis").Value) Then
                    Ter_Pru = True
                End If
            ElseIf TimeValue(StaZe) < TimeValue(RS34.Fields("ZeiVon").Value) Then
                If TimeValue(EndZe) > TimeValue(RS34.Fields("ZeiVon").Value) Then
                    Ter_Pru = True
                End If
            End If
        End If
    Else
        If TimeValue(StaZe) = TimeValue(RS34.Fields("ZeiVon").Value) Then
            Ter_Pru = True
        ElseIf TimeValue(StaZe) > TimeValue(RS34.Fields("ZeiVon").Value) Then
            If TimeValue(StaZe) < TimeValue(RS34.Fields("ZeiBis").Value) Then
                Ter_Pru = True
            End If
        ElseIf TimeValue(StaZe) < TimeValue(RS34.Fields("ZeiVon").Value) Then
            If TimeValue(EndZe) > TimeValue(RS34.Fields("ZeiVon").Value) Then
                Ter_Pru = True
            End If
        End If
    End If
    RS34.MoveNext
    Loop Until RS34.EOF
End If
RS34.Close
Set RS34 = Nothing

If GlSpP = True Then 'Überprüfung der Sprechzeiten
    If Ter_Pru = False Then
        Ter_Pru = TeVoBe(StaDa, StaZe, EndZe, ManNr) 'Sprechzeitenprüfung
    End If
End If

Exit Function

LoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_Pru " & Err.Number
Resume Next

End Function
