    .Open Options:=adCmdTableDirect
End With
If RS30.Supports(adAddNew) Then
    GlKoG = CreateID("W")
    RS30.AddNew
    RS30.Fields("GuiID").Value = GlKoG
    For Each AktCo In FM.Controls
        If AktCo.Tag <> vbNullString Then
            Select Case Left$(AktCo.Name, 3)
            Case "txt": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                        If Left$(AktCo.Tag, 1) = 1 Then
                            If AktCo.Text = vbNullString Then
                                RS30.Fields(TagWe).Value = Null
                            Else
                                RS30.Fields(TagWe).Value = AktCo.Text
                            End If
                            AktCo.Tag = 0 & TagWe
                        End If
            Case "cmb": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                        If Left$(AktCo.Tag, 1) = 1 Then
                            If AktCo.Text <> vbNullString Then
                                RS30.Fields(TagWe).Value = AktCo.ItemData(AktCo.ListIndex)
                            Else
                                RS30.Fields(TagWe).Value = AktCo.ItemData(0)
                            End If
                            AktCo.Tag = 0 & TagWe
                        End If
            Case "chk": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                        If Left$(AktCo.Tag, 1) = 1 Then
                            RS30.Fields(TagWe).Value = AktCo.Value
                            AktCo.Tag = 0 & TagWe
                        End If
            End Select
        End If
    Next AktCo
    RS30.Fields("VonDat").Value = Format$(NeuDa, "dd.mm.yyyy")
    RS30.Fields("BisDat").Value = Format$(NeuDa, "dd.mm.yyyy")
    If GlTyp < 2 Then
        RS30.Fields("ZeiVon").Value = Format$(NeuDa, "dd.mm.yyyy") & Chr$(32) & Format$(TxZeV.Text, "hh:mm:ss")
        RS30.Fields("ZeiBis").Value = Format$(NeuDa, "dd.mm.yyyy") & Chr$(32) & Format$(TxZeV.Text, "hh:mm:ss")
    Else
        RS30.Fields("ZeiVon").Value = Format$(TxZeV.Text, "hh:mm:ss")
        RS30.Fields("ZeiBis").Value = Format$(TxZeV.Text, "hh:mm:ss")
    End If
    RS30.Fields("Vorlage").Value = -1
    RS30.Update
End If
RS30.Close
Set RS30 = Nothing

If GlJet = True Then SDBSav
GlKoN = False

Exit Sub

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Kon_San " & Err.Number
Resume Next

End Sub
