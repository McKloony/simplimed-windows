    Set RpItm = RpRec.AddItem(0)
    
    If PaTe1 <> vbNullString Then
        Set RpRec = RpHcs.Add()
        Set RpItm = RpRec.AddItem(0)
        Set RpItm = RpRec.AddItem(PaTe1)
        RpItm.Icon = IC16_Telephone
