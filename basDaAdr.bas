Set RS40 = DBCmRe1("qryTermin", "@IdxNr", TerNr)
If RS40.RecordCount > 0 Then
    For Each AktCo In FM.Controls
        If AktCo.Tag <> vbNullString Then
            Select Case Left$(AktCo.Name, 3)
            Case "txt": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
