If GlTyp < 2 Then
    Select Case SuTyp
    Case 1: SQL1 = "SELECT * FROM dbo.qryPLZ WHERE [PLZ] Like '" & SuStr & "%'"
    Case 2: SQL1 = "SELECT * FROM dbo.qryPLZ WHERE ([POrt] Like '" & SuStr & "%') OR ([HOrt] Like '" & SuStr & "%')"
    End Select
Else
    Select Case SuTyp
