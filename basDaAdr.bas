Public Function Adr_Let() As Long
On Error GoTo SuErr
'Zeigt die zuletzt angelegte Adresse

Dim GesZa As Long

Set RS47 = New ADODB.Recordset
RS47.CursorLocation = adUseClient
Set RS47 = DBCmRe0("qryAdrLeMa")
GesZa = RS47.RecordCount

If GesZa > 0 Then
    If RS47.BOF Then
        Adr_Let = RS47.Fields("ID0").Value
    Else
        If RS47.Fields("Mandant").Value <> vbNullString Then
            If IsNumeric(RS47.Fields("Mandant").Value) = True Then
                If CLng(RS47.Fields("Mandant").Value) > 0 Then
                    Adr_Let = RS47.Fields("Mandant").Value + 1
                End If
            End If
        End If
    End If
End If

RS47.Close
Set RS47 = Nothing

If Adr_Let = 0 Then
    Set RS47 = New ADODB.Recordset
    RS47.CursorLocation = adUseClient
    Set RS47 = DBCmRe0("qrySimAdSu")
    GesZa = RS47.RecordCount
    If GesZa > 0 Then
        Adr_Let = RS47.Fields("ID0").Value
    End If
    RS47.Close
    Set RS47 = Nothing
End If

If Adr_Let = 0 Then
    Set RS47 = New ADODB.Recordset
    RS47.CursorLocation = adUseClient
    Set RS47 = DBCmRe0("qryAdrAl")
    GesZa = RS47.RecordCount
    If GesZa > 0 Then
        Adr_Let = RS47.Fields("ID0").Value
    End If
    RS47.Close
    Set RS47 = Nothing
End If

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Adr_Let " & Err.Number
Resume Next

End Function
Public Sub Adr_Loe()
On Error GoTo LoErr
'Löscht die aktuelle Adresse

Dim TheNr As Long
Dim Frage As Integer
Dim Mld1, Tit1 As String

Set FM = frmAdress
Set FeKur = FM.txtS1F11

Tit1 = "Adresse Entfernen"
Mld1 = "Möchten Sie die aktuelle Adresse jetzt wirklich entfernen?"

If GlRch(0, 19) = 0 Then
    WindowMess "Sie besitzen keine Berechtigung für diesen Vorgang", Dial3, Tit1, FM.hwnd
    Exit Sub
End If

If GlAdN = False Then
    If FeKur.Text <> vbNullString Then
        Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
        If Frage = 6 Then
            TheNr = S_AdIdi(GlAId, "IDP")
            DoEvents
            DBCmEx2 "qrySimAdPas", "@IdPas", "@IdxNr", True, GlAId
            DoEvents
            If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                DBCmEx1 "qrySimAdRe1", "@IdxNr", GlAId
                DBCmEx2 "qryAdrKo3", "@IdEdi", "@IdxNr", 1, GlAId
                DBCmEx3 "qryDAVAdCh2", "@IdSet", "@IdDat", "@IdxNr", 1, Now, GlAId
            End If
            DoEvents
            GlNeK = GlKoX 'Protokolleintrag
            With GlNeK
                .PatNr = GlAId
                .IdxNr = 0
                .EiDat = Format$(Date, "dd.mm.yyyy")
                .EiZei = TimeValue(Now)
                .EiTyp = 104
                .TeStr = "Patient gelöscht - " & FeKur.Text
                .ZiStr = Format$(Now, "hh:mm") & " Uhr"
                .NeuEi = True
                .KeiAk = True
                .Mitar = GlMiA(GlSmI, 2)
            End With
            S_Prot
            ANeue True
            Kon_Lis
            GlAdS = False
        End If
        SUpAd
                
        If GlThO = True Then 'TheDex
            With GlTDx
                If FM.txtS1F30.Text <> vbNullString Then
                    .CSenderInternalIdentification = CLng(FM.txtS1F30.Text)
                Else
                    .CSenderInternalIdentification = GlAId
                End If
                If FM.txtS1F05.Text <> vbNullString Then .CLastName = FM.txtS1F05.Text
                If FM.txtS1F04.Text <> vbNullString Then .CFirstName = FM.txtS1F04.Text
                If FM.txtS1F13.Text <> vbNullString Then .CBirthday = Format$(FM.txtS1F13.Text, "ddmmyyyy")
                If FM.cmbS1F08.Text <> vbNullString Then
                    Select Case LCase(Left$(FM.cmbS1F08.Text, 1))
                    Case "m": .CSex = "M"
                    Case "w": .CSex = "W"
                    Case "k": .CSex = vbNullString
                    Case "t": .CSex = vbNullString
                    Case "u": .CSex = vbNullString
                    End Select
                End If
                If FM.txtS1F06.Text <> vbNullString Then .CStreet = FM.txtS1F06.Text
                If FM.txtS1F08.Text <> vbNullString Then .CZip = FM.txtS1F08.Text
                If FM.txtS1F09.Text <> vbNullString Then .CTown = FM.txtS1F09.Text
                If FM.txtS1F12.Text <> vbNullString Then .CCountry = FM.txtS1F12.Text
                If FM.txtS1F15.Text <> vbNullString Then .CTelephone = FM.txtS1F15.Text
                If FM.txtS1F17.Text <> vbNullString Then .CFax = FM.txtS1F17.Text
                .InsuranceStatus = "P"
                If FM.txtS1F19.Text <> vbNullString Then .Email = FM.txtS1F19.Text
                If FM.txtS1F18.Text <> vbNullString Then .CellularPhone = FM.txtS1F18.Text
            End With
            
            SAdTx "ClientDelete", True
        End If
        
    Else
        Mld1 = "Das Feld Suchname muß erst ausgefüllt werden, damit dieser Datensatz gespeichern werden kann"
        Tit1 = "Fehlende Angaben"
        WindowMess Mld1, Dial2, Tit1, FM.hwnd
    End If
Else
