Private Sub Adr_Wie(ByVal GuiID As String)
On Error GoTo DaErr
'Erstellt einen Wiedervorlageeintrag beim Neuanlegen eines Patienten

Dim SQL1 As String
Dim NeuDa As Date
Dim PatGe As Date
Dim StMan As Long
Dim PatNr As Long
Dim PatNa As String

StMan = GlMan(GlSMa, 2)

Set RS40 = New ADODB.Recordset
RS40.CursorLocation = adUseClient
Set RS40 = DBCmRe1("qrySimAdGui", "@IdStr", GuiID)
If RS40.RecordCount > 0 Then
    PatNr = RS40.Fields("ID0").Value
    PatNa = RS40.Fields("IDKurz").Value
    If RS40.Fields("Geboren").Value <> vbNullString Then
        PatGe = RS40.Fields("Geboren").Value
        NeuDa = Format$(DatePart("d", PatGe, vbMonday), "00") & "." & Format$(DatePart("m", PatGe, vbMonday), "00") & "." & DatePart("yyyy", Date, vbMonday)
    End If
Else
    PatNr = 0
End If
RS40.Close
Set RS40 = Nothing

If PatNr > 0 Then
    Set RS50 = New ADODB.Recordset
    With RS50
        .CursorLocation = adUseClient
        .Source = "qryTerNeu"
        .ActiveConnection = DB1
        .CursorType = adOpenKeyset
        .LockType = adLockOptimistic
        .Open Options:=adCmdTableDirect
    End With
    
    If RS50.Supports(adUpdate) = True Then
        RS50.AddNew
        RS50.Fields("VonDat").Value = Format$(NeuDa, "dd.mm.yyyy")
        RS50.Fields("BisDat").Value = Format$(NeuDa, "dd.mm.yyyy")
        If GlTyp < 2 Then
            RS50.Fields("ZeiVon").Value = Format$(NeuDa, "dd.mm.yyyy") & Chr$(32) & "12:00:00"
            RS50.Fields("ZeiBis").Value = Format$(NeuDa, "dd.mm.yyyy") & Chr$(32) & "12:00:00"
        Else
            RS50.Fields("ZeiVon").Value = "12:00:00"
            RS50.Fields("ZeiBis").Value = "12:00:00"
        End If
        RS50.Fields("IDKurz").Value = "Geburtstag"
        RS50.Fields("Patient").Value = PatNa
        RS50.Fields("ID0").Value = PatNr
        RS50.Fields("IDP").Value = StMan
        RS50.Fields("Vorlage").Value = -1
        RS50.Update
    End If
    
    RS50.Close
    Set RS50 = Nothing
End If

Exit Sub

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Adr_Wie " & Err.Number
Resume Next

End Sub
