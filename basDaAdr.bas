    Set RpRec = RpHcs.Add()
    Set RpItm = RpRec.AddItem(0)
    Set RpItm = RpRec.AddItem(PatKa)
    RpItm.Icon = IC16_Folder_Open
    Set RpItm = RpRec.AddItem(PatNr)
    Set RpItm = RpRec.AddItem(0)
    Set RpItm = RpRec.AddItem(0)
    
    Set RpRec = RpHcs.Add()
    Set RpItm = RpRec.AddItem(0)
    Set RpItm = RpRec.AddItem(PatZa)
    RpItm.Icon = IC16_Folder_Open
    Set RpItm = RpRec.AddItem(PatNr)
    Set RpItm = RpRec.AddItem(0)
    Set RpItm = RpRec.AddItem(0)

    If AdGrp <> vbNullString Then
        If Len(AdGrp) < 20 Then
           AdGrp = "Gruppen: " & AdGrp
        End If
        Set RpRec = RpHcs.Add()
        Set RpItm = RpRec.AddItem(0)
        Set RpItm = RpRec.AddItem(AdGrp)
        RpItm.Icon = IC16_Folder_Open
        Set RpItm = RpRec.AddItem(PatNr)
        Set RpItm = RpRec.AddItem(0)
        Set RpItm = RpRec.AddItem(0)
    End If
    
    If RzAnz > 0 Then
        Set RpRec = RpHcs.Add()
        Set RpItm = RpRec.AddItem(0)
        Set RpItm = RpRec.AddItem("Folge: " & Format$(RzAkt, "00") & " / " & Format$(RzAnz, "00"))
        RpItm.Icon = IC16_Calendar_Day
        Set RpItm = RpRec.AddItem(PatNr)
        Set RpItm = RpRec.AddItem(0)
        Set RpItm = RpRec.AddItem(0)
    End If

    If MiNam <> vbNullString Then
        Set RpRec = RpHcs.Add()
        Set RpItm = RpRec.AddItem(0)
        Set RpItm = RpRec.AddItem(MiNam)
        RpItm.Icon = IC16_BusMan_Norm
        RpItm.Bold = True
        Set RpItm = RpRec.AddItem(PatNr)
        Set RpItm = RpRec.AddItem(0)
        Set RpItm = RpRec.AddItem(0)
    End If

    If PaBem <> vbNullString Then
        KoStr = PaBem
    End If
    If PaCav <> vbNullString Then
        If KoStr <> vbNullString Then
            KoStr = KoStr & vbCrLf & PaCav
        Else
            KoStr = PaCav
        End If
    End If
    If TeKom <> vbNullString Then
        If KoStr <> vbNullString Then
            KoStr = KoStr & vbCrLf & TeKom
        Else
            KoStr = TeKom
        End If
    End If
    RpRec.PreviewText = KoStr

    Set RS39 = New ADODB.Recordset
    RS39.CursorLocation = adUseClient
    If GlDeT = True Then 'Stornierte Termine Termindetails
        Set RS39 = DBCmRe1("qryTerPat6", "@IdxNr", PatNr)
    Else
        Set RS39 = DBCmRe1("qryTerPat5", "@IdxNr", PatNr)
    End If
    AnzTe = RS39.RecordCount
    If AnzTe > 0 Then
        Set RpRcs = RpCon.Records
        Do
        TerNr = RS39.Fields("ID2").Value
        MitNr = RS39.Fields("IDM").Value
        FrbZa = RS39.Fields("Farbe").Value
        RezAn = RS39.Fields("RzAnz").Value
        RezAk = RS39.Fields("RzAkt").Value
        Passi = RS39.Fields("Passiv").Value
        Datu1 = Format$(RS39.Fields("VonDat").Value, "dd.mm.yyyy")
        Datu2 = Format$(RS39.Fields("ZeiVon").Value, "hh:mm")
        Datu3 = Format$(RS39.Fields("ZeiBis").Value, "hh:mm")
        WoTag = Format$(RS39.Fields("VonDat").Value, "ddd")
        If RS39.Fields("Farbtyp").Value <> vbNullString Then
            FaTyp = RS39.Fields("Farbtyp").Value
        Else
            FaTyp = 0
        End If
        If RS39.Fields("MasTer").Value <> vbNullString Then
            MasTe = RS39.Fields("MasTer").Value
        Else
            MasTe = 0
        End If

        If RS39.Fields("Wiederholung").Value <> vbNullString Then
            If CBool(RS39.Fields("Wiederholung").Value) = True Then 'Leistungen vorhanden
                If CBool(RS39.Fields("Aufgabe").Value) = True Then 'Abgerechnet
                    Abger = 3
                Else
                    Abger = 2
                End If
            Else
                Abger = 1
            End If
        Else
            Abger = 1
        End If
        
        If IsNull(RS39.Fields("Abhaken").Value) = False Then
            If CBool(RS39.Fields("Abhaken").Value) = True Then
                Abgeh = True
            Else
                Abgeh = False
            End If
        Else
            Abgeh = False
        End If
        
        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
            If GlTiD = True Then 'Termindetails inaktiver Mitarbeitername
                For AktZa = 1 To UBound(GlMiK) 'Aktive Mitarbeiter + Terminspalte
                    If MitNr = GlMiK(AktZa, 2) Then
                        If GlMiK(AktZa, 27) <> vbNullString Then
                            MiNam = GlMiK(AktZa, 27)
                        Else
                            MiNam = GlMiK(AktZa, 1)
                        End If
                        Exit For
                    End If
                Next AktZa
            Else
                For AktZa = 1 To UBound(GlMiT) 'Aktive Mitarbeiter + Terminspalte
                    If MitNr = GlMiT(AktZa, 2) Then
                        If GlMiT(AktZa, 27) <> vbNullString Then
                            MiNam = GlMiT(AktZa, 27)
                        Else
                            MiNam = GlMiT(AktZa, 1)
                        End If
                        Exit For
                    End If
                Next AktZa
            End If
        Else
            For AktZa = 1 To UBound(GlMaT)
                If ManNr = GlMaT(AktZa, 0) Then
                    MiNam = GlMaT(AktZa, 1)
                    Exit For
                End If
            Next AktZa
        End If

        TeDat = WoTag & ". " & Datu1
        TeZei = " [" & Datu2 & " - " & Datu3 & "] "

        If RezAn > 0 Then
            RezSt = "[" & Format$(RezAk, "00") & "/" & Format$(RezAn, "00") & "] "
            If RS39.Fields("IDKurz").Value <> vbNullString Then
                TeBet = RezSt & RS39.Fields("IDKurz").Value
            ElseIf RS39.Fields("Patient").Value <> vbNullString Then
                TeBet = RezSt & RS39.Fields("Patient").Value
            Else
                TeBet = RezSt & "Termin"
            End If
        Else
            If RS39.Fields("IDKurz").Value <> vbNullString Then
                TeBet = RS39.Fields("IDKurz").Value
            Else
                TeBet = "Termin"
            End If
        End If

        If GlTrD = True Then 'Termindetails mit Mitarbeitername
            If MiNam <> vbNullString Then
                TeBet = TeBet & " - " & MiNam
            Else
                TeBet = TeBet & " - " & PaKur
            End If
        Else
            TeBet = TeBet & " - " & PaKur
        End If

        Set RpRec = RpRcs.Add()
        Set RpItm = RpRec.AddItem(TerNr)
        Set RpItm = RpRec.AddItem(TeDat & TeZei & TeBet)

        If Abger = 1 Then
            If Abgeh = True Then
                 RpItm.Icon = IC16_Sign_Check
            Else
                Select Case FaTyp
                Case 1: RpItm.Icon = IC16_Pin_Green
                Case 2: RpItm.Icon = IC16_Pin_Gray
                Case 3: RpItm.Icon = IC16_Calendar_Day
                Case 4: RpItm.Icon = IC16_Pin_Red
                End Select
            End If
        Else
            Select Case Abger
            Case 2: RpItm.Icon = IC16_Mail_Open
            Case 3: RpItm.Icon = IC16_Mail_Close
            End Select
        End If
        
        If IsDate(Datu1) = True Then
            If CDate(Datu1) >= Date Then
                RpItm.Bold = True
            Else
                RpItm.Bold = False
            End If
        Else
            RpItm.Bold = False
        End If
        
        If Passi = True Then
            Set RpItm = RpRec.AddItem(1)
        Else
            Set RpItm = RpRec.AddItem(0)
        End If
        Set RpItm = RpRec.AddItem(FrbZa)
        Set RpItm = RpRec.AddItem(MasTe)

        RS39.MoveNext
        Loop Until RS39.EOF
    End If
    RS39.Close
    Set RS39 = Nothing
    DoEvents
    
    RpCon.Populate
    DoEvents

    Set RpRws = RpCon.Rows
    For Each RpRow In RpRws
        If RpRow.GroupRow = False Then
            If RpRow.Record(0).Value = TeNum Then
                RpRow.EnsureVisible
                RpRow.Selected = True
            End If
        End If
    Next RpRow
End If

Exit Sub

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_Det " & Err.Number
Resume Next

End Sub
Public Sub Ter_Edi(ByVal PatNr As Long, ByVal IdWar As Boolean, Optional ByVal MitNr As Long = 0, Optional ByVal ManNr As Long = 0, Optional ByVal Prior As Long = 0)
On Error GoTo LiErr
'Passt die markierten Termine an in Bezug auf Warteliste und Geändert

Dim TmpWe As Variant
Dim Warte As Boolean
Dim Mld1, Tit1 As String
Dim Frage As Integer

Tit1 = "Wartenden Entfernen"
Mld1 = "Soll der Patient aus der Terminwarteliste entfernt werden?"

If PatNr > 0 Then
    TmpWe = S_AdIdx(PatNr, "Warteliste")
    If TmpWe <> vbNullString Then
        Warte = CBool(TmpWe)
    Else
        Warte = False
    End If
    DoEvents
    If IdWar = True Then
        If Warte = False Then
            DBCmEx2 "qrySimAdGen", "@IdDat", "@IdxNr", Now, PatNr 'WICHTIG Datum und Uhrzeit für SQL Server
            DoEvents
            DBCmEx2 "qrySimAdWaE", "@IdWar", "@IdxNr", IdWar, PatNr
            DoEvents
            If Prior > 0 Then
                DBCmEx2 "qryAdrPri", "@IdPri", "@IdxNr", Prior, PatNr
                DoEvents
            End If
            If MitNr > 0 Then
                DBCmEx2 "qryAdrMit", "@IdMit", "@IdxNr", MitNr, PatNr
                DoEvents
            End If
            If ManNr > 0 Then
                DBCmEx2 "qrySimAdThe", "@IdMan", "@IdxNr", ManNr, PatNr
                DoEvents
            End If
            SPopu "Wartelistenänderung", "Der Patient wurde in die Terminwarteliste hinzugefügt", IC48_Information
        End If
    Else
        If Warte = True Then
            Frage = WindowMess(Mld1, Dial1, Tit1, frmMain.hwnd)
            If Frage = 6 Then
                DBCmEx2 "qrySimAdGen", "@IdDat", "@IdxNr", Now, PatNr 'WICHTIG Datum und Uhrzeit für SQL Server
                DoEvents
                DBCmEx2 "qrySimAdWaE", "@IdWar", "@IdxNr", IdWar, PatNr
                DoEvents
                SPopu "Wartelistenänderung", "Der Patient wurde aus er Terminwarteliste entfernt", IC48_Warning
            End If
        End If
    End If
End If

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_Edi " & Err.Number
Resume Next

End Sub
Public Sub Ter_Ein(ByVal EngTy As Integer)
On Error GoTo LiErr
'Fügt Daten in das Krankenblatt ein

Dim NeuDa As Date
Dim TerDa As Date
Dim TerNr As Long
Dim RowNr As Long
Dim PosNr As Long
Dim PatNr As Long
Dim ReNum As Long
Dim KetNr As Long
Dim KatNr As Long
Dim SorNr As Long
Dim IdxNr As Long
Dim MasTm As Long
Dim MasTe As Long
Dim SQL1 As String
Dim BesSo As Single
Dim BesMe As Single
Dim SeSum As Single
Dim TeSum As Single
Dim FoFak As Single
Dim FeMul As Single
Dim FeEin As Single
Dim ReStu As Single
Dim ReStr As String
Dim SuStr As String
Dim EiTex As String
Dim TmpSt As String
Dim GebZi As String
Dim ArStr As String
Dim EiAnz As Integer
Dim LabNr As Integer
Dim GesZa As Integer
Dim CoIdx As Integer
Dim Posit As Integer
Dim Lange As Integer
Dim FeAnz As Integer
Dim RePru As Integer
Dim AnzL1 As Integer
Dim AnzL2 As Integer
Dim ZaZil As Integer
Dim AktZa As Integer
Dim DiaLa As Boolean
Dim EinZu As Boolean
Dim MaEin As Boolean
Dim RpCon As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmTermin
Set TxID0 = FM.txtID0
Set TxID2 = FM.txtID2
Set TxFa1 = FM.txtFall1
Set TxFa2 = FM.txtFall2
Set ChWie = FM.chkWiede
Set TxMas = FM.txtRefNr
Set TxAnz = FM.txtAnzal
Set TxMul = FM.txtMulti
Set TxEin = FM.txtEinze
Set CmTyp = FM.cmbTypen
Set CmZif = FM.cmbZiffe
Set CmBez = FM.cmbBezei
Set RpCon = FM.repCont2
Set RpRws = RpCon.Rows
Set RpCls = RpCon.Columns
Set RpSel = RpCon.SelectedRows

Screen.MousePointer = vbHourglass

For AktZa = 1 To UBound(GlZah) 'Standardzahlungsziel
    If GlZah(AktZa, 0) = GlStZ Then
        ZaZil = GlZah(AktZa, 2)
        Exit For
    End If
Next AktZa

CoIdx = CmTyp.ListIndex + 1

If TxID0.Text <> vbNullString Then
    If IsNumeric(TxID0.Text) Then
        PatNr = CLng(TxID0.Text)
    Else
        PatNr = 0
    End If
Else
    PatNr = 0
End If

If TxID2.Text <> vbNullString Then
    If IsNumeric(TxID0.Text) Then
        TerNr = CLng(TxID2.Text)
    Else
        TerNr = GlTem
    End If
Else
    TerNr = GlTem
End If

If TxMas.Text <> vbNullString Then
    MasTe = TxMas.Text
    MasTm = TxMas.Text
Else
    MasTe = 0
    MasTm = TerNr
End If

If IsDate(TxDa1.Text) Then
    TerDa = CDate(TxDa1.Text)
Else
    TerDa = Date
End If

'NeuDa = DateAdd("d", ZaZil, TerDa)
NeuDa = DateAdd("d", ZaZil, Date)

KatNr = S_AdIdi(PatNr, "ID3")

RowNr = 1
FoFak = 1
FoFak = Round(FoFak, 2)

If KatNr = 0 Then
    Exit Sub
End If

Select Case GlFri
Case 1: LabNr = 2 'Arzt (GOÄ)
Case 2: LabNr = 1 'Heilpraktiker (GebüH)
Case 3: LabNr = 2 'Zahnarzt (GOZ)
Case 4: LabNr = 2 'Veterinär (GOT)
Case 5: LabNr = 1 'Naturheilpraktiker (Tarif 590)
Case 6: LabNr = 1 'Physiotherapeut
Case 7: LabNr = 1 'Wahlarzt (AT)
End Select

Select Case EngTy
Case 1:
        TmpSt = CmZif.Text
        Posit = InStr(1, TmpSt, Chr$(32), 1)
        If Posit > 0 Then
            TmpSt = Left$(TmpSt, Posit - 1)
        End If
        If InStr(1, TmpSt, ",", 1) > 0 Then
            SuStr = Replace(TmpSt, ",", ".")
        Else
            SuStr = TmpSt
        End If
Case 2:
        TmpSt = CmBez.Text
        SuStr = TmpSt
Case 3:
        If IsNull(TxMul.Text) Then
            FeMul = CSng(Format$(1, GlWa1))
        ElseIf IsNumeric(TxMul.Text) = False Then
            FeMul = CSng(Format$(1, GlWa1))
        Else
            FeMul = CSng(Format$(TxMul.Text, GlWa1))
        End If
        If IsNull(TxEin.Text) Then
            FeEin = CSng(Format$(0, GlWa1))
        ElseIf IsNumeric(TxEin.Text) = False Then
            FeEin = CSng(Format$(0, GlWa1))
        Else
            FeEin = CSng(Format$(TxEin.Text, GlWa1))
        End If
        If IsNull(TxAnz.Text) Then
            FeAnz = 1
        ElseIf IsNumeric(TxAnz.Text) = False Then
            FeAnz = 1
        Else
            FeAnz = CInt(TxAnz.Text)
        End If
        If CmZif.Text <> vbNullString Then
            TmpSt = CmZif.Text
            Posit = InStr(1, TmpSt, Chr$(32), 1)
            If Posit > 0 Then
                TmpSt = Left$(TmpSt, Posit - 1)
            End If
            If InStr(1, TmpSt, ",", 1) > 0 Then
                SuStr = Replace(TmpSt, ",", ".")
            Else
                SuStr = TmpSt
            End If
            EngTy = 1
        Else
            TmpSt = CmBez.Text
            SuStr = TmpSt
            EngTy = 2
        End If
        MaEin = True
Case 4: SuStr = "-"
End Select

If SuStr <> vbNullString Then
    If GlTyp < 2 Then
        SQL1 = "SELECT * FROM dbo.qryAnKa1 WHERE ID2 = " & TerNr & " ORDER BY ID1"
    Else
        SQL1 = "SELECT * FROM qryAnKa1 WHERE [ID2] = " & TerNr & " ORDER BY [ID1];"
    End If
    
    Set RS63 = New ADODB.Recordset
    With RS63
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With
    
    If RS63.RecordCount > 0 Then
        If RS63.Fields("ID3").Value > 0 Then
            SorNr = RS63.Fields("ID3").Value
        Else
            SorNr = 0
        End If
    Else
        SorNr = 0
    End If

    Select Case CoIdx
    Case 1: 'Diagnosen
            Set RS64 = New ADODB.Recordset
            RS64.CursorLocation = adUseClient
            Select Case EngTy
            Case 1: Set RS64 = DBCmRe2("qryKat03M", "@IdxNr", "@IdStr", 1, SuStr)
            Case 2: Set RS64 = DBCmRe2("qryKat03P", "@IdxNr", "@IdStr", 1, SuStr)
            End Select
            GesZa = RS64.RecordCount
            If GesZa > 0 Then
                Select Case EngTy
                Case 1: EiTex = RS64.Fields("GOID").Value
                        RS63.Filter = "[GOID] = '" & EiTex & "'"
                Case 2: EiTex = RS64.Fields("IDKurz").Value
                        RS63.Filter = "[IDKurz] Like '*" & EiTex & "*'"
                End Select
                If RS63.RecordCount > 0 Then
                    EinZu = False
                Else
                    EinZu = True
                End If
                RS63.Filter = adFilterNone
                '---
                If EinZu = True Then
                    SorNr = SorNr + 1
                    RS63.AddNew
                    RS63.Fields("ID0").Value = PatNr
                    RS63.Fields("ID2").Value = TerNr
                    RS63.Fields("ID3").Value = SorNr
                    RS63.Fields("MasTer").Value = MasTm
                    RS63.Fields("Sorter").Value = 1
                    RS63.Fields("GOID").Value = RS64.Fields("GOID").Value
                    RS63.Fields("IDKurz").Value = Left$(RS64.Fields("IDKurz").Value, 150)
                    RS63.Fields("Kommentar").Value = RS64.Fields("Zusatztext").Value
                    RS63.Fields("ResTag").Value = 0
                    RS63.Update
                End If
            Else
                Set RS82 = New ADODB.Recordset
                RS82.CursorLocation = adUseClient
                Set RS82 = DBCmRe2("qryKat03O", "@IdxNr", "@IdStr", 1, SuStr) 'Diagnoseketten
                GesZa = RS82.RecordCount
                If GesZa > 0 Then
                    KetNr = RS82.Fields("ID1").Value
                    Set RS81 = New ADODB.Recordset
                    RS81.CursorLocation = adUseClient
                    Set RS81 = DBCmRe1("qryKet03E", "@IdxNr", KetNr)
                    If RS81.RecordCount > 0 Then
                        Do
                        Select Case EngTy
                        Case 1: EiTex = RS81.Fields("GOID").Value
                                RS63.Filter = "[GOID] = '" & EiTex & "'"
                        Case 2: EiTex = RS81.Fields("IDKurz").Value
                                RS63.Filter = "[IDKurz] Like '*" & EiTex & "*'"
                        End Select
                        If RS63.RecordCount > 0 Then
                            EinZu = False
                        Else
                            EinZu = True
                        End If
                        RS63.Filter = adFilterNone
                        '---
                        If EinZu = True Then
                            SorNr = SorNr + 1
                            RS63.AddNew
                            RS63.Fields("ID0").Value = PatNr
                            RS63.Fields("ID2").Value = TerNr
                            RS63.Fields("ID3").Value = SorNr
                            RS63.Fields("MasTer").Value = MasTm
                            RS63.Fields("Sorter").Value = 1
                            RS63.Fields("GOID").Value = RS81.Fields("GOID").Value
                            RS63.Fields("IDKurz").Value = Left$(RS81.Fields("IDKurz").Value, 150)
                            RS63.Fields("Kommentar").Value = RS81.Fields("Zusatztext").Value
                            RS63.Fields("ResTag").Value = 0
                            RS63.Update
                        End If
                        RS81.MoveNext
                        Loop Until RS81.EOF
                    End If
                    RS81.Close
                    Set RS81 = Nothing
                End If
                RS82.Close
                Set RS82 = Nothing
            End If
            RS64.Close
            Set RS64 = Nothing
    Case 3: 'Laborleistungen
            Set RS64 = New ADODB.Recordset
            RS64.CursorLocation = adUseClient
            Select Case EngTy
            Case 1: Set RS64 = DBCmRe2("qryKat02M", "@IdxNr", "@IdStr", LabNr, SuStr) 'Sucht im falschen Feld
            Case 2: Set RS64 = DBCmRe2("qryKat02N", "@IdxNr", "@IdStr", LabNr, SuStr)
            End Select
            GesZa = RS64.RecordCount
            If GesZa > 0 Then
                Select Case EngTy
                Case 1: EiTex = RS64.Fields("GOID").Value
                        RS63.Filter = "[GOID] = '" & EiTex & "'"
                Case 2: EiTex = RS64.Fields("IDKurz").Value
                        RS63.Filter = "[IDKurz] Like '*" & EiTex & "*'"
                End Select
                If RS63.RecordCount > 0 Then
                    EinZu = False
                Else
                    EinZu = True
                End If
                RS63.Filter = adFilterNone
                '---
                If EinZu = True Then
                    SorNr = SorNr + 1
                    RS63.AddNew
                    RS63.Fields("ID0").Value = PatNr
                    RS63.Fields("ID2").Value = TerNr
                    RS63.Fields("ID3").Value = SorNr
                    RS63.Fields("MasTer").Value = MasTm
                    RS63.Fields("Sorter").Value = 3
                    RS63.Fields("GOID").Value = RS64.Fields("GOID").Value
                    RS63.Fields("IDKurz").Value = Left$(RS64.Fields("IDKurz").Value, 150)
                    RS63.Fields("Kommentar").Value = RS64.Fields("Zusatztext").Value
                    RS63.Fields("Steuer").Value = RS64.Fields("Steuer").Value
                    RS63.Fields("Rabatt").Value = RS64.Fields("Rabatt").Value
                    If FeAnz > 0 Then
                        RS63.Fields("x").Value = FeAnz
                    Else
                        RS63.Fields("x").Value = 1
                    End If
                    If FeMul > 1 Then
                        RS63.Fields("Multi").Value = FeMul
                    Else
                        RS63.Fields("Multi").Value = CSng(Round(RS64.Fields("Multi").Value, 2))
                    End If
                    If FeEin > 0 Then
                        RS63.Fields("Preis1").Value = CSng(Round(FeEin, 2) / FoFak)
                    Else
                        RS63.Fields("Preis1").Value = CSng(Round(RS64.Fields("Preis1").Value, 2) / FoFak)
                    End If
                    If MaEin = True Then
                        If FeAnz > 0 Then
                            If FeEin > 0 Then
                                If FeMul > 1 Then
                                    RS63.Fields("Preis2").Value = CSng((Round(FeEin, 2) * Round(FeMul, 2)) / FoFak) * FeAnz
                                Else
                                    RS63.Fields("Preis2").Value = CSng((Round(FeEin, 2) * Round(RS64.Fields("Multi").Value, 2)) / FoFak) * FeAnz
                                End If
                            Else
                                If FeMul > 1 Then
                                    RS63.Fields("Preis2").Value = CSng((Round(RS64.Fields("Preis1").Value, 2) * Round(FeMul, 2)) / FoFak) * FeAnz
                                Else
                                    RS63.Fields("Preis2").Value = CSng((Round(RS64.Fields("Preis1").Value, 2) * Round(RS64.Fields("Multi").Value, 2)) / FoFak) * FeAnz
                                End If
                            End If
                        Else
                            If FeEin > 0 Then
                                If FeMul > 1 Then
                                    RS63.Fields("Preis2").Value = CSng((Round(FeEin, 2) * Round(FeMul, 2)) / FoFak)
                                Else
                                    RS63.Fields("Preis2").Value = CSng((Round(FeEin, 2) * Round(RS64.Fields("Multi").Value, 2)) / FoFak)
                                End If
                            Else
                                If FeMul > 1 Then
                                    RS63.Fields("Preis2").Value = CSng((Round(RS64.Fields("Preis1").Value, 2) * Round(FeMul, 2)) / FoFak)
                                Else
                                    RS63.Fields("Preis2").Value = CSng((Round(RS64.Fields("Preis1").Value, 2) * Round(RS64.Fields("Multi").Value, 2)) / FoFak)
                                End If
                            End If
                        End If
                    Else
                        RS63.Fields("Preis2").Value = CSng((Round(RS64.Fields("Preis1").Value, 2) * Round(RS64.Fields("Multi").Value, 2)) / FoFak)
                    End If
                    RS63.Fields("ResTag").Value = 0
                    RS63.Update
                End If
            Else
                Set RS82 = New ADODB.Recordset
                RS82.CursorLocation = adUseClient
                Set RS82 = DBCmRe2("qryKat02O", "@IdxNr", "@IdStr", LabNr, SuStr) 'Laborketten
