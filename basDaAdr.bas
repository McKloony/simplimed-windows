Public Sub Ter_LeS(ByVal TerNr As Long)
On Error GoTo LiErr
'Speichert die Daten aus der Tabelle

Dim SQL2 As String
Dim GesZa As Long
Dim KeyNr As String
Dim Krit1 As String
Dim TmTag As String
Dim KrRow As Integer
Dim RpCon As XtremeReportControl.ReportControl

Set FM = frmTermin
Set RpCon = FM.repCont1
Set RpRcs = RpCon.Records

Set RpSel = RpCon.SelectedRows
If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    KrRow = RpRow.Index
End If

If GlTyp < 2 Then
    SQL2 = "SELECT * FROM dbo.qryAnKa1 WHERE ID2 = " & TerNr & " ORDER BY ID1"
Else
    SQL2 = "SELECT * FROM qryAnKa1 WHERE [ID2] = " & TerNr & " ORDER BY [ID1];"
End If

If TerNr > 0 Then
    Set RS50 = New ADODB.Recordset
    With RS50
        .CursorLocation = adUseClient
        .Source = SQL2
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With
    If RS50.RecordCount > 0 Then
        If RS50.Supports(adUpdate) Then
            RS50.MoveFirst
            For Each RpRec In RpRcs
                KeyNr = RpRec.Item(TeL_ID1).Value
                RS50.MoveFirst
                Krit1 = "[ID1]=" & KeyNr
                RS50.Find Criteria:=Krit1, SkipRecords:=0, SearchDirection:=adSearchForward
                If Not (RS50.BOF Or RS50.EOF) Then
                    For Each RpItm In RpRec
                        If Left$(RpItm.Tag, 1) = "@" Then
                            TmTag = Mid$(RpItm.Tag, 2, Len(RpItm.Tag) - 1)
                            If RpItm.HasCheckbox = True Then
                                RS50.Fields(TmTag).Value = RpItm.Checked
                            Else
                                If IsNumeric(RpItm.Value) Then
                                    RS50.Fields(TmTag).Value = Replace(RpItm.Value, ",", ".", 1)
                                Else
                                    RS50.Fields(TmTag).Value = RpItm.Value
                                End If
                            End If
                        End If
                    Next RpItm
                    RS50.Update
                    RS50.MoveNext
                End If
            Next RpRec
        End If
    End If
    RS50.Close
    Set RS50 = Nothing

    If GlJet = True Then SDBSav
End If

Set RpRcs = Nothing
Set RpSel = Nothing
Set RpCon = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_LeS " & Err.Number
Resume Next

End Sub
