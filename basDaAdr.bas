            End If
        Else
            FeOrt.SetFocus
        End If
    End If
End If

RS31.Close
Set RS31 = Nothing

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Adr_Pos " & Err.Number
