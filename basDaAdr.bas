Mld1 = "Möchten Sie diese zugeordnete Adresse wirklich kopieren?"

TheNr = S_AdIdi(GlAId, "IDP")

If GlAzN = False Then 'Neue Zugeordnete anlegen
    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
        If Frage = 6 Then
            If RpRow.GroupRow = False Then
                Set RpCol = RpCls.Find(Adr_ID0)
                IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                
                If GlTyp < 2 Then
                    SQL1 = "SELECT * FROM dbo.qryMailAdress WHERE IDA = " & IdxNr
                Else
                    SQL1 = "SELECT * FROM qryMailAdress WHERE [IDA] = " & IdxNr & ";"
                End If
                
                Set RS40 = New ADODB.Recordset
                With RS40
                    .CursorLocation = adUseClient
                    .Source = SQL1
                    .ActiveConnection = DB1
                    .CursorType = adOpenKeyset
                    .LockType = adLockOptimistic
                    .Open Options:=adCmdText
                End With
                If RS40.RecordCount > 0 Then
                    GlAzG = CreateID("A")
                    AnzFe = RS40.Fields.Count
                    ReDim FldWe(AnzFe)
                    FldNr = 1
                    For Each FL101 In RS40.Fields
                        If Not IsNull(FL101.Value) Then
                            If FL101.Type = adBoolean Then
                                If FL101.Value = True Then
                                    FldWe(FldNr) = -1
                                Else
                                    FldWe(FldNr) = 0
                                End If
                            Else
                                FldWe(FldNr) = FL101.Value
                            End If
                        End If
                        FldNr = FldNr + 1
                    Next FL101
                    FldNr = 1
                    If RS40.Supports(adAddNew) Then
                        RS40.AddNew
                        For Each FL101 In RS40.Fields
                            Select Case FL101.Name
                            Case "IDA":
                            Case "Geboren":
                            Case "GuiID":
                                    RS40.Fields(FL101.Name).Value = GlAzG
                            Case "IDKurz":
                                    RS40.Fields(FL101.Name).Value = FeKur.Text & " (Kopie)"
                            Case "Datum":
                                    RS40.Fields(FL101.Name).Value = Date
                            Case "Geändert":
                                    RS40.Fields(FL101.Name).Value = Date
                            Case Else:
                                    If Not FL101.Type = 128 Then
                                        If Not FldWe(FldNr) = vbNullString Then
                                            RS40.Fields(FL101.Name).Value = FldWe(FldNr)
                                        End If
                                    End If
                            End Select
                            FldNr = FldNr + 1
                        Next FL101
                        RS40.Update
                    End If
                End If
                RS40.Close
                Set RS40 = Nothing

                GlNeK = GlKoX 'Protokolleintrag
                With GlNeK
                    .PatNr = GlAId
                    .IdxNr = 0
                    .EiDat = Format$(Date, "dd.mm.yyyy")
                    .EiZei = TimeValue(Now)
                    .EiTyp = 104
                    .TeStr = "Zugehöriger kopiert - " & FeKur.Text
                    .ZiStr = Format$(Now, "hh:mm") & " Uhr"
                    .NeuEi = True
                    .KeiAk = True
                    .Mitar = GlMiA(GlSmI, 2)
                End With
                S_Prot
                DoEvents
            End If

            RowNr = Adr_ZuLa(GlAzG) 'Zugehörigen Laden
            If RowNr > 0 Then
                If RpRws.Count > 0 Then
                    RowFi = RpCo5.TopRowIndex
                End If
            End If
            If RowNr >= RpRws.Count Then
                RowNr = RpRws.Count - 1
            End If
            RpCo5.TopRowIndex = RowFi
            RpRws.Row(0).Selected = False
            RpRws.Row(RowNr).EnsureVisible
            RpRws.Row(RowNr).Selected = True
            If GlFoc = True Then
                Set RpCo5.FocusedRow = RpRws.Row(RowNr)
            End If
            AZuLa

            GlAdZ = False 'Speichern der Zugeordneter erforderlich
        End If
    End If
Else
    AZuNe
    GlAdZ = False
End If

Set RpRws = Nothing
