Public Sub Ser_VoS(Optional ByVal TolId As Long)
On Error GoTo KoErr
'Speichert die generierten Serienterminbuchung

Dim BehNr As Long
Dim BuNum As Long
Dim MitNr As Long
Dim BuJah As Long
Dim KtIdS As Long
Dim KtNrH As Long
Dim SQL1 As String
Dim ReStu As Single
Dim BuBet As Double
Dim KtBzS As String
Dim GeKto As Integer
Dim BuTyp As Integer
Dim StuZa As Integer
Dim AktZa As Integer
Dim TxDa5 As XtremeSuiteControls.FlatEdit
Dim CmBeh As XtremeSuiteControls.ComboBox
Dim CmGel As XtremeSuiteControls.ComboBox
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmEd3 As XtremeCommandBars.CommandBarEdit
Dim RpCo6 As XtremeReportControl.ReportControl

Set FM = frmBuSer
Set CmBeh = FM.cmbBeha4
Set CmMit = FM.cmbMitar
Set CmGel = FM.cmbGegen
Set TxDa5 = FM.txtDatu5
Set RpCo6 = FM.repCont6
Set CmBrs = FM.comBar02
Set CmSta = CmBrs.StatusBar
Set RpRcs = RpCo6.Records

If CmBeh.Text <> vbNullString Then
    BehNr = CmBeh.ItemData(CmBeh.ListIndex)
Else
    BehNr = GlMan(GlSMa, 2)
End If

If CmMit.Text <> vbNullString Then
    MitNr = CmMit.ItemData(CmMit.ListIndex)
Else
    MitNr = GlMiA(GlSmI, 2)
End If

If IsDate(TxDa5.Text) = True Then
    BuJah = Year(TxDa5.Text)
Else
    BuJah = Year(Date)
End If

If FM.txtBuBet.Text <> vbNullString Then
    If IsNumeric(FM.txtBuBet.Text) = True Then
        BuBet = Round(FM.txtBuBet.Text, 2)
    Else
        BuBet = 0
    End If
Else
    BuBet = 0
End If

If FM.txtKtoNr.Text <> vbNullString Then KtIdS = CLng(FM.txtKtoNr.Text)
If FM.txtKtoHa.Text <> vbNullString Then KtNrH = CLng(FM.txtKtoHa.Text)
If FM.txtBezei.Text <> vbNullString Then KtBzS = CStr(FM.txtBezei.Text)
BuTyp = FM.cmbBuTyp.ItemData(FM.cmbBuTyp.ListIndex)
GeKto = FM.cmbGegen.ItemData(FM.cmbGegen.ListIndex)

BuNum = S_BuBel(BehNr, BuJah, GeKto)
DoEvents

Select Case TolId
Case 20121: SQL1 = "qrySimBuNe"
Case 20122: SQL1 = "qrySimBuVoNe"
Case Else: SQL1 = "qrySimBuVoNe"
End Select

Set RS45 = New ADODB.Recordset
With RS45
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenKeyset
    .LockType = adLockOptimistic
    .Open Options:=adCmdTableDirect
End With
If RS45.Supports(adAddNew) Then
    For Each RpRec In RpRcs 'gefundenen Termine
        If RpRec.Item(Buh_RechNr).Checked = True Then
            BuNum = BuNum + 1
            RS45.AddNew
            RS45.Fields("Datum").Value = CDate(RpRec.Item(Buh_Datum).Value)
            RS45.Fields("Buchtext").Value = RpRec.Item(Buh_Buchtext).Value
            RS45.Fields("IDK").Value = KtIdS
            RS45.Fields("IDKurz").Value = KtBzS
            RS45.Fields("IDA").Value = BuTyp
            RS45.Fields("IDB").Value = GeKto
            RS45.Fields("IDR").Value = 0 'WICHTIG!
            If GlBuc = True Then 'einfache Buchhaltung verwenden
                RS45.Fields("IDG").Value = 0
                Select Case BuTyp
                Case 1: RS45.Fields("Ausgabe").Value = BuBet
                        RS45.Fields("Einnahme").Value = 0
                Case 2: RS45.Fields("Einnahme").Value = BuBet
                        RS45.Fields("Ausgabe").Value = 0
                End Select
            Else
                RS45.Fields("IDG").Value = KtNrH
                RS45.Fields("Einnahme").Value = BuBet
                RS45.Fields("Ausgabe").Value = 0
            End If
            If FM.cmbBeha4.ListIndex >= 0 Then
                RS45.Fields("IDT").Value = FM.cmbBeha4.ItemData(FM.cmbBeha4.ListIndex)
            End If
            If FM.cmbMitar.ListIndex >= 0 Then
                RS45.Fields("IDM").Value = FM.cmbMitar.ItemData(FM.cmbMitar.ListIndex)
            End If
            If FM.cmbBuStu.ListIndex >= 0 Then
                StuZa = FM.cmbBuStu.ItemData(FM.cmbBuStu.ListIndex)
                For AktZa = 1 To UBound(GlStu)
                    If GlStu(AktZa, 0) = StuZa Then
                        ReStu = CDec(GlStu(AktZa, 1))
                        If ReStu > 0 And ReStu < 1 Then
                            ReStu = ReStu * 100
                        End If
                        RS45.Fields("Steuer").Value = ReStu
                        Exit For
                    End If
                Next AktZa
            End If
            RS45.Fields("Währung").Value = FM.cmbWarun.ItemData(FM.cmbWarun.ListIndex)
            RS45.Fields("GuiID").Value = RpRec.Item(Buh_GuiID).Value
            If FM.chkGewEr.Value = 1 Then
                RS45.Fields("Ermittlung").Value = -1
            Else
                RS45.Fields("Ermittlung").Value = 0
            End If
            If TolId = 20121 Then
                RS45.Fields("Beleg").Value = BuNum
            Else
                RS45.Fields("IDM").Value = MitNr
            End If
        End If
    Next RpRec
    RS45.Update
End If
RS45.Close
Set RS45 = Nothing

Set RpCo6 = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ser_VoS " & Err.Number
Resume Next

End Sub
