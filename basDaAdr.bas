Public Function Adr_Fil(SuFor As Integer, ByVal TmpSt As String, ByVal SuTyp As Integer, Optional ByVal SuDat As Date) As Long
On Error GoTo SuErr
'Füllt die Liste des Suchformulars mit den gefundenen Treffern

Dim GesZa As Long
Dim AktPo As Long
Dim BehNr As Long
Dim SuStr As String
Dim BeStr As String
Dim EmAdr As String
Dim EmaNr As String
Dim LiItm As XtremeSuiteControls.ListViewItem
Dim LiIts As XtremeSuiteControls.ListViewItems

Select Case SuFor
Case 1: Set FM = frmAdrSuch
Case 2: Set FM = frmAdrWord
Case 3: Set FM = frmAnaEdi
Case 4: Set FM = frmChipcard
End Select

Set LiVw3 = FM.lstView3
Set LiIts = LiVw3.ListItems

AktPo = 0
GesZa = 0
LiIts.Clear

SuStr = Trim$(TmpSt)

Set RS48 = New ADODB.Recordset
RS48.CursorLocation = adUseClient
Select Case SuTyp
Case 1: Set RS48 = DBCmRe1("qryAdrKur", "@IdStr", "%" & SuStr & "%")
Case 2: Set RS48 = DBCmRe1("qryAdrMan", "@IdStr", "%" & SuStr)
Case 3: Set RS48 = DBCmRe1("qrySimAdPLZ", "@IdStr", SuStr & "%")
Case 4: Set RS48 = DBCmRe1("qrySimAdBe", "@IdStr", "%" & SuStr & "%")
Case 5: Set RS48 = DBCmRe1("qrySimAdGeb", "@IdDat", SuDat)
End Select

GesZa = RS48.RecordCount

If GesZa > 0 Then
    Do Until RS48.EOF
    If RS48.Fields("IDP").Value > 0 Then
        BehNr = RS48.Fields("IDP").Value
    Else
        BehNr = 0
    End If
    If RS48.Fields("Telefon5").Value <> vbNullString Then
        EmAdr = RS48.Fields("Telefon5").Value
    Else
        EmAdr = vbNullString
    End If
    If RS48.Fields("Briefanrede").Value <> vbNullString Then
        EmaNr = RS48.Fields("Briefanrede").Value
    Else
        EmaNr = vbNullString
    End If
    For AktPo = 1 To UBound(GlThe)
        If BehNr = GlThe(AktPo, 0) Then
            BeStr = GlThe(AktPo, 13)
            Exit For
        End If
    Next AktPo
    Set LiItm = LiIts.Add(, "D" & RS48.Fields("ID0").Value, RS48.Fields("IDKurz").Value, IC16_IDCard_Norm)
    LiItm.SubItems(1) = BeStr
    LiItm.SubItems(2) = EmAdr
    LiItm.SubItems(3) = EmaNr
    AktPo = AktPo + 1
    RS48.MoveNext
    Loop
End If

RS48.Close
Set RS48 = Nothing

Adr_Fil = GesZa

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Adr_Fil " & Err.Number
Resume Next

End Function
Public Sub Adr_Geb()
On Error GoTo SuErr
'Anlegen von Aufgaben

