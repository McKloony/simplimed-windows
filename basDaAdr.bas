Public Sub Man_Cmb(ByVal CmTyp As Integer, ByVal LiIdx As Long)
On Error GoTo DaErr
'Füllt Comboboxen der Dialoge mit Daten

Dim GesZa As Long
Dim SQL1 As String
Dim AktZa As Integer
Dim cmKata As XtremeSuiteControls.ComboBox
Dim cmRahm As XtremeSuiteControls.ComboBox
Dim cmKett As XtremeSuiteControls.ComboBox
Dim cmKet2 As XtremeSuiteControls.ComboBox
Dim cmKont As XtremeSuiteControls.ComboBox
Dim cmKon2 As XtremeSuiteControls.ComboBox
Dim cmGeK1 As XtremeSuiteControls.ComboBox
Dim cmGeK2 As XtremeSuiteControls.ComboBox
Dim cmStKt As XtremeSuiteControls.ComboBox

Set FM = frmMandant
Set cmKata = FM.cmbGbKat
Set cmRahm = FM.cmbKtoRa
Set cmKett = FM.cmbGbKet
Set cmKet2 = FM.cmbGbKe2
Set cmKont = FM.cmbKtoEr
Set cmKon2 = FM.cmbKtoEk
Set cmGeK1 = FM.cmbGeKt1
Set cmGeK2 = FM.cmbGeKt2
Set cmStKt = FM.cmbKtoSt

Select Case CmTyp
Case 1:
    AktZa = 1
    cmKont.Clear
    cmKon2.Clear
    cmStKt.Clear
    DoEvents

'-------------------- Erlöskonten --------------------

    Set RS84 = New ADODB.Recordset 'Erlöskonten
    RS84.CursorLocation = adUseClient
    Set RS84 = DBCmRe2("qrySimBuKtt", "@IdTyp", "@IdxNr", 2, LiIdx)
    GesZa = RS84.RecordCount
    If GesZa > 0 Then
        Do Until RS84.EOF
        With cmKont
            .AddItem Format$(RS84.Fields("IDK").Value, "000000") & Chr$(32) & RS84.Fields("IDKurz").Value
            .ItemData(AktZa - 1) = RS84.Fields("IDI").Value
        End With
        With cmKon2
            .AddItem Format$(RS84.Fields("IDK").Value, "000000") & Chr$(32) & RS84.Fields("IDKurz").Value
            .ItemData(AktZa - 1) = RS84.Fields("IDI").Value
        End With
        AktZa = AktZa + 1
        RS84.MoveNext
        Loop
    End If
    RS84.Close
    Set RS84 = Nothing
    
'-------------------- Steuerkonten --------------------
    
    AktZa = 1
    Set RS85 = New ADODB.Recordset 'Steuerkonten
    RS85.CursorLocation = adUseClient
    Set RS85 = DBCmRe2("qrySimBuKtU", "@IdStu", "@IdxNr", -1, LiIdx)
    GesZa = RS85.RecordCount
    If GesZa > 0 Then
        Do Until RS85.EOF
        With cmStKt
            .AddItem Format$(RS85.Fields("IDK").Value, "000000") & Chr$(32) & RS85.Fields("IDKurz").Value
            .ItemData(AktZa - 1) = RS85.Fields("IDI").Value
        End With
        AktZa = AktZa + 1
        RS85.MoveNext
        Loop
    End If
    RS85.Close
    Set RS85 = Nothing

'-------------------- Geldkonten --------------------

    If GlBuc = False Then 'keine einfache Buchhaltung verwenden
        AktZa = 1
        cmGeK1.Clear
        cmGeK2.Clear
        DoEvents

        Set RS83 = New ADODB.Recordset 'Sachkonten mit Geldkontenzuordnung
        RS83.CursorLocation = adUseClient
        Set RS83 = DBCmRe2("qrySimBuKtE", "@IdGel", "@IdxNr", -1, LiIdx)
        GesZa = RS83.RecordCount
        If GesZa > 0 Then
            Do Until RS83.EOF
            With cmGeK1
                .AddItem Format$(RS83.Fields("IDK").Value, "000000") & Chr$(32) & RS83.Fields("IDKurz").Value
                .ItemData(AktZa - 1) = RS83.Fields("IDI").Value
            End With
            With cmGeK2
                .AddItem Format$(RS83.Fields("IDK").Value, "000000") & Chr$(32) & RS83.Fields("IDKurz").Value
                .ItemData(AktZa - 1) = RS83.Fields("IDI").Value
            End With
            AktZa = AktZa + 1
            RS83.MoveNext
            Loop
        End If
        RS83.Close
        Set RS83 = Nothing
    End If
    
    If cmKont.ListCount > 0 Then cmKont.ListIndex = 0
    If cmKon2.ListCount > 0 Then cmKon2.ListIndex = 0
    If cmGeK1.ListCount > 0 Then cmGeK1.ListIndex = 0
    If cmGeK2.ListCount > 0 Then cmGeK2.ListIndex = 0
    If cmStKt.ListCount > 0 Then cmStKt.ListIndex = 0

Case 2:

    AktZa = 1
    cmKett.Clear
    cmKet2.Clear
    DoEvents
    Set RS84 = New ADODB.Recordset
    RS84.CursorLocation = adUseClient
    Set RS84 = DBCmRe1("qryKat01H", "@IdxNr", LiIdx) 'Gebührenketten
    GesZa = RS84.RecordCount
    If GesZa > 0 Then
        Do Until RS84.EOF
        cmKett.AddItem RS84.Fields("IDKurz").Value
        cmKet2.AddItem RS84.Fields("IDKurz").Value
        cmKett.ItemData(AktZa - 1) = RS84.Fields("ID1").Value
        cmKet2.ItemData(AktZa - 1) = RS84.Fields("ID1").Value
        AktZa = AktZa + 1
        RS84.MoveNext
        Loop
    End If
    RS84.Close
    Set RS84 = Nothing
    
    If cmKett.ListCount > 0 Then cmKett.ListIndex = 0
    If cmKet2.ListCount > 0 Then cmKet2.ListIndex = 0

End Select

Exit Sub

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Man_Cmb " & Err.Number
Resume Next

End Sub
Public Sub Man_Lad()
On Error GoTo DaErr
'Füllt das Adressformular mit Informationen

Dim SQL1 As String
Dim IdxWe As Long
Dim RetWe As Long
Dim IdxNr As Long
Dim StaRa As Long
Dim SuStr As String
Dim TagWe As String
Dim RcStr As String
Dim FeBa2 As String
Dim FeBL2 As String
Dim FeKt2 As String
Dim FeIB2 As String
Dim FeBem As String
Dim IdRa1 As Integer
Dim IdRa2 As Integer
Dim MaxTe As Integer
Dim MaxPa As Integer
Dim Vorla As Integer
Dim BuRad As Integer
Dim Notif As Integer
Dim AktZa As Integer
Dim LiIdx As Integer
Dim StaKa As Integer
Dim Mld1, Tit1 As String

Dim CmBrs As XtremeCommandBars.CommandBars
Dim ChTeSp As XtremeSuiteControls.CheckBox
Dim cmRas1 As XtremeSuiteControls.ComboBox
Dim cmRas2 As XtremeSuiteControls.ComboBox
Dim cmMaxT As XtremeSuiteControls.ComboBox
Dim cmMaxP As XtremeSuiteControls.ComboBox
Dim cmVorl As XtremeSuiteControls.ComboBox
Dim cmBuRa As XtremeSuiteControls.ComboBox
Dim cmNoti As XtremeSuiteControls.ComboBox
Dim cmFach As XtremeSuiteControls.ComboBox
Dim cmLand As XtremeSuiteControls.ComboBox
Dim cmBuLa As XtremeSuiteControls.ComboBox
Dim cmKVBz As XtremeSuiteControls.ComboBox
Dim cmKant As XtremeSuiteControls.ComboBox
Dim cmKata As XtremeSuiteControls.ComboBox
Dim cmKett As XtremeSuiteControls.ComboBox
Dim cmKet2 As XtremeSuiteControls.ComboBox
Dim cmRahm As XtremeSuiteControls.ComboBox
Dim cmKont As XtremeSuiteControls.ComboBox
Dim cmKon2 As XtremeSuiteControls.ComboBox
Dim cmGeK1 As XtremeSuiteControls.ComboBox
Dim cmGeK2 As XtremeSuiteControls.ComboBox
Dim cmStKt As XtremeSuiteControls.ComboBox
Dim cmReTy As XtremeSuiteControls.ComboBox
Dim cmSteu As XtremeSuiteControls.ComboBox

Set FM = frmMandant
Set CmBrs = FM.comBar01
Set cmLand = FM.txtS1F12
Set ChTeSp = FM.chkKaAus
Set cmFach = FM.cmbKatal
Set cmBuLa = FM.cmbBuLnd
Set cmKVBz = FM.cmbAbrBz
Set cmKant = FM.cmbKanto
Set cmRas1 = FM.cmbRast1
Set cmRas2 = FM.cmbRast2
Set cmMaxT = FM.cmbMaxTe
Set cmMaxP = FM.cmbMaxPa
Set cmVorl = FM.cmbVorla
Set cmBuRa = FM.cmbBuRad
Set cmNoti = FM.cmbNotVa
Set cmKata = FM.cmbGbKat
Set cmKett = FM.cmbGbKet
Set cmKet2 = FM.cmbGbKe2
Set cmRahm = FM.cmbKtoRa
Set cmKont = FM.cmbKtoEr
Set cmKon2 = FM.cmbKtoEk
Set cmGeK1 = FM.cmbGeKt1
Set cmGeK2 = FM.cmbGeKt2
Set cmStKt = FM.cmbKtoSt
Set cmReTy = FM.cmbReTyp
Set cmSteu = FM.cmbSteue
Set TxBa2 = FM.txtBank2
Set TxBL2 = FM.txtBLZ02
Set TxKt2 = FM.txtKont2
Set TxIB2 = FM.txtIBAN2
Set TxBem = FM.txtS3F02
Set CmSta = CmBrs.StatusBar

GlAdN = False

Set RS40 = New ADODB.Recordset
RS40.CursorLocation = adUseClient
Set RS40 = DBCmRe1("qryAdrIdx", "@IdxNr", GlMId)

If RS40.RecordCount > 0 Then
    If RS40.Fields("StaGeb").Value > 0 Then
        StaKa = RS40.Fields("StaGeb").Value
    Else
        If GlStK > UBound(GlGKa) Then 'Gebührenkataloge
            StaKa = GlGKa(1, 0)
        Else
            StaKa = GlStK
        End If
    End If
    If RS40.Fields("StaRam").Value > 0 Then
        StaRa = RS40.Fields("StaRam").Value
    Else
        StaRa = GlKtR
    End If

    If GlMVo = True Then 'mandantenbezogene Vorgaben verwenden
        Man_Cmb 1, StaRa
        Man_Cmb 2, StaKa
        DoEvents
    End If

    For Each AktCo In FM.Controls
        If AktCo.Tag <> vbNullString Then
            Select Case Left$(AktCo.Name, 3)
            Case "txt": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                        If Not IsNull(RS40.Fields(TagWe).Value) Then
                            AktCo.Text = RS40.Fields(TagWe).Value
                            AktCo.Tag = 0 & TagWe
                        End If
            Case "cmb": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                        If Not IsNull(RS40.Fields(TagWe).Value) Then
                            Select Case AktCo.Name
                            Case "cmbS1F10":
                                SuStr = RS40.Fields(TagWe).Value
                            Case "cmbReTyp":
                                Select Case Left$(RS40.Fields(TagWe).Value, 1)
                                Case "R": LiIdx = 0
                                Case "L": LiIdx = 1
                                Case "A": LiIdx = 2
                                Case "M": LiIdx = 3
                                Case "G": LiIdx = 4
                                Case "I": LiIdx = 5
                                End Select
                                If AktCo.ListCount > 0 Then
                                    RetWe = SendMessage(AktCo.hwnd, CB_SETCURSEL, LiIdx, ByVal 0&)
                                End If
                            Case Else:
                                IdxWe = RS40.Fields(TagWe).Value
                                Select Case AktCo.Name
                                Case "cmbS1F06": IdxNr = Adr_Cm(AktCo, IdxWe)
                                Case "cmbS1F07": IdxNr = Adr_Cm(AktCo, IdxWe)
                                Case "cmbS2F07": IdxNr = Adr_Cm(AktCo, IdxWe)
                                Case "cmbS2F09": IdxNr = Adr_Cm(AktCo, IdxWe)
                                Case "cmbS2F10": IdxNr = Adr_Cm(AktCo, IdxWe)
                                Case "cmbGbKat": IdxNr = Adr_Cm(AktCo, IdxWe)
                                Case "cmbGbKet": IdxNr = Adr_Cm(AktCo, IdxWe)
                                Case "cmbGbKe2": IdxNr = Adr_Cm(AktCo, IdxWe)
                                Case "cmbKtoRa": IdxNr = Adr_Cm(AktCo, IdxWe)
                                Case "cmbSteue": IdxNr = Adr_Cm(AktCo, IdxWe)
                                Case "cmbKtoEr": IdxNr = Adr_Cm(AktCo, IdxWe)
                                Case "cmbKtoEk": IdxNr = Adr_Cm(AktCo, IdxWe)
                                Case "cmbGeKt1": IdxNr = Adr_Cm(AktCo, IdxWe)
                                Case "cmbGeKt2": IdxNr = Adr_Cm(AktCo, IdxWe)
                                Case "cmbKtoSt": IdxNr = Adr_Cm(AktCo, IdxWe)
                                Case "txtS1F12":
                                        SuStr = RS40.Fields(TagWe).Value
                                        For AktZa = 1 To UBound(GlLan)
                                            If GlLan(AktZa, 1) = SuStr Then
                                                IdxNr = AktZa - 1
                                                Exit For
                                            End If
                                        Next AktZa
                                Case "txtS2F22":
                                        SuStr = RS40.Fields(TagWe).Value
                                        For AktZa = 1 To UBound(GlLan)
                                            If GlLan(AktZa, 1) = SuStr Then
                                                IdxNr = AktZa - 1
                                                Exit For
                                            End If
                                        Next AktZa
                                Case "cmbKatal":
                                        If RS40.Fields(TagWe).Value <> vbNullString Then
                                            IdxNr = RS40.Fields(TagWe).Value - 1
                                            If IdxNr > UBound(GlFch) Then
                                                IdxNr = 1
                                            End If
                                        Else
                                            IdxNr = 1
                                        End If
                                Case Else:
                                        IdxNr = RS40.Fields(TagWe).Value
                                End Select
                                If AktCo.ListCount > 0 Then
                                    RetWe = SendMessage(AktCo.hwnd, CB_SETCURSEL, IdxNr, ByVal 0&)
                                End If
                            End Select
                            AktCo.Tag = 0 & TagWe
                        Else
                            Select Case AktCo.Name
                            Case "cmbGbKat":
                                    If cmKata.ListCount > 0 Then
                                        If GlStK <= cmKata.ListCount Then 'Standardgebührenkatalog
                                            cmKata.ListIndex = GlStK - 1
                                        Else
                                            cmKata.ListIndex = 0
                                        End If
                                    End If
                            Case "cmbGbKet":
                                    If cmKett.ListCount > 0 Then 'Standardgebührenkette 1
                                        If GlKe1 <= cmKett.ListCount Then
                                            cmKett.ListIndex = GlKe1 - 1
                                        Else
                                            cmKett.ListIndex = 0
                                        End If
                                    End If
                            Case "cmbGbKe2":
                                    If cmKet2.ListCount > 0 Then 'Standardgebührenkette 2
                                        If GlKe2 <= cmKet2.ListCount Then
                                            cmKet2.ListIndex = GlKe2 - 1
                                        Else
                                            cmKet2.ListIndex = 0
                                        End If
                                    End If
                            Case "cmbKtoRa":
                                    If cmRahm.ListCount > 0 Then
                                        If GlKtR <= cmRahm.ListCount Then
                                            cmRahm.ListIndex = GlKtR - 1
                                        Else
                                            cmRahm.ListIndex = 0
                                        End If
                                    End If
                            Case "cmbReTyp":
                                    If cmReTy.ListCount > 0 Then
                                        Select Case GlReT 'Standardbelegtyp
                                        Case "R": LiIdx = 0
                                        Case "L": LiIdx = 1
                                        Case "A": LiIdx = 2
                                        Case "M": LiIdx = 3
                                        Case "G": LiIdx = 4
                                        Case "I": LiIdx = 5
                                        End Select
                                        cmReTy.ListIndex = LiIdx
                                    End If
                            Case "cmbSteue":
                                    If cmSteu.ListCount > 0 Then
                                        cmSteu.ListIndex = GlStS - 1
                                    End If
                            Case "cmbGeKt1":
                                    If cmGeK1.ListCount > 0 Then
                                        cmGeK1.ListIndex = GlGkB - 1
                                    End If
                            Case "cmbGeKt2":
                                    If cmGeK2.ListCount > 0 Then
                                        cmGeK2.ListIndex = GlGkK - 1
                                    End If
                            Case "cmbKtoEr":
                                    If cmKont.ListCount > 0 Then
                                        cmKont.ListIndex = SCmb(cmKont, GlSE2) 'Standarderlöskonto Bankkonto
                                    End If
                            Case "cmbKtoEk":
                                    If cmKon2.ListCount > 0 Then
                                        cmKon2.ListIndex = SCmb(cmKon2, GlSE1) 'Standarderlöskonto Kasse
                                    End If
                            Case "cmbKtoSt":
                                    If cmStKt.ListCount > 0 Then
                                        cmStKt.ListIndex = SCmb(cmStKt, GlSKo) 'Standardsteuerkonto
                                    End If
                            End Select
                        End If
            Case "chk": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                        If CBool(RS40.Fields(TagWe).Value) = True Then
                            AktCo.Value = 1
                            AktCo.Tag = 0 & TagWe
                            If TagWe = "OnlTer" Then
                                ChTeSp.Enabled = False 'ausblenden wenn OTS aktiviert
                            End If
                        End If
            Case "msk": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                        If Not IsNull(RS40.Fields(TagWe).Value) Then
                            AktCo.Text = RS40.Fields(TagWe).Value
                            AktCo.Tag = 0 & TagWe
                        End If
            End Select
        End If
    Next AktCo
    
    CmSta.Pane(0).Text = "Nr.: " & Format$(RS40.Fields("ID0").Value, "000000")
    If Not IsNull(RS40.Fields("Geboren").Value) Then CmSta.Pane(1).Text = "Alter: " & AJahr(RS40.Fields("Geboren").Value) & " Jahre"
    If Not IsNull(RS40.Fields("Datum").Value) Then CmSta.Pane(2).Text = "Ersteintrag: " & RS40.Fields("Datum").Value
    If Not IsNull(RS40.Fields("Geändert").Value) Then CmSta.Pane(3).Text = "Aktualisierung: " & RS40.Fields("Geändert").Value

    If Not IsNull(RS40.Fields("OnlRas").Value) Then
        IdRa1 = CInt(RS40.Fields("OnlRas").Value)
    Else
        IdRa1 = GlZeR 'Zeitrasterindex
    End If
    If Not IsNull(RS40.Fields("OnlRa2").Value) Then
        IdRa2 = CInt(RS40.Fields("OnlRa2").Value)
    Else
        IdRa2 = GlZeR 'Zeitrasterindex
    End If
    If Not IsNull(RS40.Fields("OnlMax").Value) Then
        MaxTe = CInt(RS40.Fields("OnlMax").Value)
    Else
        MaxTe = 0 'Anzahl maximal buchbarer Termine pro Tag
    End If
    If Not IsNull(RS40.Fields("OnlMa2").Value) Then
        MaxPa = CInt(RS40.Fields("OnlMa2").Value)
    Else
        MaxPa = 1 'Anzahl maximal buchbarer Termine pro Patient und Tag
    End If
    If Not IsNull(RS40.Fields("OnlVor").Value) Then
        Vorla = CInt(RS40.Fields("OnlVor").Value)
    Else
        Vorla = 2 'Vorlaufzeit
    End If
    If Not IsNull(RS40.Fields("OnlRa1").Value) Then
        BuRad = CInt(RS40.Fields("OnlRa1").Value)
    Else
        BuRad = 12 'Buchungsradius
    End If
    If Not IsNull(RS40.Fields("OnlTmp").Value) Then
        Notif = CInt(RS40.Fields("OnlTmp").Value)
    Else
        Notif = 24 'Benachrichtigung
    End If

    If IdRa1 <= 0 Then
        IdRa1 = GlZeR 'Zeitrasterindex
    End If
    If IdRa2 <= 0 Then
        IdRa2 = GlZeR 'Zeitrasterindex
    End If
    
    If MaxTe < 0 Then MaxTe = 0
    If MaxPa < 0 Then MaxPa = 0
    If Vorla < 1 Then Vorla = 1
    If BuRad < 1 Then Vorla = 1

    For AktZa = 0 To UBound(GlTku) - 1
        If cmRas1.ItemData(AktZa) = IdRa1 Then
            cmRas1.ListIndex = AktZa
        End If
    Next AktZa

    For AktZa = 0 To UBound(GlTku) - 1
        If cmRas2.ItemData(AktZa) = IdRa2 Then
            cmRas2.ListIndex = AktZa
        End If
    Next AktZa

    cmMaxT.ListIndex = MaxTe
    cmMaxP.ListIndex = MaxPa
    cmVorl.ListIndex = Vorla - 1
    cmBuRa.ListIndex = BuRad - 1
    cmNoti.ListIndex = Notif
Else
    Mld1 = "Der Datensatz konnte nicht geöffnet werden"
    Tit1 = "Kein Datenzugriff möglich"
    WindowMess Mld1, Dial3, Tit1, FM.hwnd
End If

RS40.Close
Set RS40 = Nothing

GlAdS = False

Exit Sub

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Man_Lad " & Err.Number
Resume Next

End Sub
Public Function Man_San() As Boolean
On Error GoTo DaErr
'Speichert den Inhalt des Adressformulars bei Neuanlage einer Adresse

Dim IdxNr As Long
Dim ZeiAr As String
Dim ZeiBu As String
Dim TagWe As String
Dim Recht As String
Dim TmGui As String
Dim IdRa1 As Integer
Dim IdRa2 As Integer
Dim MaxTe As Integer
Dim MaxPa As Integer
Dim TmIdx As Integer
Dim Vorla As Integer
Dim BuRad As Integer
Dim Notif As Integer
Dim TxZei1 As XtremeSuiteControls.FlatEdit
Dim TxZei2 As XtremeSuiteControls.FlatEdit
Dim cmRas1 As XtremeSuiteControls.ComboBox
Dim cmRas2 As XtremeSuiteControls.ComboBox
Dim cmMaxT As XtremeSuiteControls.ComboBox
Dim cmMaxP As XtremeSuiteControls.ComboBox
Dim cmVorl As XtremeSuiteControls.ComboBox
Dim cmBuRa As XtremeSuiteControls.ComboBox
Dim cmNoti As XtremeSuiteControls.ComboBox
Dim cmFach As XtremeSuiteControls.ComboBox
Dim cmKata As XtremeSuiteControls.ComboBox
Dim cmKett As XtremeSuiteControls.ComboBox
Dim cmKet2 As XtremeSuiteControls.ComboBox
Dim cmRahm As XtremeSuiteControls.ComboBox
Dim cmKont As XtremeSuiteControls.ComboBox
Dim cmKon2 As XtremeSuiteControls.ComboBox
Dim cmGeK1 As XtremeSuiteControls.ComboBox
Dim cmGeK2 As XtremeSuiteControls.ComboBox
Dim cmReTy As XtremeSuiteControls.ComboBox
Dim cmSteu As XtremeSuiteControls.ComboBox
Dim PrItm As XtremePropertyGrid.PropertyGridItem
Dim PrKat As XtremePropertyGrid.PropertyGridItem
Dim PrIts As XtremePropertyGrid.PropertyGridItems
Dim PrBol As XtremePropertyGrid.PropertyGridItemBool
Dim PrDat As XtremePropertyGrid.PropertyGridItemDate
Dim RpCo5 As XtremeReportControl.ReportControl

Set FM = frmMandant
Set cmFach = FM.cmbKatal
Set cmRas1 = FM.cmbRast1
Set cmRas2 = FM.cmbRast2
Set cmMaxT = FM.cmbMaxTe
Set cmMaxP = FM.cmbMaxPa
Set cmVorl = FM.cmbVorla
Set cmBuRa = FM.cmbBuRad
Set cmNoti = FM.cmbNotVa
Set cmKata = FM.cmbGbKat
Set cmKett = FM.cmbGbKet
Set cmKet2 = FM.cmbGbKe2
Set cmRahm = FM.cmbKtoRa
Set cmKont = FM.cmbKtoEr
Set cmKon2 = FM.cmbKtoEk
Set cmGeK1 = FM.cmbGeKt1
Set cmGeK2 = FM.cmbGeKt2
Set cmReTy = FM.cmbReTyp
Set cmSteu = FM.cmbSteue
Set TxZei1 = FM.txtZeit1
Set TxZei2 = FM.txtZeit2
Set RpCo5 = FM.repCont5
Set RpRcs = RpCo5.Records

If TxZei1.Text <> vbNullString Then
    ZeiAr = TxZei1.Text
Else
    ZeiAr = GlSZe 'Sprechzietenstring
End If

If TxZei2.Text <> vbNullString Then
    ZeiBu = TxZei2.Text
Else
    ZeiBu = GlSZe 'Sprechzietenstring
End If

If cmFach.Text <> vbNullString Then
    TmIdx = cmFach.ItemData(cmFach.ListIndex)
Else
    TmIdx = GlFri
End If

If cmRas1.Text <> vbNullString Then
    IdRa1 = cmRas1.ItemData(cmRas1.ListIndex)
Else
    IdRa1 = GlZeR 'Zeitrasterindex
End If

If cmRas2.Text <> vbNullString Then
    IdRa2 = cmRas2.ItemData(cmRas2.ListIndex)
Else
    IdRa2 = GlZeR 'Zeitrasterindex
End If

If cmMaxT.Text <> vbNullString Then
    MaxTe = cmMaxT.ItemData(cmMaxT.ListIndex)
Else
    MaxTe = 0
End If

If cmMaxP.Text <> vbNullString Then
    MaxPa = cmMaxP.ItemData(cmMaxP.ListIndex)
Else
    MaxPa = 1
End If

If cmVorl.Text <> vbNullString Then
    Vorla = cmVorl.ItemData(cmVorl.ListIndex)
Else
    Vorla = 2
End If

If cmBuRa.Text <> vbNullString Then
    BuRad = cmBuRa.ItemData(cmBuRa.ListIndex)
Else
    BuRad = 12
End If
If cmNoti.Text <> vbNullString Then
    Notif = cmNoti.ItemData(cmNoti.ListIndex)
Else
    Notif = 24
End If

TmGui = CreateID("M")

Set RS40 = New ADODB.Recordset
With RS40
    .CursorLocation = adUseClient
    .Source = "qryAdrNeu"
    .ActiveConnection = DB1
    .CursorType = adOpenKeyset
    .LockType = adLockOptimistic
    .Open Options:=adCmdTableDirect
End With
If RS40.Supports(adAddNew) Then
    RS40.AddNew
    For Each AktCo In FM.Controls
        If AktCo.Tag <> vbNullString Then
            Select Case Left$(AktCo.Name, 3)
            Case "txt":     TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                            Select Case AktCo.Name
                            Case "txtS1F33":
                                    If AktCo.Text = vbNullString Then
                                        RS40.Fields(TagWe).Value = Null
                                    Else
                                        RS40.Fields(TagWe).Value = Replace(AktCo.Text, ",", ".", 1)
                                    End If
                            Case "txtS1F13":
                                    If InStr(1, "_", AktCo.Text, vbTextCompare) = 0 Then
                                        If IsDate(AktCo.Text) Then
                                            RS40.Fields(TagWe).Value = DateValue(AktCo.Text)
                                        End If
                                    End If
                            Case "txtS2F25":
                                    If InStr(1, "_", AktCo.Text, vbTextCompare) = 0 Then
                                        If IsDate(AktCo.Text) Then
                                            RS40.Fields(TagWe).Value = DateValue(AktCo.Text)
                                        End If
                                    End If
                            Case "txtS2F27":
                                    If InStr(1, "_", AktCo.Text, vbTextCompare) = 0 Then
                                        If IsDate(AktCo.Text) Then
                                            RS40.Fields(TagWe).Value = DateValue(AktCo.Text)
                                        End If
                                    End If
                            Case "txtZSRnr":
                                    If AktCo.Text = vbNullString Then
                                        RS40.Fields(TagWe).Value = Null
                                    Else
                                        If Len(AktCo.Text) > 7 Then
                                            RS40.Fields(TagWe).Value = Left$(AktCo.Text, 7)
                                        Else
                                            RS40.Fields(TagWe).Value = Trim$(AktCo.Text)
                                        End If
                                    End If
                            Case "txtGLNum":
                                    If AktCo.Text = vbNullString Then
                                        RS40.Fields(TagWe).Value = Null
                                    Else
                                        If Len(AktCo.Text) > 20 Then
                                            RS40.Fields(TagWe).Value = Left$(AktCo.Text, 20)
                                        Else
                                            RS40.Fields(TagWe).Value = Trim$(AktCo.Text)
                                        End If
                                    End If
                            Case Else:
                                    If AktCo.Text = vbNullString Then
                                        RS40.Fields(TagWe).Value = Null
                                    Else
                                        RS40.Fields(TagWe).Value = Trim$(AktCo.Text)
                                    End If
                            End Select
                            If GlMId > -3 Then
                                AktCo.Tag = 0 & TagWe 'Damit diese Funktion zweimal ausgeführt werden kann
                            End If
            Case "cmb":     TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                            Select Case AktCo.Name
                            Case "cmbS1F10":
                                    RS40.Fields(TagWe).Value = AktCo.Text
                            Case "cmbReTyp":
                                    RS40.Fields(TagWe).Value = Left$(AktCo.Text, 1)
                            Case Else:
                                    If AktCo.Text <> vbNullString Then
                                        RS40.Fields(TagWe).Value = AktCo.ItemData(AktCo.ListIndex)
                                    Else
                                        RS40.Fields(TagWe).Value = AktCo.ItemData(0)
                                    End If
                            End Select
                            If GlMId > -3 Then
                                AktCo.Tag = 0 & TagWe 'Damit diese Funktion zweimal ausgeführt werden kann
                            End If
            Case "chk":     TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                            RS40.Fields(TagWe).Value = AktCo.Value
                            AktCo.Tag = 0 & TagWe
            Case "msk":     TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                            If IsDate(AktCo.Text) Then
                                RS40.Fields(TagWe).Value = Trim$(AktCo.Text)
                            Else
                                RS40.Fields(TagWe).Value = Null
                            End If
                            If GlMId > -3 Then
                                AktCo.Tag = 0 & TagWe 'Damit diese Funktion zweimal ausgeführt werden kann
                            End If
            End Select
        End If
    Next AktCo

    Select Case GlBut
    Case RibTab_Mandanten:
            Select Case GlMId
            Case -2: RS40.Fields("VIP").Value = -1
            Case -3: RS40.Fields("Mitarbeiter").Value = -1
            Case Else: RS40.Fields("VIP").Value = -1
            End Select
    Case RibTab_Verordner:
            Select Case GlMId
            Case -2: RS40.Fields("VIP").Value = -1
            Case -3: RS40.Fields("Mitarbeiter").Value = -1
            Case Else: RS40.Fields("Arzt").Value = -1
            End Select
    Case RibTab_Mitarbeit:
            Select Case GlMId
            Case -2: RS40.Fields("VIP").Value = -1
            Case -3: RS40.Fields("Mitarbeiter").Value = -1
            Case Else: RS40.Fields("Mitarbeiter").Value = -1
            End Select
    Case Else:
            Select Case GlMId
            Case -2: RS40.Fields("VIP").Value = -1
            Case -3: RS40.Fields("Mitarbeiter").Value = -1
            Case Else: RS40.Fields("VIP").Value = -1
            End Select
    End Select

    For Each RpRec In RpRcs
        If RpRec.Item(0).Checked = True Then
            Recht = Recht & "1"
        Else
            Recht = Recht & "0"
        End If
    Next RpRec
    
    RS40.Fields("IDZ").Value = 1
    RS40.Fields("Kopien").Value = 1
    RS40.Fields("Datum").Value = Date
    RS40.Fields("GuiID").Value = GlAdG
    RS40.Fields("Geändert").Value = Date
    RS40.Fields("OnlVor").Value = Vorla 'Vorlaufzeit für Terminbuchung
    RS40.Fields("OnlRas").Value = IdRa1
    RS40.Fields("OnlRa2").Value = IdRa2
    RS40.Fields("OnlRa1").Value = BuRad
    RS40.Fields("OnlTmp").Value = Notif
