Public Sub Ter_Akt(ByVal TerNr As Long, ByVal MasTe As Long)
On Error GoTo GrErr
'Aktualisiert die Terminsummen

Dim TeSum As Single
Dim SeSum As Single

Set RS40 = New ADODB.Recordset
RS40.CursorLocation = adUseClient
Set RS40 = DBCmRe1("qryAnKa1d", "@IdxNr", TerNr) 'Summe aller Leistungen einer Termins ermitteln
If RS40.RecordCount > 0 Then
    TeSum = RS40.Fields("Preis2").Value
Else
    TeSum = 0
End If
RS40.Close
Set RS40 = Nothing

DoEvents
DBCmEx2 "qryTerSum1", "@IdBet", "@IdxNr", TeSum, TerNr 'Summe speichern in Gesamtbetrag des Termins
DoEvents

If MasTe > 0 Then
    Set RS41 = New ADODB.Recordset
    RS41.CursorLocation = adUseClient
    Set RS41 = DBCmRe1("qryAnKa1n", "@IdxNr", MasTe) 'Summe aller Leistungen der gesamten Serie
    If RS41.RecordCount > 0 Then
        SeSum = RS41.Fields("Preis2").Value
    Else
        SeSum = 0
    End If
    RS41.Close
    Set RS41 = Nothing
End If

DoEvents
If MasTe > 0 Then
    DBCmEx2 "qryTerSum3", "@IdBet", "@IdxNr", SeSum, MasTe
Else
    DBCmEx2 "qryTerSum2", "@IdBet", "@IdxNr", TeSum, TerNr
End If

Exit Sub

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_Akt " & Err.Number
Resume Next

End Sub
