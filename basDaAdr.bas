Dim AktPo As Long
Dim GesZa As Long
Dim PatNa As String
Dim Frage As Integer
Dim Mld1, Tit1 As String

Set FM = frmStatus

If GlDat = False Then Exit Sub

If GlAdF = True Then
    SQL1 = "qrySimAdMai"
Else
    SQL1 = "qryAdress"
End If

StMan = GlMan(GlSMa, 2)

Tit1 = "Geburtstage"
Mld1 = "Möchten Sie nun neue Wiedervorlageeinträge der Geburtstage für das laufende Kalenderjahr generieren lassen?"

Frage = WindowMess(Mld1, Dial1, Tit1, frmMain.hwnd)
If Frage = 6 Then

    Set RS82 = New ADODB.Recordset
    With RS82
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdText
    End With
    
    Set RS81 = New ADODB.Recordset
    With RS81
        .CursorLocation = adUseClient
        .Source = "qryTerNeu"
        .ActiveConnection = DB1
        .CursorType = adOpenKeyset
        .LockType = adLockOptimistic
        .Open Options:=adCmdTableDirect
    End With
    GesZa = RS82.RecordCount
    
    If GesZa > 0 Then
        If RS81.Supports(adUpdate) = True Then
            Set PrBr1 = FM.prbStat1
            Set PrBr2 = FM.prbStat2
            FM.Caption = "Wiedervorlage..."
            
            PrBr1.Min = 0
            PrBr1.Max = GesZa
            FM.Show
            DoEvents
                
            Do
            AktPo = AktPo + 1
            PrBr1.Value = AktPo
            PrBr2.Value = AktPo
            If RS82.Fields("Geboren").Value <> vbNullString Then
                PatNr = RS82.Fields("ID0").Value
                PatNa = RS82.Fields("IDKurz").Value
                PatGe = RS82.Fields("Geboren").Value
                NeuDa = Format$(DatePart("d", PatGe, vbMonday), "00") & "." & Format$(DatePart("m", PatGe, vbMonday), "00") & "." & DatePart("yyyy", Date, vbMonday)
                
                RS81.AddNew
                RS81.Fields("VonDat").Value = Format$(NeuDa, "dd.mm.yyyy")
                RS81.Fields("BisDat").Value = Format$(NeuDa, "dd.mm.yyyy")
                If GlTyp < 2 Then
                    RS81.Fields("ZeiVon").Value = Format$(NeuDa, "dd.mm.yyyy") & Chr$(32) & "12:00:00"
                    RS81.Fields("ZeiBis").Value = Format$(NeuDa, "dd.mm.yyyy") & Chr$(32) & "12:00:00"
                Else
                    RS81.Fields("ZeiVon").Value = "12:00:00"
                    RS81.Fields("ZeiBis").Value = "12:00:00"
                End If
                RS81.Fields("IDKurz").Value = "Geburtstagserinnerung"
                RS81.Fields("Patient").Value = PatNa
