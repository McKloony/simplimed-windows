Private Function Adr_Rch(ByVal ReNum As Long, ByVal ReBet As Single) As Boolean
On Error GoTo LiErr
'Passt den Rechnungsbetrag an

Dim RowNr As Long
Dim GeSum As Double
Dim AnSum As Double
Dim BeBet As Double
Dim ReRab As Double
Dim RaBet As Double
Dim ReAbg As Boolean
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmMain
Set RpCo3 = FM.repCont3
Set RpCls = RpCo3.Columns
Set RpSel = RpCo3.SelectedRows

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    RowNr = RpRow.Index
    Set RpCol = RpCls.Find(Rec_Selekt)
    ReAbg = CBool(RpRow.Record(RpCol.ItemIndex).Value)
    Set RpCol = RpCls.Find(Rec_Bezahlt)
    BeBet = Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1)
    Set RpCol = RpCls.Find(Rec_Rabatt)
    ReRab = Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1)
    ReBet = Format$(ReBet, GlWa1)
    
    Set RS43 = New ADODB.Recordset
    RS43.CursorLocation = adUseClient
    If GlIgL = True Then 'Keine Preisberechnung bei IgL
        Set RS43 = DBCmRe1("qrySimAbSm1", "@IdxNr", ReNum)
    Else
        Set RS43 = DBCmRe1("qrySimAbSm", "@IdxNr", ReNum)
    End If
    If RS43.RecordCount > 0 Then
        If RS43("VK").Value <> 0 Then
            If ReRab > 0 Then
                RaBet = Format$(RS43("VK").Value * ReRab / 100, GlWa1)
                GeSum = Format$(RS43("VK").Value - RaBet, GlWa1)
            Else
                RaBet = 0
                GeSum = Format$(RS43("VK").Value, GlWa1)
            End If
        Else
            GeSum = Format$(0, GlWa1)
        End If
        If RS43("WV").Value > 0 Then
            AnSum = Format$(RS43("WV").Value, GlWa1)
        Else
            AnSum = Format$(0, GlWa1)
        End If
        If GeSum <> ReBet Then
            DBCmEx2 "qrySimReSm1", "@IdBet", "@IdxNr", GeSum, ReNum
            If ReAbg = True Then
                If ReNum > 0 Then
                    DBCmEx2 "qrySimOPAn3", "@Betra", "@IdxNr", GeSum, ReNum
                    DBCmEx2 "qrySimOPAn4", "@Betra", "@IdxNr", GeSum, ReNum
                    DBCmEx2 "qrySimBuAn", "@Betra", "@IdxNr", GeSum, ReNum
                End If
            End If
        End If
        If AnSum <> BeBet Then
            DBCmEx2 "qrySimReSm3", "@IdBet", "@IdxNr", AnSum, ReNum
        End If
        If GeSum >= GlObG Then
            Adr_Rch = True
        End If
    Else
        GeSum = Format$(0, GlWa1)
        AnSum = Format$(0, GlWa1)
        If GeSum <> ReBet Then
            DBCmEx2 "qrySimReSm1", "@IdBet", "@IdxNr", GeSum, ReNum
            If ReAbg = True Then
                If ReNum > 0 Then
                    DBCmEx2 "qrySimOPAn3", "@Betra", "@IdxNr", GeSum, ReNum
                    DBCmEx2 "qrySimOPAn4", "@Betra", "@IdxNr", GeSum, ReNum
                    DBCmEx2 "qrySimBuAn", "@Betra", "@IdxNr", GeSum, ReNum
                End If
            End If
        End If
        If AnSum <> BeBet Then
            DBCmEx2 "qrySimReSm3", "@IdBet", "@IdxNr", AnSum, ReNum
        End If
    End If
    RS43.Close
    Set RS43 = Nothing
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing

Exit Function

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Adr_Rch " & Err.Number
Resume Next

End Function

