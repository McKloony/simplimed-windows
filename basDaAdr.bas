    TmpMa = CmMta.ItemData(CmMta.ListIndex)
Else
    TmpMa = CmMan.ItemData(CmMan.ListIndex)
End If

If TxID0.Text <> vbNullString Then
    If IsNumeric(TxID0.Text) Then
        PatNr = CLng(TxID0.Text)
    Else
        PatNr = 0
    End If
Else
    PatNr = 0
End If

If TxBeG.Text <> vbNullString Then
    If IsNumeric(TxBeG.Text) Then
        Behin = CInt(TxBeG.Text)
    Else
        Behin = 0
    End If
Else
    Behin = 0
End If

If CmBet.Text <> vbNullString Then
    If TxAdr.Text <> vbNullString Then
        TeBtr = TxAdr.Text & " - " & CmBet.Text
    Else
        TeBtr = CmBet.Text
    End If
ElseIf TxAdr.Text <> vbNullString Then
    TeBtr = TxAdr.Text
End If

Set TxDa5 = FM.txtDatu5
