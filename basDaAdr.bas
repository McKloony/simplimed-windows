Public Sub Ter_Zei(Optional ByVal RmuNr As Long)
On Error GoTo KoErr
'Überprüft, ob am neu eingestellten Datem, freite Zeiten sind

Dim TmpMa As Long 'Mandant
Dim TmpRa As Long 'Raum
Dim AdMin As Long
Dim StaDa As Date
Dim FreZe As Date
Dim StaZe As Date
Dim EndZe As Date
Dim RoSta As Date
Dim RoEnd As Date
Dim Behin As Integer
Dim TeDop As Boolean
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmTermVo
Set CmRmu = FM.cmbRaum1
Set CmMan = FM.cmbBehan
Set CmMta = FM.cmbMitar
Set TxBeG = FM.txtBehin
Set TxZeV = FM.txtVonZe
Set TxZeB = FM.txtBisZe
Set RpCo6 = FM.repCont6
Set RpCls = RpCo6.Columns
Set RpSel = RpCo6.SelectedRows

TmpRa = CmRmu.ItemData(CmRmu.ListIndex)
If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
    TmpMa = CmMta.ItemData(CmMta.ListIndex)
Else
    TmpMa = CmMan.ItemData(CmMan.ListIndex)
End If
StaZe = TimeValue(TxZeV.Text)
EndZe = TimeValue(TxZeB.Text)
AdMin = DateDiff("n", TimeValue(StaZe), TimeValue(EndZe))
If TxBeG.Text <> vbNullString Then
    If IsNumeric(TxBeG.Text) Then
        Behin = CInt(TxBeG.Text)
    Else
        Behin = 0
    End If
Else
    Behin = 0
End If

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        Set RpCol = RpCls.Find(2)
        If IsDate(RpRow.Record(RpCol.ItemIndex).Value) = True Then
            StaDa = CDate(RpRow.Record(RpCol.ItemIndex).Value)
            Set RpCol = RpCls.Find(3)
            RoSta = TimeValue(RpRow.Record(RpCol.ItemIndex).Value)
            Set RpCol = RpCls.Find(4)
            RoEnd = TimeValue(RpRow.Record(RpCol.ItemIndex).Value)

            TeDop = Ter_Pru(StaDa, RoSta, RoEnd, RmuNr, Behin, TmpMa)
            If TeDop = True Then
                Set RpCol = RpCls.Find(6)
                RpRow.Record(RpCol.ItemIndex).Value = FaNeg
            Else
                Set RpCol = RpCls.Find(6)
                If RoSta = StaZe Then
                    RpRow.Record(RpCol.ItemIndex).Value = vbWhite
                Else
                    RpRow.Record(RpCol.ItemIndex).Value = FaMan
                End If
            End If
        End If
    End If
End If

RpCo6.Populate

Set RpCo6 = Nothing
Set RpCls = Nothing
Set RpSel = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_Zei " & Err.Number
Resume Next

End Sub
