Public Sub Kon_Lad(ByVal IdStr As String)
On Error GoTo DaErr
'Füllt das Kontaktformular mit Informationen

Dim RetWe As Long
Dim IdxWe As Long
Dim AkTim As Date
Dim TagWe As String
Dim AktZa As Integer

Set FS = frmKontakt
Set TxDa1 = FS.txtDatum
Set TxZeV = FS.txtVonZe
Set TxZeB = FS.txtBisZe

GlKoN = False

If GlAId > 0 Then
    Set RS30 = New ADODB.Recordset
    RS30.CursorLocation = adUseClient
    Set RS30 = DBCmRe1("qryKontakt", "@IdStr", IdStr)

    If RS30.RecordCount > 0 Then
        For Each AktCo In FS.Controls
            If AktCo.Tag <> vbNullString Then
                Select Case Left$(AktCo.Name, 3)
                Case "txt": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                            If Not IsNull(RS30.Fields(TagWe).Value) Then
                                AktCo.Text = RS30.Fields(TagWe).Value
                                AktCo.Tag = 0 & TagWe
                            End If
                Case "cmb": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                            If Not IsNull(RS30.Fields(TagWe).Value) Then
                                IdxWe = RS30.Fields(TagWe).Value - 1
                                RetWe = SendMessage(AktCo.hwnd, CB_SETCURSEL, IdxWe, ByVal 0&)
                                AktCo.Tag = 0 & TagWe
                            End If
                Case "chk": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                            If RS30.Fields(TagWe).Value = -1 Then
                                AktCo.Value = 1
                                AktCo.Tag = 0 & TagWe
                            End If
                End Select
            End If
        Next AktCo
        
        AkTim = RS30.Fields("ZeiVon").Value
        TxZeV.Text = Format$(AkTim, "hh:mm")
        TxZeV.Tag = 0 & "ZeiVon"
        
        AkTim = RS30.Fields("ZeiBis").Value
        TxZeB.Text = Format$(AkTim, "hh:mm")
        TxZeB.Tag = 0 & "ZeiBis"

        TxDa1.Text = RS30.Fields("VonDat").Value
    End If
    
    RS30.Close
    Set RS30 = Nothing
End If
GlKoS = False

Exit Sub

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Kon_Lad " & Err.Number
Resume Next

End Sub


Public Sub Kon_Lis()
On Error GoTo DaErr
'Füllt das Reportcontrol mit Kontakten der Adresse

Dim GesZa As Long
Dim RpCon As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmAdress
Set RpCon = FM.repCont1
Set RpRcs = RpCon.Records

With RpCon
    .EditItem Nothing, Nothing
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    If .Records.Count > 0 Then .Records.DeleteAll
    .Populate
End With

If GlAId > 0 Then
    Set RS38 = New ADODB.Recordset
    RS38.CursorLocation = adUseClient
    Set RS38 = DBCmRe1("qryKonAll", "@IdxNr", GlAId)
    GesZa = RS38.RecordCount
    If GesZa > 0 Then
        Do
        Set RpRec = RpRcs.Add()
        Set RpItm = RpRec.AddItem(RS38.Fields("ID2").Value)
        Set RpItm = RpRec.AddItem(RS38.Fields("VonDat").Value)
        RpItm.Icon = IC16_Doc_Note
        Set RpItm = RpRec.AddItem(RS38.Fields("ZeiVon").Value)
        RpItm.Format = "%H:%M"
        Set RpItm = RpRec.AddItem(RS38.Fields("ZeiBis").Value)
        RpItm.Format = "%H:%M"
        Set RpItm = RpRec.AddItem(RS38.Fields("IDKurz").Value)
        Set RpItm = RpRec.AddItem("")
        If RS38.Fields("Datei").Value <> vbNullString Then
            RpItm.Icon = IC16_Paperclip
        End If
        Set RpItm = RpRec.AddItem(RS38.Fields("Behandler").Value)
        Set RpItm = RpRec.AddItem(vbNullString)
        RpItm.HasCheckbox = True
        If RS38.Fields("Erledigt").Value = -1 Then
            RpItm.Checked = True
        Else
            RpItm.Checked = False
        End If
        RpRec.Tag = RS38.Fields("ID2").Value
        If RS38.Fields("Kommentar").Value <> vbNullString Then
            RpRec.PreviewText = RS38.Fields("Kommentar").Value
        End If
        If GlKoG <> vbNullString Then
            If GlKoG = RS38.Fields("ID2").Value Then
                Set RpRes = RpRec
            End If
        End If
        RS38.MoveNext
        Loop Until RS38.EOF
    End If
    RS38.Close
    Set RS38 = Nothing
    
    If GesZa > 0 Then
        RpCon.Populate
        Set RpRws = RpCon.Rows
        RpRws.Row(0).Selected = False
    End If
End If

If GlKoG <> vbNullString Then
    RpRws.Row(0).Selected = False
    If RpRws.Count > 0 Then
        Set RpRow = RpRws.FindRow(RpRes)
        With RpRow
            .Selected = True
            .EnsureVisible
        End With
        GlKoG = vbNullString
    End If
End If

Set RpItm = Nothing
Set RpRes = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpRow = Nothing
Set RpRws = Nothing
Set RpCon = Nothing

Exit Sub

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Kon_Lis " & Err.Number
Resume Next

End Sub
Public Sub Kon_Loe(ByVal Flag As Integer)
On Error GoTo LoErr
'Löscht den aktuellen Kontakt

Dim AnzPo As Long
Dim IdStr As String
Dim FoID2 As XtremeSuiteControls.FlatEdit
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCon As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmAdress
Set RpCon = FM.repCont1
Set RpCls = RpCon.Columns
Set RpSel = RpCon.SelectedRows

If Flag = 1 Then
    Set FoID2 = frmKontakt.txtID2
End If

Tit1 = "Eintrag Entfernen"
Mld1 = "Möchten Sie den aktuellen Eintrag wirklich löschen?"
AnzPo = RpCon.Records.Count

If GlRch(0, 19) = 0 Then
    WindowMess "Sie besitzen keine Berechtigung für diesen Vorgang", Dial3, Tit1, FM.hwnd
    Exit Sub
End If

If AnzPo > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then
        Select Case Flag
        Case 1:
            IdStr = FoID2.Text
            DBCmEx1 "qryKonLoe", "@IdStr", IdStr
        Case 2:
            For Each RpRow In RpSel
                If RpRow.GroupRow = False Then
                    Set RpCol = RpCls.Find(Not_ID2)
                    IdStr = Trim$(RpRow.Record(RpCol.ItemIndex).Value)
                    DBCmEx1 "qryKonLoe", "@IdStr", IdStr
                End If
            Next RpRow
        End Select
        Kon_Lis
        GlKoS = False
    End If
End If

Set RpSel = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCon = Nothing

Exit Sub

LoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Kon_Loe " & Err.Number
Resume Next

End Sub
Public Sub Kon_San()
On Error GoTo DaErr
'Speichert den Inhalt des Kontaktformulars bei einer Neuanlage eines Kontakts

Dim NeuDa As Date
Dim TagWe As String
Dim Mld1, Tit1 As String

Set FS = frmKontakt
Set TxDa1 = FS.txtDatum
Set FeKur = FS.txtAnlaß
Set TxZeV = FS.txtVonZe
Set TxZeB = FS.txtBisZe

If IsDate(TxDa1.Text) Then
    NeuDa = TxDa1.Text
Else
    NeuDa = Date
End If

If FeKur.Text <> vbNullString Then
    If GlAId <= 0 Then
        Set RS47 = New ADODB.Recordset
        RS47.CursorLocation = adUseClient
        Set RS47 = DBCmRe1("qryAdrGui", "@IdStr", GlAdG)
        GlAId = RS47("ID0").Value
        RS47.Close
        Set RS47 = Nothing
    End If
    
    Set RS30 = New ADODB.Recordset
    With RS30
        .CursorLocation = adUseClient
        .Source = "qryKonNeu"
        .ActiveConnection = DB1
        .CursorType = adOpenKeyset
        .LockType = adLockOptimistic
        .Open Options:=adCmdTableDirect
    End With
    If RS30.Supports(adAddNew) Then
        GlKoG = CreateID("K")
        RS30.AddNew
        RS30.Fields("ID2").Value = GlKoG
        RS30.Fields("ID0").Value = GlAId
        For Each AktCo In FS.Controls
            If AktCo.Tag <> vbNullString Then
                Select Case Left$(AktCo.Name, 3)
                Case "txt": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                            If Left$(AktCo.Tag, 1) = "1" Then
                                If AktCo.Text = vbNullString Then
                                    RS30.Fields(TagWe).Value = Null
                                Else
                                    RS30.Fields(TagWe).Value = AktCo.Text
                                End If
                                AktCo.Tag = 0 & TagWe
                            End If
                Case "cmb": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                            If Left$(AktCo.Tag, 1) = "1" Then
                                If AktCo.Text <> vbNullString Then
                                    RS30.Fields(TagWe).Value = AktCo.ItemData(AktCo.ListIndex)
                                Else
                                    RS30.Fields(TagWe).Value = AktCo.ItemData(0)
                                End If
                                AktCo.Tag = 0 & TagWe
                            End If
                Case "chk": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                            If Left$(AktCo.Tag, 1) = "1" Then
                                RS30.Fields(TagWe).Value = AktCo.Value
                                AktCo.Tag = 0 & TagWe
                            End If
                End Select
            End If
        Next AktCo
        RS30.Fields("ZeiVon").Value = TxZeV.Text
        RS30.Fields("ZeiBis").Value = TxZeB.Text
        RS30.Fields("VonDat").Value = NeuDa
        RS30.Update
    End If
    RS30.Close
    Set RS30 = Nothing
    
    If GlJet = True Then SDBSav
    GlKoN = False
Else
    Mld1 = "Das Feld Suchname muß erst ausgefüllt werden, damit dieser Datensatz gespeichern werden kann"
    Tit1 = "Fehlende Angaben"
    WindowMess Mld1, Dial2, Tit1, FM.hwnd
End If

Exit Sub

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Kon_San " & Err.Number
Resume Next

End Sub

