Prior = CmPri.ItemData(CmPri.ListIndex)
TeTyp = CmTyp.ItemData(CmTyp.ListIndex)
FoFak = 1

If TxFar.Text <> vbNullString Then
    If IsNumeric(TxFar.Text) = True Then
        Farbe = CLng(TxFar.Text)
    End If
End If

If CmMar.ListIndex > 0 Then
    TeMar = CmMar.ItemData(CmMar.ListIndex)
End If

If GlMPl = True Then
    If CmMit.ListCount > 0 Then
        If CmMit.ListIndex >= 0 Then
            MaIdx = CmMit.ListIndex + 1
        Else
            MaIdx = GlSmI
        End If
    Else
        MaIdx = GlSmI
    End If
Else
    If CmMan.ListCount > 0 Then
        If CmMan.ListIndex >= 0 Then
            MaIdx = CmMan.ListIndex + 1
        Else
            MaIdx = GlSMa
        End If
    Else
        MaIdx = GlSMa
    End If
End If

If CmNot.ListCount > 0 Then
    If CmNot.ListIndex >= 0 Then
        NotVa = CmNot.ItemData(CmNot.ListIndex)
    Else
        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
            NotVa = GlMiT(GlSMo, 39) 'Standardmitarbeiter Online-Terminbuchungs Sytem
        Else
            NotVa = GlMaT(GlSMa, 25)
        End If
    End If
Else
    If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
        NotVa = GlMiT(GlSMo, 39) 'Standardmitarbeiter Online-Terminbuchungs Sytem
    Else
        NotVa = GlMaT(GlSMa, 25)
    End If
End If

If NotVa = 0 Then
    NotVa = 24
End If

If TeKop = True Then
    Set ViEvs = CaCol.ActiveView.GetSelectedEvents
    For Each ViEvt In ViEvs
        If ViEvt.Selected = True Then
            Set CaEvt = ViEvt.Event
            TerNr = CaEvt.id
            If TerNr > 0 Then
                S_TeDe TerNr
                With GlTDt
                    PatNr = .PatNr
                    PaStr = .PaStr
                    MitNr = .TeMit
                    ManNr = .TeMan
                    RmuNr = .TeRau
                    NotVa = .NotVa
                    Farbe = .Farbe
                    TeBtr = .TeBet
                    Prior = .TePri
                    TeMar = .TeMar
                    TeTyp = .TeTyp
                    TeLei = .TeLei
                    MasTe = .TeMas
                    GeBet = .GeBet
                    SeBet = .SeBet
                End With
                
                If TeLei = True Then
                    Set RS50 = New ADODB.Recordset
                    RS50.CursorLocation = adUseClient
                    Set RS50 = DBCmRe1("qryAnKa1e", "@IdxNr", TerNr)
                    GesLe = RS50.RecordCount
                    If GesLe > 0 Then
                        GlVrt = True 'virtuelle Leistungen vorhanden
                        ReDim GlTLe(GesLe, 14)
                        Do
                        AktLe = AktLe + 1
                        GlTLe(AktLe, 0) = PatNr
                        GlTLe(AktLe, 1) = 0
                        GlTLe(AktLe, 2) = 2
                        GlTLe(AktLe, 3) = 0
                        GlTLe(AktLe, 4) = RS50.Fields("GOID").Value
                        GlTLe(AktLe, 5) = RS50.Fields("IDKurz").Value
                        GlTLe(AktLe, 6) = RS50.Fields("Zusatztext").Value
                        GlTLe(AktLe, 7) = RS50.Fields("Steuer").Value
                        GlTLe(AktLe, 8) = RS50.Fields("Rabatt").Value
                        GlTLe(AktLe, 9) = CSng(Round(RS50.Fields("Multi").Value, 2))
                        GlTLe(AktLe, 10) = RS50.Fields("x").Value
                        GlTLe(AktLe, 14) = CSng(((Round(RS50.Fields("Preis1").Value, 2) * Round(RS50.Fields("Multi").Value, 2)) / FoFak) * RS50.Fields("x").Value)
                        If Not IsNull(RS50.Fields("Einheit").Value) Then GlTLe(AktLe, 11) = RS50.Fields("Einheit").Value
                        If Not IsNull(RS50.Fields("Provision").Value) Then GlTLe(AktLe, 12) = RS50.Fields("Provision").Value
                        GlTLe(AktLe, 13) = CSng(Round(RS50.Fields("Preis1").Value, 2) / FoFak)
                        RS50.MoveNext
                        Loop Until RS50.EOF
                    End If
                    RS50.Close
                    Set RS50 = Nothing
                End If
            End If
        End If
    Next ViEvt
End If

AnzTe = RpRcs.Count 'Anzahl Termine

If MitNr = 0 Then
    AlMit = True 'WICHTIG!
    If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
        AnzMi = UBound(GlMiT)
    Else
        AnzMi = UBound(GlMiA)
    End If
Else
    AnzMi = 1
End If

Set RS45 = New ADODB.Recordset
With RS45
    .CursorLocation = adUseClient
    .Source = "qryTerNeu"
    .ActiveConnection = DB1
    .CursorType = adOpenKeyset
    .LockType = adLockOptimistic
    .Open Options:=adCmdTableDirect
End With

If AnzTe > 0 Then
    If RS45.Supports(adAddNew) Then
        If MasTe = 0 Then
            MasTe = Ter_VoT
        End If
        For Each RpRec In RpRcs 'Die gefundenen Termine
            If RpRec.Item(5).Checked = True Then
                GesTe = GesTe + 1
            End If
        Next RpRec
        For AktMi = 1 To AnzMi
            If AlMit = True Then
                If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                    MitNr = GlMiT(AktMi, 2)
                Else
                    MitNr = GlMiA(AktMi, 2)
                End If
            End If
            AktTe = 0
            For Each RpRec In RpRcs 'Die gefundenen Termine
                If RpRec.Item(5).Checked = True Then
                    AktTe = AktTe + 1
                    GuiID = CreateID("T")
                    If IsDate(RpRec.Item(2).Value) = True Then
                        DaBeg = CDate(RpRec.Item(2).Value)
                        DaEnd = CDate(RpRec.Item(2).Value)
                    End If
                    If IsDate(RpRec.Item(3).Value) = True Then
                        TmVon = TimeValue(RpRec.Item(3).Value)
                    End If
                    If IsDate(RpRec.Item(4).Value) = True Then
                        TmBis = TimeValue(RpRec.Item(4).Value)
                    End If
                    If TeKop = False Then
                        If RpRec.Item(7).Value <> vbNullString Then
                            TeBtr = RpRec.Item(7).Value
                        Else
                            TeBtr = "kein Betreff"
                        End If
                    End If
                    If RpRec.Item(9).Value <> vbNullString Then
                        If IsNumeric(RpRec.Item(9).Value) = True Then
                            RmuNr = CInt(RpRec.Item(9).Value)
                        Else
                            RmuNr = 0
                        End If
                    Else
                        RmuNr = 0
                    End If
    
                    RS45.AddNew
                    RS45.Fields("ID0").Value = PatNr
                    RS45.Fields("IDR").Value = RmuNr
                    RS45.Fields("IDSer").Value = 6 'Serientermin
                    RS45.Fields("IDKurz").Value = TeBtr
                    If GlTyp < 2 Then
                        RS45.Fields("ZeiVon").Value = Format$(DaBeg, "dd.mm.yyyy") & Chr$(32) & Format$(TmVon, "hh:mm")
                        RS45.Fields("ZeiBis").Value = Format$(DaEnd, "dd.mm.yyyy") & Chr$(32) & Format$(TmBis, "hh:mm")
                    Else
                        RS45.Fields("ZeiVon").Value = Format$(TmVon, "hh:mm")
                        RS45.Fields("ZeiBis").Value = Format$(TmBis, "hh:mm")
                    End If
                    RS45.Fields("VonDat").Value = Format$(DaBeg, "dd.mm.yyyy")
                    RS45.Fields("BisDat").Value = Format$(DaEnd, "dd.mm.yyyy")
                    RS45.Fields("Patient").Value = PaStr
                    RS45.Fields("Priorität").Value = Prior
                    RS45.Fields("Vorwarn").Value = 1
                    RS45.Fields("Farbe").Value = Farbe
                    RS45.Fields("Anzahl").Value = GesTe
                    RS45.Fields("Farbtyp").Value = TeTyp
                    RS45.Fields("TerTyp").Value = TeMar
                    RS45.Fields("Behindert").Value = 0
                    RS45.Fields("IDM").Value = MitNr
                    RS45.Fields("IDP").Value = ManNr
                    RS45.Fields("SerTyp").Value = 1
                    RS45.Fields("MasTer").Value = MasTe
                    RS45.Fields("Raum").Value = vbNullString
                    RS45.Fields("Erinnerung").Value = 0
                    RS45.Fields("Selekt").Value = 0
                    RS45.Fields("Wiederholung").Value = 0
                    RS45.Fields("Aufgabe").Value = 0
                    RS45.Fields("GesBetrag").Value = GeBet
                    RS45.Fields("SerBetrag").Value = SeBet
                    If CmNot.Enabled = True Then
                        RS45.Fields("NotifyStatus").Value = 3 'Senden
                        RS45.Fields("NotifyValue").Value = NotVa
                    End If
                    If GlTeE = True Then 'Email-Termin-Erinnerung
                        RS45.Fields("NotifySetDate").Value = CDate(Left$(RpRec.Item(11).Value, 10))
                        RS45.Fields("NotifySetTime").Value = TimeValue(Right$(RpRec.Item(11).Value, 5))
                    End If
                    If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                        RS45.Fields("Replicated").Value = 1
                        RS45.Fields("DAVChange").Value = 1
                        RS45.Fields("LastModification").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                        RS45.Fields("DAVDate").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                    Else
                        RS45.Fields("Replicated").Value = 0
                        RS45.Fields("DAVChange").Value = 0
                    End If
                    RS45.Fields("RzAnz").Value = GesTe
                    RS45.Fields("RzAkt").Value = AktTe
                    RS45.Fields("Datum").Value = Now
                    RS45.Fields("Change").Value = Now
                    RS45.Fields("GuiID").Value = GuiID
                    RS45.Fields("Vorlage").Value = 0
                    If GlOTS = True Then 'Online-Terminbuchungs System
                        RS45.Fields("OnlGes").Value = 0
                    End If
                    RS45.Update
                    DoEvents
                    
                    Set RS47 = New ADODB.Recordset 'neue Termin ID ermitteln
                    RS47.CursorLocation = adUseClient
                    Set RS47 = DBCmRe1("qryTerGui3", "@IdStr", GuiID)
                    If RS47.RecordCount > 0 Then
                        NeTer = RS47.Fields("ID2").Value
                    Else
                        NeTer = 0
                    End If
                    RS47.Close
                    Set RS47 = Nothing
                    DoEvents
    
                    If TeLei = True Then 'Leistungen vorhanden
                        GesLe = UBound(GlTLe)
                        If GlTyp < 2 Then
                            SQL2 = "SELECT * FROM dbo.qryAnKa1 WHERE ID1 = -1"
                        Else
                            SQL2 = "SELECT * FROM qryAnKa1 WHERE [ID1] = -1;"
                        End If
                        Set RS48 = New ADODB.Recordset
                        With RS48
                            .CursorLocation = adUseClient
                            .Source = SQL2
                            .ActiveConnection = DB1
                            .CursorType = adOpenDynamic
                            .LockType = adLockOptimistic
                            .Open Options:=adCmdText
                        End With
                        If RS48.Supports(adAddNew) Then
                            For AktLe = 1 To GesLe
                                RS48.AddNew
                                RS48.Fields("ID0").Value = GlTLe(AktLe, 0)
                                RS48.Fields("ID2").Value = NeTer
                                RS48.Fields("Sorter").Value = GlTLe(AktLe, 2)
                                RS48.Fields("MasTer").Value = MasTe
                                RS48.Fields("GOID").Value = GlTLe(AktLe, 4)
                                RS48.Fields("IDKurz").Value = GlTLe(AktLe, 5)
                                RS48.Fields("Kommentar").Value = GlTLe(AktLe, 6)
                                If GlTLe(AktLe, 7) <> vbNullString Then RS48.Fields("Steuer").Value = GlTLe(AktLe, 7)
                                If GlTLe(AktLe, 8) <> vbNullString Then RS48.Fields("Rabatt").Value = GlTLe(AktLe, 8)
                                If GlTLe(AktLe, 9) <> vbNullString Then RS48.Fields("Multi").Value = GlTLe(AktLe, 9)
                                If GlTLe(AktLe, 10) <> vbNullString Then RS48.Fields("x").Value = GlTLe(AktLe, 10)
                                If GlTLe(AktLe, 11) <> vbNullString Then RS48.Fields("Einheit").Value = GlTLe(AktLe, 11)
                                If GlTLe(AktLe, 12) <> vbNullString Then RS48.Fields("Provision").Value = GlTLe(AktLe, 12)
                                RS48.Fields("Preis1").Value = GlTLe(AktLe, 13)
                                RS48.Fields("Preis2").Value = GlTLe(AktLe, 14)
                                RS48.Update
                            Next AktLe
                        End If
                        RS48.Close
                        Set RS48 = Nothing
                    End If
    
                    If GlOTS = True Then 'Online-Terminbuchungs System
                        If CDate(RpRec.Item(2).Value) >= Date Then
                            With GlSyn
                                .PrTyp = "B" 'Termin Hinzugefügt
                                .DatSt = Format$(RpRec.Item(2).Value, "dd.mm.yyyy")
                                .DatEn = Format$(RpRec.Item(2).Value, "dd.mm.yyyy")
                                .ZeiSt = Format$(RpRec.Item(3).Value, "hh:mm:ss")
                                .ZeiEn = Format$(RpRec.Item(4).Value, "hh:mm:ss")
                                .TeBet = vbNullString
                                .GuiID = GuiID
                                .MaIdx = MaIdx
                                .GnzTa = False
                                If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                                    .MaNum = MitNr
                                Else
                                    .MaNum = ManNr
                                End If
                            End With
                            S_TeSy
                            DoEvents
                        End If
                    End If
    
                    DoEvents
                    If CmNot.Enabled = True Then
                        PrStr = "Termin wurde hinzugefügt mit Emailerinnerung (" & Format$(NotVa, "00") & "h)"
                    Else
                        PrStr = "Termin wurde hinzugefügt ohne Emailerinnerung"
                    End If
                    MitNa = GlMiA(GlSmI, 1)
                    DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", NeTer, GuiID, GuiID, Now, Now, PrStr, MitNa
                End If
            Next RpRec
        Next AktMi
    End If
End If
RS45.Close
Set RS45 = Nothing

DoEvents
GlNeK = GlKoX 'Protokolleintrag
With GlNeK
    .PatNr = GlMan(GlSMa, 2)
    .IdxNr = 0
    .EiDat = Format$(Date, "dd.mm.yyyy")
    .EiZei = TimeValue(Now)
    .EiTyp = 104
    .ZiStr = Format$(Now, "hh:mm") & " Uhr"
    .NeuEi = True
    .KeiAk = True
    .Mitar = GlMiA(GlSmI, 2)
    .TeStr = "Terminserie hinzugefügt: " & Format$(DaBeg, "dd.mm.yyyy") & " - " & Format$(TmVon, "hh:mm") & " - " & Format$(TmBis, "hh:mm") & " - " & GuiID
End With
S_Prot

Set RpRcs = Nothing
Set RpCo1 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_VoP " & Err.Number
Resume Next

End Sub
Public Sub Ter_VoL()
On Error GoTo DaErr
'Füllt ReportControl mit den Leistungen

Dim GeSum As Double
Dim GesZa As Integer
Dim AktZa As Integer
Dim LeiAb As Boolean
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmEd1 As XtremeCommandBars.CommandBarEdit
Dim CmEd2 As XtremeCommandBars.CommandBarEdit
Dim CmEd3 As XtremeCommandBars.CommandBarEdit
Dim RpCon As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmTermVo
Set CmBrs = FM.comBar02
Set RpCon = FM.repCont1
Set RpRcs = RpCon.Records
Set CmAcs = CmBrs.Actions
Set CmSta = CmBrs.StatusBar

Set CmEd1 = CmBrs.FindControl(CmEd1, AD_Termin_Betrag1, , True)
Set CmEd2 = CmBrs.FindControl(CmEd2, AD_Termin_Betrag2, , True)
Set CmEd3 = CmBrs.FindControl(CmEd3, AD_Termin_Betrag3, , True)

If GlVrt = False Then
    Exit Sub
End If

GeSum = 0

With RpCon
    .EditItem Nothing, Nothing
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    If .Records.Count > 0 Then .Records.DeleteAll
    .Populate
End With

GesZa = UBound(GlTLe)

If GesZa > 0 Then
    For AktZa = 1 To GesZa
        Set RpRec = RpRcs.Add()
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_ID1"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(GlTLe(AktZa, 0))
        With RpItm
            .Tag = "_ID0"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(GlTLe(AktZa, 1))
        With RpItm
            .Tag = "_ID2"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(GlTLe(AktZa, 2))
        With RpItm
            .Tag = "_Typ"
            .Focusable = True
        End With
        Set RpItm = RpRec.AddItem(GlTLe(AktZa, 4))
        With RpItm
            .Tag = "_GOID"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(GlTLe(AktZa, 5))
        With RpItm
            .Tag = "_IDKurz"
            .Focusable = True
        End With
        Set RpItm = RpRec.AddItem(GlTLe(AktZa, 10))
        With RpItm
            .Tag = "_x"
            .Focusable = True
        End With
        Set RpItm = RpRec.AddItem(Format$(GlTLe(AktZa, 9), GlWa1))
        With RpItm
            .Tag = "_Multi"
            .Focusable = True
        End With
        Set RpItm = RpRec.AddItem(Format$(GlTLe(AktZa, 13), GlWa1))
        With RpItm
            .Tag = "_Preis1"
            .Focusable = True
        End With
        Set RpItm = RpRec.AddItem(Format$(GlTLe(AktZa, 14), GlWa1))
        With RpItm
            .Tag = "_Preis2"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Selekt"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Sorter"
            .Focusable = False
        End With
        If GlTLe(AktZa, 14) <> vbNullString Then
            GeSum = GeSum + CSng(GlTLe(AktZa, 14))
        End If
    Next AktZa
End If

If GesZa > 0 Then
    RpCon.Populate
    Set RpRws = RpCon.Rows
    RpRws.Row(0).Selected = False
End If

CmSta.Pane(0).Text = "Gesamt: " & Format$(GeSum, GlWa1)
CmEd1.Text = Format$(GeSum, GlWa1)
CmEd2.Text = Format$(GeSum, GlWa1)
DoEvents
TeVoSu

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCon = Nothing

Exit Sub

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_VoL " & Err.Number
Resume Next

End Sub
Public Sub Ter_Vor(Optional ByVal KeiBe As Boolean, Optional ByVal RmuNr As Long, Optional ByVal FreTe As Boolean = False)
On Error GoTo KoErr
'Erstellt Terminvorschläge

