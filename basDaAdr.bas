                If GlInt = True Then
                    If RS31.Fields("PTel").Value <> vbNullString Then If Len(FeTe1.Text) < 9 Then FeTe1.Text = "+49 (" & RS31.Fields("PTel").Value & ") "
                    If RS31.Fields("PTel").Value <> vbNullString Then If Len(FeTe2.Text) < 9 Then FeTe2.Text = "+49 (" & RS31.Fields("PTel").Value & ") "
                    If RS31.Fields("PTel").Value <> vbNullString Then If Len(FeTe3.Text) < 9 Then FeTe3.Text = "+49 (" & RS31.Fields("PTel").Value & ") "
                Else
                    If RS31.Fields("PTel").Value <> vbNullString Then If Len(FeTe1.Text) < 9 Then FeTe1.Text = "(" & RS31.Fields("PTel").Value & ") "
                    If RS31.Fields("PTel").Value <> vbNullString Then If Len(FeTe2.Text) < 9 Then FeTe2.Text = "(" & RS31.Fields("PTel").Value & ") "
                    If RS31.Fields("PTel").Value <> vbNullString Then If Len(FeTe3.Text) < 9 Then FeTe3.Text = "(" & RS31.Fields("PTel").Value & ") "
                End If

                DoEvents
                If MaDia = True Then
