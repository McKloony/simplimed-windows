            If GlTyp < 2 Then
                RS40.Fields("ZeiVon").Value = DatSt & Chr$(32) & ZeiSt
                RS40.Fields("ZeiBis").Value = DatEn & Chr$(32) & ZeiEn
                RS40.Fields("VonDat").Value = DatSt & Chr$(32) & ZeiSt
                RS40.Fields("BisDat").Value = DatEn & Chr$(32) & ZeiEn
                RS40.Fields("NotifySetDate").Value = DatNo & Chr$(32) & ZeiNo
                RS40.Fields("NotifySetTime").Value = DatNo & Chr$(32) & ZeiNo
                RS40.Fields("NotifyValue").Value = NotVa
            Else
                RS40.Fields("ZeiVon").Value = ZeiSt
                RS40.Fields("ZeiBis").Value = ZeiEn
                RS40.Fields("VonDat").Value = DatSt
                RS40.Fields("BisDat").Value = DatEn
                RS40.Fields("NotifySetDate").Value = DatNo
                RS40.Fields("NotifySetTime").Value = ZeiNo
                RS40.Fields("NotifyValue").Value = NotVa
            End If
            RS40.Fields("IDR").Value = RmuNr
            RS40.Fields("IDM").Value = MitNr
            RS40.Fields("IDP").Value = ManNr
            RS40.Fields("Selekt").Value = GnzTa
            RS40.Fields("Abhaken").Value = Abgeh
            RS40.Fields("GuiID").Value = GlTeG 'Termin GuiID
            RS40.Fields("IDSer").Value = 5 'Standardtermin
            If TxFar.Text <> vbNullString Then
                If IsNumeric(TxFar.Text) = True Then
                    RS40.Fields("Farbe").Value = CLng(TxFar.Text)
                End If
            End If
            If CmRem.Enabled = True Then
                RS40.Fields("Erinnerung").Value = -1
            Else
                RS40.Fields("Erinnerung").Value = 0
            End If
            If GlOTS = True Then 'Online-Terminbuchungs System
                RS40.Fields("OnlGes").Value = 0
            End If
            If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                RS40.Fields("Replicated").Value = 1
                RS40.Fields("DAVChange").Value = 1
                RS40.Fields("LastModification").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                RS40.Fields("DAVDate").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
            Else
                RS40.Fields("Replicated").Value = 0
                RS40.Fields("DAVChange").Value = 0
            End If
            RS40.Fields("Datum").Value = Now
            RS40.Fields("Change").Value = Now
            RS40.Update
        End If
        RS40.Close
        Set RS40 = Nothing
        DoEvents
        
        Set RS49 = New ADODB.Recordset
        RS49.CursorLocation = adUseClient
        Set RS49 = DBCmRe1("qryTerGui3", "@IdStr", GlTeG)
        If RS49.RecordCount > 0 Then
            GlTem = RS49.Fields("ID2").Value
        Else
            GlTem = -1
        End If
        RS49.Close
        Set RS49 = Nothing
        DoEvents
        
        TxID2.Text = GlTem
        TxMas.Text = GlTem

        DBCmEx2 "qryTerMas", "@IdMas", "@IdxNr", GlTem, GlTem
        DoEvents

        If GlOTS = True Then 'Online-Terminbuchungs System
            If DatSt >= Date Then
                With GlSyn
                    .PrTyp = "B" 'Termin Hinzugefügt
                    .DatSt = Format$(DatSt, "dd.mm.yyyy")
                    .DatEn = Format$(DatEn, "dd.mm.yyyy")
                    .ZeiSt = Format$(TxZeV.Text, "hh:mm:ss")
                    .ZeiEn = Format$(TxZeB.Text, "hh:mm:ss")
                    .TeBet = vbNullString
                    .GuiID = GlTeG 'Termin GuiID
                    .MaIdx = MaIdx
                    .GnzTa = GnzTa
                    If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                        .MaNum = MitNr
                    Else
                        .MaNum = ManNr
                    End If
                End With
                S_TeSy
                DoEvents
            End If
        End If
    
        If GlJet = True Then SDBSav
    End If
Next AktTa

Ter_San = TeAnl
DoEvents

Select Case NotSt 'Notificationstatus
Case 3: PrStr = "Termin wurde hinzugefügt mit Emailerinnerung (" & Format$(NotVa, "00") & "h)"
Case 1: PrStr = "Termin wurde hinzugefügt mit abgelaufener Emailerinnerung (" & Format$(NotVa, "00") & "h)"
Case 0: PrStr = "Termin wurde hinzugefügt ohne Emailerinnerung (" & Format$(NotVa, "00") & "h)"
End Select

MitNa = GlMiA(GlSmI, 1)
DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", GlTem, GlTeG, GlTeG, Now, Now, PrStr, MitNa

Exit Function

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_San " & Err.Number
Resume Next
    
End Function
Public Function Ter_Sav(Optional ByVal AlRmu As Long) As Boolean
On Error GoTo DaErr
'Speichert Änderungen des Inhalts des Terminformulars

Dim SQL1 As String
Dim RmuNr As Long
Dim ManNr As Long
Dim MitNr As Long
Dim OlMit As Long
Dim OlMan As Long
Dim OlIdx As Long
Dim MaIdx As Long
Dim TerNr As Long
Dim PatNr As Long
Dim DatSt As Date
Dim DatEn As Date
Dim DatNo As Date
Dim ZeiSt As Date
Dim ZeiEn As Date
Dim ZeiNo As Date
Dim KIDKu As String
Dim TagWe As String
Dim TmGui As String
Dim TmStr As String
Dim MitNa As String
Dim PrStr As String
Dim TeDop As Boolean
Dim TeAnd As Boolean
Dim GnzTa As Boolean
Dim Abgeh As Boolean
Dim AnDat As Boolean 'Datumsänderung
Dim AnzEi As Boolean 'Zeitänderung
Dim AnPat As Boolean 'Patientenänderung
Dim AnEri As Boolean 'Emailerinnerung
Dim AnMiT As Boolean 'Mitarbeiteränderung
Dim AnAbg As Boolean 'Leistungsabrechnung
Dim AnBet As Boolean 'Betreffänderung
Dim AnLei As Integer
Dim Behin As Integer
Dim AnzTa As Integer
Dim RauId As Integer
Dim NotVa As Integer
Dim NotSt As Integer
Dim AktZa As Integer
Dim Posit As Integer
Dim Frage As Integer
Dim Mld1, Mld2  As String
Dim Mld3, Mld4 As String

Set FM = frmTermin
Set TxID0 = FM.txtID0
Set TxID2 = FM.txtID2
Set TxMas = FM.txtRefNr
Set FeBet = FM.txtBetre
Set TxDa1 = FM.txtDatu1
Set TxDa2 = FM.txtDatu2
Set TxDa5 = FM.txtNoDat
Set TxZeV = FM.txtVonZe
Set TxZeB = FM.txtBisZe
Set TxZeN = FM.txtNoTim
Set TxNoS = FM.txtNoSta
Set TxFar = FM.txtFarbe
Set TxBeG = FM.txtBehin
Set CmMar = FM.cmbTeTyp
Set CmTyp = FM.cmbTypen
Set CmPri = FM.cmbPrior
Set CmRem = FM.cmbRemin
Set CmMta = FM.cmbMitar
Set CmMan = FM.cmbBehan
Set CmOrt = FM.cmbRaum1
Set CmAbr = FM.cmbAbger
Set CmAbg = FM.cmbAbgeh
Set CmGan = FM.cmbGanzt
Set CmNot = FM.cmbNotVa

If CmOrt.Text <> vbNullString Then
    RauId = CmOrt.ListIndex + 1
Else
    RauId = 1
End If

If RauId > UBound(GlRmu) Then
    RauId = RauId - 1
End If

If TxDa1.Text <> vbNullString Then
    If IsDate(TxDa1.Text) = True Then
        DatSt = CDate(TxDa1.Text)
    Else
        Exit Function
    End If
Else
    Exit Function
End If
    
If TxDa2.Text <> vbNullString Then
    If IsDate(TxDa2.Text) = True Then
        DatEn = CDate(TxDa2.Text)
    Else
        Exit Function
    End If
Else
    Exit Function
End If

If TxID0.Text <> vbNullString Then
    If IsNumeric(TxID0.Text) = True Then
        PatNr = CLng(TxID0.Text)
    End If
End If

If TxZeV.Text <> vbNullString Then
    If IsDate(TxZeV.Text) = True Then
        ZeiSt = TimeValue(TxZeV.Text)
    End If
End If

If TxZeV.Text <> vbNullString Then
    If IsDate(TxZeV.Text) = True Then
        ZeiSt = TimeValue(TxZeV.Text)
    Else
        Exit Function
    End If
Else
    Exit Function
End If

If TxZeB.Text <> vbNullString Then
    If IsDate(TxZeB.Text) = True Then
        ZeiEn = TimeValue(TxZeB.Text)
    Else
        Exit Function
    End If
Else
    Exit Function
End If

If TxID2.Text <> vbNullString Then
    If IsNumeric(TxID2.Text) Then
        TerNr = CLng(TxID2.Text)
    Else
        Exit Function
    End If
Else
    Exit Function
End If

If TxDa5.Text <> vbNullString Then
    If IsDate(TxDa5.Text) = True Then
        DatNo = CDate(TxDa5.Text)
    Else
        DatNo = DateAdd("d", -1, DatSt)
    End If
Else
    DatNo = DateAdd("d", -1, DatSt)
End If

If TxZeN.Text <> vbNullString Then
    If IsDate(TxZeN.Text) = True Then
        ZeiNo = TimeValue(TxZeN.Text)
    Else
        ZeiNo = ZeiSt
    End If
Else
    ZeiNo = ZeiSt
End If

TeAnd = True
AnzTa = DateDiff("d", DatSt, DatEn)

Mld1 = "Der von Ihnen ausgewählte Zeitabschnitt ist für den von Ihnen zugeordneten Mandanten / Mitarbeiter bereits durch einen anderen Termin belegt. Soll dieser trotzdem gespeichert werden?"
Mld2 = "Der von Ihnen ausgewählte Zeitabschnitt ist in dem von Ihnen zugeordneten Raum bereits durch einen anderen Termin belegt. Soll dieser trotzdem gespeichert werden?"
Mld3 = "Der von Ihnen ausgewählte Zeitabschnitt befindet sich für den von Ihnen zugeordneten Mandanten / Mitarbeiter außerhalb der eingestellten Sprechzeiten. Soll dieser trotzdem gespeichert werden?"
Mld4 = "Der ausgewählte Raum, ist für den Behinderungsgrad des Patienten nicht geeignet"

If AlRmu > 0 Then
    RmuNr = AlRmu
Else
    If CmOrt.ListCount > 0 Then
        If CmOrt.ListIndex >= 0 Then
            RmuNr = CmOrt.ItemData(CmOrt.ListIndex)
        Else
            RmuNr = 1
        End If
    Else
        RmuNr = 1
    End If
End If

If CmGan.ListIndex = 0 Then
    GnzTa = True
End If

If CmAbg.ListIndex = 0 Then
    Abgeh = True
End If

If CmOrt.ListCount > 0 Then
    If CmOrt.ListIndex >= 0 Then
        RmuNr = CmOrt.ItemData(CmOrt.ListIndex)
    Else
        RmuNr = 1
    End If
Else
    RmuNr = 1
End If

If CmMta.ListCount > 0 Then
    If CmMta.ListIndex >= 0 Then
        MitNr = CmMta.ItemData(CmMta.ListIndex)
    Else
        MitNr = 1
    End If
Else
    MitNr = 1
End If

For AktZa = 1 To UBound(GlMiT) 'Aktive Mitarbeiter
    If MitNr = GlMiT(AktZa, 2) Then
        MitNa = GlMiT(AktZa, 1)
        Exit For
    End If
Next AktZa

If GnzTa = True Then
    ZeiSt = "08:00:00"
    ZeiEn = "09:00:00"
End If

If CmMan.ListCount > 0 Then
    If CmMan.ListIndex >= 0 Then
        ManNr = CmMan.ItemData(CmMan.ListIndex)
    Else
        ManNr = 1
    End If
Else
    ManNr = 1
End If

If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
    If CmMta.ListCount > 0 Then
        If CmMta.ListIndex >= 0 Then
            MaIdx = CmMta.ListIndex + 1
        Else
            MaIdx = GlSMo 'Standardmitarbeiter Online-Terminbuchungs Sytem
        End If
    Else
        MaIdx = GlSMo
    End If
Else
    If CmMan.ListCount > 0 Then
        If CmMan.ListIndex >= 0 Then
            MaIdx = CmMan.ListIndex + 1
        Else
            MaIdx = GlSMa
        End If
    Else
        MaIdx = GlSMa
    End If
End If

If CmNot.ListCount > 0 Then
    If CmNot.ListIndex >= 0 Then
        NotVa = CmNot.ItemData(CmNot.ListIndex)
    Else
        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
            NotVa = GlMiT(GlSMo, 39) 'Standardmitarbeiter Online-Terminbuchungs Sytem
        Else
            NotVa = GlMaT(GlSMa, 25)
        End If
    End If
Else
    If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
        NotVa = GlMiT(GlSMo, 39) 'Standardmitarbeiter Online-Terminbuchungs Sytem
    Else
        NotVa = GlMaT(GlSMa, 25)
    End If
End If

If NotVa = 0 Then
    NotVa = 24
End If

If TxNoS.Text <> vbNullString Then
    If IsNumeric(TxNoS.Text) = True Then
        NotSt = CInt(TxNoS.Text)
    Else
        NotSt = 0
    End If
Else
    NotSt = 0
End If

If TxBeG.Text <> vbNullString Then
    If IsNumeric(TxBeG.Text) Then
        Behin = CInt(TxBeG.Text)
    Else
        Behin = 0
    End If
Else
    Behin = 0
End If

If Behin > 0 Then
    If GlRmu(RauId, 3) > 0 Then
        If GlBeG(Behin, 0) > GlRmu(RauId, 3) Then
            SPopu "Termin Speichern", Mld4, IC48_Warning
        End If
    End If
End If

If AnzTa = 0 Then
    If Behin > 0 Then
        If GlRmu(RauId, 3) > 0 Then
            If GlBeG(Behin, 0) > GlRmu(RauId, 3) Then
                SPopu "Termin Speichern", Mld4, IC48_Warning
            End If
        End If
    End If

    If GlTeW = True Then 'Terminbelegungswarnung
        If TeAnd = True Then
            TeDop = Ter_PrE(DatSt, TimeValue(TxZeV.Text), TimeValue(TxZeB.Text), RmuNr)
            If TeDop = True Then
                SMeFr "Termin Speichern", "Der Zeitraum ist bereits belegt", Mld2, vbNullString, False, 0, False, FM.hwnd
                If GlMes <> 33565 Then
                    TeAnd = False
                End If
            End If
        End If
    End If
        
    If GlSpP = True Then 'Überprüfung der Sprechzeiten
        If TeAnd = True Then
            If GlMiV = True Then 'Mitarbeiter vorhanden
                TeDop = TeVoBe(DatSt, TimeValue(TxZeV.Text), TimeValue(TxZeB.Text), MitNr) 'Sprechzeitenprüfung
            Else
                TeDop = TeVoBe(DatSt, TimeValue(TxZeV.Text), TimeValue(TxZeB.Text), ManNr) 'Sprechzeitenprüfung
            End If
            If TeDop = True Then
                SMeFr "Termin Speichern", "Der Zeitraum ist außerhalb der Sprechzeiten", Mld3, vbNullString, False, 0, False, FM.hwnd
                If GlMes <> 33565 Then
                    TeAnd = False
                End If
            End If
        End If
    End If
End If

If TeAnd = True Then
    If GlTyp < 2 Then
        SQL1 = "SELECT * FROM dbo.qryTerBele WHERE ID2 = " & TerNr
    Else
        SQL1 = "SELECT * FROM qryTerBele WHERE [ID2] = " & TerNr & ";"
    End If
    
    Set RS40 = New ADODB.Recordset
    With RS40
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenKeyset
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With
    If RS40.RecordCount > 0 Then
        If RS40.Supports(adUpdate) Then
            If RS40.Fields("GuiID").Value <> vbNullString Then
                TmGui = RS40.Fields("GuiID").Value
            Else
                TmGui = CreateID("T")
                RS40.Fields("GuiID").Value = TmGui
            End If
        
            If IsDate(TxDa1.Text) Then
                DatSt = TxDa1.Text
            Else
                DatSt = Date
            End If
            If IsDate(TxDa2.Text) Then
                DatEn = TxDa2.Text
            Else
                DatEn = Date
            End If
            If RS40.Fields("IDM").Value > 0 Then
                OlMit = RS40.Fields("IDM").Value
            Else
                OlMit = GlMiA(GlSmI, 2) 'Aktive Mitarbeiter
            End If
            If RS40.Fields("IDP").Value > 0 Then
                OlMan = RS40.Fields("IDP").Value
            Else
                OlMan = GlMan(GlSmI, 2)
            End If
            
            If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                For AktZa = 1 To UBound(GlMiT) 'Aktive Mitarbeiter
                    If OlMit = GlMiT(AktZa, 2) Then
                        OlIdx = AktZa
                        Exit For
                    End If
                Next AktZa
            Else
                For AktZa = 1 To UBound(GlMaT)
                    If OlMan = GlMaT(AktZa, 2) Then
                        OlIdx = AktZa
                        Exit For
                    End If
                Next AktZa
            End If

            For Each AktCo In FM.Controls
                If AktCo.Tag <> vbNullString Then
                    Select Case Left$(AktCo.Name, 3)
                    Case "txt": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                                If Left$(AktCo.Tag, 1) = "1" Then
                                    If AktCo.Text = vbNullString Then
                                        RS40.Fields(TagWe).Value = Null
                                    Else
                                        Select Case AktCo.Name
                                        Case "txtVonZe": AnzEi = True
                                        Case "txtBisZe": AnzEi = True
                                        Case "txtDatu1": AnDat = True
                                        Case "txtDatu2": AnDat = True
                                        Case "txtNoSta": AnEri = True
                                        Case "txtNoTim":
                                        Case "txtNoDat":
                                        Case "txtOnBuD":
                                        Case "txtOnBuT":
                                        Case "txtOnSyD":
                                        Case "txtOnSyT":
                                        Case "txtBetre": AnBet = True
                                                RS40.Fields(TagWe).Value = AktCo.Text
                                        Case "txtRzDat":
                                                If InStr(1, "_", AktCo.Text, vbTextCompare) = 0 Then
                                                    If IsDate(AktCo.Text) Then
                                                        RS40.Fields(TagWe).Value = DateValue(AktCo.Text)
                                                    End If
                                                End If
                                        Case "txtS4F18":
                                                If InStr(1, "_", AktCo.Text, vbTextCompare) = 0 Then
                                                    If IsDate(AktCo.Text) Then
                                                        RS40.Fields(TagWe).Value = DateValue(AktCo.Text)
                                                    End If
                                                End If
                                        Case "txtAdres":
                                                TmStr = AktCo.Text
                                                Posit = InStr(1, TmStr, Chr$(44), 1) 'Komma
                                                If Posit > 0 Then
                                                    RS40.Fields(TagWe).Value = TmStr
                                                End If
                                                AnPat = True
                                        Case "txtRefNr":
                                                RS40.Fields(TagWe).Value = Replace(AktCo.Text, "_", "", 1)
                                        Case Else:
                                                RS40.Fields(TagWe).Value = AktCo.Text
                                        End Select
                                    End If
                                End If
                    Case "cmb": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                                If Left$(AktCo.Tag, 1) = "1" Then
                                    If AktCo.Text <> vbNullString Then
                                        Select Case AktCo.Name
                                        Case "cmbMitar": AnMiT = True
                                        Case "cmbS4F11":
                                            RS40.Fields(TagWe).Value = AktCo.Text
                                        Case "cmbS4F12":
                                            RS40.Fields(TagWe).Value = AktCo.Text
                                        Case "cmbAbger":
                                            Select Case CmAbr.ListIndex
                                            Case 0:
                                                RS40.Fields("Wiederholung").Value = 0 'Leistungen vorhanden Ja / Nein
                                                RS40.Fields("Aufgabe").Value = 0 'Leistungen abgerechnet Ja / Nein
                                            Case 1:
                                                RS40.Fields("Wiederholung").Value = -1
                                                RS40.Fields("Aufgabe").Value = 0
                                            Case 2:
                                                RS40.Fields("Wiederholung").Value = -1
                                                RS40.Fields("Aufgabe").Value = -1
                                            End Select
                                            AnAbg = True
                                            AnLei = CmAbr.ListIndex
                                        Case Else:
                                            RS40.Fields(TagWe).Value = AktCo.ItemData(AktCo.ListIndex)
                                        End Select
                                    End If
                                End If
                    Case "chk": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                                If Left$(AktCo.Tag, 1) = "1" Then
                                    RS40.Fields(TagWe).Value = AktCo.Value
                                End If
                    Case "msk": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                            If Left$(AktCo.Tag, 1) = "1" Then
                                If IsDate(AktCo.Text) Then
                                    RS40.Fields(TagWe).Value = AktCo.Text
                                Else
                                    RS40.Fields(TagWe).Value = Null
                                End If
                            End If
                    End Select
                End If
            Next AktCo
            If GlTyp < 2 Then
                RS40.Fields("ZeiVon").Value = DatSt & Chr$(32) & ZeiSt
                RS40.Fields("ZeiBis").Value = DatEn & Chr$(32) & ZeiEn
                RS40.Fields("VonDat").Value = DatSt & Chr$(32) & ZeiSt
                RS40.Fields("BisDat").Value = DatEn & Chr$(32) & ZeiEn
                RS40.Fields("NotifySetTime").Value = DatNo & Chr$(32) & ZeiNo
                RS40.Fields("NotifySetDate").Value = DatNo & Chr$(32) & ZeiNo
                RS40.Fields("NotifyValue").Value = NotVa
            Else
                RS40.Fields("ZeiVon").Value = ZeiSt
                RS40.Fields("ZeiBis").Value = ZeiEn
                RS40.Fields("VonDat").Value = DatSt
                RS40.Fields("BisDat").Value = DatEn
                RS40.Fields("NotifySetTime").Value = ZeiNo
                RS40.Fields("NotifySetDate").Value = DatNo
                RS40.Fields("NotifyValue").Value = NotVa
            End If
            RS40.Fields("NotifyStatus").Value = NotSt
            RS40.Fields("Abhaken").Value = Abgeh
            RS40.Fields("Selekt").Value = GnzTa
            RS40.Fields("IDR").Value = RmuNr
            If CmRem.Enabled = True Then
                RS40.Fields("Erinnerung").Value = -1
            Else
                RS40.Fields("Erinnerung").Value = 0
            End If
            If GlOTS = True Then 'Online-Terminbuchungs System
                RS40.Fields("OnlGes").Value = 0
            End If
            If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                If MaIdx <> OlIdx Then 'If Doctor was changed
                    RS40.Fields("IDM").Value = OlMit
                    RS40.Fields("IDP").Value = OlMan
                Else
                    RS40.Fields("IDM").Value = MitNr
                    RS40.Fields("IDP").Value = ManNr
                End If
                RS40.Fields("Replicated").Value = 1
                RS40.Fields("DAVChange").Value = 1
                RS40.Fields("LastModification").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                RS40.Fields("DAVDate").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
            Else
                RS40.Fields("IDM").Value = MitNr
                RS40.Fields("IDP").Value = ManNr
                RS40.Fields("Replicated").Value = 0 'Kann wieder neu Synchronisiert werden
                RS40.Fields("DAVChange").Value = 0
            End If
            RS40.Fields("Change").Value = Now
            RS40.Update
        End If
    End If
    RS40.Close
    Set RS40 = Nothing
    
    If GlOTS = True Then 'Online-Terminbuchungs System
        If DatSt >= Date Then
            If MaIdx <> OlIdx Then
                With GlSyn
                    .PrTyp = "D" 'Termin Gelöscht
                    .DatSt = Format$(DatSt, "dd.mm.yyyy")
                    .DatEn = Format$(DatEn, "dd.mm.yyyy")
                    .ZeiSt = Format$(TxZeV.Text, "hh:mm:ss")
                    .ZeiEn = Format$(TxZeB.Text, "hh:mm:ss")
                    .GuiID = TmGui
                    .MaIdx = OlIdx
                    .GnzTa = GnzTa
                    If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                        .MaNum = OlMit
                    Else
                        .MaNum = OlMan
                    End If
                End With
                S_TeSy
            Else
                With GlSyn
                    .PrTyp = "C" 'Termin Geändert
                    .DatSt = Format$(DatSt, "dd.mm.yyyy")
                    .DatEn = Format$(DatEn, "dd.mm.yyyy")
                    .ZeiSt = Format$(TxZeV.Text, "hh:mm:ss")
                    .ZeiEn = Format$(TxZeB.Text, "hh:mm:ss")
                    .GuiID = TmGui
                    .MaIdx = MaIdx
                    .GnzTa = GnzTa
                    If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                        .MaNum = MitNr
                    Else
                        .MaNum = ManNr
                    End If
                End With
                S_TeSy
            End If
            DoEvents
        End If
    End If
    
    If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
        If MaIdx <> OlIdx Then
            TmGui = CreateID("T")
            DBCmEx2 "qryTerKop", "@IdxNr", "@GuiSt", TerNr, TmGui 'Copy Procedure
            DoEvents
            DBCmEx2 "qryTerMaG", "@IdMan", "@GuiSt", ManNr, TmGui
            DoEvents
            DBCmEx2 "qryTerMiG", "@IdMit", "@GuiSt", MitNr, TmGui
            DoEvents
            DBCmEx2 "qryTerPaSe", "@IdPas", "@IdxNr", 1, TerNr 'Set Original Passiv = -1
            DoEvents
            If GlOTS = True Then 'Online-Terminbuchungs System
                DoEvents
                If DatSt >= Date Then
                    With GlSyn
                        .PrTyp = "B" 'Termin Hinzugefügt
                        .DatSt = Format$(DatSt, "dd.mm.yyyy")
                        .DatEn = Format$(DatEn, "dd.mm.yyyy")
                        .ZeiSt = Format$(TxZeV.Text, "hh:mm:ss")
                        .ZeiEn = Format$(TxZeB.Text, "hh:mm:ss")
                        .TeBet = vbNullString
                        .GuiID = TmGui
                        .MaIdx = MaIdx
                        .GnzTa = GnzTa
                        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                            .MaNum = MitNr
                        Else
                            .MaNum = ManNr
                        End If
                    End With
                    S_TeSy
                End If
            End If
        End If
    End If
    DoEvents
    
    If AnDat = True Then
        If PrStr = vbNullString Then
            PrStr = "Datumsänderung"
        Else
            PrStr = PrStr & ", Datumsänderung"
        End If
    End If
    If AnzEi = True Then
        If PrStr = vbNullString Then
            PrStr = "Uhrzeitänderung"
        Else
            PrStr = PrStr & ", Uhrzeitänderung"
        End If
    End If
    If AnPat = True Then
        If PrStr = vbNullString Then
            PrStr = "Patientenänderung"
        Else
            PrStr = PrStr & ", Patientenänderung"
        End If
    End If
    If AnMiT = True Then
        If PrStr = vbNullString Then
            PrStr = "Mitarbeiteränderung"
        Else
            PrStr = PrStr & ", Mitarbeiteränderung"
        End If
    End If
    If AnBet = True Then
        If PrStr = vbNullString Then
            PrStr = "Betreffänderung"
        Else
            PrStr = PrStr & ", Betreffänderung"
        End If
    End If
    If AnAbg = True Then
        Select Case AnLei
        Case 0:
            If PrStr = vbNullString Then
                PrStr = "Keine Leistungen"
            Else
                PrStr = PrStr & ", Keine Leistungen"
            End If
        Case 1:
            If PrStr = vbNullString Then
                PrStr = "Leistungen vorhanden"
            Else
                PrStr = PrStr & ", Leistungen vorhanden"
            End If
        Case 2:
            If PrStr = vbNullString Then
                PrStr = "Leistungen abgerechnet"
            Else
                PrStr = PrStr & ", Leistungen abgerechnet"
            End If
        End Select
    End If
    If GlTeE = True Then 'Email-Termin-Erinnerung
        If AnEri = True Then
            If PrStr = vbNullString Then
                Select Case NotSt
                Case 3: PrStr = "Emailerinnerung aktiviert"
                Case 1: PrStr = "Emailerinnerung deaktiviert"
                Case 0: PrStr = "Emailerinnerung deaktiviert"
                End Select
            Else
                Select Case NotSt
                Case 3: PrStr = PrStr & ", Emailerinnerung aktiviert"
                Case 1: PrStr = PrStr & ", Emailerinnerung deaktiviert"
                Case 0: PrStr = PrStr & ", Emailerinnerung deaktiviert"
                End Select
            End If
        End If
    End If
    If PrStr = vbNullString Then
        PrStr = "Termin wurde verändert"
    Else
        PrStr = "Termin wurde verändert: " & PrStr
    End If

    MitNa = GlMiA(GlSmI, 1)
    DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", TerNr, TmGui, TmGui, Now, Now, PrStr, MitNa
End If

If GlJet = True Then SDBSav

Ter_Sav = True

Exit Function

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_Sav " & Err.Number
Resume Next

End Function
Public Sub Ter_SeD()
On Error GoTo DaErr
'Listet alle Termine auf, die dieselbe Seriennummer haben

Dim GesZa As Long
Dim TerNr As Long
Dim RpCo2 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmTermin
Set TxID2 = FM.txtID2
Set RpCo2 = FM.repCont2
Set RpRcs = RpCo2.Records

If TxID2.Text <> vbNullString Then
    TerNr = TxID2.Text
Else
    TerNr = GlTem
End If

With RpCo2
    .EditItem Nothing, Nothing
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    If .Records.Count > 0 Then .Records.DeleteAll
    .Populate
End With

If TerNr > 0 Then
    Set RS38 = New ADODB.Recordset 'Offene Posten
    RS38.CursorLocation = adUseClient
    Set RS38 = DBCmRe1("qryTerPro", "@IdxNr", TerNr)
    GesZa = RS38.RecordCount
    If GesZa > 0 Then
        Do
        Set RpRec = RpRcs.Add()
        Set RpItm = RpRec.AddItem(RS38.Fields("IDA").Value)
        Set RpItm = RpRec.AddItem(RS38.Fields("ID2").Value)
        Set RpItm = RpRec.AddItem(RS38.Fields("GuiID").Value)
        Set RpItm = RpRec.AddItem(RS38.Fields("TerID").Value)
        Set RpItm = RpRec.AddItem(Format$(RS38.Fields("Datum").Value, "dd.mm.yyyy"))
        Set RpItm = RpRec.AddItem(Format$(RS38.Fields("Zeit").Value, "hh:mm"))
        RpItm.Alignment = xtpAlignmentCenter
        Set RpItm = RpRec.AddItem(RS38.Fields("IDKurz").Value)
        Set RpItm = RpRec.AddItem(RS38.Fields("Kommentar").Value)
        RS38.MoveNext
        Loop Until RS38.EOF
    End If
    RS38.Close
    Set RS38 = Nothing
    
    If GesZa > 0 Then
        RpCo2.Populate
        Set RpRws = RpCo2.Rows
        RpRws.Row(0).Selected = False
    End If
End If

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCo2 = Nothing

Exit Sub

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_SeD " & Err.Number
Resume Next

End Sub
Public Sub Ter_Ser()
On Error GoTo LiErr
'Kopiert Serienrechnungen

Dim SQL2 As String
Dim DaBeg As Date
Dim DaEnd As Date
Dim PatNr As Long
Dim TerNr As Long
Dim MasNr As Long
Dim Farbe As Long
Dim ManNr As Long
Dim MitNr As Long
Dim NeTer As Long
Dim FoFak As Single
Dim GeBet As Double
Dim SeBet As Double
Dim GuiID As String
Dim TeBtr As String
Dim TmStr As String
Dim PatNa As String
Dim AnzRe As Integer
Dim AktRe As Integer
Dim AnzTa As Integer
Dim AktTa As Integer
