Public Sub Dia_Cli(Optional ByVal Dialo As Boolean)
On Error GoTo LiErr
'Kopiert die ICD-10 Diagnose in die Zwischenablage

Dim ReNum As Long
Dim IdxNr As Long
Dim DiGrp As Long
Dim DiRef As Long
Dim DiaDa As Date
Dim StrDi As String 'Diagnosestring
Dim StrMe As String 'Arzneimittelstring
Dim StrRe As String 'Rechnungsdiagnose
Dim CoStr As String
Dim KuStr As String
Dim AktPo As Integer
Dim GesPo As Integer
Dim ReAbg As Boolean
Dim RetWe As Boolean
Dim Mld1, Mld2, Tit1 As String
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCoK As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set LiVw1 = FM.lstView1
Set LiVw2 = FM.lstView2
Set LiVw3 = FM.lstView3
Set RpCo3 = FM.repCont3
Set RpCo6 = FM.repCont6
Set RpCoK = FM.repContK
Set RpRws = RpCo3.Rows
Set RpCls = RpCo3.Columns
Set RpSel = RpCo3.SelectedRows
Select Case GlBut
Case RibTab_Krankenbla: Set RpRcs = RpCoK.Records
Case RibTab_Abrechnung: Set RpRcs = RpCo6.Records
End Select

Select Case GlBut
Case RibTab_Krankenbla:
        Select Case GlKrT 'Krankenblattdiagnosefeldtyp
        Case 1: Set LiIts = LiVw2.ListItems
        Case 2: Set LiIts = LiVw3.ListItems
        End Select
Case RibTab_Abrechnung:
        Set LiIts = LiVw1.ListItems
End Select

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

For Each LiItm In LiIts
    If LiItm.Selected = True Then
        GesPo = GesPo + 1
    End If
Next LiItm

AktPo = 1
GlAkt = True

Tit1 = "Diagnose Ausschneiden"
Mld2 = "Die Rechnung ist bereits abgeschlossen"

If GesPo > 0 Then
    ReDim GlClp(GesPo, 4)
    
    Select Case GlBut
    Case RibTab_Krankenbla:
        ReAbg = False
    Case RibTab_Abrechnung:
        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            If RpRow.GroupRow = False Then
                Set RpCol = RpCls.Find(Rec_ID1)
                ReNum = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_Selekt)
                ReAbg = CBool(RpRow.Record(RpCol.ItemIndex).Value)
            End If
        End If
    End Select

    For Each LiItm In LiIts
        If LiItm.Selected = True Then
            IdxNr = CLng(Mid$(LiItm.Key, 2, Len(LiItm.Key) - 1))
            Set RS71 = New ADODB.Recordset
            RS71.CursorLocation = adUseClient
            Set RS71 = DBCmRe1("qrySimAbDiBe", "@IdxNr", IdxNr)
            If RS71.RecordCount > 0 Then
                CoStr = RS71.Fields("GOID").Value
                KuStr = RS71.Fields("IDKurz").Value
                If RS71.Fields("Datum").Value <> vbNullString Then
                    DiaDa = RS71.Fields("Datum").Value
                End If
                If RS71.Fields("ID1").Value <> vbNullString Then
                    DiGrp = RS71.Fields("ID1").Value
                Else
                    DiGrp = 0
                End If
                If RS71.Fields("IDS").Value <> vbNullString Then
                    DiRef = RS71.Fields("ID0").Value
                Else
                    DiRef = 0
                End If
            End If
            RS71.Close
            Set RS71 = Nothing

            If Dialo = True Then
                DBCmEx1 "qrySimAbDiLo", "@IdxNr", IdxNr
                DoEvents
            End If

            GlClp(AktPo, 0) = CoStr
            GlClp(AktPo, 1) = KuStr
            If Len(DiaDa) > 7 Then
                GlClp(AktPo, 2) = DiaDa
            End If
            GlClp(AktPo, 3) = DiGrp
            GlClp(AktPo, 4) = DiRef
            AktPo = AktPo + 1
        End If
    Next LiItm
        
    ClKop = True 'Cliparry kopiert
    
    If Dialo = True Then
        Screen.MousePointer = vbHourglass
        clFen.FenDsk 2
        
        DoEvents
        Select Case GlBut
        Case RibTab_Krankenbla:
                StrDi = S_KrDp(GlAdr) 'Aufnahmediagnosen
                StrMe = S_KrDm(GlAdr) 'Aufnahmemedikamente
        Case RibTab_Abrechnung:
                StrRe = S_KrDi(ReNum) 'Rechnungsdiagnosen
        End Select
        
        clFen.FenDsk 3
        Screen.MousePointer = vbNormal
    End If
End If

If Dialo = True Then
    If ReAbg = True Then
        SPopu Tit1, Mld2, IC48_Warning
    End If
End If

Set RpRcs = Nothing
Set RpSel = Nothing
Set RpRow = Nothing
Set RpRws = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing
Set RpCo6 = Nothing
Set RpCoK = Nothing

Set clFen = Nothing

GlAkt = False

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Dia_Cli " & Err.Number
Resume Next

End Sub
Public Sub Dia_Da(ByVal NeuDa As Date)
On Error GoTo LiErr
'Anpassen des Diagnosedatums

Dim PatNr As Long
Dim ReNum As Long
Dim IdxNr As Long
Dim StrDi As String 'Diagnosestring
Dim StrMe As String 'Arzneimittelstring
Dim StrRe As String 'Rechnungsdiagnose
Dim AktPo As Integer
Dim ReAbg As Boolean
Dim RetWe As Boolean
Dim Mld2, Tit1 As String
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set LiVw1 = FM.lstView1
Set LiVw2 = FM.lstView2
Set LiVw3 = FM.lstView3
Set RpCo3 = FM.repCont3
Set RpRws = RpCo3.Rows
Set RpCls = RpCo3.Columns
Set RpSel = RpCo3.SelectedRows

Select Case GlBut
Case RibTab_Krankenbla:
        Select Case GlKrT
        Case 1: Set LiIts = LiVw2.ListItems
        Case 2: Set LiIts = LiVw3.ListItems
        End Select
Case RibTab_Abrechnung:
        Set LiIts = LiVw1.ListItems
End Select

For Each LiItm In LiIts
    If LiItm.Selected = True Then
        AktPo = AktPo + 1
    End If
Next LiItm

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

GlAkt = True

Tit1 = "Diagnose Umbenennen"
Mld2 = "Die Rechnung wurde bereits abgeschlossen"

If AktPo > 0 Then
    Screen.MousePointer = vbHourglass
    clFen.FenDsk 2

    Select Case GlBut
    Case RibTab_Krankenbla:
        For Each LiItm In LiIts
            If LiItm.Selected = True Then
                IdxNr = CLng(Mid$(LiItm.Key, 2, Len(LiItm.Key) - 1))
                DBCmEx2 "qrySimAbDiDa", "@IdDat", "@IdxNr", NeuDa, IdxNr
            End If
        Next LiItm
        StrDi = S_KrDp(GlAdr) 'Aufnahmediagnosen
        StrMe = S_KrDm(GlAdr) 'Aufnahmemedikamente
    Case RibTab_Abrechnung:
        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            If RpRow.GroupRow = False Then
                Set RpCol = RpCls.Find(Rec_ID0)
                PatNr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_ID1)
                ReNum = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_Selekt)
                ReAbg = CBool(RpRow.Record(RpCol.ItemIndex).Value)
            Else
                Exit Sub
            End If
            For Each LiItm In LiIts
                If LiItm.Selected = True Then
                    IdxNr = CLng(Mid$(LiItm.Key, 2, Len(LiItm.Key) - 1))
                    DBCmEx2 "qrySimAbDiDa", "@IdDat", "@IdxNr", NeuDa, IdxNr
                End If
            Next LiItm
            DoEvents
            StrRe = S_KrDi(ReNum) 'Rechnungsdiagnosen
        End If
    End Select
    
    clFen.FenDsk 3
    Screen.MousePointer = vbNormal
End If

Set RpSel = Nothing
Set RpRow = Nothing
Set RpRws = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing

Set clFen = Nothing

If ReAbg = True Then SPopu Tit1, Mld2, IC48_Warning

GlDDa = False

GlAkt = False

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Dia_Da " & Err.Number
Resume Next

End Sub
