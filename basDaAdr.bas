                Case 4: If AktMo >= 10 And AktMo <= 12 Then MoAr2(AktMo) = MoAr2(AktMo) + 1
                End Select
                RS71.MoveNext
                Loop Until RS71.EOF
            ElseIf OpJah.Value = True Then
                Do
                AktMo = RS71.Fields("Monat").Value
                AnStr = Format$(RS71.Fields("Anzahl").Value, "000")
                MoAr2(AktMo) = MoAr2(AktMo) + AnStr
                RS71.MoveNext
                Loop Until RS71.EOF
            End If

            If OpMon.Value = True Then
                For AktZa = 1 To 60
                    If WoAr2(AktZa) > 0 Then
                        ChSrs.Points.Add Format$(AktZa, "00"), WoAr2(AktZa)
                    End If
                Next AktZa
            ElseIf OpQua.Value = True Then
                For AktZa = 1 To 12
                    If MoAr2(AktZa) > 0 Then
                        ChSrs.Points.Add SStaMo(AktZa), MoAr2(AktZa)
                    End If
                Next AktZa
            ElseIf OpJah.Value = True Then
                For AktZa = 1 To 12
                    If MoAr2(AktZa) > 0 Then
                        ChSrs.Points.Add SStaMo(AktZa), MoAr2(AktZa)
                    End If
                Next AktZa
            End If
        End If
        
        Select Case GlDiT
        Case 1: Set ChCnt.Series(0).Style = New ChartBarSeriesStyle
        Case 2: Set ChCnt.Series(0).Style = New ChartBarSeriesStyle
        Case 3:
        Case 4: Set ChCnt.Series(0).Style = New ChartSplineSeriesStyle
