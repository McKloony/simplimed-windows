End If
FaDa1 = DateAdd("d", ZilTa, StDa1)
FaDa2 = DateAdd("d", ZilTa, StDa2)

CmEd3.Text = Format$(FaDa1, "dd.mm.yyyy")
TxFa1.Text = Format$(FaDa1, "dd.mm.yyyy")
TxFa2.Text = Format$(FaDa2, "dd.mm.yyyy")

If FreTe = True Then 'nächsten freien Termin vorschlagen
    Ter_Vr5 KeiBe, RmuNr, Behin, TmpMa
Else
    If FoZy1.Value = True Then
        Ter_Vr1 KeiBe, RmuNr, Behin, TmpMa
    ElseIf FoZy2.Value = True Then
        Ter_Vr2 KeiBe, RmuNr, Behin, TmpMa
    ElseIf FoZy3.Value = True Then
        Ter_Vr3 KeiBe, RmuNr, Behin, TmpMa
    ElseIf FoZy4.Value = True Then
        Ter_Vr4 KeiBe, RmuNr, Behin, TmpMa
    End If
End If

GesTe = UBound(VoDat)

If GesTe > 0 Then
    With RpCo6
        .EditItem Nothing, Nothing
        If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
        If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
        If .Records.Count > 0 Then .Records.DeleteAll
        .Populate
    End With

    For AktTe = 1 To GesTe
        If VoFar(AktTe) <> FaNeg Then
            AktZa = AktZa + 1
            Set RpRec = RpRcs.Add()
            Set RpItm = RpRec.AddItem(vbNullString)
            RpItm.Icon = IC16_Calendar_Clock
            RpItm.Focusable = False
            Set RpItm = RpRec.AddItem(Format$(VoDat(AktTe), "dddd"))
            RpItm.Focusable = False
            Set RpItm = RpRec.AddItem(Format$(VoDat(AktTe), "dd.mm.yyyy"))
            RpItm.Alignment = xtpAlignmentCenter
            Set RpItm = RpRec.AddItem(Format$(VoZei(AktTe), "hh:mm"))
            RpItm.Alignment = xtpAlignmentCenter
            Set RpItm = RpRec.AddItem(Format$(DateAdd("n", AdMin, VoZei(AktTe)), "hh:mm"))
            RpItm.Alignment = xtpAlignmentCenter
            RpItm.Focusable = False
            Set RpItm = RpRec.AddItem(vbNullString)
            RpItm.HasCheckbox = True
            If FreTe = False Then
                If AktTe = 1 Then
                    If FoZy1.Value = True Then
                        RpItm.Checked = True
                    ElseIf FoZy2.Value = True Then
                        RpItm.Checked = True
                    Else
                        RpItm.Checked = True
                    End If
                Else
                    RpItm.Checked = True
                End If
            End If
            Set RpItm = RpRec.AddItem(VoFar(AktTe))
            Set RpItm = RpRec.AddItem(TeBtr)
            Set RpItm = RpRec.AddItem(TmpMa)
            If VoRau(AktTe) > 0 Then
                Set RpItm = RpRec.AddItem(VoRau(AktTe))
            Else
                If RmuNr > 0 Then
                    Set RpItm = RpRec.AddItem(VoRau(AktTe))
                Else
                    Set RpItm = RpRec.AddItem(TmpRa)
                End If
            End If
            Set RpItm = RpRec.AddItem(Format$(AktZa, "000") & " / " & Format$(GesTe, "000"))
            RpItm.Alignment = xtpAlignmentCenter
            If GlTeE = True Then 'Email-Termin-Erinnerung
                NotDa = CDate(DateAdd("h", -NotVa, VoDat(AktTe) & " " & VoZei(AktTe)))
                NotZe = TimeValue(DateAdd("h", -NotVa, VoDat(AktTe) & " " & VoZei(AktTe)))
                Set RpItm = RpRec.AddItem(Format$(NotDa, "dd.mm.yyyy") & " " & Format$(NotZe, "hh:mm"))
            End If
        End If
    Next AktTe
End If

RpCo6.Populate
If RpRws.Count > 0 Then
    RpRws.Row(0).Selected = False
End If

CmAcs(AD_Termin_Vorschau).Enabled = False
CmAcs(AD_Termin_Save).Enabled = True
CmAcs(AD_Termin_Reset).Enabled = True
CmAcs(AD_Termin_Freie).Enabled = False

Set CmAcs = Nothing
Set RpRcs = Nothing
Set CmBrs = Nothing
Set RpCo6 = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_Vor " & Err.Number
Resume Next

End Sub

Public Sub Ter_VoS(ByVal MasTe As Long, Optional ByVal RmuNr As Long, Optional ByVal WiVor As Boolean = False)
On Error GoTo KoErr
'Speichert selbst generierten Serientermin

Dim SQL2 As String
Dim DaBeg As Date
Dim DaEnd As Date
Dim AlDa1 As Date
Dim AlDa2 As Date
Dim ZeiSt As Date
Dim ZeiEn As Date
Dim FaDa1 As Date
Dim FaDa2 As Date
Dim StaDa As Date
Dim PatNr As Long
Dim Farbe As Long
Dim ManNr As Long
Dim MitNr As Long
Dim NeTer As Long
Dim TeTyp As Long
Dim GeBet As Double
Dim SeBet As Double
Dim GuiID As String
Dim TeBtr As String
Dim TeKom As String 'Kommentar vorhanden
Dim PatNa As String
Dim TreZe As String
Dim PaAnr As String
Dim PaTit As String
Dim PaVor As String
Dim PaNam As String
Dim PaFrm As String
Dim PaStr As String
Dim PaPLZ As String
Dim PaOrt As String
Dim PaLnd As String
Dim PaGeb As String
Dim PaTe1 As String
Dim PaTe5 As String
Dim PaBrf As String
Dim PrStr As String
Dim MitNa As String
Dim TeOrt As String
Dim TeGef As Boolean
Dim TrSpl As Boolean
Dim TrDop As Boolean
Dim SplZe As Boolean 'Trennzeichen gefunden
Dim GnzTa As Boolean 'Ganztagstermin
Dim AkSpl As Integer 'Aktueller Splittermin
Dim SplTe As Integer 'Splittermin laufende Zahl
Dim MaIdx As Integer
Dim AktZa As Integer
Dim GesZa As Integer
Dim GesTe As Integer
Dim SerAk As Integer
Dim PaMin As Integer 'Länge der Splitpause
Dim AdMin As Integer
Dim SplAn As Integer 'Anzahl Terminplsits
Dim SplPa As Integer 'Länge der Plitpause
Dim SplLa As Integer 'Länge ein Splitterminteils
Dim GefPo As Integer
Dim StaPo As Integer
Dim AnzTe As Integer 'Anzahl Termine
Dim AktTe As Integer
Dim TerTy As Integer
Dim ZaZil As Integer
Dim Behin As Integer
Dim NotVa As Integer
Dim ZeVon() As Date
Dim ZeBis() As Date
Dim BtrSp() As String
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmEd3 As XtremeCommandBars.CommandBarEdit
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl

Set FM = frmTermVo
Set TxID0 = FM.txtID0
Set TxDa1 = FM.txtDatu1
Set TxDa5 = FM.txtDatu5
Set TxZeV = FM.txtVonZe
Set TxZeB = FM.txtBisZe
Set TxFa1 = FM.txtFall1
Set TxFa2 = FM.txtFall2
Set TxBeG = FM.txtBehin
Set CmBet = FM.txtBetre
Set CmRem = FM.cmbRemin
Set CmMar = FM.cmbTeTyp
Set TxFar = FM.txtFarbe
Set TxAdr = FM.txtAdres
Set CmTyp = FM.cmbStatu
Set CmMan = FM.cmbBehan
Set CmMta = FM.cmbMitar
Set CmAbr = FM.cmbAbger
Set CmNot = FM.cmbNotVa
Set FoZy1 = FM.optZykl1
Set FoZy2 = FM.optZykl2
Set FoZy3 = FM.optZykl3
Set FoZy4 = FM.optZykl4
Set TxOrt = FM.txtRaum1
Set TxKom = FM.txtKomme
Set ChDop = FM.chkDopTe
Set CmGan = FM.cmbGanzt
Set ChSpl = FM.chkTeSpl
Set ChWie = FM.chkWiede
Set FeSpA = FM.txoSplAn
Set FeSpP = FM.txoSplPa
Set RpCo1 = FM.repCont1
Set RpCo6 = FM.repCont6
Set CmBrs = FM.comBar02
Set CmSta = CmBrs.StatusBar

Set CmEd3 = CmBrs.FindControl(CmEd3, AD_Termin_Betrag3, , True)

If ChSpl.Value = xtpChecked Then TrSpl = True
If ChDop.Value = xtpChecked Then TrDop = True
If CmGan.ListIndex = 0 Then GnzTa = True

TreZe = IniGetVal("TerSys", "TreZei")

For AktZa = 1 To UBound(GlZah) 'Standardzahlungsziel
    If GlZah(AktZa, 0) = GlStZ Then
        ZaZil = GlZah(AktZa, 2)
        Exit For
    End If
Next AktZa

AlDa1 = TimeValue(TxZeV.Text)
AlDa2 = TimeValue(TxZeB.Text)
SplAn = FeSpA.ItemData(FeSpA.ListIndex)
SplPa = FeSpP.ItemData(FeSpP.ListIndex)
AdMin = DateDiff("n", AlDa1, AlDa2)
PaMin = (SplAn - 1) * SplPa
SplLa = Fix(((AdMin - PaMin) / SplAn)) 'Ganze Zahl

If TxID0.Text <> vbNullString Then
    If IsNumeric(TxID0.Text) = True Then
        PatNr = CLng(TxID0.Text)
    End If
End If

If PatNr > 0 Then
    S_AdDe PatNr
    With GlADt
       PaAnr = .AdAnr
       PaTit = .AdTit
       PaVor = .AdVor
       PaNam = .AdNam
       PaFrm = .AdFir
       PaStr = .AdStr
       PaPLZ = .AdPLZ
       PaOrt = .AdOrt
       PaLnd = .AdLan
       PaGeb = .AdGeb
       PaTe1 = .AdTe1
       PaTe5 = .AdTe5
       PaBrf = .AdRBr
    End With
End If

If TxBeG.Text <> vbNullString Then
    Behin = CInt(TxBeG.Text)
End If

If CmBet.Text <> vbNullString Then
    TeBtr = CmBet.Text
End If

If TxFar.Text <> vbNullString Then
    If IsNumeric(TxFar.Text) = True Then
        Farbe = CLng(TxFar.Text)
    End If
End If

If TxAdr.Text <> vbNullString Then
    PatNa = TxAdr.Text
End If

If TxKom.Text <> vbNullString Then
    TeKom = TxKom.Text
End If

If TxOrt.Text <> vbNullString Then
    TeOrt = TxOrt.Text
End If

ManNr = CmMan.ItemData(CmMan.ListIndex)

If GlMiV = True Then
    MitNr = CmMta.ItemData(CmMta.ListIndex)
End If

If CmMar.ListIndex > 0 Then
    TerTy = CmMar.ItemData(CmMar.ListIndex)
End If

TeTyp = CmTyp.ItemData(CmTyp.ListIndex)

If TxBeG.Text <> vbNullString Then
    If IsNumeric(TxBeG.Text) Then
        Behin = CInt(TxBeG.Text)
    End If
End If

If GlMPl = True Then
    If CmMta.ListCount > 0 Then
        If CmMta.ListIndex >= 0 Then
            MaIdx = CmMta.ListIndex + 1
        Else
            MaIdx = GlSmI
        End If
    Else
        MaIdx = GlSmI
    End If
Else
    If CmMan.ListCount > 0 Then
        If CmMan.ListIndex >= 0 Then
            MaIdx = CmMan.ListIndex + 1
        Else
            MaIdx = GlSMa
        End If
    Else
        MaIdx = GlSMa
    End If
End If

If CmNot.ListCount > 0 Then
    If CmNot.ListIndex >= 0 Then
        NotVa = CmNot.ItemData(CmNot.ListIndex)
    Else
        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
            NotVa = GlMiT(GlSMo, 39) 'Standardmitarbeiter Online-Terminbuchungs Sytem
        Else
            NotVa = GlMaT(GlSMa, 25)
        End If
    End If
Else
    If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
        NotVa = GlMiT(GlSMo, 39) 'Standardmitarbeiter Online-Terminbuchungs Sytem
    Else
        NotVa = GlMaT(GlSMa, 25)
    End If
End If

If NotVa = 0 Then
    NotVa = 24
End If

StaPo = 1
GesTe = 0
SerAk = 1

If CmEd3.Text <> vbNullString Then
    If IsDate(CmEd3.Text) = True Then
        StaDa = CDate(CmEd3.Text)
        FaDa1 = StaDa
    Else
        If TxFa1.Text <> vbNullString Then
            If IsDate(TxFa1.Text) Then
                StaDa = CDate(TxDa1.Text)
            Else
                StaDa = Date
            End If
        Else
            StaDa = Date
        End If
        FaDa1 = DateAdd("d", ZaZil, StaDa)
    End If
Else
    If TxFa1.Text <> vbNullString Then
        If IsDate(TxFa1.Text) Then
            StaDa = CDate(TxDa1.Text)
        Else
            StaDa = Date
        End If
    Else
        StaDa = Date
    End If
    FaDa1 = DateAdd("d", ZaZil, StaDa)
End If

If TxFa2.Text <> vbNullString Then
    If IsDate(TxFa2.Text) Then
        FaDa2 = CDate(TxFa2.Text)
    Else
        FaDa2 = DateAdd("d", ZaZil, StaDa)
    End If
Else
    FaDa2 = DateAdd("d", ZaZil, StaDa)
End If

Set RpRcs = RpCo1.Records 'Gesamtsumme Leistungen
If RpRcs.Count > 0 Then
    For Each RpRec In RpRcs
        If RpRec.Item(TeL_Gesamt).Value <> vbNullString Then
            GeBet = GeBet + CSng(RpRec.Item(TeL_Gesamt).Value)
        End If
    Next RpRec
End If

Set RpRcs = RpCo6.Records
AnzTe = RpRcs.Count 'Anzahl Termine
If AnzTe > 0 Then
    For Each RpRec In RpRcs 'Die gefundenen Termine
        If RpRec.Item(5).Checked = True Then
            SeBet = SeBet + GeBet
            GesTe = GesTe + 1
        End If
    Next RpRec
Else
    Exit Sub
End If

If TrSpl = True Then
    ReDim BtrSp(SplAn)
    ReDim ZeVon(AnzTe * SplAn)
    ReDim ZeBis(AnzTe * SplAn)
    
    For Each RpRec In RpRcs 'Die gefundenen Termine
        If RpRec.Item(5).Checked = True Then
            AkSpl = 1
            SplTe = SplTe + 1
            ZeiSt = TimeValue(Format$(RpRec.Item(3).Value, "hh:mm"))
            ZeiEn = TimeValue(Format$(RpRec.Item(4).Value, "hh:mm"))

            ZeVon(SplTe) = ZeiSt
            ZeBis(SplTe) = DateAdd("n", SplLa, ZeiSt)
 
            For AkSpl = 2 To SplAn
                SplTe = SplTe + 1
                ZeVon(SplTe) = DateAdd("n", PaMin, ZeBis(SplTe - 1))
                ZeBis(SplTe) = DateAdd("n", SplLa, ZeVon(SplTe))
            Next AkSpl
        End If
    Next RpRec

    AktZa = 0
    GefPo = InStr(StaPo, TeBtr, TreZe, 1)
    If GefPo > 0 Then
        SplZe = True
        AktZa = AktZa + 1
        BtrSp(AktZa) = Mid$(TeBtr, StaPo, GefPo - 1)
        StaPo = GefPo + 1
        Do While GefPo > 0
            GefPo = InStr(StaPo, TeBtr, TreZe, 1)
            If GefPo > 0 Then
                AktZa = AktZa + 1
                BtrSp(AktZa) = Mid$(TeBtr, StaPo, GefPo - StaPo)
                StaPo = GefPo + 1
            Else
                AktZa = AktZa + 1
                BtrSp(AktZa) = Right$(TeBtr, Len(TeBtr) - (StaPo - 1))
                Exit Do
            End If
        Loop
    Else
        BtrSp(1) = TeBtr
    End If
Else
    SplAn = 1
End If

SplTe = 0 'wieder zurücksetzen

Set RS45 = New ADODB.Recordset
With RS45
    .CursorLocation = adUseClient
    .Source = "qryTerNeu"
    .ActiveConnection = DB1
    .CursorType = adOpenKeyset
    .LockType = adLockOptimistic
    .Open Options:=adCmdTableDirect
End With

If RS45.Supports(adAddNew) Then
    For Each RpRec In RpRcs 'Die gefundenen Termine
        For AkSpl = 1 To SplAn 'Die einzelnen Teiltermine
            If RpRec.Item(5).Checked = True Then

                AktTe = AktTe + 1
                SplTe = SplTe + 1
                GuiID = CreateID("T")
                RS45.AddNew
                RS45.Fields("ID0").Value = PatNr
                If RmuNr > 0 Then
                    RS45.Fields("IDR").Value = RmuNr
                Else
                    If RpRec.Item(6).Value > 0 Then
                        RS45.Fields("IDR").Value = RpRec.Item(9).Value
                    Else
                        RS45.Fields("IDR").Value = 1
                    End If
                End If

                DaBeg = CDate(RpRec.Item(2).Value)
                DaEnd = CDate(RpRec.Item(2).Value)
                ZeiSt = TimeValue(Format$(RpRec.Item(3).Value, "hh:mm"))
                ZeiEn = TimeValue(Format$(RpRec.Item(4).Value, "hh:mm"))
                
                If TrSpl = True Then
                    RS45.Fields("IDSer").Value = 8 'Serienterminsplit
                    If SplZe = True Then
                        RS45.Fields("IDKurz").Value = BtrSp(AkSpl)
                    Else
                        RS45.Fields("IDKurz").Value = TeBtr
                    End If
                    If GlTyp < 2 Then
                        RS45.Fields("ZeiVon").Value = Format$(DaBeg, "dd.mm.yyyy") & Chr$(32) & Format$(ZeVon(SplTe), "hh:mm")
                        RS45.Fields("ZeiBis").Value = Format$(DaEnd, "dd.mm.yyyy") & Chr$(32) & Format$(ZeBis(SplTe), "hh:mm")
                    Else
                        RS45.Fields("ZeiVon").Value = Format$(ZeVon(SplTe), "hh:mm")
                        RS45.Fields("ZeiBis").Value = Format$(ZeBis(SplTe), "hh:mm")
                    End If
                Else
                    RS45.Fields("IDSer").Value = 6 'Serientermin
                    RS45.Fields("IDKurz").Value = TeBtr
                    If GlTyp < 2 Then
                        RS45.Fields("ZeiVon").Value = Format$(DaBeg, "dd.mm.yyyy") & Chr$(32) & Format$(ZeiSt, "hh:mm")
                        RS45.Fields("ZeiBis").Value = Format$(DaEnd, "dd.mm.yyyy") & Chr$(32) & Format$(ZeiEn, "hh:mm")
                    Else
                        RS45.Fields("ZeiVon").Value = Format$(ZeiSt, "hh:mm")
                        RS45.Fields("ZeiBis").Value = Format$(ZeiEn, "hh:mm")
                    End If
                End If
                RS45.Fields("VonDat").Value = Format$(DaBeg, "dd.mm.yyyy")
                RS45.Fields("BisDat").Value = Format$(DaEnd, "dd.mm.yyyy")
                RS45.Fields("Priorität").Value = 2
                RS45.Fields("Vorwarn").Value = CmRem.ItemData(CmRem.ListIndex)
                RS45.Fields("Farbe").Value = Farbe
                RS45.Fields("Anzahl").Value = RpRec.Index + 1
                RS45.Fields("Patient").Value = PatNa
                RS45.Fields("Farbtyp").Value = TeTyp
                RS45.Fields("TerTyp").Value = TerTy
                RS45.Fields("Behindert").Value = Behin
                RS45.Fields("IDM").Value = MitNr
                RS45.Fields("IDP").Value = ManNr
                If FoZy1.Value = True Then
                    RS45.Fields("SerTyp").Value = 1
                ElseIf FoZy2.Value = True Then
                    RS45.Fields("SerTyp").Value = 2
                ElseIf FoZy3.Value = True Then
                    RS45.Fields("SerTyp").Value = 3
                ElseIf FoZy4.Value = True Then
                    RS45.Fields("SerTyp").Value = 4
                End If
                RS45.Fields("MasTer").Value = MasTe
                RS45.Fields("Raum").Value = TeOrt
                RS45.Fields("Kommentar").Value = TeKom
                If CmRem.Enabled = True Then RS45.Fields("Erinnerung").Value = -1
                If CmGan.ListIndex = 0 Then
                    RS45.Fields("Selekt").Value = -1
                End If
                If AkSpl = 1 Then 'Nur beim ersten Splittermin die Leistungen einsetzen
                    RS45.Fields("GesBetrag").Value = GeBet
                    RS45.Fields("SerBetrag").Value = SeBet
                    If SeBet > 0 Then
                        RS45.Fields("Fallig1").Value = FaDa1
                        RS45.Fields("Fallig2").Value = FaDa2
                    End If
                End If
                If ChWie.Value = xtpChecked Then 'Leistungen vorhanden Ja / Nein
                    RS45.Fields("Wiederholung").Value = -1
                Else
                    RS45.Fields("Wiederholung").Value = 0
                End If
                If CmAbr.ListIndex = 1 Then
                    RS45.Fields("Aufgabe").Value = 0
                Else
                    RS45.Fields("Aufgabe").Value = -1
                End If
                If CmNot.Enabled = True Then
                    RS45.Fields("NotifyStatus").Value = 3 'Senden
                    RS45.Fields("NotifyValue").Value = NotVa
                End If
                If GlTeE = True Then 'Email-Termin-Erinnerung
                    RS45.Fields("NotifySetDate").Value = CDate(Left$(RpRec.Item(11).Value, 10))
                    RS45.Fields("NotifySetTime").Value = TimeValue(Right$(RpRec.Item(11).Value, 5))
                End If
                If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                    RS45.Fields("Replicated").Value = 1
                    RS45.Fields("DAVChange").Value = 1
                    RS45.Fields("LastModification").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                    RS45.Fields("DAVDate").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                Else
                    RS45.Fields("Replicated").Value = 0
                    RS45.Fields("DAVChange").Value = 0
                End If
                RS45.Fields("RzAnz").Value = GesTe
                RS45.Fields("RzAkt").Value = AktTe
                RS45.Fields("Datum").Value = Now
                RS45.Fields("Change").Value = Now
                RS45.Fields("GuiID").Value = GuiID
                RS45.Fields("Vorlage").Value = WiVor 'WICHTIG!
                If GlOTS = True Then 'Online-Terminbuchungs System
                    RS45.Fields("OnlGes").Value = 0
                End If
                If PaAnr <> vbNullString Then RS45.Fields("Anrede").Value = PaAnr
                If PaTit <> vbNullString Then RS45.Fields("Titel").Value = PaTit
                If PaVor <> vbNullString Then RS45.Fields("Vorname").Value = PaVor
                If PaNam <> vbNullString Then RS45.Fields("Name").Value = PaNam
                If PaFrm <> vbNullString Then RS45.Fields("Firma1").Value = PaFrm
                If PaStr <> vbNullString Then RS45.Fields("Straße").Value = PaStr
                If PaPLZ <> vbNullString Then RS45.Fields("PLZ").Value = PaPLZ
                If PaOrt <> vbNullString Then RS45.Fields("Ort").Value = PaOrt
                If PaLnd <> vbNullString Then RS45.Fields("Land").Value = PaLnd
                If PaGeb <> vbNullString Then RS45.Fields("Geboren").Value = CDate(PaGeb)
                If PaTe1 <> vbNullString Then RS45.Fields("Telefon1").Value = PaTe1
                If PaTe5 <> vbNullString Then RS45.Fields("Telefon5").Value = PaTe5
                If PaBrf <> vbNullString Then RS45.Fields("Briefanrede").Value = PaBrf
                RS45.Update
                DoEvents

                Set RS47 = New ADODB.Recordset 'neue Termin ID ermitteln
                RS47.CursorLocation = adUseClient
                Set RS47 = DBCmRe1("qryTerGui3", "@IdStr", GuiID)
                If RS47.RecordCount > 0 Then
                    NeTer = RS47.Fields("ID2").Value
                Else
                    NeTer = 0
                End If
                RS47.Close
                Set RS47 = Nothing
                DoEvents

                If GlVrt = True Then 'virtuelle Leistungen vorhanden
                    If AkSpl = 1 Then 'nur beim ersten Splttermin die Leistungen einsetzen
                        GesZa = UBound(GlTLe)
                        If GlTyp < 2 Then
                            SQL2 = "SELECT * FROM dbo.qryAnKa1 WHERE ID1 = -1"
                        Else
                            SQL2 = "SELECT * FROM qryAnKa1 WHERE [ID1] = -1;"
                        End If
                        Set RS48 = New ADODB.Recordset
                        With RS48
                            .CursorLocation = adUseClient
                            .Source = SQL2
                            .ActiveConnection = DB1
                            .CursorType = adOpenDynamic
                            .LockType = adLockOptimistic
                            .Open Options:=adCmdText
                        End With
                        If RS48.Supports(adAddNew) Then
                            For AktZa = 1 To GesZa
                                RS48.AddNew
                                RS48.Fields("ID0").Value = GlTLe(AktZa, 0)
                                RS48.Fields("ID2").Value = NeTer
                                RS48.Fields("Sorter").Value = GlTLe(AktZa, 2)
                                RS48.Fields("MasTer").Value = MasTe
                                RS48.Fields("GOID").Value = GlTLe(AktZa, 4)
                                RS48.Fields("IDKurz").Value = GlTLe(AktZa, 5)
                                RS48.Fields("Kommentar").Value = GlTLe(AktZa, 6)
                                If GlTLe(AktZa, 7) <> vbNullString Then RS48.Fields("Steuer").Value = GlTLe(AktZa, 7)
                                If GlTLe(AktZa, 8) <> vbNullString Then RS48.Fields("Rabatt").Value = GlTLe(AktZa, 8)
                                If GlTLe(AktZa, 9) <> vbNullString Then RS48.Fields("Multi").Value = GlTLe(AktZa, 9)
                                If GlTLe(AktZa, 10) <> vbNullString Then RS48.Fields("x").Value = GlTLe(AktZa, 10)
