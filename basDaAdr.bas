Public Sub Dia_Lo()
On Error GoTo LiErr
'Löscht die ICD-10 Diagnose

Dim PatNr As Long
Dim ReNum As Long
Dim IdxNr As Long
Dim StrDi As String 'Diagnosestring
Dim StrMe As String 'Arzneimittelstring
Dim StrRe As String 'Rechnungsdiagnose
Dim CoStr As String
Dim KuStr As String
Dim ReStr As String
Dim AktPo As Integer
Dim Frage As Integer
Dim ReAbg As Boolean
Dim RetWe As Boolean
Dim Mld1, Mld2, Tit1 As String
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set LiVw1 = FM.lstView1
Set LiVw2 = FM.lstView2
Set LiVw3 = FM.lstView3
Set RpCo3 = FM.repCont3
Set RpRws = RpCo3.Rows
Set RpCls = RpCo3.Columns
Set RpSel = RpCo3.SelectedRows

Select Case GlBut
Case RibTab_Krankenbla:
        Select Case GlKrT
        Case 1: Set LiIts = LiVw2.ListItems
        Case 2: Set LiIts = LiVw3.ListItems
        End Select
Case RibTab_Abrechnung:
        Set LiIts = LiVw1.ListItems
End Select

For Each LiItm In LiIts
    If LiItm.Selected = True Then
        AktPo = AktPo + 1
    End If
Next LiItm

Set clFen = New clsFenster
GlAkt = True

Tit1 = "Diagnose Entfernen"
Mld2 = "Die Rechnung wurde bereits abgeschlossen"

If AktPo > 1 Then
    Mld1 = "Möchten Sie die " & AktPo & " markierten Einträge wirklich löschen?"
ElseIf AktPo = 1 Then
    Mld1 = "Möchten Sie den markierten Eintrag wirklich löschen?"
End If

If AktPo > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then
    
        Select Case GlBut
        Case RibTab_Krankenbla:
            PatNr = GlAdr
            ReNum = 0
            ReAbg = False
            ReStr = vbNullString
        Case RibTab_Abrechnung:
            If RpSel.Count > 0 Then
                Set RpRow = RpSel(0)
                If RpRow.GroupRow = False Then
                    Set RpCol = RpCls.Find(Rec_ID0)
                    PatNr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Rec_ID1)
                    ReNum = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Rec_Selekt)
                    ReAbg = CBool(RpRow.Record(RpCol.ItemIndex).Value)
                    Set RpCol = RpCls.Find(Rec_RechNr)
                    ReStr = RpRow.Record(RpCol.ItemIndex).Value
                End If
            End If
        End Select
                
        For Each LiItm In LiIts
            If LiItm.Selected = True Then
                If ReAbg = False Then
                    IdxNr = CLng(Mid$(LiItm.Key, 2, Len(LiItm.Key) - 1))
                    DBCmEx1 "qrySimAbDiLo", "@IdxNr", IdxNr
                End If
            End If
        Next LiItm
                
        Select Case GlBut
        Case RibTab_Krankenbla:
            StrDi = S_KrDp(GlAdr) 'Aufnahmediagnosen
            StrMe = S_KrDm(GlAdr) 'Aufnahmemedikamente
        Case RibTab_Abrechnung:
            StrRe = S_KrDi(ReNum)
        End Select
        
        If ReAbg = True Then
            SPopu Tit1, Mld2, IC48_Warning
        End If

        GlNeK = GlKoX 'Protokolleintrag
        With GlNeK
            .PatNr = PatNr
            .IdxNr = 0
            .EiDat = Format$(Date, "dd.mm.yyyy")
            .EiZei = TimeValue(Now)
            .EiTyp = 104
            If GlBut = RibTab_Abrechnung Then
                .TeStr = "Rechnungs-Katalogdiagnose gelöscht - " & ReStr
            Else
                .TeStr = "Krankenblatt-Katalogdiagnose gelöscht - " & Format$(PatNr, "000000")
            End If
            .ZiStr = Format$(Now, "hh:mm") & " Uhr"
            .NeuEi = True
            .KeiAk = True
            .Mitar = GlMiA(GlSmI, 2)
        End With
        S_Prot
    End If
End If

Set RpSel = Nothing
Set RpRow = Nothing
Set RpRws = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing

Set clFen = Nothing

GlAkt = False

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Dia_Lo " & Err.Number
Resume Next

End Sub
