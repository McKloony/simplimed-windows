Public Sub Opt_Grp()
On Error GoTo ReErr
'Speichert Termingruppen in Datenbank

Dim KatId As Long
Dim TmFar As Long 'Defaultfarbwert
Dim AryIt() As String
Dim PrItm As XtremePropertyGrid.PropertyGridItem
Dim PrKat As XtremePropertyGrid.PropertyGridItem
Dim PrIts As XtremePropertyGrid.PropertyGridItems

Set FM = frmOptions
Set PrGr2 = FM.prpGrid2
Set PrIts = PrGr2.Categories

For Each PrKat In PrIts
    For Each PrItm In PrKat.Childs
        Select Case PrItm.Type
        Case PropertyItemString:
                If PrItm.Value <> vbNullString Then
                    If PrItm.defaultValue <> PrItm.Value Then
                        If PrKat.id < 1300 Then
                            DBCmEx2 "qryterFaTe", "@IdStr", "@IdxNr", PrItm.Value, PrItm.id
                        End If
                    End If
                End If
        Case PropertyItemNumber:
                
        Case PropertyItemBool:
                
        Case PropertyItemColor:
                AryIt = Split(PrItm.defaultValue, ";")
                TmFar = RGB(AryIt(0), AryIt(1), AryIt(2))
                If CLng(PrItm.Value) > 0 Then
                    If TmFar <> PrItm.Value Then
                        If PrKat.id >= 1300 Then
                            KatId = CInt(Right$(PrKat.id, 2))
                            Select Case PrItm.id
                            Case 1: DBCmEx2 "qryTerHiF1", "@IdFar", "@IdxNr", PrItm.Value, KatId
                            Case 2: DBCmEx2 "qryTerHiF2", "@IdFar", "@IdxNr", PrItm.Value, KatId
                            Case 3: DBCmEx2 "qryTerHiF3", "@IdFar", "@IdxNr", PrItm.Value, KatId
                            Case 4: DBCmEx2 "qryTerHiF4", "@IdFar", "@IdxNr", PrItm.Value, KatId
                            Case 5: DBCmEx2 "qryTerHiF5", "@IdFar", "@IdxNr", PrItm.Value, KatId
                            End Select
                        Else
                            DBCmEx2 "qryterFaFa", "@IdFar", "@IdxNr", PrItm.Value, PrItm.id
                        End If
                    End If
                End If
        Case PropertyItemDate:
                
        End Select
        
    Next PrItm
Next PrKat

Exit Sub

ReErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Opt_Grp " & Err.Number
Resume Next
        
End Sub
