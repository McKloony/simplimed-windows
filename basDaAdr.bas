    If RS41.RecordCount > 0 Then
        SeSum = RS41.Fields("Preis2").Value
    Else
        SeSum = 0
    End If
    RS41.Close
    Set RS41 = Nothing
End If

DoEvents
If MasTe > 0 Then
    DBCmEx2 "qryTerSum3", "@IdBet", "@IdxNr", SeSum, MasTe
Else
    DBCmEx2 "qryTerSum2", "@IdBet", "@IdxNr", TeSum, TerNr
End If

Set RpSel = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCon = Nothing

Exit Sub

GrErr:
