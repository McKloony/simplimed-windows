Set RpCo0 = FM.repCont0
Set RpCls = RpCo0.Columns
Set RpSel = RpCo0.SelectedRows

If NeGru = "P800" Then
    GruNr = 1
Else
    GruNr = Mid$(NeGru, 2, Len(NeGru) - 1)
End If
GruSt = "o" & GruNr & "o"
AnzPo = RpSel.Count

If AnzPo > 0 Then
    frmStatus.Show
    DoEvents
    frmStatus.Caption = "Nachrichtenverschiebung"
