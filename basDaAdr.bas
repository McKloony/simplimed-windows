Dim Abger As Integer
Dim AktZa As Integer
Dim Abgeh As Boolean
Dim Passi As Boolean

If GlTeD = False Then 'Termindetails zeigen
    Exit Sub
End If

Select Case FrmNa
Case 1:
    Set FM = frmKatTD
    If TeNum > 0 Then
        S_TeDe TeNum
        With GlTDt
            PatNr = .PatNr
            TeAds = .TeAdr
            RzAnz = .RzAnz
            RzAkt = .RzAkt
            MitNr = .TeMit
            ManNr = .TeMan
            TeKom = Replace(.TeKom, vbCrLf, Space$(1), 1)
        End With
    End If
Case 2:
    Set FM = frmKatTK
    PatNr = GlAdr
    If TeNum > 0 Then
        S_TeDe TeNum
        With GlTDt
            TeAds = .TeAdr
            MitNr = .TeMit
            ManNr = .TeMan
            TeKom = Replace(.TeKom, vbCrLf, Space$(1), 1)
        End With
    End If
End Select

Set RpCon = FM.repCont7
Set RpRcs = RpCon.Records
Set RpHcs = RpCon.HeaderRecords

If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
    For AktZa = 1 To UBound(GlMiT) 'Aktive Mitarbeiter + Terminspalte
        If MitNr = GlMiT(AktZa, 2) Then
            If GlMiT(AktZa, 27) <> vbNullString Then
                MiNam = GlMiT(AktZa, 27)
            Else
                MiNam = GlMiT(AktZa, 1)
            End If
            Exit For
        End If
    Next AktZa
Else
    For AktZa = 1 To UBound(GlMaT)
        If ManNr = GlMaT(AktZa, 0) Then
            MiNam = GlMaT(AktZa, 1)
            Exit For
        End If
    Next AktZa
End If

With RpCon
    .EditItem Nothing, Nothing
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    If .Records.Count > 0 Then .Records.DeleteAll
    If .HeaderRecords.Count > 0 Then .HeaderRecords.DeleteAll
    .Populate
End With

If PatNr > 0 Then
    S_AdDe PatNr
    With GlADt
        PaKur = .AdKur
        PaPLZ = .AdPLZ
        PaOrt = .AdOrt
        ZaZil = .AdZil
        KatNr = .AdKat
        PaTe1 = .AdTe1
        PaTe2 = .AdTe2
        PaTe4 = .AdTe4
        AdGrp = .AdGrp
        PaBem = Replace(.AdBem, vbCrLf, Space$(1), 1)
        PaCav = Replace(.AdCav, vbCrLf, Space$(1), 1)
    End With

    For AktPo = 1 To UBound(GlGKa) 'Gebührenkataloge
        If GlGKa(AktPo, 0) = KatNr Then
            PatKa = LTrim$(GlGKa(AktPo, 1))
            Exit For
        End If
    Next AktPo

    For AktPo = 1 To UBound(GlZah)
        If GlZah(AktPo, 0) = ZaZil Then
            PatZa = LTrim$(GlZah(AktPo, 1))
            Exit For
        End If
    Next AktPo

    Set RpRec = RpHcs.Add()
    Set RpItm = RpRec.AddItem(0)
    Set RpItm = RpRec.AddItem(PaKur)
    RpItm.Icon = IC16_IDCard_Norm
