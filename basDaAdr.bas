        Set RpItm = RpRec.AddItem(PaTe2)
        RpItm.Icon = IC16_Telephone
        RpItm.Bold = True
        Set RpItm = RpRec.AddItem(PatNr)
        Set RpItm = RpRec.AddItem(0)
        Set RpItm = RpRec.AddItem(0)
    End If
    
    If PaTe4 <> vbNullString Then
        Set RpRec = RpHcs.Add()
        Set RpItm = RpRec.AddItem(0)
        Set RpItm = RpRec.AddItem(PaTe4)
        RpItm.Icon = IC16_Phone_Mobil
