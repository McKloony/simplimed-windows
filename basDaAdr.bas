Public Sub Tr_VoEi(Optional ByVal AdMin As Integer = 0)
On Error GoTo GrErr
'Fügt Parameter in Termindialog ein

Dim ParNr As Long 'Parameternummer
Dim GrpNr As Long
Dim PatNr As Long
Dim TerDa As Date
Dim NeuDa As Date
Dim FoFak As Single
Dim TreKy As String
Dim AktZa As Integer
Dim ZaZil As Integer
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmCom As XtremeCommandBars.CommandBarComboBox
Dim CmGrp As XtremeCommandBars.CommandBarComboBox
Dim RpCon As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmTermVo
Set TxID0 = FM.txtID0
Set TxDa1 = FM.txtDatu1
Set TxFa1 = FM.txtFall1
Set TxFa2 = FM.txtFall2
Set ChWie = FM.chkWiede
Set CmAbr = FM.cmbAbger

For AktZa = 1 To UBound(GlZah) 'Standardzahlungsziel
    If GlZah(AktZa, 0) = GlStZ Then
        ZaZil = GlZah(AktZa, 2)
        Exit For
    End If
Next AktZa

If TxID0.Text > 0 Then
    PatNr = TxID0.Text
Else
    PatNr = 0
End If

FoFak = 1

If IsDate(TxDa1.Text) Then
    TerDa = CDate(TxDa1.Text)
Else
    TerDa = Date
End If

NeuDa = DateAdd("d", ZaZil, TerDa)

If GlVrt = True Then 'virtuelle Leistungen vorhanden
    AktZa = UBound(GlTLe)
Else
    AktZa = 0
    ReDim GlTLe(AktZa, 13)
End If

If AdMin > 0 Then 'Standard-Gebührenkette 1
    If GlMVo = True Then 'mandantenbezogene Vorgaben verwenden
        ParNr = GlKe1 'Standardkette
    Else
        ParNr = GlKet(GlKe1, 0) 'Standardgebührenkette
    End If
    Set RS62 = New ADODB.Recordset
    RS62.CursorLocation = adUseClient
    Set RS62 = DBCmRe1("qryKet01E", "@IdxNr", ParNr)
    If RS62.RecordCount > 0 Then
        Do
        AktZa = AktZa + 1
        ReDimEx GlTLe, AktZa, 14
        GlTLe(AktZa, 0) = PatNr
        GlTLe(AktZa, 1) = 0
        GlTLe(AktZa, 2) = 2
        GlTLe(AktZa, 3) = 0
        GlTLe(AktZa, 4) = RS62.Fields("GOID").Value
        GlTLe(AktZa, 5) = RS62.Fields("IDKurz").Value
        GlTLe(AktZa, 6) = RS62.Fields("Zusatztext").Value
        GlTLe(AktZa, 7) = RS62.Fields("Steuer").Value
        GlTLe(AktZa, 8) = RS62.Fields("Rabatt").Value
        GlTLe(AktZa, 9) = CSng(Round(RS62.Fields("Multi").Value, 2))
        If GlTrG = True Then 'Standard-Gebührenkette mit Terminlänge multiplizieren
            GlTLe(AktZa, 10) = AdMin
            GlTLe(AktZa, 14) = CSng(((Round(RS62.Fields("Preis").Value, 2) * Round(RS62.Fields("Multi").Value, 2)) / FoFak) * AdMin)
        Else
            GlTLe(AktZa, 10) = RS62.Fields("x").Value
            GlTLe(AktZa, 14) = CSng(((Round(RS62.Fields("Preis").Value, 2) * Round(RS62.Fields("Multi").Value, 2)) / FoFak) * RS62.Fields("x").Value)
        End If
        If Not IsNull(RS62.Fields("Einheit").Value) Then GlTLe(AktZa, 11) = RS62.Fields("Einheit").Value
        If Not IsNull(RS62.Fields("Provision").Value) Then GlTLe(AktZa, 12) = RS62.Fields("Provision").Value
        GlTLe(AktZa, 13) = CSng(Round(RS62.Fields("Preis1").Value, 2) / FoFak)
        RS62.MoveNext
        Loop Until RS62.EOF
    End If
    RS62.Close
    Set RS62 = Nothing
Else
    Set CmBrs = frmTerKat.comBar03
    Set RpCon = frmTerKat.repCont9
    Set RpCls = RpCon.Columns
    Set RpSel = RpCon.SelectedRows
    Set CmCom = CmBrs.FindControl(CmCom, KA_SuCo1, , True)
    Set CmGrp = CmBrs.FindControl(CmGrp, KA_SuCo2, , True)
    DoEvents
    If RpSel.Count = 0 Then Exit Sub
    DoEvents
    TreKy = Chr$(CmCom.ItemData(CmCom.ListIndex))
    GrpNr = CLng(CmGrp.ItemData(CmGrp.ListIndex))
    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            Set RpCol = RpCls.Find(Kat_ID0)
            ParNr = RpRow.Record(RpCol.ItemIndex).Value
            Select Case TreKy
            Case "A": 'Gebührenkataloge
                Set RS61 = New ADODB.Recordset
                RS61.CursorLocation = adUseClient
                Set RS61 = DBCmRe1("qryKat01A", "@IdxNr", ParNr)
                If RS61.RecordCount > 0 Then
                    AktZa = AktZa + 1
                    ReDimEx GlTLe, AktZa, 14
                    GlTLe(AktZa, 0) = PatNr
                    GlTLe(AktZa, 1) = 0
                    GlTLe(AktZa, 2) = 2
                    GlTLe(AktZa, 3) = 0
                    GlTLe(AktZa, 4) = RS61.Fields("GOID").Value
                    GlTLe(AktZa, 5) = RS61.Fields("IDKurz").Value
                    GlTLe(AktZa, 6) = RS61.Fields("Zusatztext").Value
                    GlTLe(AktZa, 7) = RS61.Fields("Steuer").Value
                    GlTLe(AktZa, 8) = RS61.Fields("Rabatt").Value
                    GlTLe(AktZa, 9) = CSng(Round(RS61.Fields("Multi").Value, 2))
                    GlTLe(AktZa, 10) = 1
                    If Not IsNull(RS61.Fields("Einheit").Value) Then GlTLe(AktZa, 11) = RS61.Fields("Einheit").Value
                    If Not IsNull(RS61.Fields("Provision").Value) Then GlTLe(AktZa, 12) = RS61.Fields("Provision").Value
                    GlTLe(AktZa, 13) = CSng(Round(RS61.Fields("Preis1").Value, 2) / FoFak)
                    GlTLe(AktZa, 14) = CSng((Round(RS61.Fields("Preis1").Value, 2) * Round(RS61.Fields("Multi").Value, 2)) / FoFak)
                End If
                RS61.Close
                Set RS61 = Nothing
            Case "C": 'Diagnosen
