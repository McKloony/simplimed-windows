Dim NotVa As Integer
Dim GesLe As Integer
Dim AktLe As Integer
Dim TeLei As Boolean
Dim TxDum As VB.TextBox
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCo7 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmTerKop
Set TxFar = FM.txtFarbe
Set CmPri = FM.cmbPrior
Set CmTyp = FM.cmbStatu
Set CmMar = FM.cmbTeTyp
Set CmNot = FM.cmbNotVa
Set RpCo1 = FM.repCont1
Set RpRws = RpCo1.Rows
Set RpRcs = RpCo1.Records

Set RpCo7 = frmKatRC.repCont7
Set RpCls = RpCo7.Columns
Set RpSel = RpCo7.SelectedRows

AnzRe = RpSel.Count
AnzTa = RpRcs.Count

If TxFar.Text <> vbNullString Then
    If IsNumeric(TxFar.Text) = True Then
        Farbe = CLng(TxFar.Text)
    End If
End If

If CmMar.ListIndex > 0 Then
    TeMar = CmMar.ItemData(CmMar.ListIndex)
End If

FoFak = 1

If CmNot.ListCount > 0 Then
    If CmNot.ListIndex >= 0 Then
        NotVa = CmNot.ItemData(CmNot.ListIndex)
    Else
        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
            NotVa = GlMiT(GlSMo, 39) 'Standardmitarbeiter Online-Terminbuchungs Sytem
        Else
            NotVa = GlMaT(GlSMa, 25)
        End If
    End If
Else
    If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
        NotVa = GlMiT(GlSMo, 39) 'Standardmitarbeiter Online-Terminbuchungs Sytem
    Else
        NotVa = GlMaT(GlSMa, 25)
    End If
End If

If NotVa = 0 Then
    NotVa = 24
End If

If AnzRe > 0 Then
    If AnzTa > 0 Then
        Set RS45 = New ADODB.Recordset
        With RS45
            .CursorLocation = adUseClient
            .Source = "qryTerNeu"
            .ActiveConnection = DB1
            .CursorType = adOpenKeyset
            .LockType = adLockOptimistic
            .Open Options:=adCmdTableDirect
        End With
        If RS45.Supports(adAddNew) Then
    
            For Each RpRow In RpSel
                If RpRow.GroupRow = False Then
                    AktTa = 0
                    GeBet = 0
                    SeBet = 0
                    TeLei = False
                    AktRe = AktRe + 1
                    Set RpCol = RpCls.Find(Ter_ID0)
                    PatNr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Ter_ID2)
                    TerNr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Ter_IDP)
                    ManNr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Ter_IDM)
                    MitNr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Ter_MasTer)
                    MasNr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Ter_Patient)
                    PatNa = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Ter_TerBet)
                    GeBet = CDbl(Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1))
                    If GeBet > 0 Then
                        TeLei = True
                        SeBet = GeBet * AnzTa
                    End If

                    FM.Caption = "Terminassistent " & Format$(AktRe, "0000") & " / " & Format$(AnzRe, "0000")
                    DoEvents

                    If TeLei = True Then
                        AktLe = 0
                        Set RS50 = New ADODB.Recordset
                        RS50.CursorLocation = adUseClient
                        Set RS50 = DBCmRe1("qryAnKa1e", "@IdxNr", TerNr)
                        GesLe = RS50.RecordCount
                        If GesLe > 0 Then
                            ReDim GlTLe(GesLe, 14)
                            Do
                            AktLe = AktLe + 1
                            GlTLe(AktLe, 0) = PatNr
                            GlTLe(AktLe, 1) = 0
                            GlTLe(AktLe, 2) = 2
                            GlTLe(AktLe, 3) = 0
                            GlTLe(AktLe, 4) = RS50.Fields("GOID").Value
                            GlTLe(AktLe, 5) = RS50.Fields("IDKurz").Value
                            GlTLe(AktLe, 6) = RS50.Fields("Zusatztext").Value
                            GlTLe(AktLe, 7) = RS50.Fields("Steuer").Value
                            GlTLe(AktLe, 8) = RS50.Fields("Rabatt").Value
                            GlTLe(AktLe, 9) = CSng(Round(RS50.Fields("Multi").Value, 2))
                            GlTLe(AktLe, 10) = RS50.Fields("x").Value
                            GlTLe(AktLe, 14) = CSng(((Round(RS50.Fields("Preis1").Value, 2) * Round(RS50.Fields("Multi").Value, 2)) / FoFak) * RS50.Fields("x").Value)
                            If Not IsNull(RS50.Fields("Einheit").Value) Then GlTLe(AktLe, 11) = RS50.Fields("Einheit").Value
                            If Not IsNull(RS50.Fields("Provision").Value) Then GlTLe(AktLe, 12) = RS50.Fields("Provision").Value
                            GlTLe(AktLe, 13) = CSng(Round(RS50.Fields("Preis1").Value, 2) / FoFak)
                            RS50.MoveNext
                            Loop Until RS50.EOF
                        End If
                        RS50.Close
                        Set RS50 = Nothing
                    End If
                    DoEvents

                    For Each RpRec In RpRcs 'markierte Termine
                        If RpRec.Item(3).Checked = True Then
                            AktTa = AktTa + 1
                            TeBtr = "Serienrechnung " & Format$(AktTa, "000") & " / " & Format$(AnzTa, "000")
                            GuiID = CreateID("T")
                            If IsDate(RpRec.Item(2).Value) = True Then
                                DaBeg = CDate(RpRec.Item(2).Value)
                                DaEnd = CDate(RpRec.Item(2).Value)
                            End If

                            RS45.AddNew
                            RS45.Fields("ID0").Value = PatNr
                            RS45.Fields("IDR").Value = GlRau 'Standardraum
                            RS45.Fields("IDSer").Value = 6 'Serientermin
                            RS45.Fields("IDKurz").Value = vbNullString
                            If GlTyp < 2 Then
                                RS45.Fields("ZeiVon").Value = Format$(DaBeg, "dd.mm.yyyy") & " 08:00"
                                RS45.Fields("ZeiBis").Value = Format$(DaEnd, "dd.mm.yyyy") & " 09:00"
                            Else
                                RS45.Fields("ZeiVon").Value = "08:00"
                                RS45.Fields("ZeiBis").Value = "09:00"
                            End If
                            RS45.Fields("VonDat").Value = Format$(DaBeg, "dd.mm.yyyy")
                            RS45.Fields("BisDat").Value = Format$(DaEnd, "dd.mm.yyyy")
                            RS45.Fields("Patient").Value = PatNa
                            RS45.Fields("Priorität").Value = 2
                            RS45.Fields("Vorwarn").Value = 1
                            RS45.Fields("Farbe").Value = Farbe
                            RS45.Fields("Anzahl").Value = AnzTa
                            RS45.Fields("Farbtyp").Value = 3
                            RS45.Fields("TerTyp").Value = TeMar
                            RS45.Fields("Behindert").Value = 0
                            RS45.Fields("IDM").Value = MitNr
                            RS45.Fields("IDP").Value = ManNr
                            RS45.Fields("SerTyp").Value = 1
                            RS45.Fields("MasTer").Value = MasNr
                            RS45.Fields("Raum").Value = vbNullString
                            RS45.Fields("Erinnerung").Value = 0
                            RS45.Fields("Selekt").Value = 0
                            RS45.Fields("Wiederholung").Value = -1 'WICHTIG!
                            RS45.Fields("Aufgabe").Value = 0
                            RS45.Fields("GesBetrag").Value = GeBet
                            RS45.Fields("SerBetrag").Value = SeBet
                            If CmNot.Enabled = True Then
                                RS45.Fields("NotifyStatus").Value = 3 'Senden
                                RS45.Fields("NotifyValue").Value = NotVa
                            End If
                            If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                                RS45.Fields("Replicated").Value = 1
                                RS45.Fields("DAVChange").Value = 1
                                RS45.Fields("LastModification").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                                RS45.Fields("DAVDate").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                            Else
                                RS45.Fields("Replicated").Value = 0
                                RS45.Fields("DAVChange").Value = 0
                            End If
                            RS45.Fields("RzAnz").Value = AnzTa
                            RS45.Fields("RzAkt").Value = AktTa
                            RS45.Fields("Datum").Value = Now
                            RS45.Fields("Change").Value = Now
                            RS45.Fields("GuiID").Value = GuiID
                            RS45.Fields("Vorlage").Value = -1 'WICHTIG!
                            If GlOTS = True Then 'Online-Terminbuchungs System
                                RS45.Fields("OnlGes").Value = 0
                            End If
                            RS45.Update
                            DoEvents
                                
                            Set RS47 = New ADODB.Recordset 'neue Termin ID ermitteln
                            RS47.CursorLocation = adUseClient
                            Set RS47 = DBCmRe1("qryTerGui3", "@IdStr", GuiID)
                            If RS47.RecordCount > 0 Then
                                NeTer = RS47.Fields("ID2").Value
                            Else
                                NeTer = 0
                            End If
                            RS47.Close
                            Set RS47 = Nothing
                            DoEvents

                            If TeLei = True Then 'Leistungen vorhanden
                                GesLe = UBound(GlTLe)
                                If GlTyp < 2 Then
                                    SQL2 = "SELECT * FROM dbo.qryAnKa1 WHERE ID1 = -1"
                                Else
                                    SQL2 = "SELECT * FROM qryAnKa1 WHERE [ID1] = -1;"
                                End If
                                Set RS48 = New ADODB.Recordset
                                With RS48
                                    .CursorLocation = adUseClient
                                    .Source = SQL2
                                    .ActiveConnection = DB1
                                    .CursorType = adOpenDynamic
                                    .LockType = adLockOptimistic
                                    .Open Options:=adCmdText
                                End With
                                If RS48.Supports(adAddNew) Then
                                    For AktLe = 1 To GesLe
                                        RS48.AddNew
                                        RS48.Fields("ID0").Value = GlTLe(AktLe, 0)
                                        RS48.Fields("ID2").Value = NeTer
                                        RS48.Fields("Sorter").Value = GlTLe(AktLe, 2)
                                        RS48.Fields("MasTer").Value = MasNr
                                        RS48.Fields("GOID").Value = GlTLe(AktLe, 4)
                                        RS48.Fields("IDKurz").Value = GlTLe(AktLe, 5)
                                        RS48.Fields("Kommentar").Value = GlTLe(AktLe, 6)
                                        If GlTLe(AktLe, 7) <> vbNullString Then RS48.Fields("Steuer").Value = GlTLe(AktLe, 7)
                                        If GlTLe(AktLe, 8) <> vbNullString Then RS48.Fields("Rabatt").Value = GlTLe(AktLe, 8)
                                        If GlTLe(AktLe, 9) <> vbNullString Then RS48.Fields("Multi").Value = GlTLe(AktLe, 9)
                                        If GlTLe(AktLe, 10) <> vbNullString Then RS48.Fields("x").Value = GlTLe(AktLe, 10)
                                        If GlTLe(AktLe, 11) <> vbNullString Then RS48.Fields("Einheit").Value = GlTLe(AktLe, 11)
                                        If GlTLe(AktLe, 12) <> vbNullString Then RS48.Fields("Provision").Value = GlTLe(AktLe, 12)
                                        RS48.Fields("Preis1").Value = GlTLe(AktLe, 13)
                                        RS48.Fields("Preis2").Value = GlTLe(AktLe, 14)
                                        RS48.Update
                                    Next AktLe
                                End If
                                RS48.Close
                                Set RS48 = Nothing
                            End If

                        End If
                    Next RpRec
                End If
            Next RpRow
            
        End If
    End If
End If

Set RpRcs = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing
Set RpCo7 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_Ser " & Err.Number

End Sub
Public Sub Ter_Spa(Optional ByVal RmuNr As Long)
On Error GoTo KoErr
'Überprüft, ob am neu eingestellten Datem, freie Zeiten sind

Dim ManNr As Long 'Mandant
Dim TmpRa As Long 'Raum
Dim AdMin As Long
Dim StaDa As Date
Dim FreZe As Date
Dim StaZe As Date
Dim EndZe As Date
Dim Behin As Integer
Dim TeDop As Boolean
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmTermVo
Set CmRmu = FM.cmbRaum1
Set CmMan = FM.cmbBehan
Set CmMta = FM.cmbMitar
Set TxBeG = FM.txtBehin
Set TxZeV = FM.txtVonZe
Set TxZeB = FM.txtBisZe
Set RpCo6 = FM.repCont6
Set RpCls = RpCo6.Columns
Set RpSel = RpCo6.SelectedRows

TmpRa = CmRmu.ItemData(CmRmu.ListIndex)
If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
    ManNr = CmMta.ItemData(CmMta.ListIndex)
Else
    ManNr = CmMan.ItemData(CmMan.ListIndex)
End If
StaZe = TimeValue(TxZeV.Text)
EndZe = TimeValue(TxZeB.Text)
AdMin = DateDiff("n", TimeValue(StaZe), TimeValue(EndZe))
If TxBeG.Text <> vbNullString Then
    If IsNumeric(TxBeG.Text) Then
        Behin = CInt(TxBeG.Text)
    Else
        Behin = 0
    End If
Else
    Behin = 0
End If

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        Set RpCol = RpCls.Find(2)
        If IsDate(RpRow.Record(RpCol.ItemIndex).Value) = True Then
            StaDa = CDate(RpRow.Record(RpCol.ItemIndex).Value)
            TeDop = Ter_Pru(StaDa, StaZe, EndZe, RmuNr, Behin, ManNr)
            If TeDop = True Then
                If GlSpP = True Then 'Überprüfung der Sprechzeiten
                    Ter_FrS StaDa, StaZe, AdMin, RmuNr, , , Behin, ManNr
                Else
                    Ter_Fre StaDa, StaZe, AdMin, RmuNr, , , Behin, ManNr
                End If
                If TeFre.Gefun = True Then
                    FreZe = TeFre.StaDa
                    Set RpCol = RpCls.Find(3)
                    RpRow.Record(RpCol.ItemIndex).Value = Format$(FreZe, "hh:mm")
                    Set RpCol = RpCls.Find(4)
                    RpRow.Record(RpCol.ItemIndex).Value = Format$(DateAdd("n", AdMin, FreZe), "hh:mm")
                    Set RpCol = RpCls.Find(6)
                    RpRow.Record(RpCol.ItemIndex).Value = FaMan
                Else
                    Set RpCol = RpCls.Find(3)
                    RpRow.Record(RpCol.ItemIndex).Value = Format$(StaZe, "hh:mm")
                    Set RpCol = RpCls.Find(4)
                    RpRow.Record(RpCol.ItemIndex).Value = Format$(DateAdd("n", AdMin, StaZe), "hh:mm")
                    Set RpCol = RpCls.Find(6)
                    RpRow.Record(RpCol.ItemIndex).Value = FaNeg
                End If
            Else
                Set RpCol = RpCls.Find(6)
                RpRow.Record(RpCol.ItemIndex).Value = vbWhite
                Set RpCol = RpCls.Find(3)
                RpRow.Record(RpCol.ItemIndex).Value = Format$(StaZe, "hh:mm")
                Set RpCol = RpCls.Find(4)
                RpRow.Record(RpCol.ItemIndex).Value = Format$(DateAdd("n", AdMin, StaZe), "hh:mm")
            End If
        End If
    End If
End If

RpCo6.Populate

Set RpCo6 = Nothing
Set RpCls = Nothing
Set RpSel = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Ter_Spa " & Err.Number
Resume Next

End Sub
