    StaTa = ZyMo2.ItemData(ZyMo2.ListIndex)
    DifMo = ZyMe3.ItemData(ZyMe3.ListIndex)
    AktZa = 1
    TmDat() = WoTaJa(StaTa, Year(StaDa), TagNr, DifMo) 'Alle Termine im akuellen Jahr
    For AktZa = 1 To UBound(TmDat)
        If TmDat(AktZa) = StaDa Then
            Exit For
        End If
    Next AktZa
    DifZa = (UBound(TmDat) - AktZa) + 1 'Vergebbare Termine aktuelles Jahr
    If DaEnd = True Then
        If Year(EndDa) > Year(StaDa) Then
            For AktTe = 1 To DifZa
                ReDim Preserve VoDat(AktTe)
                ReDim Preserve VoZei(AktTe)
                ReDim Preserve VoRau(AktTe)
                ReDim Preserve VoFar(AktTe)
                If KeiBe = False Then 'keine belegten Termine berücksichtigen
                    TeVor = Ter_Pru(TmDat(AktZa), StaZe, EndZe, RmuNr, Behin, BehNr)
                Else
                    TeVor = False
                End If
                VoDat(AktTe) = TmDat(AktZa)
                If TeVor = True Then
                    If GlSpP = True Then 'Überprüfung der Sprechzeiten
                        Ter_FrS StaDa, StaZe, AdMin, RmuNr, , , Behin, BehNr
                    Else
                        Ter_Fre StaDa, StaZe, AdMin, RmuNr, , , Behin, BehNr
                    End If
                    If TeFre.Gefun = True Then
                        VoZei(AktTe) = TeFre.StaDa
                        VoRau(AktTe) = TeFre.RmuNr
                        VoFar(AktTe) = FaAng
                    Else
                        VoZei(AktTe) = StaZe
                        VoRau(AktTe) = RmuNr
                        VoFar(AktTe) = FaNeg
                    End If
                Else
                    VoZei(AktTe) = StaZe
                    VoRau(AktTe) = RmuNr
                    VoFar(AktTe) = vbWhite
                End If
                AktZa = AktZa + 1
            Next AktTe
            AktTe = AktTe - 1
            AktJa = 0
    
            Do
            AktZa = 0
            AktJa = AktJa + 1
            TmDat() = WoTaJa(StaTa, Year(StaDa) + AktJa, TagNr, DifMo) 'Vergebbare Termine im neuen Jahr
                Do
                AktTe = AktTe + 1
                AktZa = AktZa + 1
                If TmDat(AktZa) >= EndDa Then Exit Do
                If AktZa >= UBound(TmDat) Then Exit Do
                ReDim Preserve VoDat(AktTe)
                ReDim Preserve VoZei(AktTe)
                ReDim Preserve VoRau(AktTe)
                ReDim Preserve VoFar(AktTe)
                If KeiBe = False Then 'keine belegten Termine berücksichtigen
                    TeVor = Ter_Pru(TmDat(AktZa), StaZe, EndZe, RmuNr, Behin, BehNr)
                Else
                    TeVor = False
                End If
                VoDat(AktTe) = TmDat(AktZa)
