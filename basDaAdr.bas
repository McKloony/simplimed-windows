            .CursorType = adOpenDynamic
            .LockType = adLockOptimistic
            .Open Options:=adCmdTableDirect
        End With
        If RS46.RecordCount > 0 Then
            If RS46.Supports(adDelete) Then
                RS46.Move RpRow.Index
                RS46.Delete
            End If
        End If
        RS46.Close
        Set RS46 = Nothing
        
        If GlJet = True Then SDBSav
        
        Opt_BLZ SuStr, SuTyp
        
        RpNav.MoveToRow RowNr
    End If
End If

Set RpSel = Nothing
Set RpRow = Nothing
Set RpNav = Nothing
Set RpCon = Nothing

Exit Sub

ReErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Opt_BLo " & Err.Number
Resume Next
        
End Sub
Public Sub Opt_BLs(ByVal SuStr As String, ByVal SuTyp As Integer)
On Error GoTo ReErr
'Speichert Gruppen in Datenbank

Dim SQL1 As String
Dim TmTag As String
Dim RpCon As XtremeReportControl.ReportControl

Set FM = frmOptions
Set RpCon = FM.repCont4
Set RpRcs = RpCon.Records

If GlTyp < 2 Then
    Select Case SuTyp
    Case 1: SQL1 = "SELECT * FROM dbo.qryBLZ WHERE [BLZ] Like '" & SuStr & "%'"
    Case 2: SQL1 = "SELECT * FROM dbo.qryBLZ WHERE [Bank] Like '" & SuStr & "%'"
    End Select
Else
    Select Case SuTyp
    Case 1: SQL1 = "SELECT * FROM qryBLZ WHERE [BLZ] Like '" & SuStr & "%';"
    Case 2: SQL1 = "SELECT * FROM qryBLZ WHERE [Bank] Like '" & SuStr & "%';"
    End Select
End If

Set RS46 = New ADODB.Recordset
With RS46
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With
If RS46.RecordCount > 0 Then
    If RS46.Supports(adUpdate) Then
        RS46.MoveFirst
        For Each RpRec In RpRcs
            For Each RpItm In RpRec
                If Left$(RpItm.Tag, 1) = "@" Then
                    TmTag = Mid$(RpItm.Tag, 2, Len(RpItm.Tag) - 1)
                    If RpItm.HasCheckbox = True Then
                        RS46.Fields(TmTag).Value = RpItm.Checked
                    Else
                        RS46.Fields(TmTag).Value = RpItm.Value
                    End If
                End If
            Next RpItm
            RS46.Update
            RS46.MoveNext
        Next RpRec
    End If
End If
RS46.Close
Set RS46 = Nothing

If GlJet = True Then SDBSav

Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCon = Nothing

Exit Sub

ReErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Opt_BLs " & Err.Number
Resume Next
        
End Sub
