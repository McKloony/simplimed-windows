Public Sub Adr_Grp()
On Error GoTo ReErr
'Überprüft die Adressemgruppen

Dim SQL1 As String
Dim AktZa As Long
Dim GesZa As Long
Dim AkGrp As Long
Dim GruNr As Long
Dim SuStr As String
Dim GrStr As String
Dim AktPo As Integer
Dim StaPo As Integer
Dim TxDum As VB.TextBox

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qryAdrAl ORDER BY IDKurz"
Else
    SQL1 = "SELECT * FROM qryAdrAl ORDER BY [IDKurz];"
End If

Set RS46 = New ADODB.Recordset
With RS46
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenKeyset
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With

GesZa = RS46.RecordCount

If GesZa > 0 Then
    Set FM = frmStatus
    Set Lbl01 = FM.lblLab01
    Set PrBr1 = FM.prbStat1
    Set PrBr2 = FM.prbStat2
    Set TxDum = FM.txtDummy
    DoEvents
    RS46.MoveFirst
    DoEvents
    PrBr1.Min = 0
    PrBr1.Max = GesZa
    Lbl01.Caption = "Adressengruppenprüfung..."
    FM.Show
    DoEvents
    Do
    If RS46.Fields("TreKey").Value <> vbNullString Then
        SuStr = RS46.Fields("TreKey").Value
    Else
        SuStr = vbNullString
    End If
    If Left$(SuStr, 1) = "o" Then
        StaPo = 2
        GrStr = vbNullString
        Do
        AktPo = InStr(StaPo, SuStr, "o", vbTextCompare)
        If AktPo > 0 Then
            If Mid$(SuStr, StaPo, AktPo - StaPo) <> vbNullString Then
                If IsNumeric(Mid$(SuStr, StaPo, AktPo - StaPo)) = True Then
                    GruNr = CLng(Mid$(SuStr, StaPo, AktPo - StaPo))
                    For AkGrp = 1 To UBound(GlPaG)
                        If GruNr = CInt(GlPaG(AkGrp, 0)) Then
                            If GrStr = vbNullString Then
                                GrStr = GlPaG(AkGrp, 1)
                            Else
                                GrStr = GrStr & "; " & GlPaG(AkGrp, 1)
                            End If
                        End If
                    Next AkGrp
                End If
            End If
        End If
        StaPo = AktPo + 1
        Loop Until AktPo = 0
    End If
    If GrStr <> vbNullString Then
        If Len(GrStr) > 250 Then
            GrStr = Left$(GrStr, 250)
        End If
        RS46.Fields("AdrGruppe").Value = GrStr
    Else
        RS46.Fields("AdrGruppe").Value = vbNullString
    End If
    RS46.Update
    DoEvents
    If TxDum.Text = "B" Then Exit Do 'Abbrechen
    PrBr1.Value = AktZa
    AktZa = AktZa + 1
    RS46.MoveNext
    Loop Until RS46.EOF
End If

RS46.Close
Set RS46 = Nothing

Exit Sub

ReErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Adr_Grp " & Err.Number
Resume Next

End Sub

Private Sub Adr_Kat(ByVal PatNr As Long, ByVal KatNr As Integer)
On Error GoTo LiErr
'Passt die nicht abgeschlossenen Rechnungen an den neuen Katalog an

Dim IdxNr As Long
Dim ReNum As Long
Dim NePre As Double
Dim ReBet As Double
Dim SuStr As String
Dim ReStr As String
Dim GesZa As Integer
Dim KrTyp As Integer
Dim ReMel As Boolean
Dim AnzVo As Boolean
Dim ReSto As Boolean
Dim Mld1, Tit1 As String

Tit1 = "Gebührenkatalog wurde geändert"

DBCmEx2 "qrySimReKat", "@IdKat", "@IdxNr", KatNr, PatNr
DoEvents
Set RS46 = New ADODB.Recordset 'Offene Rechnungen des Patienten
RS46.CursorLocation = adUseClient
Set RS46 = DBCmRe1("qrySimReOf1", "@IdxNr", PatNr)
GesZa = RS46.RecordCount
If GesZa > 0 Then
    Do
    ReNum = RS46.Fields("ID1").Value
    ReStr = RS46.Fields("RechNr").Value
    ReBet = RS46.Fields("GesBetrag").Value
    ReSto = CBool(RS46.Fields("Storniert").Value)
    Mld1 = "Die Gebühreneinträge der Rechnung " & ReStr & " wurden automatisch angepasst."
    
    Set RS47 = New ADODB.Recordset 'Alle Positionen dieser Rechnung
    RS47.CursorLocation = adUseClient
    Set RS47 = DBCmRe1("qrySimAbIdx", "@IdxNr", ReNum)
    If RS47.RecordCount > 0 Then
        If ReSto = False Then
            AnzVo = False
            Do
            If RS47.Fields("ID1").Value = 6 Then
                AnzVo = True
                Exit Do
            End If
            RS47.MoveNext
            Loop Until RS47.EOF
            
            If AnzVo = False Then
                RS47.MoveFirst
                Do
                If RS47.Fields("GONr").Value <> vbNullString Then
                    IdxNr = RS47.Fields("ID2").Value
                    KrTyp = RS47.Fields("ID1").Value
                    SuStr = RS47.Fields("GONr").Value
                    If KrTyp = 2 Then
                        Set RS44 = New ADODB.Recordset
                        RS44.CursorLocation = adUseClient
                        Set RS44 = DBCmRe2("qryKat01G", "@IdxNr", "@IdStr", KatNr, SuStr)
                        If RS44.RecordCount > 0 Then
                            NePre = RS44.Fields("Preis1").Value
                            DBCmEx2 "qrySimAbAnp", "@IdPre", "@IdxNr", NePre, IdxNr
                        End If
                        RS44.Close
                        Set RS44 = Nothing
                    End If
                End If
                RS47.MoveNext
                Loop Until RS47.EOF
                SPopu Tit1, Mld1, IC48_Warning
            End If
        End If
    End If
    RS47.Close
    Set RS47 = Nothing
    
    DoEvents
    ReMel = Adr_Rch(ReNum, ReBet)
    DoEvents
    
    RS46.MoveNext
    Loop Until RS46.EOF
End If
RS46.Close
Set RS46 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Adr_Kat " & Err.Number
Resume Next

End Sub

Public Sub Adr_Kop()
On Error GoTo KoErr
'Kopiert die aktuelle Adresse

Dim SQL1 As String
Dim AnzFe As Long
Dim AdPIN As Long
Dim FldNr As Integer
Dim AktZa As Integer
Dim IdStr As String
Dim FldWe() As String
Dim FeFir As XtremeSuiteControls.FlatEdit
Dim FeNam As XtremeSuiteControls.FlatEdit
Dim FeVor As XtremeSuiteControls.FlatEdit
Dim FeOrt As XtremeSuiteControls.FlatEdit

Set FM = frmAdress
Set FeNum = FM.txtS1F30
Set FeFir = FM.txtS1F01
Set FeNam = FM.txtS1F05
Set FeVor = FM.txtS1F04
Set FeOrt = FM.txtS1F09

IdStr = AErSu(FeFir.Text, FeNam.Text, FeVor.Text, FeOrt.Text, CLng(FeNum.Text))

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qryAdress WHERE ID0 = " & GlAId
Else
    SQL1 = "SELECT * FROM qryAdress WHERE [ID0] = " & GlAId & ";"
End If

Set RS40 = New ADODB.Recordset
With RS40
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenKeyset
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With
If RS40.RecordCount > 0 Then
    AdPIN = Adr_Let()
    GlAdG = CreateID("A")
    AnzFe = RS40.Fields.Count
    ReDim FldWe(AnzFe)
    FldNr = 1
    For Each FL101 In RS40.Fields
        If Not IsNull(FL101.Value) Then
            If FL101.Type = adBoolean Then
                If FL101.Value = True Then
                    FldWe(FldNr) = -1
                Else
                    FldWe(FldNr) = 0
                End If
            Else
                FldWe(FldNr) = FL101.Value
            End If
        End If
        FldNr = FldNr + 1
    Next FL101
    FldNr = 1
    If RS40.Supports(adAddNew) Then
        RS40.AddNew
        For Each FL101 In RS40.Fields
            Select Case FL101.Name
            Case "ID0":
            Case "Geboren":
            Case "Mandant":
                    RS40.Fields(FL101.Name).Value = Format$(AdPIN, "000000")
            Case "Diagnose":
            Case "upsize_ts":
            Case "Replicated":
                    If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                        RS40.Fields(FL101.Name).Value = 1
                    Else
                        RS40.Fields(FL101.Name).Value = 0
                    End If
            Case "DAVChange":
                    If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                        RS40.Fields(FL101.Name).Value = 1
                    Else
                        RS40.Fields(FL101.Name).Value = 0
                    End If
            Case "LastModification":
                    If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                        RS40.Fields(FL101.Name).Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                    End If
            Case "DAVDate":
                    If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                        RS40.Fields(FL101.Name).Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                    End If
            Case "GuiID":
                    RS40.Fields(FL101.Name).Value = GlAdG
            Case "IDKurz":
                    RS40.Fields(FL101.Name).Value = IdStr
            Case "Geändert":
                    RS40.Fields(FL101.Name).Value = Date
            Case Else:
                    If Not FL101.Type = 128 Then
                        If Not FldWe(FldNr) = vbNullString Then
                            RS40.Fields(FL101.Name).Value = FldWe(FldNr)
                        End If
                    End If
            End Select
            FldNr = FldNr + 1
        Next FL101
        RS40.Update
    End If
End If
RS40.Close
Set RS40 = Nothing

DoEvents
GlAId = S_AdGui(GlAdG, "ID0")

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Adr_Kop " & Err.Number
Resume Next

End Sub
