If TxZei1.Text <> vbNullString Then
    ZeiAr = TxZei1.Text
Else
    ZeiAr = GlSZe 'Sprechzietenstring
End If

If TxZei2.Text <> vbNullString Then
    ZeiBu = TxZei2.Text
Else
    ZeiBu = GlSZe 'Sprechzietenstring
End If

If cmFach.Text <> vbNullString Then
    TmIdx = cmFach.ItemData(cmFach.ListIndex)
Else
    TmIdx = GlFri
End If

If cmRas1.Text <> vbNullString Then
    IdRa1 = cmRas1.ItemData(cmRas1.ListIndex)
Else
    IdRa1 = GlZeR 'Zeitrasterindex
End If

If cmRas2.Text <> vbNullString Then
    IdRa2 = cmRas2.ItemData(cmRas2.ListIndex)
Else
    IdRa2 = GlZeR 'Zeitrasterindex
End If

If cmMaxT.Text <> vbNullString Then
    MaxTe = cmMaxT.ItemData(cmMaxT.ListIndex)
Else
    MaxTe = 0
End If

If cmMaxP.Text <> vbNullString Then
    MaxPa = cmMaxP.ItemData(cmMaxP.ListIndex)
Else
    MaxPa = 1
End If

If cmVorl.Text <> vbNullString Then
    Vorla = cmVorl.ItemData(cmVorl.ListIndex)
Else
    Vorla = 2
End If

If cmBuRa.Text <> vbNullString Then
    BuRad = cmBuRa.ItemData(cmBuRa.ListIndex)
Else
    BuRad = 12
End If

If cmNoti.Text <> vbNullString Then
    Notif = cmNoti.ItemData(cmNoti.ListIndex)
Else
    Notif = 24
End If

Select Case GlBut
Case RibTab_Mandanten:
    For AktZa = 1 To UBound(GlMan)
        If GlMId = GlMan(AktZa, 2) Then
            MaIdx = AktZa
            Exit For
        End If
    Next AktZa
Case RibTab_Mitarbeit:
    For AktZa = 1 To UBound(GlMiK)
        If GlMId = GlMiK(AktZa, 2) Then
            MaIdx = AktZa
            Exit For
        End If
    Next AktZa
End Select

TmGui = CreateID("M")

If GlTyp < 2 Then
    If GlMId < 0 Then
        SQL1 = "SELECT * FROM dbo.qryAdress WHERE [GuiID] = '" & GlAdG
    Else
        SQL1 = "SELECT * FROM dbo.qryAdress WHERE ID0 = " & GlMId
    End If
Else
    If GlMId < 0 Then
        SQL1 = "SELECT * FROM qryAdress WHERE [GuiID] = '" & GlAdG & "';"
    Else
        SQL1 = "SELECT * FROM qryAdress WHERE [ID0] = " & GlMId & ";"
    End If
End If

If FeKur.Text <> vbNullString Then
    Set RS40 = New ADODB.Recordset
    With RS40
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenKeyset
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With
    If RS40.RecordCount > 0 Then
        If RS40.Supports(adUpdate) Then
            For Each AktCo In FM.Controls
                If AktCo.Tag <> vbNullString Then
                    Select Case Left$(AktCo.Name, 3)
                    Case "txt": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                                If Left$(AktCo.Tag, 1) = "1" Then
                                    Select Case AktCo.Name
                                    Case "txtS1F33":
                                            If AktCo.Text = vbNullString Then
                                                RS40.Fields(TagWe).Value = Null
                                            Else
                                                RS40.Fields(TagWe).Value = Replace(AktCo.Text, ",", ".", 1)
                                            End If
                                    Case "txtS1F13":
                                            If InStr(1, "_", AktCo.Text, vbTextCompare) = 0 Then
                                                If IsDate(AktCo.Text) Then
                                                    RS40.Fields(TagWe).Value = DateValue(AktCo.Text)
                                                End If
                                            End If
                                    Case "txtS2F25":
                                            If InStr(1, "_", AktCo.Text, vbTextCompare) = 0 Then
                                                If IsDate(AktCo.Text) Then
                                                    RS40.Fields(TagWe).Value = DateValue(AktCo.Text)
                                                End If
                                            End If
                                    Case "txtS2F27":
                                            If InStr(1, "_", AktCo.Text, vbTextCompare) = 0 Then
                                                If IsDate(AktCo.Text) Then
                                                    RS40.Fields(TagWe).Value = DateValue(AktCo.Text)
                                                End If
                                            End If
                                    Case "txtS2F03":
                                            If AktCo.Text = vbNullString Then
                                                RS40.Fields(TagWe).Value = Null
                                            Else
                                                If Len(AktCo.Text) > 50 Then
                                                    RS40.Fields(TagWe).Value = Left$(AktCo.Text, 50)
                                                Else
                                                    RS40.Fields(TagWe).Value = Trim$(AktCo.Text)
                                                End If
                                            End If
                                    Case "txtZSRnr":
                                            If AktCo.Text = vbNullString Then
                                                RS40.Fields(TagWe).Value = Null
                                            Else
                                                If Len(AktCo.Text) > 7 Then
                                                    RS40.Fields(TagWe).Value = Left$(AktCo.Text, 7)
                                                Else
                                                    RS40.Fields(TagWe).Value = Trim$(AktCo.Text)
                                                End If
                                            End If
                                    Case "txtGLNum":
                                            If AktCo.Text = vbNullString Then
                                                RS40.Fields(TagWe).Value = Null
                                            Else
                                                If Len(AktCo.Text) > 20 Then
                                                    RS40.Fields(TagWe).Value = Left$(AktCo.Text, 20)
                                                Else
                                                    RS40.Fields(TagWe).Value = Trim$(AktCo.Text)
                                                End If
                                            End If
                                    Case Else:
                                            If AktCo.Text = vbNullString Then
                                                RS40.Fields(TagWe).Value = Null
                                            Else
                                                RS40.Fields(TagWe).Value = Trim$(AktCo.Text)
                                            End If
                                    End Select
                                    AktCo.Tag = 0 & TagWe
                                End If
                    Case "cmb": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                                If Left$(AktCo.Tag, 1) = "1" Then
                                    Select Case AktCo.Name
                                    Case "cmbS1F10":
                                            RS40.Fields(TagWe).Value = AktCo.Text
                                    Case "cmbReTyp":
                                            RS40.Fields(TagWe).Value = Left$(AktCo.Text, 1)
                                    Case Else:
                                            If AktCo.Text <> vbNullString Then
                                                RS40.Fields(TagWe).Value = AktCo.ItemData(AktCo.ListIndex)
                                            Else
                                                RS40.Fields(TagWe).Value = AktCo.ItemData(0)
                                            End If
                                    End Select
                                    AktCo.Tag = 0 & TagWe
                                End If
                    Case "chk": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                                If Left$(AktCo.Tag, 1) = "1" Then
                                    RS40.Fields(TagWe).Value = AktCo.Value
                                    AktCo.Tag = 0 & TagWe
                                End If
                    Case "msk": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                            If Left$(AktCo.Tag, 1) = "1" Then
                                If IsDate(AktCo.Text) Then
                                    RS40.Fields(TagWe).Value = Trim$(AktCo.Text)
                                Else
                                    RS40.Fields(TagWe).Value = Null
                                End If
                                AktCo.Tag = 0 & TagWe
                            End If
                    End Select
                End If
            Next AktCo

            For Each RpRec In RpRcs
                If RpRec.Item(0).Checked = True Then
                    Recht = Recht & "1"
                Else
                    Recht = Recht & "0"
                End If
            Next RpRec

            RS40.Fields("Kopien").Value = 1
            RS40.Fields("Geändert").Value = Date
            RS40.Fields("OnlVor").Value = Vorla 'Vorlaufzeit für Terminbuchung
            RS40.Fields("OnlRas").Value = IdRa1
            RS40.Fields("OnlRa2").Value = IdRa2
            RS40.Fields("OnlRa1").Value = BuRad
            RS40.Fields("OnlTmp").Value = Notif
            RS40.Fields("OnlMax").Value = MaxTe 'Anzahl maximal buchbarer Termine pro Tag
            RS40.Fields("OnlMa2").Value = MaxPa 'Anzahl maximal buchbarer Termine pro Patient und Tag
            RS40.Fields("Kontoinhaber").Value = Recht
            RS40.Fields("Sprechzeiten").Value = ZeiAr
            RS40.Fields("Buchungszeiten").Value = ZeiBu

            RS40.Update
        End If
    End If

    RS40.Close
    Set RS40 = Nothing
    
    If GlJet = True Then SDBSav

    If GlMId >= 0 Then
        GlNeK = GlKoX 'Protokolleintrag
        With GlNeK
            .PatNr = GlMan(GlSMa, 2)
            .IdxNr = 0
            .EiDat = Format$(Date, "dd.mm.yyyy")
            .EiZei = TimeValue(Now)
            .EiTyp = 104
            Select Case GlBut
            Case RibTab_Mandanten: .TeStr = "Mandant geändert - " & FM.txtS1F11.Text
            Case RibTab_Verordner: .TeStr = "Arzt geändert - " & FM.txtS1F11.Text
            Case RibTab_Mitarbeit: .TeStr = "Mitarbeiter geändert - " & FM.txtS1F11.Text
            End Select
            .ZiStr = Format$(Now, "hh:mm") & " Uhr"
            .NeuEi = True
            .KeiAk = True
            .Mitar = GlMiA(GlSmI, 2)
        End With
        S_Prot
    End If
Else
    Mld1 = "Das Feld Suchname muß erst ausgefüllt werden, damit dieser Datensatz gespeichern werden kann"
    Tit1 = "Fehlende Angaben"
    WindowMess Mld1, Dial2, Tit1, FM.hwnd
End If

Set RpCo5 = Nothing

Exit Sub

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Man_Sav " & Err.Number
Resume Next

End Sub
Public Sub Man_Set(ByVal IdGes As Boolean, ByVal ManNr As Long)
On Error GoTo DaErr
'Kalenderspalte ausblenden

Dim FeIdx As Integer
Dim IdxZa As Integer
Dim AktZa As Integer
Dim GesZa As Integer

Set FM = frmMain

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

IdxZa = 1

Screen.MousePointer = vbHourglass
clFen.FenDsk 2

If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
    For AktZa = 1 To UBound(GlMiA) 'aktive Mitarbeiter
        If ManNr = GlMiA(AktZa, 2) Then
            GlMiA(AktZa, 12) = IdGes
            Exit For
        End If
    Next AktZa
    For AktZa = 1 To UBound(GlMiA) 'aktive Mitarbeiter
        If CBool(GlMiA(AktZa, 12)) = False Then
            GesZa = GesZa + 1
        End If
    Next AktZa
    If GesZa > 0 Then
        ReDim GlMiT(GesZa, 40) 'aktive Mitarbeier + Terminspalte
        For AktZa = 1 To UBound(GlMiA) 'aktive Mitarbeiter
            If CBool(GlMiA(AktZa, 12)) = False Then
                GlMiT(IdxZa, 0) = IdxZa
                For FeIdx = 1 To 40
                    GlMiT(IdxZa, FeIdx) = GlMiA(AktZa, FeIdx)
                Next FeIdx
                IdxZa = IdxZa + 1
            End If
        Next AktZa
    End If
Else
    For AktZa = 1 To UBound(GlMaA)
        If ManNr = GlMaA(AktZa, 2) Then
            GlMaA(AktZa, 11) = IdGes
            Exit For
        End If
    Next AktZa
    For AktZa = 1 To UBound(GlMaA) 'aktive Mitarbeiter
        If CBool(GlMaA(AktZa, 11)) = False Then
            GesZa = GesZa + 1
        End If
    Next AktZa
    If GesZa > 0 Then
        ReDim GlMaT(GesZa, 26) 'aktive Mandanten + Terminspalte
        For AktZa = 1 To UBound(GlMaA) 'aktive Mitarbeiter
            If CBool(GlMaA(AktZa, 11)) = False Then
                GlMaT(IdxZa, 0) = IdxZa
                For FeIdx = 1 To 26
                    GlMaT(IdxZa, FeIdx) = GlMaA(AktZa, FeIdx)
                Next FeIdx
                IdxZa = IdxZa + 1
            End If
        Next AktZa
    End If
End If

DoEvents
STeRa True
DoEvents
S_TeLi

clFen.FenDsk 3
Screen.MousePointer = vbNormal

Exit Sub

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Man_Set " & Err.Number
Resume Next

End Sub
