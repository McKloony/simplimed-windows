    Set PrBr2 = frmStatus.prbStat2
    Lbl01.Caption = "Bitte warten..."
    PrBr1.Min = 0
    PrBr1.Max = AnzPo

    Screen.MousePointer = vbHourglass
    DoEvents

    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            RowNr = RpRow.Index
            IdxNr = MaAry(Mai_IDA, RpRow.Index)
            MitNr = MaAry(Mai_IDM, RpRow.Index)
            If Left$(NeGru, 1) = "P" Then
                If NeGru = "P801" Then 'Hauptordner
                    If MitNr <> GlMiA(GlSmI, 2) Then
                        Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                        Case 1: DBCmEx2 "qryMailInMia", "@IdMit", "@IdxNr", GlMiA(GlSmI, 2), IdxNr
                        Case 2: DBCmEx2 "qryMailOutMia", "@IdMit", "@IdxNr", GlMiA(GlSmI, 2), IdxNr
                        Case 3: DBCmEx2 "qryMailInMia", "@IdMit", "@IdxNr", GlMiA(GlSmI, 2), IdxNr
                        Case 4: DBCmEx2 "qryMailOutMia", "@IdMit", "@IdxNr", GlMiA(GlSmI, 2), IdxNr
                        End Select
                    End If
                ElseIf NeGru = "P805" Then 'Junkmail
                    If MitNr <> GlMiA(GlSmI, 2) Then
                        Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                        Case 1: DBCmEx2 "qryMailInMia", "@IdMit", "@IdxNr", GlMiA(GlSmI, 2), IdxNr
                        Case 2: DBCmEx2 "qryMailOutMia", "@IdMit", "@IdxNr", GlMiA(GlSmI, 2), IdxNr
                        Case 3: DBCmEx2 "qryMailInMia", "@IdMit", "@IdxNr", GlMiA(GlSmI, 2), IdxNr
                        Case 4: DBCmEx2 "qryMailOutMia", "@IdMit", "@IdxNr", GlMiA(GlSmI, 2), IdxNr
                        End Select
                    End If
                Else
                    Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                    Case 1: DBCmEx2 "qryMailInMia", "@IdMit", "@IdxNr", 0, IdxNr
                    Case 2: DBCmEx2 "qryMailOutMia", "@IdMit", "@IdxNr", 0, IdxNr
                    Case 3: DBCmEx2 "qryMailInMia", "@IdMit", "@IdxNr", 0, IdxNr
                    Case 4: DBCmEx2 "qryMailOutMia", "@IdMit", "@IdxNr", 0, IdxNr
                    End Select
                End If
            Else
                If Val(Right$(NeGru, 3)) > 900 Then
                    Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                    Case 1: DBCmEx2 "qryMailInMia", "@IdMit", "@IdxNr", 0, IdxNr
                    Case 2: DBCmEx2 "qryMailOutMia", "@IdMit", "@IdxNr", 0, IdxNr
                    Case 3: DBCmEx2 "qryMailInMia", "@IdMit", "@IdxNr", 0, IdxNr
                    Case 4: DBCmEx2 "qryMailOutMia", "@IdMit", "@IdxNr", 0, IdxNr
                    End Select
                Else
                    If MitNr <> GlMiA(GlSmI, 2) Then
                        Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                        Case 1: DBCmEx2 "qryMailInMia", "@IdMit", "@IdxNr", GlMiA(GlSmI, 2), IdxNr
                        Case 2: DBCmEx2 "qryMailOutMia", "@IdMit", "@IdxNr", GlMiA(GlSmI, 2), IdxNr
                        Case 3: DBCmEx2 "qryMailInMia", "@IdMit", "@IdxNr", GlMiA(GlSmI, 2), IdxNr
                        Case 4: DBCmEx2 "qryMailOutMia", "@IdMit", "@IdxNr", GlMiA(GlSmI, 2), IdxNr
                        End Select
                    End If
                End If
            End If
            Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
            Case 1: DBCmEx2 "qryMailInTre", "@IdStr", "@IdxNr", GruSt, IdxNr
            Case 2: DBCmEx2 "qryMailOutTre", "@IdStr", "@IdxNr", GruSt, IdxNr
            Case 3: DBCmEx2 "qryMailInTre", "@IdStr", "@IdxNr", GruSt, IdxNr
            Case 4: DBCmEx2 "qryMailOutTre", "@IdStr", "@IdxNr", GruSt, IdxNr
            End Select
            DoEvents
            GrMa_Ord = RowNr
        End If

        AktZa = AktZa + 1
        PrBr1.Value = AktZa
    Next RpRow
    
    DoEvents
    Screen.MousePointer = vbNormal
    
    Unload frmStatus
    Set frmStatus = Nothing
End If

Set RpSel = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo0 = Nothing

Exit Function

LoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "GrMa_Ord " & Err.Number
Resume Next

End Function
