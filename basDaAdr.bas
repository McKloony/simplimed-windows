Dim Frage As Integer
Dim ReAbg As Boolean
Dim RetWe As Boolean
Dim Mld1, Mld2, Tit1 As String
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCoK As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set LiVw1 = FM.lstView1
Set LiVw2 = FM.lstView2
Set LiVw3 = FM.lstView3
Set RpCo3 = FM.repCont3
Set RpCo6 = FM.repCont6
Set RpCoK = FM.repContK
Set RpRws = RpCo3.Rows
Set RpCls = RpCo3.Columns
Set RpSel = RpCo3.SelectedRows
Select Case GlBut
Case RibTab_Krankenbla: Set RpRcs = RpCoK.Records
Case RibTab_Abrechnung: Set RpRcs = RpCo6.Records
End Select

Select Case GlBut
Case RibTab_Krankenbla:
        Select Case GlKrT 'Krankenblattdiagnosefeldtyp
        Case 1: Set LiIts = LiVw2.ListItems
        Case 2: Set LiIts = LiVw3.ListItems
        End Select
Case RibTab_Abrechnung:
        Set LiIts = LiVw1.ListItems
End Select

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

GlAkt = True
GesPo = UBound(GlClp)

Tit1 = "Diagnose Einfügen"
Mld2 = "Die Rechnung wurde bereits abgeschlossen"

If ClKop = True Then 'Cliparry kopiert
    If GesPo > 0 Then
        Select Case GlBut
        Case RibTab_Krankenbla:
            PatNr = GlAdr
            ReNum = 0
            ReAbg = False
        Case RibTab_Abrechnung:
            If RpSel.Count > 0 Then
                Set RpRow = RpSel(0)
                If RpRow.GroupRow = False Then
                    Set RpCol = RpCls.Find(Rec_ID0)
                    PatNr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Rec_ID1)
                    ReNum = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Rec_Selekt)
                    ReAbg = CBool(RpRow.Record(RpCol.ItemIndex).Value)
                End If
                If RpRcs.Count > 0 Then
                    Set RpRec = RpRcs(0)
                    EinDa = RpRec.Item(Kra_Datum).Value
                Else
                    EinDa = Date
                End If
            End If
        End Select

        For AktPo = 1 To GesPo
            CoStr = GlClp(AktPo, 0)
            KuStr = GlClp(AktPo, 1)
            DiaDa = GlClp(AktPo, 2)
            DiGrp = GlClp(AktPo, 3)
            DiRef = GlClp(AktPo, 4)
            Select Case GlBut
            Case RibTab_Krankenbla:
                If GlClp(AktPo, 2) <> vbNullString Then
                    DBCmEx7 "qrySimAbDiA4", "@PatNr", "@IdxNr", "@IdCod", "@IdStr", "@IdDat", "@IdGrp", "@IdRef", PatNr, ReNum, CoStr, KuStr, DiaDa, DiGrp, DiRef
                Else
                    DBCmEx6 "qrySimAbDiA1", "@PatNr", "@IdxNr", "@IdCod", "@IdStr", "@IdGrp", "@IdRef", PatNr, ReNum, CoStr, KuStr, DiGrp, DiRef
                End If
            Case RibTab_Abrechnung:
                If EinDa < "01.01.2000" Then
                    EinDa = DiaDa
                End If
                DBCmEx7 "qrySimAbDiA4", "@PatNr", "@IdxNr", "@IdCod", "@IdStr", "@IdDat", "@IdGrp", "@IdRef", PatNr, ReNum, CoStr, KuStr, EinDa, DiGrp, DiRef
            End Select
        Next AktPo

        ClKop = False 'Cliparry kopiert
                            
        Screen.MousePointer = vbHourglass
        clFen.FenDsk 2
        
        DoEvents
        Select Case GlBut
        Case RibTab_Krankenbla:
                StrDi = S_KrDp(GlAdr) 'Aufnahmediagnosen
                StrMe = S_KrDm(GlAdr) 'Aufnahmemedikamente
        Case RibTab_Abrechnung:
                StrRe = S_KrDi(ReNum) 'Rechnungsdiagnosen
        End Select
        
        clFen.FenDsk 3
        Screen.MousePointer = vbNormal
    End If
End If

Set RpRcs = Nothing
Set RpSel = Nothing
Set RpRow = Nothing
Set RpRws = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing
Set RpCo6 = Nothing
Set RpCoK = Nothing

Set clFen = Nothing

If ReAbg = True Then
    SPopu Tit1, Mld2, IC48_Warning
End If

GlAkt = False

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Dia_Ein " & Err.Number
Resume Next

End Sub
