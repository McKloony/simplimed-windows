Public Sub Adr_Ana()
On Error GoTo LiErr

Dim AktPo As Integer

Set FM = frmAdrWord
Set LiVw1 = FM.lstView1
Set LiVw2 = FM.lstView2

AktPo = 0
Set LiIts = LiVw1.ListItems
Set RS71 = New ADODB.Recordset
RS71.CursorLocation = adUseClient
Set RS71 = DBCmRe1("qryPatAnBog", "@IdxNr", GlAdr)
If RS71.RecordCount > 0 Then
    Do
    With LiVw1
        AktPo = AktPo + 1
        Set LiItm = LiIts.Add(AktPo, "D" & RS71.Fields("ID5").Value, RS71.Fields("IDKurz").Value, IC16_Doc_Norm)
        LiItm.SubItems(1) = RS71.Fields("Datum").Value
        LiItm.Checked = True
    End With
    RS71.MoveNext
    Loop Until RS71.EOF
End If
RS71.Close
Set RS71 = Nothing

AktPo = 0
Set LiIts = LiVw2.ListItems
Set RS72 = New ADODB.Recordset
RS72.CursorLocation = adUseClient
Set RS72 = DBCmRe1("qryLabBePat", "@IdxNr", GlAdr)
If RS72.RecordCount > 0 Then
    Do
    With LiVw1
        AktPo = AktPo + 1
        Set LiItm = LiIts.Add(AktPo, "D" & RS72.Fields("ID0").Value, RS72.Fields("Auftrag").Value, IC16_Potion_Red)
        LiItm.SubItems(1) = RS72.Fields("Labor").Value
        LiItm.SubItems(2) = RS72.Fields("L-Ausgang").Value
        If AktPo = 1 Then LiItm.Checked = True
    End With
    RS72.MoveNext
    Loop Until RS72.EOF
End If
RS72.Close
Set RS72 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Adr_Ana " & Err.Number
Resume Next

End Sub
Public Sub Adr_Bnk(Optional ByVal BeDat As Boolean, Optional ByVal FmOpn As Boolean)
On Error GoTo PoErr
'Ordnet die Bank zur BLZ zu überprüft, ob mehrere Ortsteile passen

Dim FM As Form
Dim RetWe As Long
Dim IdStr As String
Dim AktZa As Integer
Dim FeBLZ As XtremeSuiteControls.FlatEdit
Dim FeBnk As XtremeSuiteControls.FlatEdit
Dim FeKto As XtremeSuiteControls.FlatEdit
Dim FeBIC As XtremeSuiteControls.FlatEdit
Dim RpCon As XtremeReportControl.ReportControl

If BeDat = True Then
    Set FM = frmMandant
    Set FeBIC = FM.txtS2F34
Else
    Set FM = frmAdress
    Set FeBIC = FM.txtS2F35
End If

Set FeBnk = FM.txtS2F03
Set FeBLZ = FM.txtS2F04
Set FeKto = FM.txtS2F05

AktZa = 0
If FeBLZ.Text <> vbNullString Then
    IdStr = Replace(FeBLZ.Text, Chr$(32), vbNullString, 1)
Else
    IdStr = "00000"
End If

Set RS31 = New ADODB.Recordset
RS31.CursorLocation = adUseClient
Set RS31 = DBCmRe1("qryBLZSu", "@IdStr", IdStr & "%")

If FmOpn = True Then
    If GlOrt = True Then
        Load frmAdrBLZ
        Set FM = frmAdrBLZ
        Set RpCon = FM.repCont1
        Set RpRcs = RpCon.Records
        FM.Show
        RpCon.SetFocus
        DoEvents
        If RS31.RecordCount > 0 Then
            RS31.MoveFirst
            Do
            Set RpRec = RpRcs.Add()
            Set RpItm = RpRec.AddItem(RS31.Fields("BLZ").Value)
            Set RpItm = RpRec.AddItem(RS31.Fields("Bank").Value)
            Set RpItm = RpRec.AddItem(RS31.Fields("Ort").Value)
            Set RpItm = RpRec.AddItem(RS31.Fields("BIC").Value)
            Set RpItm = RpRec.AddItem(RS31.Fields("IDKurz").Value)
            RS31.MoveNext
            Loop Until RS31.EOF
            RpCon.Populate
        End If
    End If
    Exit Sub
End If

If RS31.RecordCount > 0 Then
    If RS31.RecordCount > 1 Then
        If GlOrt = True Then
            Load frmAdrBLZ
            Set FM = frmAdrBLZ
            Set RpCon = FM.repCont1
            Set RpRcs = RpCon.Records
            FM.Show
            RpCon.SetFocus
            DoEvents
            RS31.MoveFirst
            Do
            Set RpRec = RpRcs.Add()
            Set RpItm = RpRec.AddItem(RS31.Fields("BLZ").Value)
            Set RpItm = RpRec.AddItem(RS31.Fields("Bank").Value)
            Set RpItm = RpRec.AddItem(RS31.Fields("Ort").Value)
            Set RpItm = RpRec.AddItem(RS31.Fields("BIC").Value)
            Set RpItm = RpRec.AddItem(RS31.Fields("IDKurz").Value)
            RS31.MoveNext
            Loop Until RS31.EOF
            RpCon.Populate
        Else
            If GlBnk = True Then
                If RS31.Fields("IDKurz").Value <> vbNullString Then If FeBnk.Text = vbNullString Then FeBnk.Text = RS31.Fields("IDKurz").Value
            Else
                If RS31.Fields("Bank").Value <> vbNullString Then If FeBnk.Text = vbNullString Then FeBnk.Text = RS31.Fields("Bank").Value & ", " & RS31.Fields("Ort").Value
            End If
            FeKto.SetFocus
        End If
    Else
        If GlBnk = True Then
            If RS31.Fields("IDKurz").Value <> vbNullString Then If FeBnk.Text = vbNullString Then FeBnk.Text = RS31.Fields("IDKurz").Value
        Else
            If RS31.Fields("Bank").Value <> vbNullString Then If FeBnk.Text = vbNullString Then FeBnk.Text = RS31.Fields("Bank").Value & ", " & RS31.Fields("Ort").Value
        End If
        FeKto.SetFocus
    End If
End If

RS31.Close
Set RS31 = Nothing

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Adr_Bnk " & Err.Number
Resume Next

End Sub
Public Function Adr_Cm(ByVal Combo As XtremeSuiteControls.ComboBox, ByVal IdxWe As Long) As Long
On Error GoTo DoErr
'Gibt die Indexnummer eines Combowertes zurück

Dim GesZa As Long
Dim AktZa As Long
Dim Vorha As Boolean

GesZa = Combo.ListCount
If GesZa > 0 Then
    For AktZa = 0 To GesZa - 1
        If Combo.ItemData(AktZa) = IdxWe Then
            Vorha = True
            Exit For
        End If
    Next AktZa
End If

If Vorha = True Then
    Adr_Cm = AktZa
Else
    Adr_Cm = -1
End If

Exit Function

DoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Adr_Cm " & Err.Number
Resume Next
    
End Function
Public Function Adr_Dop(ByVal SuStr As String, Optional ByVal AdTyp As Integer) As Boolean
On Error GoTo DoErr
'Prüft, ob ein Eintrag bereits vorhanden ist

Dim Krite As String
Dim Mld1, Tit1 As String

Adr_Dop = False

If SuStr <> vbNullString Then
    Set RS40 = New ADODB.Recordset
    RS40.CursorLocation = adUseClient
    Set RS40 = DBCmRe1("qryAdrKur", "@IdStr", SuStr)
    If RS40.RecordCount > 0 Then
        Select Case AdTyp
        Case 1: 'Mandanten
            Krite = "[VIP] = -1"
            RS40.Filter = Krite
            If RS40.RecordCount > 0 Then
                Adr_Dop = True
                Mld1 = "Der Eintrag " & SuStr & " existiert bereits"
                Tit1 = "Doppelter Eintrag"
                SPopu Tit1, Mld1, IC48_Warning
            End If
        Case 2: 'Mitarbeiter
            Krite = "[Mitarbeiter] = -1"
            RS40.Filter = Krite
            If RS40.RecordCount > 0 Then
                Adr_Dop = True
                Mld1 = "Der Eintrag " & SuStr & " existiert bereits"
                Tit1 = "Doppelter Eintrag"
                SPopu Tit1, Mld1, IC48_Warning
            End If
        Case 3: 'Verordner
            Krite = "[Arzt] = -1"
            RS40.Filter = Krite
            If RS40.RecordCount > 0 Then
                Adr_Dop = True
                Mld1 = "Der Eintrag " & SuStr & " existiert bereits"
                Tit1 = "Doppelter Eintrag"
                SPopu Tit1, Mld1, IC48_Warning
            End If
        Case Else: 'Patienten
            Adr_Dop = True
            Mld1 = "Der Eintrag " & SuStr & " existiert bereits"
            Tit1 = "Doppelter Eintrag"
            SPopu Tit1, Mld1, IC48_Warning
        End Select
    End If
    RS40.Close
    Set RS40 = Nothing
End If

Exit Function

DoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Adr_Dop " & Err.Number
Resume Next
    
End Function
Private Sub Adr_EiLi()
On Error GoTo LiErr
'Liest die Daten in die Propertyfelder ein

Dim GesZa As Long
Dim TmTag As Long
Dim TmStr As String
Dim PrKat As XtremePropertyGrid.PropertyGridItem
Dim PrItm As XtremePropertyGrid.PropertyGridItem
Dim PrIts As XtremePropertyGrid.PropertyGridItems
Dim PrBol As XtremePropertyGrid.PropertyGridItemBool
Dim PrDat As XtremePropertyGrid.PropertyGridItemDate

Set FM = frmAdress
Set PrGr3 = FM.prpGrid3
Set PrIts = PrGr3.Categories

Set RS48 = New ADODB.Recordset
RS48.CursorLocation = adUseClient
Set RS48 = DBCmRe1("qryPatFlAdr", "@IdxNr", GlAId)

GesZa = RS48.RecordCount

If GesZa > 0 Then
    Do
    TmStr = RS48.Fields("Inhalt").Value
    TmTag = RS48.Fields("ID6").Value
        For Each PrKat In PrIts
            For Each PrItm In PrKat.Childs
                If PrItm.Tag = TmTag Then
                    Select Case PrItm.Type
                    Case PropertyItemString:
                            PrItm.Value = TmStr
                    Case PropertyItemNumber:
                            PrItm.Value = TmStr
                    Case PropertyItemBool:
                            Set PrBol = PrItm
                            PrBol.Value = CBool(TmStr)
                    Case PropertyItemColor:
                            PrItm.Value = TmStr
                    Case PropertyItemDate:
                            PrItm.Value = CDate(TmStr)
                    End Select
                End If
            Next PrItm
        Next PrKat
    RS48.MoveNext
    Loop Until RS48.EOF
End If

RS48.Close
Set RS48 = Nothing

Set PrKat = Nothing
Set PrGr3 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Adr_EiLi " & Err.Number
Resume Next

End Sub
Public Sub Adr_EiSa(ByVal PrItm As XtremePropertyGrid.PropertyGridItem)
On Error GoTo LiErr
'Speichert die Daten

Dim GesZa As Long
Dim EiVor As Boolean
Dim PrKat As XtremePropertyGrid.PropertyGridItem
Dim PrIts As XtremePropertyGrid.PropertyGridItems
Dim PrBol As XtremePropertyGrid.PropertyGridItemBool
Dim PrDat As XtremePropertyGrid.PropertyGridItemDate

Set FM = frmAdress
Set PrGr3 = FM.prpGrid3
Set PrIts = PrGr3.Categories

If GlAId > 0 Then
    Set RS48 = New ADODB.Recordset
    RS48.CursorLocation = adUseClient
    Set RS48 = DBCmRe1("qryPatFlAdr", "@IdxNr", GlAId)
    
    GesZa = RS48.RecordCount
    
    Select Case PrItm.Type
    Case PropertyItemString:
        If GesZa > 0 Then
            RS48.MoveFirst
            Do
            If PrItm.Tag = RS48.Fields("ID6").Value Then
                Adr_EiSav PrItm.Value, PrItm.Tag
                EiVor = True
                Exit Do
            End If
            RS48.MoveNext
            Loop Until RS48.EOF
            If EiVor = False Then
                If Val(Left$(PrItm.Tag, 1)) > 0 Then
                    Adr_EiSan PrItm.Value, PrItm.Tag
                End If
            End If
        Else
            If Val(Left$(PrItm.Tag, 1)) > 0 Then
                Adr_EiSan PrItm.Value, PrItm.Tag
            End If
        End If
    Case PropertyItemNumber:
        If GesZa > 0 Then
            RS48.MoveFirst
            Do
            If PrItm.Tag = RS48.Fields("ID6").Value Then
                Adr_EiSav PrItm.Value, PrItm.Tag
                EiVor = True
                Exit Do
            End If
            RS48.MoveNext
            Loop Until RS48.EOF
            If EiVor = False Then
                If Val(Left$(PrItm.Tag, 1)) > 0 Then
                    Adr_EiSan PrItm.Value, PrItm.Tag
                End If
            End If
        Else
            If Val(Left$(PrItm.Tag, 1)) > 0 Then
                Adr_EiSan PrItm.Value, PrItm.Tag
            End If
        End If
    Case PropertyItemBool:
        Set PrBol = PrItm
        If GesZa > 0 Then
            RS48.MoveFirst
            Do
            If PrBol.Tag = RS48.Fields("ID6").Value Then
                Adr_EiSav CBool(PrBol.Value), PrBol.Tag
                EiVor = True
                Exit Do
            End If
            RS48.MoveNext
            Loop Until RS48.EOF
            If EiVor = False Then
                If Val(Left$(PrItm.Tag, 1)) > 0 Then
                    Adr_EiSan CBool(PrBol.Value), PrBol.Tag
                End If
            End If
        Else
            If Val(Left$(PrItm.Tag, 1)) > 0 Then
                Adr_EiSan CBool(PrBol.Value), PrBol.Tag
            End If
        End If
    Case PropertyItemColor:
        If GesZa > 0 Then
            RS48.MoveFirst
            Do
            If PrItm.Tag = RS48.Fields("ID6").Value Then
                Adr_EiSav CBool(PrItm.Value), PrItm.Tag
