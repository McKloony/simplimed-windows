Private Sub Tr_Rec(ByRef RST As ADODB.Recordset, ByVal TreKy As String, Optional ByVal KetMe As Boolean = False, Optional ByVal GrVor As Boolean = False)
On Error GoTo LiErr
'Füllt die Tabelle mit Daten

Dim RpCon As XtremeReportControl.ReportControl

Set FM = frmTerKat
Set RpCon = FM.repCont9
Set RpRcs = RpCon.Records

Do
Set RpRec = RpRcs.Add()
If KetMe = True Then
    Set RpItm = RpRec.AddItem(RST.Fields("ID1").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("GOID").Value)
    RpItm.Icon = IC16_Doc_Norm
    Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
    Set RpItm = RpRec.AddItem(0)
    If TreKy = "F" Then
        Set RpItm = RpRec.AddItem(0)
    Else
        Set RpItm = RpRec.AddItem(Format$(RST.Fields("Preis").Value, GlWa1))
    End If
    Set RpItm = RpRec.AddItem(0)
Else
    Select Case TreKy
    Case "K":
            Set RpItm = RpRec.AddItem(RST.Fields("ID0").Value)
            Set RpItm = RpRec.AddItem(RST.Fields("GOIK").Value)
            RpItm.Icon = IC16_Doc_Norm
            Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
    Case "M":
            Set RpItm = RpRec.AddItem(RST.Fields("ID4").Value)
            Set RpItm = RpRec.AddItem(RST.Fields("ID3").Value)
            Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
            RpItm.Icon = IC16_Doc_Norm
    Case Else:
            Set RpItm = RpRec.AddItem(RST.Fields("ID0").Value)
            Set RpItm = RpRec.AddItem(RST.Fields("GOID").Value)
            RpItm.Icon = IC16_Doc_Norm
            Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
    End Select
    If GrVor = True Then
        If Len(RST.Fields("Gruppe").Value) > 0 Then
            Set RpItm = RpRec.AddItem(RST.Fields("Gruppe").Value)
        Else
            Set RpItm = RpRec.AddItem(vbNullString)
        End If
    Else
        Set RpItm = RpRec.AddItem(vbNullString)
    End If
    Select Case TreKy
    Case "C": Set RpItm = RpRec.AddItem(0)
    Case "M": Set RpItm = RpRec.AddItem(0)
    Case Else: Set RpItm = RpRec.AddItem(Format$(RST.Fields("Preis1").Value * RST.Fields("Multi").Value, GlWa1))
    End Select
    Set RpItm = RpRec.AddItem(0)
    If GrVor = True Then
        If RST.Fields("Kommentar").Value <> vbNullString Then
            RpRec.PreviewText = RST.Fields("Kommentar").Value
        End If
    End If
End If
RST.MoveNext
Loop Until RST.EOF

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCon = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Tr_Rec " & Err.Number
Resume Next

End Sub
