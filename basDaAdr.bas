Public Sub Tr_VoRe(ByVal TerNr As Long)
On Error GoTo GrErr
'Lädt Informationen aus einem besthenden Serientermin in den Dialog

Dim TerDa As Date
Dim NeuDa As Date
Dim GesZa As Integer
Dim AktZa As Integer
Dim FoFak As Integer
Dim ZaZil As Integer

Set FM = frmTermVo
Set TxID0 = FM.txtID0
Set TxDa1 = FM.txtDatu1
Set TxFa1 = FM.txtFall1
Set TxFa2 = FM.txtFall2
Set ChWie = FM.chkWiede
Set CmAbr = FM.cmbAbger

FoFak = 1

For AktZa = 1 To UBound(GlZah) 'Standardzahlungsziel
    If GlZah(AktZa, 0) = GlStZ Then
        ZaZil = GlZah(AktZa, 2)
        Exit For
    End If
Next AktZa

If IsDate(TxDa1.Text) Then
    TerDa = CDate(TxDa1.Text)
Else
    TerDa = Date
End If

NeuDa = DateAdd("d", ZaZil, TerDa)

If GlVrt = True Then 'virtuelle Leistungen vorhanden
    AktZa = UBound(GlTLe)
Else
    AktZa = 0
    ReDim GlTLe(AktZa, 13)
End If

Set RS62 = New ADODB.Recordset
RS62.CursorLocation = adUseClient
Set RS62 = DBCmRe1("qryAnKa1e", "@IdxNr", TerNr)
GesZa = RS62.RecordCount
If GesZa > 0 Then
    Do
    AktZa = AktZa + 1
    ReDimEx GlTLe, AktZa, 14
    GlTLe(AktZa, 0) = RS62.Fields("ID0").Value
    GlTLe(AktZa, 1) = 0
    GlTLe(AktZa, 2) = 2
    GlTLe(AktZa, 3) = 0
    GlTLe(AktZa, 4) = RS62.Fields("GOID").Value
    GlTLe(AktZa, 5) = RS62.Fields("IDKurz").Value
    GlTLe(AktZa, 6) = RS62.Fields("Zusatztext").Value
    GlTLe(AktZa, 7) = RS62.Fields("Steuer").Value
    GlTLe(AktZa, 8) = RS62.Fields("Rabatt").Value
    GlTLe(AktZa, 9) = CSng(Round(RS62.Fields("Multi").Value, 2))
    GlTLe(AktZa, 10) = RS62.Fields("x").Value
    GlTLe(AktZa, 14) = CDbl(((Round(RS62.Fields("Preis1").Value, 2) * Round(RS62.Fields("Multi").Value, 2)) / FoFak) * RS62.Fields("x").Value)
    If Not IsNull(RS62.Fields("Einheit").Value) Then GlTLe(AktZa, 11) = RS62.Fields("Einheit").Value
    If Not IsNull(RS62.Fields("Provision").Value) Then GlTLe(AktZa, 12) = RS62.Fields("Provision").Value
    GlTLe(AktZa, 13) = CSng(Round(RS62.Fields("Preis1").Value, 2) / FoFak)
    RS62.MoveNext
    Loop Until RS62.EOF
End If
RS62.Close
Set RS62 = Nothing

If ChWie.Value = xtpUnchecked Then
    ChWie.Value = xtpChecked
End If

If CmAbr.ListIndex <> 1 Then
    CmAbr.ListIndex = 1
End If

If IsNull(TxFa1.Text) = True Then
    TxFa1.Text = NeuDa
Else
    If IsDate(TxFa1.Text) = False Then
        TxFa1.Text = NeuDa
    End If
End If

GlVrt = True 'virtuelle Leistungen vorhanden

Exit Sub

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Tr_VoEi " & Err.Number
Resume Next

End Sub
Public Function Wie_Adr(ByVal SuStr As String) As Long
On Error GoTo SuErr
'Füllt die Liste des Suchformulars mit den gefundenen Treffern

Dim GesZa As Long
Dim IdxNr As Long
Dim MaNum As Long
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim IdStr As String
Dim TagWe As String
Dim AktZa As Integer
Dim TeWer As Variant
Dim BeVor As Boolean
Dim List4 As XtremeSuiteControls.ListBox
Dim CmBrs As XtremeCommandBars.CommandBars

Set FM = frmWieder

TeTit = "Patient nicht gefunden"
TeMai = "Der eingegebene Patient konnte nicht gefunden werden"
TeInh = "Unter der Bezeichnung '" & SuStr & "' konnte in der Datenbank kein Eintrag gefunden werden. Eventuell muss der Patient zuerst angelegt oder im Betreff vermerkt werden."
TeFus = "Wenn Sie sicher sind, dass die gesuchte Patienten in der Datenbank vorhanden ist, wiederholen Sie die Suche und geben nur die ersten drei bis vier Buchstaben des Nachnamens ein."

Set RS48 = New ADODB.Recordset
RS48.CursorLocation = adUseClient
Set RS48 = DBCmRe1("qryAdrSet", "@IdStr", SuStr & "%")
GesZa = RS48.RecordCount

If GesZa > 0 Then
    If GesZa = 1 Then
        IdxNr = RS48.Fields("ID0").Value
        IdStr = RS48.Fields("IDKurz").Value
        If IdxNr > 0 Then
            FM.txtID0.Text = IdxNr
            TagWe = Mid$(FM.txtID0.Tag, 2, Len(FM.txtID0.Tag) - 1)
            FM.txtID0.Tag = 1 & TagWe
            GlKoS = True
        End If
        If IdStr <> vbNullString Then
            FM.txtPatie.Text = IdStr
            TagWe = Mid$(FM.txtPatie.Tag, 2, Len(FM.txtPatie.Tag) - 1)
            FM.txtPatie.Tag = 1 & TagWe
            GlKoS = True
        End If
    Else
        AktZa = 0
        Set FM = frmWiedAnh
        Set List4 = FM.lstList1
        List4.Clear
        DoEvents
        Do Until RS48.EOF
        List4.AddItem RS48.Fields("IDKurz").Value
        List4.ItemData(AktZa) = RS48.Fields("ID0").Value
        RS48.MoveNext
        AktZa = AktZa + 1
        Loop
        If List4.ListCount > 0 Then
            List4.Selected(0) = True
        End If
    End If
    RS48.Close
    Set RS48 = Nothing
Else
    RS48.Close
    Set RS48 = Nothing
    FM.txtPatie.Text = vbNullString
    SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
End If

Wie_Adr = GesZa

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Wie_Adr " & Err.Number
Resume Next

End Function

Public Sub Wie_Lad(ByVal IdxNr As Long)
On Error GoTo DaErr
'Füllt das Wiedervorlageformular mit Informationen

Dim RetWe As Long
Dim IdxWe As Long
Dim AkTim As Date
Dim TagWe As String
Dim AktZa As Integer

Set FM = frmWieder
Set TxDa1 = FM.txtDatum
Set TxZeV = FM.txtVonZe

GlKoN = False

Set RS30 = New ADODB.Recordset
RS30.CursorLocation = adUseClient
Set RS30 = DBCmRe1("qryTermin", "@IdxNr", IdxNr)
If RS30.RecordCount > 0 Then
    For Each AktCo In FM.Controls
        If AktCo.Tag <> vbNullString Then
            Select Case Left$(AktCo.Name, 3)
            Case "txt": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                        If Not IsNull(RS30.Fields(TagWe).Value) Then
                            AktCo.Text = RS30.Fields(TagWe).Value
                            AktCo.Tag = 0 & TagWe
                        End If
            Case "cmb": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                        If Not IsNull(RS30.Fields(TagWe).Value) Then
                            IdxWe = RS30.Fields(TagWe).Value - 1
                            Select Case AktCo.Name
                            Case "cmbBehan": IdxNr = Adr_Cm(AktCo, RS30.Fields(TagWe).Value)
                            Case "cmbMitar": IdxNr = Adr_Cm(AktCo, RS30.Fields(TagWe).Value)
                            Case Else: IdxNr = IdxWe
                            End Select
                            If AktCo.ListCount > 0 Then
                                RetWe = SendMessage(AktCo.hwnd, CB_SETCURSEL, IdxNr, ByVal 0&)
                            End If
                            AktCo.Tag = 0 & TagWe
                        End If
            Case "chk": TagWe = Mid$(AktCo.Tag, 2, Len(AktCo.Tag) - 1)
                        If RS30.Fields(TagWe).Value = -1 Then
                            AktCo.Value = 1
                            AktCo.Tag = 0 & TagWe
                        End If
            End Select
        End If
    Next AktCo
    
    AkTim = RS30.Fields("ZeiVon").Value
    TxZeV.Text = Format$(AkTim, "hh:mm")
    TxZeV.Tag = 0 & "ZeiVon"

    TxDa1.Text = RS30.Fields("VonDat").Value
End If

RS30.Close
Set RS30 = Nothing
GlKoS = False

Exit Sub

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "Wie_Lad " & Err.Number
Resume Next

End Sub
