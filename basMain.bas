            End Select
        Else
            Select Case GlSuK.SuQua
            Case 1: Krit2 = "(([Datum] Between #01/01/" & GlSuK.SuJah & "# AND #03/31/" & GlSuK.SuJah & "#))"
            Case 2: Krit2 = "(([Datum] Between #04/01/" & GlSuK.SuJah & "# AND #06/30/" & GlSuK.SuJah & "#))"
