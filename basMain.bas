        If GlTyp < 2 Then
            Krit2 = "(Datum >= CONVERT(DATETIME, '" & Jahr1 & "-01-01 00:00:00', 102)) AND (Datum <= CONVERT(DATETIME, '" & Jahr2 & "-12-31 00:00:00', 102)) "
        Else
            Krit2 = "(([Datum] Between #01/01/" & Jahr1 & "# AND #12/31/" & Jahr2 & "#))"
        End If
    End Select
Case 2:
    Select Case GlSuO.SuIdx
    Case 1:
