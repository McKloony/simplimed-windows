                            .TeStr = TypNa & " - " & NeuNa
                            .NeuEi = True
                            .Mitar = GlMiA(GlSmI, 2)
                        End With
                        If K_Einf = False Then
                            'DB-Eintrag fehlgeschlagen - kopierte Datei entfernen um Orphan zu verhindern
                            On Error Resume Next
                            If clFil.FilVor(FiNeu) = True Then
