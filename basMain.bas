Public Function SUmw(ByVal UmStr As String, Optional ByVal KomUm As Boolean = False, Optional ByVal UmlUm As Boolean = True, Optional ZeiUm As Boolean = False, Optional ByVal Erwei As Boolean = False) As String
On Error GoTo LiErr
'Konvertiert Umlaute und Sonderzeichen

Dim TmStr As String

TmStr = UmStr

If ZeiUm = True Then
    TmStr = Replace(TmStr, vbCrLf, Space$(1), 1)
Else
    TmStr = Replace(TmStr, Chr$(36), vbNullString, 1) '$
End If

If GlTyp < 2 Then
    If Len(TmStr) = 4 Then
        TmStr = Replace(TmStr, "WAHR", "1", 1, , 1)
        TmStr = Replace(TmStr, "Wahr", "1", 1, , 1)
    End If
    If Len(TmStr) = 6 Then
        TmStr = Replace(TmStr, "FALSCH", "0", 1, , 1)
        TmStr = Replace(TmStr, "Falsch", "0", 1, , 1)
    End If
Else
    If Len(TmStr) = 4 Then
        TmStr = Replace(TmStr, "WAHR", "-1", 1, , 1)
        TmStr = Replace(TmStr, "Wahr", "-1", 1, , 1)
    End If
    If Len(TmStr) = 6 Then
        TmStr = Replace(TmStr, "FALSCH", "0", 1, , 1)
        TmStr = Replace(TmStr, "Falsch", "0", 1, , 1)
    End If
End If

If UmlUm = True Then
    TmStr = Replace(TmStr, "ä", "ae", 1)
    TmStr = Replace(TmStr, "Ä", "Ae", 1)
    TmStr = Replace(TmStr, "ö", "oe", 1)
    TmStr = Replace(TmStr, "Ö", "Oe", 1)
    TmStr = Replace(TmStr, "ü", "ue", 1)
    TmStr = Replace(TmStr, "Ü", "Ue", 1)
    TmStr = Replace(TmStr, "ß", "ss", 1)
End If

If Erwei = True Then
    TmStr = Replace(TmStr, Chr$(38), vbNullString, 1) '&
    TmStr = Replace(TmStr, Chr$(39), vbNullString, 1) ''
    TmStr = Replace(TmStr, Chr$(43), vbNullString, 1) '+
    TmStr = Replace(TmStr, Chr$(45), vbNullString, 1) '-
    TmStr = Replace(TmStr, Chr$(61), vbNullString, 1) '=
    TmStr = Replace(TmStr, Chr$(46), vbNullString, 1) '.
    TmStr = Replace(TmStr, Chr$(64), vbNullString, 1) '@
    TmStr = Replace(TmStr, Chr$(58), vbNullString, 1) ':
    TmStr = Replace(TmStr, Chr$(60), vbNullString, 1) '<
    TmStr = Replace(TmStr, Chr$(62), vbNullString, 1) '>
    TmStr = Replace(TmStr, Chr$(92), vbNullString, 1) '\
    TmStr = Replace(TmStr, Chr$(47), vbNullString, 1) '/
    TmStr = Replace(TmStr, Chr$(126), vbNullString, 1) '~
    TmStr = Replace(TmStr, Chr$(35), vbNullString, 1) '#
    TmStr = Replace(TmStr, Chr$(123), vbNullString, 1) '{
    TmStr = Replace(TmStr, Chr$(124), vbNullString, 1) '|
    TmStr = Replace(TmStr, Chr$(125), vbNullString, 1) '}
End If

TmStr = Replace(TmStr, Chr$(20), vbNullString, 1) '¶
TmStr = Replace(TmStr, Chr$(34), vbNullString, 1) '"
TmStr = Replace(TmStr, Chr$(37), vbNullString, 1) '%
TmStr = Replace(TmStr, Chr$(42), vbNullString, 1) '*
TmStr = Replace(TmStr, Chr$(59), vbNullString, 1) ';
TmStr = Replace(TmStr, Chr$(94), vbNullString, 1) '^
TmStr = Replace(TmStr, Chr$(96), vbNullString, 1) '`
TmStr = Replace(TmStr, Chr$(127), vbNullString, 1) '¦
TmStr = Replace(TmStr, Chr$(128), vbNullString, 1) 'Ç
TmStr = Replace(TmStr, Chr$(130), vbNullString, 1) 'é
TmStr = Replace(TmStr, Chr$(131), vbNullString, 1) 'â
TmStr = Replace(TmStr, Chr$(133), vbNullString, 1) 'ŕ
TmStr = Replace(TmStr, Chr$(134), vbNullString, 1) 'ĺ
TmStr = Replace(TmStr, Chr$(135), vbNullString, 1) 'ç
TmStr = Replace(TmStr, Chr$(136), vbNullString, 1) 'ę
TmStr = Replace(TmStr, Chr$(137), vbNullString, 1) 'ë
TmStr = Replace(TmStr, Chr$(138), vbNullString, 1) 'č
TmStr = Replace(TmStr, Chr$(139), vbNullString, 1) 'ď
TmStr = Replace(TmStr, Chr$(140), vbNullString, 1) 'î
TmStr = Replace(TmStr, Chr$(141), vbNullString, 1) 'ě

TmStr = Replace(TmStr, "ĂĽ", "ü", 1)
TmStr = Replace(TmStr, "Ăś", "Ü", 1)

If KomUm = True Then
    TmStr = Replace(TmStr, Chr$(44), vbNullString, 1) ',
End If

SUmw = TmStr

Exit Function

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SUmw " & Err.Number
Resume Next

