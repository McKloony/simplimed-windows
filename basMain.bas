Public Sub SPrf1(Optional ByVal KeiMi As Boolean = False)
On Error GoTo CrErr
'Registrierungsprüfung

Dim ManNr As Long
Dim ErKId As Long
Dim MiNam As String
Dim TmpNa As String
Dim AktZa As Integer
Dim AkKat As Integer
Dim BeAnm As Boolean
Dim Mld1, Tit1 As String
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmPa3 As XtremeCommandBars.StatusBarPane
Dim BaItm As XtremeShortcutBar.ShortcutBarItem

Set FM = frmMain
Set CmBrs = FM.comBar01
Set CmSta = CmBrs.StatusBar

Set CmPa3 = CmSta.FindPane(Tex_Pa_Labl3)

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

If GlRDP = True Then
    TmpNa = "SimpliMed23 Online"
Else
    TmpNa = "SimpliMed23"
End If

If KeiMi = False Then 'keine Mitarbeiter angelegt
    If GlSeE = True Then 'Setupdaten eingelesen
        BeAnm = CBool(GlSet(4, 9)) 'Benutzeranmeldung beim Start
    Else
        BeAnm = True
    End If
    If BeAnm = True Then 'Benutzeranmeldung beim Start
        If CBool(IniGetVal("Vorgabe", "StMaVo")) = True Then  'Standardmandant vorhanden
            If GlMiV = True Then 'Mitarbeiter vorhanden
                clFen.FenTit TmpNa
                DoEvents
                frmLogin.Show vbModal
                DoEvents
                MiNam = GlMiA(GlSmI, 1)
            Else
                For AktZa = 0 To GlZaR - 1 'Rechteanzahl
                    GlRch(0, AktZa) = 1
                Next AktZa
                MiNam = "Es wurde noch kein Mitarbeiter angelegt..."
            End If
        Else
            For AktZa = 0 To GlZaR - 1 'Rechteanzahl
                GlRch(0, AktZa) = 1
            Next AktZa
            If GlMiV = True Then 'Mitarbeiter vorhanden
                MiNam = GlMiA(GlSmI, 1)
            Else
                MiNam = "Es wurde noch kein Mitarbeiter angelegt..."
            End If
        End If
    Else
        For AktZa = 0 To GlZaR - 1 'Rechteanzahl
            GlRch(0, AktZa) = 1
        Next AktZa
        If GlMiV = True Then 'Mitarbeiter vorhanden
            MiNam = GlMiA(GlSmI, 1)
            ManNr = GlMiA(GlSmI, 7) 'zugeordnete Mandantennummer
        Else
            MiNam = "Es wurde noch kein Mitarbeiter angelegt..."
            ManNr = GlMan(GlSMa, 2) 'Standardmandant
        End If
        GlReM = ManNr 'Standardmandant Mandantenrestriktionen
        
        For AktZa = 1 To UBound(GlMan)
            If ManNr = GlMan(AktZa, 2) Then
                GlFri = GlMan(AktZa, 35) 'Fachrichtung
            End If
        Next AktZa
        
        If GlFri > 9 Then
            GlFri = 2
        End If

        DoEvents
        SRecht
        DoEvents

        If GlMVo = True Then 'mandantenbezogene Vorgaben verwenden
            For AktZa = 1 To UBound(GlMan)
                If ManNr = GlMan(AktZa, 2) Then 'Mandantennummer
                    If GlMan(AktZa, 22) <> vbNullString Then 'Standardgebührenkatalog
                        For AkKat = 1 To UBound(GlGKa)
                            If GlGKa(AkKat, 0) = GlMan(AktZa, 22) Then
                                GlStK = AkKat
                                Exit For
                            End If
                        Next AkKat
                    End If
                    If GlMan(AktZa, 23) <> vbNullString Then GlKe1 = GlMan(AktZa, 23) 'Standardgebührenkette 1
                    If GlMan(AktZa, 38) <> vbNullString Then GlKe2 = GlMan(AktZa, 38) 'Standardgebührenkette 2
                    If GlMan(AktZa, 24) <> vbNullString Then GlStS = GlMan(AktZa, 24) 'Standardsteuersatz
                    If GlMan(AktZa, 25) <> vbNullString Then GlKtR = GlMan(AktZa, 25) 'Standardkontenrahmen
                    If GlMan(AktZa, 26) <> vbNullString Then ErKId = GlMan(AktZa, 26) 'Standarderlöskonto Bank
                    S_KoDe ErKId
                    GlSE2 = GlKto.KtoNr 'Standarderlöskonto Bankkonto
                    If GlMan(AktZa, 27) <> vbNullString Then ErKId = GlMan(AktZa, 27) 'Standarderlöskonto Kasse
                    S_KoDe ErKId
                    GlSE1 = GlKto.KtoNr
                    If GlMan(AktZa, 28) <> vbNullString Then GlGkB = GlMan(AktZa, 28) 'Standardgeldkonto Bankkonto
                    If GlMan(AktZa, 29) <> vbNullString Then GlGkK = GlMan(AktZa, 29) 'Standardgeldkonto Kasse
                    If GlMan(AktZa, 30) <> vbNullString Then GlReT = GlMan(AktZa, 30) 'Standardbelegtyp
                    GlSMa = AktZa 'neuer Standardmandant!
                    If GlMPl = False Then 'Mitarbeiterplan anstelle von Mandantenplan
                        GlTBx = GlMan(GlSMa, 0) - 1
                    End If
                    Exit For
                End If
            Next AktZa
        End If
    End If
Else
    For AktZa = 0 To GlZaR - 1 'Rechteanzahl
        GlRch(0, AktZa) = 1
    Next AktZa

    MiNam = "Es wurde noch kein Mitarbeiter angelegt..."
    Mld1 = "Es wurde noch kein Mitarbeiter angelegt!"
    Tit1 = "Keine Mitarbeiter vorhanden"
    SPopu Tit1, Mld1, IC48_Forbidden
    SMeMs "Keine Mitarbeiter vorhanden", "Bitte legen Sie in der Mitarbeiterverwaltung mind. einen Mitarbeiter an!", IC16_Paperclip
    DoEvents
End If

Set CmBrs = Nothing

If GlRst = True Then 'Mandantenbezogene Datenbegrenzung
    CmPa3.Text = "Mitarbeiter: " & MiNam & " (Mandantenrestriktionen)"
Else
    CmPa3.Text = "Mitarbeiter: " & MiNam
End If

Set clFen = Nothing

Exit Sub

CrErr:
If GlDbg = True Then SErLog Err.Description & " SPrf1 " & Err.Number
Resume Next

End Sub
