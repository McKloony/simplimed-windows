Tit1 = "Akontozahlung nicht möglich"
Mld1 = "Diesem Termin wurden noch keine Leistungen hingefügt, für die Sie eine Akontozahlung eintragen könnten"
Mld2 = "Die Gesamtsumme aller Leistungen für diese Terminserie wurde bereits durch Akontozahlung(en) erreicht"
Mld3 = "Die Gesamtsumme aller Leistungen für diesen Termin wurde bereits durch Akontozahlung(en) erreicht"

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        Set RpCol = RpCls.Find(Ter_TerBet)
        TeBet = CSng(RpRow.Record(RpCol.ItemIndex).Value)
        Set RpCol = RpCls.Find(Ter_SerBet)
        SeBet = CSng(RpRow.Record(RpCol.ItemIndex).Value)
        Set RpCol = RpCls.Find(Ter_BezBet)
        BzBet = CSng(RpRow.Record(RpCol.ItemIndex).Value)
        If TeBet > 0 Then
            If SeBet > 0 Then
                If BzBet >= SeBet Then
                    WindowMess Mld2, Dial2, Tit1, FM.hwnd
                Else
                    If RpSel.Count > 1 Then
                        frmOPAusg.Show vbModal
                    Else
                        frmAnzahl.Show vbModal
                    End If
                End If
            Else
                If BzBet >= TeBet Then
                    WindowMess Mld3, Dial2, Tit1, FM.hwnd
                Else
                    If RpSel.Count > 1 Then
                        frmOPAusg.Show vbModal
                    Else
                        frmAnzahl.Show vbModal
                    End If
                End If
            End If
        Else
            WindowMess Mld1, Dial2, Tit1, FM.hwnd
        End If
    End If
End If

