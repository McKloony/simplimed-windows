Public Sub SGrUm(ByVal Flag As Integer, Optional ByVal NeuSt As String)
On Error GoTo ReErr
'Benennt eine Gruppe um

Dim FilNa As String
Dim TmpKy As String
Dim Mld1, Tit1 As String

Set FM = frmMain
Set TrLi1 = FM.trvList1

TmpKy = GlPaK

Set clFil = New clsFile

FilNa = TrLi1.SelectedItem.Text & ".sql"

Select Case Flag
Case 1:
        If Left$(TmpKy, 1) = "G" Then
            TrLi1.StartLabelEdit
        ElseIf Left$(TmpKy, 1) = "F" Then
            TrLi1.StartLabelEdit
        Else
            Mld1 = "Diese Gruppe kann nicht umbenannt werden"
            Tit1 = "Umbenennen"
            WindowMess Mld1, Dial2, Tit1, FM.hwnd
        End If
Case 2:
        If Left$(TmpKy, 1) = "G" Then
            If Not NeuSt = vbNullString Then
                GrAd_Umb NeuSt
            End If
        ElseIf Left$(TmpKy, 1) = "F" Then
            If Not NeuSt = vbNullString Then
                clFil.DaCop = GlFPf & FilNa & ";" & GlFPf & NeuSt & ".sql" & vbNullChar
                If clFil.FilCop(3) = False Then
                    SPopu "Datei schreibgeschützt", "Die Datei kann nicht umbenannt werden", IC48_Warning
                End If
            End If
        End If
Case 3:
    Dia_Ed
Case 4:
    Dia_Um NeuSt
End Select

Set clFil = Nothing

Exit Sub

ReErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SGrUm " & Err.Number
Resume Next

End Sub
Public Sub SImage(ByVal FiNam As String)
