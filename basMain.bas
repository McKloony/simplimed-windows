Public Sub SClear()
On Error GoTo BuErr
'Prüft auf ClearType Einstellungen

Dim RetWe As Long
Dim FntNa As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim FonGr As Single
Dim CleTy As Boolean

TeTit = "Windows Schriftenglättung"
TeMai = "Soll die Windows Schriftenglättung jetzt eingeschaltet werden"
TeInh = "Es wurde festgestellt, dass Sie Windows die Schriftenglättung noch nicht eingeschaltet haben. Möchten Sie die Windows Schriftenglättung nun einschalten?"
TeFus = "Die Windows Schriftenglättung (ClearType) verbessert die Schriftdarstellung auf Ihrem Bildschirm. Es wird daher empfohlen, diese einzuschalten"

If IniGetVal("Layout", "CleTyp") <> vbNullString Then
    CleTy = CBool(IniGetVal("Layout", "CleTyp"))
Else
    CleTy = False
End If

If CleTy = False Then
    RetWe = WindowClear(False)
    If RetWe <= 0 Then
        If GloSp = False Then 'Splashscreen zeigen
            If GlRDP = True Then
                Unload frmSplashR
            Else
                Unload frmSplash
            End If
        End If
        If GlApp = False Then 'AppMOde
            SMeFr TeTit, TeMai, TeInh, TeFus, True, 0, False, frmMain.hwnd
        Else
            GlMso = True
        End If
        If GlMso = True Then 'Mesage Dialog Option
            IniSetVal "Layout", "CleTyp", -1
            GlMso = False
        End If
        If GlMes = 33565 Then
            RetWe = WindowClear(True)
            FntNa = "Arial"
            IniSetVal "Layout", "FntNam", FntNa
            IniSetVal "Layout", "KraFnt", FntNa
            IniSetVal "Layout", "CleTyp", -1
        Else
            FntNa = "MS Sans Serif"
            If GlTFt.Name <> FntNa Then
                IniSetVal "Layout", "FntNam", FntNa
                IniSetVal "Layout", "KraFnt", FntNa
            End If
        End If
    Else
        If IniGetVal("Layout", "CleTyp") <> vbNullString Then
            IniSetVal "Layout", "CleTyp", -1
        End If
        FonGr = 9
        FntNa = "Arial"
        If GlTFt.Name <> FntNa Then
            IniSetVal "Layout", "FntNam", FntNa
            IniSetVal "Layout", "KraFnt", FntNa
            IniSetVal "Layout", "FntGro", FonGr
            IniSetVal "Layout", "KraGro", FonGr
        End If
    End If
End If

Exit Sub

BuErr:
If GlDbg = True Then SErLog Err.Description & " SClear " & Err.Number
Resume Next

End Sub
