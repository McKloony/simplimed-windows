            FlIdx = TxCoN.FieldNext(FlIdx, 0)
        Wend
        .HeaderFooterSelect 0
        DoEvents
        .HeaderFooterSelect txFooter
        FlIdx = TxCoN.FieldNext(0, 0)
        While FlIdx <> 0
            TxCoN.FieldCurrent = FlIdx
            For AktZa = 1 To UBound(GlSer)
                If TxCoN.FieldData(FlIdx) = GlSer(AktZa, 1) Then
                    Select Case AktZa
                    Case 60: 'Rechnungspositionen
                    Case 61: 'Krankenblattpositionen
                    Case 62: 'Laborberichtpositionen
                    Case Else: TxCoN.FieldText = GlSer(AktZa, 2)
                    End Select
                    Exit For
                End If
            Next AktZa
            TxCoN.FieldCurrent = 0
            FlIdx = TxCoN.FieldNext(FlIdx, 0)
        Wend
    End If
    .HeaderFooterSelect 0
End With

TxCoN.Refresh

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "STxV1 " & Err.Number
Resume Next

End Sub

