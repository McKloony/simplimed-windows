Public Function SVePr(ByVal VerNr As String) As Boolean
On Error GoTo LaErr
'Versionsprüfung der Datenbankdatei

Dim PrgLg As Long
Dim VerLg As Long
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim PrgVe As String
Dim DaPfa As String
Dim Gefun As Integer
Dim Frage As Integer
Dim Mld1, Tit1 As String

PrgVe = App.Major & "." & App.Minor & "." & App.Revision

PrgVe = Replace(PrgVe, ",", vbNullString, 1)
PrgVe = Replace(PrgVe, ".", vbNullString, 1)

VerNr = Replace(VerNr, ",", vbNullString, 1)
VerNr = Replace(VerNr, ",", vbNullString, 1)

PrgLg = CLng(PrgVe)
VerLg = CLng(VerNr)

If VerNr = "0" Then
    TeTit = "Falsche Datenbank"
    TeMai = "Die geöffnete Datenbank hat keine Versionsnummer"
    TeInh = "Sie versuchen eine Datenbank zu öffnen, die keine Versionsnummer hat! Bitte beenden Sie das Programm und führen ein Datenbankupdate durch."
    TeFus = "Wenn Sie Daten aus einer fremden Datenbank importieren möchten, so nutzen Sie das Datenübernahmetool oder wenden sich an den technischen Support."
ElseIf GlTyp < 2 Then
    TeTit = "Falsche Datenbankversion"
    TeMai = "Die Version der geöffneten Datenbank passt nicht zur Programmversion"
    TeInh = "Das von Ihnen installierte Programm hat die Releasenummer: " & PrgVe & " und die Datenbank, die Sie versuchen zu öffnen, hat die Releasenummer: " & VerNr & ". Bitte beenden Sie das Programm und führen ein Datenbankupdate durch."
    If CLng(PrgVe) > CLng(VerNr) Then 'Programmversion ist neuer als die Datenbankversion
        VerNr = "0"
        TeFus = "Die Datenbank muss mit einem SQL Script an das aktuelle Programmrelease angepasst werden."
    ElseIf PrgLg < VerLg Then
        VerNr = "0"
        TeFus = "Das von Ihnen gestartete SimpliMed Programm hat eine ältere Releasenummer, als die Datenbankdatei, die Sie versuchen zu öffnen. Bitte installieren Sie die aktuelle SimpliMed Version."
    Else
        SVePr = True
    End If
Else
    TeTit = "Falsche Datenbankversion"
    TeMai = "Die Version der geöffneten Datenbankdatei passt nicht zur Programmversion"
    TeInh = "Das von Ihnen installierte Programm hat die Releasenummer: " & PrgVe & " und die Datenbankdatei, die Sie versuchen zu öffnen, hat die Releasenummer: " & VerNr & ". Bitte beenden Sie das Programm und führen ein Datenbankupdate durch."
    If PrgLg > VerLg Then 'Programmversion ist neuer als die Datenbankversion
        VerNr = "0"
        TeFus = "Bitte beenden Sie SimpliMed und starten das Datenbanktool, um die Datenbankdatei an das aktuelle Programmrelease anzupassen."
    ElseIf PrgLg < VerLg Then
        VerNr = "0"
        TeFus = "Das von Ihnen gestartete SimpliMed Programm hat eine ältere Releasenummer, als die Datenbankdatei, die Sie versuchen zu öffnen. Bitte installieren Sie die aktuelle SimpliMed Version."
    Else
        SVePr = True
    End If
End If

If VerNr = "0" Then
    SSplS1 'Splashscreen schließen
    SSplS2 'Splashscreen schließen
    If GlTyp > 1 Then
        IniSetVal "SysPfa", "DatPfa", LCase(GlPfa & "Datenbankdatei.dbv")
    End If
    If GlApp = False Then
        SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, True, frmMain.hwnd
    Else
        SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, True, frmApMod.hwnd
    End If
    If GlMes <> 33565 Then
        SVePr = True
    End If
End If

Exit Function

LaErr:
If GlDbg = True Then SErLog Err.Description & " SVePr " & Err.Number
Resume Next

End Function
