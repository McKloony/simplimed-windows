Public Sub SBuDo()
On Error GoTo KoErr
'Buchungsdokument Öffnen

Dim FiNam As String
Dim DaNam As String
Dim DaPfa As String
Dim DaExt As String
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    Set RpCol = RpCls.Find(Buh_Datei)
    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
        DaNam = RpRow.Record(RpCol.ItemIndex).Value
        FiNam = GlBPf & DaNam
        If clFil.FilVor(FiNam) = False Then
            FiNam = GlDox & DaNam
            If clFil.FilVor(FiNam) = False Then
                SPopu "Dokument nicht gefunden", "Das zugeordnete Dokument konnte nciht gefunden werden.", IC48_Warning
                Set clFil = Nothing
                Set RpCo1 = Nothing
                Exit Sub
            End If
        End If
        With clFil
            .FilPfa FiNam
            DaExt = .DaExt
            DaPfa = .DaPfa & "\"
        End With

        Select Case LCase(DaExt)
        Case "pdf": SImage FiNam
        Case "jpg": SImage FiNam
        Case "png": SImage FiNam
        Case "bmp": SImage FiNam
        Case "tif": SImage FiNam
        Case "gif": SImage FiNam
        Case "wmf": SImage FiNam
