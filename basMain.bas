                    Else
                        SQL1 = "SELECT * FROM qryPrSimKr5 WHERE (([PatNr] = " & PatNr & ") AND ([Typ] = " & TypNr & ") AND ([Jahr] = " & SuJah & ") AND ([Monat] = " & SuMon & ") AND ([Typ] > 9)) ORDER BY [Datum];"
                    End If
                End If
                
                If EmlSe = True Then
                    DaNam = ForNa & "_" & Format$(Now, "YYYYMMDD_HHMMSS")
                    With GlTxV
                        .TxStr = GlEmT(10, 3)
                        .Datum = Date
                        .DaNam = DaNam
                        .MitNr = MitNr
                        .ManNr = ManNr
                        .PatNr = PatNr
                    End With
                    EmBet = SEmTx()
                    Select Case GlEmA 'Emailafdresse Rechnungsversand
                    Case 0: EmAdr = S_AdIdx(PatNr, "Telefon5")
                            Brief = S_AdIdx(PatNr, "Briefanrede")
                    Case 1: EmAdr = S_AdIdx(ManNr, "Telefon5")
                            Brief = S_AdIdx(ManNr, "Briefanrede")
                    End Select
                    EmTex = Brief & vbCrLf & vbCrLf & "als Anlage sende ich Ihnen das angehängte Dokument."
                End If
                
                If Formu = True Then
                    With clLis
                        .ForNam = ForNa
                        .FilNam = FiNam
                        .PfaTmp = GlTmp
                        .Kriter = SQL1
                        .MandVo = True
                        .MitaVo = GlMiV
                        .ArztVo = GlArV
                        If EmlSe = True Then
                            .EmlAdr = EmAdr
                            .EmlBet = EmBet
                            .EmlTex = EmTex
                            .EmlDia = True
                            .DruVor = True
                            .DruDia = False
                            If ExpOr = True Then
                                .EmlSen = 10
                            Else
                                .EmlSen = GlEmA + 1 'Emailafdresse Rechnungsversand
                            End If
                        Else
                            .DruVor = GlDrV
                            .DruDia = True
                        End If
                        .LLPrLi
                        If ExpOr = True Then
                            WindowMess "Das Krankenblatt wurde nach " & GlEPf & " exportiert", Dial2, "Krankenblattexport", FM.hwnd
                        End If
                    End With
                End If
                ReDim GloDr(0)
                                
            End If
        End If
    End If
End If

Set RpCls = Nothing
Set RpSel = Nothing
Set RpCo6 = Nothing
Set RpCoK = Nothing

Set clLis = Nothing
Set clFil = Nothing

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SVoDr " & Err.Number
Resume Next

End Sub

Public Sub SWaSe(ByVal WaSet As Integer)
On Error GoTo AdErr
'Wartezimmerliste setzen

Dim TerNr As Long
Dim RowNr As Long
Dim EndZe As Date
Dim SuStr As String
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCol As XtremeReportControl.ReportColumn
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpSel As XtremeReportControl.ReportSelectedRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmTermWa

Set clFen = New clsFenster
clFen.hwnd = frmMain.hwnd

Select Case WaSet
Case 1: 'Patienten Aufnahme
    Set RpCo1 = frmMain.repCont1
    Set RpCls = RpCo1.Columns
    Set RpSel = RpCo1.SelectedRows

    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        If RpRow.GroupRow = False Then
            Set RpCol = RpCls.Find(Ter_ZeiVor)
            If IsNull(RpRow.Record(RpCol.ItemIndex).Value) = True Then
                Set RpCol = RpCls.Find(Ter_WartZim)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    If CInt(RpRow.Record(RpCol.ItemIndex).Value) < 1 Then
                        FM.WaSet = WaSet
                        FM.Show vbModal
                    Else
                        SPopu "Patientenaufnahme", "Dieser Patient wurde der Wartezimmerliste bereits hinzugefügt.", IC48_Forbidden
                    End If
                End If
            Else
                Tit1 = "Patientenaufnahme"
                Mld1 = "Dieser Patient wurde bereits entlassen. Soll dieser jetzt wieder aufgenommen werden?"
                Frage = WindowMess(Mld1, Dial1, Tit1, frmMain.hwnd)
                If Frage = 6 Then
                    FM.WaSet = WaSet
                    FM.Show vbModal
                End If
            End If
        End If
    End If
Case 2: 'Patient in Behanldung
    Set RpCo6 = frmMain.repCont6
    Set RpCls = RpCo6.Columns
    Set RpSel = RpCo6.SelectedRows
    
    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        If RpRow.GroupRow = False Then
            RowNr = RpRow.Index
            Set RpCol = RpCls.Find(War_ID2)
            TerNr = CLng(RpRow.Record(RpCol.ItemIndex).Value)
            Set RpCol = RpCls.Find(War_Wartezimmer)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                If CInt(RpRow.Record(RpCol.ItemIndex).Value) = 1 Then
                    FM.WaSet = WaSet
                    FM.Show vbModal
                Else
                    SPopu "Patientenaufnahme", "Dieser Patient befindet sich bereits im Behandlungszimmer.", IC48_Forbidden
                End If
            End If
        End If
    End If
Case 3: 'Patient aus Behandlung
    Set RpCo6 = frmMain.repCont6
    Set RpCls = RpCo6.Columns
    Set RpSel = RpCo6.SelectedRows
    
    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        If RpRow.GroupRow = False Then
            RowNr = RpRow.Index
            Set RpCol = RpCls.Find(War_ID2)
            TerNr = CLng(RpRow.Record(RpCol.ItemIndex).Value)
            Set RpCol = RpCls.Find(War_Wartezimmer)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                If CInt(RpRow.Record(RpCol.ItemIndex).Value) = 2 Then
                    S_WaSe2 TerNr, 1
                    DoEvents
                    
                    Screen.MousePointer = vbHourglass
                    clFen.FenDsk 2
                    
                    S_WaPo RowNr
                    
                    clFen.FenDsk 3
                    Screen.MousePointer = vbNormal
                Else
                    SPopu "Patientenaufnahme", "Dieser Patient befindet sich nicht im Behandlungszimmer.", IC48_Forbidden
                End If
            End If
        End If
    End If
Case 4: 'Patient Entlassen
    Set RpCo6 = frmMain.repCont6
    Set RpCls = RpCo6.Columns
    Set RpSel = RpCo6.SelectedRows
    
    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        If RpRow.GroupRow = False Then
            RowNr = RpRow.Index
            Set RpCol = RpCls.Find(War_ID2)
            TerNr = CLng(RpRow.Record(RpCol.ItemIndex).Value)
            Set RpCol = RpCls.Find(War_GuiID)
            SuStr = RpRow.Record(RpCol.ItemIndex).Value

            S_WaSe3 TerNr, 0
            DoEvents
            
            Screen.MousePointer = vbHourglass
            clFen.FenDsk 2

            S_WaPo RowNr
            DoEvents
            SUpTe

            clFen.FenDsk 3
            Screen.MousePointer = vbNormal
        End If
    End If
End Select

Set RpCo1 = Nothing
Set RpCo6 = Nothing
Set RpCls = Nothing
Set RpSel = Nothing

Set clFen = Nothing

Exit Sub

AdErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SWaSe " & Err.Number
Resume Next

End Sub
