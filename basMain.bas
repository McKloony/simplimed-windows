Public Function STxPl(Optional ByVal AdDat As Boolean = False, Optional ByVal NoDia As Boolean = False) As Boolean
On Error GoTo PoErr
'Prüft die Platzhalter im Text

Dim SuTex As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim Posit As Integer
Dim DoSav As Boolean
Dim RetWe As Boolean
Dim TxFnt As New StdFont

Set FM = frmMain
Set TxCoN = FM.TexCont1

TeTit = "Fehlender Platzhalter"
TeMai = "Es wurde kein Unterschriften-Platzhalter gefunden"
TeInh = "Soll ein Dokument digital unterschrieben werden, ist es erforderlich zu kennzeichnen, an welcher Stelle das Dokument unterzeichnet werden soll. Dazu fügen Sie an die gewünschte Position die Zeichenkette $$$ ein."
TeFus = "Bitte beachten Sie, dass am unteren Rand beziehungsweise unter dem Platzhalter genügend Platz verbleiben muss, damit die digitale Unterschrift hinzufügen werden kann. Die Zeichengröße des Platzhalters sollte nicht größer als der übliche Text im Dokument sein."

TxFnt.Name = GlXFt.Name
TxFnt.SIZE = GlXFt.SIZE

SuTex = TxCoN.Text
Posit = InStr(1, SuTex, "$$$", 1)
If Posit > 0 Then
    STxPl = True
    With TxCoN
        .SelStart = Posit - 1
        .SelLength = 3
        DoEvents
        If .FontName <> TxFnt.Name Then
            .FontName = TxFnt.Name
            DoSav = True
        End If
        If CInt(.FontSize) <> CInt(TxFnt.SIZE) Then
            .FontSize = TxFnt.SIZE
            DoSav = True
        End If
        If .ForeColor <> 0 Then
            .ForeColor = 0
            DoSav = True
        End If
        If .Alignment <> 0 Then
            .Alignment = 0
            DoSav = True
        End If
        If .IndentL <> 0 Then
            .IndentL = 0
            DoSav = True
        End If
        .FontBold = False
        .FontItalic = False
        .FontUnderline = False
        .FontStrikethru = False
        .LineSpacing = 110
    End With
    If NoDia = False Then
        If DoSav = True Then
            RetWe = STxSa()
        End If
    End If
Else
    STxPl = False
    If NoDia = False Then
        SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, frmMain.hwnd
    End If
    Exit Function
End If

If AdDat = True Then
    TeTit = "Fehlender Platzhalter"
    TeMai = "Es wurde kein Adressen-Platzhalter gefunden"
    TeInh = "Sollen die Adressdaten des Patienten in das Dokument eingefügt werden, ist es erforderlich zu kennzeichnen, an welcher Stelle das Dokuments diese dargestellt werden soll. Dazu fügen Sie an die gewünschte Position die Zeichenkette &&&1 oder &&&2 ein."
    TeFus = "Bitte beachten Sie, dass unter dem Platzhalter genügend Platz verbleiben muss, damit die Adresse eingefügt werden kann. Die Zeichengröße des Platzhalters sollte nicht größer als der übliche Text im Dokument sein."
    
    Posit = InStr(1, SuTex, "&&&", 1)
    If Posit > 0 Then
        STxPl = True
    Else
        STxPl = False
        If NoDia = False Then
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, frmMain.hwnd
        End If
        Exit Function
    End If
Else
    TeTit = "Falsche Platzhalter"
    TeMai = "Es wurde falsche Adressen-Platzhalter gefunden"
    TeInh = "Sollen die Adressdaten des Patienten in das Dokument eingefügt werden, ist es erforderlich zu kennzeichnen, an welcher Stelle das Dokuments diese dargestellt werden soll. Dazu fügen Sie an die entsprechende Position die gewünschten Serienfelder ein."
    TeFus = "Es wurden die Platzhalter für das Neuaufnahmeformular bzw. für einen Fragebogen gefunden. Diese Platzhalter können auch nur in diesem Kontext verwendet werden und nicht bei der Funktion, die gerade ausgeführt wird."
    
    Posit = InStr(1, SuTex, "&&&", 1)
    If Posit > 0 Then
        STxPl = False
        If NoDia = False Then
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, frmMain.hwnd
        End If
        Exit Function
    Else
        STxPl = True
    End If
End If

Exit Function

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "STxPl " & Err.Number
Resume Next

End Function
