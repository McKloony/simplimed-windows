Function SDeco(ByVal TmStr) As String
On Error Resume Next

Dim DaLen As Long
Dim AkGrp As Long
Dim OuStr As String

Const BaStr = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

Set PrBr1 = frmStatus.prbStat1
Set PrBr2 = frmStatus.prbStat2

frmStatus.Show
DoEvents
frmStatus.Caption = "PDF Erzeugung"

TmStr = Replace(TmStr, vbCrLf, "")
TmStr = Replace(TmStr, vbTab, "")
TmStr = Replace(TmStr, " ", "")
  
DaLen = Len(TmStr)
If DaLen Mod 4 <> 0 Then
    Err.Raise 1, "Base64Decode", "Bad Base64 string."
    Exit Function
End If

PrBr1.Min = 0
PrBr1.Max = DaLen
  
For AkGrp = 1 To DaLen Step 4
    Dim NuByt As Long
    Dim AkChr As Long
    Dim AkStr As String
    Dim DaStr As String
    Dim WaStr As String
    Dim NuGrp As Variant

    NuByt = 3
    NuGrp = 0

    For AkChr = 0 To 3
        AkStr = Mid(TmStr, AkGrp + AkChr, 1)

        If AkStr = "=" Then
            NuByt = NuByt - 1
            DaStr = 0
        Else
            DaStr = InStr(1, BaStr, AkStr, vbBinaryCompare) - 1
        End If
        If DaStr = -1 Then
            Err.Raise 2, "Base64Decode", "Bad character In Base64 string."
            Exit Function
        End If

        NuGrp = 64 * NuGrp + DaStr
    Next
    NuGrp = Hex(NuGrp)
    NuGrp = String(6 - Len(NuGrp), "0") & NuGrp
    WaStr = Chr(CByte("&H" & Mid(NuGrp, 1, 2))) + Chr(CByte("&H" & Mid(NuGrp, 3, 2))) + Chr(CByte("&H" & Mid(NuGrp, 5, 2)))
    OuStr = OuStr & Left(WaStr, NuByt)
    
    PrBr1.Value = AkGrp
    DoEvents
Next

Unload frmStatus
DoEvents

SDeco = OuStr

End Function
Public Sub SKoEd()
On Error GoTo SpErr
'Krankenblatteintrag bearbeiten

Dim EinTy As Long
Dim DaNam As String
Dim DaNaO As String
Dim ReLok As Boolean
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCoK As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmMain
Set RpCo3 = FM.repCont3
Set RpCo6 = FM.repCont6
Set RpCoK = FM.repContK

If GlBut = RibTab_Abrechnung Then
    If RpCo3.Records.Count > 0 Then
        Set RpSel = RpCo3.SelectedRows
        Set RpRow = RpSel(0)
        Set RpCls = RpCo3.Columns
        If RpSel.Count > 0 Then
            Set RpCol = RpCls.Find(Rec_Lock)
            If RpRow.Record(RpCol.ItemIndex).Checked = True Then
                ReLok = True
            Else
                ReLok = False
            End If
        Else
            ReLok = True
        End If
    Else
        ReLok = True
    End If
End If

Select Case GlBut
Case RibTab_Krankenbla:
        Set RpSel = RpCoK.SelectedRows
        Set RpCls = RpCoK.Columns
Case RibTab_Abrechnung:
        Set RpSel = RpCo6.SelectedRows
        Set RpCls = RpCo6.Columns
End Select

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then

        Set RpCol = RpCls.Find(Kra_Typ)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            If IsNumeric(RpRow.Record(RpCol.ItemIndex).Value) = True Then
                EinTy = CLng(RpRow.Record(RpCol.ItemIndex).Value)
            End If
        End If
        Set RpCol = RpCls.Find(Kra_Typname)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            DaNam = RpRow.Record(RpCol.ItemIndex).Value
        Else
            DaNam = vbNullString
        End If
        Set RpCol = RpCls.Find(Kra_Kommentar)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            DaNaO = RpRow.Record(RpCol.ItemIndex).Value
        Else
            DaNaO = vbNullString
        End If
            
        Select Case GlBut
        Case RibTab_Abrechnung:
            If ReLok = False Then
                KoMain
            Else
                SPopu "GOBD Festschreibung", "Die markierte Rechnung wurde bereits festgeschrieben", IC48_Forbidden
            End If
        Case RibTab_Krankenbla:
            Select Case EinTy
            Case 24: KoMain DaNam, DaNaO 'Textdokument
            Case 101: KoMain DaNam, DaNaO 'Rezepte
            Case 102: KoMain DaNam, DaNaO 'Datei
            Case 105: KoMain DaNam, DaNaO 'Bild
            Case 106: KoMain DaNam, DaNaO 'Rechnung
            Case Else: KrMain
            End Select
        End Select
        
    End If
End If

Set RpCo3 = Nothing
Set RpCo6 = Nothing
Set RpCoK = Nothing

Exit Sub

SpErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SKoEd " & Err.Number
Resume Next

End Sub
Public Sub SKrAk()
On Error GoTo PoErr
'Aktualisierungen im Krankneblatt

Dim GesBe As Single
Dim EinBe As Single
Dim Fakto As Single
Dim Anzal As Integer
Dim Tit1, Mld1 As String
Dim Mld2, Mld3 As String
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCoK As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmMain
Set RpCo6 = FM.repCont6
Set RpCoK = FM.repContK
Select Case GlBut
Case RibTab_Krankenbla:
        Set RpSel = RpCoK.SelectedRows
        Set RpCls = RpCoK.Columns
Case RibTab_Abrechnung:
        Set RpSel = RpCo6.SelectedRows
        Set RpCls = RpCo6.Columns
End Select

Tit1 = "Steigerungsfaktor von " & Format$(GlFak, GlWa1) & " überschritten"
Mld1 = "Der Steigerungsfaktor wurde überschritten. Möchten Sie eine Begründung zu dieser Ziffer eingeben?"
Mld2 = "Der im Optionsdialog eingestellte Steigerungsfaktor von " & Format$(GlFak, GlWa1) & " wurde überschritten. In der Regel macht dieses die Eingabe einer Begründung erforderlich."
Mld3 = "Mit einem Begründungstext zu der von Ihnen eingegebenen Abrechnungsziffer können Sie erläutern, aus welchen gründen ein höherer als der vorgegebene Steigerungsfaktor erforderlich ist."

GlSav = True

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then

        Set RpCol = RpCls.Find(Kra_Bezeichnung)
        RpRow.Record(RpCol.ItemIndex).Tag = "@Bezeichnung" 'Tag geändert
        If IsNull(RpRow.Record(RpCol.ItemIndex).Value) Then
            RpRow.Record(RpCol.ItemIndex).Value = "..."
        End If

        Set RpCol = RpCls.Find(Kra_Faktor)
        Select Case GlStD 'Standard-Dezimaltrennzeichen
        Case 0: Fakto = CSng(Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1))
        Case 1: Fakto = CSng(RpRow.Record(RpCol.ItemIndex).Value)
        End Select
                
        Set RpCol = RpCls.Find(Kra_Anz)
        Anzal = CInt(RpRow.Record(RpCol.ItemIndex).Value)

        Set RpCol = RpCls.Find(Kra_Betrag)
        If IsNull(RpRow.Record(RpCol.ItemIndex).Value) Then
            Set RpCol = RpCls.Find(Kra_GesBetrag)
            If Not IsNull(RpRow.Record(RpCol.ItemIndex).Value) Then
                Select Case GlStD 'Standard-Dezimaltrennzeichen
                Case 0: GesBe = CSng(Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1))
                Case 1: GesBe = CSng(RpRow.Record(RpCol.ItemIndex).Value)
                End Select
                Set RpCol = RpCls.Find(Kra_Betrag)
                RpRow.Record(RpCol.ItemIndex).Value = Format$(GesBe, GlWa1)
            Else
                Set RpCol = RpCls.Find(Kra_Betrag)
                RpRow.Record(RpCol.ItemIndex).Value = GlWa2
            End If
        Else
            Select Case GlStD 'Standard-Dezimaltrennzeichen
            Case 0: EinBe = CSng(Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1))
            Case 1: EinBe = CSng(RpRow.Record(RpCol.ItemIndex).Value)
            End Select
            RpRow.Record(RpCol.ItemIndex).Value = Format$(EinBe, GlWa1)
            RpRow.Record(RpCol.ItemIndex).Tag = "@Betrag" 'Tag geändert
        End If
        
        Set RpCol = RpCls.Find(Kra_GesBetrag)
        If IsNull(RpRow.Record(RpCol.ItemIndex).Value) Then
            Set RpCol = RpCls.Find(Kra_Betrag)
            If Not IsNull(RpRow.Record(RpCol.ItemIndex).Value) Then
                Select Case GlStD 'Standard-Dezimaltrennzeichen
                Case 0: EinBe = CSng(Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1))
                Case 1: EinBe = CSng(RpRow.Record(RpCol.ItemIndex).Value)
                End Select
                Set RpCol = RpCls.Find(Kra_GesBetrag)
                RpRow.Record(RpCol.ItemIndex).Value = Format$(EinBe, GlWa1)
            Else
                Set RpCol = RpCls.Find(Kra_GesBetrag)
                RpRow.Record(RpCol.ItemIndex).Value = GlWa2
            End If
        Else
            If Anzal < 1 Then Anzal = 1
            If Fakto < 0.25 Then Fakto = 1
            Set RpCol = RpCls.Find(Kra_GesBetrag)
            RpRow.Record(RpCol.ItemIndex).Value = Format$(EinBe * Anzal * Fakto, GlWa1)
        End If

        Set RpCol = RpCls.Find(Kra_GesBetrag)
        RpRow.Record(RpCol.ItemIndex).Value = Format$(EinBe * Fakto * Anzal, GlWa1)
        RpRow.Record(RpCol.ItemIndex).Tag = "@GesBetrag" 'Tag geändert
                                
        If Fakto >= GlFak Then
            If GlFHi = True Then
                SMeFr Tit1, Mld1, Mld2, Mld3, True, 0, False, frmMain.hwnd
                If GlMso = True Then 'Mesage Dialog Option
                    IniSetVal "System", "FakHin", 0
                    GlMso = False
                    GlFHi = False
                End If
                If GlMes = 33565 Then
                    SKoEd
                End If
            End If
        End If
    End If
End If

Set RpCls = Nothing
Set RpSel = Nothing
Set RpCo6 = Nothing
Set RpCoK = Nothing

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SKrAk " & Err.Number
Resume Next

End Sub
Public Sub SKrDa()
