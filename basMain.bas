Private Sub SKrEm(ByVal KrDat As Date, ByVal MitNr As Long, ByVal ManNr As Long, ByVal DoNam As String, ByVal FilNa As String, ByRef clFile As clsFile, Optional ByVal PreCr As Boolean = False)
On Error GoTo PoErr

Dim NeuNa As String
Dim ZipNa As String
Dim ZpDir As String
Dim DaNam As String
Dim DaNaO As String
Dim EmEmp As String
Dim EmTex As String
Dim EmPas As String
Dim EmBet As String
Dim EmVer As Boolean

S_AdDe GlAdr
With GlADt
    EmEmp = .AdTe5
    EmTex = .AdBrf
    EmPas = .AdPas
    EmVer = .AdAut
End With

If PreCr = True Then
    EmTex = vbCrLf & EmTex
End If

With GlTxV
    .TxStr = GlEmT(9, 3)
    .Datum = KrDat
    .MitNr = MitNr
    .ManNr = ManNr
    .DoNam = DoNam
    .PatNr = GlAdr
End With
EmBet = SEmTx()

With GlTxV
    .TxStr = GlEmT(9, 1)
    .Datum = KrDat
    .MitNr = MitNr
    .ManNr = ManNr
    .DoNam = DoNam
    .PatNr = GlAdr
End With

EmTex = EmTex & vbCrLf & vbCrLf & SEmTx()

If EmVer = True Then
    If EmPas <> vbNullString Then
        With clFile
            .FilPfa FilNa
            DaNam = .DaNam
            DaNaO = .DaNaO
            ZpDir = GlTmp & DaNaO
            NeuNa = ZpDir & "\" & DaNam
            ZipNa = GlTmp & DaNaO & ".zip"
            If Dir$(ZpDir, vbDirectory) = vbNullString Then
                MkDir ZpDir
                DoEvents
            End If
            If .FilVor(NeuNa) = True Then
                .DaLoe = NeuNa & vbNullChar
                .FilLoe
            End If
            .DaCop = FilNa & ";" & NeuNa & vbNullChar
            .FilCop 1
        End With
        DoEvents
        SZipp ZipNa, ZpDir, True, False, EmPas
        FilNa = ZipNa
    End If
End If

SMaNe GlAdr, EmEmp, , EmTex, EmBet, FilNa

Exit Sub
PoErr:
    If GlLog = True Then SLogi "SKrEm Err: " & Err.Description & " #" & Err.Number
End Sub

