            GlTBx = GlMiA(GlSMo, 0) - 1
        Else
            GlTBx = GlMiA(GlSmI, 0) - 1
        End If
    Else
        GlTBx = GlMan(GlSMa, 0) - 1
    End If
    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        Set RpCol = RpCls.Find(Ter_ID2)
        IdxNr = RpRow.Record(RpCol.ItemIndex).Value
    Else
        Mld1 = "Sie müssen erst einen Termin anlegen, um diesen drucken zu können"
        Tit1 = "Termin Drucken"
        WindowMess Mld1, Dial2, Tit1, FM.hwnd
    End If
End Select

For AktZa = 0 To 105 'WICHTIG!
    If LCase(ForNa) = LCase(GlFrm(2, 57)) Then
        FrmBe = GlFrm(0, 57)
        Exit For
    End If
Next AktZa

If FrmBe = vbNullString Then
    For AktZa = 0 To 105 'WICHTIG
        If LCase(ForNa) = LCase(GlFrm(2, 58)) Then
            FrmBe = GlFrm(0, 58)
            Exit For
        End If
    Next AktZa
End If

If PaNum > 0 Then

    ReDim Preserve GloDr(1)
    Select Case ForNa
    Case "TerPat":
        GloDr(1) = PaNum
    Case Else:
        Exit Sub
    End Select
    DaNam = STeDa(PaNum)
    SDruck ForNa, True, , , , DaNam, EmVer
    DoEvents
    GlNeK = GlKoX

    If ForNa = "TerPat" Then
        If GlTMa = True Then 'Kennzeichnung bei Terminzetteldruck
            DBCmEx2 "qryTerOnSe", "@OnlTe", "@IdxNr", -1, PaNum '[OnlTer]
        End If
    End If

    With GlNeK
        .PatNr = PaNum
        .IdxNr = 0
        .EiDat = Format$(Date, "dd.mm.yyyy")
        .EiZei = TimeValue(Now)
        .EiTyp = 22 'Notiz
        .KoStr = FrmBe & " gedruckt"
        .NeuEi = True
        .Mitar = GlMiA(GlSmI, 2)
    End With
    K_Einf
    
ElseIf TeNum > 0 Then

    S_TeDe TeNum
    With GlTDt
        MasNr = .TeMas
        PatNr = .PatNr
    End With
    ReDim Preserve GloDr(1)
    Select Case ForNa
    Case "TeUbNo": GloDr(1) = TeNum
    Case "TeUbEu": GloDr(1) = TeNum
    Case "QuiTer": GloDr(1) = TeNum
    Case "QuiTem": GloDr(1) = TeNum
    Case "TeUbAN": GloDr(1) = TeNum
    Case "TeUbAE": GloDr(1) = TeNum
    Case "TeEiMa": GloDr(1) = TeNum
    Case "TeEiSa": GloDr(1) = TeNum
    Case Else: Exit Sub
    End Select
    DaNam = STeDa(PatNr)
    SDruck ForNa, True, , , , DaNam, EmVer
    DoEvents

    GlNeK = GlKoX
    With GlNeK
        .PatNr = PatNr
        .IdxNr = 0
        .EiDat = Format$(Date, "dd.mm.yyyy")
        .EiZei = TimeValue(Now)
        .EiTyp = 22 'Notiz
        .KoStr = FrmBe & " gedruckt"
        .NeuEi = True
        .Mitar = GlMiA(GlSmI, 2)
    End With
    K_Einf
    
Else

    If IdxNr > 0 Then
        S_TeDe IdxNr
        With GlTDt
            MasNr = .TeMas
            PatNr = .PatNr
        End With
        If PatNr > 0 Then
            ReDim Preserve GloDr(1)
            Select Case ForNa
            Case "TerPat": GloDr(1) = PatNr
            Case "TerSer": GloDr(1) = MasNr
            Case "TeUbNo": GloDr(1) = IdxNr
            Case "TeUbEu": GloDr(1) = IdxNr
            Case "QuiTer": GloDr(1) = IdxNr
            Case "QuiTem": GloDr(1) = IdxNr
            Case "TeUbAN": GloDr(1) = IdxNr
            Case "TeUbAE": GloDr(1) = IdxNr
            Case "TeEiMa": GloDr(1) = PatNr
            Case "TeEiSa": GloDr(1) = PatNr
            End Select

            GlDru = GlDrX
            With GlDru
                .ForNa = ForNa
                .DruVo = True
                .DrDia = False
                .PaNum = PatNr
                .EmVer = EmVer
            End With
            
            DaNam = STeDa(PatNr)
            SDruck ForNa, True, , , , DaNam, EmVer
            DoEvents

            If ForNa = "TerPat" Then
                If GlTMa = True Then 'Kennzeichnung bei Terminzetteldruck
                    DBCmEx2 "qryTerOnSe", "@OnlTe", "@IdxNr", -1, PatNr '[OnlTer]
                End If
            End If

            GlNeK = GlKoX
            With GlNeK
                .PatNr = PatNr
                .IdxNr = 0
                .EiDat = Format$(Date, "dd.mm.yyyy")
                .EiZei = TimeValue(Now)
                .EiTyp = 22 'Notiz
                .KoStr = FrmBe & " gedruckt"
                .NeuEi = True
                .Mitar = GlMiA(GlSmI, 2)
            End With
            K_Einf
        Else
            SPopu "Kein Patient zugeordnet", "Sie müssen dem Termin erst einen Patienten zuordnen", IC48_Forbidden
        End If
    Else
        SPopu "Kein Termin ausgewählt", "Sie müssen erst einen Termine auswählen", IC48_Forbidden
    End If
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing
Set CaCol = Nothing

Exit Sub

AdErr:
If GlDbg = True Then MsgBox Err.Description, 48, "STeDr " & Err.Number
Resume Next

End Sub
