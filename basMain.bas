            .EnsureVisible NeuDa - 30
        End With
        Set CmBr2 = FM.comBar02
        Set CmEdt = CmBr2.FindControl(CmEdt, KA_Kalen, , True)
        CmEdt.Text = NeuDa
        
        Set FM = frmKatKM
