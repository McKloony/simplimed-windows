Public Sub STxSv()
On Error GoTo PoErr
'Speichert eine Textvorlage ab

Dim DaNam As String
Dim FiNam As String

Set FM = frmMain
Set TxCoN = FM.TexCont1
Set CoDia = FM.comDialo

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

DaNam = SDaNa()

With CoDia
    .CancelError = True
    .DialogStyle = 1
    .DialogTitle = "Bitte Name und Ordner der Datei angeben"
    Select Case GlBut
    Case RibTab_Tex_Dokumt:
            .DefaultExt = "*.txm"
            .Filter = "Textverarbeitung (*.txm)|*.txm|Alle Dateien (*.*)|*.*"
    Case RibTab_Tex_Vorlag:
            .DefaultExt = "*.txm"
            .Filter = "Textverarbeitung (*.txm)|*.txm|Alle Dateien (*.*)|*.*"
    Case RibTab_Tex_Rezept:
            .DefaultExt = "*.txr"
            .Filter = "Langrezepte (*.txr)|*.txr|Alle Dateien (*.*)|*.*"
    Case RibTab_Tex_NewsLe:
            .DefaultExt = "*.txn"
            .Filter = "Newslettervorlage (*.txn)|*.txn|Alle Dateien (*.*)|*.*"
    End Select
    .FileName = GlVor & DaNam
    .InitDir = GlVor
    .ShowSave
    FiNam = .FileName
    If .FileTitle = vbNullString Then Exit Sub
End With
        
Select Case GlBut
Case RibTab_Tex_Dokumt:
        If Right$(FiNam, 4) <> ".txm" Then FiNam = FiNam & ".txm"
Case RibTab_Tex_Vorlag:
        If Right$(FiNam, 4) <> ".txm" Then FiNam = FiNam & ".txm"
Case RibTab_Tex_Rezept:
        If Right$(FiNam, 4) <> ".txr" Then FiNam = FiNam & ".txr"
Case RibTab_Tex_NewsLe:
        If Right$(FiNam, 4) <> ".txn" Then FiNam = FiNam & ".txn"
End Select
    
With clFil
    If .FilVor(FiNam) = True Then
        .DaLoe = FiNam & vbNullChar
        .FilLoe
    End If
End With

TxCoN.Save FiNam, 0, 3
DoEvents

GlTSV = False 'Speichern Textverarbeitung
GlTxN = False 'Kein neues Dokument mehr
GlTxS = False

Set clFil = Nothing

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "STxSv " & Err.Number
Resume Next

End Sub
Public Sub STxTa(Optional ByVal TaNeu As Boolean = False)
On Error GoTo PoErr
'Erstellt Tabellen und fügt Daten ein

Dim TabId As Integer 'TabelID
Dim TaIdx As Integer 'Tabellenindex
Dim FlIdx As Integer 'Feldnumer
Dim AktZa As Integer
Dim AktTa As Integer
Dim AkSpa As Integer
Dim AkZei As Integer
Dim GeZei As Integer
Dim KrTyD As Boolean

Dim PosiX As Long
Dim PosiY As Long

Const RaBr1 = 25
Const RaBr2 = 10

KrTyD = CBool(IniGetVal("TexVer", "KrTyDa"))

Set FM = frmMain
Set TxCoN = FM.TexCont1

If TaNeu = True Then
    If GlRVo = True Then
        FlIdx = TxCoN.FieldNext(0, 0)
        While FlIdx <> 0
            TxCoN.FieldCurrent = FlIdx
            For AktZa = 1 To UBound(GlSer)
                If TxCoN.FieldData(FlIdx) = GlSer(60, 1) Then 'Rechnungspositionen
                    TabId = 1001 'Rechnungspositionen
                    TxCoN.FieldGoto txFieldStandard, FlIdx
                    GeZei = UBound(GlReA) 'Rechnungspositionen
                    If GeZei > 1 Then
                    
                        If TxCoN.TableCanInsert = True Then
                            TxCoN.TableInsert GeZei, 5, -1, TabId
                        End If
                               
                        For AkZei = 1 To GeZei
                            For AkSpa = 1 To 5
                                TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellVertAlign) = 1
                                TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellBorderWidth) = RaBr2
                                TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellPageBreakAllowed) = True
                                Select Case AkSpa
                                Case 1: TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 1000
                                Case 2: TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 4500
                                Case 3: TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 1100
                                Case 4: TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 900
                                Case 5: TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 2500
                                End Select
                            Next AkSpa
                        Next AkZei
                    
                        For AkSpa = 1 To 5
                            TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellPageBreakAllowed) = False
                            TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellBorderWidth) = RaBr1
                            TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellVertAlign) = 1
                            TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellHeight) = 600
                            TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellIsHeader) = True
                        Next AkSpa
                                        
                    End If
                    Exit For
                End If
            Next AktZa
            TxCoN.FieldCurrent = 0
            FlIdx = TxCoN.FieldNext(FlIdx, 0)
        Wend
    End If
    
    If GlLVo = True Then
        FlIdx = TxCoN.FieldNext(0, 0)
        While FlIdx <> 0
            TxCoN.FieldCurrent = FlIdx
            For AktZa = 1 To UBound(GlSer)
                If TxCoN.FieldData(FlIdx) = GlSer(62, 1) Then 'Laborpositionen
                    TabId = 1002 'Laborpositionen
                    TxCoN.FieldGoto txFieldStandard, FlIdx
                    GeZei = UBound(GlLaA) 'Laborpositionen
                    If GeZei > 1 Then
                        If TxCoN.TableCanInsert = True Then
                            TxCoN.TableInsert GeZei, 5, -1, TabId
                        End If
                               
                        For AkZei = 1 To GeZei
                            For AkSpa = 1 To 5
                                TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellVertAlign) = 1
                                TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellBorderWidth) = RaBr2
                                TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellPageBreakAllowed) = True
                                Select Case AkSpa
                                Case 1: TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 4500
                                Case 2: TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 1200
                                Case 3: TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 1200
                                Case 4: TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 1100
                                Case 5: TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 2000
                                End Select
                            Next AkSpa
                        Next AkZei
                    
                        For AkSpa = 1 To 5
                            TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellPageBreakAllowed) = False
                            TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellBorderWidth) = RaBr1
                            TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellVertAlign) = 1
                            TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellHeight) = 600
                            TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellIsHeader) = True
                        Next AkSpa
                    End If
                    Exit For
                End If
            Next AktZa
            TxCoN.FieldCurrent = 0
            FlIdx = TxCoN.FieldNext(FlIdx, 0)
        Wend
    End If
    
    If GlDVo = True Then
        FlIdx = TxCoN.FieldNext(0, 0)
        While FlIdx <> 0
            TxCoN.FieldCurrent = FlIdx
            For AktZa = 1 To UBound(GlSer)
                If TxCoN.FieldData(FlIdx) = GlSer(61, 1) Then 'Krankenblattpositionen
                    TabId = 1003 'Krankenblattpositionen
                    TxCoN.FieldGoto txFieldStandard, FlIdx
                    GeZei = UBound(GlDoA) 'Krankenblattpositionen
                    If GeZei > 1 Then
                        If TxCoN.TableCanInsert = True Then
                            If KrTyD = True Then
                                TxCoN.TableInsert GeZei, 3, -1, TabId
                            Else
                                TxCoN.TableInsert GeZei, 2, -1, TabId
                            End If
                        End If
                        If KrTyD = True Then
                            For AkZei = 1 To GeZei
                                For AkSpa = 1 To 3
                                    TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellVertAlign) = 1
                                    TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellBorderWidth) = RaBr2
                                    TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellPageBreakAllowed) = True
                                    TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellTopTextGap) = 50
                                    TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellBottomTextGap) = 50
                                    Select Case AkSpa
                                    Case 1: TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 1300
                                    Case 2: TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 1500
                                    Case 3: TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 6600
                                    End Select
                                Next AkSpa
                            Next AkZei
                            For AkSpa = 1 To 3
                                TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellPageBreakAllowed) = False
                                TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellBorderWidth) = RaBr1
                                TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellVertAlign) = 1
                                TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellHeight) = 600
                                TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellIsHeader) = True
                            Next AkSpa
                        Else
                            For AkZei = 1 To GeZei
                                For AkSpa = 1 To 2
                                    TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellVertAlign) = 1
                                    TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellBorderWidth) = RaBr2
                                    TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellPageBreakAllowed) = True
                                    TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellTopTextGap) = 50
                                    TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellBottomTextGap) = 50
                                    Select Case AkSpa
                                    Case 1: TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 1500
                                    Case 2: TxCoN.TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 7800
                                    End Select
                                Next AkSpa
                            Next AkZei
                            For AkSpa = 1 To 2
                                TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellPageBreakAllowed) = False
                                TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellBorderWidth) = RaBr1
                                TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellVertAlign) = 1
                                TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellHeight) = 600
                                TxCoN.TableCellAttribute(TabId, 1, AkSpa, txTableCellIsHeader) = True
                            Next AkSpa
                        End If
                    End If
                    Exit For
                End If
            Next AktZa
            TxCoN.FieldCurrent = 0
            FlIdx = TxCoN.FieldNext(FlIdx, 0)
        Wend
    End If
End If

AktTa = 0

Do
AktTa = TxCoN.TableNext(AktTa, TabId)
If AktTa = 0 Then
    Exit Do
Else
    Select Case TabId
    Case 1001:
        If GlRVo = True Then
            GeZei = UBound(GlReA) 'Rechnungspositionen
            If GeZei > 1 Then
                For AkZei = 1 To GeZei
                    For AkSpa = 1 To 5
                        If GlReA(AkZei, AkSpa - 1) <> vbNullString Then
                            TxCoN.TableCellText(TabId, AkZei, AkSpa) = GlReA(AkZei, AkSpa - 1)
                        End If
                    Next AkSpa
                Next AkZei
            End If
        End If
    Case 1002:
        If GlLVo = True Then
            GeZei = UBound(GlLaA) 'Laborpositionen
            If GeZei > 1 Then
                For AkZei = 1 To GeZei
                    For AkSpa = 1 To 5
                        If GlLaA(AkZei, AkSpa - 1) <> vbNullString Then
                            TxCoN.TableCellText(TabId, AkZei, AkSpa) = GlLaA(AkZei, AkSpa - 1)
                        End If
                    Next AkSpa
                Next AkZei
            End If
        End If
    Case 1003:
        If GlDVo = True Then
            GeZei = UBound(GlDoA) 'Krankenblattpositionen
            If GeZei > 1 Then
                For AkZei = 1 To GeZei
                    If KrTyD = True Then
                        For AkSpa = 1 To 3
                            If GlDoA(AkZei, AkSpa - 1) <> vbNullString Then
                                TxCoN.TableCellText(TabId, AkZei, AkSpa) = GlDoA(AkZei, AkSpa - 1)
                            End If
                        Next AkSpa
                    Else
                        For AkSpa = 1 To 2
                            If GlDoA(AkZei, AkSpa) <> vbNullString Then
                                TxCoN.TableCellText(TabId, AkZei, AkSpa) = GlDoA(AkZei, AkSpa)
                            End If
                        Next AkSpa
                    End If
                Next AkZei
            End If
        End If
    End Select
End If
Loop

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "STxTa " & Err.Number
Resume Next

End Sub
Public Sub STxV1(Optional ByVal TxBsp As Boolean = False)
