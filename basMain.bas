                            clFil.FilPfa FilNa
                            DaExt = clFil.DaExt
                            DaNaO = clFil.DaNaO
                            DaPfa = clFil.DaPfa & "\"
                            AnzDa = clFil.FilLis(DaPfa, DaNaO & ".*", DiNam)
                            If AnzDa > 0 Then
                                DaNam = DiNam(1)
