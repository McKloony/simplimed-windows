Public Sub SStPo()
On Error GoTo PoErr

Dim FenBr As Long
Dim FenHo As Long
Dim ClDri As Long
Dim Rpc10 As XtremeReportControl.ReportControl
Dim Rpc11 As XtremeReportControl.ReportControl
Dim Rpc12 As XtremeReportControl.ReportControl

Set FM = frmStart
Set Rpc10 = FM.repCon10
Set Rpc11 = FM.repCon11
Set Rpc12 = FM.repCon12
Set PuBu2 = FM.btnPict2
Set PuBu3 = FM.btnPict3
Set PuBu4 = FM.btnPict4
Set Labl1 = FM.lblLab01
Set Labl2 = FM.lblLab02
Set Labl3 = FM.lblLab03

If GlInF = False Then Exit Sub

FenBr = FM.ScaleWidth
FenHo = FM.ScaleHeight
ClDri = FenBr / 3

If FenBr > 10000 Then
    If FenBr > 1500 Then
        PuBu2.Move 400, 100, 550, 550
        PuBu3.Move ClDri + 100, 100, 550, 550
        PuBu4.Move ClDri + ClDri + 100, 100, 550, 550
        
        Labl1.Move 1000, 250, ClDri - 1400, 300
        Labl2.Move ClDri + 700, 250, ClDri - 1000, 300
        Labl3.Move ClDri + ClDri + 700, 250, ClDri - 1100, 300
        
        Rpc10.Move 400, 660, ClDri - 800, FenHo - 660
        Rpc11.Move ClDri + 100, 660, ClDri - 400, FenHo - 660
        Rpc12.Move ClDri + ClDri + 100, 660, ClDri - 500, FenHo - 660
    End If
End If

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SStPo " & Err.Number
Resume Next

End Sub
