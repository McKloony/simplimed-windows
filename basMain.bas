Public Sub STaGr()
On Error GoTo OpErr
'Gruppiert das Tagesprotokoll

Dim GrPre As Single
Dim GrCap As String
Dim GrAnz As Integer

Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmCom As XtremeCommandBars.CommandBarComboBox
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set RpCo6 = FM.repCont6
Set CmBrs = FM.comBar01
Set CmAcs = CmBrs.Actions

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

Set CmCom = CmBrs.FindControl(CmCom, SY_TP_TagPro_Grupp, , True)

GlGrP = CmCom.ListIndex

GlAkt = True

Screen.MousePointer = vbHourglass
clFen.FenDsk 2

With RpCo6
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    Select Case GlGrP
    Case 2:
        .SortOrder.Add .Columns(Kra_TagSo)
        .GroupsOrder.Add .Columns(Kra_TagSo)
    Case 3:
        .SortOrder.Add .Columns(Kra_Woche)
        .GroupsOrder.Add .Columns(Kra_Woche)
    Case 4:
        .SortOrder.Add .Columns(Kra_Monat)
        .GroupsOrder.Add .Columns(Kra_Monat)
    Case 5:
        .SortOrder.Add .Columns(Kra_Quart)
        .GroupsOrder.Add .Columns(Kra_Quart)
    Case 6:
        .SortOrder.Add .Columns(Kra_Typname)
        .GroupsOrder.Add .Columns(Kra_Typname)
    Case 7:
        .SortOrder.Add .Columns(Kra_KatNa)
        .GroupsOrder.Add .Columns(Kra_KatNa)
    End Select
    If GlGrP > 1 Then
        Select Case GlSoL
        Case 2: .GroupsOrder(0).SortAscending = False
        Case 1: .GroupsOrder(0).SortAscending = True
        End Select
    End If
    RpCo6.Populate
    DoEvents
    
    Set RpRws = RpCo6.Rows
    
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            Set RpGrw = RpRow
            Set ChRws = RpGrw.Childs
            GrAnz = ChRws.Count
            For Each ChRow In ChRws
                If IsNumeric(ChRow.Record.Item(Kra_GesBetrag).Value) Then
                    GrPre = GrPre + ChRow.Record.Item(Kra_GesBetrag).Value
                End If
            Next ChRow
            If Len(RpGrw.GroupCaption) > 0 Then
                GrCap = RpGrw.GroupCaption
                RpGrw.GroupCaption = GrCap & " - Anzahl: " & GrAnz
                If GlExT = 1 Then
                    RpGrw.Expanded = True
                Else
                    RpGrw.Expanded = False
                End If
            End If
        End If
        GrPre = 0
    Next RpRow
End With

If GlGrP > 1 Then
    CmAcs(SY_TP_TagPro_Expan).Enabled = True
Else
    CmAcs(SY_TP_TagPro_Expan).Enabled = False
End If
IniSetVal "Layout", "GruTap", GlGrP

clFen.FenDsk 3
Screen.MousePointer = vbNormal

Set CmAct = Nothing
Set CmBrs = Nothing
Set RpRws = Nothing
Set RpCo6 = Nothing

Set clFen = Nothing

GlAkt = False

Exit Sub

OpErr:
If GlDbg = True Then MsgBox Err.Description, 48, "STaGr " & Err.Number
Resume Next

End Sub
