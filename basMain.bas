                End Select
            Case 2:
                Select Case VoTyp
                Case 1: .FontSize = 9
                Case 2: .FontSize = 10
                End Select
            Case 3:
                Select Case VoTyp
                Case 1: .FontSize = 10
                Case 2: .FontSize = 9
                End Select
            Case 4:
                Select Case VoTyp
                Case 1: .FontSize = 8
                Case 2: .FontSize = 8
                End Select
            End Select
            .FontBold = False
            .FontItalic = False
            .Alignment = 0
                        
       End With
    Next AkSpa
Next AkZei

With TxCoN
    Select Case VoTyp
    Case 1: .TableCellSelect TabId, 1, 1
    Case 2: .TableCellSelect TabId, 1, 2
    End Select
    .FieldInsert "<" & GlSer(74, 0) & ">" 'Tagesdatum
    FlIdx = .FieldCurrent
    .FieldType(FlIdx) = txFieldStandard
    .FieldData(FlIdx) = GlSer(74, 1)
    .FieldEditAttr(FlIdx) = &H2 + &H10
    .FieldChangeable = False
    .FieldDeleteable = True
    
    Select Case VoTyp 'Tagesdatum
    Case 1:
        .TableCellSelect TabId, 1, 2
        .FontBold = True
        .FontSize = 9
    Case 2:
        .TableCellSelect TabId, 1, 3
        .FontBold = True
        .FontSize = 9
    End Select
    
    '----------
    
    Select Case VoTyp
    Case 1: .TableCellSelect TabId, 2, 2
    Case 2: .TableCellSelect TabId, 2, 1
    End Select
    .FieldInsert "<" & GlSer(30, 0) & ">" 'Rechnungsempänger Briefanrede
    FlIdx = .FieldCurrent
    .FieldType(FlIdx) = txFieldStandard
    .FieldData(FlIdx) = GlSer(30, 1)
    .FieldEditAttr(FlIdx) = &H2 + &H10
    .FieldChangeable = False
    .FieldDeleteable = True
    
    Select Case VoTyp 'Rechnungsempänger Briefanrede
    Case 1:
        .TableCellSelect TabId, 2, 3
        .FontBold = False
        .FontSize = 10
    Case 2:
        .TableCellSelect TabId, 2, 2
        .FontBold = False
        .FontSize = 10
    End Select
    
    '----------
    
    If DaFel = True Then
        Select Case VoTyp
        Case 1: .TableCellSelect TabId, 4, 1
        Case 2: .TableCellSelect TabId, 4, 2
        End Select
        .FieldInsert "<" & GlSer(86, 0) & ">" 'Mandantenbriefkopf Links
        FlIdx = .FieldCurrent
        .FieldType(FlIdx) = txFieldStandard
        .FieldData(FlIdx) = GlSer(86, 1)
        .FieldEditAttr(FlIdx) = &H2 + &H10
        .FieldChangeable = False
        .FieldDeleteable = True
        
        Select Case VoTyp 'Mandantenbriefkopf Links
        Case 1:
            .TableCellSelect TabId, 4, 2
            .FontBold = True
            .FontSize = 8
        Case 2:
            .TableCellSelect TabId, 4, 3
            .FontBold = True
            .FontSize = 8
        End Select
    Else
        Select Case VoTyp 'Mandantenbriefkopf Links
        Case 1:
            .TableCellSelect TabId, 4, 2
            .FontBold = True
            .FontSize = 8
