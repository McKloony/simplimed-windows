Public Sub SPaTx()
On Error GoTo PoErr
'Setzt die Filter für die Textverarbeitung

Dim TmpNa As String
Dim DaNam As String
Dim NeNam As String
Dim FilNa As String
Dim PaStr As String
Dim SuFix As String
Dim Posit As Integer
Dim AnzDa As Integer
Dim AktZa As Integer
Dim AkKey As Integer
Dim DiNam() As String

Set FM = frmMain
Set LiVw4 = FM.lstView4
Set TxCoN = FM.TexCont1
Set LiIts = LiVw4.ListItems

Set clFil = New clsFile

TxCoN.ResetContents
DoEvents

If GlAdr > 0 Then
    LiIts.Clear
    DoEvents
    PaStr = Format$(GlAdr, "000000")
    If clFil.FilVor(GlDox & "TD" & PaStr & "_*.*") = True Then
        AnzDa = clFil.FilLis(GlDox, "TD" & PaStr & "_*.*", DiNam)
        If AnzDa > 0 Then
            For AktZa = 1 To AnzDa
                Posit = 0
                DaNam = DiNam(AktZa)
                If GlBut = RibTab_Tex_Rezept Then
                    If Right$(DaNam, 3) = "txr" Then
                        AkKey = AkKey + 1
                        Posit = InStrRev(DaNam, "_", Len(DaNam), 1)
                        If Posit = 43 Then
                            NeNam = Mid$(DaNam, Posit + 1, Len(DaNam) - (Posit + 4))
                        Else
                            NeNam = "Textdokument"
                        End If
                        TmpNa = clFil.FilReIn(GlDox & DaNam) & Space$(1) & NeNam
                        Set LiItm = LiIts.Add(, "T" & AkKey, TmpNa, IC16_Doc_Norm)
                        LiItm.Tag = DaNam
                        With LiVw4
                            .Sorted = True
                            .SortKey = 0
                            .SortOrder = 1
                        End With
                    End If
                Else
                    If Right$(DaNam, 3) = "txm" Then
                        AkKey = AkKey + 1
                        Posit = InStrRev(DaNam, "_", Len(DaNam), 1)
                        If Posit = 43 Then
                            NeNam = Mid$(DaNam, Posit + 1, Len(DaNam) - (Posit + 4))
                        Else
                            NeNam = "Textdokument"
                        End If
                        TmpNa = clFil.FilReIn(GlDox & DaNam) & Space$(1) & NeNam
                        Set LiItm = LiIts.Add(, "T" & AkKey, TmpNa, IC16_Doc_Norm)
                        LiItm.Tag = DaNam
                        With LiVw4
                            .Sorted = True
                            .SortKey = 0
                            .SortOrder = 1
                        End With
                    End If
                End If
            Next AktZa
        End If
    End If
    If LiIts.Count > 0 Then
         With LiVw4
            .Sorted = True
            .SortKey = 0
            .SortOrder = 1
        End With
        LiIts(1).Selected = True
        
        For Each LiItm In LiIts
            If LiItm.Selected = True Then
                FilNa = GlDox & LiItm.Tag
                Exit For
            End If
        Next LiItm

        Posit = InStrRev(FilNa, ".", Len(FilNa), 1)
        If Posit > 0 Then
            SuFix = Mid$(FilNa, Posit + 1, Len(FilNa) - Posit)
        Else
            SuFix = vbNullString
        End If
        
        GlTxF = FilNa 'Filname für Textcontrol Error
        GlTxU = LCase(SuFix)
        DoEvents
        STxLa
    End If
End If

Set clFil = Nothing

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SPaTx " & Err.Number
Resume Next

End Sub
