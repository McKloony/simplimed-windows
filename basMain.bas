                Case 3: FiNam = GlPfa & "Datenbankdatei[" & DaNum + 1 & "].dbv"
                End Select
            Else
                Select Case GlTyp
                Case 2: FiNam = GlPfa & "Datenbankdatei[1].dbx"
                Case 3: FiNam = GlPfa & "Datenbankdatei[1].dbv"
                End Select
            End If
        Else
            StaNa = DiNam(1)
            Posit = InStr(1, StaNa, "[", 1)
            If Posit > 0 Then
                If IsNumeric(Mid$(StaNa, Posit + 1, 1)) Then
                    DaNum = Mid$(StaNa, Posit + 1, 1)
                    Select Case GlTyp
