        End If
    Case 2:
        If GlTyp < 2 Then
            Select Case GlSuK.SuQua
            Case 1: Krit2 = "((Datum >= '01.01." & GlSuK.SuJah & "') AND (Datum <= '31.03." & GlSuK.SuJah & "'))"
            Case 2: Krit2 = "((Datum >= '01.04." & GlSuK.SuJah & "') AND (Datum <= '30.06." & GlSuK.SuJah & "'))"
