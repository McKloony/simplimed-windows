                    .SetDataProvider DaPro, False
                    Set CaSID = .ScheduleIDs
                    .Name = GlRmu(AktZa, 1)
                    CaSID.Add AktZa
                End With
                CaRes.Add CaRec
            Next AktZa
            If CaSes.Count = 0 Then 'Ist das erforderlich ?
                For AktZa = 1 To UBound(GlRmu)
                    CaSes.AddNewSchedule GlRmu(AktZa, 1)
                    CaSes(AktZa - 1).id = GlRmu(AktZa, 0)
                Next
            End If
        End If
        
    Case RibTab_Ter_Mitarb:

        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
            With CaRec
                Set DaPro = .DataProvider
                Set CaSID = .ScheduleIDs
                Set CaSes = DaPro.Schedules
                If GlTKa = True Then 'Kalendermitarbeiternamen
                    If GlMiT(1, 27) <> vbNullString Then
                        TmNam = GlMiT(1, 27)
                    Else
                        TmNam = GlMiT(1, 1)
                    End If
                Else
                    TmNam = GlMiT(1, 1)
                End If
                .Name = TmNam 'aktive Mitarbeiter + Terminspalte
                CaSID.Add 1
            End With
            CaRes.Add CaRec
            For AktZa = 2 To UBound(GlMiT)
                Set CaRec = New XtremeCalendarControl.CalendarResource
                With CaRec
                    .SetDataProvider DaPro, False
                    Set CaSID = .ScheduleIDs
                    If GlTKa = True Then 'Kalendermitarbeiternamen
                        If GlMiT(AktZa, 27) <> vbNullString Then
                            TmNam = GlMiT(AktZa, 27)
                        Else
                            TmNam = GlMiT(AktZa, 1)
                        End If
                    Else
                        TmNam = GlMiT(AktZa, 1)
                    End If
                    .Name = TmNam
                    CaSID.Add AktZa
                End With
                CaRes.Add CaRec
            Next AktZa
            If CaSes.Count = 0 Then 'Ist das erforderlich ?
                For AktZa = 1 To UBound(GlMiT)
                    CaSes.AddNewSchedule GlMiT(AktZa, 1)
                    CaSes(AktZa - 1).id = GlMiT(AktZa, 0)
                Next
            End If
        Else
            With CaRec
                Set DaPro = .DataProvider
                Set CaSID = .ScheduleIDs
                Set CaSes = DaPro.Schedules
                If GlTKa = True Then 'Kalendermitarbeiternamen
                    If GlMaT(1, 32) <> vbNullString Then
                        TmNam = GlMaT(1, 32)
                    Else
                        TmNam = GlMaT(1, 1)
                    End If
                Else
                    TmNam = GlMaT(1, 1)
                End If
                .Name = TmNam
                CaSID.Add 1
            End With
            CaRes.Add CaRec
            For AktZa = 2 To UBound(GlMaT)
                Set CaRec = New XtremeCalendarControl.CalendarResource
                With CaRec
                    .SetDataProvider DaPro, False
                    Set CaSID = .ScheduleIDs
                    If GlTKa = True Then 'Kalendermitarbeiternamen
                        If GlMaT(AktZa, 32) <> vbNullString Then
                            TmNam = GlMaT(AktZa, 32)
                        Else
                            TmNam = GlMaT(AktZa, 1)
                        End If
                    Else
                        TmNam = GlMaT(AktZa, 1)
                    End If
                    .Name = TmNam
                    CaSID.Add AktZa
                End With
                CaRes.Add CaRec
            Next AktZa
            If CaSes.Count = 0 Then 'Ist das erforderlich ?
                For AktZa = 1 To UBound(GlMaT)
                    CaSes.AddNewSchedule GlMaT(AktZa, 1)
                    CaSes(AktZa - 1).id = GlMaT(AktZa, 0)
                Next
            End If
        End If
        
    End Select
    DoEvents
    
    With CaCol
        Select Case GlCal 'Kalenderanzeige
        Case 1:
            .UseMultiColumnWeekMode = True
            .Options.WorkWeekMask = xtpCalendarDayAllWeek
            .ViewType = xtpCalendarDayView
        Case 2:
            .UseMultiColumnWeekMode = True
            .Options.WorkWeekMask = xtpCalendarDayMo_Fr
            .ViewType = xtpCalendarWorkWeekView
        Case 3:
            .UseMultiColumnWeekMode = True
            .Options.WorkWeekMask = xtpCalendarDayAllWeek
            .ViewType = xtpCalendarFullWeekView
        Case 4:
            .UseMultiColumnWeekMode = False
            .ViewType = xtpCalendarWeekView
        Case 5:
            .UseMultiColumnWeekMode = False
            .ViewType = xtpCalendarMonthView
        End Select
    End With
    
Else

    With CaRec
        Set CaSID = .ScheduleIDs
        .Name = vbNullString
        CaSID.removeAll
    End With
    CaRes.Add CaRec
    
End If

With CaCol
    .SetMultipleResources CaRes
    .Populate
    .RedrawControl
End With

Set CaRes = Nothing
Set CaRec = Nothing
Set CaCol = Nothing

Exit Sub

OpErr:
If GlDbg = True Then SErLog Err.Description & " STeRa " & Err.Number
Resume Next

