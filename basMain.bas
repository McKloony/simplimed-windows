Public Function SRzFi(ByVal TmTxt As String, Optional ByVal NoCtl As Boolean) As String
On Error GoTo ReErr

Dim Lange As Long
Dim AktPo As Long
Dim TxStr As String
Dim TmStr As String
Dim TeTtr As String

TxStr = Replace(TmTxt, Chr$(34), vbNullString, 1, , 1)
TxStr = Replace(TxStr, ";", vbNullString, 1, , 1)
TxStr = Replace(TxStr, "}", vbNullString, 1, , 1)
TxStr = Replace(TxStr, "{", vbNullString, 1, , 1)

If NoCtl = True Then
    SRzFi = LTrim$(TmTxt)
Else
    TmStr = TxStr
    Lange = Len(TxStr)
    
    For AktPo = 1 To Lange
        TeTtr = Mid$(TmStr, AktPo, 1)
        If Len(TeTtr) > 0 Then
            If Asc(TeTtr) < 32 Or Asc(TeTtr) > 128 Then
                If ((Lange - AktPo)) > 0 Then
                    TmStr = Mid$(TmStr, 1, AktPo - 1) & Mid$(TmStr, AktPo + 1, (Lange - AktPo))
                End If
            End If
        End If
    Next AktPo
    
    TeTtr = Right$(TmStr, 1)
    If Len(TeTtr) > 0 Then
        If Asc(TeTtr) < 32 Or Asc(TeTtr) > 128 Then
            TmStr = Left$(TmStr, Lange - 1)
        End If
    End If

    If NoCtl = False Then
        TxStr = Replace(TmStr, vbCrLf, vbNullString, 1, , 1)
        TxStr = Replace(TxStr, vbCrLf & vbCrLf, vbNullString, 1, , 1)
        TxStr = Replace(TxStr, Chr$(13) & Chr$(10) & Chr$(13) & Chr$(10), vbNullString, 1, , 1)
    End If
    
    If Len(TxStr) > 1 Then
        SRzFi = LTrim$(TxStr)
    End If
End If

Exit Function

ReErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SRzFi " & Err.Number
Resume Next

End Function
