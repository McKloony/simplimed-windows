            Set RpSel = RpCoK.SelectedRows
            Set RpCls = RpCoK.Columns
            Set RpRcs = RpCoK.Records
Case RibTab_Abrechnung:
            Set RpSel = RpCo6.SelectedRows
            Set RpCls = RpCo6.Columns
            Set RpRcs = RpCo6.Records
End Select

GlSav = True

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        Set RpCol = RpCls.Find(Kra_Ziffer)
        SuStr = RpRow.Record(RpCol.ItemIndex).Value
        Set RpCol = RpCls.Find(Kra_IDD)
        DiIdx = RpRow.Record(RpCol.ItemIndex).Value
        Set RpCol = RpCls.Find(Kra_ID4)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            IdxNr = RpRow.Record(RpCol.ItemIndex).Value
        Else
            IdxNr = 0
        End If
        Set RpCol = RpCls.Find(Kra_KrTyp)
        KrTyp = RpRow.Record(RpCol.ItemIndex).Value
        If DiIdx > 0 Then
            If IdxNr > 0 Then
                If SuStr <> vbNullString Then
                    Dia_Zu KrTyp, DiIdx, SuStr
                End If
            End If
        End If
    End If
End If

If SuStr <> vbNullString Then
    For Each RpRec In RpRcs
        If SuStr = RpRec.Item(Kra_Ziffer).Value Then
            RpRec.Item(Kra_IDD).Value = DiIdx
            RpRec.Item(Kra_IDD).Tag = "@IDD" 'Tag geändert
