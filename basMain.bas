Public Sub STxLa(Optional ByVal SeNam As String)
On Error GoTo SuErr
'Zeigt das Textdokument an

Dim FiNam As String
Dim DaExt As String
Dim DaNam As String
Dim Posit As Integer
Dim CmBrs As XtremeCommandBars.CommandBars

Set FM = frmMain
Set CmBrs = FM.comBar01
Set LiVw4 = FM.lstView4
Set TxCoN = FM.TexCont1
Set CoDia = FM.comDialo
Set CmAcs = CmBrs.Actions
Set LiIts = LiVw4.ListItems

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

If LiIts.Count > 0 Then
    CmAcs(Tex_KopDat).Enabled = True
    CmAcs(Tex_FusZal).Enabled = True
    
    If SeNam <> vbNullString Then
        FiNam = GlDox & SeNam
    Else
        For Each LiItm In LiIts
            If LiItm.Selected = True Then
                FiNam = GlDox & LiItm.Tag
                Exit For
            End If
        Next LiItm
    End If

    Posit = InStrRev(FiNam, ".", Len(FiNam), 1)
    If Posit > 0 Then
        DaExt = LCase(Mid$(FiNam, Posit + 1, Len(FiNam) - Posit))
    Else
        DaExt = vbNullString
    End If

    With clFil
        .FilPfa FiNam
        GlTDa = .DaNam 'Textverarbeitung Dateiname
    End With

    GlTxF = FiNam 'Filname für Textcontrol Error
    GlTxU = LCase(DaExt)
    
    Select Case LCase(DaExt)
    Case "txm":
        With TxCoN
            .ResetContents
            .Load FiNam, , 3
        End With
    Case "txn":
        With TxCoN
            .ResetContents
            .Load FiNam, , 3
        End With
    Case "txr":
        With TxCoN
            .ResetContents
            .Load FiNam, , 3
        End With
    Case "htm":
        With TxCoN
            .ResetContents
            .Load FiNam, , 4
        End With
    Case "rtf":
        With TxCoN
            .ResetContents
            .Load FiNam, , 5
        End With
    Case "css":
        With TxCoN
            .ResetContents
            .Load FiNam, , 11
        End With
    Case "doc":
        With TxCoN
            .ResetContents
            .Load FiNam, , 9
        End With
    Case "docx":
        With TxCoN
            .ResetContents
            .Load FiNam, , 13
        End With
    Case Else:
        With TxCoN
            .ResetContents
           .Text = vbNullString
        End With
    End Select
End If

GlTSV = False 'Speichern Textverarbeitung
GlTxN = False
GlTxS = False

Set CmAcs = Nothing
Set CmBrs = Nothing
Set CoDia = Nothing

Set clFil = Nothing

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "STxLa " & Err.Number
Resume Next

End Sub
Public Sub STxMa(ByVal EmAnl As Boolean, Optional ByVal EmVer As Boolean = False, Optional ByVal SeUpl As Integer = 0)
On Error GoTo PoErr
'Mail als Dokument

Dim ManNr As Long
Dim MitNr As Long
Dim ExVer As String
Dim EmBet As String
Dim EmTex As String
Dim EmAdr As String
Dim EmBCC As String
Dim EmaNr As String
Dim DaNam As String
Dim NeuNa As String
Dim SuFix As String
Dim Posit As Integer
Dim Lange As Integer
Dim RetWe As Boolean
Dim DoSav As Boolean
Dim TmDat() As Byte

If GlTSV = True Then 'Speichern Textverarbeitung
    RetWe = STxSa()
    DoEvents
End If

Set FM = frmMain
Set TxCoN = FM.TexCont1

Screen.MousePointer = vbHourglass
DoEvents

MitNr = GlMiA(GlSmI, 2) 'Standardmitarbeiter

If EmAnl = True Then
    If SeUpl < 2 Then
        If GlTDa <> vbNullString Then
            Lange = Len(GlTDa)
            DaNam = Left$(GlTDa, Lange - 4) & ".pdf"
        Else
            DaNam = Left$(CreateID("D"), 10) & ".pdf"
        End If
    Else
        If GlTDa <> vbNullString Then
            Lange = Len(GlTDa)
            If Left$(DaNam, 1) = "_" Then
                DaNam = Mid$(DaNam, 2, Len(DaNam) - 1)
            End If
            DaNam = Left$(GlTDa, Lange - 4) & ".pdf"
        Else
            DoEvents
            Screen.MousePointer = vbNormal
            Exit Sub
        End If
    End If
    If DaNam <> vbNullString Then
        Select Case SeUpl
        Case 0: 'Dokument als Emailanlage
            If EmVer = True Then
                Select Case GlEmA 'Emailafdresse Rechnungsversand
                Case 0: SExFo 9, 1, 1, DaNam
                Case 1: SExFo 9, 1, 2, DaNam
                End Select
            Else 'Dokument Exportieren
                SExFo 9, 1, 0, DaNam
            End If
        Case 1: 'Dokument Downloadlink
                SExFo 9, 1, 1, DaNam, , , SeUpl
        Case 2: 'Dokument Digitalunterschrift
            If STxPl(False) = True Then
                SExFo 9, 1, 1, DaNam, , , SeUpl
            End If
        Case 3: 'Dokument Neuaufnahmeformular
            If STxPl(True) = True Then
                SExFo 9, 1, 1, DaNam, , , SeUpl
            End If
        End Select
    End If
Else 'Dokument als Nachricht
    If GlTDa <> vbNullString Then
        Lange = Len(GlTDa)
        DaNam = Left$(GlTDa, Lange - 3) & "pdf"
    Else
        DaNam = "Dokument"
    End If
    If EmVer = True Then
        S_AdDe GlAdr 'Adressendetails
        With GlADt
            EmAdr = .AdTe5
            EmTex = .AdBrf
            ManNr = .AdMan
        End With
        
        With GlTxV
            .TxStr = GlEmT(9, 3)
            .DaNam = DaNam
            .MitNr = MitNr
            .ManNr = ManNr
            .PatNr = GlAdr
        End With
        EmBet = SEmTx()

        TmDat = TxCoN.SaveToMemory(3, False)
        SMaNe GlAdr, EmAdr, EmBCC, EmTex, EmBet
        DoEvents
        Set FM = frmMaiView
        Set TxCoN = FM.TexCont3
        TxCoN.LoadFromMemory TmDat, 3, False 'Laden des Dokumentes
    Else
        TxCoN.PrintDialog DaNam
    End If
End If

DoEvents
Screen.MousePointer = vbNormal

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "STxMa " & Err.Number
Resume Next

End Sub
Public Sub STxMe()
