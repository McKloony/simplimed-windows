Public Function SEmAd(ByVal EmpAd As String) As Boolean
On Error GoTo DaErr
'Check valid Emailadress

Dim ZeStr As String
Dim TmStr As String
Dim AktZa As Integer
Dim ZeGef As Boolean

ZeStr = "!#$%^&*()=+{}[]|\;:'/?>,< "

If EmpAd = vbNullString Then
    SEmAd = False
    Exit Function
End If

SEmAd = True

If InStr(1, EmpAd, Chr$(34), 1) > 0 Then
    SPopu "Falsche Emailadresse", "Die Emailadresse " & EmpAd & " enthält ein Anführungszeichen", IC48_Warning
    SEmAd = False
ElseIf InStr(1, EmpAd, "..", 1) > 0 Then
    SPopu "Falsche Emailadresse", "Die Emailadresse " & EmpAd & " enthält zu viele Punkte", IC48_Warning
    SEmAd = False
End If

If Len(EmpAd) > Len(ZeStr) Then
    For AktZa = 1 To Len(ZeStr)
        If InStr(EmpAd, Mid(ZeStr, AktZa, 1)) > 0 Then
            SPopu "Falsche Emailadresse", "Die Emailadresse " & EmpAd & " enthält Sonderzeichen", IC48_Warning
            SEmAd = False
        End If
    Next
Else
    For AktZa = 1 To Len(EmpAd)
        If InStr(ZeStr, Mid(EmpAd, AktZa, 1)) > 0 Then
            SPopu "Falsche Emailadresse", "Die Emailadresse " & EmpAd & " enthält Sonderzeichen", IC48_Warning
            SEmAd = False
        End If
    Next
End If

If InStr(1, EmpAd, "@") > 1 Then
    ZeGef = Len(Left(EmpAd, InStr(1, EmpAd, "@") - 1)) > 0
Else
    ZeGef = False
End If

If ZeGef = False Then
    SPopu "Falsche Emailadresse", "Die Emailadresse " & EmpAd & " hat das falsche Format", IC48_Warning
    SEmAd = False
End If

TmStr = Right(EmpAd, Len(EmpAd) - InStr(1, EmpAd, "@"))
ZeGef = Not InStr(1, TmStr, "@") > 0

If ZeGef = False Then
    SPopu "Falsche Emailadresse", "Die Emailadresse " & EmpAd & " hat das falsche Format", IC48_Warning
    SEmAd = False
End If

TmStr = Right(EmpAd, Len(EmpAd) - InStr(1, EmpAd, "."))
ZeGef = Len(TmStr) > 0 And InStr(1, EmpAd, ".") < Len(EmpAd)

If ZeGef = False Then
    SPopu "Falsche Emailadresse", "Die Emailadresse " & EmpAd & " hat das falsche Format", IC48_Warning
    SEmAd = False
End If

TmStr = Left$(EmpAd, Len(EmpAd) - Len(TmStr) - 1)

Do Until InStr(1, TmStr, ".") <= 1
    If Len(TmStr) >= InStr(1, TmStr, ".") Then
        TmStr = Left(TmStr, Len(TmStr) - (InStr(1, TmStr, ".") - 1))
    Else
        ZeGef = False
        SPopu "Falsche Emailadresse", "Die Emailadresse " & EmpAd & " hat das falsche Format", IC48_Warning
    End If
Loop

If TmStr = "." Or Len(TmStr) = 0 Then
    SPopu "Falsche Emailadresse", "Die Emailadresse " & EmpAd & " hat das falsche Format", IC48_Warning
End If

Exit Function

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SEmAd " & Err.Number
Resume Next

End Function
Public Sub SEmNe(Optional ByVal DocMa As Boolean = False)
On Error GoTo DaErr
'Sendet eine Email

Dim AktZa As Long
Dim GesZa As Long
Dim PatNr As Long
Dim EmAdr As String
Dim EmBrf As String
Dim EmTex As String
Dim AbEmr As String
Dim FiNam As String
Dim DaNam As String
Dim SigNa As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim TmGui As String
Dim EmVer As Boolean
Dim Frage As Integer
