Public Sub SGDT()
On Error GoTo InErr
'Startet die WEGAMED Schnittstelle mit Parametern

Dim mHwnd As Long
Dim PfaNa As String
Dim TiStr As String
Dim Mld1, Tit1 As String

S_AdBDT True
DoEvents

Set FM = frmMain

Set clFil = New clsFile
Set clAnw = New clsAnwend
Set clFen = New clsFenster
clFen.hwnd = FM.hwnd
clFil.hwnd = FM.hwnd

TiStr = IniGetVal("System", "GDTApp")
PfaNa = IniGetVal("System", "GDTPrg")

If clFil.FilVor(PfaNa) = True Then
    clAnw.AnNam = TiStr
    If clAnw.AnwSu = 0 Then
        WindowStart PfaNa, vbNormalFocus, False, True
        DoEvents
    End If
    With clFen
        mHwnd = .FenFin(TiStr)
        If mHwnd > 0 Then
            .hwnd = mHwnd
            .FenVor
        End If
    End With
Else
    MsgBox PfaNa & " kann nicht gefunden werden", vbInformation, "Programm nicht gefunden"
End If

Set clFil = Nothing
Set clAnw = Nothing
Set clFen = Nothing

Exit Sub

InErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SGDT " & Err.Number
Resume Next

End Sub
