Public Sub STePr()
On Error GoTo OpErr
'Druckt den Kalender

Dim StaZe As Date
Dim EndZe As Date
Dim LiId1 As Long
Dim LiId2 As Long
Dim IdxNr As Long
Dim FuStr As String
Dim AnwNa As String
Dim AktZa As Integer
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmCo1 As XtremeCommandBars.CommandBarComboBox
Dim CmCo2 As XtremeCommandBars.CommandBarComboBox
Dim CaCol As XtremeCalendarControl.CalendarControl

Set FM = frmMain
Set CmBrs = FM.comBar01
Set CaCol = FM.calCont1

Set CmCo1 = CmBrs.FindControl(CmCo1, SY_TE_Termin_FiltTyp, , True)
Set CmCo2 = CmBrs.FindControl(CmCo2, SY_TE_Termin_FiltIdx, , True)

LiId1 = CmCo1.ListIndex

Select Case LiId1
Case 1:
        If GlBut = RibTab_Ter_Kalend Then
            FuStr = "Alle Mandanten / Alle Räume)"
        Else
            FuStr = vbNullString
        End If
Case 2: LiId2 = CmCo2.ItemData(CmCo2.ListIndex)
        For AktZa = 1 To UBound(GlRmu)
            If LiId2 = GlRmu(AktZa, 2) Then
                FuStr = "Raum: " & GlRmu(AktZa, 1)
                Exit For
            End If
        Next AktZa
Case 3: LiId2 = CmCo2.ItemData(CmCo2.ListIndex)
        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
            For AktZa = 1 To UBound(GlMiT) 'Aktive Mitarbeiter + Terminspalte
                If LiId2 = GlMiT(AktZa, 2) Then
                    FuStr = "Mitarbeiter: " & GlMiT(AktZa, 1)
                    Exit For
                End If
            Next AktZa
        Else
            For AktZa = 1 To UBound(GlMaT)
                If LiId2 = GlMaT(AktZa, 2) Then
                    FuStr = "Mandant: " & GlMaT(AktZa, 1)
                    Exit For
                End If
            Next AktZa
        End If
End Select

If GlMiV = True Then
    AnwNa = SUmw(GlMiA(GlSmI, 1), True, True, True, True)
Else
    AnwNa = IniGetVal("Adress", "AVoNa") & Chr$(32) & IniGetVal("Adress", "AName")
End If

StaZe = Format$(IniGetVal("TerSys", "StaPri"), "hh:mm:ss")
EndZe = Format$(IniGetVal("TerSys", "EndPri"), "hh:mm:ss")

With CaCol.PrintOptions
    .Header.TextLeft = FuStr
    .Footer.TextLeft = "Datum: " & DateValue(Now)
    .Footer.TextRight = AnwNa
    .PrintDateHeader = False
    .PrintFrom = StaZe
    .PrintTo = EndZe
    .PrintFromToExactly = False
    .BlackWhitePrinting = False
    .MarginTop = 0
    .MarginBottom = 0
    .MarginLeft = 0
    .MarginRight = 0
    Select Case GlBut
    Case RibTab_Ter_Kalend:
    Select Case GlCal 'Kalenderanzeige
        Case 1: .Landscape = False
        Case 2: .Landscape = True
        Case 3: .Landscape = True
        Case 4: .Landscape = True
        End Select
    Case RibTab_Ter_Raeume: .Landscape = True
    Case RibTab_Ter_Mitarb: .Landscape = True
    End Select
End With

'CaCol.PrintPreview True

PrtMain 2

Set CaCol = Nothing

Exit Sub

OpErr:
If GlDbg = True Then MsgBox Err.Description, 48, "STePr " & Err.Number
Resume Next

End Sub

