Public Function SKaW1(ByVal Datu1 As Date) As String
On Error Resume Next
' *** Ermittelt die Kalenderwoche mit dem zur Kalenderwoche gehörigem Jahr
' *** SKaWo wird in der Form YYYYWW zurückgegeben ***

' DatePart - in der uns üblichen Arbeitsweise
' DatePart("ww", Datum, vbMonday, vbFirstFourDays) -
' wirft für folgende Daten folgende Werte aus
' So, 28.12.2003 oder 30.12.2007 -> KW52 -> richtig
' Mo, 29.12.2003 oder 31.12.2007 -> KW53 -> QUATSCH
' Di, 30.12.2003 oder 01.01.2008 -> KW01 -> richtig
' deshalb bestimme ich vorsichtshalber die Kalenderwoche
' des Dienstags ?!?!?!?!?!

If Weekday(Datu1) = vbMonday Then Datu1 = Datu1 + 1

SKaW1 = DatePart("ww", Datu1, vbMonday, vbFirstFourDays)

' Anpassung des Jahres und Ergänzung der Null
' (in den Kalenderwochen 01, 52 und 53 kann das Jahr des Datums
' anders sein als das Jahr der zugehörigen Kalenderwoche.
' So liegt der 31.12.2001 in KW01/2002)

If SKaW1 < 10 Then
    SKaW1 = Year(Datu1 + 6) & "0" & SKaW1
Else
    SKaW1 = Year(Datu1 - 6) & SKaW1
End If
  
End Function
Public Function SKaW2(ByVal AktWo As Integer, Optional ByVal WoTag As VBA.VbDayOfWeek = vbMonday, Optional ByVal AkJah As Integer = -1) As Date
On Error Resume Next

Dim TmpWo As Integer
Dim AkSta As Variant
Dim AkTag As Integer

' Kein Jahr angeben? Dann aktuelles Jahr verwenden!
If AkJah = -1 Then AkJah = Year(Now)

' aktuelle Woche im Jahr AkJah ermitteln
AkSta = DateSerial(AkJah, Month(Now), Day(Now))
TmpWo = Val(Format$(AkSta, "ww", vbMonday))

' Datum der gewünschten Woche ermitteln
AkSta = DateAdd("ww", AktWo - TmpWo, AkSta)

' Wochenanfang ermitteln
AkTag = Weekday(AkSta, vbMonday)

' Datum des gewünschten Wochentags ermitteln
If WoTag = vbSunday Then
    SKaW2 = DateAdd("d", -AkTag + 7, AkSta)
Else
    SKaW2 = DateAdd("d", -AkTag + WoTag - 1, AkSta)
End If

End Function
