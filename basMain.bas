Public Sub SNfSe()
On Error GoTo AdErr
'Sendet das Neuaufnahmeformular

Dim ManNr As Long
Dim MitNr As Long
Dim KmStr As String
Dim EmAdr As String
Dim EmBCC As String
Dim EmTex As String
Dim DaNam As String
Dim EmBet As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim Posit As Integer

MitNr = GlMiA(GlSmI, 2) 'Standardmitarbeiter

KmStr = GlNaf

If GlEKV = False Then 'Emailkonten vorhanden
    TeTit = "E-Mail-Versand"
    TeMai = "Es ist kein E-Mail-Konto vorhanden"
    TeInh = "Um eine E-Mail-Bestätigung für ein ausgefüllten Aufnahmeformular zu erhalten, ist es notwendig mind. ein E-Mail-Konto hinzuzufügen."
    TeFus = "Um ein E-Mail-Konto hinzuzufügen, wechseln Sie in das Modul: Textverarbeitung und dann oben auf Emails. Dort klicken Sie auf die Schaltfläche Emailkonten."
    SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, frmMain.hwnd
Else
    TeTit = "Noch kein Neuaufnahmeformular vorhanden"
    TeMai = "Das Neuaufnahmeformular wurde noch nicht publiziert, möchten Sie es nun publizieren?"
    TeInh = "Bevor Sie diesem Patienten den Link zum Neuaufnahmeformular zusenden können, ist es erforderlich, dieses erst zu veröffentlichen."
    TeFus = "Das Neuaufnahmeformular wird mit seinen Eigenschaften für den Patienten verfügbar gemacht. In diesem Zusammenhang ist es auch möglich, dem Patienten Dokumente zur digitalen Unterschritt bereitzustellen."
    
    S_AdDe GlAdr 'Adressendetails
    With GlADt
        EmAdr = .AdTe5
        EmTex = .AdBrf
        ManNr = .AdMan
    End With
    
    With GlTxV
        .TxStr = GlEmT(9, 3)
        .DaNam = DaNam
        .MitNr = MitNr
        .ManNr = ManNr
        .PatNr = GlAdr
    End With
    EmBet = SEmTx()

    EmBet = SEmTx()
    With GlTxV
        .TxStr = GlEmT(14, 1)
        .Datum = Date
        .MitNr = MitNr
        .ManNr = ManNr
        .PatNr = GlAdr
        .DoLnk = GlNaf
        .DoLan = GlVrw
        .DoNam = DaNam
    End With
    EmTex = SEmTx()

    If GlNaf <> vbNullString Then
        Posit = InStr(1, GlNaf, "terminland", 1)
        If Posit > 0 Then
            S_SeSe 83, vbNullString
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, False, frmMain.hwnd
            If GlMes = 33565 Then
                FPubl True
            End If
        Else
            SMaNe GlAdr, EmAdr, EmBCC, EmTex, EmBet
        End If
    Else
        SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, False, frmMain.hwnd
        If GlMes = 33565 Then
            FPubl True
        End If
    End If
End If

Exit Sub

AdErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SNfSe " & Err.Number
Resume Next

End Sub


