Private Sub SKrTv(ByVal DaNam As String, ByVal RibTa As Long, ByVal ShCut As Long, ByRef Items As Object, Optional ByVal CmpTag As Boolean = True)
On Error GoTo PoErr

Dim LiItm As Object
Dim CmpSt As String

GlBu6 = RibTa
STaSe ShCut, RibTa
DoEvents

If Items.Count > 0 Then
    For Each LiItm In Items
        If CmpTag = True Then
            CmpSt = LiItm.Tag
        Else
            CmpSt = LiItm.Text
        End If
        If LCase(CmpSt) = LCase(DaNam) Then
            LiItm.Selected = True
            STxLa
            Exit For
        End If
    Next LiItm
End If

Exit Sub
PoErr:
    If GlLog = True Then SLogi "SKrTv Err: " & Err.Description & " #" & Err.Number
End Sub


