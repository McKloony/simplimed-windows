Public Sub SStMa()
On Error GoTo LiErr
'Überprüft, ob der Standardmandant Aktiv oder Passiv ist

Dim AktZa As Integer

If GlMaV = True Then 'Mandanten vorhanen
    If CBool(GlMaA(GlSMa, 5)) = True Then 'Passive = True
        For AktZa = 1 To UBound(GlMan)
            If CBool(GlMaA(AktZa, 5)) = False Then 'Passive = False
                GlSMa = AktZa
                Exit For
            End If
        Next AktZa
    End If
End If

Exit Sub

LiErr:
If GlDbg = True Then SErLog Err.Description & " SStMa " & Err.Number
Resume Next

End Sub
