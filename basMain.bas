Set CaRec = CaCol.MultipleResources(0)

If SetRe = True Then
    CaCol.DataProvider.RemoveAllEvents
    DoEvents
    
    Select Case GlBut
    Case RibTab_Ter_Raeume:
    
        If GlRmu(0, 4) <> vbNullString Then
            If CLng(GlRmu(0, 4)) < 1 Then
                GlTRa = False
            End If
        Else
            GlTRa = False
        End If
        If GlTRa = True Then 'Mitarbeiter / Mandanten in Raumbelegung aktivieren
            If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                IdxNr = GlMiA(GlSmI, 2)
            Else
                IdxNr = GlMiA(GlSmI, 7)
            End If
        End If
        If GlTRa = True Then 'Mitarbeiter / Mandanten in Raumbelegung aktivieren
            For AkRmu = 1 To UBound(GlRmu)
                If GlRmu(AkRmu, 4) = IdxNr Then
                    With CaRec
                        Set DaPro = .DataProvider
                        Set CaSID = .ScheduleIDs
                        Set CaSes = DaPro.Schedules
                        .Name = GlRmu(AkRmu, 1)
                        CaSID.Add 1
                    End With
                    Exit For
                End If
            Next AkRmu
            CaRes.Add CaRec
            For AktZa = (AkRmu + 1) To UBound(GlRmu)
                If GlRmu(AktZa, 4) = IdxNr Then
                    Set CaRec = New XtremeCalendarControl.CalendarResource
                    With CaRec
                        .SetDataProvider DaPro, False
                        Set CaSID = .ScheduleIDs
                        .Name = GlRmu(AktZa, 1)
                        CaSID.Add AktZa
                    End With
                    CaRes.Add CaRec
                End If
            Next AktZa
            If CaSes.Count = 0 Then 'Ist das erforderlich ?
                For AktZa = 1 To UBound(GlRmu)
                    CaSes.AddNewSchedule GlRmu(AktZa, 1)
                    CaSes(AktZa - 1).id = GlRmu(AktZa, 0)
                Next
            End If
        Else
            With CaRec
                Set DaPro = .DataProvider
                Set CaSID = .ScheduleIDs
                Set CaSes = DaPro.Schedules
                .Name = GlRmu(1, 1)
                CaSID.Add 1
            End With
            CaRes.Add CaRec
            For AktZa = 2 To UBound(GlRmu)
                Set CaRec = New XtremeCalendarControl.CalendarResource
