    SMeFr GlMeT, GlMeM, GlMeI, GlMeF, False, 1, True, FM.hwnd
End If

If GlTyp < 2 Then
    Select Case GlSoK 'Sortierung Krankenmblatt
    Case 2:
        Select Case GlUm2
        Case 1: SQL1 = "SELECT * FROM dbo.qryPrSimKr5 WHERE ((PatNr=" & GlAdr & ")) AND " & Krit2 & " ORDER BY Datum DESC, Druckdatum DESC" 'Datum absteigend
        Case 2: SQL1 = "SELECT * FROM dbo.qryPrSimKr5 WHERE ((PatNr=" & GlAdr & ")) AND " & Krit2 & " AND ((Typ > 9)) ORDER BY Datum DESC, Druckdatum DESC" 'Datum absteigend
        Case Else: SQL1 = "SELECT * FROM dbo.qryPrSimKr5 WHERE ((PatNr=" & GlAdr & ")) AND " & Krit1 & " AND " & Krit2 & " ORDER BY Datum DESC, Druckdatum DESC;" 'Datum absteigend
        End Select
    Case 1:
        Select Case GlUm2
        Case 1: SQL1 = "SELECT * FROM dbo.qryPrSimKr5 WHERE ((PatNr=" & GlAdr & ")) AND " & Krit2 & " ORDER BY Datum, Druckdatum" 'Datum aufsteigend
        Case 2: SQL1 = "SELECT * FROM dbo.qryPrSimKr5 WHERE ((PatNr=" & GlAdr & ")) AND " & Krit2 & " AND ((Typ > 9)) ORDER BY Datum, Druckdatum" 'Datum aufsteigend
        Case Else: SQL1 = "SELECT * FROM dbo.qryPrSimKr5 WHERE ((PatNr=" & GlAdr & ")) AND " & Krit1 & " AND " & Krit2 & " ORDER BY Datum, Druckdatum" 'Datum aufsteigend
        End Select
    End Select
Else
    Select Case GlSoK
    Case 2:
        Select Case GlUm2
        Case 1: SQL1 = "SELECT * FROM qryPrSimKr5 WHERE (([PatNr]=" & GlAdr & ")) AND " & Krit2 & " ORDER BY [Datum] DESC, [Druckdatum] DESC;" 'Datum absteigend
        Case 2: SQL1 = "SELECT * FROM qryPrSimKr5 WHERE (([PatNr]=" & GlAdr & ")) AND " & Krit2 & " AND (([Typ] > 9)) ORDER BY [Datum] DESC, [Druckdatum] DESC;" 'Datum absteigend
        Case Else: SQL1 = "SELECT * FROM qryPrSimKr5 WHERE (([PatNr]=" & GlAdr & ")) AND " & Krit1 & " AND " & Krit2 & " ORDER BY [Datum], [Druckdatum] DESC;" 'Datum absteigend
        End Select
    Case 1:
        Select Case GlUm2
        Case 1: SQL1 = "SELECT * FROM qryPrSimKr5 WHERE (([PatNr]=" & GlAdr & ")) AND " & Krit2 & " ORDER BY [Datum], [Druckdatum];" 'Datum aufsteigend
        Case 2: SQL1 = "SELECT * FROM qryPrSimKr5 WHERE (([PatNr]=" & GlAdr & ")) AND " & Krit2 & " AND (([Typ] > 9)) ORDER BY [Datum], [Druckdatum];" 'Datum aufsteigend
        Case Else: SQL1 = "SELECT * FROM qryPrSimKr5 WHERE (([PatNr]=" & GlAdr & ")) AND " & Krit1 & " AND " & Krit2 & " ORDER BY [Datum], [Druckdatum];" 'Datum aufsteigend
        End Select
    End Select
End If

If EmVer > 0 Then
    Select Case EmVer
    Case 1: EmAdr = S_AdIdx(GlAdr, "Telefon5")
    Case 2: EmAdr = S_AdIdx(ManNr, "Telefon5")
    End Select
    If EmAdr = vbNullString Then
        Select Case EmVer
        Case 1: EmAdr = S_AdIdx(GlAdr, "Telefon6")
        Case 2: EmAdr = S_AdIdx(ManNr, "Telefon6")
        End Select
    End If
    EmTex = S_AdIdx(GlAdr, "Briefanrede") & vbCrLf & vbCrLf
    For AktPo = 1 To UBound(GlThe)
        If ManNr = GlThe(AktPo, 0) Then
            With GlTxV
                .TxStr = GlEmT(9, 3)
                .Datum = Date
                .MitNr = MitNr
                .ManNr = ManNr
                .PatNr = GlAdr
            End With
            EmBet = SEmTx()
            Exit For
        End If
    Next AktPo
    If UBound(GlEmT) > 9 Then
        EmTex = EmTex & GlEmT(10, 1)
    Else
        EmTex = EmTex & GlEmT(9, 1)
    End If
End If

If Formu = True Then
    ReDim Preserve GloDr(1)
