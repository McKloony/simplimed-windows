Public Sub SERech(ByVal FiNam As String, ByVal XrNam As String)
On Error GoTo DaErr

Dim PaStr As String
Dim PrNam As String
Dim XFina As String
Dim DaNam As String
Dim DaPfa As String

Set FM = frmMain

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

PrNam = App.Path & "\sminvoice.exe"

If clFil.FilVor(PrNam) = False Then
    PrNam = clFil.FilVer(22) & "\SimpliMed\sminvoice.exe"
    If clFil.FilVor(PrNam) = False Then
        SPopu "Programmdatei nicht gefunden!", "Eine zur Ausführung benötigte Datei konnte nicht gefunden werden.", IC48_Forbidden
        Exit Sub
    End If
End If

If clFil.FilVor(FiNam) = True Then
    If clFil.FilVor(XrNam) = True Then
        With clFil
            .FilPfa FiNam
            DaPfa = .DaPfa & "\"
            DaNam = .DaNam
        End With
        XFina = DaPfa & "X" & DaNam
        PaStr = "create" & Space$(1) & Chr$(34) & FiNam & Chr$(34) & Space$(1) & Chr$(34) & XrNam & Chr$(34)
        WindowStart PrNam & Space$(1) & PaStr, vbNormalFocus, True, True
        DoEvents
        If GlLog = False Then 'General Logging
            With clFil
                .DaLoe = XrNam & vbNullChar
                .FilLoe
                .DaLoe = FiNam & vbNullChar
                .FilLoe
                .DaLoe = XFina & vbNullChar
                .FilLoe
            End With
        Else
            Clipboard.Clear
            Clipboard.SetText PrNam & Space$(1) & PaStr
        End If
    End If
End If

Set clFil = Nothing

Exit Sub

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SERech " & Err.Number
Resume Next

End Sub

Public Sub SErLog(ByVal ErStr As String, Optional ByVal OrgSt As Boolean = False)
On Error Resume Next

Dim FiNam As String
Dim nUnit As Integer

FiNam = GlEig & "Praxisdaten\" & GlPrg & "_Logfile.log"

nUnit = FreeFile

Open FiNam For Append As nUnit

If OrgSt = True Then
    Print #nUnit, ErStr
Else
    Print #nUnit, Now() & Chr$(32) & ErStr
End If

Close nUnit

End Sub
