Public Sub SToGr()
On Error GoTo OpErr
'Gruppiert die Listenansicht

Dim TerBe As Single
Dim SerBe As Single
Dim BezBe As Single
Dim GrCap As String
Dim GrAnz As Integer
Dim AktZa As Integer
Dim GrTer() As Double
Dim GrSer() As Double
Dim GrBez() As Double

Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set RpCo1 = FM.repCont1

With RpCo1
    .SortOrder.DeleteAll
    .GroupsOrder.DeleteAll
    If GlKnZ > 0 Then
        Select Case GlKnZ
        Case 1:
            .SortOrder.Add .Columns(Ter_VonDat)
            .GroupsOrder.Add .Columns(Ter_VonDat)
        Case 2:
            .SortOrder.Add .Columns(Ter_Monat)
            .GroupsOrder.Add .Columns(Ter_Monat)
        Case 3:
            .SortOrder.Add .Columns(Ter_Patient)
            .GroupsOrder.Add .Columns(Ter_Patient)
        Case 4:
            .SortOrder.Add .Columns(Ter_IDP)
            .GroupsOrder.Add .Columns(Ter_IDP)
        Case 5:
            .SortOrder.Add .Columns(Ter_Fallig1)
            .GroupsOrder.Add .Columns(Ter_Fallig1)
        End Select
        .GroupsOrder(0).SortAscending = True
    End If
End With
RpCo1.Populate

If GlKnZ > 0 Then
    Set RpRws = RpCo1.Rows
    
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            TerBe = 0
            SerBe = 0
            BezBe = 0
            AktZa = AktZa + 1
            ReDim Preserve GrTer(AktZa)
            ReDim Preserve GrSer(AktZa)
            ReDim Preserve GrBez(AktZa)
        Else
            If RpRow.Record(Ter_TerBet).Value <> vbNullString Then
                If IsNumeric(RpRow.Record(Ter_TerBet).Value) Then
                    TerBe = TerBe + RpRow.Record(Ter_TerBet).Value
                    GrTer(AktZa) = TerBe
                End If
            End If
        End If
    Next RpRow
    
    AktZa = 0
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            Set RpGrw = RpRow
            If GlGrZ = True Then
                RpGrw.Expanded = True
            Else
                RpGrw.Expanded = False
            End If
            Set ChRws = RpGrw.Childs
            GrAnz = ChRws.Count
            AktZa = AktZa + 1
            If Len(RpGrw.GroupCaption) > 0 Then
                GrCap = RpGrw.GroupCaption
                RpGrw.GroupCaption = GrCap & " - Anzahl: " & GrAnz
            End If
        End If
    Next RpRow
End If

Exit Sub

OpErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SToGr " & Err.Number
Resume Next

End Sub
Public Sub STran(ByVal ImTyp As Integer, Optional ByVal Email As Boolean = False)
On Error GoTo LdErr
'Importieren / Exportieren von LDT-Dateien

Dim PatNr As Long
Dim DaNam As String
Dim FiNam As String
Dim NeNam As String
Dim ImDat As String
Dim PatNa As String
Dim PatVo As String
Dim Brief As String
Dim DaPfa As String
Dim ZipNa As String
Dim KryBn As String  'KrypBin
Dim KryZi As String  'KrypBin
Dim KryPr As String  'Kryptpfad
Dim KryKo As String  'Konfiguration
Dim KryZk As String  'Konfiguration
Dim KrySt As String  'Kryptstring
Dim UmNam As String  'Neuer Name
Dim EmAdr As String  'Emailadresse
Dim EmBCC As String
Dim EmBet As String  'Emailbetreff
Dim EmTex As String  'Emailtext
Dim ExpFo As String  'Exportformat
Dim BerNr As String  'Laborberichte
Dim AnzPo As Integer 'Anzahl Berichte
Dim DatOk As Boolean
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmMain
Set CoDia = FM.comDialo
Set RpCo1 = FM.repCont1
Set RpCo5 = FM.repCont5

Select Case GlBut
Case RibTab_LabBericht:
    Set RpCls = RpCo5.Columns
    Set RpSel = RpCo5.SelectedRows
Case RibTab_LabBerichte:
    Set RpCls = RpCo1.Columns
    Set RpSel = RpCo1.SelectedRows
End Select

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

AnzPo = RpSel.Count
ExpFo = Left$(IniGetVal("System", "ExpFor"), 1)
DaNam = ExpFo & "01" & Format$(DatePart("d", Date, vbMonday), "00") & Format$(DatePart("m", Date, vbMonday), "00") & DatePart("yyyy", Date, vbMonday) & ".ldt"
KryPr = UCase(App.Path & "\KRYP.EXE")
KryKo = UCase(App.Path & "\KRYP.CFG")
KryBn = UCase(App.Path & "\KRYPTAB.BIN")

Select Case ImTyp
Case 1:
    With clFil
        If AnzPo > 0 Then
            Set RpRow = RpSel(0)
            If RpRow.GroupRow = False Then
                With CoDia
                    .CancelError = True
                    .DialogStyle = 1
                    .DefaultExt = "*.ldt"
                    .DialogTitle = "Bitte Name und Ordner der Datei angeben"
                    .FileName = GlEPf & DaNam
                    .Filter = "Laborberichte Standard (*.ldt)|*.ldt|Alle Dateien (*.*)|*.*"
                    .InitDir = GlEPf
                    .ShowSave
                    FiNam = .FileName
                    If .FileTitle = vbNullString Then
                        Set CoDia = Nothing
                        Set RpSel = Nothing
                        Set RpCls = Nothing
                        Set RpCo5 = Nothing
                        Set RpCo1 = Nothing
                        Set clFil = Nothing
                        Exit Sub
                    End If
                End With
                If Right$(FiNam, 4) <> LCase(".ldt") Then
                    FiNam = FiNam & ".ldt"
                End If

                If Not IsNull(FiNam) And Not FiNam = vbNullString Then
                    For Each RpRow In RpSel
                        If RpRow.GroupRow = False Then
                            If GlBut = RibTab_LabBericht Or GlBut = RibTab_LabBerichte Then
                                Set RpCol = RpCls.Find(Lab_ID0)
                            ElseIf GlBut = RibTab_LabAuftrag Or GlBut = RibTab_LabAuftrage Then
                                Set RpCol = RpCls.Find(Lau_ID1)
                            End If
                            If BerNr = vbNullString Then
                                BerNr = RpRow.Record(RpCol.ItemIndex).Value & "_"
                            Else
                                BerNr = BerNr & RpRow.Record(RpCol.ItemIndex).Value & "_"
                            End If
                        End If
                    Next RpRow
                    If .FilVor(FiNam) = True Then
                        Tit1 = "LDT-Export"
                        Mld1 = "Die Datei " & FiNam & " existiert bereits. Soll diese ?berschrieben werden?"
                        Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
                        If Frage = 6 Then
                            .DaLoe = FiNam & vbNullChar
                            .FilLoe
                        Else
                            Set CoDia = Nothing
                            Set RpSel = Nothing
                            Set RpCls = Nothing
                            Set RpCo5 = Nothing
                            Set RpCo1 = Nothing
                            Set clFil = Nothing
                            Exit Sub
                        End If
                    End If
                    
                    If Email = True Then
                        Set RpRow = RpSel(0)
                        If RpRow.GroupRow = False Then
                            Set RpCol = RpCls.Find(Lab_IDP)
                            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                                PatNr = RpRow.Record(RpCol.ItemIndex).Value
                            Else
                                PatNr = 0
                            End If
                            Set RpCol = RpCls.Find(Lab_Name)
                            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                                PatNa = RpRow.Record(RpCol.ItemIndex).Value
                            Else
                                PatNa = Chr$(32)
                            End If
                            Set RpCol = RpCls.Find(Lab_Vorname)
                            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                                PatVo = RpRow.Record(RpCol.ItemIndex).Value
                            Else
                                PatVo = Chr$(32)
                            End If
                            Set RpCol = RpCls.Find(Lab_Briefanrede)
                            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                                Brief = RpRow.Record(RpCol.ItemIndex).Value
                            Else
                                Brief = Chr$(32)
                            End If
                            Set RpCol = RpCls.Find(Lab_Telefon5)
                            EmAdr = RpRow.Record(RpCol.ItemIndex).Value
                            EmBet = "Laborbericht: " & PatNa & ", " & PatVo
                            EmTex = Brief & vbCrLf & vbCrLf & "als Anlage sende ich den Laborbefund von " & PatVo & Chr$(32) & PatNa & ". Bitte die Datei " & DaNam & " ?ffnen."
                        End If
                    End If
                                        
                    .FilPfa FiNam
                    .StrDa = T_Exp(BerNr)
                    .FilWrSt
                    DoEvents
                    
                    If Email = True Then
                        SMaNe PatNr, EmAdr, EmBCC, EmTex, EmBet, FiNam
                    End If
                End If
            End If
        End If
    End With
    
Case 2:

    If clFil.FilDir(GlImO) = False Then 'Importordner
        GlImO = GlIPf
    End If
    If Right$(GlImO, 1) <> "\" Then
        GlImO = GlImO & "\"
    End If

    With CoDia
        .CancelError = True
        .DialogStyle = 1
        .DefaultExt = "*.ldt"
        .Filter = "Laborberichte Standard (*.ldt)|*.ldt|Laborberichte verschl?sselt (*.ldc)|*.ldc|Elektronisches Leistungsverzeichnis (*.elv)|*.elv|Alle Dateien (*.*)|*.*"
        .DialogTitle = "Wo befindet sich die Importdatei?"
        .InitDir = GlImO
        .FileName = vbNullString
        .ShowOpen
        FiNam = .FileName
        If .FileTitle = vbNullString Then
            Set CoDia = Nothing
            Set RpSel = Nothing
            Set RpCls = Nothing
            Set RpCo5 = Nothing
            Set RpCo1 = Nothing
            Set clFil = Nothing
            Exit Sub
        End If
    End With

    With clFil
        If Not IsNull(FiNam) And Not FiNam = vbNullString Then
            .FilPfa FiNam
            DaPfa = .DaPfa & "\"
            KryZi = .DaPfa & "\KRYPTAB.BIN"
            KryZk = .DaPfa & "\KRYP.CFG"
            UmNam = .DaPfa & "\" & .DaNaO & ".ldt"
            NeNam = Left$(FiNam, Len(FiNam) - 3) & "ld_"
            If LCase(DaPfa) <> LCase(GlImO) Then
                IniSetVal "System", "ImpOrd", LCase(DaPfa)
                GlImO = DaPfa
            End If
            If UCase(Right$(FiNam, 3)) = "LDC" Then
                If clFil.FilVor(KryPr) = True Then
                    If clFil.FilVor(KryKo) = True Then
                        If clFil.FilVor(KryBn) = True Then
                            If clFil.FilVor(KryZi) = True Then
                                .DaCop = KryBn & ";" & KryZi & vbNullChar
                                .FilCop 1
                            End If
                            If clFil.FilVor(KryZk) = True Then
                                .DaCop = KryKo & ";" & KryZk & vbNullChar
                                .FilCop 1
                            End If
                            KrySt = KryPr & " -kKRYPTAB.BIN -f" & UCase(FiNam) & " -z" & UCase(UmNam) & " -c" & KryKo & " -m1 -a0 -s1 -n0 -r0 -v0"
                            WindowStart KrySt, vbNormalFocus, True, False
                            If clFil.FilVor(UmNam) = True Then
                                DatOk = True
                            Else
                                Mld1 = "Beim entschl?sseln der Datei " & FiNam & " trat ein Fehler auf"
                                Tit1 = "Entschl?sselungsfehler"
                                WindowMess Mld1, Dial3, Tit1, FM.hwnd
                            End If
                        Else
                            MsgBox KryBn & " konnte nicht gefunden werden", vbExclamation, "Datei nicht gefunden"
                        End If
                    Else
                        Mld1 = "Die Datei " & KryKo & " konnte nicht gefunden werden"
                        Tit1 = "Konfigurationsdatei nicht gefunden"
                        WindowMess Mld1, Dial3, Tit1, FM.hwnd
                    End If
                Else
                    Mld1 = "Die Datei " & KryPr & " konnte nicht gefunden werden"
                    Tit1 = "Kryptomodul nicht gefunden"
                    WindowMess Mld1, Dial3, Tit1, FM.hwnd
                End If
            Else
                DatOk = True
            End If
            If DatOk = True Then
                If LCase(Right$(FiNam, 3)) = "ldc" Then
                    .FilPfa UmNam
                End If
                frmStatus.Show
                DoEvents
                If LCase(Right$(FiNam, 3)) = "ldc" Then
                    basLabor.L_Imp UmNam
                Else
                    basLabor.L_Imp FiNam
                End If
                DoEvents
                If .FilVor(FiNam) = True Then
                    .DaLoe = FiNam & vbNullChar
                    .DaCop = FiNam & ";" & NeNam & vbNullChar
                    .FilCop 3
                End If
                SUpLa
                Unload frmStatus
                DoEvents
                SLaZu 'öffnet den Laborzuordnungsassistenten
                DoEvents
            End If
        End If
    End With
End Select

Set CoDia = Nothing
Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing
Set RpCo5 = Nothing

Set clFil = Nothing

Exit Sub

LdErr:
If GlDbg = True Then MsgBox Err.Description, 48, "STran " & Err.Number
Exit Sub

End Sub
Public Function STrCa(ByVal StrVa As String, ByVal SuStr As String) As String
On Error Resume Next

'Trim the right
Do While Right$(StrVa, 1) Like "[" & SuStr & "]"
    StrVa = Left$(StrVa, Len(StrVa) - 1)
Loop

'Trim the left
Do While Left$(StrVa, 1) Like "[" & SuStr & "]"
    StrVa = Mid(StrVa, 2)
Loop

'Return the result
STrCa = StrVa

End Function

