With RpCo6
    .SortOrder.DeleteAll
    .GroupsOrder.DeleteAll
    If GlKnW > 0 Then
        Select Case GlKnW
        Case 1:
            .SortOrder.Add .Columns(War_ZeiVon)
            .GroupsOrder.Add .Columns(War_ZeiVon)
        Case 2:
            .SortOrder.Add .Columns(War_Raum)
            .GroupsOrder.Add .Columns(War_Raum)
        Case 3:
            .SortOrder.Add .Columns(War_IDM)
            .GroupsOrder.Add .Columns(War_IDM)
        Case 4:
            .SortOrder.Add .Columns(War_IDP)
            .GroupsOrder.Add .Columns(War_IDP)
        Case 5:
            .SortOrder.Add .Columns(War_Patient)
            .GroupsOrder.Add .Columns(War_Patient)
        End Select
        .GroupsOrder(0).SortAscending = True
    End If
End With
RpCo6.Populate

If GlKnW > 0 Then
    Set RpRws = RpCo6.Rows

    AktZa = 0
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            Set RpGrw = RpRow
            If GlGrW = True Then
                RpGrw.Expanded = True
            Else
                RpGrw.Expanded = False
            End If
            Set ChRws = RpGrw.Childs
            GrAnz = ChRws.Count
            AktZa = AktZa + 1
            If Len(RpGrw.GroupCaption) > 0 Then
                GrCap = RpGrw.GroupCaption
                RpGrw.GroupCaption = GrCap & " - Anzahl: " & GrAnz
            End If
        End If
    Next RpRow
End If

Set RpCo6 = Nothing

