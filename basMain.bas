Public Sub SBuGr()
On Error GoTo OpErr
'Gruppiert die Listenansicht

Dim SumEi As Double
Dim SumAu As Double
Dim GrCap As String
Dim GrAnz As Integer
Dim AktZa As Integer
Dim GrEin() As Single
Dim GrAus() As Single

Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set RpCo1 = FM.repCont1

With RpCo1
    .SortOrder.DeleteAll
    .GroupsOrder.DeleteAll
    If GlKnB > 0 Then
        Select Case GlKnB
        Case 1:
            .SortOrder.Add .Columns(Buh_Datum)
            .GroupsOrder.Add .Columns(Buh_Datum)
        Case 2:
            .SortOrder.Add .Columns(Buh_Monat)
            .GroupsOrder.Add .Columns(Buh_Monat)
        Case 3:
            If GlBuc = True Then 'einfache Buchhaltung verwenden
                .SortOrder.Add .Columns(Buh_Geldkontenbez)
                .GroupsOrder.Add .Columns(Buh_Geldkontenbez)
            Else
                .SortOrder.Add .Columns(Buh_Gegenkonto)
                .GroupsOrder.Add .Columns(Buh_Gegenkonto)
            End If
        Case 4:
            .SortOrder.Add .Columns(Buh_Sachkonto)
            .GroupsOrder.Add .Columns(Buh_Sachkonto)
        Case 5:
            .SortOrder.Add .Columns(Buh_IDT)
            .GroupsOrder.Add .Columns(Buh_IDT)
        End Select
        .GroupsOrder(0).SortAscending = True
    End If
End With
RpCo1.Populate

If GlKnB > 0 Then
    Set RpRws = RpCo1.Rows
    
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            SumEi = 0
            SumAu = 0
            AktZa = AktZa + 1
            ReDim Preserve GrEin(AktZa)
            ReDim Preserve GrAus(AktZa)
        Else
            If RpRow.Record(Buh_Einnahme).Value <> vbNullString Then
                If IsNumeric(RpRow.Record(Buh_Einnahme).Value) Then
                    If IsNull(RpRow.Record(Buh_Storniert).Value) = False Then
                        If CBool(RpRow.Record(Buh_Storniert).Value) = False Then
                            SumEi = SumEi + RpRow.Record(Buh_Einnahme).Value
                            GrEin(AktZa) = SumEi
                        End If
                    End If
                End If
            End If
            If RpRow.Record(Buh_Ausgabe).Value <> vbNullString Then
                If IsNumeric(RpRow.Record(Buh_Ausgabe).Value) Then
                    If IsNull(RpRow.Record(Buh_Storniert).Value) = False Then
                        If CBool(RpRow.Record(Buh_Storniert).Value) = False Then
                            SumAu = SumAu + RpRow.Record(Buh_Ausgabe).Value
                            GrAus(AktZa) = SumAu
                        End If
                    End If
                End If
            End If
        End If
    Next RpRow
    
    AktZa = 0
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            Set RpGrw = RpRow
            If GlGrB = True Then
                RpGrw.Expanded = True
            Else
                RpGrw.Expanded = False
            End If
            Set ChRws = RpGrw.Childs
            GrAnz = ChRws.Count
            AktZa = AktZa + 1
            If Len(RpGrw.GroupCaption) > 0 Then
                GrCap = RpGrw.GroupCaption
                RpGrw.GroupCaption = GrCap & " - Anzahl: " & GrAnz & " - Betrag : " & Format$(GrEin(AktZa) - GrAus(AktZa), GlWa1)
            End If
        End If
    Next RpRow
End If

Set RpCo1 = Nothing

Exit Sub

OpErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SBuGr " & Err.Number
Resume Next

End Sub
