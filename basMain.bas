            End If
            .TableCellSelect TabId, AkZei, AkSpa
            If AkSpa = 1 Then
                .FontSize = 8
                .Alignment = 0
            ElseIf AkSpa = 2 Then
                .FontSize = 8
                .Alignment = 2
            Else
                .FontSize = 10
                .Alignment = 2
