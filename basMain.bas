Public Sub SArSo(AryNa As Variant, Optional ByVal SpIdx As Integer = 1, Optional ByVal lngStart As Variant, Optional ByVal lngEnd As Variant)
On Error GoTo PoErr
 
If IsMissing(lngStart) Then lngStart = LBound(AryNa)
If IsMissing(lngEnd) Then lngEnd = UBound(AryNa)

Dim i As Long
Dim j As Long
Dim H As Variant
Dim x As Variant
Dim u As Long
Dim lb_dim As Integer
Dim ub_dim As Integer

lb_dim = LBound(AryNa, 2)
ub_dim = UBound(AryNa, 2)

i = lngStart: j = lngEnd
x = AryNa((lngStart + lngEnd) / 2, SpIdx - 1)

Do
While (AryNa(i, SpIdx - 1) < x): i = i + 1: Wend
While (AryNa(j, SpIdx - 1) > x): j = j - 1: Wend
    If (i <= j) Then
        For u = lb_dim To ub_dim
            H = AryNa(i, u)
            AryNa(i, u) = AryNa(j, u)
            AryNa(j, u) = H
        Next u
        i = i + 1: j = j - 1
    End If
Loop Until (i > j)

If (lngStart < j) Then SArSo AryNa, SpIdx, lngStart, j
If (i < lngEnd) Then SArSo AryNa, SpIdx, i, lngEnd

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SArSo " & Err.Number
Resume Next

End Sub
Public Sub SBaGr()
On Error GoTo OpErr
'Gruppiert die Listenansicht

Dim SumBe As Single
Dim GrCap As String
Dim GrAnz As Integer
Dim AktZa As Integer
Dim GrBet() As Single

Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set RpCo1 = FM.repCont1

With RpCo1
    .SortOrder.DeleteAll
    .GroupsOrder.DeleteAll
    If GlKnH > 0 Then
        Select Case GlKnH
        Case 1:
            .SortOrder.Add .Columns(Ban_Datum)
            .GroupsOrder.Add .Columns(Ban_Datum)
        Case 2:
            .SortOrder.Add .Columns(Ban_Monat)
            .GroupsOrder.Add .Columns(Ban_Monat)
        Case 3:
            .SortOrder.Add .Columns(Ban_Selekt) 'Zugeordnet
            .GroupsOrder.Add .Columns(Ban_Selekt)
        Case 4:
            .SortOrder.Add .Columns(Ban_Ausgabe)
            .GroupsOrder.Add .Columns(Ban_Ausgabe)
        Case 5:
            .SortOrder.Add .Columns(Ban_IDP)
            .GroupsOrder.Add .Columns(Ban_IDP)
        End Select
        .GroupsOrder(0).SortAscending = True
    End If
End With
RpCo1.Populate

If GlKnH > 0 Then
    Set RpRws = RpCo1.Rows
    
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            SumBe = 0
            AktZa = AktZa + 1
            ReDim Preserve GrBet(AktZa)
        Else
            If RpRow.Record(Ban_KoBetrag).Value <> vbNullString Then
                If IsNumeric(RpRow.Record(Ban_KoBetrag).Value) Then
                    SumBe = SumBe + RpRow.Record(Ban_KoBetrag).Value
                    GrBet(AktZa) = SumBe
                End If
            End If
        End If
    Next RpRow
    
    AktZa = 0
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            Set RpGrw = RpRow
            If GlGrH = True Then
                RpGrw.Expanded = True
            Else
                RpGrw.Expanded = False
            End If
            Set ChRws = RpGrw.Childs
            GrAnz = ChRws.Count
            AktZa = AktZa + 1
            If Len(RpGrw.GroupCaption) > 0 Then
                GrCap = RpGrw.GroupCaption
                RpGrw.GroupCaption = GrCap & " - Anzahl: " & GrAnz & " - Betrag : " & Format$(GrBet(AktZa), GlWa1)
            End If
        End If
    Next RpRow
End If

Set RpCo1 = Nothing

Exit Sub

OpErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SBaGr " & Err.Number
Resume Next

End Sub
Public Sub SBaNa()
On Error GoTo LiErr
'Erstellt eine Email für Banking

Dim IdxNr As Long
Dim PatNr As Long
Dim RowNr As Long
Dim ManNr As Long
Dim MitNr As Long
Dim BaKom As String
Dim ReStr As String
Dim EmAdr As String
Dim EmBrf As String
Dim EmTex As String
Dim EmBet As String
Dim MaNam As String
Dim AnzPo As Integer
Dim AktPo As Integer
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows
    
AnzPo = RpSel.Count

If AnzPo > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        RowNr = RpRow.Index

        Set RpCol = RpCls.Find(Ban_ID2)
        IdxNr = RpRow.Record(RpCol.ItemIndex).Value
        Set RpCol = RpCls.Find(Ban_ID0)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            PatNr = RpRow.Record(RpCol.ItemIndex).Value
        Else
            PatNr = 0
        End If
        Set RpCol = RpCls.Find(Ban_IDP)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            ManNr = RpRow.Record(RpCol.ItemIndex).Value
        Else
            ManNr = 0
        End If
        Set RpCol = RpCls.Find(Ban_IDM)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            MitNr = RpRow.Record(RpCol.ItemIndex).Value
        Else
            MitNr = 0
        End If
        Set RpCol = RpCls.Find(Ban_IDKurz)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BaKom = RpRow.Record(RpCol.ItemIndex).Value
        End If
        Set RpCol = RpCls.Find(Ban_RechNr1)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            ReStr = RpRow.Record(RpCol.ItemIndex).Value
        End If

        If PatNr > 0 Then
            For AktPo = 1 To UBound(GlThe)
                If ManNr = GlThe(AktPo, 0) Then
                    MaNam = GlThe(AktPo, 13)
                    Exit For
                End If
            Next AktPo
            S_AdDe PatNr 'Adressendetails
            With GlADt
                EmAdr = .AdTe5
                EmBrf = .AdBrf
            End With

            With GlTxV
                .TxStr = GlEmT(9, 3)
                .Datum = Date
                .ReStr = ReStr
                .MitNr = MitNr
                .ManNr = ManNr
                .PatNr = PatNr
            End With
            EmBet = SEmTx()
                                    
            EmTex = EmBrf & vbCrLf & vbCrLf & BaKom
            GlMaY = 0 'Emailflyoutfenster Mailindex
            GlNaT = 2 'Mailtyp (1=View 2=Neu 3=Antwort)
            MaMain 0, PatNr, EmAdr, vbNullString, EmTex, EmBet
        End If
    End If
End If

Set RpSel = Nothing
Set RpCo1 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SBaNa " & Err.Number
Resume Next

End Sub
