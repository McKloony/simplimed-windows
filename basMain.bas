Public Sub STeSt()
On Error GoTo SaErr
'Storniert die dem Termin zugeordnete Akontozahlung

Dim RowNr As LogEventTypeConstants
Dim TerNr As Long
Dim MasNr As Long
Dim PatNr As Long
Dim TeBet As Double
Dim BzBet As Double
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpCol As XtremeReportControl.ReportColumn

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    RowNr = RpRow.Index
    Set RpCol = RpCls.Find(Ter_ID2)
    TerNr = RpRow.Record(RpCol.ItemIndex).Value
    Set RpCol = RpCls.Find(Ter_ID0)
    PatNr = RpRow.Record(RpCol.ItemIndex).Value
    Set RpCol = RpCls.Find(Ter_TerBet)
    TeBet = CSng(RpRow.Record(RpCol.ItemIndex).Value)
    Set RpCol = RpCls.Find(Ter_BezBet)
    BzBet = CSng(RpRow.Record(RpCol.ItemIndex).Value)
    
    Set RpCol = RpCls.Find(Ter_MasTer)
    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
        Tit1 = "Terminserie Akontozahlung Rückgängig"
        Mld1 = "Soll die gesamte Akontozahlung für diese Terminserie wieder rückgängig gemacht werden?"
        MasNr = RpRow.Record(RpCol.ItemIndex).Value
    Else
        Tit1 = "Termin Akontozahlung Rückgängig"
        Mld1 = "Soll die gesamte Akontozahlung für diesen Termin wieder rückgängig gemacht werden?"
        MasNr = 0
    End If
Else
    TerNr = 0
    MasNr = 0
    PatNr = 0
End If

If RpSel.Count > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then
        S_PaTe 0, TerNr, MasNr
        S_PaGu PatNr, , BzBet
        Set RpRow = RpSel(0)
        RowNr = RpRow.Index
        SUpTe RowNr
    End If
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing

Exit Sub

SaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "STeSt " & Err.Number
Resume Next

End Sub
