Public Sub SAdre(ByVal StaOp As Integer, Optional ByVal MaLad As Boolean)
On Error GoTo AdErr
'Öffnet das Adressformular

Dim FS As VB.Form
Dim PatNr As Long
Dim PatNa As String
Dim TagWe As String
Dim Passi As Boolean
Dim Mld1, Tit1 As String
Dim CmMan As XtremeSuiteControls.ComboBox
Dim CmMit As XtremeSuiteControls.ComboBox
Dim RpCo2 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim ImMan As XtremeCommandBars.ImageManager

Set FM = frmMain
Set RpCo2 = FM.repCont2
Set RpCls = RpCo2.Columns
Set RpSel = RpCo2.SelectedRows

Select Case StaOp
Case 1:
    PatNr = 0
    If MaLad = True Then
        MMain PatNr
    Else
        AMain PatNr
    End If
Case 2:
    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        If RpRow.GroupRow = False Then
            PatNr = AdAry(Adr_ID0, RpRow.Index)
            Passi = AdAry(Adr_Passiv, RpRow.Index)
            If MaLad = True Then
                MMain PatNr
            Else
                If Passi = False Then
                    AMain PatNr
                End If
            End If
        End If
    Else
        Mld1 = "Sie müssen erst einen Eintrag markieren, um diesen bearbeiten zu können"
        Tit1 = "Adresse öffnen"
        WindowMess Mld1, Dial2, Tit1, FM.hwnd
    End If
Case 3:
    If GlAdr > 0 Then
        PatNr = GlAdr
        AMain PatNr
    Else
        Mld1 = "Sie müssen erst einen Patienten anlegen, um diesen bearbeiten zu können"
        Tit1 = "Adresse öffnen"
        WindowMess Mld1, Dial2, Tit1, FM.hwnd
    End If
Case 4:
    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        If RpRow.GroupRow = False Then
            PatNr = AdAry(Adr_ID0, RpRow.Index)
            PatNa = AdAry(Adr_IDKurz, RpRow.Index)
            If GlMiV = True Then 'Mitarbeiter vorhanden
                If UBound(GlMiT) > 1 Then
                    GlBu4 = RibTab_Ter_Mitarb
                    STaSe ShoCut_Termin, RibTab_Ter_Mitarb
                    TeMain 0, PatNr, PatNa
                Else
                    GlBu4 = RibTab_Ter_Kalend
                    STaSe ShoCut_Termin, RibTab_Ter_Kalend
                    TeMain 0, PatNr, PatNa
                End If
            Else
                GlBu4 = RibTab_Ter_Kalend
                STaSe ShoCut_Termin, RibTab_Ter_Kalend
                TeMain 0, PatNr, PatNa
            End If
        End If
    Else
        Mld1 = "Sie müssen erst einen Eintrag markieren, um für diesen einen Termin anlegen zu können"
        Tit1 = "Adresse öffnen"
        WindowMess Mld1, Dial2, Tit1, FM.hwnd
    End If
Case 5:
    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        If RpRow.GroupRow = False Then
            Set FS = frmWieder
            Set PuBu1 = FS.btnDatu1
            Set CmMan = FS.cmbBehan
            Set CmMit = FS.cmbMitar
            Set ImMan = FM.imgManag

            PatNr = AdAry(Adr_ID0, RpRow.Index)
            PatNa = AdAry(Adr_IDKurz, RpRow.Index)
            GlKoN = True
            GlKoS = True
            If PatNr > 0 Then
                FS.txtID0.Text = PatNr
                TagWe = Mid$(FS.txtID0.Tag, 2, Len(FS.txtID0.Tag) - 1)
                FS.txtID0.Tag = 1 & TagWe
            End If
            If PatNa <> vbNullString Then
                FS.txtPatie.Text = PatNa
                TagWe = Mid$(FS.txtPatie.Tag, 2, Len(FS.txtPatie.Tag) - 1)
                FS.txtPatie.Tag = 1 & TagWe
            End If

            PuBu1.Icon = ImMan.Icons.GetImage(IC16_Calendar_Month, 16)
            CmMan.ListIndex = GlSMa - 1
            CmMit.ListIndex = GlSmI - 1
            CmMan.Tag = "1IDP"
            CmMit.Tag = "1IDM"
            DoEvents
            frmWieder.Show vbModal
        End If
    Else
        Mld1 = "Sie müssen erst einen Eintrag markieren, um für diesen einen Termin anlegen zu können"
        Tit1 = "Adresse öffnen"
        WindowMess Mld1, Dial2, Tit1, FM.hwnd
    End If
End Select

Set RpSel = Nothing
Set RpRow = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo2 = Nothing

Exit Sub

AdErr:
If GlDbg = True Then SErLog Err.Description & " SAdre " & Err.Number
Resume Next

End Sub
