    TeFus = "Um ein E-Mail-Konto hinzuzufügen, wechseln Sie in das Modul: Textverarbeitung und dann oben auf Emails. Dort klicken Sie auf die Schaltfläche Emailkonten."
    SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, True, FM.hwnd
    Exit Sub
End If

Set clFil = New clsFile
Set clICS = New clsICS
clFil.hwnd = FM.hwnd

GesZa = RpSel.Count
Tit1 = "Terminnachrichtenversand"
Mld1 = "Sollen jetzt für die " & GesZa & " markierten Termine eine Terminnachricht per Email versendet werden?"

Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
If Frage = 6 Then
    Screen.MousePointer = vbHourglass

    frmStatus.Show
    DoEvents
    Set PrBr1 = frmStatus.prbStat1
    Set PrBr2 = frmStatus.prbStat2
    Set TxDum = frmStatus.txtDummy
    
    PrBr1.Min = 0
    PrBr1.Max = GesZa
    frmStatus.Caption = "Terminnachrichtenversand..."
    DoEvents

    For Each RpRow In RpSel
    If RpRow.GroupRow = False Then
        RowNr = RpRow.Index
        
        TerNr = 0
        PatNr = 0
        TeMit = 0
        TeMan = 0
        PaStr = vbNullString
        EmBet = vbNullString
        EmEmp = vbNullString
        EmBCC = vbNullString
        TeStr = vbNullString
        MaNam = vbNullString
        MiNam = vbNullString
        TeOrt = vbNullString

        Set RpCol = RpCls.Find(Ter_ID2)
        TerNr = RpRow.Record(RpCol.ItemIndex).Value

        S_TeDe TerNr
        With GlTDt
            PatNr = .PatNr
            PaStr = .PaStr
            TeMit = .TeMit
            TeMan = .TeMan
            TeGui = .TeGui
            GnzTa = .GnzTa
            TeOrt = .TeOrt
            DaSta = .DaSta
            DaEnd = .DaEnd
            DaAdd = .DaAdd
            ZeSta = .ZeSta
            ZeEnd = .ZeEnd
            TePri = .TePri
        End With
        
        If PaStr = vbNullString Then
            If PatNr > 0 Then
                PaStr = S_AdIdx(PatNr, "IDKurz")
            End If
        End If
        
        DaStL = Format$(DaSta, "dddd" & ", " & "dd" & ". " & "mmmm" & Chr$(32) & "yyyy")
        DaStK = Format$(DaSta, "ddd" & ", " & "dd" & ". " & "mmm" & Chr$(32) & "yyyy")
        DaStN = Format$(DaSta, "dd.mm.yyyy")
        ZeStS = Format$(ZeSta, "hh:mm")
        ZeStE = Format$(ZeEnd, "hh:mm")
    
        For AktZa = 1 To UBound(GlMan)
            If TeMan = GlMan(AktZa, 2) Then
                If GlMan(AktZa, 32) <> vbNullString Then
                    MaNam = GlMan(AktZa, 32)
                Else
                    MaNam = GlMan(AktZa, 1) 'Mandantenname
                End If
                Exit For
            End If
        Next AktZa
        
        For AktZa = 1 To UBound(GlMiK)
            If TeMit = GlMiK(AktZa, 2) Then
                If GlMiK(AktZa, 27) <> vbNullString Then
                    MiNam = GlMiK(AktZa, 27) 'Anzeigename
                Else
                    If GlMiK(AktZa, 4) <> vbNullString Then 'Vorname
                        If GlMiK(AktZa, 3) <> vbNullString Then 'Name
                            MiNam = GlMiK(AktZa, 4) & " " & GlMiK(AktZa, 3)
                        Else
                            MiNam = GlMiK(AktZa, 1) 'Kurzbezeichnung
                        End If
                    Else
                        MiNam = GlMiK(AktZa, 1) 'Kurzbezeichnung
                    End If
                End If
                Exit For
            End If
        Next AktZa

        If PatNr > 0 Then
            TmStr = vbNullString
            
            With GlTxV
                If GlEmN(DoTyp, 1) <> vbNullString Then
                    .TxStr = GlEmN(DoTyp, 1)
                Else
                    .TxStr = "Termin"
                End If
                If DoTyp < 6 Then
                    .DaStr = DaStL
                ElseIf DoTyp < 10 Then
                    .DaStr = DaStK
                Else
                    .DaStr = DaStN
                End If
                .Datum = DaSta
                .MitNr = TeMit
                .ManNr = TeMan
                .PaStr = PaStr
                .ZeiSt = ZeStS
                .ZeiEn = ZeStE
                .TerID = TeGui
                .PatNr = PatNr
            End With
            TeStr = SEmTx()

            If DoTyp > 5 Then
                With GlTxV
                    If GlEmN(DoTyp, 3) <> vbNullString Then
                        .TxStr = GlEmN(DoTyp, 3)
                    Else
                        .TxStr = "Termin " & MiNam
                    End If
                    .MitNr = TeMit
                    .ManNr = TeMan
                    .PatNr = PatNr
                End With
                EmBet = SEmTx()
            End If

            S_AdDe PatNr 'Adressendetails
            With GlADt
                EmEmp = .AdTe5
                EmTex = .AdRBr & vbCrLf & vbCrLf & TeStr
            End With
            
            If GlTeB = True Then 'Terminnachricht auch an BCC
                If GlMkt(1, 13) <> vbNullString Then
                    EmBCC = GlMkt(1, 13)
                Else
                    If GlThe(GlSMa, 16) <> vbNullString Then
                        EmBCC = GlThe(GlSMa, 16)
                    End If
                End If
            Else
                EmBCC = vbNullString
            End If
            
            If TerNr > 0 Then
                DBCmEx2 "qryTerOnTe", "@OnlTe", "@IdxNr", -1, TerNr 'Kennzeichnung
            End If

            If GlICS = True Then 'Terminnachricht mit ICS Dateiversand
                With GlTxV
                    .TxStr = GlEmT(5, 3)
                    .MitNr = TeMit
                    .ManNr = TeMan
                    .PatNr = PatNr
                End With
                EmBet = SEmTx()

                With clICS
                    .moKaNa = MiNam
                    .moTeID = TeGui
                    .moDaAd = DaAdd
                    .moDaSt = DaSta
                    .moDaEn = DaEnd
                    .moZeSt = ZeSta
                    .moZeEn = ZeEnd
                    .moTeBe = EmBet
                    .moTeGa = GnzTa
                    .moTeKo = Left$(EmTex, 62)
                    .moTePr = TePri
                    TmStr = .ICSHead
                    TmStr = TmStr & .ICSBody
                    TmStr = TmStr & .ICSFoot
                End With
                
                DaNam = CreateID("I")
                FiNam = GlTEx & DaNam & ".ics" 'Termineordner

                With clFil
                    If .FilVor(FiNam) = True Then
                        .DaLoe = FiNam & vbNullChar
                        .FilLoe
                    End If
                    DoEvents
                    Call .FilCnWr(FiNam, TmStr)
                End With
                
                EmVer = SEmSe(EmEmp, EmBet, EmTex, FiNam)
                DoEvents
                If EmVer = True Then
                    If PatNr > 0 Then
                        EmTex = Replace(EmTex, vbCrLf, Space$(1), 1)
                        EmTex = Trim$(EmTex)
                        TmGui = CreateID("E")
                        GlNeK = GlKoX
                        With GlNeK
                            .PatNr = PatNr
                            .IdxNr = 0
                            .EiDat = Format$(Date, "dd.mm.yyyy")
                            .EiZei = TimeValue(Now)
                            .EiTyp = 108 'Email
                            .KoStr = EmTex
                            .KoGui = TmGui
                            .NeuEi = True
                            .Mitar = GlMiA(GlSmI, 2)
                        End With
                        K_Einf
                    End If
                End If
            Else
                EmVer = SEmSe(EmEmp, EmBet, EmTex)
                DoEvents
                If EmVer = True Then
                    If PatNr > 0 Then
                        EmTex = Replace(EmTex, vbCrLf, Space$(1), 1)
                        EmTex = Trim$(EmTex)
                        TmGui = CreateID("E")
                        GlNeK = GlKoX
                        With GlNeK
                            .PatNr = PatNr
                            .IdxNr = 0
                            .EiDat = Format$(Date, "dd.mm.yyyy")
                            .EiZei = TimeValue(Now)
                            .EiTyp = 108 'Email
                            .KoStr = EmTex
                            .KoGui = TmGui
                            .NeuEi = True
                            .Mitar = GlMiA(GlSmI, 2)
                        End With
                        K_Einf
                    End If
                End If
            End If
        End If
        
        AkTer = AkTer + 1
        PrBr1.Value = AkTer
        If TxDum.Text = "B" Then Exit For 'Abbrechen
        DoEvents
    End If
    Next RpRow
    
    Unload frmStatus
    DoEvents
    
    SUpTe RowNr
    
    Screen.MousePointer = vbNormal
End If

Set clICS = Nothing
Set clFil = Nothing

Set RpCo1 = Nothing

Exit Sub

AdErr:
If GlDbg = True Then MsgBox Err.Description, 48, "STeMa " & Err.Number
Resume Next

End Sub
Public Sub STeNa(ByVal DoTyp As Integer, Optional ByVal WaLis As Boolean = False)
On Error GoTo AdErr
'Erstellt eine Terminnachricht

Dim DaSta As Date
Dim DaEnd As Date
Dim DaAdd As Date
Dim ZeSta As Date
Dim ZeEnd As Date
Dim TerNr As Long
Dim PatNr As Long
Dim RowNr As Long
Dim TeMit As Long
Dim TeMan As Long
Dim EmEmp As String
Dim EmTex As String
Dim EmBCC As String
Dim TelMo As String
Dim TelPr As String
Dim TeStr As String
Dim EmBet As String
Dim TeOrt As String
Dim MiNam As String
Dim PaStr As String
Dim DaStL As String
Dim DaStK As String
Dim DaStN As String
Dim ZeStS As String
Dim ZeStE As String
Dim TmStr As String
Dim FiNam As String
Dim TeBrf As String
Dim TeGui As String
Dim PrStr As String
Dim PrGui As String
Dim MitNa As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim DayGa As Boolean
Dim RetWe As Boolean
Dim TePri As Integer
Dim AktZa As Integer
Dim AktKo As Integer
Dim GesZa As Integer
Dim DoGrp As Integer
Dim Mld1, Tit1 As String
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCo7 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim CaCol As XtremeCalendarControl.CalendarControl
Dim CaEvt As XtremeCalendarControl.CalendarEvent
Dim CaEvs As XtremeCalendarControl.CalendarEvents
Dim CaHit As XtremeCalendarControl.CalendarHitTestInfo
Dim ViEvt As XtremeCalendarControl.CalendarViewEvent
Dim ViEvs As XtremeCalendarControl.CalendarViewEvents

Set FM = frmMain
Set CaCol = FM.calCont1
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows

Set clICS = New clsICS
Set clFil = New clsFile
clFil.hwnd = FM.hwnd

GlTrM = False 'Terminbearbeitung direkt im Kalender
GlTrB = False 'Terminbearbeitung direkt im Kalender

Select Case GlBut
Case RibTab_Ter_Kalend:
    Set ViEvs = CaCol.ActiveView.GetSelectedEvents
    If ViEvs.Count > 0 Then
        For Each ViEvt In ViEvs
            If ViEvt.Selected = True Then
                Set CaEvt = ViEvt.Event
                TerNr = CaEvt.id
                Exit For
            End If
        Next ViEvt
    Else
        Set CaHit = CaCol.ActiveView.HitTest
        If Not CaHit.HitCode = xtpCalendarHitTestDayViewTimeScale Then
            If Not CaHit.HitCode = xtpCalendarHitTestUnknown Then
                If Not CaHit.ViewEvent Is Nothing Then
                    TerNr = CaHit.ViewEvent.Event.id
                End If
            End If
        End If
    End If
Case RibTab_Ter_Raeume:
    Set ViEvs = CaCol.ActiveView.GetSelectedEvents
    If ViEvs.Count > 0 Then
        For Each ViEvt In ViEvs
            If ViEvt.Selected = True Then
                Set CaEvt = ViEvt.Event
                TerNr = CaEvt.id
                Exit For
            End If
        Next ViEvt
    Else
        Set CaHit = CaCol.ActiveView.HitTest
        If Not CaHit.HitCode = xtpCalendarHitTestDayViewTimeScale Then
            If Not CaHit.HitCode = xtpCalendarHitTestUnknown Then
                If Not CaHit.ViewEvent Is Nothing Then
                    TerNr = CaHit.ViewEvent.Event.id
                End If
            End If
        End If
    End If
Case RibTab_Ter_Mitarb:
    Set ViEvs = CaCol.ActiveView.GetSelectedEvents
    If ViEvs.Count > 0 Then
        For Each ViEvt In ViEvs
            If ViEvt.Selected = True Then
                Set CaEvt = ViEvt.Event
                TerNr = CaEvt.id
                Exit For
            End If
        Next ViEvt
    Else
        Set CaHit = CaCol.ActiveView.HitTest
        If Not CaHit.HitCode = xtpCalendarHitTestDayViewTimeScale Then
            If Not CaHit.HitCode = xtpCalendarHitTestUnknown Then
                If Not CaHit.ViewEvent Is Nothing Then
                    TerNr = CaHit.ViewEvent.Event.id
                End If
            End If
        End If
    End If
Case RibTab_Ter_Listen:
    GesZa = RpSel.Count
    If GesZa > 0 Then
        If GesZa = 1 Then
            Set RpRow = RpSel(0)
            If RpRow.GroupRow = False Then
                RowNr = RpRow.Index
                Set RpCol = RpCls.Find(Ter_ID2)
                TerNr = RpRow.Record(RpCol.ItemIndex).Value
            End If
        Else
            If DoTyp < 10 Or DoTyp > 14 Then
                STeMa DoTyp
                Exit Sub
            Else
                Set RpRow = RpSel(0)
                If RpRow.GroupRow = False Then
                    RowNr = RpRow.Index
                    Set RpCol = RpCls.Find(Ter_ID2)
                    TerNr = RpRow.Record(RpCol.ItemIndex).Value
                End If
            End If
        End If
    End If
Case RibTab_Ter_Warte:
    GesZa = RpSel.Count
    If GesZa > 0 Then
        If GesZa = 1 Then
            Set RpRow = RpSel(0)
            If RpRow.GroupRow = False Then
                RowNr = RpRow.Index
                Set RpCol = RpCls.Find(Ter_ID2)
                TerNr = RpRow.Record(RpCol.ItemIndex).Value
            End If
        Else
            If DoTyp < 10 Or DoTyp > 14 Then
                STeMa DoTyp
                Exit Sub
            Else
                Set RpRow = RpSel(0)
                If RpRow.GroupRow = False Then
                    RowNr = RpRow.Index
                    Set RpCol = RpCls.Find(Ter_ID2)
                    TerNr = RpRow.Record(RpCol.ItemIndex).Value
                End If
            End If
        End If
    End If
End Select

If WaLis = True Then
    Set FM = frmKatTE
    Set RpCo7 = FM.repCont7
    Set RpCls = RpCo7.Columns
    Set RpSel = RpCo7.SelectedRows

    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        If RpRow.GroupRow = False Then
            Set RpCol = RpCls.Find(Kat_ID0)
            PatNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Kat_IDKurz)
            PaStr = RpRow.Record(RpCol.ItemIndex).Value
            ZeSta = TimeValue(DaSta)
            ZeEnd = TimeValue(DaEnd)
            TeGui = CreateID("T")
            DBCmEx2 "qryAdrPri", "@IdPri", "@IdxNr", 4, PatNr
        End If
    End If
End If

If TerNr > 0 Or WaLis = True Then
    If WaLis = False Then
        S_TeDe TerNr
        With GlTDt
            PatNr = .PatNr
            TeMit = .TeMit
            TeMan = .TeMan
            TeGui = .TeGui
            DayGa = .GnzTa
            TeOrt = .TeOrt
            DaSta = .DaSta
            DaEnd = .DaEnd
            DaAdd = .DaAdd
            ZeSta = .ZeSta
            ZeEnd = .ZeEnd
            TePri = .TePri
            If .PaNam <> vbNullString Then
                If .PaVor <> vbNullString Then
                    PaStr = .PaVor & Space$(1) & .PaNam
                Else
                    PaStr = .PaVor & Space$(1) & .PaNam
                End If
            Else
                PaStr = .PaStr
            End If
        End With
    Else
        Set CaHit = CaCol.ActiveView.HitTest
        If CaHit.ViewEvent Is Nothing Then
            CaCol.ActiveView.GetSelection DaSta, DaEnd, DayGa
        Else
            DaSta = CaHit.ViewEvent.Event.StartTime
            DaEnd = CaHit.ViewEvent.Event.EndTime
            DayGa = CaHit.ViewEvent.Event.AllDayEvent
        End If
        ZeSta = DaSta
        ZeEnd = DaEnd
    End If

    DaStL = Format$(DaSta, "dddd" & ", " & "dd" & ". " & "mmmm" & Chr$(32) & "yyyy")
    DaStK = Format$(DaSta, "ddd" & ", " & "dd" & ". " & "mmm" & Chr$(32) & "yyyy")
    DaStN = Format$(DaSta, "dd.mm.yyyy")
    ZeStS = Format$(ZeSta, "hh:mm")
    ZeStE = Format$(ZeEnd, "hh:mm")

    If TeMit > 0 Then
        For AktZa = 1 To UBound(GlMiK)
            If TeMit = GlMiK(AktZa, 2) Then
                If GlMiK(AktZa, 27) <> vbNullString Then
                    MiNam = GlMiK(AktZa, 27) 'Verkehrsname
                Else
                    If GlMiK(AktZa, 4) <> vbNullString Then 'Vorname
                        If GlMiK(AktZa, 3) <> vbNullString Then 'Name
                            MiNam = GlMiK(AktZa, 4) & " " & GlMiK(AktZa, 3)
                        Else
                            MiNam = GlMiK(AktZa, 1) 'Kurzbezeichnung
                        End If
                    Else
                        MiNam = GlMiK(AktZa, 1) 'Kurzbezeichnung
                    End If
                End If
                Exit For
            End If
        Next AktZa
    Else
        If GlMiK(GlSmI, 27) <> vbNullString Then 'Standardmitarbeiter
            MiNam = GlMiK(GlSmI, 27) 'Verkehrsname
        Else
            If GlMiK(GlSmI, 4) <> vbNullString Then 'Vorname
                If GlMiK(GlSmI, 3) <> vbNullString Then 'Name
                    MiNam = GlMiK(GlSmI, 4) & " " & GlMiK(GlSmI, 3)
                Else
                    MiNam = GlMiK(GlSmI, 1) 'Kurzbezeichnung
                End If
            Else
                MiNam = GlMiK(GlSmI, 1) 'Kurzbezeichnung
            End If
        End If
    End If
    
    With GlTxV
        If GlEmN(DoTyp, 1) <> vbNullString Then
            .TxStr = GlEmN(DoTyp, 1)
        Else
            .TxStr = "Termin"
        End If
        If DoTyp < 6 Then
            .DaStr = DaStL
        ElseIf DoTyp < 10 Then
            .DaStr = DaStK
        Else
            .DaStr = DaStN
        End If
        .Datum = DaSta
        .MitNr = TeMit
        .ManNr = TeMan
        .PaStr = PaStr
        .ZeiSt = ZeStS
        .ZeiEn = ZeStE
        .TerID = TeGui
        .PatNr = PatNr
    End With
    TeStr = SEmTx()
    
    If DoTyp > 5 Then
        With GlTxV
            If GlEmN(DoTyp, 3) <> vbNullString Then
                .TxStr = GlEmN(DoTyp, 3)
            Else
                .TxStr = "Termin " & MiNam
            End If
            .MitNr = TeMit
            .ManNr = TeMan
            .PatNr = PatNr
        End With
        EmBet = SEmTx()
    End If

    Select Case DoTyp
    Case 0: 'Textverarbeitung
        If PatNr > 0 Then
            GlAdr = PatNr
            STxVo False, PatNr, TerNr
        Else
            SPopu "kein Stammpatient", "Es wurde kein Stammpatient zugeordnet", IC48_Forbidden
        End If
    Case 1: 'Terminbescheinigung (Brief)
        DoGrp = 1
    Case 2: 'Terminbestätigung (Brief)
        DoGrp = 1
    Case 3: 'Terminerinnerung (Brief)
        DoGrp = 1
    Case 4: 'Terminabsage (Brief)
        DoGrp = 1
    Case 5: 'Terminvorschlag (Brief)
        DoGrp = 1
    Case 6: 'Terminbestätigung (Email)
        DoGrp = 2
    Case 7: 'Terminerinnerung (Email)
        DoGrp = 2
    Case 8: 'Terminabsage (Email)
        DoGrp = 2
    Case 9: 'Terminvorschlag (Email)
        DoGrp = 2
    Case 10: 'Terminbestätigung (SMS)
        DoGrp = 3
        TeStr = SNaFi(TeStr)
    Case 11: 'Terminerinnerung (SMS)
        DoGrp = 3
        TeStr = SNaFi(TeStr)
    Case 12: 'Terminabsage (SMS)
        DoGrp = 3
        TeStr = SNaFi(TeStr)
    Case 13: 'Terminvorschlag (SMS)
        DoGrp = 3
        TeStr = SNaFi(TeStr)
    Case 14: 'Terminstornierung (Brief)
        DoGrp = 1
    Case 15: 'Terminstornierung (Email)
        DoGrp = 2
    Case 16: 'Terminstornierung (SMS)
        DoGrp = 3
        TeStr = SNaFi(TeStr)
    Case 20: 'Textverarbeitung
        If PatNr > 0 Then
            STxEi DoTyp, PatNr, TeStr, TerNr
        Else
            SPopu "kein Stammpatient", "Es wurde kein Stammpatient zugeordnet", IC48_Forbidden
        End If
    End Select

    Select Case DoGrp
    Case 1: 'Brief
        
        If PatNr > 0 Then
            If DoTyp = 5 Then DoTyp = 10
            GlAdr = PatNr
            STxEi DoTyp, PatNr, TeStr, TerNr
        Else
            SPopu "kein Stammpatient", "Es wurde kein Stammpatient zugeordnet", IC48_Forbidden
        End If
        
    Case 2: 'Email
    
        If GlEKV = False Then 'Emailkonten vorhanden
            TeTit = "E-Mail-Versand"
            TeMai = "Es ist kein E-Mail-Konto vorhanden"
            TeInh = "Um E-Mails versenden zu können, ist es notwendig mind. ein E-Mail-Konto hinzuzufügen."
            TeFus = "Um ein E-Mail-Konto hinzuzufügen, wechseln Sie in das Modul: Textverarbeitung und dann oben auf Emails. Dort klicken Sie auf die Schaltfläche Emailkonten."
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, True, FM.hwnd
            Exit Sub
        End If

        If PatNr > 0 Then
            S_AdDe PatNr 'Adressendetails
            With GlADt
                EmEmp = .AdTe5
                TeBrf = .AdRBr
            End With
        End If
        
        EmTex = TeBrf & vbCrLf & vbCrLf & TeStr

        If GlTeB = True Then 'Terminnachricht auch an BCC
            GesZa = UBound(GlMkt)
            If GesZa > 0 Then
                For AktKo = 1 To GesZa
                    If CLng(GlMkt(AktKo, 1)) = CLng(GlMiA(GlSmI, 2)) Then
                        Exit For
                    End If
                Next AktKo
                If AktKo <= GesZa Then
                    If GlMkt(AktKo, 14) <> vbNullString Then 'Antwortadresse
                        EmBCC = GlMkt(AktKo, 14)
                    ElseIf GlMkt(AktKo, 13) <> vbNullString Then 'Emailadresse
                        EmBCC = GlMkt(AktKo, 13)
                    ElseIf GlMiK(AktZa, 22) <> vbNullString Then
                        EmBCC = GlMiK(AktZa, 22)
                    End If
                End If
            End If
        Else
            EmBCC = vbNullString
        End If

        If TerNr > 0 Then
            DBCmEx2 "qryTerOnTe", "@OnlTe", "@IdxNr", -1, TerNr
        End If

        If GlICS = True Then 'Terminnachricht mit ICS Dateiversand
            DoEvents
            With clICS
                .moKaNa = MiNam
                .moTeID = TeGui
                .moDaAd = DaAdd
                .moDaSt = DaSta
                .moDaEn = DaEnd
                .moZeSt = ZeSta
                .moZeEn = ZeEnd
                .moTeBe = EmBet
                .moTeGa = DayGa
                .moTeKo = Left$(TeStr, 62)
                .moTePr = TePri
                TmStr = .ICSHead
                TmStr = TmStr & .ICSBody
                TmStr = TmStr & .ICSFoot
            End With

            FiNam = GlTEx & "Termin_" & Format$(Now, "YYYYMMDD_HHMMSS") & ".ics" 'Termineordner
            With clFil
                If .FilVor(FiNam) = True Then
                    .DaLoe = FiNam & vbNullChar
                    .FilLoe
                End If
                Call .FilCnWr(FiNam, TmStr)
            End With

            DoEvents
            SMaNe PatNr, EmEmp, EmBCC, EmTex, EmBet, FiNam
        Else
            DoEvents
            SMaNe PatNr, EmEmp, EmBCC, EmTex, EmBet
        End If

    Case 3: 'SMS
    
        If PatNr > 0 Then
            TelMo = S_AdIdx(PatNr, "Telefon4")
        End If
        If TelMo <> vbNullString Then
            frmSMS.NaTex = TeStr
