            If RpRws.Row(RowNr).GroupRow = False Then
                RpRws.Row(RowNr).EnsureVisible
                RpRws.Row(RowNr).Selected = True
                If GlFoc = True Then
                    Set RpCo4.FocusedRow = RpRws.Row(RowNr)
                End If
            End If
        End If
    End If
Else
    If EiMar = True Then
        If Not (Not GloRe) Then
            If RpRws.Count > 0 Then
                If RpRws.Count <= UBound(GloRe) Then
                    If RpRws.Row(0).GroupRow = False Then
                        RpRws.Row(0).Selected = False
                        RpRws.Row(GloRe(1)).EnsureVisible
                    End If
                End If
            End If
        End If
    End If
End If

Set RpRws = Nothing
Set RpCo4 = Nothing

GlAkt = False

Exit Sub

LaErr:
