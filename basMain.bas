                            LiFi1.RefreshViewFast
                            DoEvents
                            SBiFi
                        End If
                    Else
                        SPopu "Datei nicht lesbar", "Die von Ihnen ausgewählte Datei kann nicht gelesen werden", IC48_Warning
                    End If
                Else
                    SPopu "Datei nicht lesbar", "Die von Ihnen ausgewählte Datei kann nicht gelesen werden", IC48_Warning
                End If
            Else
                SPopu "Keine Bilddatei", "Die von Ihnen ausgewählte Datei ist keine Bilddatei", IC48_Warning
