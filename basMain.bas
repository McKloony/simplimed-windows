Public Function SCrypt(SuStr As String, DeCry As Boolean) As String
On Error GoTo CrErr
'Ver/- und Entschlüsselt einen String

Dim AktZa As Long
Dim Posit As Long
Dim CptZa As Long
Dim OrgZa As Long
Dim KeyZa As Long
Dim CptSt As String
Dim KeOut As String
  
For AktZa = 1 To Len(SuStr)
    Posit = Posit + 1
    If Posit > Len(VerKy) Then Posit = 1
    KeyZa = Asc(Mid(VerKy, Posit, 1))
    If DeCry = True Then ' Verschlüsseln
        OrgZa = Asc(Mid(SuStr, AktZa, 1))
        CptZa = OrgZa Xor KeyZa
        CptSt = Hex(CptZa)
        If Len(CptSt) < 2 Then CptSt = "0" & CptSt
        KeOut = KeOut & CptSt
    Else 'Entschlüsseln
        If AktZa > Len(SuStr) \ 2 Then Exit For
        CptZa = CByte("&H" & Mid$(SuStr, AktZa * 2 - 1, 2))
        OrgZa = CptZa Xor KeyZa
        KeOut = KeOut & Chr$(OrgZa)
    End If
Next AktZa
 
SCrypt = KeOut

Exit Function

CrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SCrypt " & Err.Number
Resume Next

End Function
