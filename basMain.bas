Public Sub SLaGr()
On Error GoTo OpErr
'Gruppiert die Listenansicht

Dim GrCap As String
Dim GrAnz As Integer
Dim AktZa As Integer

Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set RpCo1 = FM.repCont1

With RpCo1
    .SortOrder.DeleteAll
    .GroupsOrder.DeleteAll
    If GlKnU > 0 Then
        Select Case GlKnU
        Case 1:
            .SortOrder.Add .Columns(Lau_Datum)
            .GroupsOrder.Add .Columns(Lau_Datum)
        Case 2:
            .SortOrder.Add .Columns(Lau_Auftrag)
            .GroupsOrder.Add .Columns(Lau_Auftrag)
        Case 3:
            .SortOrder.Add .Columns(Lau_ID0)
            .GroupsOrder.Add .Columns(Lau_ID0)
        Case 4:
            .SortOrder.Add .Columns(Lau_BefKosten)
            .GroupsOrder.Add .Columns(Lau_BefKosten)
        Case 5:
            .SortOrder.Add .Columns(Lau_IP0)
            .GroupsOrder.Add .Columns(Lau_IP0)
        End Select
        .GroupsOrder(0).SortAscending = True
    End If
End With
RpCo1.Populate

If GlKnU > 0 Then
    Set RpRws = RpCo1.Rows
    AktZa = 0
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            Set RpGrw = RpRow
            If GlGrU = True Then
                RpGrw.Expanded = True
            Else
                RpGrw.Expanded = False
            End If
            Set ChRws = RpGrw.Childs
            GrAnz = ChRws.Count
            AktZa = AktZa + 1
            If Len(RpGrw.GroupCaption) > 0 Then
                GrCap = RpGrw.GroupCaption
                RpGrw.GroupCaption = GrCap & " - Anzahl: " & GrAnz
            End If
        End If
    Next RpRow
End If

Exit Sub

OpErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SLaGr " & Err.Number
Resume Next

End Sub
Public Sub SLaZe(Optional ByVal PaNum As Long, Optional ByVal LabNr As Long)
On Error GoTo LiErr

Dim LaNum As Long
Dim IdxNr As Long
Dim RowNr As Long
Dim CmBrs As XtremeCommandBars.CommandBars
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCo5 = FM.repCont5
Set CmBrs = FM.comBar01
Set CmAcs = CmBrs.Actions

If PaNum = 0 Then
    If LabNr = 0 Then
        Set RpCls = RpCo1.Columns
        Set RpSel = RpCo1.SelectedRows
        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            Set RpCol = RpCls.Find(0) 'Lab_ID0 oder Lau_ID1
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                    LaNum = RpRow.Record(RpCol.ItemIndex).Value
                    Select Case GlBut
                    Case RibTab_LabBerichte: Set RpCol = RpCls.Find(Lab_IDP)
                    Case RibTab_LabAuftrage: Set RpCol = RpCls.Find(Lau_ID0)
                    End Select
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        GlAdr = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        GlAdr = 0
                    End If
                    GlTDa = vbNullString 'Wichtig für Textverarbeitung
                Else
                    Exit Sub
                End If
            Else
                Exit Sub
            End If
        End If
    Else
        LaNum = LabNr
        GlTDa = vbNullString 'Wichtig für Textverarbeitung
    End If
ElseIf PaNum > 0 Then
    GlAdr = PaNum
    GlTDa = vbNullString 'Wichtig für Textverarbeitung
    If LabNr > 0 Then
        LaNum = LabNr
    End If
End If

If GlAdr > 0 Then
    DoEvents
    GlSuP = GlSuX
    S_KrLa
    DoEvents
    S_KrCo
    DoEvents

    Select Case GlBut
    Case RibTab_LabBerichte:
        GlBu5 = RibTab_LabBericht
        STaSe ShoCut_Labor, RibTab_LabBericht
    Case RibTab_LabAuftrage:
        GlBu5 = RibTab_LabAuftrag
        STaSe ShoCut_Labor, RibTab_LabAuftrag
    End Select
    
    If LaNum > 0 Then
        Set RpCls = RpCo5.Columns
        Set RpRws = RpCo5.Rows
        For Each RpRow In RpRws
            Set RpCol = RpCls.Find(0) 'Lab_ID0 oder Lau_ID1
            IdxNr = RpRow.Record(RpCol.ItemIndex).Value
            If IdxNr = LaNum Then
                RowNr = RpRow.Index
                RpRws.Row(0).Selected = False
                RpRws.Row(RowNr).EnsureVisible
                RpRws.Row(RowNr).Selected = True
                If GlFoc = True Then
                    Set RpCo5.FocusedRow = RpRws.Row(RowNr)
                End If
                S_LaPo
                DoEvents
                If GlBut = RibTab_LabBerichte Then
                    S_LaBe
                    DoEvents
                End If
                Exit For
            End If
        Next RpRow
    End If
Else
    SPopu "Laborbericht Anzeigen", "Diesem Laborbericht wurde noch kein Patient zugeordnet", IC48_Forbidden
End If

Set RpCo1 = Nothing
Set RpCo5 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SLaZe " & Err.Number
Resume Next

End Sub
