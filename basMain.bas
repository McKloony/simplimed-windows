Public Sub SBiIa()
On Error GoTo CrErr
'Importiert ein Antlitzbild

Dim PhoBr As Long
Dim PhoHo As Long
Dim TeiBr As Double
Dim TeiHo As Double
Dim TeiSc As Double
Dim DaExt As String
Dim DaNam As String
Dim PaStr As String
Dim BldNa As String
Dim FiNam As String
Dim TmGui As String
Dim TmpNa As String
Dim ImDat As String
Dim AktZ1 As Integer
Dim AktZ2 As Integer
Dim AnzDa As Integer
Dim DiaEn As Boolean
Dim DiNam() As String
Dim ImMan As XtremeCommandBars.ImageManager

Set FM = frmDoImp
Set PuBu1 = FM.btnButt1
Set ImMan = frmMain.imgManag
Set TxDe5 = frmMain.txtDeta5
Set PiBi1 = frmMain.picBild1
Set PiBi2 = frmMain.picBild2

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

PaStr = Format$(GlAdr, "000000")

If PuBu1.Icon.id = IC16_Folder_Close Then
    PuBu1.Icon = ImMan.Icons.GetImage(IC16_Folder_Open, 16)
ElseIf PuBu1.Icon.id = IC16_Folder_Open Then
    PuBu1.Icon = ImMan.Icons.GetImage(IC16_Folder_Paper, 16)
Else
    PuBu1.Icon = ImMan.Icons.GetImage(IC16_Folder_Close, 16)
End If

If clFil.FilVor(GlIPf & "*.*") = True Then
    AnzDa = clFil.FilLis(LCase(GlIPf), "*.*", DiNam)
    DoEvents
    If AnzDa > 0 Then
        For AktZ1 = 1 To UBound(DiNam)
            FiNam = LCase(GlIPf & DiNam(AktZ1))
            
            If SNaPr(FiNam) = False Then
                clFil.FilPfa FiNam
                DaExt = clFil.DaExt
                For AktZ2 = 1 To UBound(GlFor)
                    If GlFor(AktZ2) = LCase(DaExt) Then

                        TmGui = CreateID("D")
                        BldNa = PaStr & "_" & TmGui & "." & DaExt
                        DaNam = GlBPf & BldNa
                        DoEvents
    
                        clFil.DaCop = FiNam & ";" & DaNam & vbNullChar
                        If clFil.FilCop(2) = True Then
                            DoEvents
                            If clFil.FilVor(DaNam) = True Then

                                PiBi2.Picture = LoadPicture(DaNam)
                                PiBi1.ScaleMode = vbPixels
                                PiBi2.ScaleMode = vbPixels
                                With PiBi1
                                    .AutoRedraw = True
                                    .Picture = LoadPicture("")
                                    .Width = 2000
                                    .Height = 2000
                                    .Refresh
                                    .AutoRedraw = False
                                End With
                                TeiBr = PiBi1.ScaleWidth / PiBi2.ScaleWidth
                                TeiHo = PiBi1.ScaleHeight / PiBi2.ScaleHeight
                                If PiBi2.ScaleWidth * TeiHo > PiBi1.ScaleWidth Then
                                  TeiSc = TeiBr
                                Else
                                  TeiSc = TeiHo
                                End If
                                PhoBr = PiBi2.ScaleWidth * TeiSc
                                PhoHo = PiBi2.ScaleHeight * TeiSc
                                With PiBi1
                                    .AutoRedraw = True
                                    .Width = PhoBr * Screen.TwipsPerPixelX
                                    .Height = PhoHo * Screen.TwipsPerPixelY
                                    .Refresh
                                    .PaintPicture PiBi2.Picture, 0, 0, PhoBr, PhoHo
                                    .AutoRedraw = False
                                End With
                                TxDe5.Text = BldNa
                                SSave

                            End If
                        End If
                        
                        If GlBCl = True Then
                            Unload frmDoImp
                        End If
                        
                    End If
                Next AktZ2

            Else
                SPopu "Dateiname nicht lesbar", "Der von Ihnen ausgewählte Dateiname kann nicht gelesen werden weil er ggf. Sonderzeichen enthält", IC48_Warning
            End If
        Next AktZ1
    End If
End If

Set clFil = Nothing

Exit Sub

CrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SBiIa " & Err.Number
Exit Sub

End Sub
