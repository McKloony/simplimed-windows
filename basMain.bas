If GlRch(0, 5) = 0 Then
    WindowMess "Sie besitzen keine Berechtigung für diesen Vorgang", Dial3, "Krankenblatt", FM.hwnd
    Exit Sub
End If

If PaNum > 0 Then
    GlAdr = PaNum
    PaSto = CBool(S_AdIdx(GlAdr, "Passiv"))
    If PaSto = True Then
        SPopu "Patient gelöscht", "Dieser Patient wurde bereits gelöscht und kann daher nciht aufgerufen werden", IC48_Forbidden
        Exit Sub
    End If
    GlTDa = vbNullString 'Wichtig für Textverarbeitung
    GlBu2 = RibTab_Krankenbla
    DoEvents
    STaSe ShoCut_Kranken, RibTab_Krankenbla
    DoEvents
Else
    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        If RpRow.GroupRow = False Then
            GlAdr = AdAry(Adr_ID0, RpRow.Index)
            PaSto = CBool(S_AdIdx(GlAdr, "Passiv"))
            If PaSto = True Then
                SPopu "Patient gelöscht", "Dieser Patient wurde bereits gelöscht und kann daher nciht aufgerufen werden", IC48_Forbidden
                Exit Sub
            End If
            GlTDa = vbNullString 'Wichtig für Textverarbeitung
            'S_KrLa
            'S_KrCo
            DoEvents
            GlBu2 = RibTab_Krankenbla
            DoEvents
            STaSe ShoCut_Kranken, RibTab_Krankenbla
        End If
    End If
End If

Set RpSel = Nothing
Set RpRow = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo2 = Nothing

Exit Sub

InErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SKrZe " & Err.Number
Resume Next

