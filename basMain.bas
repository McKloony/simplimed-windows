Public Function STxSa(Optional ByVal KeiAk As Boolean = False) As Boolean
On Error GoTo SuErr
'Überprüft, ob das aktuelle Dokument gespeichert werden muss

Dim FiNam As String
Dim BilNa As String
Dim PfaNa As String
Dim DaNam As String
Dim DaNaO As String
Dim TeStr As String
Dim TeNam As String
Dim TmpNa As String
Dim TmGui As String
Dim Posit As Integer
Dim Lange As Integer
Dim AnzPo As Integer
Dim Frage As Integer
Dim SeiPo As Variant

Set FM = frmMain
Set TxCoN = FM.TexCont1
Set CoDia = FM.comDialo
Set LiVw4 = FM.lstView4
Set LiIts = LiVw4.ListItems

AnzPo = LiIts.Count

Screen.MousePointer = vbHourglass
DoEvents

If GlTSV = True Then 'Speichern Textverarbeitung
    If GlTDa <> vbNullString Then 'Textverarbeitung Dateiname
        DaNam = GlTDa
    Else
        If GlTxM = True Then 'Serienbriefmodus
            DaNam = SDaNa()
        Else
            DaNam = SDaNa(GlAdr)
        End If
        GlTDa = DaNam 'Textverarbeitung Dateiname
    End If
    BilNa = Left$(DaNam, Len(DaNam) - 3) & "bmp"
    DoEvents

    If GlTxN = True Then 'Neues Textdokument
        If GlTDa <> vbNullString Then
            If GlTxM = True Then 'Serienbriefmodus
                FiNam = GlVor & DaNam
            Else
                FiNam = GlDox & DaNam
            End If
        Else
            If GlTxM = True Then 'Serienbriefmodus
                FiNam = GlVor & DaNam
            Else
                FiNam = GlDox & DaNam
            End If
        End If
    Else
        If GlTxM = True Then 'Serienbriefmodus
            FiNam = GlVor & DaNam
        Else
            FiNam = GlDox & DaNam
        End If
    End If

    Set clFil = New clsFile
        
    clFil.FilPfa FiNam
    TeNam = clFil.DaNam
    PfaNa = clFil.DaPfa
    DaNaO = clFil.DaNaO
    TeStr = Mid$(TeNam, 9, 1)
    
    If GlTDa = vbNullString Then
        If GlTxM = False Then 'Serienbriefmodus
            If TeStr <> "_" Then
                DaNam = "TD" & Format$(GlAdr, "000000") & "_" & TeNam
            Else
                DaNam = TeNam
            End If
            BilNa = DaNaO & ".bmp"
            TeStr = Right$(TeNam, 4)
            If Left$(TeStr, 3) <> ".tx" Then
                Select Case GlBut
                Case RibTab_Tex_Dokumt: DaNam = DaNam & ".txm"
                Case RibTab_Tex_Vorlag: DaNam = DaNam & ".txm"
                Case RibTab_Tex_Rezept: DaNam = DaNam & ".txr"
                Case RibTab_Tex_NewsLe: DaNam = DaNam & ".txn"
                End Select
            Else
                DaNam = TeNam
            End If
        Else
            TeStr = Right$(DaNam, 4)
            If TeStr <> ".tx" Then
                Select Case GlBut
                Case RibTab_Tex_Dokumt: DaNam = DaNam & ".txm"
                Case RibTab_Tex_Vorlag: DaNam = DaNam & ".txm"
                Case RibTab_Tex_Rezept: DaNam = DaNam & ".txr"
                Case RibTab_Tex_NewsLe: DaNam = DaNam & ".txn"
                End Select
            End If
        End If
    End If
    DoEvents

    If clFil.FilVor(PfaNa & "\" & BilNa) = False Then
        clFil.DaLoe = PfaNa & "\" & BilNa & vbNullChar
        clFil.FilLoe
        DoEvents
    End If

    Set clFil = Nothing

    If GlTxK <> vbNullString Then
        TmpNa = Format$(Date, "yyyy.mm.dd") & " - " & Format$(Now, "hh:mm:ss") & Space$(1) & GlTxK
    Else
        TmpNa = Format$(Date, "yyyy.mm.dd") & " - " & Format$(Now, "hh:mm:ss") & " Textdokument"
    End If
                
    With TxCoN
        .HeaderFooterActivate txMainText
        DoEvents
        SeiPo = .CurrentInputPosition
        SeiPo(0) = 1
        SeiPo(1) = 1
        SeiPo(2) = 0
        .CurrentInputPosition = SeiPo
        DoEvents
        .Save FiNam, 0, 3
    End With
    DoEvents

    If KeiAk = False Then
        If GlTxN = True Then 'neues Textdokument
            GlAkt = True 'WICHTIG!
            Set LiItm = LiIts.Add(, "T" & AnzPo + 1, TmpNa, IC16_Doc_Norm)
            LiItm.Tag = DaNam
            With LiVw4
                .Sorted = True
                .SortKey = 0
                .SortOrder = 1
            End With

            LiItm.Selected = True
            GlAkt = False
        End If
    End If
    
    STxSa = True
End If

If GlTxN = True Then 'Neues Textdokument
    If GlTSV = True Then 'Speichern Textverarbeitung
        If DaNam <> vbNullString Then
            Lange = Len(DaNam)
            If Mid$(DaNam, 9, 1) = "_" And Lange > 30 Then
                TmGui = Mid$(DaNam, 10, 32)
            End If
        
            GlNeK = GlKoX
            With GlNeK
                .PatNr = GlAdr
                .IdxNr = 0
                .EiDat = Format$(Date, "dd.mm.yyyy")
                .EiZei = TimeValue(Now)
                .EiTyp = 24 'Textdokument
                .KoStr = DaNam
                .KoGui = TmGui
                .TeStr = GlTxK 'Info Krankenblatteintrag
                .NeuEi = True
                .Mitar = GlMiA(GlSmI, 2)
            End With
            K_Einf
        End If
    End If
End If

DoEvents
Screen.MousePointer = vbNormal

GlTSV = False 'Speichern Textverarbeitung
GlTxN = False 'Neues Textdokument
GlTxS = False 'Seriendokument

Set CoDia = Nothing

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "STxSa " & Err.Number
Resume Next

End Function
