Resume Next

End Sub
Public Sub SKrGr()
On Error GoTo OpErr
'Gruppiert das Krankenblatt

Dim GrPre As Single
Dim GrCap As String
Dim GrAnz As Integer

Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmCom As XtremeCommandBars.CommandBarComboBox
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCoK As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set RpCo6 = FM.repCont6
Set RpCoK = FM.repContK
Set CmBrs = FM.comBar01
Set CmAcs = CmBrs.Actions

Set CmCom = CmBrs.FindControl(CmCom, SY_KB_KraBla_Grupp, , True)

GlGrK = CmCom.ListIndex

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

GlAkt = True

Screen.MousePointer = vbHourglass
clFen.FenDsk 2

Select Case GlBut
Case RibTab_Krankenbla:
    With RpCoK
        If .SortOrder.Count > 0 Then
            .SortOrder.DeleteAll
        End If
        If .GroupsOrder.Count > 0 Then
            .GroupsOrder.DeleteAll
        End If
        Select Case GlGrK
        Case 2:
            .SortOrder.Add .Columns(Kra_TagSo)
            .GroupsOrder.Add .Columns(Kra_TagSo)
        Case 3:
            .SortOrder.Add .Columns(Kra_Woche)
            .GroupsOrder.Add .Columns(Kra_Woche)
        Case 4:
            .SortOrder.Add .Columns(Kra_Monat)
            .GroupsOrder.Add .Columns(Kra_Monat)
        Case 5:
            .SortOrder.Add .Columns(Kra_Quart)
            .GroupsOrder.Add .Columns(Kra_Quart)
        End Select
        If GlGrK > 1 Then
            Select Case GlSoK
            Case 2: .GroupsOrder(0).SortAscending = False
            Case 1: .GroupsOrder(0).SortAscending = True
            End Select
        End If
        .Populate
        DoEvents
    
        Set RpRws = RpCoK.Rows
        
        For Each RpRow In RpRws
            If RpRow.GroupRow = True Then
                Set RpGrw = RpRow
                Set ChRws = RpGrw.Childs
                GrAnz = ChRws.Count
                If Len(RpGrw.GroupCaption) > 0 Then
                    GrCap = RpGrw.GroupCaption
                    RpGrw.GroupCaption = GrCap & " - Anzahl: " & GrAnz
                End If
            End If
            GrPre = 0
        Next RpRow
    End With
Case RibTab_Abrechnung:
    With RpCoK
        If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
        If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
        Select Case GlGrK
        Case 2:
            .SortOrder.Add .Columns(Kra_TagSo)
            .GroupsOrder.Add .Columns(Kra_TagSo)
        Case 3:
            .SortOrder.Add .Columns(Kra_Woche)
            .GroupsOrder.Add .Columns(Kra_Woche)
        Case 4:
            .SortOrder.Add .Columns(Kra_Monat)
            .GroupsOrder.Add .Columns(Kra_Monat)
        Case 5:
            .SortOrder.Add .Columns(Kra_Quart)
            .GroupsOrder.Add .Columns(Kra_Quart)
        End Select
        If GlGrK > 1 Then
