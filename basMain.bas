Public Function SRtFi(ByVal TmTxt As String) As String
On Error GoTo ReErr

Dim Lange As Long
Dim AktPo As Long
Dim TxStr As String
Dim TmStr As String
Dim TeTtr As String

TxStr = Replace(TmTxt, Chr$(34), vbNullString, 1, , 1)

TmStr = TxStr
Lange = Len(TxStr)

For AktPo = 1 To Lange
    TeTtr = Mid$(TmStr, AktPo, 1)
    If Len(TeTtr) > 0 Then
        If Asc(TeTtr) < 32 Or Asc(TeTtr) > 128 Then
            If ((Lange - AktPo)) > 0 Then
                TmStr = Mid$(TmStr, 1, AktPo - 1) & Mid$(TmStr, AktPo + 1, (Lange - AktPo))
            End If
        End If
    End If
Next AktPo

TeTtr = Right$(TmStr, 1)
If Len(TeTtr) > 0 Then
    If Asc(TeTtr) < 32 Or Asc(TeTtr) > 128 Then
        TmStr = Left$(TmStr, Lange - 1)
    End If
End If

TxStr = Replace(TmStr, Chr$(95), Chr$(45), 1, , 1)
TxStr = Replace(TmStr, vbCrLf, vbNullString, 1, , 1)
TxStr = Replace(TxStr, vbCrLf & vbCrLf, vbNullString, 1, , 1)
TxStr = Replace(TxStr, Chr$(13) & Chr$(10) & Chr$(13) & Chr$(10), vbNullString, 1, , 1)

If Len(TxStr) > 1 Then
    SRtFi = LTrim$(TxStr)
End If

Exit Function

ReErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SRtFi " & Err.Number
Resume Next

End Function
Public Function SRufn(ByVal TeNum As String, Optional ByVal LaCod As String) As String
On Error GoTo ReErr
'Formatiert die Rufnummer

Dim TmStr As String
Dim LaSt2 As String
Dim LaSt3 As String
Dim AkZa1 As Integer
Dim AkZa2 As Integer
Dim Posit As Integer

TmStr = TeNum

If LaCod = vbNullString Then
    LaCod = "0049"
End If

If Left$(TmStr, 1) = "+" Then
    TmStr = "00" & Mid$(TmStr, 2, Len(TmStr) - 1)
End If

For AkZa2 = 1 To 20 'Nur Zahlen zulassen
    For AkZa1 = 0 To 180
        If AkZa1 < 48 Or AkZa1 > 57 Then
            TmStr = Replace(TmStr, Chr$(AkZa1), vbNullString, 1)
        End If
    Next AkZa1
Next AkZa2

LaSt2 = Left$(TmStr, 2)
LaSt3 = Left$(TmStr, 3)

If IsNumeric(LaSt2) = True Then
    If CInt(LaSt2) > 0 Then
        Select Case LaSt3
        Case "001":
        Case "031": TmStr = Replace(TmStr, "031", "0049", 1)
        Case "034": TmStr = Replace(TmStr, "034", "0049", 1)
        Case "035": TmStr = Replace(TmStr, "035", "0049", 1)
        Case "041": TmStr = Replace(TmStr, "041", "0049", 1)
        Case "043": TmStr = Replace(TmStr, "043", "0049", 1)
        Case "049": TmStr = Replace(TmStr, "049", "0049", 1)
        Case Else:
            If Left$(TmStr, 1) = "0" Then
                TmStr = LaCod & Mid$(TmStr, 2, Len(TmStr) - 1)
            Else
                TmStr = LaCod & Mid$(TmStr, 1, Len(TmStr))
            End If
        End Select
    End If
End If

If Mid$(TmStr, 5, 1) = "0" Then
    TmStr = Left$(TmStr, 4) & Mid$(TmStr, 6, Len(TmStr) - 5)
End If

SRufn = TmStr

Exit Function

ReErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SRufn " & Err.Number
Resume Next

End Function
