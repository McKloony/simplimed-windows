Public Sub SPhot(Optional ByVal BiLoe As Boolean, Optional ByVal ImNam As String)
On Error GoTo PoErr
'Lädt das Abtlitzbild

Dim PhoBr As Long
Dim PhoHo As Long
Dim TeiBr As Double
Dim TeiHo As Double
Dim TeiSc As Double
Dim FiNam As String
Dim DaNam As String
Dim PaStr As String
Dim NeuNa As String
Dim NeuDa As String
Dim TmGui As String
Dim DaExt As String

Set FM = frmMain
Set TxDe5 = FM.txtDeta5
Set PiBi1 = FM.picBild1
Set PiBi2 = FM.picBild2
Set CoDia = FM.comDialo

Set clFil = New clsFile

PaStr = "A" & Format$(GlAdr, "000000") & "_"

TmGui = CreateID("D")

If BiLoe = False Then
    If ImNam <> vbNullString Then
        FiNam = ImNam
    Else
        With CoDia
            .CancelError = True
            .DialogStyle = 1
            .DefaultExt = "*.jpg"
            .Filter = "Joint Photographic Experts Group (.jpg)|*.jpg|Windows Bitmap (.bmp)|*.bmp|Portable Network Graphics (.png)|*.png|Tagged Image Format (.tif)|*.tif|Windows Metafile (.wmf)|*.wmf"
            .DialogTitle = "Wo befindet sich die Grafikdatei?"
            .InitDir = GlIPf
            .FileName = vbNullString
            .ShowOpen
            FiNam = .FileName
            If .FileTitle = vbNullString Then
                Set CoDia = Nothing
                Set clFil = Nothing
                Exit Sub
            End If
        End With
    End If
    
    If SNaPr(FiNam) = False Then
        With clFil
            If Not IsNull(FiNam) And Not FiNam = vbNullString Then
                .FilPfa FiNam
                DaNam = .DaNam
                DaExt = .DaExt
                
                NeuDa = PaStr & "_" & TmGui & "." & DaExt
                NeuNa = GlBPf & NeuDa
                                
                If .FilVor(NeuNa) = True Then
                    .DaLoe = NeuNa & vbNullChar
                    .FilLoe
                End If
                .DaCop = FiNam & ";" & NeuNa & vbNullChar
                If .FilCop(1) = False Then
                    SPopu "Datei schreibgeschützt", "Die Datei kann nicht kopiert werden", IC48_Warning
                End If
            End If
        End With

        PiBi2.Picture = LoadPicture(NeuNa)
        PiBi1.ScaleMode = vbPixels
        PiBi2.ScaleMode = vbPixels
        With PiBi1
            .AutoRedraw = True
            .Picture = LoadPicture(vbNullString)
            .Width = 2000
            .Height = 2000
            .Refresh
            .AutoRedraw = False
        End With
        TeiBr = PiBi1.ScaleWidth / PiBi2.ScaleWidth
        TeiHo = PiBi1.ScaleHeight / PiBi2.ScaleHeight
        If PiBi2.ScaleWidth * TeiHo > PiBi1.ScaleWidth Then
            TeiSc = TeiBr
        Else
            TeiSc = TeiHo
        End If
        PhoBr = PiBi2.ScaleWidth * TeiSc
        PhoHo = PiBi2.ScaleHeight * TeiSc
        With PiBi1
            .AutoRedraw = True
            .Width = PhoBr * Screen.TwipsPerPixelX
            .Height = PhoHo * Screen.TwipsPerPixelY
            .Refresh
            .PaintPicture PiBi2.Picture, 0, 0, PhoBr, PhoHo
            .AutoRedraw = False
        End With
        TxDe5.Text = NeuDa
        GlSav = True
        S_KrSv
    Else
        SPopu "Dateiname nicht lesbar", "Der von Ihnen ausgewählte Dateiname kann nicht gelesen werden weil er ggf. Sonderzeichen enthält", IC48_Warning
    End If
Else
    With clFil
        If TxDe5.Text <> vbNullString Then
            NeuNa = GlBPf & TxDe5.Text
            If .FilVor(NeuNa) = True Then
                .DaLoe = NeuNa & vbNullChar
                .FilLoe
            End If
        End If
    End With
    TxDe5.Text = vbNullString
    SSave
    If GlABi = True Then
        SPaBi
    End If
End If

Set CoDia = Nothing

Set clFil = Nothing

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SPhot " & Err.Number
Exit Sub

End Sub
Public Sub SPoGr()
On Error GoTo OpErr
'Gruppiert die Listenansicht

Dim GrSum As Single
Dim GrCap As String
Dim GrAnz As Integer
Dim AktZa As Integer
Dim GrPre() As Single

Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set RpCo1 = FM.repCont1

With RpCo1
    .SortOrder.DeleteAll
    .GroupsOrder.DeleteAll
    If GlKnM > 0 Then
        Select Case GlKnM
        Case 1:
            .SortOrder.Add .Columns(OPo_Datum)
            .GroupsOrder.Add .Columns(OPo_Datum)
        Case 2:
            .SortOrder.Add .Columns(OPo_Monat)
            .GroupsOrder.Add .Columns(OPo_Monat)
        Case 3:
            .SortOrder.Add .Columns(OPo_Stufe)
            .GroupsOrder.Add .Columns(OPo_Stufe)
        Case 4:
            .SortOrder.Add .Columns(OPo_Patient)
            .GroupsOrder.Add .Columns(OPo_Patient)
        Case 5:
            .SortOrder.Add .Columns(OPo_IDP)
            .GroupsOrder.Add .Columns(OPo_IDP)
        End Select
        .GroupsOrder(0).SortAscending = True
    End If
End With
RpCo1.Populate

If GlKnM > 0 Then
    Set RpRws = RpCo1.Rows
    
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            GrSum = 0
            AktZa = AktZa + 1
            ReDim Preserve GrPre(AktZa)
        Else
            If RpRow.Record(OPo_OffBetrag).Value <> vbNullString Then
                If IsNumeric(RpRow.Record(OPo_OffBetrag).Value) Then
                    GrSum = GrSum + RpRow.Record(OPo_OffBetrag).Value
                    GrPre(AktZa) = GrSum
                End If
            End If
        End If
    Next RpRow
    
    AktZa = 0
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            Set RpGrw = RpRow
            If GlGrM = True Then
                RpGrw.Expanded = True
            Else
                RpGrw.Expanded = False
            End If
            Set ChRws = RpGrw.Childs
            GrAnz = ChRws.Count
            AktZa = AktZa + 1
            If Len(RpGrw.GroupCaption) > 0 Then
                GrCap = RpGrw.GroupCaption
                RpGrw.GroupCaption = GrCap & " - Anzahl: " & GrAnz & " - Offen : " & Format$(GrPre(AktZa), GlWa1)
            End If
        End If
    Next RpRow
End If

Set RpCo1 = Nothing

Exit Sub

OpErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SPoGr " & Err.Number
Resume Next

End Sub

