                                    End If
                                End If
                                If GlDoL = True Then 'Dokument nach einf?gen l?schen
                                    If .FilVor(AryIt(AktZa)) = True Then
                                        .DaLoe = AryIt(AktZa) & vbNullChar
                                        .FilLoe
                                    End If
                                End If
                            End If
                        End If

                        GlNeK = GlKoX
                        With GlNeK
                            .PatNr = GlAdr
                            .IdxNr = 0
                            .EiDat = Format$(Date, "dd.mm.yyyy")
                            .EiZei = TimeValue(Now)
                            .EiTyp = EiTyp
