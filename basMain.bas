Private Function STeDa(Optional ByVal PatNr As Long) As String
On Error GoTo OpErr
'Gibt den nächsten Dateinamen vor

Dim PaStr As String
Dim DaNam As String
Dim TmGui As String
Dim AnzDa As Integer
Dim StaNa As Integer
Dim DiNam() As String

Set FM = frmMain

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

TmGui = CreateID("D")

If PatNr > 0 Then
    PaStr = Format$(PatNr, "000000")
    DaNam = "TD" & PaStr & "_" & TmGui & ".pdf"
Else
    If clFil.FilVor(GlVor & "TD*.*") = True Then
        AnzDa = clFil.FilLis(GlVor, "TD*.*", DiNam)
        If AnzDa > 0 Then
            StaNa = CInt(Mid$(DiNam(AnzDa), 3, 6))
            DaNam = "TD" & Format$(StaNa + 1, "000000") & ".pdf"
        Else
            DaNam = "TD000001.pdf"
        End If
    ElseIf clFil.FilVor(GlVor & "td*.*") = True Then
        AnzDa = clFil.FilLis(LCase(GlVor), "td*.*", DiNam)
        If AnzDa > 0 Then
            StaNa = CInt(Mid$(DiNam(AnzDa), 3, 6))
            DaNam = "TD" & Format$(StaNa + 1, "000000") & ".pdf"
        Else
            DaNam = "TD000001.pdf"
        End If
    Else
        DaNam = "TD000001.pdf"
    End If
End If

STeDa = DaNam

Set clFil = Nothing

Exit Function

OpErr:
If GlDbg = True Then MsgBox Err.Description, 48, "STeDa " & Err.Number
Resume Next

End Function
Public Sub STeDe(Optional ByVal HitTy As Boolean = False)
