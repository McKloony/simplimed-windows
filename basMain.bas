                        FilNa = GlBPf & TmpNa
                    End If
            End Select
        End If
        
        Posit = InStrRev(FilNa, ".", Len(FilNa), 1)
        If Posit > 0 Then
            DaExt = LCase(Mid$(FilNa, Posit + 1, Len(FilNa) - Posit))
            FiNam = Mid$(FilNa, 1, Len(FilNa) - (Len(FilNa) - Posit)) & "bmp"
        Else
