Public Sub SFilIm(ByVal FiNam As String, ByVal PatNr As Long)
On Error GoTo LdErr
'Importiertiert eine Datei aus der Dateiverwaltung

Dim DaNam As String
Dim DaNaO As String
Dim NeuNa As String
Dim NeuDa As String
Dim TeFil As String
Dim PfaNa As String
Dim PaStr As String
Dim TmGui As String
Dim DaExt As String
Dim TypNa As String
Dim EiTyp As Integer

Set clFil = New clsFile

If PatNr > 0 Then
    PaStr = "P" & Format$(PatNr, "000000")
    TmGui = CreateID("D")
    If Not IsNull(FiNam) And Not FiNam = vbNullString Then
        If SNaPr(FiNam) = False Then
            With clFil
                .FilPfa FiNam
                DaNam = .DaNam
                DaExt = .DaExt
                DaNaO = .DaNaO
                DaNaO = SUmw(DaNaO, True, True, True, True)

                Select Case LCase(DaExt)
                Case "pdf":
                    TypNa = "PDF-Dokument"
                    PfaNa = GlBPf
                    EiTyp = 105
                Case "jpg":
                    TypNa = "Bilddokument"
                    PfaNa = GlBPf
                    EiTyp = 105
                Case "jpeg":
                    TypNa = "Bilddokument"
                    PfaNa = GlBPf
                    EiTyp = 105
                Case "png":
                    TypNa = "Bilddokument"
                    PfaNa = GlBPf
                    EiTyp = 105
                Case "psd":
                    TypNa = "Bilddokument"
                    PfaNa = GlBPf
                    EiTyp = 105
                Case "bmp":
                    TypNa = "Bilddokument"
                    PfaNa = GlBPf
                    EiTyp = 105
                Case "tif":
                    TypNa = "Bilddokument"
                    PfaNa = GlBPf
                    EiTyp = 105
                Case "tiff":
                    TypNa = "Bilddokument"
                    PfaNa = GlBPf
                    EiTyp = 105
                Case "gif":
                    TypNa = "Bilddokument"
                    PfaNa = GlBPf
                    EiTyp = 105
                Case "wmf":
                    TypNa = "Bilddokument"
                    PfaNa = GlBPf
                    EiTyp = 105
                Case "emf":
                    TypNa = "Bilddokument"
                    PfaNa = GlBPf
                    EiTyp = 105
                Case "doc":
                    TypNa = "Textdokument"
                    PfaNa = GlDox
                    EiTyp = 102
                Case "docx":
                    TypNa = "Textdokument"
                    PfaNa = GlDox
                    EiTyp = 102
                 Case "docx":
                    TypNa = "Textdokument"
                    PfaNa = GlDox
                    EiTyp = 102
                Case "xlsx":
                    TypNa = "Excel-Dokument"
                    PfaNa = GlDox
                    EiTyp = 102
                Case "xls":
                    TypNa = "Excel-Dokument"
                    PfaNa = GlDox
                    EiTyp = 102
                Case "rtf":
                    TypNa = "Textdokument"
                    PfaNa = GlDox
                    EiTyp = 102
                Case "txm":
                    TypNa = "Textdokument"
                    PfaNa = GlDox
                    EiTyp = 24
                Case "txn":
                    TypNa = "Textdokument"
                    PfaNa = GlDox
                    EiTyp = 24
                Case "txr":
                    TypNa = "Textdokument"
                    PfaNa = GlDox
                    EiTyp = 24
                Case "txt":
                    TypNa = "Textdokument"
                    PfaNa = GlDox
                    EiTyp = 24
                Case "eml":
                    TypNa = "Textdokument"
                    PfaNa = GlDox
                    EiTyp = 102
                Case "msg":
                    TypNa = "Textdokument"
                    PfaNa = GlDox
                    EiTyp = 102
                Case Else:
                    Set clFil = Nothing
                    SPopu "Ungültiger Dateityp", "Der von Ihnen ausgewählte Dateityp kann nicht geöffnet werden", IC48_Warning
                    Exit Sub
                End Select

                TeFil = PfaNa & DaNam
                If LCase(TeFil) <> LCase(FiNam) Then
                    NeuDa = PaStr & "_" & TmGui & "#_" & DaNaO & "." & LCase(DaExt)
                    NeuNa = PfaNa & NeuDa

                    If .FilVor(NeuNa) = True Then
                        .DaLoe = NeuNa & vbNullChar
                        .FilLoe
                    End If
                    .DaCop = FiNam & ";" & NeuNa & vbNullChar
                    If .FilCop(1) = False Then
                        SPopu "Datei schreibgeschützt", "Die Datei kann nicht kopiert werden", IC48_Warning
                    End If

                    GlNeK = GlKoX
                    With GlNeK
                        .PatNr = PatNr
                        .IdxNr = 0
                        .EiDat = Format$(Date, "dd.mm.yyyy")
                        .EiZei = TimeValue(Now)
                        .EiTyp = EiTyp
                        .KoStr = NeuDa
                        .KoGui = TmGui
                        .TeStr = TypNa
                        .NeuEi = True
                        .Mitar = GlMiA(GlSmI, 2)
                    End With
                    K_Einf
                    DoEvents
                    SPopu "Dateiimport", "Die Datei: " & NeuDa & " wurde erfolgreich importiert.", IC48_Information
                End If
            End With
        Else
            SPopu "Dateiname nicht lesbar", "Der von Ihnen ausgewählte Dateiname kann nicht gelesen werden weil er ggf. Sonderzeichen enthält", IC48_Warning
        End If
    End If
End If

Set clFil = Nothing
Set CoDia = Nothing

Exit Sub

LdErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SFilIm " & Err.Number
Exit Sub

End Sub
