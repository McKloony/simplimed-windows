                If Left$(DaNam, 1) <> "." Then
                    If DaExt = "pdf" Then
                        TmStr = "PDF-Dokument"
                    Else
                        TmStr = "Bilddokument"
                    End If
                    If .FilVor(NeuNa) = True Then
                        .DaLoe = NeuNa & vbNullChar
                        .FilLoe
                    End If
                    .DaCop = FiNam & ";" & NeuNa & vbNullChar
                    If .FilCop(1) = True Then
                        DoEvents
                        GlNeK = GlKoX
                        With GlNeK
                            .PatNr = GlAdr
                            .IdxNr = 0
                            .EiDat = Format$(Date, "dd.mm.yyyy")
                            .EiZei = TimeValue(Now)
                            .EiTyp = 105 'Bilddatei
                            .KoStr = NeuDa
                            .KoGui = TmGui
                            .TeStr = TmStr
                            .NeuEi = True
                            .Mitar = GlMiA(GlSmI, 2)
                        End With
                        K_Einf
                        DoEvents
                        If FilNa = vbNullString Then
