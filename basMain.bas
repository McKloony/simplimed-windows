        .InitDir = GlImO
        .FileName = vbNullString
        .ShowOpen
        FiNam = .FileName
        If .FileTitle = vbNullString Then
            Set CoDia = Nothing
            Set clFil = Nothing
            Exit Sub
        End If
    End With
Else
    FiNam = FilNa
End If

