                FilNa = GlDox & DaNam

                If EmSen = False Then 'Emailversand
                    Select Case LCase$(Right$(DaNam, 3))
                    Case "txm"
                        SKrTv DaNam, RibTab_Tex_Dokumt, ShoCut_Texte, LiIts, True
                    Case "txr"
                        SKrTv DaNam, RibTab_Tex_Rezept, ShoCut_Texte, LiIts, True
                    Case "eml", "msg"
                        SKrFlAu FilNa, clFil
                    Case Else
                        If clFil.FilVor(FilNa) = True Then
                            clAnw.AnNam = "WinWord"
                            If clAnw.AnwSu > 0 Then
                                OpnWo = 3
                            Else
                                OpnWo = 1
                            End If
                            With clWor
                                .OPeTyp = OpnWo
                                .DoSchu = False
                                .FilNam = FilNa
                                .DocSav = False
                                .FWoUbe
                            End With
                            clVor.VoSet
                        Else
                            SPopu "Dokument nicht gefunden", "Das Dokument kann unter dem angegebenen Pfad nicht gefunden werden oder wurde geloescht", IC48_Warning
                        End If
                    End Select
                End If
            Case 101: 'Rezepte und Belege
                If EmSen = False Then 'Emailversand
                    Set RpCol = RpCls.Find(Kra_Bezeichnung)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        TmpNa = RpRow.Record(RpCol.ItemIndex).Value
                    End If
                    Set RpCol = RpCls.Find(Kra_IDR)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        If IsNumeric(RpRow.Record(RpCol.ItemIndex).Value) Then
                            ReNum = RpRow.Record(RpCol.ItemIndex).Value
                            If InStr(1, TmpNa, "Quittung", vbTextCompare) > 0 Then
                                SRzZe ReNum, True
                            ElseIf InStr(1, TmpNa, "Bescheinigung", vbTextCompare) > 0 Then
                                SRzZe ReNum, True
                            Else
                                SRzZe ReNum
                            End If
                        End If
                    End If
                End If
            Case 106: 'Rechnungen
                If EmSen = False Then 'Emailversand
                    Set RpCol = RpCls.Find(Kra_IDR)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        If IsNumeric(RpRow.Record(RpCol.ItemIndex).Value) Then
                            ReNum = RpRow.Record(RpCol.ItemIndex).Value
                            If GlRch(0, 9) = 1 Then
                                SReZe 0, True
                            Else
                                WindowMess "Sie besitzen keine Berechtigung fuer diesen Vorgang", Dial3, Tit1, FM.hwnd
                            End If
                        End If
                    End If
                End If
            Case 102: 'Dateien
                Set RpCol = RpCls.Find(Kra_Typname) 'Kra_Bezeichnung
                TmpNa = RpRow.Record(RpCol.ItemIndex).Value
                DaNam = TmpNa
                If InStr(1, TmpNa, "\", vbTextCompare) > 0 Then 'Falls ganzer Pfad gespeichert ist
                    clFil.FilPfa TmpNa
                    DaNam = clFil.DaNam
                    FilNa = GlDox & DaNam
                Else
                    Select Case EinTy
                    Case 24:  DaPfa = GlDox  'Textdokumente
                    Case 102: DaPfa = GlDox  'Datei
                    Case 105: DaPfa = GlBPf  'Bilddatei
                    Case Else:  DaPfa = GlDox
                    End Select
                    FilNa = DaPfa & TmpNa
                End If
                If clFil.FilVor(FilNa) = True Then
                    clFil.FilPfa FilNa
                    DaExt = clFil.DaExt
                    Select Case LCase(DaExt)
                    Case "txm"
                        If EmSen = False Then
                            SKrTv DaNam, RibTab_Tex_Dokumt, ShoCut_Texte, LiIts, False
                        End If
                    Case "txr"
                        If EmSen = False Then
                            SKrTv DaNam, RibTab_Tex_Rezept, ShoCut_Texte, LiIts, False
                        End If
                    Case "eml", "msg"
                        If EmSen = False Then
                            SKrFlAu FilNa, clFil
                        End If
                    Case "doc"
                        If EmSen = True Then
                            SKrEm KrDat, MitNr, ManNr, DoNam, FilNa, clFil, True
                        Else
                            SKrWoKv Tit1, Mld1, Mld2, Mld3, FilNa, DaNam, KrDat, KrZei, TmpNa, IdxNr, 9, frmMain.hwnd
                        End If
                    Case "docx"
                        If EmSen = True Then
                            SKrEm KrDat, MitNr, ManNr, DoNam, FilNa, clFil
                        Else
                            SKrWoKv Tit1, Mld1, Mld2, Mld3, FilNa, DaNam, KrDat, KrZei, TmpNa, IdxNr, 13, frmMain.hwnd
                        End If
                    Case Else
                        If EmSen = True Then
                            SKrEm KrDat, MitNr, ManNr, DoNam, FilNa, clFil
                        Else
                            SKrDaOf DaExt, FilNa, DaNam, clFil
                        End If
                    End Select
                Else 'Wenn Datei nicht im angegebenen Ordner gefunden wurde
                    FilNa = GlBPf & TmpNa
                    If clFil.FilVor(FilNa) = True Then
                        clFil.FilPfa FilNa
                        DaExt = clFil.DaExt
                        If EmSen = True Then
                            SKrEm KrDat, MitNr, ManNr, DoNam, FilNa, clFil
                        Else
                            SKrDaOf DaExt, FilNa, DaNam, clFil
                        End If
                    Else
                        SPopu "Datei nicht gefunden", "Die Datei kann unter dem angegebenen Pfad nicht gefunden werden oder wurde geloescht", IC48_Forbidden
                    End If
                End If
            Case 105: 'Bilddateien
                Set RpCol = RpCls.Find(Kra_Typname) 'Kra_Bezeichnung
                TmpNa = RpRow.Record(RpCol.ItemIndex).Value
                DaNam = TmpNa
                If InStr(1, TmpNa, "\", vbTextCompare) > 0 Then
                    clFil.FilPfa TmpNa
                    DaNam = clFil.DaNam
                    FilNa = GlDox & DaNam
                Else
                    Select Case EinTy
                    Case 24: DaPfa = GlDox
                    Case 102: DaPfa = GlDox
                    Case 105: DaPfa = GlBPf
                    Case Else: DaPfa = GlDox
                    End Select
                    FilNa = DaPfa & TmpNa
                End If
                If clFil.FilVor(FilNa) = True Then
                    clFil.FilPfa FilNa
                    DaExt = clFil.DaExt
                    If EmSen = True Then
                        SKrEm KrDat, MitNr, ManNr, DoNam, FilNa, clFil
                    ElseIf DaExp = True Then
                        If GlRDP = True Then
                            If clFil.FilDir(GlIPf) = False Then
                                ImOrd = GlDpf & "Import\"
                            Else
                                ImOrd = GlIPf
                            End If
                        Else
                            If clFil.FilDir(GlImO) = False Then
                                ImOrd = GlEPf 'Exportordner
                            Else
                                ImOrd = GlExO
                            End If
                        End If
                        If Right$(ImOrd, 1) <> "\" Then
                            ImOrd = ImOrd & "\"
                        End If
                        With CoDia
                            Select Case DaExt
                            Case "jpg": .DefaultExt = "*.jpg"
                                        .Filter = "Joint Photographic Experts Group (.jpg)|*.jpg|Alle Dateien (*.*)|*.*"
                            Case "png": .DefaultExt = "*.png"
                                        .Filter = "Portable Network Graphics (.png)|*.png|Alle Dateien (*.*)|*.*"
                            Case "tif": .DefaultExt = "*.tif"
                                        .Filter = "Tagged Image Format (.tif)|*.tif|Alle Dateien (*.*)|*.*"
                            Case "bmp": .DefaultExt = "*.bmp"
                                        .Filter = "Windows Bitmap Format (.bmp)|*.bmp|Alle Dateien (*.*)|*.*"
                            Case "gif": .DefaultExt = "*.gif"
                                        .Filter = "Graphics Interchange (.gif)|*.gif|Alle Dateien (*.*)|*.*"
                            Case "pdf": .DefaultExt = "*.pdf"
                                        .Filter = "Adobe-Acrobat Dokument (.pdf)|*.pdf|Alle Dateien (*.*)|*.*"
                            Case "doc": .DefaultExt = "*.doc"
                                        .Filter = "Microsof-Word 2003 Dokument (.doc)|*.doc|Alle Dateien (*.*)|*.*"
                            Case "docx": .DefaultExt = "*.docx"
                                        .Filter = "Microsof-Word 2007 Dokument (.docx)|*.docx|Alle Dateien (*.*)|*.*"
                            Case Else:  .DefaultExt = "*.*"
                                        .Filter = "Alle Dateien (*.*)|*.*"
                            End Select
                            .CancelError = True
                            .DialogStyle = 1
                            .DialogTitle = "Bitte Name und Ordner der Datei angeben"
                            .FileName = ImOrd & DaNam
                            .InitDir = ImOrd
                            .ShowSave
                            NeuNa = .FileName
                            If .FileTitle = vbNullString Then Exit Sub
                        End With
                        With clFil
                            If .FilVor(NeuNa) = True Then
                                .DaLoe = NeuNa & vbNullChar
                                .FilLoe
                            End If
                            .DaCop = FilNa & ";" & NeuNa & vbNullChar
                            .FilCop 1
                        End With
                    ElseIf DaUpl = True Then 'Downloadlink
                        Tit1 = "Downloadlink"
                        Mld1 = "Soll fuer das markierte Dokument jetzt ein Downloadlink generiert werden?"
                        Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
                        If Frage = 6 Then
                            With GlTxV
                                .TxStr = GlEmT(9, 3)
                                .Datum = KrDat
                                .MitNr = MitNr
                                .ManNr = ManNr
                                .DoNam = DoNam
                                .PatNr = GlAdr
                            End With
                            EmBet = SEmTx()
                            With GlTxV
                                .TxStr = GlEmT(9, 1)
                                .Datum = KrDat
                                .MitNr = MitNr
                                .ManNr = ManNr
                                .DoNam = DoNam
                                .PatNr = GlAdr
                            End With
                            EmTex = EmTex & vbCrLf & vbCrLf & SEmTx()
                            Posit = InStr(1, DaNam, "#_", 1)
                            Lange = Len(DaNam)
                            If Posit > 0 Then
                                DaNam = Mid$(DaNam, Posit + 2, Lange - Posit)
                            End If
                            NeuNa = GlEPf & DaNam
                            With clFil
                                If .FilVor(NeuNa) = True Then
                                    .DaLoe = NeuNa & vbNullChar
                                    .FilLoe
                                End If
                                .DaCop = FilNa & ";" & NeuNa & vbNullChar
                                .FilCop 1
                            End With
                            DoEvents
                            TmStr = SMCUp(NeuNa, GlAdr)
                            DoEvents

                            If TmStr <> vbNullString Then
                                Lange = Len(TmStr)
                                Posit = InStr(1, TmStr, ";", 1)
                                If Posit > 0 Then
                                    S_AdDe GlAdr 'Adressendetails
                                    With GlADt
                                        EmEmp = .AdTe5
                                        EmBrf = .AdBrf
                                    End With
                                    DoLnk = Left$(TmStr, Posit - 1)
                                    FoLnk = Mid$(TmStr, Posit + 1, Lange - Posit)
                                    With GlTxV
                                        .TxStr = GlEmT(13, 1)
                                        .MitNr = MitNr
                                        .ManNr = ManNr
                                        .Datum = KrDat
                                        .DoNam = DoNam
                                        .DoLan = GlVrw
                                        .DoLnk = DoLnk
                                        .PoLnk = FoLnk
                                        .DoLan = GlVrw
                                        .PatNr = GlAdr
                                    End With
                                    EmTex = SEmTx()
                                    SMaNe GlAdr, EmEmp, , EmBrf & vbCrLf & vbCrLf & EmTex, EmBet
                                End If
                            End If
                        End If
                    Else
                        SKrDaOf DaExt, FilNa, DaNam, clFil
                    End If
                Else 'Wenn Datei nicht im angegebenen Ordner gefunden wurde
                    With clFil
                        .FilPfa FilNa
                        DaExt = .DaExt
                        DaNaO = .DaNaO
                        DaPfa = .DaPfa & "\"
                        AnzDa = .FilLis(DaPfa, DaNaO & ".*", DiNam)
                    End With
                    If AnzDa > 0 Then
                        DaNam = DiNam(1)
                        FilNa = DaPfa & DaNam
                        If clFil.FilVor(FilNa) = True Then
                            SKrDaOf DaExt, FilNa, DaNam, clFil
                        Else
                            SPopu "Datei nicht gefunden", "Die Datei kann unter dem angegebenen Pfad nicht gefunden werden oder wurde geloescht", IC48_Forbidden
                        End If
                    Else
                        SPopu "Datei nicht gefunden", "Die Datei kann unter dem angegebenen Pfad nicht gefunden werden oder wurde geloescht", IC48_Forbidden
                    End If
                End If
            Case 108: 'Emails
                MaiNr = S_MaGui(GuiID)
                DoEvents
                If MaiNr > 0 Then
                    Screen.MousePointer = vbHourglass
                    DoEvents
                    GlNaT = 1 'Mailtyp (1=View 2=Neu 3=Antwort)
                    MaMain MaiNr, GlAdr
                    Screen.MousePointer = vbNormal
                End If
            Case Is > 20:
                SKoEd
            End Select
        End If
    End If
End Select

Set clFil = Nothing
Set clWor = Nothing
Set clVor = Nothing
Set clAnw = Nothing

Set RpCls = Nothing
Set RpSel = Nothing
Set RpCo6 = Nothing
Set RpCoK = Nothing

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SKrDo " & Err.Number
Resume Next

End Sub

Public Sub SKrDr(Optional ByVal EmVer As Integer)
On Error GoTo PoErr
'Druckt das Krankenblatt

Dim ManNr As Long
Dim MitNr As Long
Dim SQL1 As String
Dim ForNa As String
Dim LoNam As String
Dim FiNam As String
Dim Krit1 As String
Dim Krit2 As String
Dim EmAdr As String
Dim EmTex As String
Dim EmBet As String
Dim AktPo As Integer
Dim Formu As Boolean

MitNr = GlMiA(GlSmI, 2) 'Standardmitarbeiter

If GlMen = True Then 'Krankenblattdokument
    If EmVer > 0 Then
        STxMa True, True 'Dokument als Email
    Else
        STxMa False, False 'Dokument Drucken
    End If
    Exit Sub
