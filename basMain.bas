    TeFus = "Um ein E-Mail-Konto hinzuzufügen, wechseln Sie in das Modul: Textverarbeitung und dann oben auf Emails. Dort klicken Sie auf die Schaltfläche Emailkonten."
    SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, True, FM.hwnd
    Exit Sub
End If

Set clFil = New clsFile

If GlMkt(1, 13) <> vbNullString Then
    AbEmr = GlMkt(1, 13)
Else
    If GlThe(GlSMa, 16) <> vbNullString Then
        AbEmr = GlThe(GlSMa, 16)
    End If
End If

If GlMiA(GlSmI, 11) <> vbNullString Then
    SigNa = GlMiA(GlSmI, 11)
Else
    SigNa = GlMiA(GlSmI, 1)
End If

GesZa = RpSel.Count

If DocMa = False Then
    If GesZa > 0 Then
        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                If AdAry(Adr_Telefon5, RpRow.Index) <> vbNullString Then
                    If GesZa = 1 Then
                        PatNr = AdAry(Adr_ID0, RpRow.Index)
                    Else
                        PatNr = 0
                    End If
                    If EmAdr = vbNullString Then
                        EmAdr = AdAry(Adr_Telefon5, RpRow.Index)
                    Else
                        EmAdr = EmAdr & ";" & AdAry(Adr_Telefon5, RpRow.Index) ' Semikolon Trennzeichen
                    End If
                    If AdAry(Adr_Briefanrede, RpRow.Index) <> vbNullString Then
                        EmBrf = AdAry(Adr_Briefanrede, RpRow.Index)
                    Else
                        EmBrf = vbNullString
                    End If
                End If
            End If
        Next RpRow
    End If

    If GesZa > 1 Then
        If EmBrf <> vbNullString Then
            EmBrf = Left$(EmBrf, Len(EmBrf) - 1)
        Else
            EmBrf = vbNullString
        End If
        SMaNe PatNr, AbEmr, EmAdr
    Else
        If EmAdr <> vbNullString Then
            SMaNe PatNr, EmAdr, , EmBrf
        Else
            SPopu "Keine Emailadresse", "Für dieses Emailkonto wurde keine Emailadresse angegeben", IC48_Warning
        End If
    End If
Else
    With CoDia
        .CancelError = True
        .DialogStyle = 1
        .DialogTitle = "Bitte Name und Ordner der Datei angeben"
        .DefaultExt = "*.pdf"
        .Filter = "Adobe-Acrobat Dokument (*.pdf)|*.pdf|Microsoft Word 2002/2003 (.doc)|*.doc|Rich Text Format (.rtf)|*.rtf|ANSI-Textdatei (.txt)|*.txt|Hypertext Markup Language (.htm)|*.htm|Alle Dateien (*.*)|*.*"
        .InitDir = GlVor
        .FileName = vbNullString
        .ShowOpen
        FiNam = .FileName
        If .FileTitle = vbNullString Then
            Set RpSel = Nothing
            Set RpRow = Nothing
            Set RpCol = Nothing
            Set RpCls = Nothing
            Set RpCo2 = Nothing
            Set clFil = Nothing
            Exit Sub
        End If
    End With
    If Not IsNull(FiNam) And Not FiNam = vbNullString Then
        With clFil
            .FilPfa FiNam
            DaNam = .DaNaO
        End With
        If GesZa > 0 Then
            Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
            If Frage = 6 Then
                frmStatus.Show
                DoEvents
                frmStatus.Caption = "Emailversand"
                Set PrBr1 = frmStatus.prbStat1
                Set PrBr2 = frmStatus.prbStat2
                PrBr1.Min = 0
                PrBr1.Max = GesZa
    
                For Each RpRow In RpSel
                    If RpRow.GroupRow = False Then
                        If AdAry(Adr_Telefon5, RpRow.Index) <> vbNullString Then
                            EmAdr = AdAry(Adr_Telefon5, RpRow.Index)
                            If AdAry(Adr_Briefanrede, RpRow.Index) <> vbNullString Then
                                EmBrf = AdAry(Adr_Briefanrede, RpRow.Index)
                            Else
                                EmBrf = vbNullString
                            End If
                            EmTex = EmBrf & vbCrLf & vbCrLf & GlEmT(9, 1) & vbCrLf & vbCrLf & SigNa
                            EmVer = SEmSe(EmAdr, DaNam, EmTex, FiNam)
                            DoEvents
                            If EmVer = True Then
                                If PatNr > 0 Then
                                    EmTex = Replace(EmTex, vbCrLf, Space$(1), 1)
                                    EmTex = Trim$(EmTex)
                                    TmGui = CreateID("E")
                                    GlNeK = GlKoX
                                    With GlNeK
                                        .PatNr = PatNr
                                        .IdxNr = 0
                                        .EiDat = Format$(Date, "dd.mm.yyyy")
                                        .EiZei = TimeValue(Now)
                                        .EiTyp = 108 'Email
                                        .KoStr = EmTex
                                        .KoGui = TmGui
                                        .NeuEi = True
                                        .Mitar = GlMiA(GlSmI, 2)
                                    End With
                                    K_Einf
                                End If
                            End If
                            DoEvents
                        End If
                        DoEvents
                        AktZa = AktZa + 1
                        If AktZa <= GesZa Then PrBr1.Value = AktZa
                    End If
                Next RpRow
                Unload frmStatus
                DoEvents
            End If
        End If
    End If
End If

Set RpSel = Nothing
Set RpRow = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo2 = Nothing

Set clFil = Nothing

Exit Sub

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SEmNe " & Err.Number
Resume Next

End Sub

Public Function SEmSe(ByVal EmpAd As String, ByVal MaBet As String, ByVal MaTex As String, Optional ByVal MaFil As String, Optional ByVal MaHtm As String, Optional ByVal EmpNa As String, Optional ByVal MaPro As Boolean = True, Optional ByVal NoPop As Boolean = False) As Boolean
On Error GoTo DaErr
'Sendet eine Email

Dim MitNr As Long
Dim ManNr As Long
Dim Mld1 As String
Dim TmStr As String
Dim TmHtm As String
Dim SigDa As String
Dim VeStr As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim RetWe As Integer
Dim AktZa As Integer
Dim NeTLS As Integer
Dim GesZa As Integer
Dim KoGef As Boolean

Mld1 = "Es wurde kein Emailkonto angelegt oder dessen Angaben sind unvollst?ig!"

If GlEKV = False Then 'Emailkonten vorhanden
    TeTit = "E-Mail-Versand"
    TeMai = "Es ist kein E-Mail-Konto vorhanden"
    TeInh = "Um E-Mails versenden zu können, ist es notwendig mind. ein E-Mail-Konto hinzuzufügen."
    TeFus = "Um ein E-Mail-Konto hinzuzufügen, wechseln Sie in das Modul: Textverarbeitung und dann oben auf Emails. Dort klicken Sie auf die Schaltfläche Emailkonten."
    SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, True, FM.hwnd
    Exit Function
End If

SEmSe = False

ManNr = GlMan(GlSMa, 2)
MitNr = GlMiA(GlSmI, 2)

GesZa = UBound(GlMkt)

If GlMiA(GlSmI, 25) <> vbNullString Then
    If Right$(LCase(GlMiA(GlSmI, 25)), 3) <> "txn" Then
        SigDa = GlVor & GlMiA(GlSmI, 25)
    End If
End If

If GesZa > 0 Then
    For AktZa = 1 To GesZa
        If CLng(GlMkt(AktZa, 1)) = MitNr Then
            If CBool(GlMkt(AktZa, 20)) = True Then 'Standardemailkonto
                KoGef = True
                Exit For
            End If
        End If
    Next AktZa
End If

If KoGef = False Then
    SPopu "Kein SMTP-Server", Mld1, IC48_Warning
    Exit Function
End If

If SEmAd(EmpAd) = False Then
    Exit Function
End If

If MaHtm = vbNullString Then
    If MaTex <> vbNullString Then
        TmStr = Replace(MaTex, vbCrLf, "<br>", 1)
        TmHtm = "<!doctype html> <html> <head> <meta charset='utf-8'> <title>" & MaBet & "</title> <meta name='generator' content='SimpliMed'> </head> <body> <span style='color:#000000;font-family:" & GlEFt.Name & ";font-size:" & Round(GlEFt.SIZE) + 3 & "px;'>" & TmStr & "</span></div> </body> </html>"
        MaHtm = TmHtm
    End If
End If

Set clMai = New clsMailing

With clMai
    If GlMkt(AktZa, 7) <> vbNullString Then
        .moSMTP = GlMkt(AktZa, 7)
    Else
        SPopu "Kein SMTP-Server", Mld1, IC48_Warning
        Exit Function
    End If
    If GlMkt(AktZa, 9) <> vbNullString Then
        .moPor2 = GlMkt(AktZa, 9)
    Else
        SPopu "Kein SMTP-Port", Mld1, IC48_Warning
        Exit Function
    End If
    If CBool(GlMkt(AktZa, 15)) = True Then
        If GlMkt(AktZa, 10) <> vbNullString Then
            .moUsNa = GlMkt(AktZa, 10)
        Else
            SPopu "Kein Usernamen", Mld1, IC48_Warning
            Exit Function
        End If
        If GlMkt(AktZa, 11) <> vbNullString Then
            .moUsPa = GlMkt(AktZa, 11)
        Else
            SPopu "Kein Userpaswort", Mld1, IC48_Warning
            Exit Function
        End If
    End If
    If GlMkt(AktZa, 12) <> vbNullString Then
        .moSeNa = GlMkt(AktZa, 12)
    End If
    If GlMkt(AktZa, 13) <> vbNullString Then
        .moSeAd = GlMkt(AktZa, 13)
    End If
    If GlMkt(AktZa, 14) <> vbNullString Then
        .moSeRe = GlMkt(AktZa, 14)
    End If
    .moAnon = 0
    .moPrio = 3
    .moAsyn = 1
    .moReAd = EmpAd
    .moReNa = EmpNa
    .moBest = False
    .moTLSs = CInt(GlMkt(AktZa, 4))
    .moAuUs = CBool(GlMkt(AktZa, 15))
    .moSubj = MaBet
    .moImag = SigDa
    .moProg = MaPro
    If MaFil <> vbNullString Then
        .moAtFi = MaFil
    End If
    If MaHtm <> vbNullString Then
        .moFrmt = 1
        .moTxHt = MaHtm
        If MaTex <> vbNullString Then
            .moTxAc = MaTex
        End If
    Else
        .moFrmt = 0
        .moTxHt = MaTex
        .moTxAc = MaTex
    End If
    RetWe = .MaiSen()
    DoEvents
    NeTLS = .moTLSs
End With

Set clMai = Nothing

If NeTLS <> GlMkt(AktZa, 4) Then
    Select Case NeTLS
    Case 0: VeStr = "SSL"
    Case 1: VeStr = "TLS"
    Case 2: VeStr = "Auto"
    End Select
    SPopu "TLS/SSL Prüfen", "Bitte ändern Sie die SSL/TLS Einstellung auf : " & VeStr, IC48_Information
End If

If RetWe = 0 Then
    If NoPop = False Then
        SPopu "Nachricht wurde versandt", "Die Nachricht wurde an " & EmpAd & " versandt.", IC48_Information
    End If
ElseIf RetWe = 1 Then
    SPopu "Emailversand abgebrochen", "Der Emailversand wurde abgebrochen.", IC48_Warning
Else
    SPopu "Emailversand fehlerhaft", "Der Emailversand war fehlerhaft.", IC48_Warning
End If

SEmSe = True

Exit Function

DaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SEmSe " & Err.Number
Resume Next

End Function
Public Function SEmTx() As String
On Error GoTo DaErr
'Esetzt die Variablen im E-Email-Betreff und Text

Dim TxStr As String
Dim TmStr As String
Dim ManNa As String
Dim MitNa As String
Dim AktPo As Integer
Dim Lange As Integer
Dim Posi1 As Integer
Dim Posi2 As Integer

If GlTxV.TxStr <> vbNullString Then
    TxStr = GlTxV.TxStr
Else
    If GlMiK(GlSmI, 27) <> vbNullString Then
        MitNa = GlMiK(GlSmI, 27)
    Else
        MitNa = GlMiK(GlSmI, 1) 'Standardmitarbeiter
    End If
    SEmTx = MitNa
    Exit Function
End If

If InStr(1, TxStr, "{", 1) = 0 Then
    SEmTx = TxStr
    Exit Function
End If

AktPo = 1
Lange = Len(TxStr)

Do
Posi1 = InStr(AktPo, TxStr, "{", 1)
If Posi1 > 0 Then
    Posi2 = InStr((Posi1 + 1), TxStr, "}", 1)
    If Posi2 > 0 Then
        TmStr = Mid$(TxStr, Posi1, (Posi2 - Posi1) + 1)
        TxStr = Replace(TxStr, TmStr, LCase(TmStr), 1)
        AktPo = Posi2 + 1
    End If
End If
Loop Until Posi1 = 0

If InStr(1, TxStr, "{mandant}", 1) > 0 Then
    If GlTxV.ManNr > 0 Then
        For AktPo = 1 To UBound(GlMan)
            If CLng(GlTxV.ManNr) = CLng(GlMan(AktPo, 2)) Then
                If GlMan(AktPo, 32) <> vbNullString Then
                    ManNa = GlMan(AktPo, 32)
                Else
                    ManNa = GlMan(AktPo, 1)
                End If
                TxStr = Replace(TxStr, "{mandant}", ManNa, 1)
                Exit For
            End If
        Next AktPo
    Else
        TxStr = Replace(TxStr, "{mandant}", vbNullString, 1)
        SEmTx = TxStr
    End If
End If

If InStr(1, TxStr, "{mitarbeiter}", 1) > 0 Then
    If GlTxV.MitNr > 0 Then
        For AktPo = 1 To UBound(GlMiK)
            If CLng(GlTxV.MitNr) = CLng(GlMiK(AktPo, 2)) Then
                If GlMiK(AktPo, 27) <> vbNullString Then
                    MitNa = GlMiK(AktPo, 27)
                Else
                    MitNa = GlMiK(AktPo, 1)
                End If
                TxStr = Replace(TxStr, "{mitarbeiter}", MitNa, 1)
                Exit For
            End If
        Next AktPo
    Else
        TxStr = Replace(TxStr, "{mitarbeiter}", vbNullString, 1)
        SEmTx = TxStr
    End If
End If

If InStr(1, TxStr, "{rechnung}", 1) > 0 Then
    TxStr = Replace(TxStr, "{rechnung}", GlTxV.ReStr, 1)
End If

If InStr(1, TxStr, "{datum}", 1) > 0 Then
    If GlTxV.DaStr <> vbNullString Then
        TxStr = Replace(TxStr, "{datum}", GlTxV.DaStr, 1)
    ElseIf GlTxV.Datum <> "00:00:00" Then
        TxStr = Replace(TxStr, "{datum}", GlTxV.Datum, 1)
    End If
End If

If InStr(1, TxStr, "{startzeit}", 1) > 0 Then
    TxStr = Replace(TxStr, "{startzeit}", GlTxV.ZeiSt, 1)
End If

If InStr(1, TxStr, "{endzeit}", 1) > 0 Then
    TxStr = Replace(TxStr, "{endzeit}", GlTxV.ZeiEn, 1)
End If

If InStr(1, TxStr, "{dateiname}", 1) > 0 Then
    TxStr = Replace(TxStr, "{dateiname}", GlTxV.DaNam, 1)
End If

If InStr(1, TxStr, "{dokument}", 1) > 0 Then
    TxStr = Replace(TxStr, "{dokument}", GlTxV.DoNam, 1)
End If

If InStr(1, TxStr, "{direktlink}", 1) > 0 Then
    TxStr = Replace(TxStr, "{direktlink}", GlTxV.DoLnk, 1)
End If

If InStr(1, TxStr, "{portallink}", 1) > 0 Then
    TxStr = Replace(TxStr, "{portallink}", GlTxV.PoLnk, 1)
End If

If InStr(1, TxStr, "{termine}", 1) > 0 Then
    TxStr = Replace(TxStr, "{termine}", GlTxV.Termi, 1)
End If

If InStr(1, TxStr, "{passwort}", 1) > 0 Then
    TxStr = Replace(TxStr, "{passwort}", GlTxV.PasWo, 1)
End If

If InStr(1, TxStr, "{gültigkeit}", 1) > 0 Then
    TxStr = Replace(TxStr, "{gültigkeit}", GlTxV.DoLan, 1)
End If

If InStr(1, TxStr, "{patient}", 1) > 0 Then
    TxStr = Replace(TxStr, "{patient}", GlTxV.PaStr, 1)
End If

If InStr(1, TxStr, "{terminid}", 1) > 0 Then
    TxStr = Replace(TxStr, "{terminid}", GlTxV.TerID, 1)
End If

If InStr(1, TxStr, "{pin}", 1) > 0 Then
    TxStr = Replace(TxStr, "{pin}", Format$(GlTxV.PatNr, "000000"), 1)
End If

If InStr(1, TxStr, "{cr}", 1) > 0 Then
    TxStr = Replace(TxStr, "{cr}", vbCrLf, 1)
End If

If InStr(1, TxStr, "{cr}", 1) > 0 Then
    TxStr = Replace(TxStr, "{cr}", vbCrLf, 1)
