        .DruDia = True
        .Gesamt = False
        .Kriter = SQL1
        .MandVo = True
        .MitaVo = GlMiV
        .ArztVo = GlArV
        If EmVer > 0 Then
            .EmlAdr = EmAdr
            .EmlBet = EmBet
            .EmlTex = EmTex
            .EmlDia = True
            .EmlSen = EmVer
        End If
        .LLPrLi
    End With
End If

ReDim GloDr(0)

Set clLis = Nothing
Set clFil = Nothing

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SKrDr " & Err.Number
Resume Next

End Sub
Public Sub SKrEi()
On Error GoTo PoErr
'Kontrolloert die Eingabe in der starren Eingabezeile

