Public Function STele(TelNr As String) As String
On Error GoTo DrErr

Dim TmSt1 As String
Dim TmSt2 As String
Dim AkZa1 As Integer
Dim AkZa2 As Integer
Dim Posi1 As Integer
Dim Posi2 As Integer
Dim Posi3 As Integer

If Len(TelNr) > 3 Then
    TmSt1 = TelNr
    
    If InStr(1, TelNr, ")", 1) > 0 Then
        If InStr(1, TelNr, "(", 1) > 0 Then
            Posi3 = InStr(1, TelNr, ")", 1) - 1
        Else
            Posi3 = InStr(1, TelNr, ")", 1)
        End If
    ElseIf InStr(1, TelNr, Chr$(32), 1) > 0 Then
        If Left$(TelNr, 1) = "+" Then
            Posi3 = InStr(5, TelNr, Chr$(32), 1)
        Else
            Posi3 = InStr(1, TelNr, Chr$(32), 1)
        End If
    ElseIf InStr(1, TelNr, "-", 1) > 0 Then
        Posi3 = InStr(1, TelNr, "-", 1)
    ElseIf InStr(1, TelNr, "/", 1) > 0 Then
        Posi3 = InStr(1, TelNr, "/", 1)
    Else
        Posi3 = 6
    End If
    
    For AkZa2 = 1 To 20
        For AkZa1 = 30 To 165
            If AkZa1 < 48 Or AkZa1 > 57 Then
                If AkZa1 <> 43 Then
                    TmSt1 = Replace(TmSt1, Chr$(AkZa1), vbNullString, 1)
                End If
            End If
        Next AkZa1
    Next AkZa2
    
    If Left$(TmSt1, 1) = "+" Then
        If Posi3 > 0 Then
            TmSt2 = Left$(TmSt1, 3) & "(" & Mid$(TmSt1, 4, Posi3 - 1) & ")" & Mid$(TmSt1, 9, Len(TmSt1) - (Posi3 - 1))
        End If
    Else
        TmSt2 = "(" & Left$(TmSt1, Posi3 - 1) & ")" & Mid$(TmSt1, Posi3, Len(TmSt1) - (Posi3 - 1))
    End If
End If

STele = TmSt2

Exit Function

DrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "STele " & Err.Number
Resume Next

End Function
