Public Function SDaFi1(ByVal SuTyp As Integer) As String
On Error GoTo LaErr
'Generiert einen Filterstring

Dim Krit1 As String
Dim KrTyp As Integer
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmTyp As XtremeCommandBars.CommandBarComboBox

Set FM = frmMain
Set CmBrs = FM.comBar01
Set TrLi5 = FM.trvList5

Set CmTyp = CmBrs.FindControl(CmTyp, SY_KB_KraBla_Typen, , True)

Select Case SuTyp
Case 1:
    KrTyp = CmTyp.ListIndex
    Select Case KrTyp
    Case 1:
        Krit1 = KrTyp
    Case 2:
        Krit1 = KrTyp
    Case 3:
        Krit1 = KrTyp
    Case 4:
        Krit1 = KrTyp
    Case Else:
        If (KrTyp - 3) > 0 Then
            If GlTyp < 2 Then
                Krit1 = "((Typ = " & GlKrA(KrTyp - 3, 0) & "))"
            Else
                Krit1 = "(([Typ] = " & GlKrA(KrTyp - 3, 0) & "))"
            End If
        Else
            If GlTyp < 2 Then
                Krit1 = "(Typ = 1)"
            Else
                Krit1 = "([Typ] = 1)"
            End If
        End If
    End Select
Case 2:
    For Each Knote In TrLi5.Nodes
        If Knote.Index > 1 Then
            If Knote.Checked = False Then
                If Len(Knote.Key) = 4 Then
                    KrTyp = Right$(Knote.Key, 3)
                ElseIf Len(Knote.Key) = 3 Then
                    KrTyp = Right$(Knote.Key, 2)
                ElseIf Len(Knote.Key) = 2 Then
                    KrTyp = Right$(Knote.Key, 1)
                End If
                If Krit1 = vbNullString Then
                    If GlTyp < 2 Then
                        Krit1 = "((Typ <> " & KrTyp & ")"
                    Else
                        Krit1 = "(([Typ] <> " & KrTyp & ")"
                    End If
                Else
                    If GlTyp < 2 Then
                        Krit1 = Krit1 & " AND (Typ <> " & KrTyp & ")"
                    Else
                        Krit1 = Krit1 & " AND ([Typ] <> " & KrTyp & ")"
                    End If
                End If
            End If
        End If
    Next Knote
    If Krit1 <> vbNullString Then Krit1 = Krit1 & ")"
End Select

SDaFi1 = Krit1

Exit Function

LaErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SDaFi1 " & Err.Number
Resume Next

End Function
Public Function SDaFi2(ByVal SuTyp As Integer) As String
On Error GoTo LaErr
