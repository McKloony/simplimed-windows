Public Sub SRzZe(ByVal RzNum As Long, Optional ByVal BelVe As Boolean = False)
On Error GoTo InErr
'Zeigt das Krankenblatt mit der zugehörigen Rechnung

Dim IdxNr As Long
Dim RowNr As Long
Dim AktZa As Integer
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set RpCo5 = FM.repCont5
Set RpCls = RpCo5.Columns
Set RpSel = RpCo5.SelectedRows
Set RpRws = RpCo5.Rows

If BelVe = True Then
    GlBu2 = RibTab_Belegmodul
    STaSe ShoCut_Kranken, RibTab_Belegmodul
Else
    GlBu2 = RibTab_Rezeptmodul
    STaSe ShoCut_Kranken, RibTab_Rezeptmodul
End If
DoEvents

If RzNum > 0 Then
    For Each RpRow In RpRws
        Set RpCol = RpCls.Find(Rzp_ID1)
        IdxNr = RpRow.Record(RpCol.ItemIndex).Value
        
        If IdxNr = RzNum Then
            RowNr = RpRow.Index
            RpRws.Row(0).Selected = False
            RpRws.Row(RowNr).EnsureVisible
            RpRws.Row(RowNr).Selected = True
            If GlFoc = True Then
                Set RpCo5.FocusedRow = RpRws.Row(RowNr)
            End If
            S_RzLa
            Exit For
        End If
    Next RpRow
Else
    If RpRws.Count > 0 Then
        RpRws(0).Selected = True
        S_RzLa
    End If
End If

Set RpCls = Nothing
Set RpSel = Nothing
Set RpRws = Nothing
Set RpCo5 = Nothing

Exit Sub

InErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SRzZe " & Err.Number
Resume Next

End Sub
