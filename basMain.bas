                        Else
                            If GlRDP = True Then
                                If GlDoL = False Then 'Dokument nach einf?gen l?schen
                                    SMeFr TeTit, TeMai, TeInh, TeFus, True, 1, False, FM.hwnd, TeFra
                                    If GlMso = True Then 'Mesage Dialog Option
                                        IniSetVal "System", "DokEin", -1
                                        S_SeSe 86, , , , True
