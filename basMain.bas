Public Sub SAbGr()
On Error GoTo OpErr
'Gruppiert die Abrechung

Dim GrPre As Single
Dim GrCap As String
Dim GrAnz As Integer

Dim CmBrs As XtremeCommandBars.CommandBars
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set RpCo6 = FM.repCont6
Set CmBrs = FM.comBar01
Set CmAcs = CmBrs.Actions

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

GlAkt = True

Screen.MousePointer = vbHourglass
clFen.FenDsk 2

With RpCo6
    If GlGrA = False Then 'Gruppierung Abrechnung
        .SortOrder.Add .Columns(Kra_TagSo)
        .GroupsOrder.Add .Columns(Kra_TagSo)
        Select Case GlSoA 'Sortierung Abrechnung
        Case 1: .GroupsOrder(0).SortAscending = False
        Case 2: .GroupsOrder(0).SortAscending = True
        End Select
    Else
        .SortOrder.DeleteAll
        .GroupsOrder.DeleteAll
    End If
    .Populate
    DoEvents

    GlGrA = Not GlGrA

    Set RpRws = RpCo6.Rows
    
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            Set RpGrw = RpRow
            Set ChRws = RpGrw.Childs
            GrAnz = ChRws.Count
            For Each ChRow In ChRws
                If IsNumeric(ChRow.Record.Item(Kra_GesBetrag).Value) Then
                    GrPre = GrPre + ChRow.Record.Item(Kra_GesBetrag).Value
                End If
            Next ChRow
            If Len(RpGrw.GroupCaption) > 0 Then
                GrCap = RpGrw.GroupCaption
                Select Case GlBut
                Case RibTab_Krankenbla:
                    If GlUm2 = 1 Then 'Alle Einträge
                        RpGrw.GroupCaption = GrCap & " - Anzahl: " & GrAnz & " - Summe: " & Format$(GrPre, GlWa1)
                    Else
                        RpGrw.GroupCaption = GrCap & " - Anzahl: " & GrAnz
                    End If
                Case RibTab_Abrechnung:
                    RpGrw.GroupCaption = GrCap & " - Anzahl: " & GrAnz & " - Summe: " & Format$(GrPre, GlWa1)
                    If GlExA = True Then
                        RpGrw.Expanded = True
                    Else
                        RpGrw.Expanded = False
                    End If
                Case RibTab_Tagesproto:
                    RpGrw.GroupCaption = GrCap & " - Anzahl: " & GrAnz
                    If GlExT = True Then
                        RpGrw.Expanded = True
                    Else
                        RpGrw.Expanded = False
                    End If
                End Select
            End If
        End If
        GrPre = 0
    Next RpRow
End With

CmAcs(SY_AB_Abrech_Expan).Enabled = GlGrA
CmAcs(SY_AB_Abrech_Grupp).Checked = GlGrA
IniSetVal "Layout", "GruAbr", GlGrA

clFen.FenDsk 3
Screen.MousePointer = vbNormal

Set CmAct = Nothing
Set CmBrs = Nothing
Set RpRws = Nothing
Set RpCo6 = Nothing

Set clFen = Nothing

GlAkt = False

Exit Sub

OpErr:
If GlDbg = True Then SErLog Err.Description & " SAbGr " & Err.Number
Resume Next

End Sub
