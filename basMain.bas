Public Function SBuFo(ByVal KntNr As Long) As String
On Error GoTo OpErr
'Sachkontenformatierung

Dim KntSt As String
Dim KoStr As String
Dim Lange As Integer

If KntNr = 0 Then
    If GlKnF = False Then 'Sachkontenformatierung sechsstellig
        KntSt = "0000"
    Else
        KntSt = "000000"
    End If
Else
    KoStr = CStr(KntNr)
    
    If GlKnF = False Then 'Sachkontenformatierung
        Lange = Len(KoStr)
        If Lange = 1 Then
            KntSt = KoStr & "000"
        ElseIf Lange = 2 Then
            KntSt = KoStr & "00"
        ElseIf Lange = 3 Then
            KntSt = KoStr & "0"
        ElseIf Lange = 4 Then
            KntSt = KoStr
        ElseIf Lange > 4 Then
            KntSt = Left$(KoStr, 4)
        Else
            KntSt = Format$(KntNr, "0000")
        End If
    Else
        Lange = Len(KoStr)
        If Lange = 1 Then
            KntSt = KoStr & "00000"
        ElseIf Lange = 2 Then
            KntSt = KoStr & "0000"
        ElseIf Lange = 3 Then
            KntSt = KoStr & "000"
        ElseIf Lange = 4 Then
            KntSt = KoStr & "00"
        ElseIf Lange = 5 Then
            KntSt = KoStr & "0"
        ElseIf Lange = 6 Then
            KntSt = KoStr
        ElseIf Lange > 6 Then
            KntSt = Left$(KoStr, 6)
        Else
            KntSt = Format$(KntNr, "000000")
        End If
    End If
End If

SBuFo = KntSt

Exit Function

OpErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SBaSo " & Err.Number
Resume Next

End Function
Public Sub SBiEi(Optional ByVal FilNa As String)
On Error GoTo CrErr
'Kopiert ein neues Bild in den Bilderordner und benennt dieses um

