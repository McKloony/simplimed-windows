Public Sub SKrZe(Optional ByVal PaNum As Long)
On Error GoTo InErr
'Zeigt die Abrechung mit der zugehörigen Rechnung

Dim PaSto As Boolean
Dim RpCo2 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmMain
Set RpCo2 = FM.repCont2
Set RpCls = RpCo2.Columns
