            If clFil.FilVor(FilNa) = True Then
                With clInf
                    .FilePath = FilNa
                    .ReadData
                    Labl9.Caption = .DisplayInfo
                End With
            Else
                SPopu "Datei nicht gefunden", "Die Datei kann unter dem angegebenen Pfad nicht gefunden werden oder wurde gelöscht", IC48_Forbidden
            End If
        Case 102: 'Datei
            If GlP06 = False Then 'Flyoutfenster ist geöffnet
                If clFil.FilVor(FilNa) = True Then
                    With clInf
                        .FilePath = FilNa
                        .ReadData
                        Labl9.Caption = .DisplayInfo
                    End With
                Else
                    FilNa = GlBPf & TmpNa
                    If clFil.FilVor(FilNa) = True Then
                        With clInf
                            .FilePath = FilNa
                            .ReadData
                            Labl9.Caption = .DisplayInfo
                        End With
                    Else
                        SPopu "Datei nicht gefunden", "Die Datei kann unter dem angegebenen Pfad nicht gefunden werden oder wurde gelöscht", IC48_Forbidden
                    End If
                End If
            End If
        Case 105: 'Bilddatei
            If GlP06 = False Then 'Flyoutfenster ist geöffnet
                If clFil.FilVor(FilNa) = True Then
                    With clInf
                        .FilePath = FilNa
                        .ReadData
                        Labl9.Caption = .DisplayInfo
                    End With
                Else
                    SPopu "Datei nicht gefunden", "Die Datei kann unter dem angegebenen Pfad nicht gefunden werden oder wurde gelöscht", IC48_Forbidden
                End If
            End If
        Case 106: 'Rechnungskommentar
            Labl9.Caption = vbNullString
        Case Else:
            For AktZa = 1 To UBound(GlKrA)
                If EinTy = GlKrA(AktZa, 0) Then
                    FaWer = GlKrA(AktZa, 3)
                    Exit For
                End If
            Next AktZa
            If Mid$(TmKTF, 1, 1) = "1" Then
                Labl9.Font.Bold = True
            Else
                Labl9.Font.Bold = False
            End If
            If Mid$(TmKTF, 2, 1) = "1" Then
                Labl9.Font.Italic = True
            Else
                Labl9.Font.Italic = False
            End If
            If Mid$(TmKTF, 3, 1) = "1" Then
                Labl9.Font.Underline = True
            Else
                Labl9.Font.Underline = False
            End If
            If Mid$(TmKTF, 4, 1) = "1" Then
                Labl9.Font.Strikethrough = True
            Else
                Labl9.Font.Strikethrough = False
            End If
            If Mid$(TmKTF, 5, 1) = "L" Then
                Labl9.Alignment = xtpEditAlignLeft
            ElseIf Mid$(TmKTF, 5, 1) = "R" Then
                Labl9.Alignment = xtpEditAlignRight
            ElseIf Mid$(TmKTF, 5, 1) = "Z" Then
                Labl9.Alignment = xtpEditAlignCenter
            Else
                Labl9.Alignment = xtpEditAlignLeft
            End If
            If Mid$(TmKTF, 6, 8) <> vbNullString Then
                Labl9.ForeColor = CLng(Mid$(TmKTF, 6, 8))
            Else
                Labl9.ForeColor = 0
            End If
            If Mid$(TmKTF, 14, 8) <> vbNullString Then
                If IsNumeric(Mid$(TmKTF, 14, 8)) = True Then
                    Labl9.BackColor = CLng(Mid$(TmKTF, 14, 8))
                Else
                    Labl9.BackColor = 16777215
                End If
            Else
                Labl9.BackColor = 16777215
            End If
            If Mid$(TmKTF, 22, 2) <> vbNullString Then
                Labl9.Font.SIZE = CLng(Mid$(TmKTF, 22, 2))
            Else
                Labl9.Font.SIZE = GlKFt.SIZE
            End If
            If Len(TmKTF) > 23 Then
                Labl9.Font.Name = Mid$(TmKTF, 24, Len(TmKTF) - 23)
            Else
                Labl9.Font.Name = "Arial"
            End If
            With Labl9
