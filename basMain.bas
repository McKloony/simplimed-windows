Public Function SModw(ByVal ErgWe As Long) As Variant
On Error GoTo ReErr

Dim TmpWe As Long
Dim AktZa As Long
Dim TmpSt As String

Do
AktZa = AktZa + 1
TmpWe = ErgWe Mod 2
If TmpWe <> 0 Then TmpSt = TmpSt & 2 ^ (AktZa - 1) & ";"
ErgWe = ErgWe \ 2
Loop Until ErgWe = 0

SModw = Split(TmpSt, ";")

Exit Function

ReErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SModw " & Err.Number
Resume Next

End Function
Public Function SMSize(ByVal lngBytes As Long) As String
On Error Resume Next

Dim lngKB As Long

lngKB = Int(lngBytes / 1024)

If lngKB < 1 Then lngKB = 1

SMSize = Replace(Format$(lngKB, "###,###"), ",", ".") & " KB"

End Function
Public Function SNaFi(ByVal TeStr As String, Optional ByVal Leerz As Boolean = False, Optional ByVal Umlau As Boolean = True, Optional ByVal LeeSt As Boolean = True, Optional ByVal Erwei As Boolean = False) As String
On Error GoTo LiErr
'Filtert einen Dateinamen ohne Sonderzeichen und Umlaute

Dim TmStr As String
Dim AkZa1 As Integer
Dim AkZa2 As Integer
Dim StaZa As Integer
Dim Posit As Integer

TmStr = TeStr

TmStr = Trim$(TmStr)

If Erwei = True Then
    StaZa = 40
Else
    StaZa = 45
End If

TmStr = Replace(TmStr, vbCrLf, Space$(1), 1) 'Zeilenumbruch

If LeeSt = True Then
    For AkZa2 = 1 To 10 'das Sonderzeichen darf max. 10x im String vorkommen
        TmStr = Replace(TmStr, Chr$(32) & Chr$(32), Chr$(32), 1)
    Next AkZa2
End If

If Erwei = True Then
    For AkZa2 = 1 To 10 'das Sonderzeichen darf max. 10x im String vorkommen
        TmStr = Replace(TmStr, Chr$(95), vbNullString, 1) '_
        TmStr = Replace(TmStr, Chr$(59), vbNullString, 1) ';
    Next AkZa2
End If

For AkZa2 = 1 To 10 'das Sonderzeichen darf max. 10x im String vorkommen
    For AkZa1 = 30 To 180
        If (AkZa1 < StaZa Or AkZa1 > 122) Then
            Select Case AkZa1
            Case 10:
            Case 13:
            Case 32: If Leerz = True Then TmStr = Replace(TmStr, Chr$(32), vbNullString, 1)
            Case 45: TmStr = Replace(TmStr, "-", vbNullString, 1)
            Case 129: If Umlau = True Then TmStr = Replace(TmStr, "ü", "ue", 1)
            Case 132: If Umlau = True Then TmStr = Replace(TmStr, "ä", "ae", 1)
            Case 142: If Umlau = True Then TmStr = Replace(TmStr, "Ä", "Ae", 1)
            Case 148: If Umlau = True Then TmStr = Replace(TmStr, "ö", "oe", 1)
            Case 153: If Umlau = True Then TmStr = Replace(TmStr, "Ö", "Oe", 1)
            Case 154: If Umlau = True Then TmStr = Replace(TmStr, "Ü", "Ue", 1)
            Case 225: If Umlau = True Then TmStr = Replace(TmStr, "ß", "ss", 1)
            Case Else: TmStr = Replace(TmStr, Chr$(AkZa1), vbNullString, 1)
            End Select
        End If
    Next AkZa1
Next AkZa2


SNaFi = TmStr

Exit Function

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SNaFi " & Err.Number
Resume Next

End Function
Public Function SNaPr(ByVal FiNam As String) As Boolean
On Error GoTo LiErr
'Überprüft einen Dateinamen auf Sonderzeichen und Umlaute

Dim DaNam As String
Dim DaNaO As String
Dim TeStr As String
Dim Posit As Integer
Dim AktZa As Integer
Dim GesZa As Integer
Dim NamFa As Boolean

Posit = InStrRev(FiNam, "\")
If Posit > 0 Then
    DaNam = Right$(FiNam, Len(FiNam) - Posit)
    Posit = InStrRev(DaNam, ".")
    If Posit > 0 Then
        DaNaO = Left$(DaNam, Posit - 1)
        GesZa = Len(DaNaO)
        For AktZa = 1 To GesZa
            TeStr = Mid$(DaNaO, AktZa, 1)
            If Asc(TeStr) > 122 Then
                Select Case Asc(TeStr)
                Case 123: '{
                Case 125: '}
                Case 129: 'ü
                Case 132: 'ä
                Case 142: 'Ä
                Case 148: 'ö
                Case 153: 'Ö
                Case 154: 'Ü
                Case 225: 'ß
                Case 196: 'Ä ANSI
                Case 220: 'Ü ANSI
                Case 214: 'Ö ANSI
                Case 228: 'ä ANSI
                Case 252: 'ü ANSI
                Case 246: 'ö ANSI
                Case 223: 'ß ANSI
                Case Else:
                    NamFa = True
                    Exit For
                End Select
            ElseIf Asc(TeStr) < 48 Then
                Select Case Asc(TeStr)
                Case 32: 'Leerzeichen
                Case 35: '#
                Case 40: '(
                Case 41: ')
                Case 44: ',
                Case 45: '-
                Case 46: '.
                Case 95: '_
                Case Else:
                    NamFa = True
                    Exit For
                End Select
            Else
                NamFa = False
            End If
        Next AktZa
        If Left$(DaNaO, 1) = "." Then
            NamFa = True
        End If
    End If
End If

SNaPr = NamFa

Exit Function

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SNaPr " & Err.Number
Resume Next

End Function
