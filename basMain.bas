Public Sub SFilSu()
On Error GoTo LdErr
'Lädt alle Dateien mit der Endung *.sql in ein Array

Dim FiNam As String
Dim TrKey As String
Dim AnzDa As Integer
Dim AktZa As Integer
Dim DiNam() As String

Set FM = frmMain
Set TrLi1 = FM.trvList1

Set clFil = New clsFile

If clFil.FilVor(GlFPf & "*.sql") = True Then
    AnzDa = clFil.FilLis(GlFPf, "*.sql", DiNam)
    If AnzDa > 0 Then
        For AktZa = 1 To UBound(DiNam)
            TrKey = "F" & Format$(AktZa + 1, "0000")
            FiNam = DiNam(AktZa)
            Set Knote = TrLi1.Nodes.Add("P804", 4, TrKey, FiNam, IC16_Doc_View)
        Next AktZa
    End If
End If

Set clFil = Nothing

Exit Sub

LdErr:
If GlDbg = True Then SErLog Err.Description & " SFilSu " & Err.Number
Resume Next

End Sub
Public Function SFiNa(ByVal FilNa As String) As String
On Error GoTo LdErr
'Gibt den Datgeinamen eines Pfades zurück

Dim DaNam As String
Dim Posit As Integer

If Mid$(FilNa, 2, 1) = ":" Then
    DaNam = Right(FilNa, Len(FilNa) - 3)
End If

Posit = InStrRev(FilNa, "\")
If Posit > 0 Then
    DaNam = Right$(FilNa, Len(FilNa) - Posit)
Else
    DaNam = vbNullString
End If

SFiNa = DaNam
    
Exit Function

LdErr:
If GlDbg = True Then SErLog Err.Description & " SFiNa " & Err.Number
Resume Next

End Function

