        .TableCellSelect TabId, 1, 3
        .FontBold = True
        .FontSize = 11
        .SelText = "Praxisinformation"
    Case 2:
        .TableCellSelect TabId, 1, 2
        .FontBold = True
        .FontSize = 11
        .SelText = "Einladung"
    End Select
    
    '----------
    
    Select Case VoTyp 'Salvatorisches
    Case 1:
        .TableCellSelect TabId, 5, 2
        .FontBold = False
        .FontSize = 8
        .SelText = "Diese Email erhalten Sie als Patient des oben genannten Absenders. Wenn Sie keine weiteren Informationen per Email erhalten möchten, senden Sie uns bitte eine Nachricht mit dem Betreff: Newsletter abbestellen."
    Case 2:
        .TableCellSelect TabId, 5, 3
        .FontBold = False
        .FontSize = 8
        .SelText = "Diese Email erhalten Sie als Patient des oben genannten Absenders. Wenn Sie keine weiteren Informationen per Email erhalten möchten, senden Sie uns bitte eine Nachricht mit dem Betreff: Newsletter abbestellen."
    End Select
    
    '----------
    
    Select Case VoTyp 'Siagnatur
