        With TxCoN
            .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellVertAlign) = 1
            .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellBorderWidth) = RaBr2
            .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellPageBreakAllowed) = True
            .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHeight) = 500
            If AkSpa = 1 Then
                .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 4000
