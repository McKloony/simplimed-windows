If IsNull(TxEin.Text) Then
    TxEin.Text = GlWa2
ElseIf IsNumeric(TxEin.Text) = False Then
    TxEin.Text = GlWa2
Else
    EinBe = CSng(Format$(TxEin.Text, GlWa1))
    TxEin.Text = Format$(TxEin.Text, GlWa1)
