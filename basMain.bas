Public Sub SReGr()
On Error GoTo OpErr
'Gruppiert die Rechnungsübersicht

Dim GrSum As Single
Dim GrCap As String
Dim GrAnz As Integer
Dim AktZa As Integer
Dim GrPre() As Single

Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set RpCo4 = FM.repCont4

With RpCo4
    .SortOrder.DeleteAll
    .GroupsOrder.DeleteAll
    If GlKnR > 0 Then
        Select Case GlKnR
        Case 1:
            .SortOrder.Add .Columns(Rec_Datum)
            .GroupsOrder.Add .Columns(Rec_Datum)
        Case 2:
            .SortOrder.Add .Columns(Rec_Monat)
            .GroupsOrder.Add .Columns(Rec_Monat)
        Case 3:
            .SortOrder.Add .Columns(Rec_Selekt)
            .GroupsOrder.Add .Columns(Rec_Selekt)
        Case 4:
            .SortOrder.Add .Columns(Rec_Storniert)
            .GroupsOrder.Add .Columns(Rec_Storniert)
        Case 5:
            .SortOrder.Add .Columns(Rec_IDP)
            .GroupsOrder.Add .Columns(Rec_IDP)
        End Select
        .GroupsOrder(0).SortAscending = False
    End If
End With
RpCo4.Populate

If GlKnR > 0 Then
    Set RpRws = RpCo4.Rows
    
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            GrSum = 0
            AktZa = AktZa + 1
            ReDim Preserve GrPre(AktZa)
        Else
            If RpRow.Record(Rec_Betrag).Value <> vbNullString Then
                If IsNumeric(RpRow.Record(Rec_Betrag).Value) Then
                    GrSum = GrSum + RpRow.Record(Rec_Betrag).Value
                    GrPre(AktZa) = GrSum
                End If
            End If
        End If
    Next RpRow
    
    AktZa = 0
    For Each RpRow In RpRws
        If RpRow.GroupRow = True Then
            Set RpGrw = RpRow
            If GlGrR = True Then
                RpGrw.Expanded = True
            Else
                RpGrw.Expanded = False
            End If
            Set ChRws = RpGrw.Childs
            GrAnz = ChRws.Count
            AktZa = AktZa + 1
            If Len(RpGrw.GroupCaption) > 0 Then
                GrCap = RpGrw.GroupCaption
                RpGrw.GroupCaption = GrCap & " - Anzahl: " & GrAnz & " - Gesamt : " & Format$(GrPre(AktZa), GlWa1)
            End If
        End If
    Next RpRow
End If

Set RpCo4 = Nothing

Exit Sub

OpErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SReGr " & Err.Number
Resume Next

End Sub
