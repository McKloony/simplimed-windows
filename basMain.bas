Public Sub SAdTx(Optional ByVal MsTyp As String, Optional ByVal ExpOr As Boolean)
On Error GoTo LiErr
'Exporiert / Importiert Adressen im THEDEX Format

Dim FiNam As String  'Dateinamen
Dim DirNa As String  'Pfadname
Dim TmStr As String
Dim MesTy As String
Dim PfaNa As String
Dim StaZa As Integer 'Stapelzahl
Dim AktZa As Integer
Dim AnzDa As Integer
Dim RetWe As Boolean
Dim DiNam() As String
Dim TxDum As VB.TextBox

Set FM = frmMain
Set CoDia = FM.comDialo

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

If ExpOr = True Then 'Export
    If GlRDP = True Then
        DirNa = GlIPf
    Else
        DirNa = GlEPf
    End If

    If clFil.FilVor(DirNa & "*.tdx") = True Then
        AnzDa = clFil.FilLis(DirNa, "SimpliMed" & "*.tdx", DiNam)
        If AnzDa > 0 Then
            StaZa = Val(Mid$(DiNam(AnzDa), Len("SimpliMed") + 1, 4)) + 1
        Else
            StaZa = 1
        End If
    Else
        StaZa = 1
    End If
    
    FiNam = DirNa & "SimpliMed" & Format$(StaZa, "0000") & ".tdx"

    TmStr = "[Thedex]" & vbCrLf
    TmStr = TmStr & "ThedexVersionNumber=1.7" & vbCrLf
    TmStr = TmStr & "[Sender]" & vbCrLf
    TmStr = TmStr & "SenderIdentification=SimpliMed" & vbCrLf
    TmStr = TmStr & "SenderVerification=" & vbCrLf
    TmStr = TmStr & "SenderDescription=SimpliMed23" & vbCrLf
    TmStr = TmStr & "SenderSoftwareVersionInformation=11.00" & vbCrLf
    TmStr = TmStr & "SenderLanIdentification=SimpliMed" & vbCrLf
    TmStr = TmStr & "[Message]" & vbCrLf
    TmStr = TmStr & "MessageType=" & MsTyp & vbCrLf
    TmStr = TmStr & "MessageCountryInformation=049" & vbCrLf
    TmStr = TmStr & "MessageCodePageInformation=ANSI" & vbCrLf
    TmStr = TmStr & "MessageDate=" & Format$(Date, "ddmmyyyy") & vbCrLf
    TmStr = TmStr & "MessageTime=" & Format$(TimeValue(Now), "hh:mm") & vbCrLf
    TmStr = TmStr & "[Client]" & vbCrLf
    TmStr = TmStr & "CSenderInternalIdentification=" & GlTDx.CSenderInternalIdentification & vbCrLf
    TmStr = TmStr & "CExternalIdentification=" & GlTDx.CExternalIdentification & vbCrLf
    TmStr = TmStr & "CLastName=" & GlTDx.CLastName & vbCrLf
    TmStr = TmStr & "CFirstName=" & GlTDx.CFirstName & vbCrLf
    TmStr = TmStr & "CBirthday=" & GlTDx.CBirthday & vbCrLf
    TmStr = TmStr & "CSex=" & GlTDx.CSex & vbCrLf
    TmStr = TmStr & "CStreet=" & GlTDx.CStreet & vbCrLf
    TmStr = TmStr & "CZip=" & GlTDx.CZip & vbCrLf
    TmStr = TmStr & "CTown=" & GlTDx.CTown & vbCrLf
    TmStr = TmStr & "CCountryCode=" & GlTDx.CCountryCode & vbCrLf
    TmStr = TmStr & "CCountry=" & GlTDx.CCountry & vbCrLf
    TmStr = TmStr & "CFax=" & GlTDx.CFax & vbCrLf
    TmStr = TmStr & "InsuranceID=" & GlTDx.InsuranceID & vbCrLf
    TmStr = TmStr & "InsuranceClientID=" & GlTDx.InsuranceClientID & vbCrLf
    TmStr = TmStr & "InsuranceStatus=" & GlTDx.InsuranceStatus & vbCrLf
    TmStr = TmStr & "ClinicDepartment=" & GlTDx.ClinicDepartment & vbCrLf
    TmStr = TmStr & "ClinicRoomNumber=" & GlTDx.ClinicRoomNumber & vbCrLf
    TmStr = TmStr & "CustomerAccount=" & GlTDx.CustomerAccount & vbCrLf
    TmStr = TmStr & "eMail=" & GlTDx.Email & vbCrLf
    TmStr = TmStr & "CellularPhone=" & GlTDx.CellularPhone & vbCrLf
    
    With clFil
        .FilPfa FiNam
        .StrDa = TmStr
        RetWe = .FilWrSt
    End With

    If MsTyp <> "ClientInfo" Then
        SPopu "THEDEX Export", "Es wurde THEDEX Nachricht exportiert", IC48_Information
    End If
    
Else 'Import

    With CoDia
        .CancelError = True
        .DialogStyle = 1
        .DialogTitle = "Wo befindet sich der richtige Ordner?"
        .FileName = GlIPf
        RetWe = .ShowBrowseFolder
        PfaNa = .FileName
        If RetWe = 0 Then Exit Sub
    End With
    
    If PfaNa <> vbNullString Then
        PfaNa = PfaNa & "\"
        If clFil.FilVor(PfaNa & "*.tdx") = True Then
            AnzDa = clFil.FilLis(PfaNa, "*.tdx", DiNam)
            If AnzDa > 0 Then
                frmStatus.Show
                Set PrBr1 = frmStatus.prbStat1
                Set PrBr2 = frmStatus.prbStat2
                Set TxDum = frmStatus.txtDummy
            
                PrBr1.Min = 0
                PrBr1.Max = AnzDa
                frmStatus.Caption = "Einlesen der TDX-Dateien..."
                DoEvents

                For AktZa = 1 To AnzDa
                    FiNam = PfaNa & DiNam(AktZa)
                    MesTy = IniGetFil(FiNam, "Message", "MessageType")
                    With GlTDx
                        .CSenderInternalIdentification = IniGetFil(FiNam, "Client", "CSenderInternalIdentification")
                        .CExternalIdentification = IniGetFil(FiNam, "Client", "CExternalIdentification")
                        .CLastName = IniGetFil(FiNam, "Client", "CLastName")
                        .CFirstName = IniGetFil(FiNam, "Client", "CFirstName")
                        .CBirthday = IniGetFil(FiNam, "Client", "CBirthday")
                        .CSex = IniGetFil(FiNam, "Client", "CSex")
                        .CStreet = IniGetFil(FiNam, "Client", "CStreet")
                        .CZip = IniGetFil(FiNam, "Client", "CZip")
                        .CTown = IniGetFil(FiNam, "Client", "CTown")
                        .CCountryCode = IniGetFil(FiNam, "Client", "CCountryCode")
                        .CCountry = IniGetFil(FiNam, "Client", "CCountry")
                        .CTelephone = IniGetFil(FiNam, "Client", "CTelephone")
                        .CFax = IniGetFil(FiNam, "Client", "CFax")
                        .InsuranceID = IniGetFil(FiNam, "Client", "InsuranceID")
                        .InsuranceClientID = IniGetFil(FiNam, "Client", "InsuranceClientID")
                        .InsuranceStatus = IniGetFil(FiNam, "Client", "InsuranceStatus")
                        .ClinicDepartment = IniGetFil(FiNam, "Client", "ClinicDepartment")
                        .ClinicRoomNumber = IniGetFil(FiNam, "Client", "ClinicRoomNumber")
                        .CustomerAccount = IniGetFil(FiNam, "Client", "CustomerAccount")
                        .Email = IniGetFil(FiNam, "Client", "eMail")
                        .CellularPhone = IniGetFil(FiNam, "Client", "CellularPhone")
                    End With
                    S_AdTx MesTy, False
                    DoEvents
                    PrBr1.Value = AktZa
                    If TxDum.Text = "B" Then Exit For 'Abbrechen
                Next AktZa
                
                DoEvents
                Adr_Er1
                DoEvents
                SUpAd
                
                For AktZa = 1 To AnzDa
                    FiNam = PfaNa & DiNam(AktZa)
                    With clFil
                        .DaLoe = FiNam & vbNullChar
                        .FilLoe
                    End With
                Next AktZa
            End If
        End If
    End If
    
End If

Set CoDia = Nothing
Set clFil = Nothing

Exit Sub

LiErr:
If GlDbg = True Then SErLog Err.Description & " SAdTx " & Err.Number
Resume Next

End Sub
