Public Sub SPaBi()
On Error GoTo PoErr
'Lädt die Patientenfostos und scaliert die Picturebox

Dim PhoBr As Long
Dim PhoHo As Long
Dim TeiBr As Double
Dim TeiHo As Double
Dim TeiSc As Double
Dim TmpNa As String
Dim FiNam As String
Dim ImMan As XtremeCommandBars.ImageManager
Dim ImIcs As XtremeCommandBars.ImageManagerIcons

Set FM = frmMain
Set TxDe5 = FM.txtDeta5
Set PiBi1 = FM.picBild1
Set PiBi2 = FM.picBild2
Set ImMan = FM.imgManag
Set ImIcs = ImMan.Icons

Set clFil = New clsFile

If TxDe5.Text <> vbNullString Then
    TmpNa = GlBPf & TxDe5.Text
    If clFil.FilVor(TmpNa) = True Then
        FiNam = TmpNa
    Else
        If clFil.FilVor(TxDe5.Text) = True Then
            FiNam = TxDe5.Text
        Else
            FiNam = App.Path & "\Skins\LeerBild.skn"
        End If
    End If
Else
    FiNam = App.Path & "\Skins\LeerBild.skn"
End If

If clFil.FilVor(FiNam) = True Then
    PiBi2.Picture = LoadPicture(FiNam)
    PiBi1.ScaleMode = vbPixels
    PiBi2.ScaleMode = vbPixels
    With PiBi1
        .AutoRedraw = True
        .Picture = LoadPicture(vbNullString)
        .Width = 2000
        .Height = 2000
        .Refresh
        .AutoRedraw = False
    End With
    TeiBr = PiBi1.ScaleWidth / PiBi2.ScaleWidth
    TeiHo = PiBi1.ScaleHeight / PiBi2.ScaleHeight
    If PiBi2.ScaleWidth * TeiHo > PiBi1.ScaleWidth Then
      TeiSc = TeiBr
    Else
      TeiSc = TeiHo
    End If
    PhoBr = PiBi2.ScaleWidth * TeiSc
    PhoHo = PiBi2.ScaleHeight * TeiSc
    With PiBi1
        .AutoRedraw = True
        .Width = PhoBr * Screen.TwipsPerPixelX
        .Height = PhoHo * Screen.TwipsPerPixelY
        .Refresh
        .PaintPicture PiBi2.Picture, 0, 0, PhoBr, PhoHo
        .AutoRedraw = False
    End With
Else
    PiBi2.Picture = LoadPicture("")
    PiBi1.ScaleMode = vbPixels
    PiBi2.ScaleMode = vbPixels
    With PiBi1
        .AutoRedraw = True
        .Picture = LoadPicture("")
        .Width = 2000
        .Height = 2000
        .Refresh
        .AutoRedraw = False
    End With
End If

Set clFil = Nothing

Exit Sub

PoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SPaBi " & Err.Number
Resume Next

End Sub
