Public Function SZahl(ByVal StrWe As String) As Double
On Error GoTo CrErr
'Gibt die Zahl aus einem Text zurück

Dim RetZa As Double
Dim AktZa As Integer

RetZa = 0

For AktZa = 1 To Len(StrWe)
    RetZa = Val(Mid$(StrWe, AktZa))
    If RetZa <> 0 Then Exit For
Next AktZa

SZahl = RetZa

Exit Function

CrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SZahl " & Err.Number
Resume Next

End Function
Public Function SZech(ByVal TxStr As String, ByVal Flag As Boolean) As String
On Error GoTo ErErr
'Konvertiert Ascii in ANSI und umgekehrt

Dim RetWe As Long

If Flag = True Then
    RetWe = OemToChar(TxStr, TxStr)
Else
    RetWe = CharToOem(TxStr, TxStr)
End If

SZech = Trim$(TxStr)

Exit Function

ErErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SZech " & Err.Number
Resume Next

End Function
