                    .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellBackColor) = FaSp1
                End Select
            Case 2:
                Select Case VoTyp
                Case 1:
                    .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 2700
                    .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellBackColor) = FaSp2
                Case 2:
                    .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 6600
                    .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellBackColor) = FaSp1
                End Select
            Case 3:
                Select Case VoTyp
                Case 1:
                    .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 6600
                    .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellBackColor) = FaSp1
                Case 2:
                    .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 2700
                    .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellBackColor) = FaSp3
                End Select
            Case 4:
