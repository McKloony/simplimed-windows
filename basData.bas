Public Function S_BuZal(ByVal BuDat As Date, ByVal BetBz As Double, ByVal GuiID As String, ByVal ErKId As Long, ByVal KtoNr As Long, KtoSt As String, ByVal GeKId As Long, ByVal GeKNr As Long, ByVal GeKBe As String, ByVal StKID As Long, ByVal StKNr As Long, ByVal StKBe As String, ByVal ManNr As Long, ByVal MitNr As Long, ByVal BuJah As Long, Optional ByVal BuTex As String, Optional ByVal KoTex As String) As Boolean
On Error GoTo LiErr
'Legt eine Zahlung in Buchführung an

Dim PatNr As Long 'Patientennummer
Dim ReNum As Long 'Rechnungsnummer
Dim BuBel As Long
Dim MasTe As Long
Dim BetBr As Double
Dim BuBet As Double
Dim BetRe As Double 'Rechnungsbetrag
Dim ReStu As Single 'Steuer
Dim ReStr As String 'Rechnungsnummer
Dim PaNam As String
Dim TSENa As String  'Kassenkennung
Dim AnzSt As Integer 'Anzahl Steuerarten
Dim FoWar As Integer
Dim AktZa As Integer
Dim Verre As Boolean
Dim Kasse As Boolean
Dim ReAbg As Boolean 'Rechnung abgeschlossen
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCo2 As XtremeReportControl.ReportControl
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo3 = FM.repCont3
Set RpCo1 = frmMain.repCont1
Set RpCo2 = frmMain.repCont2

BetBz = Round(BetBz, 2)

If WindowLoad("frmAdress") = True Then
    PatNr = GlAId
    PaNam = frmAdress.txtS1F11.Text
    ReNum = 0
    ReStu = 0
    ReStr = vbNullString
    FoWar = frmAdress.cmbS2F07.ItemData(frmAdress.cmbS2F07.ListIndex)
Else
    Select Case GlBut
    Case RibTab_Abrechnung:
        Set RpCls = RpCo3.Columns
        Set RpSel = RpCo3.SelectedRows
        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            Set RpCol = RpCls.Find(Rec_ID0)
            PatNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_ID1)
            ReNum = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Steuer)
            ReStu = Round(RpRow.Record(RpCol.ItemIndex).Value, 2)
            Set RpCol = RpCls.Find(Rec_IDKurz)
            PaNam = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_RechNr)
            ReStr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Wahrung)
            FoWar = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Selekt)
            ReAbg = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Betrag)
            BetRe = Round(RpRow.Record(RpCol.ItemIndex).Value, 2)
            If ReAbg = True Then 'Rechnung ist abgeschlossen
                Exit Function
            End If
        End If
    Case RibTab_Adressen:
        Set RpCls = RpCo2.Columns
        Set RpSel = RpCo2.SelectedRows
        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            PatNr = AdAry(Adr_ID0, RpRow.Index)
            PaNam = AdAry(Adr_IDKurz, RpRow.Index)
        Else
            PatNr = 0
        End If
        ReNum = 0
        ReStu = 0
        ReStr = vbNullString
        FoWar = S_AdIdi(PatNr, "Währung")
    Case RibTab_Ter_Listen:
        Set RpCls = RpCo1.Columns
        Set RpSel = RpCo1.SelectedRows
        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            Set RpCol = RpCls.Find(Ter_ID0)
            PatNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Ter_Patient)
            PaNam = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Ter_MasTer)
            MasTe = RpRow.Record(RpCol.ItemIndex).Value
        Else
            PatNr = 0
            MasTe = 0
        End If
        ReNum = 0
        ReStu = 0
        ReStr = MasTe
        FoWar = S_AdIdi(PatNr, "Währung")
    Case RibTab_Ter_Akont:
        Set RpCls = RpCo1.Columns
        Set RpSel = RpCo1.SelectedRows
        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            Set RpCol = RpCls.Find(Ter_ID0)
            PatNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Ter_Patient)
            PaNam = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Ter_MasTer)
            MasTe = RpRow.Record(RpCol.ItemIndex).Value
        Else
            PatNr = 0
            MasTe = 0
        End If
        ReNum = 0
        ReStu = 0
        ReStr = MasTe
        FoWar = S_AdIdi(PatNr, "Währung")
    End Select
End If

For AktZa = 1 To UBound(GlGeK) 'Geldkonten
    If GlGeK(AktZa, 0) = GeKId Then
