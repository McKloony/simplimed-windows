Else
    QurTa = 0
End If

GrTag = Year(KrDat) & "-" & Format$(Month(KrDat), "00") & "-" & Format$(Day(KrDat), "00")
GrWek = Year(KrDat) & "-" & Format$(DatePart("ww", KrDat), "00")
GrMon = Year(KrDat) & "-" & Format$(Month(KrDat), "00")
