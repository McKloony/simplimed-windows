Private Sub S_LaNu(ByVal PatNr As Long, ByVal ReTyp As String, Optional ByVal AuStr As String, Optional ByVal BeUnf As Boolean = False, Optional ByVal ManNr As Long)
On Error GoTo SuErr
'Schlägt eine neue Rechnungsnummer vor und legt diese an

Dim NeuRe As Long
Dim ReJah As Long
Dim AkJah As String
Dim AkMon As String
Dim NeuSt As String
Dim ReNum As String
Dim GuiID As String
Dim Posit As Integer

GuiID = CreateID("L")

ReJah = Year(Date)
AkJah = Right$(Year(Date), 2)
AkMon = Format$(Month(Date), "00")

Set RS120 = New ADODB.Recordset
RS120.CursorLocation = adUseClient

If GlRMa = True Then 'getrennter Mandentenrechnungsnummernkreis
    If GlRnm = True Then 'Neustart Rechnungsnummer am Jahrenanfang
        Set RS120 = DBCmRe3("qrySimReVt2", "@IdxNr", "@IdJah", "@IdStr", ManNr, ReJah, ReTyp)
    Else
        Set RS120 = DBCmRe2("qrySimReVt1", "@IdxNr", "@IdStr", ManNr, ReTyp)
    End If
Else
    If GlRnm = True Then 'Neustart Rechnungsnummer am Jahrenanfang
        Set RS120 = DBCmRe2("qrySimReVt3", "@IdJah", "@IdStr", ReJah, ReTyp)
    Else
        Set RS120 = DBCmRe1("qrySimReVt0", "@IdStr", ReTyp)
    End If
End If

If RS120.RecordCount > 0 Then
    If Len(RS120.Fields("PLZ").Value) > 0 Then
        NeuRe = CLng(RS120.Fields("PLZ").Value) + 1
    Else
        NeuRe = CLng(S_LaNm()) + 1
    End If
Else
    NeuRe = 1
End If

RS120.Close
Set RS120 = Nothing

If GlReN = True Then 'Rechnungsnummern sofort erzeugen
    Select Case GlRFm
    Case 2: NeuSt = AkJah & "-" & AkMon & "-" & Format$(NeuRe, "000000")
    Case 3: NeuSt = AkJah & AkMon & "-" & Format$(NeuRe, "000000")
    Case 4: NeuSt = AkJah & "-" & Format$(NeuRe, "000000")
    Case 5: NeuSt = AkJah & AkMon & "-" & Format$(NeuRe, "0000")
    End Select
Else
    NeuSt = "-"
End If

Posit = InStrRev(NeuSt, "-", -1, 1)
If Posit > 0 Then
    ReNum = Format$(Mid$(NeuSt, Posit + 1, Len(NeuSt)), "00000000")
Else
    ReNum = NeuSt
End If

Set RS121 = New ADODB.Recordset
RS121.CursorLocation = adUseClient
Set RS121 = DBCmRe1("qrySimRePa", "@PatNr", PatNr)
If RS121.RecordCount > 0 Then
    Set RS122 = New ADODB.Recordset
    With RS122
        .CursorLocation = adUseClient
        .Source = "qrySimReTop"
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdTableDirect
    End With
    If RS122.Supports(adAddNew) Then
        RS122.AddNew
        RS122.Fields("ID0").Value = PatNr
        RS122.Fields("RechNr").Value = NeuSt
        RS122.Fields("PLZ").Value = ReNum
        RS122.Fields("IDKurz").Value = RS121.Fields("IDKurz").Value
        RS122.Fields("ID3").Value = RS121.Fields("ID3").Value
        RS122.Fields("IDZ").Value = RS121.Fields("IDZ").Value
        RS122.Fields("Intervall").Value = RS121.Fields("Intervall").Value
        RS122.Fields("Mahnbar").Value = RS121.Fields("Mahnbar").Value
        RS122.Fields("Ziel").Value = RS121.Fields("Ziel").Value
        RS122.Fields("Datum").Value = Date
        If RS121.Fields("Mahnbar").Value = -1 Then
            RS122.Fields("Fallig").Value = Date + RS121.Fields("Ziel").Value
        Else
            RS122.Fields("Fallig").Value = Date
        End If
        RS122.Fields("GesBetrag").Value = 0
        RS122.Fields("WVBetrag").Value = 0
        RS122.Fields("Anzahlung").Value = 0
        RS122.Fields("Währung").Value = RS121.Fields("Währung").Value
        RS122.Fields("Offen").Value = 0
        RS122.Fields("Type").Value = "R"
        RS122.Fields("Drucken").Value = BeUnf
        RS122.Fields("IDP").Value = RS121.Fields("IDP").Value
        If RS121.Fields("Kopien").Value = 0 Then
            RS122.Fields("Kopie").Value = 1
        Else
            RS122.Fields("Kopie").Value = RS121.Fields("Kopien").Value
        End If
        RS122.Fields("GuiID").Value = GuiID
        If AuStr <> vbNullString Then RS122.Fields("IDA").Value = AuStr
        RS122.Update
    End If
    RS122.Close
    Set RS122 = Nothing
End If
RS121.Close
Set RS121 = Nothing

DoEvents 'Übertrag ID1 Feld in IDR
DBCmEx2 "qrySimReSet", "@IdNum", "@IdxNr", NeuRe, NeuRe
DoEvents

Exit Sub

SuErr:
If GlDbg = True Then SErLog Err.Description & " S_LaNu " & Err.Number
Resume Next

End Sub
Public Sub S_MaAbr()
On Error GoTo KoErr
'Emails Abrufen

Dim UIDNa As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim TrKey As String
Dim RetWe As Integer
Dim MaiKo As Integer
Dim IdPsf As Integer
Dim MaLoe As Boolean
Dim BeAut As Boolean

Set FM = frmMain
Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

If GlEKV = False Then 'Emailkonten vorhanden
    TeTit = "E-Mail-Abruf"
    TeMai = "Es ist kein E-Mail-Konto vorhanden"
    TeInh = "Um E-Mails abrufen zu können, ist es notwendig mind. ein E-Mail-Konto hinzuzufügen."
    TeFus = "Um ein E-Mail-Konto hinzuzufügen, wechseln Sie in das Modul: Textverarbeitung und dann oben auf Emails. Dort klicken Sie auf die Schaltfläche Emailkonten."
    SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
    Exit Sub
End If

For MaiKo = LBound(GlMkt) To UBound(GlMkt)
    If GlMkt(MaiKo, 1) = GlMiA(GlSmI, 2) Then
        UIDNa = "UIDL" & Format$(GlMkt(MaiKo, 0), "0000") & ".txt"
    
        IdPsf = CInt(GlMkt(MaiKo, 2))
        BeAut = CBool(GlMkt(MaiKo, 15))
        If CBool(GlMkt(MaiKo, 21)) = True Then
            TrKey = "o803o"
        Else
            TrKey = "o801o"
        End If
    
        Select Case IdPsf
        Case 1: 'IMAP
            If GlMkt(MaiKo, 5) = vbNullString Then
                SPopu "Kein IMAP-Server", "Für dieses Emailkonto wurde kein POP3-Server angegeben", IC48_Warning
                Exit For
            End If
            If GlMkt(MaiKo, 8) = vbNullString Then
                SPopu "Kein IMAP-Port", "Für dieses Emailkonto wurde kein POP3-Port angegeben", IC48_Warning
                Exit For
            End If
        Case 2: 'POP3
            If GlMkt(MaiKo, 6) = vbNullString Then
                SPopu "Kein POP3-Server", "Für dieses Emailkonto wurde kein POP3-Server angegeben", IC48_Warning
                Exit For
            End If
            If GlMkt(MaiKo, 8) = vbNullString Then
                SPopu "Kein POP3-Port", "Für dieses Emailkonto wurde kein POP3-Port angegeben", IC48_Warning
                Exit For
            End If
        End Select
        If GlMkt(MaiKo, 13) = vbNullString Then
            SPopu "Keine Emailadresse", "Für dieses Emailkonto wurde keine Emailadresse angegeben", IC48_Warning
            Exit For
        End If
        If GlMkt(MaiKo, 12) = vbNullString Then
            SPopu "Kein Name", "Für dieses Emailkonto wurde kein Name angegeben", IC48_Warning
            Exit For
        End If
        If GlMkt(MaiKo, 14) = vbNullString Then
            SPopu "Keine Antwortadresse", "Für dieses Emailkonto wurde keine Antwortadresse angegeben", IC48_Warning
            Exit For
        End If
        If BeAut = True Then
            If GlMkt(MaiKo, 10) = vbNullString Then
                SPopu "Kein Benutzername", "Für dieses Emailkonto wurde kein Benutzername angegeben", IC48_Warning
                Exit For
            End If
            If GlMkt(MaiKo, 11) = vbNullString Then
                SPopu "Kein Benutzerpasswort", "Für dieses Emailkonto wurde kein Benutzerpasswort angegeben", IC48_Warning
                Exit For
            End If
        End If
        If GlMkt(MaiKo, 12) <> vbNullString Then
            MaLoe = Not CBool(GlMkt(MaiKo, 16))
        Else
            MaLoe = True
        End If
    
        Set clMai = New clsMailing

        With clMai
            .moUIDn = UIDNa
            .moFold = "Emails"
            .moPosf = IdPsf
            Select Case IdPsf
            Case 1: .moIMAP = GlMkt(MaiKo, 5)
            Case 2: .moPOP3 = GlMkt(MaiKo, 6)
            End Select
            If BeAut = True Then
                .moUsNa = GlMkt(MaiKo, 10)
                .moUsPa = GlMkt(MaiKo, 11)
            End If
            .moPor1 = GlMkt(MaiKo, 8)
            .moTLSg = GlMkt(MaiKo, 3)
            .moNoDe = CBool(GlMkt(MaiKo, 16)) 'Emails auf Server belassen
            .moGele = CBool(GlMkt(MaiKo, 17)) 'Als gelesen kennzeichnen
            .moAlTy = CInt(GlMkt(MaiKo, 18)) 'Emailabrufalter
            .moAlAk = CBool(GlMkt(MaiKo, 19)) 'Nur neue Emails abrufen
            .moProg = True 'Statusanzeige
            .moAuTy = 0 'Userlogin
            .moTrKy = TrKey
            RetWe = .MaiGet()
        End With

        Set clMai = Nothing
    End If
Next MaiKo

Screen.MousePointer = vbHourglass
DoEvents

clFen.FenDsk 2
DoEvents

SUpMa
DoEvents

clFen.FenDsk 3

DoEvents
Screen.MousePointer = vbNormal

Set clFen = Nothing

Set FM = Nothing

Exit Sub

KoErr:
If GlDbg = True Then
    MsgBox Err.Description, 48, "S_MaAbr " & Err.Number
    SErLog Err.Description & " S_MaAbr " & Err.Number & " - " & Err.Source
End If
Resume Next

End Sub
