                .CursorLocation = adUseClient
                .Source = "qryLabAuNo"
                .ActiveConnection = DB1
                .CursorType = adOpenStatic
                .LockType = adLockBatchOptimistic
                .Open Options:=adCmdTableDirect
                Set .ActiveConnection = Nothing
            End With
        
            If RS122.Supports(adAddNew) Then
                For Each RpRow In RpSel
                    If RpRow.GroupRow = False Then

                        Set RpCol = RpCls.Find(Lau_IP0)
                        BehNr = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(Lau_ID0)
                        PatNr = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(Lau_IDA)
                        AuStr = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(Lau_ID1)
                        AufNr = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(Lau_Name)
                        PatNa = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(Lau_Datum)
                        BeDat = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(Lau_AbrTyp)
                        AbrTy = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(Lau_Vorname)
                        PatVo = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(Lau_Geboren)
                        PatGe = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(Lau_GebTyp)
                        GebTy = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(Lau_G)
