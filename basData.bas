            RS126.Fields("Diagnose").Value = StrDi
            RS126.Fields("Anamnese").Value = TmStr
            RS126.Fields("Objekt").Value = STrCa
            RS126.Fields("Grafik").Value = TxDe5.Text
            RS126.Update
        End If
    End If
    RS126.Close
    Set RS126 = Nothing
    
    If GlBut = RibTab_Bildmodul Then
        If LiFi1.SelectedCount > 0 Then
        Set LiFit = LiFi1.FirstSelectedItem
            DaNam = LiFit.DisplayName
            Lange = Len(DaNam)
            If Mid$(DaNam, 8, 1) = "_" And Lange > 30 Then
                TmGui = Mid$(DaNam, 9, 32)
            End If
        End If

        If TmGui <> vbNullString Then
            GlNeK = GlKoX
            With GlNeK
                .PatNr = GlAdr
                .IdxNr = 0
                .EiDat = Format$(Date, "dd.mm.yyyy")
                .EiZei = TimeValue(Now)
                .EiTyp = 105 'Bilddatei
                .KoStr = DaNam
                .KoGui = TmGui
                .TeStr = BiKom
                .NeuEi = False
                .Mitar = GlMiA(GlSmI, 2)
            End With
            K_Einf
        End If
    End If
End If

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KrSv " & Err.Number
Resume Next

End Sub
Public Function S_KrTa(ByVal ReNum As Long, ByVal TaDat As Date) As Double
On Error GoTo KoErr
'Zeigt die Tagessumme einer Rechnung

