Tit1 = "Auftrag Speichern"
AktBe = 1
ParZa = 0

If AnzPo > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then
        Set RpRow = RpSel(0)
