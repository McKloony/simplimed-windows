    ReBet = RpRow.Record(RpCol.ItemIndex).Value
Else
    ReBet = 0
End If
Set RpCol = RpCls.Find(Rec_IDP)
If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
    ManNr = RpRow.Record(RpCol.ItemIndex).Value
Else
    ManNr = GlMan(GlSMa, 2)
End If
Set RpCol = RpCls.Find(Rec_IDM)
