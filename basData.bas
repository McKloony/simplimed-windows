Set CmSta = CmBrs.StatusBar
Set RpRcs = RpCo1.Records

Set CmCom = CmBrs.FindControl(CmCom, KA_SuCo1, , True)

IdBnk = CmCom.ItemData(CmCom.ListIndex)

With RpCo1
    .EditItem Nothing, Nothing
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    If .Records.Count > 0 Then .Records.DeleteAll
    .Populate
End With

Set RS130 = New ADODB.Recordset
RS130.CursorLocation = adUseClient
Set RS130 = DBCmRe1("qrySimBuZaKas", "@IdxNr", IdBnk)
GesZa = RS130.RecordCount
If GesZa > 0 Then
    Do
    Set RpRec = RpRcs.Add()
    Set RpItm = RpRec.AddItem(RS130.Fields("IDK").Value)
    Set RpItm = RpRec.AddItem(RS130.Fields("Datum").Value)
    Set RpItm = RpRec.AddItem(Format$(RS130.Fields("Uhrzeit").Value, "hh:mm") & " Uhr")
    If RS130.Fields("Gesamt").Value <> 0 Then
        Set RpItm = RpRec.AddItem(Format$(RS130.Fields("Gesamt").Value, GlWa1))
    Else
        Set RpItm = RpRec.AddItem(Format$(0, GlWa1))
    End If
    If RS130.Fields("Laufend").Value <> 0 Then
        Set RpItm = RpRec.AddItem(Format$(RS130.Fields("Laufend").Value, GlWa1))
    Else
        Set RpItm = RpRec.AddItem(Format$(0, GlWa1))
    End If
    If RS130.Fields("Different").Value <> 0 Then
        Set RpItm = RpRec.AddItem(Format$(RS130.Fields("Different").Value, GlWa1))
    Else
        Set RpItm = RpRec.AddItem(Format$(0, GlWa1))
    End If
