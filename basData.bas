    Case 8: Set RS113 = DBCmRe1("qryKat01E", "@IdxNr", KatNr) 'IGeL Leistungen
    Case 9: Set RS113 = DBCmRe1("qryKat12G", "@IdxNr", 1)     'Artikelliste
    End Select
    GeZa2 = RS113.RecordCount
        
    If GeZa1 > 0 Then
        KaVa1 = RS112.GetRows 'Array einlesen
    
        ReDim GlEi1(GeZa1)
        AktZa = 0
        CmZif.Clear

        For AktZa = 0 To UBound(KaVa1, 2)
            Select Case CoIdx
            Case 1: 'Diagnosen (4-5)
                If KaVa1(4, AktZa) <> vbNullString Then
                    If KaVa1(5, AktZa) <> vbNullString Then
                        TmStr = KaVa1(4, AktZa) & " - " & KaVa1(5, AktZa)
                        CmZif.AddItem TmStr
                        GlEi1(AktZa) = TmStr
                    End If
                End If
            Case 2: 'Gebührenziffer (4-5)
                If KaVa1(5, AktZa) <> vbNullString Then
                    If KaVa1(6, AktZa) <> vbNullString Then
                        TmStr = KaVa1(5, AktZa) & " - " & KaVa1(6, AktZa)
                        CmZif.AddItem TmStr
                        GlEi1(AktZa) = TmStr
                    End If
                End If
            Case 3: 'Laborparameter (5-7)
                If KaVa1(7, AktZa) <> vbNullString Then
                    If KaVa1(8, AktZa) <> vbNullString Then
                        TmStr = KaVa1(7, AktZa) & " - " & KaVa1(8, AktZa)
                        CmZif.AddItem TmStr
