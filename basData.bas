Public Sub S_AdAn(ByVal KatNr As Long, ByVal ZalZi As Long, ByVal Kopie As Long, ByVal Grupp As Boolean, Optional ByVal ManNr As Long, Optional ByVal SerAd As Integer, Optional ByVal OutAd As Integer, Optional ByVal SynAd As Integer, Optional ByVal Passi As Integer, Optional Mitar As Integer, Optional ByVal GrEnt As Boolean = False, Optional ByVal AdNum As Long = 0, Optional ByVal Versa As Integer = -1)
On Error GoTo KoErr
'Adressdaten anpassen

Dim PatNr As Long
Dim PaStr As String
Dim GrKey As String
Dim GrAlt As String
Dim GrNeu As String
Dim GrDif As String
Dim GrIdx As String
Dim TmGui As String
Dim Lange As Integer
Dim Posit As Integer
Dim GuiVo As Boolean
Dim RpCo2 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo2 = FM.repCont2
Set RpCls = RpCo2.Columns
Set RpSel = RpCo2.SelectedRows
Set TrLi1 = frmAdrAnpa.trvList1

Screen.MousePointer = vbHourglass

If RpSel.Count > 0 Then
    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            PatNr = AdAry(Adr_ID0, RpRow.Index)
            If AdAry(Adr_IDKurz, RpRow.Index) <> vbNullString Then
                PaStr = AdAry(Adr_IDKurz, RpRow.Index)
            Else
                PaStr = vbNullString
            End If
            If AdAry(Adr_TreKey, RpRow.Index) <> vbNullString Then
                GrAlt = AdAry(Adr_TreKey, RpRow.Index)
            Else
                GrAlt = vbNullString
            End If
            If AdAry(Adr_GuiID, RpRow.Index) = vbNullString Then
                GuiVo = False
            Else
                GuiVo = True
            End If
            If Versa >= 0 Then
                DBCmEx2 "qryAdrVer", "@IdVer", "@IdxNr", Versa, PatNr
            End If
            If KatNr > 0 Then
                DBCmEx2 "qryPatKata", "@IdKat", "@IdxNr", KatNr, PatNr
                DBCmEx2 "qrySimReKat", "@IdKat", "@IdxNr", KatNr, PatNr
            End If
            If ZalZi > 0 Then
                DBCmEx2 "qryPatZalu", "@IdZal", "@IdxNr", ZalZi, PatNr
                DBCmEx2 "qrySimReIdz", "@IdIdz", "@IdxNr", ZalZi, PatNr
            End If
            If Kopie > 0 Then
                DBCmEx2 "qryPatKopie", "@IdKop", "@IdxNr", Kopie, PatNr
                DBCmEx2 "qrySimReKop", "@Kopie", "@IdxNr", Kopie, PatNr
            End If
            If ManNr > 0 Then
                DBCmEx2 "qrySimAdThe", "@IdMan", "@IdxNr", ManNr, PatNr
            End If
            If AdNum > 0 Then
                DBCmEx2 "qrySimAdrMa", "@IdPat", "@IdxNr", AdNum, PatNr
                AdNum = AdNum + 1
            End If
            If SerAd > 0 Then
                Select Case GlBut
                Case RibTab_Mitarbeit:
                    Select Case SerAd
                    Case 1: DBCmEx2 "qrySimAdGes", "@IdGes", "@IdxNr", 0, PatNr
                    Case 2: DBCmEx2 "qrySimAdGes", "@IdGes", "@IdxNr", -1, PatNr
                    End Select
                Case RibTab_Mandanten:
                    Select Case SerAd
                    Case 1: DBCmEx2 "qrySimAdGes", "@IdGes", "@IdxNr", 0, PatNr
                    Case 2: DBCmEx2 "qrySimAdGes", "@IdGes", "@IdxNr", -1, PatNr
                    End Select
                Case Else:
                    Select Case SerAd
                    Case 1: DBCmEx2 "qryAdrKo2", "@IdMai", "@IdxNr", -1, PatNr '[Mailing]
                    Case 2: DBCmEx2 "qryAdrKo2", "@IdMai", "@IdxNr", 0, PatNr
                    End Select
                End Select
            End If
            
            If OutAd > 0 Then
                Select Case OutAd
                Case 1: DBCmEx2 "qryAdrKo3", "@IdEdi", "@IdxNr", -1, PatNr '[Edit]
                Case 2: DBCmEx2 "qryAdrKo3", "@IdEdi", "@IdxNr", 0, PatNr
                End Select
            End If
            If Mitar > 0 Then
                Select Case Mitar
                Case 1: 'Patient
                    DBCmEx2 "qrySimAdMit", "@IdMit", "@IdxNr", 0, PatNr '[Mitarbeiter]
                    DBCmEx2 "qryAdrKo1", "@IdVip", "@IdxNr", 0, PatNr '[VIP]
                    DBCmEx2 "qryAdrKo5", "@IdVer", "@IdxNr", 0, PatNr '[Arzt]
                Case 2: 'Mitarbeiter
                    DBCmEx2 "qrySimAdMit", "@IdMit", "@IdxNr", -1, PatNr '[Mitarbeiter]
                    DBCmEx2 "qryAdrKo1", "@IdVip", "@IdxNr", 0, PatNr '[VIP]
                    DBCmEx2 "qryAdrKo5", "@IdVer", "@IdxNr", 0, PatNr '[Arzt]
                Case 3: 'Mandant
                    DBCmEx2 "qrySimAdMit", "@IdMit", "@IdxNr", 0, PatNr '[Mitarbeiter]
                    DBCmEx2 "qryAdrKo1", "@IdVip", "@IdxNr", -1, PatNr '[VIP]
                    DBCmEx2 "qryAdrKo5", "@IdVer", "@IdxNr", 0, PatNr '[Arzt]
                Case 4: 'Verordner
                    DBCmEx2 "qrySimAdMit", "@IdMit", "@IdxNr", 0, PatNr '[Mitarbeiter]
                    DBCmEx2 "qryAdrKo1", "@IdVip", "@IdxNr", 0, PatNr '[VIP]
                    DBCmEx2 "qryAdrKo5", "@IdVer", "@IdxNr", -1, PatNr '[Arzt]
                End Select
            End If
            If SynAd > 0 Then
                Select Case GlBut
                Case RibTab_Mitarbeit:
                    Select Case SynAd
                    Case 1: DBCmEx2 "qryAdrOnl", "@OnlTe", "@IdxNr", -1, PatNr
                    Case 2: DBCmEx2 "qryAdrOnl", "@OnlTe", "@IdxNr", 0, PatNr
                    End Select
                Case RibTab_Mandanten:
                    Select Case SynAd
                    Case 1: DBCmEx2 "qryAdrOnl", "@OnlTe", "@IdxNr", -1, PatNr
                    Case 2: DBCmEx2 "qryAdrOnl", "@OnlTe", "@IdxNr", 0, PatNr
                    End Select
                Case Else:
                        Select Case SynAd
                        Case 1: DBCmEx2 "qrySimAdEdit", "@IdEdi", "@IdxNr", 1, PatNr
                                DBCmEx2 "qryAdrKo6", "@IdRep", "@IdxNr", 0, PatNr '[Replicated]
                                DBCmEx3 "qryDAVAdCh2", "@IdSet", "@IdDat", "@IdxNr", 1, Now, PatNr
                        Case 2: DBCmEx2 "qrySimAdEdit", "@IdEdi", "@IdxNr", 0, PatNr
                                DBCmEx2 "qryAdrKo6", "@IdRep", "@IdxNr", 1, PatNr '[Replicated]
                                DBCmEx3 "qryDAVAdCh2", "@IdSet", "@IdDat", "@IdxNr", 0, Now, PatNr
                        End Select
                    If GuiVo = False Then
                        TmGui = CreateID("A")
                        DBCmEx2 "qryAdrKo8", "@GuiID", "@IdxNr", TmGui, PatNr '[GuiID]
                    End If
                End Select
            End If
            If Passi > 0 Then
                Select Case Passi
                Case 1:
                    DBCmEx2 "qryAdrKo9", "@IdPas", "@IdxNr", -1, PatNr '[Passiv]
                Case 2:
                    DBCmEx2 "qryAdrKo9", "@IdPas", "@IdxNr", 0, PatNr '[Passiv]
                    If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                        DBCmEx1 "qryAdrKo7", "@IdxNr", PatNr '[LastModification]
                        DBCmEx3 "qryDAVAdCh2", "@IdSet", "@IdDat", "@IdxNr", 0, Now, PatNr
                    End If
                End Select
            End If

            If Grupp = True Then
                GrNeu = vbNullString
                For Each Knote In TrLi1.Nodes
                    GrKey = vbNullString
                    If Knote.Checked = True Then
                        If Knote.Key <> "P801" Then
                            GrIdx = Mid$(Knote.Key, 2, Len(Knote.Key) - 1)
                            GrKey = "o" & GrIdx & "o"
                            Lange = Len(GrKey)
                            GrDif = Right$(GrKey, Lange - 1)
                            If GrEnt = False Then
                                If GrNeu = vbNullString Then
                                    If GrAlt = vbNullString Then
                                        GrNeu = GrKey
                                    Else
                                        Posit = InStr(1, GrAlt, GrKey, 1)
                                        If Posit = 0 Then
                                            GrNeu = GrAlt & GrDif
                                        Else
                                            GrNeu = GrAlt
                                        End If
                                    End If
                                Else
                                    If GrAlt = vbNullString Then
                                        GrNeu = GrNeu & GrDif
                                    Else
                                        Posit = InStr(1, GrAlt, GrKey, 1)
                                        If Posit = 0 Then
                                            GrNeu = GrNeu & GrDif
                                        Else
                                            GrNeu = GrNeu
                                        End If
                                    End If
                                End If
                            Else
                                If GrAlt <> vbNullString Then
                                    If GrNeu = vbNullString Then
                                        Posit = InStr(1, GrAlt, GrKey, 1)
                                        If Posit > 0 Then
                                            GrNeu = Replace(GrAlt, GrDif, vbNullString, 1)
                                        End If
                                    Else
                                        Posit = InStr(1, GrNeu, GrKey, 1)
                                        If Posit > 0 Then
                                            GrNeu = Replace(GrNeu, GrDif, vbNullString, 1)
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                Next Knote
                If GrNeu <> vbNullString Then
                    DBCmEx2 "qryAdrGrp", "@IdStr", "@IdxNr", GrNeu, PatNr
                End If
            End If
        End If
    Next RpRow

    SUpAd
End If

Screen.MousePointer = vbNormal

Set RpSel = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo2 = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_AdAn " & Err.Number
Resume Next

End Sub
