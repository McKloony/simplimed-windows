                                            DBCmEx2 "qrySimOPAu3", "@PaSel", "@IdxNr", -1, OpNu3
                                            DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", -1, ReNu3 'Rechung Bezahlt Kennzeichnen
                                        End If
                                        
                                        If OpNu4 > 0 Then
                                            BetAn = CDbl(S_OPIdx(OpNu4, "Bezahlt"))
                                            DoEvents
                                            BetNe = BetNe - OpBe3 'WICHTIG!
                                            If BetNe >= OpBe4 Then
                                                BetBu = OpBe4 + BetAn
                                                BetDf = 0
                                            Else
                                                BetBu = BetNe + BetAn
                                                If (OpBe4 - BetNe) < 0.02 Then 'Rundungsfehler ausgleichen
                                                    BetDf = 0
                                                Else
                                                    BetDf = OpBe4 - BetNe
                                                End If
                                            End If
                                            DBCmEx2 "qrySimOPAu1", "@PaSum", "@IdxNr", BetBu, OpNu4
                                            DBCmEx2 "qrySimOPAu2", "@PaSum", "@IdxNr", BetDf, OpNu4
                                            DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", BetBu, ReNu4
                                            DBCmEx2 "qrySimOPAu4", "@IdDat", "@IdxNr", BuDat, OpNu4 'Kontoauszugsdatum
                                            DBCmEx3 "qrySimBaBez", "@IdBez", "@IdSel", "@IdxNr", -1, -1, BaIdx
                                            DBCmEx2 "qrySimOpBel", "@IdStr", "@IdxNr", "0", OpNu4
                                            If BetDf <= 0 Then
                                                DBCmEx2 "qrySimOPAu3", "@PaSel", "@IdxNr", -1, OpNu4
                                                DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", -1, ReNu4
                                            End If
    
                                            If OpNu5 > 0 Then
                                                BetAn = CDbl(S_OPIdx(OpNu5, "Bezahlt"))
                                                DoEvents
                                                BetNe = BetNe - OpBe4 'WICHTIG!
                                                If BetNe >= OpBe5 Then
                                                    BetBu = OpBe5 + BetAn
                                                    BetDf = 0
                                                Else
                                                    BetBu = BetNe + BetAn
                                                    If (OpBe5 - BetNe) < 0.02 Then 'Rundungsfehler ausgleichen
                                                        BetDf = 0
                                                    Else
                                                        BetDf = OpBe5 - BetNe
                                                    End If
                                                End If
                                                DBCmEx2 "qrySimOPAu1", "@PaSum", "@IdxNr", BetBu, OpNu5
                                                DBCmEx2 "qrySimOPAu2", "@PaSum", "@IdxNr", BetDf, OpNu5
                                                DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", BetBu, ReNu5
                                                DBCmEx2 "qrySimOPAu4", "@IdDat", "@IdxNr", BuDat, OpNu5 'Kontoauszugsdatum
                                                DBCmEx3 "qrySimBaBez", "@IdBez", "@IdSel", "@IdxNr", -1, -1, BaIdx
                                                DBCmEx2 "qrySimOpBel", "@IdStr", "@IdxNr", "0", OpNu5
                                                If BetDf <= 0 Then
                                                    DBCmEx2 "qrySimOPAu3", "@PaSel", "@IdxNr", -1, OpNu5
                                                    DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", -1, ReNu5
                                                End If
                                    
                                            End If
                                        End If
                                    End If
                                End If
                            End If
    
                            GlNeK = GlKoX 'Protokolleintrag
                            With GlNeK
                                .PatNr = ManNr
                                .IdxNr = 0
                                .EiDat = Format$(Date, "dd.mm.yyyy")
                                .EiZei = TimeValue(Now)
                                .EiTyp = 104
                                .ZiStr = Format$(Now, "hh:mm") & " Uhr"
                                .NeuEi = True
                                .KeiAk = True
                                .Mitar = GlMiA(GlSmI, 2)
                                .TeStr = "Offener Posten ausgeglichen - " & ReSt1 & " - " & PaNam
                            End With
                            S_Prot
                        End If
                    End If
                                        
                ElseIf KtoID > 0 Then '--------------------------------------------------------------------------------

                    S_KoDe KtoID
                    With GlKto
                        KtoNr = .KtoNr
                        KtoSt = .KtBez
                        KoStu = .Steue
                    End With
                    DoEvents
                    BuBel = S_BuBel(ManNr, BuJah, GeKId)
                    DoEvents
                    With GlNuB
                        .BuWär = 1
                        .BuBel = BuBel
                        .BuBet = BaBet
                        .BuDat = BuDat
                        .BuTex = GeTex
                        .ByTyp = BuTyp
                        .GuiID = BaGui
                        .GlkId = GeKId
                        If GlBuc = True Then 'einfache Buchhaltung verwenden
                            .KtNrS = KtoNr
                            .KtBeS = KtoSt
                            .KtNrH = GeKNr
                            .KtBeH = GeKBe
                        Else
                            If BuTyp = 1 Then 'Ausgabe
                                .KtNrS = KtoNr
                                .KtNrH = GeKNr
                                .KtBeS = KtoSt
                                .KtBeH = GeKBe
                            Else
                                .KtNrS = GeKNr
                                .KtNrH = KtoNr
                                .KtBeS = GeKBe
                                .KtBeH = KtoSt
                            End If
                        End If
                        .KoTex = vbNullString
                        .MaNum = ManNr
                        .MitNr = MitNr
                        .PatNr = 0
                        .ReNum = ReNu1
                        .ReStr = vbNullString
                        .Steue = KoStu
                    End With
                    S_BuNe
                    DoEvents
                    DBCmEx3 "qrySimBaBez", "@IdBez", "@IdSel", "@IdxNr", -1, -1, BaIdx
    
                End If
            End If
        End If

        AktPo = AktPo + 1
        If TxDum.Text = "B" Then Exit For 'Abbrechen
        PrBr1.Value = AktPo
        DoEvents
    Next RpRow
    
    RS121.Close
    Set RS121 = Nothing
    
    DoEvents
    Screen.MousePointer = vbNormal
    
    If GlJet = True Then SDBSav
    
    DoEvents
    P_List "BaPo", 0, 1
    DoEvents
    
    Unload frmStatus
    Set frmStatus = Nothing
    DoEvents
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing

Screen.MousePointer = vbHourglass
DoEvents
SUpBa RowNr
DoEvents
Screen.MousePointer = vbNormal

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BaGen " & Err.Number
Resume Next

End Sub

Private Sub S_BaNeu()
On Error GoTo LiErr
'Generiert eine einzelne Buchung aus zugeordneten Umsatz

Dim BuDat As Date
Dim IdxWe As Long
Dim BaIdx As Long
Dim AktZa As Long
Dim ManNr As Long
Dim MitNr As Long
Dim KtoNr As Long
Dim KtoGe As Long
Dim BaBet As Double
Dim KoStu As Single
Dim KtoSt As String
Dim KtStG As String
Dim KtBez As String
Dim KtBeG As String
Dim KtKom As String
Dim BaAus As String
Dim BuTex As String
Dim UmTex As String
Dim GeTex As String
Dim BaGui As String
Dim GeKId As Integer
Dim MaIdx As Integer
Dim MiIdx As Integer
Dim Lange As Integer
Dim TabId As Integer
Dim BuTyp As Integer
Dim AktKo As Integer
Dim Ermit As Boolean
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

