Public Function S_BuSa(ByVal BuJah As Long, BisDa As Date, Optional ByVal ManNr As Long) As Double
On Error GoTo LiErr
'Errechnet den Saldovortrag

Dim VonDa As Date
Dim SaEin As Double
Dim SaAus As Double
Dim SalEi As Double
Dim SalAu As Double
Dim SaAnf As Double 'Anfangsbestand
Dim SaAlg As Double 'Saldoallgemein
Dim SaEnd As Double 'Endsaldo
Dim Datu1 As String
Dim Datu2 As String
Dim IdBnk As Integer
Dim SQL1 As String
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmGlk As XtremeCommandBars.CommandBarComboBox

Set FM = frmMain
Set CmBrs = FM.comBar01
Set CmGlk = CmBrs.FindControl(CmGlk, SY_SuBuh, , True)

IdBnk = CmGlk.ItemData(CmGlk.ListIndex)

VonDa = CDate("01.01." & BuJah) 'wird immer vom 01.01.xxxx bis BisDa berechnet

If GlTyp < 2 Then
    Datu1 = DatePart("yyyy", VonDa) & "-" & DatePart("m", VonDa) & "-" & DatePart("d", VonDa) & " 00:00:00"
    Datu2 = DatePart("yyyy", BisDa) & "-" & DatePart("m", BisDa) & "-" & DatePart("d", BisDa) & " 00:00:00"
Else
    Datu1 = Format$(DatePart("m", VonDa, vbMonday), "00") & "/" & Format$(DatePart("d", VonDa, vbMonday), "00") & "/" & DatePart("yyyy", VonDa, vbMonday)
    Datu2 = Format$(DatePart("m", BisDa, vbMonday), "00") & "/" & Format$(DatePart("d", BisDa, vbMonday), "00") & "/" & DatePart("yyyy", BisDa, vbMonday)
End If

If ManNr > 0 Then
    If GlTyp < 2 Then
        If IdBnk > 0 Then
            SQL1 = "SELECT Sum(dbo.qryPrBuJo1a.Einnahme) AS Einnahme, Sum(dbo.qryPrBuJo1a.Ausgabe) AS Ausgabe From dbo.qryPrBuJo1a WHERE (Datum >= CONVERT(DATETIME, '" & Datu1 & "', 102)) AND (Datum <= CONVERT(DATETIME, '" & Datu2 & "', 102)) AND (IDT = " & ManNr & ") AND (IDB = " & IdBnk & ")"
        Else
            SQL1 = "SELECT Sum(dbo.qryPrBuJo1a.Einnahme) AS Einnahme, Sum(dbo.qryPrBuJo1a.Ausgabe) AS Ausgabe From dbo.qryPrBuJo1a WHERE (Datum >= CONVERT(DATETIME, '" & Datu1 & "', 102)) AND (Datum <= CONVERT(DATETIME, '" & Datu2 & "', 102)) AND (IDT = " & ManNr & ")"
        End If
    Else
        If IdBnk > 0 Then
            SQL1 = "SELECT Sum(qryPrBuJo1a.Einnahme) AS Einnahme, Sum(qryPrBuJo1a.Ausgabe) AS Ausgabe From qryPrBuJo1a HAVING (((qryPrBuJo1a.Datum) Between #" & Datu1 & "# And #" & Datu2 & "#)) AND ([IDT] = " & ManNr & ") AND ([IDB] = " & IdBnk & ");"
        Else
            SQL1 = "SELECT Sum(qryPrBuJo1a.Einnahme) AS Einnahme, Sum(qryPrBuJo1a.Ausgabe) AS Ausgabe From qryPrBuJo1a HAVING (((qryPrBuJo1a.Datum) Between #" & Datu1 & "# And #" & Datu2 & "#)) AND ([IDT] = " & ManNr & ");"
        End If
    End If
Else
    If GlTyp < 2 Then
        If IdBnk > 0 Then
            SQL1 = "SELECT Sum(dbo.qryPrBuJo1.Einnahme) AS Einnahme, Sum(dbo.qryPrBuJo1.Ausgabe) AS Ausgabe From dbo.qryPrBuJo1 WHERE (Datum >= CONVERT(DATETIME, '" & Datu1 & "', 102)) AND (Datum <= CONVERT(DATETIME, '" & Datu2 & "', 102)) AND (IDB = " & IdBnk & ")"
        Else
            SQL1 = "SELECT Sum(dbo.qryPrBuJo1.Einnahme) AS Einnahme, Sum(dbo.qryPrBuJo1.Ausgabe) AS Ausgabe From dbo.qryPrBuJo1 WHERE (Datum >= CONVERT(DATETIME, '" & Datu1 & "', 102)) AND (Datum <= CONVERT(DATETIME, '" & Datu2 & "', 102))"
        End If
    Else
        If IdBnk > 0 Then
            SQL1 = "SELECT Sum(qryPrBuJo1.Einnahme) AS Einnahme, Sum(qryPrBuJo1.Ausgabe) AS Ausgabe From qryPrBuJo1 HAVING (((qryPrBuJo1.Datum) Between #" & Datu1 & "# And #" & Datu2 & "#) AND ([IDB] = " & IdBnk & "));"
        Else
            SQL1 = "SELECT Sum(qryPrBuJo1.Einnahme) AS Einnahme, Sum(qryPrBuJo1.Ausgabe) AS Ausgabe From qryPrBuJo1 HAVING (((qryPrBuJo1.Datum) Between #" & Datu1 & "# And #" & Datu2 & "#));"
        End If
    End If
End If

Set RS121 = New ADODB.Recordset 'Allgemein
RS121.CursorLocation = adUseClient

If ManNr > 0 Then 'Angangsbestände ermitteln
    If IdBnk > 0 Then
        Set RS121 = DBCmRe3("qrySimBuEr2a", "@BuJah", "@IdxNr", "@IdBnk", BuJah, ManNr, IdBnk)
    Else
        Set RS121 = DBCmRe2("qrySimBuEr1a", "@BuJah", "@IdxNr", BuJah, ManNr)
    End If
Else
    If IdBnk > 0 Then
        Set RS121 = DBCmRe2("qrySimBuEr2", "@BuJah", "@IdBnk", BuJah, IdBnk)
    Else
        Set RS121 = DBCmRe1("qrySimBuEr1", "@BuJah", BuJah)
    End If
End If

If RS121.RecordCount > 0 Then
    If RS121.Fields("Einnahme").Value <> vbNullString Then
        SaEin = RS121.Fields("Einnahme").Value
    Else
        SaEin = 0
    End If
    If RS121.Fields("Ausgabe").Value <> vbNullString Then
        SaAus = RS121.Fields("Ausgabe").Value
    Else
        SaAus = 0
    End If
    SaAnf = SaEin - SaAus
    DoEvents

    If BisDa > VonDa Then
        Set RS122 = New ADODB.Recordset
        With RS122
            .CursorLocation = adUseClient
            .Source = SQL1
            .ActiveConnection = DB1
            .CursorType = adOpenForwardOnly
            .LockType = adLockReadOnly
            .Open Options:=adCmdText
        End With
        If RS122.RecordCount > 0 Then
            If RS122.Fields("Einnahme").Value > 0 Then
                SalEi = RS122.Fields("Einnahme").Value
            Else
                SalEi = 0
            End If
            If RS122.Fields("Ausgabe").Value > 0 Then
                SalAu = RS122.Fields("Ausgabe").Value
            Else
                SalAu = 0
            End If
            SaAlg = SalEi - SalAu

            SaEnd = SaAnf + SaAlg
        Else
            SaEnd = SaAnf
        End If
        RS122.Close
        Set RS122 = Nothing
    Else
        SaEnd = SaAnf
    End If
Else
    SaEnd = 0
End If
RS121.Close
Set RS121 = Nothing

S_BuSa = SaEnd

Exit Function

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BuSa " & Err.Number
Resume Next

End Function
