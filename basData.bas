                    Else
                        .MaIdx = GlSMa
                        .MaNum = ManNr
                    End If
                Else
                    .PrTyp = "C"
                    .MaIdx = MaIdx
                    If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                        .MaNum = MitNr
                    Else
                        .MaNum = ManNr
                    End If
                End If
            End With
            S_TeSy
            DoEvents
        End If
    End If
    DoEvents

    PrGui = CreateID("P")
    MitNa = GlMiA(GlSmI, 1)
    If NeuTe = True Then 'neuer Termin
        Select Case NotSt
        Case 3: PrStr = "Termin wurde manuell hinzugefügt mit Emailerinnerung (" & Format$(NotVa, "00") & "h)"
        Case 1: PrStr = "Termin wurde manuell hinzugefügt mit abgelaufener Emailerinnerung (" & Format$(NotVa, "00") & "h)"
        Case 0: PrStr = "Termin wurde manuell hinzugefügt ohne Emailerinnerung (" & Format$(NotVa, "00") & "h)"
        End Select
    Else
        If AnMiT = True Then
            Select Case NotSt
            Case 3: PrStr = "Termin wurde verschoben mit Emailerinnerung (" & Format$(NotVa, "00") & "h) und Mitarbeiter geändert"
            Case 1: PrStr = "Termin wurde verschoben mit abgelaufener Emailerinnerung und Mitarbeiter geändert"
            Case 0: PrStr = "Termin wurde verschoben ohne Emailerinnerung (" & Format$(NotVa, "00") & "h) und Mitarbeiter geändert"
            End Select
        Else
            Select Case NotSt
            Case 3: PrStr = "Termin wurde verschoben mit Emailerinnerung (" & Format$(NotVa, "00") & "h)"
            Case 1: PrStr = "Termin wurde verschoben mit abgelaufener Emailerinnerung (" & Format$(NotVa, "00") & "h)"
            Case 0: PrStr = "Termin wurde verschoben ohne Emailerinnerung (" & Format$(NotVa, "00") & "h)"
            End Select
        End If
    End If
    DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", TerNr, PrGui, TmGui, Now, Now, PrStr, MitNa
    DoEvents

