Public Sub S_AdLo()
On Error GoTo LoErr
'Adressen löschen

Dim IdxNr As Long
Dim AnzPa As Long
Dim AktPo As Long
Dim RowNr As Long
Dim RowFi As Long
Dim AnzPo As Long
Dim GesZa As Long
Dim PaStr As String
Dim Passi As Boolean
Dim MitZa As Integer
Dim Frage As Integer
Dim Mld2 As String
Dim Mld4, Tit1 As String
Dim RpCo2 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo2 = FM.repCont2
Set RpRws = RpCo2.Rows
Set RpCls = RpCo2.Columns
Set RpSel = RpCo2.SelectedRows

Tit1 = "Adresse Entfernen"

AnzPo = RpSel.Count
GesZa = RpCo2.Rows.Count

If GlBut = RibTab_Adressen Then
    frmStatus.Show
    DoEvents
    frmStatus.Caption = "Adressen Entfernen"
    Set Lbl01 = frmStatus.lblLab01
    Set PrBr1 = frmStatus.prbStat1
    Set PrBr2 = frmStatus.prbStat2
    Set TxDum = frmStatus.txtDummy
    Lbl01.Caption = "Bitte warten..."
    PrBr1.Min = 0
    PrBr1.Max = AnzPo
End If
    
Select Case GlBut
Case RibTab_Mandanten:
    Mld4 = "Es ist erforderlich, dass mindestens ein Mandant erhalten bleibt! Dieser Mandant kann aus diesem Grund nicht gelöscht werden. Klicken Sie gegebenenfalls auf Mandant Bearbeiten, um den Mandanten zu ändern."
    If (GesZa = 1) Or (AnzPo >= GesZa) Then
        WindowMess Mld4, Dial2, Tit1, FM.hwnd
        Exit Sub
    Else
        For Each RpRow In RpRws
            If RpRow.GroupRow = False Then
                Passi = AdAry(Adr_Passiv, RpRow.Index)
                If Passi = False Then
                    MitZa = MitZa + 1
                End If
            End If
        Next RpRow
        If MitZa = 1 Then
            WindowMess Mld4, Dial2, Tit1, FM.hwnd
            Exit Sub
        End If
    End If
