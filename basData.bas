                    .ZiStr = Format$(Now, "hh:mm") & " Uhr"
                    .NeuEi = True
                    .KeiAk = True
                    .Mitar = GlMiA(GlSmI, 2)
                End With
                S_Prot
            End If
        Next RpRow

        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            RowNr = RpRow.Index
            SUpBu RowNr
        End If
    End If
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BuKo " & Err.Number
Resume Next

