Public Sub S_TeSy() '~~~
On Error GoTo SaErr
'Generates a protocoll record in table: Tabelle_Abre with type [ID1] = 800

Dim PatNr As Long
Dim IdxNr As Long
Dim ManNr As Long
Dim MitNr As Long
Dim ZeiSt As String
Dim DaSta As String
Dim DaEnd As String
