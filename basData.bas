                DBCmEx7 "qrySimBaKon", "@IdxWe", "@IdKon", "@KoStr", "@BuTex", "@IdStu", "@IdErm", "@IdxNr", IdxWe, KtIdS, KtBeS, BuTex, KoStu, Ermit, BaIdx
            Else
                DBCmEx7 "qrySimBaKon", "@IdxWe", "@IdKon", "@KoStr", "@BuTex", "@IdStu", "@IdErm", "@IdxNr", IdxWe, KtNrH, KtBeH, BuTex, KoStu, Ermit, BaIdx
