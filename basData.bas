Public Sub S_KrLi(Optional ByVal RowNr As Long)
On Error GoTo LiErr
'Alle Rechnungen eines Patienten für Privatabrechnung

Dim GesZa As Long
Dim RowFi As Long
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set RpCo3 = FM.repCont3
Set RpRws = RpCo3.Rows

If RowNr > 0 Then
    If RpRws.Count > 0 Then
        RowFi = RpCo3.TopRowIndex
    End If
End If

With RpCo3
    .EditItem Nothing, Nothing
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    If .Records.Count > 0 Then .Records.DeleteAll
    .Populate
End With

Set RS131 = New ADODB.Recordset
RS131.CursorLocation = adUseClient
Set RS131 = DBCmRe1("qrySimReKra", "@IdxNr", GlAdr)

GesZa = RS131.RecordCount

If GesZa > 0 Then
    S_AbRec RS131
    RpCo3.Populate
End If
RS131.Close
Set RS131 = Nothing

If RpRws.Count > 0 Then
    If RowNr >= RpRws.Count Then
        RowNr = RpRws.Count - 1
    End If
    If RpRws.Count > 0 Then
        RpCo3.TopRowIndex = RowFi
        RpRws.Row(0).Selected = False
        If RpRws.Row(RowNr).GroupRow = False Then
            RpRws.Row(RowNr).EnsureVisible
            RpRws.Row(RowNr).Selected = True
            If GlFoc = True Then
                Set RpCo3.FocusedRow = RpRws.Row(RowNr)
            End If
        End If
    End If
End If

SMark

Set RpRws = Nothing
Set RpCo3 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then SErLog Err.Description & " S_KrLi " & Err.Number
Resume Next

End Sub
Public Sub S_KrLo(Optional ByVal LoeRe As Boolean = False, Optional ByVal EiAus As Boolean = False)
On Error GoTo LiErr
'Löscht die markierten Einträge im Krankenblatt

Dim IdxNr As Long
Dim RowNr As Long
Dim KrRow As Long
Dim AnzPo As Long
Dim ReNum As Long
Dim RzNum As Long
Dim PatNr As Long
Dim KrTyp As Long
Dim FilNa As String
Dim KoStr As String
Dim BuGui As String
Dim ReStr As String
Dim PaStr As String
Dim DaNaO As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim ReBet As Double 'Rechnungsgesamtbetrag
Dim BezBe As Double 'Bezahltergesamtbetrag
Dim ZalBe As Double 'Positionsanzahlungsbetrag
Dim KraBe As Double 'Positionsgesamtbetrag
Dim GutBe As Double 'Guthabenbuchungsbetrag
Dim RabBe As Double 'Rabattgesamtbetrag
Dim NeReB As Double 'neuer Rechnungsgesamtbetrag
Dim AktZa As Integer
Dim AnzRo As Integer
Dim AktPo As Integer
Dim WoLoe As Boolean
