Public Sub S_TeSe(ByVal IdxNr As Long)
On Error GoTo SuErr
'Entfert alle Serientermine aus dem Kalender

Dim TerNr As Long
Dim DayFi As Date
Dim DayLa As Date
Dim AkDat As Date
Dim TmpDa As Date
Dim PrStr As String
Dim MitNa As String
Dim PrGui As String
Dim TmGui As String
Dim AnzTa As Integer
Dim AktTa As Integer
Dim CaCol As XtremeCalendarControl.CalendarControl
Dim CaEvt As XtremeCalendarControl.CalendarEvent
Dim CaEvs As XtremeCalendarControl.CalendarEvents
Dim WiSta As XtremeCalendarControl.CalendarEventRecurrenceState

Set FM = frmMain
Set CaCol = FM.calCont1

DayFi = CaCol.ActiveView.Days(0).Date
TmpDa = "01." & DatePart("m", DayFi) & "." & DatePart("yyyy", DayFi)
DayFi = DateAdd("m", -1, TmpDa)
DayLa = DateAdd("m", 12, DayFi)

AnzTa = DateDiff("d", DayFi, DayLa)
PrStr = "Termin(serie) wurde entfernt"
MitNa = GlMiA(GlSmI, 1)

Set RS121 = New ADODB.Recordset
RS121.CursorLocation = adUseClient
Set RS121 = DBCmRe1("qryTerSer01", "@IdxNr", IdxNr)
If RS121.RecordCount > 0 Then
    Do
    AkDat = DayFi
    TerNr = RS121.Fields("ID2").Value
    TmGui = RS121.Fields("GuiID").Value

    For AktTa = 1 To AnzTa
        Set CaEvs = CaCol.DataProvider.RetrieveDayEvents(AkDat)
        For Each CaEvt In CaEvs
            IdxNr = CaEvt.id
            If IdxNr = TerNr Then
                CaCol.DataProvider.DeleteEvent CaEvt
                Exit For
            End If
        Next CaEvt
        AkDat = DateAdd("d", 1, AkDat)
    Next AktTa
    
    PrGui = CreateID("P")
    DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", TerNr, PrGui, TmGui, Now, Now, PrStr, MitNa
    DoEvents
    
    RS121.MoveNext
    Loop Until RS121.EOF
End If
RS121.Close
Set RS121 = Nothing

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TeSe " & Err.Number
Resume Next

End Sub
