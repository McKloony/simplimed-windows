                        Set RS126 = New ADODB.Recordset 'Summen ermitteln
                        RS126.CursorLocation = adUseClient
                        Set RS126 = DBCmRe1("qryLabPoSu", "@IdxNr", AufNr)
                        If RS126.RecordCount > 0 Then
                            SumEK = Format$(RS126.Fields("Betrag").Value, GlWa1)
                            SumVK = Format$(RS126.Fields("Gesamt").Value, GlWa1)
                        Else
                            SumEK = 0
                            SumVK = 0
