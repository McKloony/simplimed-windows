Public Function S_BuBel(ByVal ManNr As Long, ByVal AkJah As Integer, ByVal IdBnk As Long) As Long
On Error GoTo KoErr
'Ermittelt die nächste Belegnummer

Dim BuJah As Long
Dim BelNr As Long
Dim BnkNr As Long
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmJah As XtremeCommandBars.CommandBarComboBox
Dim CmGlk As XtremeCommandBars.CommandBarComboBox

Set FM = frmMain
Set CmBrs = FM.comBar01

Set CmJah = CmBrs.FindControl(CmJah, SY_SuJah, , True)
Set CmGlk = CmBrs.FindControl(CmGlk, SY_SuBuh, , True)

If AkJah > 0 Then
    BuJah = AkJah
Else
    BuJah = CLng(CmJah.Text)
End If

If IdBnk > 0 Then
    BnkNr = IdBnk
Else
    BnkNr = CmGlk.ItemData(CmGlk.ListIndex)
End If

S_BuBel = 1

Set RS140 = New ADODB.Recordset
RS140.CursorLocation = adUseClient

If GlBGe = True Then 'Getrennter Geldkonten Belegnummernkreis
    If BnkNr > 0 Then
        If GlBMa = True Then 'Getrennter Mandanten Belegnummernkreis
            Set RS140 = DBCmRe3("qrySimBuBe9", "@IdJah", "@IdxNr", "@IdBnk", BuJah, ManNr, BnkNr)
        Else
            Set RS140 = DBCmRe2("qrySimBuBe8", "@IdJah", "@IdBnk", BuJah, BnkNr)
        End If
    Else
        If GlBMa = True Then 'Getrennter Mandanten Belegnummernkreis
            Set RS140 = DBCmRe2("qrySimBuBe5", "@IdJah", "@IdxNr", BuJah, ManNr)
        Else
            Set RS140 = DBCmRe1("qrySimBuBe4", "@IdJah", BuJah)
        End If
    End If
Else
    If GlBMa = True Then 'Getrennter Mandanten Belegnummernkreis
        Set RS140 = DBCmRe2("qrySimBuBe5", "@IdJah", "@IdxNr", BuJah, ManNr)
    Else
        Set RS140 = DBCmRe1("qrySimBuBe4", "@IdJah", BuJah)
    End If
End If

If RS140.RecordCount > 0 Then
    If RS140.Fields("Beleg").Value <> vbNullString Then
        If IsNumeric(RS140.Fields("Beleg").Value) Then
            BelNr = RS140.Fields("Beleg").Value
            S_BuBel = BelNr + 1
        Else
            Do While Not IsNumeric(RS140.Fields("Beleg").Value)
                If IsNumeric(RS140.Fields("Beleg").Value) Then
                    BelNr = RS140.Fields("Beleg").Value
                    S_BuBel = BelNr + 1
                    Exit Do
                Else
                    S_BuBel = 1
                End If
                RS140.MoveNext
            Loop
        End If
    Else
        Do While RS140.Fields("Beleg").Value = vbNullString
            If RS140.Fields("Beleg").Value <> vbNullString Then
                If IsNumeric(RS140.Fields("Beleg").Value) Then
                    BelNr = RS140.Fields("Beleg").Value
                    S_BuBel = BelNr + 1
                    Exit Do
                Else
                    S_BuBel = 1
                End If
            Else
                S_BuBel = 1
            End If
            RS140.MoveNext
        Loop
    End If
Else
    S_BuBel = 1
End If
RS140.Close
Set RS140 = Nothing

Set CmBrs = Nothing

Exit Function

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BuBel " & Err.Number
Resume Next

End Function
Public Function S_BuBeP(ByVal BelNr As Long, ByVal ManNr As Long, ByVal AkJah As Integer, ByVal IdBnk As Long) As Boolean
On Error GoTo KoErr
'Prüft ob die Belegnummer bereits vorhanden ist

