            EmpNa = MaAry(Mai_Empfaenger, RpRow.Index)
            SenNa = MaAry(Mai_SenderName, RpRow.Index)
            MaiDa = MaAry(Mai_Maildate, RpRow.Index)
            DaNam = MaAry(Mai_MailFile, RpRow.Index)
            FiNam = GlDpf & "Emails\" & DaNam
            With clFil
                .DaLoe = FiNam & vbNullChar
                .FilLoe
            End With
        End If
        Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
        Case 1: DBCmEx2 "qryMailInPas", "@IdPas", "@IdxNr", -1, IdxNr
        Case 2: DBCmEx2 "qryMailOutPas", "@IdPas", "@IdxNr", -1, IdxNr
        Case 3: DBCmEx2 "qryMailInPas", "@IdPas", "@IdxNr", -1, IdxNr
        Case 4: DBCmEx2 "qryMailOutPas", "@IdPas", "@IdxNr", -1, IdxNr
        End Select
    End If
Next RpRow
   
If RowNr > 0 Then
    If RpRws.Count > 0 Then
        RowFi = RpCo0.TopRowIndex
    End If
End If

DoEvents
S_MaLis

If RowNr > 0 Then
