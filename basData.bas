Public Sub S_KrAn(ByVal NeDat As Date, ByVal AnzBe As Double, ByVal GuiID As String, ByVal ZaStr As String, ByVal GuVer As Boolean, Optional ByVal KoStr As String)
On Error GoTo SuErr
'Legt eine Anzahlung an

Dim RowNr As Long
Dim PatNr As Long
Dim ReNum As Long
Dim SorNr As Long
Dim KrRow As Long
Dim SQL3 As String
Dim ReStr As String
Dim ReBet As Double
Dim NeBet As Double
Dim BezBe As Double
Dim FoWär As Integer
Dim RetWe As Boolean
Dim ReAbg As Boolean
Dim ReMel As Boolean
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo4 = FM.repCont4
Set RpCo6 = FM.repCont6
Set RpCo3 = FM.repCont3
Set RpCls = RpCo3.Columns
Set RpSel = RpCo3.SelectedRows
Set RpRws = RpCo3.Rows

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        RowNr = RpRow.Index
        Set RpCol = RpCls.Find(Rec_ID0)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            PatNr = RpRow.Record(RpCol.ItemIndex).Value
        Else
            PatNr = 0
        End If
        Set RpCol = RpCls.Find(Rec_ID1)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            ReNum = RpRow.Record(RpCol.ItemIndex).Value
        Else
            ReNum = 0
        End If
        Set RpCol = RpCls.Find(Rec_Betrag)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            ReBet = RpRow.Record(RpCol.ItemIndex).Value
        Else
            ReBet = 0
        End If
        Set RpCol = RpCls.Find(Rec_RechNr)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            ReStr = RpRow.Record(RpCol.ItemIndex).Value
        Else
            ReStr = vbNullString
        End If
        Set RpCol = RpCls.Find(Rec_Wahrung)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            FoWär = RpRow.Record(RpCol.ItemIndex).Value
        Else
            FoWär = 1
        End If
        Set RpCol = RpCls.Find(Rec_Bezahlt)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BezBe = RpRow.Record(RpCol.ItemIndex).Value
        Else
            BezBe = 0
        End If
        Set RpCol = RpCls.Find(Rec_Selekt)
        ReAbg = CBool(RpRow.Record(RpCol.ItemIndex).Value)
    Else
        Exit Sub
    End If
Else
    Exit Sub
End If

If GuVer = True Then 'Guthaben verrechnen
    If ReBet = 0 Then
        NeBet = AnzBe
    Else
        If AnzBe > (ReBet - BezBe) Then
            NeBet = (ReBet - BezBe)
        Else
            NeBet = AnzBe
        End If
    End If
Else
    If AnzBe > (ReBet - BezBe) Then
        NeBet = (ReBet - BezBe)
    Else
        NeBet = AnzBe
    End If
End If

Set RpSel = RpCo6.SelectedRows
If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    KrRow = RpRow.Index
End If

If ReAbg = True Then 'Rechnung ist abgeschlossen
    SMeFr "Einträge Einfügen", "Diese Rechnung wurde bereits abgeschlossen!", "Die Rechnung " & ReStr & " wurde bereits abgeschlossen. Um diese Rechnung zu verändern, muss diese zuerst entriegelt werden.", "Um eine Rechnung zu entriegeln markieren Sie diese bitte mit der rechten Maustaste und wählen die gleichnamige Funktion.", False, 1, True, frmAnzahl.hwnd
    Exit Sub
End If

If GlTyp < 2 Then
    SQL3 = "SELECT * FROM dbo.qrySimAbSav WHERE IDR = " & ReNum & " ORDER BY ID3 DESC"
Else
    SQL3 = "SELECT * FROM qrySimAbSav WHERE [IDR] = " & ReNum & " ORDER BY [ID3] DESC;"
End If

Set RS123 = New ADODB.Recordset
With RS123
    .CursorLocation = adUseClient
    .Source = SQL3
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With
If RS123.RecordCount > 0 Then
    SorNr = RS123.Fields("ID3").Value + 1
Else
    SorNr = 1
End If
If RS123.Supports(adAddNew) Then
    RS123.AddNew
    RS123.Fields("ID0").Value = PatNr
    RS123.Fields("IDR").Value = ReNum
    RS123.Fields("ID3").Value = SorNr
    RS123.Fields("ID1").Value = 6 'Anzahlung
    RS123.Fields("RechNr").Value = ReStr
    RS123.Fields("Datum").Value = NeDat & Space$(1) & TimeValue(Now)
    RS123.Fields("Druckdatum").Value = NeDat & Space$(1) & TimeValue(Now)
    RS123.Fields("IDKurz").Value = ZaStr & " am " & NeDat & " : (" & Format$(NeBet, GlWa1) & ")"
    RS123.Fields("WVBetrag").Value = NeBet
    RS123.Fields("Währung").Value = FoWär
    RS123.Fields("Kommentar").Value = KoStr
    RS123.Fields("Kommentar2").Value = GuiID
    RS123.Fields("IDM").Value = GlMiA(GlSmI, 2)
    If ReAbg = True Then RS123.Fields("Gedruckt").Value = -1
    RS123.Update
End If
RS123.Close
Set RS123 = Nothing
DoEvents

DBCmEx2 "qrySimReSm3", "@IdBet", "@IdxNr", BezBe + NeBet, ReNum '[Anzahlung]
DoEvents
DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", BezBe + NeBet, ReNum '[Bezahlt]
DoEvents

If GuVer = True Then 'Guthaben verrechnen
    S_PaGu PatNr, , AnzBe
    DoEvents
End If

Set RpSel = RpCo3.SelectedRows
If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    RowNr = RpRow.Index
    SUpAb RowNr, , GuiID
End If

If GlVrz = False Then
    Set RpSel = RpCo4.SelectedRows
    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        RowNr = RpRow.Index
        SUpRe RowNr
    End If
Else
    GlVzA = True
End If

Set RpRws = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing
Set RpCo4 = Nothing
Set RpCo6 = Nothing

If ReMel = True Then SReMe

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KrAn " & Err.Number
Resume Next

End Sub
Public Function S_KrBe(ByVal ReNum As Long, ByVal ZaZil As Integer, ByVal ReBet As Double, ByVal BeBet As Double) As Boolean
On Error GoTo KoErr
'Rechnet den Endbetrag aus

Dim GeSum As Double
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmMain
Set RpCo6 = FM.repCont6
Set RpCls = RpCo6.Columns

If GlBut = RibTab_Abrechnung Then
    ReBet = Format$(ReBet, GlWa1)

    Set RS130 = New ADODB.Recordset
    RS130.CursorLocation = adUseClient
    If GlIgL = True Then 'Keine Preisberechnung bei IgL
        Set RS130 = DBCmRe1("qrySimAbSm1", "@IdxNr", ReNum)
    Else
        Set RS130 = DBCmRe1("qrySimAbSm", "@IdxNr", ReNum)
    End If
    If RS130.RecordCount > 0 Then
        If RS130("VK").Value <> 0 Then
            GeSum = Format$(RS130("VK").Value, GlWa1)
        End If
    Else
        GeSum = Format$(0, GlWa1)
    End If
    RS130.Close
    Set RS130 = Nothing
    
    Set RpCol = RpCls.Find(Kra_Betrag)
    RpCol.FooterText = "Summe:"
    Set RpCol = RpCls.Find(Kra_GesBetrag)
    RpCol.FooterText = Format$(GeSum, GlWa1)
    Set RpCol = RpCls.Find(Kra_Bezeichnung)
    If BeBet > 0 Then
        RpCol.FooterText = "Differenz: " & Format$(ReBet - BeBet, GlWa1)
    Else
        RpCol.FooterText = vbNullString
    End If
    RpCo6.Redraw
End If

Set RpCls = Nothing
Set RpCo6 = Nothing

Exit Function

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KrBe " & Err.Number
Resume Next

End Function
