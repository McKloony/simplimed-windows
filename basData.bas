                                                            RS125.Fields(FL101.Name).Value = Replace(AryFe(AktFe), Chr$(32), ".", 1)
                                                        End If
                                                    End If
                                            Case "Geändert":
                                                    If Left$(AryFe(AktFe), 2) <> "00" Then
                                                        If AryFe(AktFe) <> Space$(1) Then
                                                            RS125.Fields(FL101.Name).Value = Left$(AryFe(AktFe), 10)
                                                        Else
                                                            RS125.Fields(FL101.Name).Value = Date
                                                        End If
                                                    Else
                                                        RS125.Fields(FL101.Name).Value = Date
                                                    End If
                                            Case "Geboren":
                                                    If IsDate(AryFe(AktFe)) = True Then
                                                        If Left$(AryFe(AktFe), 2) <> "00" Then
                                                            RS125.Fields(FL101.Name).Value = Left$(AryFe(AktFe), 10)
                                                        Else
                                                            RS125.Fields(FL101.Name).Value = Date
                                                        End If
                                                    Else
                                                        RS125.Fields(FL101.Name).Value = Date
                                                    End If
                                            Case "R_Geboren":
                                                    If IsDate(AryFe(AktFe)) = True Then
                                                        If Left$(AryFe(AktFe), 2) <> "00" Then
                                                            RS125.Fields(FL101.Name).Value = Left$(AryFe(AktFe), 10)
                                                        Else
                                                            RS125.Fields(FL101.Name).Value = Date
                                                        End If
                                                    Else
                                                        RS125.Fields(FL101.Name).Value = Date
                                                    End If
                                            Case "Mitarbeiter":
