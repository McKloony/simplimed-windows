Public Sub S_MaKSt(ByVal KaTyp As Integer)
On Error GoTo KoErr
'Lädt Mailkonten

Dim SQL1 As String
Dim SQL2 As String
Dim GesZa As Long
Dim RowFi As Long
Dim RpCon As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMailKont
Set RpCon = FM.repCont1
Set RpRws = RpCon.Rows

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qryMailKonta WHERE IDM = " & GlMiA(GlSmI, 2) & " ORDER BY IDK"
Else
    SQL1 = "SELECT * FROM qryMailKonta WHERE [IDM] =  " & GlMiA(GlSmI, 2) & " ORDER BY [IDK];"
End If

If GlTyp < 2 Then
    SQL2 = "SELECT * FROM dbo.qryMailSpm WHERE IDM = " & GlMiA(GlSmI, 2) & " ORDER BY IDA"
Else
    SQL2 = "SELECT * FROM qryMailSpm WHERE [IDM] = " & GlMiA(GlSmI, 2) & " ORDER BY [IDA];"
End If

With RpCon
    .EditItem Nothing, Nothing
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    If .Records.Count > 0 Then .Records.DeleteAll
    .Populate
End With

Select Case KaTyp
Case 1:
    Set RS130 = New ADODB.Recordset
    With RS130
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdText
    End With
    
    GesZa = RS130.RecordCount
    If GesZa > 0 Then
        S_MaKRc RS130, KaTyp
    End If
    RS130.Close
    Set RS130 = Nothing
Case 2:
    Set RS130 = New ADODB.Recordset
    With RS130
        .CursorLocation = adUseClient
        .Source = SQL2
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdText
    End With
    
    GesZa = RS130.RecordCount
    If GesZa > 0 Then
        S_MaKRc RS130, KaTyp
    End If
    RS130.Close
    Set RS130 = Nothing
End Select

RpCon.Populate

If GesZa > 0 Then
    Set RpRws = RpCon.Rows
    RpRws.Row(0).Selected = True
End If

Set RpRws = Nothing
Set RpCon = Nothing

Exit Sub

KoErr:
If GlDbg = True Then SErLog Err.Description & " S_MaKSt " & Err.Number
Resume Next

End Sub
