        End If
        Set RpCol = RpCls.Find(Ban_KoBetrag)
        If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
            BuBet = RpRow.Record(RpCol.ItemIndex).Value
        Else
            BuBet = 0
        End If
        Set RpCol = RpCls.Find(Ban_GeBetrag)
        If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
            GeBet = RpRow.Record(RpCol.ItemIndex).Value
        Else
            GeBet = 0
        End If
        Set RpCol = RpCls.Find(Ban_Ausgabe)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BaAus = LCase(RpRow.Record(RpCol.ItemIndex).Value)
        Else
            BaAus = "ja"
        End If
        Set RpCol = RpCls.Find(Ban_Bezahlt)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BaBez = LCase(RpRow.Record(RpCol.ItemIndex).Value)
        Else
            BaBez = "ja"
        End If
        Set RpCol = RpCls.Find(Ban_Selekt)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BaSel = LCase(RpRow.Record(RpCol.ItemIndex).Value)
        Else
            BaSel = "ja"
        End If
        Set RpCol = RpCls.Find(Ban_IDZ)
        BaIDZ = CInt(RpRow.Record(RpCol.ItemIndex).Value)

        If GuNum > 0 Then
            ReZuo = False
            TeTit = "Rechnung Zuordnen"
            TeMai = "Der markierte Eintrag ist keine Rechnung"
            TeInh = "Der markierte Eintrag ist eine Gutschrift und kann keiner eingehenden Zahlung zugeordnet werden."
            TeFus = "Es können ausschließlich Rechnungen zugeordnet werden."
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
            Exit Sub
        End If
        
        If ReAbg = False Then
            ReZuo = False
            TeTit = "Rechnung Zuordnen"
            TeMai = "Der markierte Rechnung wurde noch nicht abgeschlossen"
            TeInh = "Nur Rechnungen, die bereits abgeschlossen wurden, können einem Umsatz zugeordnet werden."
            TeFus = "Es wird davon ausgagangen, dass Rechnungen, die noch nicht abgeschlossen wurden, dem Patienten noch nicht zugestellt wurden."
            Exit Sub
        End If

        If BaIDZ < 0 Then
            ReZuo = False
            TeTit = "Rechnung Zuordnen"
            TeMai = "Diesem Umsatz kann keine Rechnung zugeordnet werden"
            TeInh = "Dieser Umsatz wurde gekennzeichnet. Es kann daher keine weiterere Rechnung zugeordnet werden."
            TeFus = "Um die Kennzeichnung aufzuheben ist es erforderlich, den Umsatz ein weiters Mal zu kennzeichnen."
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
            Exit Sub
        End If
        
        If BaBez = "ja" Then
            ReZuo = False
            TeTit = "Rechnung Zuordnen"
            TeMai = "Diesem Umsatz kann keine Rechnung zugeordnet werden"
            TeInh = "Aus diesem Umsatz wurde bereits eine Erlösbuchung abgeleitet. Es kann daher keine weitere Rechnung zugeordnet werden."
            TeFus = "Wurden diesem Umsatz eine falsche Rechnung zugeordnet, so kann diese Zuordnung über die gleichnamige Funktion wieder aufgehoben werden."
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
            Exit Sub
        End If

        If BaSel = "ja" Then
            TeTit = "Rechnung Zuordnen"
            TeMai = "Möchten Sie diesem Umsatz eine weitere Rechnung zuordnen?"
            TeInh = "Dem markierten Umsatz wurde bereits eine Rechnung zugeordnet. Klicken Sie auf Ja, um eine weitere Rechnung zuzuordnen."
            TeFus = "Wurden diesem Umsatz eine falsche Rechnung zugeordnet, so kann diese Zuordnung über die gleichnamige Funktion wieder aufgehoben werden."
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, False, FM.hwnd
            If GlMes <> 33565 Then
                ReZuo = False
                Exit Sub
            Else
                ReZuo = True
            End If
        End If

        If PatNr > 0 Then
            If PaNum <> PatNr Then
                Mld1 = "Dieser Umsatz ist bereits dem Patienten: " & PatSt & " zugeordnet. Möchten Sie diesem Umsatz wirklich den Patienten: " & PaStr & " zuordnen?"
                Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
                If Frage = 6 Then
                    ReZuo = True
                Else
                    ReZuo = False
                    Exit Sub
                End If
            Else
                ReZuo = True
            End If
        Else
            ReZuo = True
        End If

        If BuBet > ReBet Then
            Mld1 = "Der Umsatzbetrag von: " & Format$(BuBet, GlWa1) & " ist größer als der Rechnungsbetrag von : " & Format$(ReBet, GlWa1) & ". Soll diese Rechnung trotzdem zugeordnet werden?"
            Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
            If Frage = 6 Then
                ReZuo = True
            Else
                ReZuo = False
                Exit Sub
            End If
        Else
            ReZuo = True
        End If

        If ReZuo = True Then
            Screen.MousePointer = vbHourglass
        
            If GlTyp < 2 Then
                SQL1 = "SELECT * FROM dbo.qrySimBaSu WHERE ID2 = " & IdxNr
            Else
                SQL1 = "SELECT * FROM qrySimBaSu WHERE [ID2] = " & IdxNr & ";"
            End If
            Set RS125 = New ADODB.Recordset
            With RS125
                .CursorLocation = adUseClient
                .Source = SQL1
                .ActiveConnection = DB1
                .CursorType = adOpenDynamic
                .LockType = adLockOptimistic
                .Open Options:=adCmdText
            End With
            If RS125.RecordCount > 0 Then
                If RS125.Supports(adUpdate) = True Then
                    If RS125.Fields("RechNr").Value = vbNullString Or IsNull(RS125.Fields("RechNr").Value) = True Then
                        RS125.Fields("RGBetrag").Value = ReBet
                        RS125.Fields("RechNr").Value = ReStr
                        RS125.Fields("IDR").Value = ReNum
                        RS125.Fields("ID0").Value = PaNum
                        RS125.Fields("IDM").Value = ManNr
                        RS125.Fields("IDT").Value = MitNr
                        RS125.Fields("GuiID").Value = TmGui
                        RS125.Fields("Kommentar").Value = PaStr
                        RS125.Fields("Selekt").Value = True
                        RS125.Update
                    End If
                End If
            End If
            RS125.Close
            Set RS125 = Nothing
            
            
            Screen.MousePointer = vbNormal
        End If
    End If
End If

Set RpSel = Nothing
Set RpCo1 = Nothing
Set RpCo7 = Nothing

Set clFen = Nothing

Screen.MousePointer = vbHourglass
DoEvents
SUpBa RowNr
DoEvents
Screen.MousePointer = vbNormal

Exit Sub

