                                    RS122.Fields("Testcode").Value = RS121.Fields("Testcode").Value
                                    RS122.Fields("StartPo").Value = RS121.Fields("StartPo").Value
                                    RS122.Fields("Länge").Value = RS121.Fields("Länge").Value
                                    RS122.Fields("Spezi").Value = RS121.Fields("Spezi").Value
                                Else
                                    ProNr = RS121.Fields("ID4").Value
                                    ParAu = RS121.Fields("IDA").Value
                                    Set RS123 = New ADODB.Recordset 'Angehängte Parameter
                                    RS123.CursorLocation = adUseClient
                                    Set RS123 = DBCmRe2("qryLabAuSto", "@IdxNr", "@AufNr", ProNr, ParAu)
                                    If RS123.RecordCount > 0 Then
                                        Do
                                        RS122.AddNew
                                        RS122.Fields("IDB").Value = BerID
                                        RS122.Fields("ID4").Value = RS123.Fields("ID0").Value
                                        RS122.Fields("Ident").Value = RS123.Fields("GOIK").Value
                                        RS122.Fields("Testbezeichnung").Value = RS123.Fields("IDKurz").Value
                                        RS122.Fields("Einheit").Value = RS123.Fields("Einheit").Value
                                        If Not IsNull(RS123.Fields("IDU").Value) Then RS122.Fields("IDU").Value = RS123.Fields("IDU").Value
                                        If Not IsNull(RS123.Fields("Testcode").Value) Then RS122.Fields("Testcode").Value = RS123.Fields("Testcode").Value
                                        If Not IsNull(RS123.Fields("StartPo").Value) Then RS122.Fields("StartPo").Value = RS123.Fields("StartPo").Value
                                        If Not IsNull(RS123.Fields("Länge").Value) Then RS122.Fields("Länge").Value = RS123.Fields("Länge").Value
                                        If Not IsNull(RS123.Fields("Spezi").Value) Then RS122.Fields("Spezi").Value = RS123.Fields("Spezi").Value
                                        RS123.MoveNext
                                        Loop Until RS123.EOF
                                    End If
                                    RS123.Close
                                    Set RS123 = Nothing
                                End If
                                AktPa = AktPa + 1
                                RS121.MoveNext
                                Loop Until RS121.EOF
                            End If
                            RS121.Close
                            Set RS121 = Nothing
                            
                            PrBr1.Value = AktBe
                            TeBer(AktBe) = BerID
                            AktBe = AktBe + 1
                        Else
                            Mld1 = "Der Auftrag " & AuStr & " wurde bereits gespeichert"
                            Tit1 = "Speichern"
                            SPopu Tit1, Mld1, IC48_Forbidden
                        End If

                    End If
                Next RpRow
            End If
            
            If RS122.Supports(adUpdateBatch) Then 'Neue Testdaten speichern
                Set RS122.ActiveConnection = DB1
                RS122.UpdateBatch
            End If
            
            If RS124.Supports(adAddNew) Then
                For AktBe = 1 To UBound(TeBer())
                    BerID = TeBer(AktBe)
                    Set RS125 = New ADODB.Recordset 'Neue Testdaten IDs
                    RS125.CursorLocation = adUseClient
                    Set RS125 = DBCmRe1("qryLabBeTe", "@IdxNr", BerID)
                    GesZa = RS125.RecordCount
                    If GesZa > 0 Then
                        AktPa = 1
                        Do
                        RS124.AddNew
                        RS124.Fields("TID").Value = RS125.Fields("ID0").Value
                        Select Case RS125.Fields("Geschlech").Value
                        Case "M":
                            If RS125.Fields("NorMann").Value <> vbNullString Then
                                RS124.Fields("Normwert").Value = RS125.Fields("NorMann").Value
                            End If
                        Case "W":
                            If RS125.Fields("NorFrau").Value <> vbNullString Then
                                RS124.Fields("Normwert").Value = RS125.Fields("NorFrau").Value
                            End If
                        Case "K":
                            If RS125.Fields("NorKind").Value <> vbNullString Then
                                RS124.Fields("Normwert").Value = RS125.Fields("NorKind").Value
                            End If
                        End Select
                        If TxDum.Text = "B" Then Exit Do 'Abbrechen
                        AktPa = AktPa + 1
                        RS125.MoveNext
                        Loop Until RS125.EOF
                    End If
                    RS125.Close
                    Set RS125 = Nothing
                    PrBr2.Value = AktBe
                    DoEvents
                Next AktBe
            End If
            
            If RS124.Supports(adUpdateBatch) Then 'Neue Testdaten speichern
                Set RS124.ActiveConnection = DB1
                RS124.UpdateBatch
            End If
            
            RS122.Close
            RS124.Close
            Set RS122 = Nothing
            Set RS124 = Nothing
            
            If GlJet = True Then SDBSav
            
            Unload frmStatus
            Set frmStatus = Nothing
            DoEvents

            SUpAu RowNr
            SMark
        End If
    End If
End If

Set RpCls = Nothing
Set RpSel = Nothing
Set RpCo1 = Nothing
Set RpCo5 = Nothing
Set RpCo6 = Nothing

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_LaBrt " & Err.Number
Resume Next

End Sub
