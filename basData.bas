Public Function S_KrDp(ByVal PatNr As Long) As String
On Error GoTo SuErr
'Lädt die Aufnahmediagnosen in das Krankaenblatt

Dim TmStr As String
Dim AktPo As Integer

Set FM = frmMain
Set LiVw2 = FM.lstView2
Set LiIts = LiVw2.ListItems

LiIts.Clear

Set RS125 = New ADODB.Recordset
RS125.CursorLocation = adUseClient
If GlDSo = True Then 'Katalogdiagnosen alphabetisch sortieren
    Set RS125 = DBCmRe1("qrySimAbDiPa", "@IdxNr", PatNr)
Else
    Set RS125 = DBCmRe1("qrySimAbDiP2", "@IdxNr", PatNr)
End If
If RS125.RecordCount > 0 Then
    Do
    AktPo = AktPo + 1
    If RS125.Fields("Datum").Value <> vbNullString Then
        If GldId = True Then 'Diagnosedatumn anzeigen
            If GlICD = True Then 'ICD anzeigen
                Set LiItm = LiIts.Add(AktPo, "D" & RS125.Fields("ID2").Value, RS125.Fields("Datum").Value & ": " & RS125.Fields("IDKurz").Value & " (" & Trim$(RS125.Fields("GOID").Value) & ")", IC16_Doc_Norm)
                TmStr = TmStr & "; " & RS125.Fields("Datum").Value & ": " & RS125.Fields("IDKurz").Value & " (" & Trim$(RS125.Fields("GOID").Value) & ")"
            Else
                Set LiItm = LiIts.Add(AktPo, "D" & RS125.Fields("ID2").Value, RS125.Fields("Datum").Value & ": " & RS125.Fields("IDKurz").Value, IC16_Doc_Norm)
                TmStr = TmStr & "; " & RS125.Fields("Datum").Value & ": " & RS125.Fields("IDKurz").Value
            End If
        Else
            If GlICD = True Then 'ICD anzeigen
                Set LiItm = LiIts.Add(AktPo, "D" & RS125.Fields("ID2").Value, RS125.Fields("IDKurz").Value & " (" & Trim$(RS125.Fields("GOID").Value) & ")", IC16_Doc_Norm)
                TmStr = TmStr & "; " & RS125.Fields("IDKurz").Value & " (" & Trim$(RS125.Fields("GOID").Value) & ")"
            Else
                Set LiItm = LiIts.Add(AktPo, "D" & RS125.Fields("ID2").Value, RS125.Fields("IDKurz").Value, IC16_Doc_Norm)
                TmStr = TmStr & "; " & RS125.Fields("IDKurz").Value
            End If
        End If
    Else
        If GlICD = True Then 'ICD anzeigen
            Set LiItm = LiIts.Add(AktPo, "D" & RS125.Fields("ID2").Value, RS125.Fields("IDKurz").Value & " (" & Trim$(RS125.Fields("GOID").Value) & ")", IC16_Doc_Norm)
            TmStr = TmStr & "; " & RS125.Fields("IDKurz").Value & " (" & Trim$(RS125.Fields("GOID").Value) & ")"
        Else
            Set LiItm = LiIts.Add(AktPo, "D" & RS125.Fields("ID2").Value, RS125.Fields("IDKurz").Value, IC16_Doc_Norm)
            TmStr = TmStr & "; " & RS125.Fields("IDKurz").Value
        End If
    End If
    RS125.MoveNext
    Loop Until RS125.EOF
End If
RS125.Close
Set RS125 = Nothing

If TmStr <> vbNullString Then
    If Left$(TmStr, 1) = ";" Then
        TmStr = Right$(TmStr, Len(TmStr) - 1)
    End If
    S_KrDp = LTrim$(TmStr)
Else
    S_KrDp = vbNullString
End If

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KrDp " & Err.Number
Resume Next

End Function
Public Sub S_KrEi(Optional ByVal NeDat As Boolean = False, Optional ByVal Dupli As Boolean = False)
On Error GoTo PeErr
'Fügt Inhalt aus ClipArry in Datenbank ein

Dim NeuDa As Date
Dim RowNr As Long
Dim PatNr As Long
Dim ReNum As Long
Dim SorNr As Long
Dim RowFi As Long
Dim RecFi As Long
Dim StMan As Long
Dim SQL3 As String
Dim KrGui As String
Dim FoFak As Single
Dim ReBet As Double
Dim ReRab As Single
Dim NeReB As Double
Dim ReStu As Single
Dim ReStr As String
Dim PaStr As String
Dim KrRow As Integer
Dim FoWär As Integer
Dim AktPo As Integer
Dim AnzRo As Integer
Dim ReAbg As Boolean
Dim RetWe As Boolean
Dim EinOk As Boolean
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCoK As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set TxDa1 = FM.txtDatu1
Set RpCo3 = FM.repCont3
Set RpCo4 = FM.repCont4
Set RpCo6 = FM.repCont6
Set RpCoK = FM.repContK
Set RpCls = RpCo3.Columns
Set RpSel = RpCo3.SelectedRows

If IsDate(TxDa1.Text) Then
    NeuDa = DateValue(TxDa1.Text)
Else
    NeDat = False
End If

If ClKop = True Then 'Cliparry kopiert
    Select Case GlBut
    Case RibTab_Krankenbla:
        If Dupli = True Then
            AnzRo = 1
        Else
            AnzRo = UBound(GlClp)
        End If

        For AktPo = 1 To AnzRo
            KrGui = CreateID("K")
            With GlNeK
                .PatNr = GlAdr
                .IdxNr = 0
                If Dupli = True Then
                    .EiDat = DateValue(Now)
                    .EiZei = TimeValue(Now)
                Else
                    .EiDat = DateValue(GlClp(AktPo, 1))
                    .EiZei = TimeValue(GlClp(AktPo, 12))
                End If
                .EiTyp = GlClp(AktPo, 2)
                .KoGui = KrGui
