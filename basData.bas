Public Sub S_AdFlt(Optional ByVal Flag As Boolean = False)
On Error GoTo ReErr
'Wendet einen Filter an

Dim RowNr As Long
Dim RowFi As Long
Dim SQL1 As String
Dim FiNam As String
Dim Krite As String
Dim SoStr As String
Dim AktZa As Integer
Dim SpIdx As Integer
Dim Mld1, Tit1 As String
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmCom As XtremeCommandBars.CommandBarComboBox
Dim RpCo2 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set CmBrs = FM.comBar01
Set TrLi1 = FM.trvList1
Set RpCo2 = FM.repCont2
Set RpRcs = RpCo2.Records
Set CmAcs = CmBrs.Actions
Set CmSta = CmBrs.StatusBar

Set CmCom = CmBrs.FindControl(CmCom, SY_AD_Adresse_SortFeld, , True)

SpIdx = CmCom.ListIndex

Select Case SpIdx
Case 1: SoStr = "[IDKurz]"
Case 2: SoStr = "[Name]"
Case 3: SoStr = "[Vorname]"
Case 4: SoStr = "[Firma1]"
Case 5: SoStr = "[Geboren]"
Case 6: SoStr = "[Straße]"
Case 7: SoStr = "[PLZ]"
Case 8: SoStr = "[Ort]"
Case 9: SoStr = "[Telefon1]"
Case 10: SoStr = "[Telefon1]"
Case 11: SoStr = "[Telefon5]"
Case 12:
    If GlTyp < 2 Then
        SoStr = "RIGHT ('00000000' + CONVERT (varchar(10), Mandant), 8)"
    Else
        SoStr = "Format$([Mandant],'00000000')"
    End If
End Select

Set clFil = New clsFile

If GlzPa <> GlPaK Then
    FiNam = TrLi1.SelectedItem.Text
    If clFil.FilVor(GlFPf & FiNam) = True Then
        With clFil
            .DaPfa = GlFPf
            .DaNam = FiNam
            SQL1 = .FilReSt
        End With
        If Len(SQL1) > 0 Then
            If Left$(SQL1, 6) <> "SELECT" Then
                If GlTyp < 2 Then
                    SQL1 = "SELECT * FROM dbo.qryAdrSu WHERE " & SQL1
                Else
                    SQL1 = "SELECT * FROM qryAdrSu WHERE " & SQL1
                End If
            End If

            Set RS147 = New ADODB.Recordset
            With RS147
                .CursorLocation = adUseClient
                .Source = SQL1
                .ActiveConnection = DB1
                .CursorType = adOpenForwardOnly
                .LockType = adLockReadOnly
                .Open Options:=adCmdText
            End With
            GlAdA = RS147.RecordCount
            
            If Flag = True Then
                If RS147.RecordCount > 0 Then
                    RS147.MoveFirst
                    Krite = "[ID0]=" & GlAId
                    RS147.Find Criteria:=Krite, SkipRecords:=0, SearchDirection:=adSearchForward
                    If Not (RS147.BOF Or RS147.EOF) Then
                        RowNr = RS147.AbsolutePosition
                    End If
                End If
            End If
            
            If GlAdA > 0 Then 'Anzahl gefundener Adressen
                With RpCo2
                    .EditItem Nothing, Nothing
                    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
                    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
                    If .Records.Count > 0 Then .Records.DeleteAll
                    .Populate
                End With
                                
                If RowNr > 0 Then
                    RowFi = RpCo2.TopRowIndex
                End If
                
                AdAry = RS147.GetRows 'Array Füllen
                DoEvents

                RpCo2.SetVirtualMode GlAdA 'Anzahl gefundener Adressen
                DoEvents
            
                Set RpRec = RpCo2.Records(0)
                For AktZa = 0 To 31
                    Set RpItm = RpRec.AddItem(vbNullString)
                Next AktZa
            
                DoEvents
                With RpCo2
                    .Populate
                    .SetCustomDraw xtpCustomBeforeDrawRow
                End With
                
                Set RpRws = RpCo2.Rows
                If RowNr > 0 Then
                    If RpRws.Count > 0 Then
                        If RowNr >= RpRws.Count Then
                            RowNr = RpRws.Count - 1
                        End If
                        RpCo2.TopRowIndex = RowFi
                        RpRws.Row(0).Selected = False
                        RpRws.Row(RowNr).EnsureVisible
                        RpRws.Row(RowNr).Selected = True
                        If GlFoc = True Then
                            Set RpCo2.FocusedRow = RpRws.Row(RowNr)
                        End If
                    End If
                End If
            Else
                GlAdA = 0
                If GlAdA > 0 Then
                    Erase AdAry
                End If
                RpCo2.SetVirtualMode 0
                                            
                DoEvents
                With RpCo2
                    .Populate
                    .SetCustomDraw xtpCustomBeforeDrawRow
                End With
                
                SPopu "Keine Adressen gefunden", "Es wurden keine Adressen gefunden, die dem Suchkriterium entsprechen", IC48_Information
            End If
            
            RS147.Close
            Set RS147 = Nothing
            
            SMark
        Else
            Mld1 = "Die Filterdatei " & TrLi1.SelectedItem.Text & ".sql" & " enthält keine gültige Filteranweisung"
            Tit1 = "Falscher Inhalt"
            WindowMess Mld1, Dial3, Tit1, FM.hwnd
        End If
    Else
        Mld1 = "Die Filterdatei " & TrLi1.SelectedItem.Text & ".sql" & " konnte nicht gefunden werden"
        Tit1 = "Datei nicht gefunden"
        WindowMess Mld1, Dial3, Tit1, FM.hwnd
    End If
    GlzPa = GlPaK
End If

Set RpRws = Nothing
Set RpRec = Nothing
Set RpCo2 = Nothing

Set clFil = Nothing

Exit Sub

ReErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_AdFlt " & Err.Number
Resume Next

End Sub
