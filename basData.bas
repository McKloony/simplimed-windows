Private Function S_LaNm() As String
On Error GoTo SuErr
'Ergänz das Feld PLZ bei Rechnungsnummer

Dim NeuDa As Date
Dim ReNum As String
Dim TmpNr As String
Dim RchNr As String
Dim Posit As Integer

Set RS121 = New ADODB.Recordset
With RS121
    .CursorLocation = adUseClient
    .Source = "qrySimReNuA"
    .ActiveConnection = DB1
    .CursorType = adOpenStatic
    .LockType = adLockBatchOptimistic
    .Open Options:=adCmdTableDirect
    Set .ActiveConnection = Nothing
End With

If RS121.RecordCount > 0 Then
    Do
    RchNr = RS121.Fields("RechNr").Value
    NeuDa = RS121.Fields("Datum").Value
    Posit = InStrRev(RchNr, "-", -1, 1)
    If Posit > 0 Then
        TmpNr = Mid$(RchNr, Posit + 1, Len(RchNr))
        If Len(TmpNr) > 6 Then TmpNr = Right$(TmpNr, 6)
    Else
        TmpNr = Right$(RchNr, 3)
    End If
    ReNum = Format$(TmpNr, "00000000")
    RS121.Fields("PLZ").Value = ReNum
    RS121.MoveNext
    Posit = 0
    Loop Until RS121.EOF
    If RS121.Supports(adUpdateBatch) Then
        Set RS121.ActiveConnection = DB1
        RS121.UpdateBatch
        Set RS121.ActiveConnection = Nothing
    End If
End If

RS121.Close
Set RS121 = Nothing

S_LaNm = ReNum

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_LaNm " & Err.Number
Resume Next

End Function
