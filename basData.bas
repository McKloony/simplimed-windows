Public Sub S_BuKaO()
On Error GoTo KoErr
'Löscht die Kassenzählung

Dim IdxNr As Long
Dim RowNr As Long
Dim RowFi As Long
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpRow As XtremeReportControl.ReportRow
Dim RpRws As XtremeReportControl.ReportRows
Dim RpCo1 As XtremeReportControl.ReportControl

Set FM = frmZaehlung
Set RpCo1 = FM.repCont1
Set RpSel = RpCo1.SelectedRows
Set RpRws = RpCo1.Rows

Tit1 = "Kassenzählung Entfernen"
Mld1 = "Soll die markierte Kassenzählung gelöscht werden?"

If RpSel.Count > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then

        Set RpRow = RpSel(0)
        RowNr = RpRow.Index
        RowFi = RpCo1.TopRowIndex
        IdxNr = RpRow.Record(0).Value
        
        DBCmEx1 "qrySimBuZaLo", "@IdxNr", IdxNr
        DoEvents
        
        S_BuKaL
        DoEvents
        
        Set RpRws = RpCo1.Rows
        If RowNr >= RpRws.Count Then
            RowNr = RpRws.Count - 1
        End If
        RpCo1.TopRowIndex = RowFi
        RpRws.Row(0).Selected = False
        RpRws.Row(RowNr).EnsureVisible
        RpRws.Row(RowNr).Selected = True
        If GlFoc = True Then
            Set RpCo1.FocusedRow = RpRws.Row(RowNr)
        End If
        IdxNr = RpRow.Record(0).Value
        S_BuKaD IdxNr
    End If
End If

