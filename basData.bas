Public Sub S_MaAdr()
On Error GoTo PoErr
'Öffnet die Adresseingabemaske

Dim IdxNr As Long
Dim GesZa As Long
Dim FiNam As String
Dim FiPfa As String
Dim EmEmp As String
Dim MeTex As String
Dim MaiTo As String
Dim MaSpl As String
Dim PaPrx As String
Dim PaVor As String
Dim PaNam As String
Dim PaStr As String
Dim PaPLZ As String
Dim PaOrt As String
Dim PaLan As String
Dim PaTel As String
Dim PaEma As String
Dim CuVal As String
Dim Posit As Integer
Dim LiPos As Integer
Dim AktZa As Integer
Dim RowNr As Integer
Dim RoIdx As Integer
Dim CoIdx As Integer
Dim EmaOK As Boolean
Dim RpRow As XtremeReportControl.ReportRow
Dim RpCo0 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RetWe() As String
Dim MaBod() As String
Dim MaLin() As String
Dim MaSpa() As String
Dim MaAdr() As Variant

Set MaiGeTo = New EAGetMailObjLib.Tools
Set MaiMail = New EAGetMailObjLib.Mail

Set FM = frmMain
Set RpCo0 = FM.repCont0
Set RpCls = RpCo0.Columns
Set RpSel = RpCo0.SelectedRows

MaiMail.LicenseCode = "EG-C1653719494-01199-8BVCAA171B372F1D-F797V24BDU55166A"

EmEmp = "shop@simplimed.de"

Screen.MousePointer = vbHourglass
DoEvents

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        RowNr = RpRow.Index
        IdxNr = MaAry(Mai_IDA, RowNr)
        FiNam = MaAry(Mai_MailFile, RowNr)
        FiPfa = GlDpf & "Emails\" & FiNam
        
        MaiMail.LoadFile FiPfa, True
        
        If MaiMail.IsEncrypted = True Then
            Set MaiMail = MaiMail.Decrypt(Nothing)
            If Err.Number <> 0 Then
                SPopu "Emailverschlüsselung", Err.Description, IC48_Forbidden
            End If
        End If
        
        If MaiMail.IsSigned = True Then
            MaiMail.VerifySignature
            If Err.Number <> 0 Then
                SPopu "Emailsignatur", Err.Description, IC48_Forbidden
            End If
        End If

        MeTex = MaiMail.TextBody

        ReDim Preserve RetWe(1, 0)

        MaAdr = MaiMail.To
        MaiTo = MaAdr(LBound(MaAdr)).Address

        If EmEmp = MaiTo Then
            EmaOK = True
            MaBod = Split(MeTex, vbCrLf)
            Posit = 0
            LiPos = 0
            Do While Posit <= UBound(MaBod)
                If Trim$(MaBod(Posit)) <> vbNullString Then
                    ReDim Preserve MaLin(LiPos + 1)
                    MaLin(LiPos) = MaBod(Posit)
                    LiPos = LiPos + 1
                End If
                Posit = Posit + 1
            Loop
            If UBound(MaLin) > 0 And MaLin(UBound(MaLin)) = "" Then
                ReDim Preserve MaLin(UBound(MaLin) - 1)
            End If
            If UBound(MaLin) > 1 Then
                ReDim Preserve RetWe(1, 1)
                RetWe(0, 0) = Trim$(MaLin(AktZa))
            End If
            RoIdx = -1
            For AktZa = 0 To UBound(MaLin)
                Dim startAktza As Integer
                startAktza = AktZa
                CuVal = MaLin(AktZa)
                If CuVal = "---row---" Then
                    RoIdx = RoIdx + 1
                    CoIdx = -1
                    AktZa = AktZa + 1
                    CuVal = MaLin(AktZa)
                End If
                If CuVal = "---column---" Then
                    CoIdx = CoIdx + 1
                    AktZa = AktZa + 1
                    CuVal = MaLin(AktZa)
                End If
                If CuVal <> "---row---" And CuVal <> "---column---" Then
                    ReDim Preserve RetWe(1, RoIdx + 1)
                    RetWe(CoIdx, RoIdx) = Trim$(CuVal)
                Else
                    AktZa = startAktza
                End If
            Next AktZa
            If UBound(RetWe, 2) > 0 And RetWe(1, UBound(RetWe, 2)) = "" Then
                ReDim Preserve RetWe(1, UBound(RetWe, 2) - 1)
            End If
        End If
        
    End If
    
    MaiMail.Clear
End If

If EmaOK = False Then
    SAdre 1
    Exit Sub
End If

If UBound(RetWe, 2) < 5 Or InStr(1, RetWe(0, 5), "plz") = 0 Then
    SAdre 1
    Exit Sub
End If

PaPrx = RetWe(1, 1)
PaVor = RetWe(1, 2)
PaNam = RetWe(1, 3)
PaStr = RetWe(1, 4)
PaPLZ = RetWe(1, 5)
PaOrt = RetWe(1, 6)
PaLan = RetWe(1, 7)
PaTel = RetWe(1, 8)
PaEma = RetWe(1, 9)

Set RS158 = New ADODB.Recordset
RS158.CursorLocation = adUseClient
Set RS158 = DBCmRe1("qrySimAdEma", "@IdStr", "%" & PaEma & "%")
GesZa = RS158.RecordCount
If GesZa > 0 Then
    Load frmMailAdr
    S_MaAd1 RS158, RetWe
Else
    Set RS159 = New ADODB.Recordset
    RS159.CursorLocation = adUseClient
    Set RS159 = DBCmRe1("qrySimAdEm2", "@IdStr", "%" & PaEma & "%")
    GesZa = RS159.RecordCount
    If GesZa > 0 Then
        Load frmMailAdr
        S_MaAd1 RS159, RetWe
    Else
        Set RS160 = New ADODB.Recordset
        RS160.CursorLocation = adUseClient
        Set RS160 = DBCmRe1("qrySimAdKur", "@IdStr", "%" & PaNam & ", " & PaVor & "%")
        GesZa = RS160.RecordCount
        If GesZa > 0 Then
            Load frmMailAdr
            S_MaAd1 RS160, RetWe
        Else
            Set RS161 = New ADODB.Recordset
            RS161.CursorLocation = adUseClient
            Set RS161 = DBCmRe1("qrySimAdPLZ", "@IdStr", "%" & PaPLZ & "%")
            GesZa = RS161.RecordCount
            If GesZa > 0 Then
                Load frmMailAdr
                S_MaAd1 RS161, RetWe
            Else
                S_MaAd2 RetWe
            End If
            RS161.Close
            Set RS161 = Nothing
        End If
        RS160.Close
        Set RS160 = Nothing
    End If
    RS159.Close
    Set RS159 = Nothing
End If
RS158.Close
Set RS158 = Nothing

Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
Case 1: DBCmEx2 "qryMailInGel", "@IdGel", "@IdxNr", -1, IdxNr
Case 2: DBCmEx2 "qryMailOutGel", "@IdGel", "@IdxNr", -1, IdxNr
End Select
DoEvents

If GlSuI.SuIdx < 1 Then
    SUpMa RowNr
End If

DoEvents
Screen.MousePointer = vbNormal

Set RpCls = Nothing
Set RpSel = Nothing
Set RpCo0 = Nothing
Set FM = Nothing

Exit Sub

PoErr:
If GlDbg = True Then SErLog Err.Description & " S_MaAdr " & Err.Number
Resume Next

End Sub
