            RpRws.Row(RowNr - 1).EnsureVisible
            RpRws.Row(RowNr - 1).Selected = True
            If GlFoc = True Then
                Set RpCo0.FocusedRow = RpRws.Row(RowNr - 1)
            End If
        Else
            RpRws.Row(0).EnsureVisible
            RpRws.Row(0).Selected = True
            If GlFoc = True Then
                Set RpCo0.FocusedRow = RpRws.Row(0)
            End If
        End If
    End If
    
    CmAcs(TX_Mail_Vollst).Enabled = True
    DoEvents
Else
    GlEmV = 0
    If GlEmV > 0 Then Erase MaAry
    RpCo0.SetVirtualMode 0
    
    DoEvents
    With RpCo0
        .Populate
        .SetCustomDraw xtpCustomBeforeDrawRow
    End With
        
    SPopu "Keine Emails gefunden", "Es wurden keine Emails gefunden, die dem Suchkriterium entsprechen", IC48_Information
End If

RS147.Close
Set RS147 = Nothing

SMark

Set RpRws = Nothing
Set RpRec = Nothing
Set RpCo0 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then SErLog Err.Description & " S_MaSuc " & Err.Number
Resume Next

End Sub
