    MitNr = RpRow.Record(RpCol.ItemIndex).Value
Else
    MitNr = GlMiA(GlSmI, 2)
End If
Set RpCol = RpCls.Find(Rec_Selekt)
ReAbg = CBool(RpRow.Record(RpCol.ItemIndex).Value)

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows
    
AnzPo = RpSel.Count

If AnzPo > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        RowNr = RpRow.Index
                        
        Set RpCol = RpCls.Find(Ban_ID2)
        IdxNr = RpRow.Record(RpCol.ItemIndex).Value

        Set RpCol = RpCls.Find(Ban_ID0)
        If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
