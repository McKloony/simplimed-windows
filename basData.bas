        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdText
    End With
    
    GesZa = RS130.RecordCount
    If GesZa > 0 Then
        S_MaKRc RS130, KaTyp
    End If
    RS130.Close
    Set RS130 = Nothing
Case 2:
    Set RS130 = New ADODB.Recordset
    With RS130
        .CursorLocation = adUseClient
        .Source = SQL2
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdText
    End With

    GesZa = RS130.RecordCount
    If GesZa > 0 Then
        S_MaKRc RS130, KaTyp
    End If
    RS130.Close
    Set RS130 = Nothing
End Select

RpCon.Populate

If GesZa > 0 Then
    Set RpRws = RpCon.Rows
    If RowNr > 0 Then
        If RowNr >= RpRws.Count Then
            RowNr = RpRws.Count - 1
        End If
        RpCon.TopRowIndex = RowFi
        RpRws.Row(0).Selected = False
        RpRws.Row(RowNr).EnsureVisible
        RpRws.Row(RowNr).Selected = True
        If GlFoc = True Then
            Set RpCon.FocusedRow = RpRws.Row(RowNr)
        End If
    Else
        RpRws.Row(0).Selected = True
    End If
End If

Set RpRws = Nothing
Set RpCon = Nothing

Exit Sub

KoErr:
If GlDbg = True Then SErLog Err.Description & " S_MaKLa " & Err.Number
Resume Next

End Sub
Public Sub S_MaKLo(ByVal LiTyp As Integer)
On Error GoTo GrErr
'Löscht die markierten Einträge

Dim IdxNr As Long
Dim GesZa As Long
Dim RowNr As Long
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim CmBrs As XtremeCommandBars.CommandBars
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpCon As XtremeReportControl.ReportControl
Dim RpRow As XtremeReportControl.ReportRow

Tit1 = "Eintrag Entfernen"

Set FM = frmMailKont
Set CmBrs = FM.comBar02
Set RpCon = FM.repCont1
Set RpCls = RpCon.Columns
Set RpSel = RpCon.SelectedRows

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

GesZa = RpSel.Count

If GesZa = 0 Then
    Exit Sub
ElseIf GesZa = 1 Then
    Mld1 = "Möchten Sie den markierten Eintrag wirklich löschen?"
ElseIf GesZa > 1 Then
    Mld1 = "Möchten Sie die " & GesZa & " markierten Einträge wirklich löschen?"
End If

Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
If Frage = 6 Then
    Screen.MousePointer = vbHourglass
    clFen.FenDsk 2

    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            RowNr = RpRow.Index
            Select Case LiTyp
            Case 1:
                Set RpCol = RpCls.Find(Kon_IDK)
                IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                DBCmEx1 "qryMailKonDel", "@IdxNr", IdxNr
            Case 2:
                Set RpCol = RpCls.Find(SPM_IDA)
                IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                DBCmEx1 "qryMailSpDe", "@IdxNr", IdxNr
            End Select
        End If
    Next RpRow

    S_MaKLa RowNr, LiTyp
    S_MaKPo LiTyp
    
    clFen.FenDsk 3
    Screen.MousePointer = vbNormal
End If

Set CmBrs = Nothing
Set RpSel = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCon = Nothing

Set clFen = Nothing

Exit Sub

GrErr:
If GlDbg = True Then SErLog Err.Description & " S_MaKLo " & Err.Number
Resume Next

End Sub
Public Sub S_MaKom()
