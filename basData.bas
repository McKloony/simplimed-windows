Public Function S_TeTm(ByVal PatNr As Long) As String
On Error GoTo LoErr
'gibt Termine des Patienten wieder

Dim TmStr As String
Dim TeSta As String
Dim TerSt As Integer

Set RS127 = New ADODB.Recordset
RS127.CursorLocation = adUseClient
Set RS127 = DBCmRe1("qryPrTerm4", "@IdStr", PatNr)
If RS127.RecordCount > 0 Then
    Do
    TmStr = TmStr & vbCrLf
    TmStr = TmStr & Format$(RS127.Fields("VonDat").Value, "ddd") & ", " & Format$(RS127.Fields("VonDat").Value, "dd.mm.yyyy") & " - " & Format$(RS127.Fields("ZeiVon").Value, "hh:mm") & " Uhr"
    If RS127.Fields("Betreff").Value <> vbNullString Then
        TmStr = TmStr & " - " & RS127.Fields("Betreff").Value
    End If
    If RS127.Fields("Status").Value <> vbNullString Then
        TerSt = CInt(RS127.Fields("Status").Value)
        If TerSt <> 3 Then
            TeSta = GlTeS(TerSt, 1)
            If TeSta <> vbNullString Then
                TmStr = TmStr & " - " & TeSta
            End If
        End If
    End If
    RS127.MoveNext
    Loop Until RS127.EOF
End If
RS127.Close
Set RS127 = Nothing

S_TeTm = TmStr

Exit Function

LoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TeTm " & Err.Number
Resume Next

End Function
