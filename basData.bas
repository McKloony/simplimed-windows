Dim CmEdi As XtremeCommandBars.CommandBarEdit
Dim CmCoS As XtremeCommandBars.CommandBarControls
Dim CmCom As XtremeCommandBars.CommandBarComboBox
Dim CmCoZ As XtremeCommandBars.CommandBarComboBox
Dim RpRow As XtremeReportControl.ReportRow
Dim RpRws As XtremeReportControl.ReportRows
Dim RpCo2 As XtremeReportControl.ReportControl

Set FM = frmZaehlung
Set CmBrs = FM.comBar02
Set RpCo2 = FM.repCont2
Set CmAcs = CmBrs.Actions
Set CmSta = CmBrs.StatusBar
Set RpRcs = RpCo2.Records
Set RpRws = RpCo2.Rows

Set CmEdi = CmBrs.FindControl(CmEdi, KA_Kalen, , True)
Set CmCoZ = CmBrs.FindControl(CmCoZ, KA_Uhrze, , True)
Set CmCom = CmBrs.FindControl(CmCom, KA_SuCo1, , True)

IdBnk = CmCom.ItemData(CmCom.ListIndex)

If CmEdi.Text <> vbNullString Then
    If IsDate(CmEdi.Text) = True Then
        NeuDa = CDate(CmEdi.Text)
    Else
        NeuDa = Date
    End If
Else
    NeuDa = Date
End If

BuJah = Year(NeuDa)

If CmCoZ.Text <> vbNullString Then
    If IsDate(CmCoZ.Text) = True Then
        NeuZe = TimeValue(CmCoZ.Text)
    Else
        NeuZe = TimeValue(Now)
    End If
Else
    NeuZe = TimeValue(Now)
End If

For Each RpRec In RpRcs
    If RpRec.Item(4).Value <> vbNullString Then
        If IsNumeric(RpRec.Item(4).Value) = True Then
            If CSng(RpRec.Item(4).Value) > 0 Then
                GeSum = GeSum + CDbl(RpRec.Item(4).Value)
            End If
        End If
    End If
Next RpRec

Set RS121 = New ADODB.Recordset
RS121.CursorLocation = adUseClient
Set RS121 = DBCmRe2("qrySimBuSuB1", "@BuJah", "@IdBnk", BuJah, IdBnk)
If RS121.RecordCount > 0 Then
    If RS121.Fields("Einnahme").Value <> vbNullString Then
        SaEin = RS121.Fields("Einnahme").Value
    Else
        SaEin = 0
    End If
    If RS121.Fields("Ausgabe").Value <> vbNullString Then
        SaAus = RS121.Fields("Ausgabe").Value
    Else
        SaAus = 0
    End If
    SaBan = SaEin - SaAus
End If
RS121.Close
Set RS121 = Nothing
DoEvents

Set RS125 = New ADODB.Recordset
With RS125 'Neue Zählung
    .CursorLocation = adUseClient
    .Source = "qrySimBuZaNe"
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdTableDirect
End With

If RS125.Supports(adAddNew) Then RS125.AddNew
RS125.Fields("ID3").Value = IdBnk
RS125.Fields("Datum").Value = NeuDa
RS125.Fields("Uhrzeit").Value = NeuZe
RS125.Fields("Gesamt").Value = GeSum
RS125.Fields("Laufend").Value = SaBan
RS125.Fields("Different").Value = SaBan - GeSum
For Each RpRec In RpRcs
    If RpRec.Item(3).Value <> vbNullString Then
        If IsNumeric(RpRec.Item(3).Value) = True Then
            If CInt(RpRec.Item(3).Value) > 0 Then
                Select Case RpRec.Index
                Case 0: If RpRec.Item(3).Value <> vbNullString Then RS125.Fields("M001").Value = RpRec.Item(3).Value
                Case 1: If RpRec.Item(3).Value <> vbNullString Then RS125.Fields("M002").Value = RpRec.Item(3).Value
                Case 2: If RpRec.Item(3).Value <> vbNullString Then RS125.Fields("M005").Value = RpRec.Item(3).Value
                Case 3: If RpRec.Item(3).Value <> vbNullString Then RS125.Fields("M010").Value = RpRec.Item(3).Value
                Case 4: If RpRec.Item(3).Value <> vbNullString Then RS125.Fields("M020").Value = RpRec.Item(3).Value
                Case 5: If RpRec.Item(3).Value <> vbNullString Then RS125.Fields("M050").Value = RpRec.Item(3).Value
                Case 6: If RpRec.Item(3).Value <> vbNullString Then RS125.Fields("M100").Value = RpRec.Item(3).Value
                Case 7: If RpRec.Item(3).Value <> vbNullString Then RS125.Fields("M200").Value = RpRec.Item(3).Value
                Case 8: If RpRec.Item(3).Value <> vbNullString Then RS125.Fields("S005").Value = RpRec.Item(3).Value
                Case 9: If RpRec.Item(3).Value <> vbNullString Then RS125.Fields("S010").Value = RpRec.Item(3).Value
                Case 10: If RpRec.Item(3).Value <> vbNullString Then RS125.Fields("S020").Value = RpRec.Item(3).Value
                Case 11: If RpRec.Item(3).Value <> vbNullString Then RS125.Fields("S050").Value = RpRec.Item(3).Value
                Case 12: If RpRec.Item(3).Value <> vbNullString Then RS125.Fields("S100").Value = RpRec.Item(3).Value
                Case 13: If RpRec.Item(3).Value <> vbNullString Then RS125.Fields("S200").Value = RpRec.Item(3).Value
                Case 14: If RpRec.Item(3).Value <> vbNullString Then RS125.Fields("S500").Value = RpRec.Item(3).Value
                End Select
            End If
        End If
    End If
Next RpRec
RS125.Update
RS125.Close
Set RS125 = Nothing

With RpCo2
    .EditItem Nothing, Nothing
    If .AllowEdit = True Then .AllowEdit = False
    If .EditOnClick = True Then .EditOnClick = False
    .Populate
End With

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCo2 = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BuKaS " & Err.Number
Resume Next

