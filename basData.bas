Private Sub S_MaSp(ByVal EmAdr As String, Optional ByVal EmBet As String, Optional ByVal EiLoe As Boolean = False)
On Error GoTo KoErr
'Fügt einen Spamfilter hinzu oder löscht diesen

Dim SQL1 As String
Dim IdxNr As Long
Dim AktZa As Integer

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qryMailSpAd"
Else
    SQL1 = "SELECT * FROM qryMailSpAd;"
End If

If EiLoe = True Then
    Set RS128 = New ADODB.Recordset
    RS128.CursorLocation = adUseClient
    Set RS128 = DBCmRe1("qryMailSpSe", "@IdStr", EmAdr)
    If RS128.RecordCount > 0 Then
        IdxNr = RS128.Fields("IDA").Value
        DBCmEx1 "qryMailSpDe", "@IdxNr", IdxNr
    Else
        Set RS129 = New ADODB.Recordset
        RS129.CursorLocation = adUseClient
        Set RS129 = DBCmRe1("qryMailSpSu", "@IdStr", EmAdr)
        If RS129.RecordCount > 0 Then
            IdxNr = RS129.Fields("IDA").Value
            DBCmEx1 "qryMailSpDe", "@IdxNr", IdxNr
        End If
        RS129.Close
        Set RS129 = Nothing
    End If
    RS128.Close
    Set RS128 = Nothing
Else
    Set RS128 = New ADODB.Recordset
    With RS128
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With
    If RS128.Supports(adAddNew) Then
        RS128.AddNew
        RS128.Fields("IDKurz").Value = EmAdr
        RS128.Fields("SenderMail").Value = EmAdr
        If EmBet <> vbNullString Then
            RS128.Fields("Subject").Value = EmBet
        End If
        RS128.Fields("IDM").Value = GlMiA(GlSmI, 2)
        RS128.Fields("ID1").Value = 805 'Junkmailordner
        RS128.Update
    End If
    RS128.Close
    Set RS128 = Nothing
End If

Exit Sub

KoErr:
If GlDbg = True Then SErLog Err.Description & " S_MaSp " & Err.Number
Resume Next

End Sub
