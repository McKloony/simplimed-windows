Private Sub S_TeAk(ByVal MasTe As Long, Optional ByVal RezAn As Integer = 0)
On Error GoTo SuErr
'Aktualisiert die Folge einer Terminserie

Dim TerNr As Long
Dim TeAnz As Integer
Dim TerAk As Integer

Set RS121 = New ADODB.Recordset
RS121.CursorLocation = adUseClient
Set RS121 = DBCmRe1("qryTerSer01", "@IdxNr", MasTe)
TeAnz = RS121.RecordCount
If TeAnz > 0 Then
    Do
    TerAk = TerAk + 1
    TerNr = RS121.Fields("ID2").Value
    DBCmEx3 "qryTerAnz", "@TeAnz", "@TeAkt", "@IdxNr", RezAn, TerAk, TerNr
    RS121.MoveNext
    Loop Until RS121.EOF
End If
RS121.Close
Set RS121 = Nothing
DoEvents

If TeAnz > 0 Then
    If RezAn > 0 Then
        If TerAk = RezAn Then
            SPopu "Verordnungsmenge erreicht", "Die verordnete Menge von " & RezAn & " Terminen, wurde erreicht.", IC48_Information
        ElseIf TerAk > RezAn Then
            SPopu "Verordnungsmenge überschritten", "Die verordnete Menge von " & RezAn & " Terminen, wurde überschritten.", IC48_Warning
        End If
    End If
End If

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TeAk " & Err.Number
Resume Next

End Sub
Public Sub S_TeAl(ByVal IdxNr As Long, Optional ByVal AnMin As Long)
On Error GoTo KoErr
'Ändert die Alarme eines Termins

Dim AktTa As Long
Dim DaDif As Long
Dim TerGe As Long
Dim DatSt As Date
Dim DatEn As Date
Dim NeuSt As Date
Dim NeuEn As Date
Dim AkDat As Date
Dim SQL1 As String
Dim TeGef As Boolean
Dim TerEr As Boolean
Dim AnzTa As Integer
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim CaCol As XtremeCalendarControl.CalendarControl
Dim CaEvt As XtremeCalendarControl.CalendarEvent
Dim CaEvs As XtremeCalendarControl.CalendarEvents

Set FM = frmMain
Set CaCol = FM.calCont1

Tit1 = "Erinnerung"
Mld1 = "Soll der Termin an die neuen Position verschoben werden?"

AnzTa = DateDiff("d", GlDFi, GlDLa)

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qryTerBele WHERE ID2 = " & IdxNr
Else
    SQL1 = "SELECT * FROM qryTerBele WHERE [ID2] = " & IdxNr & ";"
End If

Set RS138 = New ADODB.Recordset
With RS138
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With
If RS138.RecordCount > 0 Then
    If AnMin > 0 Then
        Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
        If Frage = 6 Then
            DatSt = RS138.Fields("VonDat").Value & Chr$(32) & RS138.Fields("ZeiVon").Value
            DatEn = RS138.Fields("BisDat").Value & Chr$(32) & RS138.Fields("ZeiBis").Value
            DaDif = Abs(DateDiff("n", DatSt, DatEn, vbMonday))
            NeuSt = DateAdd("n", AnMin, Now)
            NeuEn = DateAdd("n", AnMin, DateAdd("n", DaDif, Now))
            RS138.Fields("VonDat").Value = Format$(NeuSt, "dd.mm.yyyy")
            RS138.Fields("BisDat").Value = Format$(NeuEn, "dd.mm.yyyy")
            RS138.Fields("ZeiVon").Value = Format$(NeuSt, "hh:mm")
            RS138.Fields("ZeiBis").Value = Format$(NeuEn, "hh:mm")
            RS138.Fields("Vorwarn").Value = 1
            If GlTeV = True Then 'Termine vorhanden
                For AktTa = 1 To AnzTa
                    AkDat = DateAdd("d", AktTa, GlDFi)
                    Set CaEvs = CaCol.DataProvider.RetrieveDayEvents(AkDat)
                    For Each CaEvt In CaEvs
                        TerGe = CaEvt.id
                        If TerGe = IdxNr Then
                            TeGef = True
                            Exit For
                        End If
                    Next CaEvt
                    If TeGef = True Then Exit For
                Next AktTa
            End If
            If TeGef = True Then
                With CaEvt
                    .StartTime = NeuSt
                    .EndTime = NeuEn
                    .ReminderMinutesBeforeStart = 0
                End With
                CaCol.DataProvider.ChangeEvent CaEvt
                CaCol.Populate
            End If
        End If
    Else
        RS138.Fields("Erinnerung").Value = 0
    End If
    RS138.Update
End If
RS138.Close
Set RS138 = Nothing

Set CaCol = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TeAl " & Err.Number
Resume Next

End Sub
