            RowNr = RpRow.Index
        
            ReDim TeBer(AnzPo)
            PrBr1.Min = 0
            PrBr1.Max = AnzPo
            PrBr2.Min = 0
            PrBr2.Max = AnzPo
            frmStatus.Show
            frmStatus.Caption = "Speichern"
            DoEvents
        
            Set RS122 = New ADODB.Recordset 'Neue Testdaten aus Laborauftrag
            With RS122
                .CursorLocation = adUseClient
                .Source = "qryLabTeNe"
                .ActiveConnection = DB1
                .CursorType = adOpenStatic
                .LockType = adLockBatchOptimistic
                .Open Options:=adCmdTableDirect
                Set .ActiveConnection = Nothing
