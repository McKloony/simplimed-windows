End With

TeKom = S_MaIdx(IdxNr, "Kommentar")
TeKom = Replace(TeKom, vbCrLf, Chr$(32), 1)
TeKom = LTrim$(TeKom)
TeKom = RTrim$(TeKom)

If PatNr > 0 Then
    Set RS131 = New ADODB.Recordset 'Patientenfilter
    RS131.CursorLocation = adUseClient
    Set RS131 = DBCmRe1("qryAdrIdx", "@IdxNr", PatNr)
    If RS131.RecordCount > 0 Then

        PaKur = RS131.Fields("IDKurz").Value
        ZaZil = Val(RS131.Fields("IDZ").Value)
        KatNr = Val(RS131.Fields("ID3").Value)
        
        If RS131.Fields("PLZ").Value <> vbNullString Then PaPLZ = RS131.Fields("PLZ").Value
        If RS131.Fields("Ort").Value <> vbNullString Then PaOrt = RS131.Fields("Ort").Value
        If RS131.Fields("Telefon1").Value <> vbNullString Then PaTe1 = RS131.Fields("Telefon1").Value
        If RS131.Fields("Telefon2").Value <> vbNullString Then PaTe2 = RS131.Fields("Telefon2").Value
        If RS131.Fields("Telefon4").Value <> vbNullString Then PaTe4 = RS131.Fields("Telefon4").Value
        If RS131.Fields("AdrGruppe").Value <> vbNullString Then AdGrp = RS131.Fields("AdrGruppe").Value

        If RS131.Fields("Objekt").Value <> vbNullString Then
            PaBem = RS131.Fields("Objekt").Value
        ElseIf RS131.Fields("Bemerkung").Value <> vbNullString Then
            PaBem = RS131.Fields("Bemerkung").Value
        Else
            PaBem = TeKom
        End If

        Set RpRec = RpHcs.Add()
        Set RpItm = RpRec.AddItem(0)
        Set RpItm = RpRec.AddItem(PaKur)
        RpItm.Icon = IC16_IDCard_Norm
        RpItm.Bold = True
        Set RpItm = RpRec.AddItem(PatNr)
        Set RpItm = RpRec.AddItem(0)
    
        Set RpRec = RpHcs.Add()
        Set RpItm = RpRec.AddItem(0)
        Set RpItm = RpRec.AddItem(PaPLZ & Chr$(32) & PaOrt)
        RpItm.Icon = IC16_IDCard_Norm
        Set RpItm = RpRec.AddItem(PatNr)
        Set RpItm = RpRec.AddItem(0)
        
        If PaTe1 <> vbNullString Then
            Set RpRec = RpHcs.Add()
            Set RpItm = RpRec.AddItem(0)
            Set RpItm = RpRec.AddItem(PaTe1)
            RpItm.Icon = IC16_Telephone
            RpItm.Bold = True
            Set RpItm = RpRec.AddItem(PatNr)
            Set RpItm = RpRec.AddItem(0)
        End If
        
        If PaTe2 <> vbNullString Then
            Set RpRec = RpHcs.Add()
            Set RpItm = RpRec.AddItem(0)
            Set RpItm = RpRec.AddItem(PaTe2)
            RpItm.Icon = IC16_Telephone
            RpItm.Bold = True
            Set RpItm = RpRec.AddItem(PatNr)
            Set RpItm = RpRec.AddItem(0)
        End If
        
        If PaTe4 <> vbNullString Then
            Set RpRec = RpHcs.Add()
            Set RpItm = RpRec.AddItem(0)
            Set RpItm = RpRec.AddItem(PaTe4)
            RpItm.Icon = IC16_Phone_Mobil
            RpItm.Bold = True
            Set RpItm = RpRec.AddItem(PatNr)
            Set RpItm = RpRec.AddItem(0)
        End If

        If AdGrp <> vbNullString Then
            If Len(AdGrp) < 20 Then
               AdGrp = "Gruppen: " & AdGrp
            End If
            Set RpRec = RpHcs.Add()
            Set RpItm = RpRec.AddItem(0)
            Set RpItm = RpRec.AddItem(AdGrp)
            RpItm.Icon = IC16_Folder_Open
            Set RpItm = RpRec.AddItem(PatNr)
            Set RpItm = RpRec.AddItem(0)
        End If
        
        If PaBem <> vbNullString Then
            RpRec.PreviewText = PaBem
        End If

        Set RS161 = New ADODB.Recordset
        RS161.CursorLocation = adUseClient 'alle weiteren Emails des Patienten
        Set RS161 = DBCmRe1("qryMailInAdr", "@IdxNr", PatNr)
        AnzTe = RS161.RecordCount
        If AnzTe > 0 Then
            Do
            AktTe = AktTe + 1
            EmaNr = RS161.Fields("IDA").Value
            Geles = RS161.Fields("Gelesen").Value
            If RS161.Fields("Sensitivity").Value <> vbNullString Then
                Sensi = RS161.Fields("Sensitivity").Value
            Else
                Sensi = 0
            End If
            Datu1 = Format$(RS161.Fields("Maildate").Value, "dd.mm.yyyy")
            Datu2 = Format$(RS161.Fields("Mailtime").Value, "hh:mm")
            EmDat = Datu1
            EmZei = " [ " & Datu2 & " ] "
            If RS161.Fields("Subject").Value <> vbNullString Then
                EmBet = RS161.Fields("Subject").Value
            ElseIf RS161.Fields("Patient").Value <> vbNullString Then
                EmBet = RS161.Fields("Patient").Value
            Else
                EmBet = "kein Betreff"
            End If
            Set RpRcs = RpCon.Records
            Set RpRec = RpRcs.Add()
            Set RpItm = RpRec.AddItem(EmaNr)
            Set RpItm = RpRec.AddItem(EmDat & EmZei & EmBet)
            If Geles = True Then
                RpItm.Bold = False
                If Sensi = 1 Then
                    RpItm.Icon = IC16_Mail_Read
                Else
                    RpItm.Icon = IC16_Mail_Open
                End If
            Else
                RpItm.Bold = True
                RpItm.Icon = IC16_Mail_Close
            End If
            Set RpItm = RpRec.AddItem(0)
            Set RpItm = RpRec.AddItem(PatNr)
            
            RS161.MoveNext
            Loop Until RS161.EOF
        End If
        RS161.Close
        Set RS161 = Nothing
        
    End If
    RS131.Close
    Set RS131 = Nothing
    
    DoEvents
    RpCon.Populate
End If

Exit Sub

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_MaDet " & Err.Number
Resume Next

End Sub
