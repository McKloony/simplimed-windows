Public Sub S_BuKs()
On Error GoTo SuErr
'Sachkontenprüfung

Dim KtoNr As Long
Dim RowNr As Long
Dim AnzGe As Long
Dim AktZa As Long
Dim BetEi As Double
Dim BetAu As Double
Dim KtoSt As String
Dim KtTyp As Integer
Dim StaRa As Integer
Dim Frage As Integer
Dim Lange As Integer
Dim Mld1, Tit1 As String
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows

If GlMVo = True Then 'mandantenbezogene Vorgaben verwenden
    StaRa = GlMan(GlSMa, 25) 'Standardkontenrahmen
Else
    StaRa = GlKtR
End If

Mld1 = "Soll nun eine Sachkontenprüfung durchgeführt werden? Bei dieser Überprüfung werden die Sachkontenbezeichnungen basierend auf den Sachkonten im Sachkontenrahmen verglichen und die Sachkontennummer neu zugeordnet."
Tit1 = "Sachkontenprüfung"

Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
If Frage = 6 Then
    Screen.MousePointer = vbHourglass

    frmStatus.Show
    DoEvents
    frmStatus.Caption = "Sachkontenprüfungslauf"
    Set Lbl01 = frmStatus.lblLab01
    Set PrBr1 = frmStatus.prbStat1
    Set PrBr2 = frmStatus.prbStat2
    Set TxDum = frmStatus.txtDummy
    Lbl01.Caption = "Bitte warten..."

    Set RS129 = New ADODB.Recordset
    With RS129
        .CursorLocation = adUseClient
        .Source = "qrySimBuAll" 'alle Buchungen
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdTableDirect
    End With
    AnzGe = RS129.RecordCount

    If AnzGe > 0 Then
        AktZa = 0
        PrBr1.Min = 0
        PrBr1.Max = AnzGe

        Do
        If RS129.Fields("IDKurz").Value <> vbNullString Then
            KtoSt = RS129.Fields("IDKurz").Value
            If RS129.Fields("Ausgabe").Value <> vbNullString Then
                BetAu = CDbl(RS129.Fields("Ausgabe").Value)
            Else
                BetAu = 0
            End If
            If RS129.Fields("Einnahme").Value <> vbNullString Then
                BetEi = CDbl(RS129.Fields("Einnahme").Value)
            Else
                BetEi = 0
            End If
            Set RS126 = New ADODB.Recordset
            RS126.CursorLocation = adUseClient
            Set RS126 = DBCmRe2("qrySimBuKtB", "@IdStr", "@IdxNr", "%" & KtoSt & "%", StaRa)
            If RS126.RecordCount > 0 Then
                KtoNr = SBuFo(RS126.Fields("IDK").Value)
                KtTyp = RS126.Fields("IDA").Value
                If KtTyp > 2 Then KtTyp = 2
                RS129.Fields("IDK").Value = KtoNr
                RS129.Fields("IDA").Value = KtTyp
                If KtTyp = 2 Then
                    If BetEi > 0 Then
                        RS129.Fields("Einnahme").Value = 0
                        RS129.Fields("Ausgabe").Value = BetEi
                    End If
                Else
                    If BetAu > 0 Then
                        RS129.Fields("Einnahme").Value = BetAu
                        RS129.Fields("Ausgabe").Value = 0
                    End If
                End If
                RS129.Update
            End If
            RS126.Close
            Set RS126 = Nothing
        End If

        DoEvents
        AktZa = AktZa + 1
        If TxDum.Text = "B" Then Exit Do 'Abbrechen
        PrBr1.Value = AktZa
        
        RS129.MoveNext
        Loop Until RS129.EOF
    End If
    RS129.Close
    Set RS129 = Nothing
        
    Unload frmStatus
    Set frmStatus = Nothing
    DoEvents

    GlNeK = GlKoX 'Protokolleintrag
    With GlNeK
        .PatNr = GlMan(GlSMa, 2)
        .IdxNr = 0
        .EiDat = Format$(Date, "dd.mm.yyyy")
        .EiZei = TimeValue(Now)
        .EiTyp = 104
        .TeStr = "Sachkontenprüfungslauf durchgeführt"
        .ZiStr = Format$(Now, "hh:mm") & " Uhr"
        .NeuEi = True
        .KeiAk = True
        .Mitar = GlMiA(GlSmI, 2)
    End With
    S_Prot

    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        RowNr = RpRow.Index
        SUpBu RowNr
    End If
    
    Screen.MousePointer = vbNormal
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BuKs " & Err.Number
Resume Next

End Sub
