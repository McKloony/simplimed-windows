                Case 5: '[Bezeichnung]
                    .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = Weite - 4600
                    .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellPageBreakAllowed) = True
                Case 6: '[IDM]
                    .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellHorizontalExt) = 1400
                    .TableCellAttribute(TabId, AkZei, AkSpa, txTableCellPageBreakAllowed) = False
                End Select
            End With
        Next AkSpa
        
        PrBr1.Value = AkZei
        DoEvents
    Next AkZei
    
    AkZei = 1
    Do
    If RS149.Fields("Datum").Value <> vbNullString Then
        KrDat = RS149.Fields("Datum").Value
        StrDa = Left$(KrDat, 10)
        
        If RS149.Fields("IDM").Value > 0 Then
            MitNr = RS149.Fields("IDM").Value
        Else
            MitNr = 0
        End If
        For AktZa = 1 To UBound(GlMiA)
            If MitNr = GlMiA(AktZa, 2) Then
                ManNr = GlMiA(AktZa, 7)
                Exit For
            End If
        Next AktZa
        
        If RS149.Fields("Druckdatum").Value <> vbNullString Then
            StrZe = Format$(TimeValue(RS149.Fields("Druckdatum").Value), "hh:mm:ss")
        Else
            StrZe = vbNullString
        End If
        
         If RS149.Fields("Typ").Value > 0 Then
            KrTyp = RS149.Fields("Typ").Value
        Else
            KrTyp = 0
        End If
        
        For AktZa = 1 To UBound(GlKrA)
            If GlKrA(AktZa, 0) = KrTyp Then
                TyStr = GlKrA(AktZa, 1)
                TyCol = GlKrA(AktZa, 3)
                Exit For
            End If
        Next AktZa
    
        For AktZa = 1 To UBound(GlMiT)
            If MitNr = GlMiT(AktZa, 2) Then
                MitNa = GlMiT(AktZa, 1)
                Exit For
            End If
        Next AktZa
    
        'If GlRsK = True Then 'Mandantenbezogene Datenbegrenzung für Krankenblatt
        '    If ManNr <> GlReM Then 'Standardmandant Mandantenrestriktionen
        '        If ManNr = 0 Then
        '            EinOk = True
        '        Else
        '            EinOk = False
        '        End If
        '    End If
        'End If
    
        If RS149.Fields("Provision").Value <> vbNullString Then
            PrStr = RS149.Fields("Provision").Value
            Lange = Len(PrStr)
            Ausri = Mid$(PrStr, 5, 1)
            TxCol = Mid$(PrStr, 6, 8)
            BaCol = Mid$(PrStr, 14, 8)
            FntGr = Mid$(PrStr, 22, 2)
            FntNa = Mid$(PrStr, 24, (Lange - 23))
            Select Case Ausri
            Case "L": FntAs = 0
            Case "R": FntAs = 1
            Case "Z": FntAs = 2
            End Select
        Else
            PrStr = vbNullString
            BaCol = vbWhite
            TxCol = vbBlack
            FntGr = GlRFt.SIZE
            FntNa = GlRFt.Name
            FntAs = 0
        End If
                        
        If EinOk = True Then
            With TxCoN
                .TableCellSelect TabId, AkZei, 1
                .SelText = RS149.Fields("ID2").Value
                
                .TableCellSelect TabId, AkZei, 2
                .Alignment = 2
                .SelText = Left$(RS149.Fields("Datum").Value, 10)
                
                .TableCellSelect TabId, AkZei, 3
                .Alignment = 2
                If RS149.Fields("Druckdatum").Value <> vbNullString Then
                    .SelText = Format$(TimeValue(RS149.Fields("Druckdatum").Value), "hh:mm:ss")
                End If
                
                .TableCellSelect TabId, AkZei, 4
                .Alignment = 2
                .SelText = TyStr
                
                .TableCellSelect TabId, AkZei, 5
                .Alignment = FntAs
                Select Case KrTyp
                Case 6: 'Zahlung
                    .ForeColor = TyCol
                    .SelText = RS149.Fields("Bezeichnung").Value
                Case 24: 'Textdokument
                    DaNam = RS149.Fields("Kommentar").Value
                    IdStr = RS149.Fields("Bezeichnung").Value
                    Lange = Len(DaNam)
                    Posi1 = InStrRev(DaNam, "#_", Lange, 1)
                    Posi2 = InStrRev(DaNam, ".", Lange, 1)
                    If Posi1 > 0 Then
                        If IdStr <> vbNullString Then
                            NeNam = Mid$(DaNam, Posi1 + 2, Posi2 - (Posi1 + 2)) & " - " & IdStr
                        Else
                            NeNam = Mid$(DaNam, Posi1 + 2, Posi2 - (Posi1 + 2))
                        End If
                    Else
                        If IdStr <> vbNullString Then
                            NeNam = IdStr
                        Else
                            If IdStr <> vbNullString Then
                                NeNam = "Textdokument" & " - " & IdStr
                            Else
                                NeNam = "Textdokument"
                            End If
                        End If
                    End If
                    .ForeColor = TyCol
                    .SelText = NeNam
                Case 101: 'Rezept
                    If RS149.Fields("Kommentar").Value <> vbNullString Then
                        .TableCellText(TabId, AkZei, 5) = RS149.Fields("Kommentar").Value
                    Else
                        .TableCellText(TabId, AkZei, 5) = RS149.Fields("Bezeichnung").Value
                    End If
                Case 102: 'Dateien
                    DaNam = RS149.Fields("Kommentar").Value
                    If RS149.Fields("Bezeichnung").Value <> vbNullString Then
                        IdStr = RS149.Fields("Bezeichnung").Value
                    Else
                        IdStr = vbNullString
                    End If
                    Lange = Len(DaNam)
                    Posi1 = InStrRev(DaNam, "#_", Lange, 1)
                    Posi2 = InStrRev(DaNam, ".", Lange, 1)
                    If Posi1 > 0 Then
                        If IdStr <> vbNullString Then
                            NeNam = Mid$(DaNam, Posi1 + 2, Posi2 - (Posi1 + 2)) & " - " & IdStr
                        Else
                            NeNam = Mid$(DaNam, Posi1 + 2, Posi2 - (Posi1 + 2))
                        End If
                    ElseIf Mid$(DaNam, 8, 1) = "_" Then
                        If IdStr <> vbNullString Then
                            NeNam = IdStr
                        Else
                            NeNam = "Dateidokument"
                        End If
                    Else
                        If IdStr <> vbNullString Then
                            NeNam = "Dateidokument" & " - " & IdStr
                        Else
                            If Posi1 > 0 Then
                                NeNam = Mid$(DaNam, Posi1 + 1, Posi2 - (Posi1 + 1))
                            Else
                                NeNam = "Dateidokument" & " - " & DaNam
                            End If
                        End If
                    End If
                    .ForeColor = TyCol
                    .SelText = NeNam
                Case 104: 'Protokoll
                    .ForeColor = TyCol
                    .SelText = RS149.Fields("Bezeichnung").Value
                Case 105: 'Bilddatei
                    DaNam = RS149.Fields("Kommentar").Value
                    IdStr = RS149.Fields("Bezeichnung").Value
                    Lange = Len(DaNam)
                    If Lange > 0 Then
                        Posi1 = InStrRev(DaNam, "#_", Lange, 1)
                        Posi2 = InStrRev(DaNam, ".", Lange, 1)
                    Else
                        Posi1 = 0
                        Posi2 = 0
                    End If
                    If Posi1 > 0 Then
                        If IdStr <> vbNullString Then
                            NeNam = Mid$(DaNam, Posi1 + 2, Posi2 - (Posi1 + 2)) & " - " & IdStr
                        Else
                            NeNam = Mid$(DaNam, Posi1 + 2, Posi2 - (Posi1 + 2))
                        End If
                    ElseIf Mid$(DaNam, 8, 1) = "_" Then
                        If IdStr <> vbNullString Then
                            NeNam = IdStr
                        Else
                            If IdStr <> vbNullString Then
                                NeNam = "Bilddokument" & " - " & IdStr
                            Else
                                NeNam = Mid$(DaNam, Posi1 + 2, Posi2 - (Posi1 + 2))
                            End If
                        End If
                    Else
                        If DaNam <> vbNullString Then
                            NeNam = Mid$(DaNam, Posi1 + 1, Posi2 - (Posi1 + 1))
                        End If
                    End If
                    .ForeColor = TyCol
                    .SelText = NeNam
                Case 106: 'Rechnung
                    .ForeColor = TyCol
                    .SelText = RS149.Fields("Bezeichnung").Value
                Case 108: 'Email
                    .ForeColor = TyCol
                    .SelText = RS149.Fields("Kommentar").Value
                Case Else:
                    .FontName = FntNa
                    .ForeColor = TxCol
                    .BackColor = BaCol
                    .FontSize = FntGr
                    If KrTyp < 10 Then
                        .SelText = RS149.Fields("Bezeichnung").Value
                    Else
                        .SelText = RS149.Fields("Kommentar").Value
                    End If
                End Select
    
                .TableCellSelect TabId, AkZei, 6
                .SelText = MitNa
            End With
        End If
    End If
    PrBr2.Value = AkZei
    DoEvents
    AkZei = AkZei + 1
    RS149.MoveNext
    Loop Until RS149.EOF
    
    TxCoN.Refresh
    DoEvents
    GlTSV = True 'Speichern Textverarbeitung
    
    Unload frmStatus
    Set frmStatus = Nothing
    
    clFen.FenDsk 3
    Screen.MousePointer = vbNormal
End If
RS149.Close
Set RS149 = Nothing

Set TxCoN = Nothing

Set clFen = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KrKn " & Err.Number
Resume Next

End Sub

Public Sub S_KrKp(ByVal AltRe As Long, ByVal NeuRe As Long, ByVal PatNr As Long, Optional ByVal BehEr As Boolean = False, Optional ByVal LeiAl As Boolean = False)
On Error GoTo KoErr
'Kopiert Positionen aus der alten Rechnung in die neue Rechnung

Dim KoDat As Date
Dim AkDat As Date
Dim IdxNr As Long
Dim PosNr As Long
Dim AnzPo As Long
Dim AnzTa As Long
Dim AktTa As Long
Dim SorNr As Long
Dim EiBet As Single
Dim GeBet As Single
Dim Multi As Single
Dim SQL2 As String
Dim SQL3 As String
Dim KrGui As String
Dim EiAnz As Integer
Dim LeTyp As Integer
Dim EinZu As Boolean
Dim Frage As Integer
Dim Mld1, Tit1 As String

Set FM = frmMain

If LeiAl = True Then 'Alle Leistungen (Gutschrift)
    AnzTa = 1
Else
    AnzTa = UBound(GlTag)
End If
Tit1 = "Einträge kopieren"

If AnzTa > 0 Then
    If GlTyp < 2 Then
        If BehEr = True Then
            SQL2 = "SELECT * FROM dbo.qrySimAbLei1 WHERE IDR = " & AltRe & " ORDER BY Sorter, ID3"
        Else
            SQL2 = "SELECT * FROM dbo.qrySimAbLei1 WHERE IDR = " & AltRe & " ORDER BY Sorter DESC, ID3"
        End If
    Else
        If BehEr = True Then
            SQL2 = "SELECT * FROM qrySimAbLei1 WHERE [IDR] = " & AltRe & " ORDER BY [Sorter], [ID3];"
        Else
            SQL2 = "SELECT * FROM qrySimAbLei1 WHERE [IDR] = " & AltRe & " ORDER BY [Sorter] DESC, [ID3];"
        End If
    End If

    If GlTyp < 2 Then
        SQL3 = "SELECT * FROM dbo.qrySimAbSav WHERE IDR = " & NeuRe & " ORDER BY ID3 DESC"
    Else
        SQL3 = "SELECT * FROM qrySimAbSav WHERE [IDR] = " & NeuRe & " ORDER BY [ID3] DESC;"
    End If
    
    Set RS122 = New ADODB.Recordset 'Krenkanblatt
    With RS122
        .CursorLocation = adUseClient
        .Source = SQL2
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdText
    End With
    
    Set RS123 = New ADODB.Recordset 'Krenkanblatt
    With RS123
        .CursorLocation = adUseClient
        .Source = SQL3
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With
    
    If RS122.RecordCount > 0 Then
        If RS123.RecordCount > 0 Then
            SorNr = RS123.Fields("ID3").Value
        Else
            SorNr = 0
        End If

        For AktTa = 1 To AnzTa 'Behandlungstage
            RS122.MoveFirst
            KoDat = RS122.Fields("Datum").Value
            
            Do
            LeTyp = RS122.Fields("Typ").Value
            AkDat = RS122.Fields("Datum").Value
            
            If LeiAl = False Then 'alle Leistungen (Gutschrift)
                If KoDat <> AkDat Then
                    Exit Do
                End If
            End If

            Select Case LeTyp
            Case 5:
            Case 6:
            Case 7:
            Case Else:

                KrGui = CreateID("K")
                SorNr = SorNr + 1
                If RS122.Fields("Betrag").Value <> vbNullString Then
                    EiBet = Round(RS122.Fields("Betrag").Value, 2)
                Else
                    EiBet = 0
                End If
                If RS122.Fields("GesBetrag").Value <> vbNullString Then
                    GeBet = Round(RS122.Fields("GesBetrag").Value, 2)
                Else
                    GeBet = 0
                End If
                If RS122.Fields("Faktor").Value <> vbNullString Then
                    Multi = Round(RS122.Fields("Faktor").Value, 2)
                Else
                    Multi = 0
                End If

                RS123.AddNew
                RS123.Fields("ID0").Value = PatNr
                RS123.Fields("IDR").Value = NeuRe
                RS123.Fields("ID3").Value = SorNr
                RS123.Fields("ID1").Value = LeTyp
                RS123.Fields("GONr").Value = RS122.Fields("Ziffer").Value
                RS123.Fields("IDKurz").Value = RS122.Fields("Bezeichnung").Value
                RS123.Fields("x").Value = RS122.Fields("Anz").Value
                If LeTyp > 1 Then
                    RS123.Fields("Betrag").Value = EiBet
                    RS123.Fields("GesBetrag").Value = GeBet
                    RS123.Fields("Multi").Value = Multi
                End If
                RS123.Fields("Analog").Value = RS122.Fields("Analog").Value
                RS123.Fields("WVBetrag").Value = RS122.Fields("WVBetrag").Value
                RS123.Fields("Kommentar").Value = RS122.Fields("Kommentar").Value
                RS123.Fields("Zeit").Value = RS122.Fields("Zeit").Value
                RS123.Fields("Kommentar2").Value = KrGui
                RS123.Fields("Währung").Value = RS122.Fields("Währung").Value
                RS123.Fields("IDM").Value = RS122.Fields("IDM").Value
                If GlDiZ = False Then 'Gebührendiagnosezuordnungen auslassen
                    RS123.Fields("IDD").Value = RS122.Fields("IDD").Value
                End If
                If LeiAl = True Then 'alle Leistungen (Gutschrift)
                    RS123.Fields("Datum").Value = CDate(RS122.Fields("Datum").Value) & Space$(1) & TimeValue(Now)
                    RS123.Fields("Druckdatum").Value = CDate(RS122.Fields("Datum").Value) & Space$(1) & TimeValue(RS122.Fields("Druckdatum").Value)
                Else
                    RS123.Fields("Datum").Value = GlTag(AktTa) & Space$(1) & TimeValue(Now)
                    RS123.Fields("Druckdatum").Value = GlTag(AktTa) & Space$(1) & TimeValue(Now)
                End If
                RS123.Update
            End Select
            
            RS122.MoveNext

            Loop Until RS122.EOF = True
        Next AktTa
        
        RS123.Close
        Set RS123 = Nothing
    End If
    RS122.Close
    Set RS122 = Nothing
    DoEvents
        
    Set RS127 = New ADODB.Recordset
    RS127.CursorLocation = adUseClient
    If GlDSo = True Then 'Katalogdiagnosen alphabetisch sortieren
        Set RS127 = DBCmRe1("qrySimAbDiag", "@IdxNr", NeuRe)
    Else
        Set RS127 = DBCmRe1("qrySimAbDia5", "@IdxNr", NeuRe)
    End If
    If RS127.RecordCount > 0 Then
        Do
        IdxNr = RS127.Fields("ID2").Value
        DBCmEx2 "qrySimAbDiDa", "@IdDat", "@IdxNr", GlTag(1), IdxNr
        RS127.MoveNext
        Loop Until RS127.EOF
    End If
    RS127.Close
    Set RS127 = Nothing

Else
    Mld1 = "Sie müssen erst einen Tag markieren, um einen Eintrag zu kopieren"
    Tit1 = "Kein Tag markiert"
    WindowMess Mld1, Dial2, Tit1, FM.hwnd
End If


Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KrKp " & Err.Number
Resume Next

End Sub
Public Sub S_KrLa()
On Error GoTo SuErr
'Lädt die Patientendetails

Dim KatNr As Long
Dim ZaZil As Long
Dim ReNum As Long
Dim MaNum As Long
Dim PatNr As Long
Dim OpSum As Double
Dim GuSum As Double
Dim AdGeb As String
Dim AdStr As String
Dim AdKur As String
Dim AdAcr As String
Dim AdTit As String
Dim AdNam As String
Dim AdVor As String
Dim AdFrm As String
Dim AdOrt As String
Dim KatNa As String
Dim ZalNa As String
Dim BeNam As String
Dim NuStr As String
Dim DaStr As String
Dim LbStr As String
Dim GuStr As String
Dim OpStr As String
Dim Tele1 As String
Dim Tele2 As String
Dim VrsAr As String
Dim AdGrp As String
Dim GeStr As String
Dim AktZa As Integer
Dim GesZa As Integer
Dim AktPo As Integer
Dim CmBrs As XtremeCommandBars.CommandBars

Set FM = frmMain
Set CmBrs = FM.comBar01
Set TxDe0 = FM.txtDeta0 'Aufnahmemedikamente
Set TxDe1 = FM.txtDeta1 'Aufnahmediagnosen
Set TxDe2 = FM.txtDeta2 'Cave Field
Set TxDe5 = FM.txtDeta5 'Antlitzbild
Set TxDe7 = FM.txtDeta7
Set Labl5 = FM.lblDeta5
Set Labl7 = FM.lblDeta7 'Infofeld Allgemein
Set Labl8 = FM.lblDeta8 'Infofeld Allgemein
Set CmSta = CmBrs.StatusBar

Ter_Det 0, 2
DoEvents

OpSum = S_ReSm(GlAdr)
If OpSum > 0 Then
    OpStr = "Offen: " & Format$(OpSum, GlWa1)
End If

Set RS126 = New ADODB.Recordset
RS126.CursorLocation = adUseClient
Set RS126 = DBCmRe1("qryAdrIdx", "@IdxNr", GlAdr)
GesZa = RS126.RecordCount

If GesZa > 0 Then
    If RS126.Fields("ID3").Value <> vbNullString Then
        KatNr = RS126.Fields("ID3").Value
    End If
    If RS126.Fields("IDZ").Value <> vbNullString Then
        ZaZil = RS126.Fields("IDZ").Value
    End If
    If RS126.Fields("Name").Value <> vbNullString Then
        AdNam = RS126.Fields("Name").Value
    End If
    If RS126.Fields("Vorname").Value <> vbNullString Then
        AdVor = RS126.Fields("Vorname").Value
    End If
    If RS126.Fields("Firma1").Value <> vbNullString Then
        AdFrm = RS126.Fields("Firma1").Value
    End If
    If RS126.Fields("Titel").Value <> vbNullString Then
        AdTit = RS126.Fields("Titel").Value
    End If
    If RS126.Fields("PLZ").Value <> vbNullString Then
        AdOrt = RS126.Fields("PLZ").Value
    End If
    If RS126.Fields("Ort").Value <> vbNullString Then
        If AdOrt = vbNullString Then
            AdOrt = RS126.Fields("Ort").Value
        Else
            AdOrt = AdOrt & Space$(1) & RS126.Fields("Ort").Value
        End If
    End If

    DaStr = "Aktualisiert: " & RS126.Fields("Geändert").Value
    LbStr = RS126.Fields("Anschrift").Value & vbCrLf
    GuSum = RS126.Fields("Guthaben").Value
    GuStr = "Guthaben: " & Format$(GuSum, GlWa1)
    
    If RS126.Fields("Mandant").Value <> vbNullString Then
        If IsNumeric(RS126.Fields("Mandant").Value) = True Then
            If RS126.Fields("Mandant").Value > 0 Then
                PatNr = RS126.Fields("Mandant").Value
            Else
                PatNr = RS126.Fields("ID0").Value
            End If
        Else
            PatNr = RS126.Fields("ID0").Value
        End If
    Else
        PatNr = RS126.Fields("ID0").Value
    End If
    NuStr = "Nummer: " & Format$(PatNr, "00000")

    AdAcr = AErKu(AdFrm, AdNam, AdVor, GlAdr, AdTit)
    DoEvents
    
    If RS126.Fields("IDKurz").Value <> vbNullString Then
        AdKur = RS126.Fields("IDKurz").Value
    Else
        AdKur = vbNullString
    End If
    If RS126.Fields("GebTyp").Value <> vbNullString Then
        GeStr = RS126.Fields("GebTyp").Value
    Else
        GeStr = vbNullString
    End If
    
    If RS126.Fields("Versand").Value <> vbNullString Then
        Select Case CInt(RS126.Fields("Versand").Value)
        Case 0: VrsAr = "Postversand"
        Case 1: VrsAr = "Emailversand"
        Case 2: VrsAr = "Downloadlink"
        End Select
    End If
        
    For AktZa = 1 To UBound(GlGKa)
        If GlGKa(AktZa, 0) = KatNr Then
            KatNa = LTrim$(GlGKa(AktZa, 1))
            Exit For
        End If
    Next AktZa
    For AktZa = 1 To UBound(GlZah) 'Standardzahlungsziel
        If GlZah(AktZa, 0) = ZaZil Then
            ZalNa = GlZah(AktZa, 1)
            Exit For
        End If
    Next AktZa
    

    If RS126.Fields("AdrGruppe").Value <> vbNullString Then
        If Len(RS126.Fields("AdrGruppe").Value) > 20 Then
            AdGrp = RS126.Fields("AdrGruppe").Value
        Else
            AdGrp = "Gruppen: " & RS126.Fields("AdrGruppe").Value
        End If
    Else
        AdGrp = "Gruppen:"
    End If
    
    If RS126.Fields("Geboren").Value <> vbNullString Then
         AdGeb = RS126.Fields("Geboren").Value
         AdGeb = Format$(AdGeb, "ddd. dd.mm.yyyy") & " (" & AJahr(AdGeb) & " Jahre)"
    Else
        AdGeb = AdOrt
    End If
    
    If Len(RS126.Fields("Telefon1").Value) > 5 Then
        Tele1 = "Telefon: " & RS126.Fields("Telefon1").Value
    ElseIf Len(RS126.Fields("Telefon2").Value) > 5 Then
        Tele1 = "Telefon: " & RS126.Fields("Telefon2").Value
    ElseIf Len(RS126.Fields("Telefon4").Value) > 5 Then
        Tele1 = "Telefon: " & RS126.Fields("Telefon4").Value
    Else
        Tele1 = "Telefon: -"
    End If
    If Len(RS126.Fields("Telefon4").Value) > 5 Then
        Tele2 = "Telefon: " & RS126.Fields("Telefon4").Value
    End If

    If RS126.Fields("IDP").Value > 0 Then
        MaNum = RS126.Fields("IDP").Value
        For AktPo = 1 To UBound(GlThe)
            If MaNum = GlThe(AktPo, 0) Then
                BeNam = GlThe(AktPo, 13)
                Exit For
            End If
        Next AktPo
    End If

    If RS126.Fields("ID3").Value <> vbNullString Then
        TxDe7.Text = RS126.Fields("ID3").Value
    Else
        TxDe7.Text = vbNullString
    End If
    If RS126.Fields("Grafik").Value <> vbNullString Then
        TxDe5.Text = RS126.Fields("Grafik").Value
    Else
        TxDe5.Text = vbNullString
    End If
    If RS126.Fields("Objekt").Value <> vbNullString Then
        TxDe2.Text = RS126.Fields("Objekt").Value
    ElseIf RS126.Fields("Bemerkung").Value <> vbNullString Then
        TxDe2.Text = RS126.Fields("Bemerkung").Value
    Else
        If GlCav = True Then 'Cave Infotext zeigen
            TxDe2.Text = "Hier Kommentar eintragen und mit [F8] speichern"
        Else
            TxDe2.Text = vbNullString
        End If
    End If
    If RS126.Fields("Diagnose").Value <> vbNullString Then
        TxDe1.Text = RS126.Fields("Diagnose").Value
    Else
        TxDe1.Text = vbNullString
    End If
    If RS126.Fields("Anamnese").Value <> vbNullString Then
        TxDe0.Text = RS126.Fields("Anamnese").Value
    Else
        TxDe0.Text = vbNullString
    End If
    DoEvents

    If AdKur <> vbNullString Then
        AdStr = "<TextBlock><Run FontSize='15'>" & AdAcr & "</Run> <LineBreak/>"
        AdStr = AdStr & "<Run FontSize='11'>" & AdGeb & "</Run> <LineBreak/>"
        AdStr = AdStr & "<Bold>" & Tele1 & "</Bold> <LineBreak/>"
        If Tele2 <> vbNullString Then
            If Tele1 <> Tele2 Then
                AdStr = AdStr & Tele2 & "<LineBreak/>"
            End If
        End If
        
        If OpSum > 0 Then
            AdStr = AdStr & "<Run Foreground='DarkRed'>" & OpStr & "</Run><LineBreak/>"
        Else
            AdStr = AdStr & KatNa & "<LineBreak/>"
        End If
        If GuSum > 0 Then
            AdStr = AdStr & "<Run Foreground='DarkGreen'>" & GuStr & "</Run><LineBreak/>"
        Else
            If OpSum = 0 Then
                AdStr = AdStr & "<Run Foreground='DarkGreen'>" & GuStr & "</Run><LineBreak/>"
            Else
                AdStr = AdStr & KatNa & "<LineBreak/>"
            End If
        End If
        If Tele2 = vbNullString Then
            AdStr = AdStr & ZalNa & "<LineBreak/>"
        ElseIf Tele1 = Tele2 Then
