Set CmGlk = CmBrs.FindControl(CmGlk, SY_SuBuh, , True)
Set CmEd2 = CmBrs.FindControl(CmEd2, SY_BA_Banking_Saldo, , True)
Set CmCom = CmBrs.FindControl(CmCom, SY_BA_Banking_SuchCombo, , True)

BuJah = CmJah.Text
LiIdx = CmCom.ListIndex
IdBnk = CmGlk.ItemData(CmGlk.ListIndex)

If GlRst = True Then 'mandantenbezogene Datenbegrenzung
    ManNr = GlMan(GlSMa, 2) 'Standardmandant
Else
    ManNr = CmThe.ItemData(CmThe.ListIndex)
End If

If IdBnk = 0 Then
    Set RS121 = New ADODB.Recordset
    RS121.CursorLocation = adUseClient
    If GlRst = True Then 'mandantenbezogene Datenbegrenzung
        Set RS121 = DBCmRe2("qrySimBaSum2", "@IdJah", "@IdxNr", BuJah, ManNr)
    Else
        If LiIdx = 6 Then 'Mandant
            Set RS121 = DBCmRe2("qrySimBaSum2", "@IdJah", "@IdxNr", BuJah, ManNr)
        Else
            Set RS121 = DBCmRe1("qrySimBaSum1", "@IdJah", BuJah)
        End If
    End If
    If RS121.RecordCount > 0 Then
        If RS121.Fields("Betrag").Value <> vbNullString Then
            SaAlg = RS121.Fields("Betrag").Value
        Else
            SaAlg = 0
        End If
        StrAl = Format$(SaAlg, GlWa1)
    End If
    RS121.Close
    Set RS121 = Nothing
    CmEd2.Text = StrAl
Else
    Set RS121 = New ADODB.Recordset
    RS121.CursorLocation = adUseClient
    If GlRst = True Then 'mandantenbezogene Datenbegrenzung
        Set RS121 = DBCmRe3("qrySimBaSum4", "@IdJah", "@IdxNr", "@IdBnk", BuJah, ManNr, IdBnk)
    Else
        If LiIdx = 6 Then 'Mandant
            Set RS121 = DBCmRe3("qrySimBaSum4", "@IdJah", "@IdxNr", "@IdBnk", BuJah, ManNr, IdBnk)
        Else
            Set RS121 = DBCmRe2("qrySimBaSum3", "@IdJah", "@IdBnk", BuJah, IdBnk)
        End If
    End If
    If RS121.RecordCount > 0 Then
        If RS121.Fields("Betrag").Value <> vbNullString Then
            SaBan = RS121.Fields("Betrag").Value
        Else
            SaBan = 0
        End If
        StrBa = Format$(SaBan, GlWa1)
    End If
    RS121.Close
    Set RS121 = Nothing
    CmEd2.Text = StrBa
End If

Set CmBrs = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BaSal " & Err.Number
Resume Next

End Sub


Public Sub S_BaSet(ByVal OpDia As Boolean, Optional ByVal OpLoe As Boolean = False, Optional ByVal SuStr As String)
On Error GoTo LiErr
'Ordnen dem Umsatz einen offenen Posten zu

Dim SQL1 As String
Dim IdxNr As Long
Dim RowNr As Long
Dim OpNum As Long
Dim ReNum As Long
Dim ReNu5 As Long
Dim PaNum As Long
Dim PatNr As Long
Dim ManNr As Long
Dim MitNr As Long
Dim OpBet As Single
Dim BuBet As Single
Dim GeBet As Single
Dim BaAus As String
Dim BaBez As String
Dim BaSel As String
Dim ReStr As String
Dim PaStr As String
Dim PatSt As String
Dim TmGui As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim OpBel As String
Dim BaIDZ As Integer
Dim AnzPo As Integer
Dim AnzPs As Integer
Dim Frage As Integer
Dim OpZuo As Boolean
Dim Mld1, Tit1 As String
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCo7 As XtremeReportControl.ReportControl
Dim RpRow As XtremeReportControl.ReportRow

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

Set FM = frmKatBA
Set RpCo7 = FM.repCont7
Set RpCls = RpCo7.Columns
Set RpSel = RpCo7.SelectedRows

AnzPs = RpSel.Count

If AnzPs = 0 Then
    TeTit = "Posten Zuordnen"
    TeMai = "Es wurde noch kein offener Posten markiert"
    TeInh = "Um einen Offene Posten zuordnen zu können, muss dieser zuerst markiert werden."
    TeFus = "Bitte wählen Sie zuerst einen noch nicht zugeordnetren offenen Psoten aus."
    SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
    Exit Sub
End If

Set RpRow = RpSel(0)
Set RpCol = RpCls.Find(OPo_ID1)
If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
    OpNum = RpRow.Record(RpCol.ItemIndex).Value
Else
    OpNum = 0
End If
Set RpCol = RpCls.Find(OPo_IDR)
If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
    ReNum = RpRow.Record(RpCol.ItemIndex).Value
Else
    ReNum = 0
End If
Set RpCol = RpCls.Find(OPo_ID0)
If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
    PaNum = RpRow.Record(RpCol.ItemIndex).Value
Else
    PaNum = 0
End If
Set RpCol = RpCls.Find(OPo_GuiID)
If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
    TmGui = RpRow.Record(RpCol.ItemIndex).Value
Else
    TmGui = CreateID("P")
End If
Set RpCol = RpCls.Find(OPo_RechNr)
If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
    ReStr = RpRow.Record(RpCol.ItemIndex).Value
Else
    ReStr = vbNullString
End If
Set RpCol = RpCls.Find(OPo_Patient)
If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
    PaStr = RpRow.Record(RpCol.ItemIndex).Value
Else
    PaStr = vbNullString
End If
Set RpCol = RpCls.Find(OPo_OffBetrag)
If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
    OpBet = RpRow.Record(RpCol.ItemIndex).Value
Else
    OpBet = 0
End If
Set RpCol = RpCls.Find(OPo_Beleg)
If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
    OpBel = RpRow.Record(RpCol.ItemIndex).Value
Else
    OpBel = vbNullString
End If
Set RpCol = RpCls.Find(OPo_IDP)
If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
    ManNr = RpRow.Record(RpCol.ItemIndex).Value
Else
    ManNr = GlMan(GlSMa, 2)
End If
Set RpCol = RpCls.Find(OPo_IDT)
If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
    MitNr = RpRow.Record(RpCol.ItemIndex).Value
Else
    MitNr = GlMiA(GlSmI, 2)
End If

If OpLoe = True Then
    Frage = WindowMess("Möchten Sie den markierten offenen Posten wirklich entfernen?", Dial1, "Posten Entfernen", FM.hwnd)
    If Frage = 6 Then
        DBCmEx2 "qrySimReOpL", "@IdOpl", "@IdxNr", -1, ReNum 'Rechung Bezahlt Kennzeichnen
        If GlBuL = False Then 'echtes Löschen erlauben
            DBCmEx2 "qrySimOPAu3", "@PaSel", "@IdxNr", -1, OpNum
        Else
            DBCmEx1 "qrySimOPLo", "@IdxNr", OpNum
        End If
        DoEvents
        KSuch "BaPo", 3, 1
        DoEvents
        GlNeK = GlKoX 'Protokolleintrag
        With GlNeK
            .PatNr = PaNum
            .IdxNr = 0
            .EiDat = Format$(Date, "dd.mm.yyyy")
            .EiZei = TimeValue(Now)
            .EiTyp = 104
            If GlBuL = False Then 'echtes Löschen erlauben
                .TeStr = "Offener Posten storniert - " & ReStr & Chr$(32) & PaStr & " (" & Format$(OpBet, GlWa1) & ")"
            Else
                .TeStr = "Offener Posten entfernt - " & ReStr & Chr$(32) & PaStr & " (" & Format$(OpBet, GlWa1) & ")"
            End If
            .ZiStr = Format$(Now, "hh:mm") & " Uhr"
            .NeuEi = True
            .KeiAk = True
            .Mitar = GlMiA(GlSmI, 2)
        End With
        S_Prot
    End If
    Set clFen = Nothing
    Exit Sub
End If

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows
    
AnzPo = RpSel.Count

If AnzPo > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        RowNr = RpRow.Index
                        
        Set RpCol = RpCls.Find(Ban_ID2)
        IdxNr = RpRow.Record(RpCol.ItemIndex).Value

        Set RpCol = RpCls.Find(Ban_ID0)
        If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
            PatNr = RpRow.Record(RpCol.ItemIndex).Value
        Else
            PatNr = 0
        End If
        Set RpCol = RpCls.Find(Ban_Kommentar)
        If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
            PatSt = RpRow.Record(RpCol.ItemIndex).Value
        Else
            PatSt = vbNullString
        End If
        Set RpCol = RpCls.Find(Ban_KoBetrag)
        If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
            BuBet = RpRow.Record(RpCol.ItemIndex).Value
        Else
            BuBet = 0
        End If
        Set RpCol = RpCls.Find(Ban_GeBetrag)
        If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
            GeBet = RpRow.Record(RpCol.ItemIndex).Value
        Else
            GeBet = 0
        End If
        Set RpCol = RpCls.Find(Ban_Ausgabe)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BaAus = LCase(RpRow.Record(RpCol.ItemIndex).Value)
        Else
            BaAus = "ja"
        End If
        Set RpCol = RpCls.Find(Ban_Bezahlt)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BaBez = LCase(RpRow.Record(RpCol.ItemIndex).Value)
        Else
            BaBez = "ja"
        End If
        Set RpCol = RpCls.Find(Ban_Selekt)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BaSel = LCase(RpRow.Record(RpCol.ItemIndex).Value)
        Else
            BaSel = "ja"
        End If
        Set RpCol = RpCls.Find(Ban_IDZ)
        BaIDZ = CInt(RpRow.Record(RpCol.ItemIndex).Value)
        Set RpCol = RpCls.Find(Ban_IDR5)
        ReNu5 = CLng(RpRow.Record(RpCol.ItemIndex).Value)
        
        If BaAus = "ja" Then
            OpZuo = False
            TeTit = "Posten Zuordnen"
            TeMai = "Der markierte Umsatz ist eine Ausgabe"
            TeInh = "Offene Posten können nur eingehenden Zahlungen zugeordnet werden."
            TeFus = "Der markirte Umsatz ist eine Ausgabe. Der offene Posten kann daher nicht zugeordnet werden."
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
            Exit Sub
        End If

        If OpBel <> vbNullString Then
            If OpBel <> "0" Then
                OpZuo = False
                TeTit = "Posten Zuordnen"
                TeMai = "Dieser offene Posten wurde bereits einem anderen Umsatz zugeordnet"
                TeInh = "Ein offener Posten kann immer nur einem Umsatz zugeordnet werden aber nicht mehreren Kontoauszugsbuchungen"
                TeFus = "Wurde dieser offene Posten einem falschen Umsatz zugeordnet, so können Sie die Zuordnung wieder aufheben"
                SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
                Exit Sub
            End If
        End If

        If BaIDZ < 0 Then
            OpZuo = False
            TeTit = "Posten Zuordnen"
            TeMai = "Diesem Umsatz kann kein offener Posten zugeordnet werden"
            TeInh = "Dieser Umsatz wurde gekennzeichnet. Es kann daher kein weiterer offener Posten zugeordnet werden."
            TeFus = "Um die Kennzeichnung aufzuheben ist es erforderlich, den Umsatz ein weiters Mal zu kennzeichnen."
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
            Exit Sub
        End If
        
        If BaBez = "ja" Then
            OpZuo = False
            TeTit = "Posten Zuordnen"
            TeMai = "Diesem Umsatz kann kein offener Posten zugeordnet werden"
            TeInh = "Aus diesem Umsatz wurde bereits gebucht. Es kann daher kein weiterer offener Posten zugeordnet werden."
            TeFus = "Die Buchung kann rückgängig gemacht werden, indem die Zuordnung aufgehoben wird. Danach können dem Umsatz mehrere Posten zugeordnet werden."
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
            Exit Sub
        End If

        If ReNu5 > 0 Then
            OpZuo = False
            TeTit = "Posten Zuordnen"
            TeMai = "Diesem Umsatz kann kein weiterer offener Posten zugeordnet werden"
            TeInh = "Diesdem Umsatz wurden schon fünf offene Posten zugeordnet. Es kann daher kein weiterer offener Posten zugeordnet werden."
            TeFus = "Bitte buchen Sie nun den Umsatz mit seinen bereits zugeordneten offenen Posten. Alle weiteren offenen Posten können dann in der oofene Posten Verwaltung manuell ausgeglichen werden."
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
            Exit Sub
        End If

        If BaSel = "ja" Then
            TeTit = "Posten Zuordnen"
            TeMai = "Möchten Sie diesem Kontoumsatz einen weiteren offenen Posten zuordnen?"
            TeInh = "Dem markierten Kontoumsatz wurde bereits mindestens ein offener Posten zugeordnet. Klicken Sie auf Ja, um einen weiteren offenen Posten zuzuordnen."
            TeFus = "Wurden diesem Kontoumsatz ein falscher offener Posten zugeordnet, so heben Sie diese Zuordnung mit der gleichnamigen Funktion erst wieder auf, bevor Sie einen neuen offenen Posten zuordnen."
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, False, FM.hwnd
            If GlMes <> 33565 Then
                OpZuo = False
                Exit Sub
            Else
                OpZuo = True
            End If
        End If

        If PatNr > 0 Then
            If PaNum <> PatNr Then
                Tit1 = "Kontoumsatzzuordnung"
                Mld1 = "Diesem Umsatz ist bereits dem Patienten: " & PatSt & " zugeordnet. Möchten Sie diesem Umsatz wirklich den Patienten: " & PaStr & " zuordnen?"
                Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
                If Frage = 6 Then
                    OpZuo = True
                Else
                    OpZuo = False
                    Exit Sub
                End If
            Else
                OpZuo = True
            End If
        Else
            OpZuo = True
        End If

        If (BuBet - GeBet) > OpBet Then
            Tit1 = "Kontoumsatzzuordnung"
            Mld1 = "Der Umsatzbetrag von: " & Format$(BuBet, GlWa1) & " ist größer als der Postenbetrag von : " & Format$(OpBet, GlWa1) & ". Soll dieser offene Posten trotzdem zugeordnet werden?"
            Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
            If Frage = 6 Then
                OpZuo = True
            Else
                OpZuo = False
                Exit Sub
            End If
        Else
            OpZuo = True
        End If

        If OpZuo = True Then
            If GlTyp < 2 Then
                SQL1 = "SELECT * FROM dbo.qrySimBaSu WHERE ID2 = " & IdxNr
            Else
                SQL1 = "SELECT * FROM qrySimBaSu WHERE [ID2] = " & IdxNr & ";"
            End If
            Set RS125 = New ADODB.Recordset
            With RS125
                .CursorLocation = adUseClient
                .Source = SQL1
                .ActiveConnection = DB1
                .CursorType = adOpenDynamic
                .LockType = adLockOptimistic
                .Open Options:=adCmdText
            End With
            If RS125.RecordCount > 0 Then
                If RS125.Supports(adUpdate) = True Then
                    If RS125.Fields("RechNr").Value <> vbNullString Then
                        If RS125.Fields("RechNr2").Value <> vbNullString Then
                            If RS125.Fields("RechNr3").Value <> vbNullString Then
                                If RS125.Fields("RechNr4").Value <> vbNullString Then
                                    S_BaSuT RS125, 5, OpBet, ReStr, OpNum, ReNum, PaNum, ManNr, MitNr, PaStr, TmGui, True
                                Else
                                    S_BaSuT RS125, 4, OpBet, ReStr, OpNum, ReNum, PaNum, ManNr, MitNr, PaStr, TmGui, True
                                End If
                            Else
                                S_BaSuT RS125, 3, OpBet, ReStr, OpNum, ReNum, PaNum, ManNr, MitNr, PaStr, TmGui, True
                            End If
                        Else
                            S_BaSuT RS125, 2, OpBet, ReStr, OpNum, ReNum, PaNum, ManNr, MitNr, PaStr, TmGui, True
                        End If
                    Else
                        S_BaSuT RS125, 1, OpBet, ReStr, OpNum, ReNum, PaNum, ManNr, MitNr, PaStr, TmGui, True
                    End If
                    DoEvents
                    DBCmEx2 "qrySimOPBel", "@IdStr", "@IdxNr", ReStr, OpNum
                End If
            End If
            RS125.Close
            Set RS125 = Nothing
        End If
    End If
End If

Set RpSel = Nothing
Set RpCo1 = Nothing
Set RpCo7 = Nothing

Set clFen = Nothing

If OpLoe = False Then
    If OpDia = True Then
        If AnzPo > 1 Then
            Tit1 = "Kontoumsatzzuordnung"
            Mld1 = "Bitte markieren Sie nur eine Kontoauszugs-Buchung"
            WindowMess Mld1, Dial2, Tit1, FM.hwnd
        Else
            If OpZuo = True Then
                SUpBa RowNr
                frmOPAusg.Show vbModal
            End If
        End If
    Else
        If AnzPo > 1 Then
            SUpBa RowNr
        Else
            If OpZuo = True Then
                SUpBa RowNr
            End If
        End If
    End If
End If
DoEvents

If GlSuE.SuStr = vbNullString Then
    P_List "BaPo", 0, 1
Else
    P_LiSu "BaPo", 3, 1
End If

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BaSet " & Err.Number
Resume Next

End Sub
