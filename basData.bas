Case 2: Set RS123 = DBCmRe3("qryMailOuZah", "@IdxNr", "@IdStr", "@IdGel", 0, "o802o", 0)
Case 3: Set RS123 = DBCmRe3("qryMailInZah", "@IdxNr", "@IdStr", "@IdGel", 0, "o802o", 0)
Case 4: Set RS123 = DBCmRe3("qryMailOuZah", "@IdxNr", "@IdStr", "@IdGel", 0, "o802o", 0)
