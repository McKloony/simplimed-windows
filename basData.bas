Public Sub S_BaZuo()
On Error GoTo LiErr
'Ordnet dem Umsatz ein Regeleintrag zu und extrahiert die Begriffe aus dem Umsatztext

Dim SQL1 As String
Dim IdxWe As Long
Dim BaIdx As Long
Dim RegNr As Long
Dim RowNr As Long
Dim KtoNr As Long
Dim KtoSt As String
Dim BuTex As String
Dim BaAus As String
Dim BaBez As String
Dim BaSel As String
Dim UmsTx As String
Dim TmStr As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim KoStu As Single
Dim BaIDZ As Integer
Dim GesPo As Integer
Dim TmLan As Integer
Dim AnzPo As Integer
Dim AktPo As Integer
Dim AktZa As Integer
Dim GesZa As Integer
Dim Posit As Integer
Dim StaPo As Integer
Dim AnzWo As Integer
Dim AktWo As Integer
Dim ReZuo As Boolean
Dim Ermit As Boolean
Dim TmAry() As String
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCo7 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set RpCo7 = frmKatBV.repCont7
Set RpCls = RpCo7.Columns
Set RpRws = RpCo7.Rows

If RpRws.Count > 0 Then
    Set RpSel = RpCo7.SelectedRows
    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        If RpRow.GroupRow = False Then
            Set RpCol = RpCls.Find(Buh_ID0) 'Ban_IDZ
            RegNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Buh_IDP) 'Ban_IDI
            IdxWe = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Buh_Sachkonto) 'Ban_IDK
            KtoNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Buh_Sachkontenbez)
            KtoSt = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Buh_Buchtext)
            BuTex = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Buh_Steuer)
            KoStu = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Buh_Ermittlung)
            Ermit = RpRow.Record(RpCol.ItemIndex).Checked
        End If
    End If
End If

If RpSel.Count = 0 Then
    TeTit = "Buchungsregel Zuordnen"
    TeMai = "Es wurde noch keine Buchungsregel markiert"
    TeInh = "Um eine Buchungsregel zuordnen zu können, muss diese zuerst markiert werden."
    TeFus = "Bitte wählen Sie zuerst eine Buchungsregel aus."
    SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
    Exit Sub
End If

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows
    
AnzPo = RpSel.Count

If AnzPo > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        RowNr = RpRow.Index
        
        Set RpCol = RpCls.Find(Ban_ID2)
        BaIdx = RpRow.Record(RpCol.ItemIndex).Value
        
        Set RpCol = RpCls.Find(Ban_IDZ)
        BaIDZ = CInt(RpRow.Record(RpCol.ItemIndex).Value)
                
        Set RpCol = RpCls.Find(Ban_IDKurz)
        UmsTx = RpRow.Record(RpCol.ItemIndex).Value

        Set RpCol = RpCls.Find(Ban_Ausgabe)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BaAus = LCase(RpRow.Record(RpCol.ItemIndex).Value)
        Else
            BaAus = "ja"
        End If
        Set RpCol = RpCls.Find(Ban_Bezahlt)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BaBez = LCase(RpRow.Record(RpCol.ItemIndex).Value)
        Else
            BaBez = "ja"
        End If
        Set RpCol = RpCls.Find(Ban_Selekt)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BaSel = LCase(RpRow.Record(RpCol.ItemIndex).Value)
        Else
            BaSel = "ja"
        End If

        If BaIDZ < 0 Then
            ReZuo = False
            TeTit = "Buchungsregel Zuordnen"
            TeMai = "Diesem Umsatz kann keine Buchungsregel zugeordnet werden"
            TeInh = "Dieser Umsatz wurde gekennzeichnet. Es kann daher keine Buchungsregel zugeordnet werden."
            TeFus = "Um die Kennzeichnung aufzuheben ist es erforderlich, den Umsatz ein weiters Mal zu kennzeichnen."
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
            Exit Sub
        End If
        
        If BaBez = "ja" Then
            ReZuo = False
            TeTit = "Buchungsregel Zuordnen"
            TeMai = "Diesem Umsatz kann keine Buchungsregel zugeordnet werden"
            TeInh = "Aus diesem Umsatz wurde bereits eine Erlösbuchung abgeleitet. Es kann daher keine Buchungsregel zugeordnet werden."
            TeFus = "Wurden diesem Umsatz eine falsche Buchungsregel zugeordnet, so kann diese Zuordnung über die gleichnamige Funktion wieder aufgehoben werden."
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
            Exit Sub
        End If
        
        If BaSel = "ja" Then
            TeTit = "Buchungsregel Zuordnen"
            TeMai = "Diesem Umsatz kann keine weitere Buchungsregel zugeordnet werden"
            TeInh = "Dem markierten Umsatz wurde bereits eine Buchungsregel zugeordnet. Es kann daher keine weitere Buchungsregel zugeordnet werden."
            TeFus = "Fügen Sie eine weitere Buchungsregel mit derselben Sachkontennummer hinzu, um diese dem markierten Umsatz zuordnen zu können."
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
            Exit Sub
        End If
        
        GesPo = Len(UmsTx)
        StaPo = 1

        For AktPo = 1 To GesPo
            Posit = InStr(StaPo, UmsTx, Chr$(32), vbTextCompare)
            If Posit > 0 Then
                TmStr = Mid$(UmsTx, StaPo, Posit - StaPo)
                If TmStr <> vbNullString Then
                    TmLan = Len(TmStr)
                    StaPo = Posit + 1
                    If TmLan > 2 And TmLan < 20 Then
                        If IsDate(TmStr) = False And IsNumeric(TmStr) = False Then
                            GesZa = GesZa + 1
                            ReDim Preserve TmAry(GesZa)
                            TmAry(GesZa) = TmStr
                        End If
                    End If
                End If
            End If
        Next AktPo
        
        AnzWo = UBound(TmAry) 'WICHTIG!

        If AnzWo > 1 Then
            If GlTyp < 2 Then
                SQL1 = "SELECT * FROM dbo.qrySimBaZuor WHERE IDZ = " & RegNr
            Else
                SQL1 = "SELECT * FROM qrySimBaZuor WHERE [IDZ] = " & RegNr & ";"
            End If
            Set RS125 = New ADODB.Recordset
            With RS125
                .CursorLocation = adUseClient
                .Source = SQL1
                .ActiveConnection = DB1
                .CursorType = adOpenDynamic
                .LockType = adLockOptimistic
                .Open Options:=adCmdText
            End With
            If RS125.RecordCount > 0 Then
                For AktZa = 4 To 9 'Felindex
                    If RS125.Fields(AktZa).Value = vbNullString Then
                        AktWo = AktWo + 1
                        If AktWo <= AnzWo Then
                            RS125.Fields(AktZa).Value = TmAry(AktWo)
                        End If
                    End If
                Next AktZa
            End If
            RS125.Fields("Anzahl").Value = AktWo
            RS125.Update
            RS125.Close
            Set RS125 = Nothing
        End If

        DoEvents
        DBCmEx7 "qrySimBaKon", "@IdxWe", "@IdKon", "@KoStr", "@BuTex", "@IdStu", "@IdErm", "@IdxNr", IdxWe, KtoNr, KtoSt, BuTex, KoStu, Ermit, BaIdx
        DoEvents
        DBCmEx2 "qrySimBaSel", "@IdSel", "@IdxNr", -1, BaIdx
        DoEvents
    End If
End If

Set RpSel = Nothing
Set RpCo1 = Nothing
Set RpCo7 = Nothing

Screen.MousePointer = vbHourglass
DoEvents
SUpBa RowNr
DoEvents
Screen.MousePointer = vbNormal

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BaZuo " & Err.Number
Resume Next

End Sub
