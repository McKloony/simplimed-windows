If RS127.RecordCount > 0 Then
    If RS127.Fields(FelNa).Value <> vbNullString Then
        S_AdIdx = RS127.Fields(FelNa).Value
    Else
        Select Case RS127.Fields(FelNa).Type
        Case adBigInt: S_AdIdx = 0
        Case adBoolean: S_AdIdx = 0
        Case adChar: S_AdIdx = vbNullString
        Case adVarChar: S_AdIdx = vbNullString
        Case adCurrency: S_AdIdx = 0
        Case adDate: S_AdIdx = vbNullString
        Case adDecimal: S_AdIdx = 0
        Case adDouble: S_AdIdx = 0
        Case adInteger: S_AdIdx = 0
        Case adNumeric: S_AdIdx = 0
        Case adSingle: S_AdIdx = 0
        Case adSmallInt: S_AdIdx = 0
        Case Else: S_AdIdx = vbNullString
        End Select
    End If
Else
    Select Case RS127.Fields(FelNa).Type
    Case adBigInt: S_AdIdx = 0
    Case adBoolean: S_AdIdx = 0
    Case adChar: S_AdIdx = vbNullString
    Case adVarChar: S_AdIdx = vbNullString
    Case adCurrency: S_AdIdx = 0
    Case adDate: S_AdIdx = vbNullString
    Case adDecimal: S_AdIdx = 0
    Case adDouble: S_AdIdx = 0
    Case adInteger: S_AdIdx = 0
    Case adNumeric: S_AdIdx = 0
    Case adSingle: S_AdIdx = 0
    Case adSmallInt: S_AdIdx = 0
    Case Else: S_AdIdx = vbNullString
    End Select
End If
RS127.Close
Set RS127 = Nothing

Exit Function

LoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_AdIdx " & Err.Number
Resume Next

End Function
Public Sub S_AdIm(ByVal ImTyp As String, ByVal ManNr As Long, Optional ByVal GruKy As String, Optional ByVal IsArz As Boolean = False)
On Error GoTo LiErr
'Adressenimport

Dim PatNr As Long
Dim RowNr As Long
Dim TheNr As Long
Dim IdxNr As Long
Dim GesZa As Long
Dim AktZa As Long
Dim AktZe As Long
Dim AktFe As Long
Dim AnzPa As Long
Dim FiNam As String 'Filename
Dim PatKu As String 'Kurzbezeichnung
Dim PaKur As String 'Kurzbezeichnung
Dim PaGui As String 'GuiID
Dim TmpSt As String
Dim Lange As Integer
Dim AnzGe As Integer
Dim TmpWe As Variant
Dim DatOk As Boolean
Dim OutAd As Boolean
Dim OutGb As Boolean
Dim Mld2, Tit1 As String
Dim Frage As Integer
Dim AryZe() As String
Dim AryDe() As String
Dim AryFe() As String
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmThe As XtremeCommandBars.CommandBarComboBox
Dim RpCo2 As XtremeReportControl.ReportControl
Dim RpRow As XtremeReportControl.ReportRow

Dim NaSpa As Object
Dim MapFo As Object
Dim KoIts As Object
Dim KoItm As Object

Set FM = frmMain
Set CoDia = FM.comDialo
Set RpCo2 = FM.repCont2
Set CmBrs = FM.comBar01

Set CmThe = CmBrs.FindControl(CmThe, SY_SuMan, , True)

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

Tit1 = "Adressenimport"
OutAd = CBool(IniGetVal("System", "OutAdr"))
OutGb = CBool(IniGetVal("System", "OutGeb"))

If CmThe.Visible = True Then
    TheNr = CmThe.ItemData(CmThe.ListIndex)
Else
    TheNr = GlMan(GlSMa, 2)
End If

If ImTyp = "psx" Then
    SOuOp 'Outlook

    Set NaSpa = OutOb.GetNamespace("MAPI") 'NameSpace
    Set MapFo = NaSpa.PickFolder

    If TypeName(MapFo) = "Nothing" Then
        Exit Sub
    ElseIf MapFo.DefaultItemType <> olContactItem Then
        Exit Sub
    End If
    
    Set KoIts = MapFo.Items
    GesZa = KoIts.Count
    
    If GesZa > 0 Then
        Set RS121 = New ADODB.Recordset 'Patienten
        With RS121
            .CursorLocation = adUseClient
            .Source = "qryAdrNeu"
            .ActiveConnection = DB1
            .CursorType = adOpenKeyset
            .LockType = adLockOptimistic
            .Open Options:=adCmdTableDirect
        End With
        If RS121.Supports(adAddNew) Then
            Screen.MousePointer = vbHourglass
            
            frmStatus.Show
            DoEvents
            frmStatus.Caption = "Outlookimport"
            Set Lbl01 = frmStatus.lblLab01
            Set PrBr1 = frmStatus.prbStat1
            Set PrBr2 = frmStatus.prbStat2
            Set TxDum = frmStatus.txtDummy
            Lbl01.Caption = "Bitte warten..."
            PrBr1.Min = 0
            PrBr1.Max = GesZa
            
            For Each KoItm In KoIts
                RS121.AddNew
                With KoItm
                    If .CustomerID <> vbNullString Then
                        RS121.Fields("Mandant").Value = .CustomerID
                    Else
                        RS121.Fields("Mandant").Value = CreateID("A")
                    End If
                    If .FileAs <> vbNullString Then
                        RS121.Fields("IDKurz").Value = .FileAs
                    Else
                        RS121.Fields("IDKurz").Value = "-"
                    End If
                    If .Title <> vbNullString Then RS121.Fields("Anrede").Value = .Title
                    If .CompanyName <> vbNullString Then
                        If Len(.CompanyName) > 70 Then
                            RS121.Fields("R_Firma1").Value = Left$(.CompanyName, 69)
                        Else
                            RS121.Fields("R_Firma1").Value = .CompanyName
                        End If
                    End If
                    If .FirstName <> vbNullString Then
                        If Len(.CompanyName) > 70 Then
                            RS121.Fields("Vorname").Value = Left(.FirstName, 69)
                        Else
                            RS121.Fields("Vorname").Value = .FirstName
                        End If
                    End If
                    If .LastName <> vbNullString Then
                        If Len(.LastName) > 70 Then
                            RS121.Fields("Name").Value = Left$(.LastName, 69)
                        Else
                            RS121.Fields("Name").Value = .LastName
                        End If
                    End If
                    If .Body <> vbNullString Then RS121.Fields("Bemerkung").Value = .Body
                    If .BusinessAddressStreet <> vbNullString Then
                        If Len(.BusinessAddressStreet) > 50 Then
                            RS121.Fields("R_Straße").Value = Left$(.BusinessAddressStreet, 49)
                        Else
                            RS121.Fields("R_Straße").Value = .BusinessAddressStreet
                        End If
                    End If
                    If .BusinessAddressCity <> vbNullString Then
                        If Len(.BusinessAddressCity) > 50 Then
                            RS121.Fields("R_Ort").Value = Left$(.BusinessAddressCity, 49)
                        Else
                            RS121.Fields("R_Ort").Value = .BusinessAddressCity
                        End If
                    End If
                    If .BusinessAddressPostalCode <> vbNullString Then RS121.Fields("R_PLZ").Value = .BusinessAddressPostalCode
                    If .BusinessAddressCountry <> vbNullString Then RS121.Fields("R_Land").Value = .BusinessAddressCountry
                    If .PrimaryTelephoneNumber <> vbNullString Then RS121.Fields("Telefon1").Value = .PrimaryTelephoneNumber
                    If .BusinessTelephoneNumber <> vbNullString Then RS121.Fields("Telefon2").Value = .BusinessTelephoneNumber
                    If .BusinessFaxNumber <> vbNullString Then RS121.Fields("Telefon3").Value = .BusinessFaxNumber
                    If .MobileTelephoneNumber <> vbNullString Then RS121.Fields("Telefon4").Value = .MobileTelephoneNumber
                    If .Email1Address <> vbNullString Then RS121.Fields("Telefon5").Value = .Email1Address
                    If .Email2Address <> vbNullString Then RS121.Fields("Telefon6").Value = .Email2Address
                    If .BusinessHomePage <> vbNullString Then RS121.Fields("Internet").Value = .BusinessHomePage
                    If .HomeAddressStreet <> vbNullString Then
                        If Len(.HomeAddressStreet) > 50 Then
                            RS121.Fields("Straße").Value = Left$(.HomeAddressStreet, 49)
                        Else
                            RS121.Fields("Straße").Value = .HomeAddressStreet
                        End If
                    End If
                    If .HomeAddressCity <> vbNullString Then
                        If Len(.HomeAddressCity) > 50 Then
                            RS121.Fields("Ort").Value = Left$(.HomeAddressCity, 49)
                        Else
                            RS121.Fields("Ort").Value = .HomeAddressCity
                        End If
                    End If
                    If .HomeAddressCountry <> vbNullString Then RS121.Fields("Land").Value = .HomeAddressCountry
                    If .HomeAddressPostalCode <> vbNullString Then RS121.Fields("PLZ").Value = .HomeAddressPostalCode
                    If .Profession <> vbNullString Then RS121.Fields("Beruf").Value = .Profession
                    'If .Birthday <> vbnullstring Then RS121.Fields("Geboren").Value = .Birthday
                    If .LastModificationTime <> vbNullString Then
                        RS121.Fields("LastModification").Value = Format$(DateValue(.LastModificationTime), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(.LastModificationTime), "hh:mm:ss")
                    Else
                        RS121.Fields("LastModification").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                    End If
                    If .BillingInformation <> vbNullString Then
                        RS121.Fields("GuiID").Value = .BillingInformation
                    Else
                        RS121.Fields("GuiID").Value = CreateID("A")
                    End If
                    RS121.Fields("ID3").Value = GlGKa(GlStK, 0) 'Standardgebührenkatalog
                    RS121.Fields("IDZ").Value = GlZah(GlStZ, 0) 'Standardzahlungsziel
                    RS121.Fields("Datum").Value = Date
                    RS121.Fields("Geändert").Value = Date
                    RS121.Fields("IDP").Value = TheNr
                    RS121.Fields("Arzt").Value = IsArz
                    RS121.Fields("Replicated").Value = -1 'Wurde Synchronisiert
                End With
                AktZa = AktZa + 1
                DoEvents
                If TxDum.Text = "B" Then Exit For 'Abbrechen
                PrBr1.Value = AktZa
            Next KoItm
            
            RS121.Update
            RS121.Close
            Set RS121 = Nothing
            
            Screen.MousePointer = vbNormal
            
            Unload frmStatus
            Set frmStatus = Nothing
            DoEvents
            Adr_Er1
            
            Set KoItm = Nothing
            Set NaSpa = Nothing
            Set MapFo = Nothing
            Set KoIts = Nothing
            Set OutOb = Nothing
        End If
    End If
Else
    If ImTyp = "txt" Then
        With CoDia
            .CancelError = True
            .DialogStyle = 1
            .DefaultExt = "*.txt"
            .Filter = "Ascii-Text Format (*.txt)|*.txt|Alle Dateien (*.*)|*.*"
            .DialogTitle = "Wo befindet sich die Importdatei?"
            .InitDir = GlIPf
            .FileName = vbNullString
            .ShowOpen
            FiNam = .FileName
            If .FileTitle = vbNullString Then
                Set CoDia = Nothing
                Set CmBrs = Nothing
                Set RpCo2 = Nothing
                Set clFil = Nothing
                Exit Sub
            End If
        End With
            
        Set RS121 = New ADODB.Recordset 'Patienten
        With RS121
            .CursorLocation = adUseClient
            .Source = "qryAdrNeu"
            .ActiveConnection = DB1
            .CursorType = adOpenForwardOnly
            .LockType = adLockReadOnly
            .Open Options:=adCmdTableDirect
        End With
        
        Set RS125 = New ADODB.Recordset 'Neues Recordset erstellen Patienten
        RS125.CursorLocation = adUseClient
        For Each FL101 In RS121.Fields
            RS125.Fields.Append FL101.Name, FL101.Type, FL101.DefinedSize
        Next FL101
        If RS125.State = adStateClosed Then RS125.Open
        
        RS121.Close
        Set RS121 = Nothing
        
        If clFil.FilVor(FiNam) = True Then 'Patienten
            frmStatus.Show
            DoEvents
            Set Lbl01 = frmStatus.lblLab01
            Set PrBr1 = frmStatus.prbStat1
            Set PrBr2 = frmStatus.prbStat2
            Set TxDum = frmStatus.txtDummy
            Lbl01.Caption = "Bitte warten..."
        
            With clFil
                .FilPfa FiNam
                TmpSt = .FilReSt
            End With
            
            AryZe = Split(TmpSt, "|") 'Zeilen aufsplitten
            AryDe = Split(AryZe(0), ";") 'Feldnamen aufsplitten
            
            PrBr1.Min = 0
            PrBr1.Max = UBound(AryZe)
            frmStatus.Caption = "Adressenimport"
            
            If TmpSt <> vbNullString Then
                For AktZe = 1 To UBound(AryZe) - 1
                    If AryZe(AktZe) <> vbNullString Then
                        AryFe = Split(AryZe(AktZe), ";") 'Felder aufsplitten
                        RS125.AddNew
                        For AktFe = 0 To UBound(AryDe) - 1
                            For Each FL101 In RS125.Fields
                                If FL101.Name = AryDe(AktFe) Then
                                    
                                    If AktFe <= UBound(AryFe) Then
                                        If AryFe(AktFe) <> vbNullString Then
                                            Select Case FL101.Name
                                            Case "LastModification":
                                            Case "TreKey":
                                                If GruKy <> vbNullString Then
                                                    If AryFe(AktFe) <> vbNullString Then
                                                        RS125.Fields(FL101.Name).Value = AryFe(AktFe) & GruKy
                                                    Else
                                                        RS125.Fields(FL101.Name).Value = GruKy
                                                    End If
                                                Else
                                                    RS125.Fields(FL101.Name).Value = AryFe(AktFe)
                                                End If
                                            Case "ID0":
                                                If AryFe(AktFe) <> vbNullString Then
                                                    If IsNumeric(AryFe(AktFe)) = True Then
                                                        RS125.Fields(FL101.Name).Value = AryFe(AktFe)
                                                    End If
                                                End If
                                            Case "IDP":
                                                If ManNr > 0 Then
                                                    RS125.Fields(FL101.Name).Value = ManNr
                                                Else
                                                    RS125.Fields(FL101.Name).Value = TheNr
                                                End If
                                            Case "IDZ":
                                                If AryFe(AktFe) <> vbNullString Then
                                                    If IsNumeric(AryFe(AktFe)) = True Then
                                                        RS125.Fields(FL101.Name).Value = CLng(AryFe(AktFe))
                                                    Else
                                                        RS125.Fields(FL101.Name).Value = GlZah(GlStZ, 0) 'Standardzahlungsziel
                                                    End If
                                                Else
                                                    RS125.Fields(FL101.Name).Value = GlZah(GlStZ, 0)
                                                End If
                                            Case "ID3":
                                                If AryFe(AktFe) <> vbNullString Then
                                                    If IsNumeric(AryFe(AktFe)) = True Then
                                                        RS125.Fields(FL101.Name).Value = CLng(AryFe(AktFe))
                                                    Else
                                                        RS125.Fields(FL101.Name).Value = GlGKa(GlStK, 0) 'Standardgebührenkatalog
                                                    End If
                                                Else
                                                    RS125.Fields(FL101.Name).Value = GlGKa(GlStK, 0)
                                                End If
                                            Case "IDV":
                                                If AryFe(AktFe) <> vbNullString Then
                                                    If IsNumeric(AryFe(AktFe)) = True Then
                                                        RS125.Fields(FL101.Name).Value = AryFe(AktFe)
                                                    End If
                                                End If
                                            Case "HausNr":
                                                If AryFe(AktFe) <> vbNullString Then
                                                    If Len(AryFe(AktFe)) > 10 Then
                                                        RS125.Fields(FL101.Name).Value = Left$(AryFe(AktFe), 10)
                                                    Else
                                                        RS125.Fields(FL101.Name).Value = AryFe(AktFe)
                                                    End If
                                                End If
                                            Case "Arzt":
                                                    RS125.Fields(FL101.Name).Value = IsArz
                                            Case "Guthaben":
                                                    RS125.Fields(FL101.Name).Value = Replace(AryFe(AktFe), Chr$(32), ".", 1)
                                            Case "Entfernung":
                                                    If IsNumeric(AryFe(AktFe)) = True Then
