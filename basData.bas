Public Sub S_BaOpo()
On Error GoTo LiErr
'Leitet aus dem Umsatz einen offenen Posten ab

Dim IdxNr As Long
Dim PatNr As Long
Dim RowNr As Long
Dim ManNr As Long
Dim MitNr As Long
Dim ReNum As Long
Dim ReStr As String
Dim PaIBN As String
Dim PaBIC As String
Dim PaKto As String
Dim PaBLZ As String
Dim BaGui As String
Dim BaKom As String
Dim OpBet As Single
Dim ReStu As Single 'Steuer
Dim AnzPo As Integer
Dim AktZa As Integer
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows
    
AnzPo = RpSel.Count

If AnzPo > 0 Then
    If AnzPo = 1 Then
        Frage = WindowMess("Soll zum markierten Umsatz, ein offener Posten abgeleitet werden?", Dial1, "Offener Posten ableiten", FM.hwnd)
    Else
        Frage = WindowMess("Sollen zu den markierten " & AnzPo & " Umsätzen, offene Posten abgeleitet werden?", Dial1, "Offene Posten ableiten", FM.hwnd)
    End If
    If Frage = 6 Then
        Screen.MousePointer = vbHourglass

        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                RowNr = RpRow.Index
                
                Set RpCol = RpCls.Find(Ban_IDR)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    ReNum = RpRow.Record(RpCol.ItemIndex).Value
                    
                    Set RpCol = RpCls.Find(Ban_IDZ)
                    If CInt(RpRow.Record(RpCol.ItemIndex).Value) = 0 Then
                    
                        Set RpCol = RpCls.Find(Ban_Selekt)
                        If LCase(RpRow.Record(RpCol.ItemIndex).Value) = "ja" Then
                        
                            Set RpCol = RpCls.Find(Ban_KoBetrag)
                            If CDbl(RpRow.Record(RpCol.ItemIndex).Value) < 0 Then
                                OpBet = Abs(CSng(RpRow.Record(RpCol.ItemIndex).Value))
            
                                Set RpCol = RpCls.Find(Ban_ID2)
                                IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                                Set RpCol = RpCls.Find(Ban_ID0)
                                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                                    PatNr = RpRow.Record(RpCol.ItemIndex).Value
                                Else
                                    PatNr = 0
                                End If
                                Set RpCol = RpCls.Find(Ban_IDP)
                                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                                    ManNr = RpRow.Record(RpCol.ItemIndex).Value
                                Else
                                    ManNr = 0
                                End If
                                Set RpCol = RpCls.Find(Ban_IDM)
                                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                                    MitNr = RpRow.Record(RpCol.ItemIndex).Value
                                Else
                                    MitNr = 0
                                End If
                                Set RpCol = RpCls.Find(Ban_RechNr1)
                                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                                    ReStr = RpRow.Record(RpCol.ItemIndex).Value
                                Else
                                    ReStr = vbNullString
                                End If
                                Set RpCol = RpCls.Find(Ban_GuiID)
                                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                                    BaGui = RpRow.Record(RpCol.ItemIndex).Value
                                Else
                                    BaGui = vbNullString
                                End If
                                Set RpCol = RpCls.Find(Ban_IDKurz)
                                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                                    BaKom = RpRow.Record(RpCol.ItemIndex).Value
                                End If
            
                                S_AdDe PatNr 'Adressendetails
                                With GlADt
                                    PaIBN = .AdIBA
                                    PaBIC = .AdBIC
                                    PaKto = .AdKto
                                    PaBLZ = .AdBLZ
                                End With
            
                                ReStu = CSng(S_ReIdx(ReNum, "Steuer"))
                                DoEvents
            
                                Set RS122 = New ADODB.Recordset
                                With RS122 'Neuer Posten
                                    .CursorLocation = adUseClient
                                    .Source = "qrySimOPNe"
                                    .ActiveConnection = DB1
                                    .CursorType = adOpenStatic
                                    .LockType = adLockOptimistic
                                    .Open Options:=adCmdTableDirect
                                End With
    
                                RS122.AddNew 'neuer Posten
                                RS122.Fields("ID0").Value = PatNr
                                RS122.Fields("IDR").Value = ReNum
                                RS122.Fields("IDP").Value = ManNr
                                RS122.Fields("IDT").Value = MitNr
                                RS122.Fields("RechNr").Value = ReStr
                                RS122.Fields("Intervall").Value = 7
                                RS122.Fields("Datum").Value = Date
                                RS122.Fields("Fällig").Value = Date
                                RS122.Fields("Betrag").Value = OpBet
                                RS122.Fields("Bezahlt").Value = 0
                                RS122.Fields("Offen").Value = OpBet
                                RS122.Fields("Währung").Value = GlWar(GlStW, 0)
                                RS122.Fields("Mahnbar").Value = -1
                                RS122.Fields("GuiID").Value = BaGui
                                RS122.Fields("IDM").Value = 0
                                RS122.Fields("Mahnfrist").Value = Date
                                RS122.Fields("Steuer").Value = ReStu
                                RS122.Fields("Versand").Value = 0
                                If BaKom <> vbNullString Then
                                    RS122.Fields("Kommentar").Value = Trim$(BaKom)
                                End If
                                If PaKto <> vbNullString Then RS122.Fields("Konto").Value = PaKto
                                If PaBLZ <> vbNullString Then RS122.Fields("BLZ").Value = PaBLZ
                                If PaBIC <> vbNullString Then RS122.Fields("BIC").Value = PaBIC
                                If PaIBN <> vbNullString Then RS122.Fields("IBAN").Value = PaIBN
                                RS122.Update
    
                                DoEvents
                                AktZa = AktZa + 1
                                DBCmEx3 "qrySimBaBez", "@IdBez", "@IdSel", "@IdxNr", -1, -1, IdxNr
                            Else
                                SPopu "Buchung bereits abgeleitet", "Von diesem Umsatz wurde bereits eine Buchung abgeleitet", IC48_Warning
                            End If
                        Else
                            SPopu "Umsatz gekennzeichnet", "Dieser Umsatz wurde gekennzeichnet", IC48_Warning
                        End If
                    End If
                Else
                    SPopu "Keine Rechnung zugeordnet", "Diesem Umsatz wurde noch keine Rechnung zugeordnet", IC48_Warning
                End If
            End If
        Next RpRow
        
        Screen.MousePointer = vbNormal
    End If
End If

If AktZa > 0 Then
    Screen.MousePointer = vbHourglass
    DoEvents
    SUpBa RowNr
    DoEvents
    Screen.MousePointer = vbNormal
    SPopu "Offene Posten Ableitung", "Es wurden " & AktZa & " Offene Posten hinzugefügt", IC48_Information
End If

Set RpSel = Nothing
Set RpCo1 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BaOpo " & Err.Number
Resume Next

End Sub

Public Sub S_BaRch()
