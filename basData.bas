Public Function S_BuZu1(ByVal SuStr As String, ByVal SuFel As Integer, ByVal SuTyp As Integer) As Long
On Error GoTo SuErr

Dim GesZa As Long
Dim Mld1, Tit1 As String
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpCon As XtremeReportControl.ReportControl

Set FM = frmBuZuo
Set RpCon = FM.repCont1
Set RpCls = RpCon.Columns
Set RpRcs = RpCon.Records

GlAkt = True 'WICHTIG!

If SuTyp = 1 Then
    If SuFel = 2 Then
        If IsNumeric(SuStr) = False Then
            Tit1 = "Falsches Eingabeformat"
            Mld1 = "Der von Ihnen eingegebene Wert ist keine Zahl"
            SPopu Tit1, Mld1, IC48_Information
            Exit Function
        End If
    End If
Else
    If SuFel = 2 Then
        If IsDate(SuStr) = False Then
            Tit1 = "Falsches Eingabeformat"
            Mld1 = "Der von Ihnen eingegebene Wert ist kein Datum"
            SPopu Tit1, Mld1, IC48_Information
            Exit Function
        End If
    End If
End If

Set RS120 = New ADODB.Recordset
RS120.CursorLocation = adUseClient
If SuTyp = 1 Then
    Select Case SuFel
    Case 1: Set RS120 = DBCmRe1("qrySimAdKur", "@IdStr", "%" & SuStr & "%")
    Case 2: Set RS120 = DBCmRe1("qrySimAdIdx", "@IdxNr", CLng(SuStr))
    Case 3: Set RS120 = DBCmRe1("qrySimAdPLZ", "@IdStr", SuStr)
    End Select
Else
    Select Case SuFel
    Case 1: Set RS120 = DBCmRe1("qrySimReKu1", "@IdStr", "%" & SuStr & "%")
    Case 2: Set RS120 = DBCmRe1("qrySimReNu1", "@IdStr", "%" & SuStr & "%")
    Case 3: Set RS120 = DBCmRe1("qrySimReDt1", "@IdDat", CDate(SuStr))
    End Select
End If
GesZa = RS120.RecordCount

If GesZa > 0 Then
    If SuTyp = 1 Then
        S_BuZu2 RS120
    Else
        S_BuZu3 RS120
    End If
    DoEvents
    RpCon.Populate
End If

RS120.Close
Set RS120 = Nothing

S_BuZu1 = GesZa

Set RpCol = Nothing
Set RpCls = Nothing
Set RpCon = Nothing

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BuZu1 " & Err.Number
Resume Next

End Function
