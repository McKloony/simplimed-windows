        If RowNr >= RpRws.Count Then
            RowNr = RpRws.Count - 1
        End If
        RpCo0.TopRowIndex = RowFi
        RpRws.Row(0).Selected = False
        RpRws.Row(RowNr).EnsureVisible
        RpRws.Row(RowNr).Selected = True
        If GlFoc = True Then
            Set RpCo0.FocusedRow = RpRws.Row(RowNr)
        End If
    End If
End If

GlNeK = GlKoX 'Protokolleintrag
With GlNeK
    .PatNr = GlMan(GlSMa, 2)
    .IdxNr = 0
    .EiDat = Format$(Date, "dd.mm.yyyy")
    .EiZei = TimeValue(Now)
    .EiTyp = 104
    .TeStr = "Email gelöscht - " & MaiDa & Chr$(32) & EmpNa & Chr$(32) & SenNa
    .ZiStr = Format$(Now, "hh:mm") & " Uhr"
    .NeuEi = True
    .KeiAk = True
    .Mitar = GlMiA(GlSmI, 2)
End With
S_Prot

Set RpSel = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo0 = Nothing

Set clFil = Nothing

Exit Sub

LoErr:
If GlDbg = True Then SErLog Err.Description & " S_MaLo " & Err.Number
Resume Next

End Sub
Public Sub S_MaMa(ByVal MaTyp As Integer, Optional ByVal PatNr As Long, Optional ByVal PaStr As String)
On Error GoTo LoErr
'Email Markieren

Dim IdxNr As Long
Dim GruNr As Long
Dim GruSt As String
Dim EmAdr As String
Dim EmBet As String
Dim SpmAd As String
Dim GesZa As Integer
Dim RowNr As Integer
Dim Frage As Integer
Dim RetWe As Boolean
Dim Mld1, Tit1 As String
Dim RpCo0 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo0 = FM.repCont0
Set RpCls = RpCo0.Columns
Set RpSel = RpCo0.SelectedRows

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

Screen.MousePointer = vbHourglass
DoEvents

GesZa = RpSel.Count

If GesZa > 0 Then
    Set RpRow = RpSel(0)
    RowNr = RpRow.Index
    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            IdxNr = MaAry(Mai_IDA, RpRow.Index)
            EmAdr = MaAry(Mai_SenderEmail, RpRow.Index)
            EmBet = MaAry(Mai_Subject, RpRow.Index)
                        
            Select Case MaTyp
            Case 1: 'Gelesen
                If MaAry(Mai_Gelesen, RpRow.Index) <> vbNullString Then
                    If CBool(MaAry(Mai_Gelesen, RpRow.Index)) = False Then
                        Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                        Case 1: DBCmEx2 "qryMailInGel", "@IdGel", "@IdxNr", -1, IdxNr
                        Case 2: DBCmEx2 "qryMailOutGel", "@IdGel", "@IdxNr", -1, IdxNr
                        Case 3: DBCmEx2 "qryMailInGel", "@IdGel", "@IdxNr", -1, IdxNr
                        Case 4: DBCmEx2 "qryMailOutGel", "@IdGel", "@IdxNr", -1, IdxNr
                        End Select
                    Else
                        Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                        Case 1: DBCmEx2 "qryMailInGel", "@IdGel", "@IdxNr", 0, IdxNr
                        Case 2: DBCmEx2 "qryMailOutGel", "@IdGel", "@IdxNr", 0, IdxNr
                        Case 3: DBCmEx2 "qryMailInGel", "@IdGel", "@IdxNr", 0, IdxNr
                        Case 4: DBCmEx2 "qryMailOutGel", "@IdGel", "@IdxNr", 0, IdxNr
                        End Select
                    End If
                Else
                    Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                    Case 1: DBCmEx2 "qryMailInGel", "@IdGel", "@IdxNr", -1, IdxNr
                    Case 2: DBCmEx2 "qryMailOutGel", "@IdGel", "@IdxNr", -1, IdxNr
                    Case 3: DBCmEx2 "qryMailInGel", "@IdGel", "@IdxNr", -1, IdxNr
                    Case 4: DBCmEx2 "qryMailOutGel", "@IdGel", "@IdxNr", -1, IdxNr
                    End Select
                End If
            Case 2: 'Markierung
                If CBool(MaAry(Mai_Marker, RpRow.Index)) = False Then
                    Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                    Case 1: DBCmEx2 "qryMailInMar", "@IdMar", "@IdxNr", -1, IdxNr
                    Case 2: DBCmEx2 "qryMailOutMar", "@IdMar", "@IdxNr", -1, IdxNr
                    Case 3: DBCmEx2 "qryMailInMar", "@IdMar", "@IdxNr", -1, IdxNr
                    Case 4: DBCmEx2 "qryMailOutMar", "@IdMar", "@IdxNr", -1, IdxNr
                    End Select
                Else
                    Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                    Case 1: DBCmEx2 "qryMailInMar", "@IdMar", "@IdxNr", 0, IdxNr
                    Case 2: DBCmEx2 "qryMailOutMar", "@IdMar", "@IdxNr", 0, IdxNr
                    Case 3: DBCmEx2 "qryMailInMar", "@IdMar", "@IdxNr", 0, IdxNr
                    Case 4: DBCmEx2 "qryMailOutMar", "@IdMar", "@IdxNr", 0, IdxNr
                    End Select
                End If
            Case 3: 'Junkmail
                If MaAry(Mai_Spammail, RpRow.Index) <> vbNullString Then
                    If CBool(MaAry(Mai_Spammail, RpRow.Index)) = False Then
                        GruNr = Mid$("P805", 2, Len("P805") - 1)
                        GruSt = "o" & GruNr & "o"
                        Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                        Case 1: DBCmEx2 "qryMailInSpm", "@IdSpm", "@IdxNr", -1, IdxNr
                        Case 2: DBCmEx2 "qryMailOutSpm", "@IdSpm", "@IdxNr", -1, IdxNr
                        Case 3: DBCmEx2 "qryMailInSpm", "@IdSpm", "@IdxNr", -1, IdxNr
                        Case 4: DBCmEx2 "qryMailOutSpm", "@IdSpm", "@IdxNr", -1, IdxNr
                        End Select
                        DoEvents
                        If SpmAd <> EmAdr Then
                            S_MaSp EmAdr, EmBet
                            SpmAd = EmAdr
                        End If
                    Else
                        GruNr = Mid$("P801", 2, Len("P801") - 1)
                        GruSt = "o" & GruNr & "o"
                        Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                        Case 1: DBCmEx2 "qryMailInSpm", "@IdSpm", "@IdxNr", 0, IdxNr
                        Case 2: DBCmEx2 "qryMailOutSpm", "@IdSpm", "@IdxNr", 0, IdxNr
                        Case 3: DBCmEx2 "qryMailInSpm", "@IdSpm", "@IdxNr", 0, IdxNr
                        Case 4: DBCmEx2 "qryMailOutSpm", "@IdSpm", "@IdxNr", 0, IdxNr
                        End Select
                        DoEvents
                        If SpmAd <> EmAdr Then
                            S_MaSp EmAdr, EmBet, True
                            SpmAd = EmAdr
                        End If
                    End If
                    Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                    Case 1: DBCmEx2 "qryMailInTre", "@IdStr", "@IdxNr", GruSt, IdxNr
                    Case 2: DBCmEx2 "qryMailOutTre", "@IdStr", "@IdxNr", GruSt, IdxNr
                    Case 3: DBCmEx2 "qryMailInTre", "@IdStr", "@IdxNr", GruSt, IdxNr
                    Case 4: DBCmEx2 "qryMailOutTre", "@IdStr", "@IdxNr", GruSt, IdxNr
                    End Select
                Else
                    GruNr = Mid$("P805", 2, Len("P805") - 1)
                    GruSt = "o" & GruNr & "o"
                    Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                    Case 1: DBCmEx2 "qryMailInSpm", "@IdSpm", "@IdxNr", -1, IdxNr
                    Case 2: DBCmEx2 "qryMailOutSpm", "@IdSpm", "@IdxNr", -1, IdxNr
                    Case 3: DBCmEx2 "qryMailInSpm", "@IdSpm", "@IdxNr", -1, IdxNr
                    Case 4: DBCmEx2 "qryMailOutSpm", "@IdSpm", "@IdxNr", -1, IdxNr
                    End Select
                End If
            Case 4: 'Sensitivity
                    Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                    Case 1: DBCmEx2 "qryMailInSen", "@IdSen", "@IdxNr", 1, IdxNr
                    Case 2: DBCmEx2 "qryMailOutSen", "@IdSen", "@IdxNr", 1, IdxNr
                    Case 3: DBCmEx2 "qryMailInSen", "@IdSen", "@IdxNr", 1, IdxNr
                    Case 4: DBCmEx2 "qryMailOutSen", "@IdSen", "@IdxNr", 1, IdxNr
                    End Select
            Case 5: 'Patienten
                    Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                    Case 1: DBCmEx3 "qryMailInPat", "@IdPat", "@IdStr", "@IdxNr", PatNr, PaStr, IdxNr
                    Case 2: DBCmEx3 "qryMailOutPat", "@IdPat", "@IdStr", "@IdxNr", PatNr, PaStr, IdxNr
                    Case 3: DBCmEx3 "qryMailInPat", "@IdPat", "@IdStr", "@IdxNr", PatNr, PaStr, IdxNr
                    Case 4: DBCmEx3 "qryMailOutPat", "@IdPat", "@IdStr", "@IdxNr", PatNr, PaStr, IdxNr
                    End Select
                    If EmAdr <> vbNullString Then
                        Set RS131 = New ADODB.Recordset 'Patientenfilter
                        RS131.CursorLocation = adUseClient
                        Set RS131 = DBCmRe1("qryAdrIdx", "@IdxNr", PatNr)
                        If RS131.RecordCount > 0 Then
                            If RS131.Fields("Telefon5").Value = vbNullString Then
                                DBCmEx2 "qrySimAdEAk1", "@IdStr", "@IdxNr", EmAdr, PatNr
                            ElseIf IsNull(RS131.Fields("Telefon5").Value) = True Then
                                DBCmEx2 "qrySimAdEAk1", "@IdStr", "@IdxNr", EmAdr, PatNr
                            ElseIf RS131.Fields("Telefon6").Value = vbNullString Then
                                DBCmEx2 "qrySimAdEAk2", "@IdStr", "@IdxNr", EmAdr, PatNr
                            ElseIf IsNull(RS131.Fields("Telefon6").Value) = True Then
                                DBCmEx2 "qrySimAdEAk2", "@IdStr", "@IdxNr", EmAdr, PatNr
                            Else
                                RetWe = Adr_ZuMa(PatNr, EmAdr, EmBet)
                            End If
                        End If
                        RS131.Close
                        Set RS131 = Nothing
                    End If
            Case 7: 'Geöffnet und gelesen
                    If MaAry(Mai_Gelesen, RpRow.Index) <> vbNullString Then
                        If CBool(MaAry(Mai_Gelesen, RpRow.Index)) = False Then
                            Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                            Case 1: DBCmEx2 "qryMailInGel", "@IdGel", "@IdxNr", -1, IdxNr
                            Case 2: DBCmEx2 "qryMailOutGel", "@IdGel", "@IdxNr", -1, IdxNr
                            Case 3: DBCmEx2 "qryMailInGel", "@IdGel", "@IdxNr", -1, IdxNr
                            Case 4: DBCmEx2 "qryMailOutGel", "@IdGel", "@IdxNr", -1, IdxNr
                            End Select
                        End If
                    Else
                        Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                        Case 1: DBCmEx2 "qryMailInGel", "@IdGel", "@IdxNr", -1, IdxNr
                        Case 2: DBCmEx2 "qryMailOutGel", "@IdGel", "@IdxNr", -1, IdxNr
                        Case 3: DBCmEx2 "qryMailInGel", "@IdGel", "@IdxNr", -1, IdxNr
                        Case 4: DBCmEx2 "qryMailOutGel", "@IdGel", "@IdxNr", -1, IdxNr
                        End Select
                    End If
            End Select
        End If
    Next RpRow
    DoEvents
    
    Screen.MousePointer = vbHourglass
    clFen.FenDsk 2
    DoEvents
    
    SUpMa RowNr
    
    clFen.FenDsk 3
    Screen.MousePointer = vbNormal
    DoEvents
End If

DoEvents
Screen.MousePointer = vbNormal

Set clFen = Nothing

Set RpSel = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo0 = Nothing

Set FM = Nothing

Exit Sub

LoErr:
If GlDbg = True Then SErLog Err.Description & " S_MaMa " & Err.Number
Resume Next

End Sub
Public Sub S_MaSe()
On Error GoTo DaErr
'Email-Sendings

Dim IdxNr As Long
Dim MaSiz As Long
