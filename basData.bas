Public Sub S_BuZu4(ByVal SuTyp As Integer)
On Error GoTo SuErr
'Buchung zuordnen

Dim SQL3 As String
Dim IdxNr As Long
Dim PatNr As Long
Dim ReNum As Long
Dim RowNr As Long
Dim SorNr As Long
Dim BuDat As Date
Dim ReStr As String
Dim GuiID As String
Dim ZaStr As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim BuEin As Double
Dim BuAus As Double
Dim BezBe As Double
Dim NeBet As Double
Dim ReBet As Double
Dim GuBet As Double
Dim OpBet As Double
Dim OpBez As Double
Dim NeuOp As Double
Dim AktZa As Integer
Dim FoWär As Integer
Dim BuTyp As Integer
Dim IdGeg As Integer
Dim Kasse As Boolean
Dim ReAbg As Boolean
Dim ReLok As Boolean
Dim Mld1, Tit1 As String
Dim RpCon As XtremeReportControl.ReportControl
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo4 = FM.repCont4
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        RowNr = RpRow.Index
        Set RpCol = RpCls.Find(Buh_ID0)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            IdxNr = RpRow.Record(RpCol.ItemIndex).Value
        Else
            IdxNr = 0
        End If
        Set RpCol = RpCls.Find(Buh_IDA)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BuTyp = RpRow.Record(RpCol.ItemIndex).Value
        Else
            BuTyp = 2
        End If
        Set RpCol = RpCls.Find(Buh_IDB)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            IdGeg = RpRow.Record(RpCol.ItemIndex).Value
        Else
            IdGeg = 0
        End If
        Set RpCol = RpCls.Find(Buh_Datum)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BuDat = CDate(RpRow.Record(RpCol.ItemIndex).Value)
        Else
            BuDat = Date
        End If
        Set RpCol = RpCls.Find(Buh_Einnahme)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                BuEin = Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1)
            Else
                BuEin = 0
            End If
        Else
            BuEin = 0
        End If
        Set RpCol = RpCls.Find(Buh_Ausgabe)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                BuAus = Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1)
            Else
                BuAus = 0
            End If
        Else
            BuAus = 0
        End If
        For AktZa = 1 To UBound(GlGeK)
            If GlGeK(AktZa, 0) = IdGeg Then
                Kasse = CBool(GlGeK(AktZa, 5))
                Exit For
            End If
        Next AktZa
        If Kasse = True Then
            ZaStr = "Kassenzahlung"
        Else
            ZaStr = "Bankzahlung"
        End If
    End If
End If

Set FM = frmBuZuo
Set RpCon = FM.repCont1
Set RpCls = RpCon.Columns
Set RpSel = RpCon.SelectedRows

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then

        If SuTyp = 1 Then
            Set RpCol = RpCls.Find(Adr_ID0)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                PatNr = RpRow.Record(RpCol.ItemIndex).Value
            Else
                PatNr = 0
            End If
        Else
            Set RpCol = RpCls.Find(Rec_Selekt)
            ReAbg = CBool(RpRow.Record(RpCol.ItemIndex).Value)
            Set RpCol = RpCls.Find(Rec_Lock)
            If RpRow.Record(RpCol.ItemIndex).Checked = True Then
                ReLok = True
            Else
                ReLok = False
            End If
            Set RpCol = RpCls.Find(Rec_Wahrung)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                FoWär = RpRow.Record(RpCol.ItemIndex).Value
            Else
                FoWär = 1
            End If
            Set RpCol = RpCls.Find(Rec_RechNr)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                ReStr = RpRow.Record(RpCol.ItemIndex).Value
            Else
                ReStr = vbNullString
            End If
            Set RpCol = RpCls.Find(Rec_ID0)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                PatNr = RpRow.Record(RpCol.ItemIndex).Value
            Else
                PatNr = 0
            End If
            Set RpCol = RpCls.Find(Rec_Betrag)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                ReBet = RpRow.Record(RpCol.ItemIndex).Value
            Else
                ReBet = 0
            End If
            Set RpCol = RpCls.Find(Rec_Bezahlt)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                BezBe = RpRow.Record(RpCol.ItemIndex).Value
            Else
                BezBe = 0
            End If
            Set RpCol = RpCls.Find(Rec_ID1)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                ReNum = RpRow.Record(RpCol.ItemIndex).Value
            Else
                ReNum = 0
            End If
        End If

        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            If SuTyp = 1 Then 'Patienten
                If BuTyp = 2 Then 'Einnahme
                    S_PaGu PatNr, BuEin
                Else
                    If GlBuc = True Then 'einfache Buchhaltung verwenden
                        S_PaGu PatNr, , BuAus
                    Else
                        S_PaGu PatNr, , BuEin
                    End If
                End If
                DoEvents
                DBCmEx2 "qrySimBuZuPa", "@IdPat", "@IdxNr", PatNr, IdxNr
                DoEvents
                SUpBu RowNr
            Else
                If Len(ReStr) > 5 Then 'Bindestrich
                    If BuTyp = 2 Then 'Einnahme
                        If ReLok = False Then
                            GuiID = CreateID("K")
                            
                            OpBet = (ReBet - BezBe)
                            OpBez = (BezBe + BuEin)
                            If BuEin > OpBet Then
                                NeBet = OpBet
                                NeuOp = 0
                                GuBet = BuEin - NeBet 'Guthabenbetrag
                            Else
                                NeBet = BuEin
                                NeuOp = (OpBet - BuEin)
                                GuBet = 0
                            End If

                            If GlTyp < 2 Then
                                SQL3 = "SELECT * FROM dbo.qrySimAbSav WHERE IDR = " & ReNum & " ORDER BY ID3 DESC"
                            Else
                                SQL3 = "SELECT * FROM qrySimAbSav WHERE [IDR] = " & ReNum & " ORDER BY [ID3] DESC;"
                            End If
                            Set RS123 = New ADODB.Recordset
                            With RS123
                                .CursorLocation = adUseClient
                                .Source = SQL3
                                .ActiveConnection = DB1
                                .CursorType = adOpenDynamic
                                .LockType = adLockOptimistic
                                .Open Options:=adCmdText
                            End With
                            If RS123.RecordCount > 0 Then
                                SorNr = RS123.Fields("ID3").Value + 1
                            Else
                                SorNr = 1
                            End If
                            If RS123.Supports(adAddNew) Then
                                RS123.AddNew
                                RS123.Fields("ID0").Value = PatNr
                                RS123.Fields("IDR").Value = ReNum
                                RS123.Fields("ID3").Value = SorNr
                                RS123.Fields("ID1").Value = 6 'Anzahlung
                                RS123.Fields("RechNr").Value = ReStr
                                RS123.Fields("Datum").Value = BuDat
                                RS123.Fields("IDKurz").Value = ZaStr & " am " & BuDat & " : (" & Format$(NeBet, GlWa1) & ")"
                                RS123.Fields("WVBetrag").Value = NeBet
                                RS123.Fields("Währung").Value = FoWär
                                RS123.Fields("Kommentar2").Value = GuiID
                                RS123.Fields("IDM").Value = GlMiA(GlSmI, 2)
                                If ReAbg = True Then RS123.Fields("Gedruckt").Value = -1
                                RS123.Update
                            End If
                            RS123.Close
                            Set RS123 = Nothing
                            DoEvents

                            DBCmEx2 "qrySimReSm3", "@IdBet", "@IdxNr", (BezBe + NeBet), ReNum
                            DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", (BezBe + NeBet), ReNum
                            DBCmEx2 "qrySimOPAn0", "@Betra", "@IdxNr", OpBez, ReNum
                            DBCmEx2 "qrySimOPAn4", "@Betra", "@IdxNr", NeuOp, ReNum
                            DBCmEx4 "qrySimBuZuRe", "@IdPat", "@IdRec", "@IdStr", "@IdxNr", PatNr, ReNum, ReStr, IdxNr
                            If NeuOp <= 0 Then
                                DBCmEx1 "qrySimOPLoR", "@IdxNr", ReNum 'Posten löschen
                            End If
                            DoEvents
                            
                            If GuBet > 0 Then
                                TeTit = "Guthaben hinzufügen"
                                TeMai = "Soll der überschüssige Betrag als Guthaben hinzugefügt werden?"
                                TeInh = "Der Buchungsbetrag von " & Format$(BuEin, GlWa1) & " ist größer als der zu zahlende Betrag von " & Format$(NeBet, GlWa1) & ". Soll dem Patienten dieser Betrag als Guthaben hinzugefügt werden?"
                                TeFus = "Ein vorhandenes Guthaben kann zu einem späteren Zeitpunkt mit einer anderen Rechnnung des Patienten verrechnet werden."
                                SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, False, FM.hwnd
                                If GlMes = 33565 Then
                                    S_PaGu PatNr, GuBet
                                End If
                            End If
        
                            If GlVrz = False Then
                                Set RpSel = RpCo4.SelectedRows
                                If RpSel.Count > 0 Then
                                    Set RpRow = RpSel(0)
                                    RowNr = RpRow.Index
                                    SUpRe RowNr
                                End If
                            Else
                                GlVzA = True
                            End If
                            
                            DoEvents
                            SUpBu RowNr
                        Else
                            SPopu "Rechnung bereits festgeschrieben", "Die markierte Rechnung wurde bereits festgeschrieben und kann daher nicht mehr verändert werden.", IC48_Warning
                        End If
                    Else
                        SPopu "Keine Einnahmebuchung", "Die markierte Buchung ist keine Einnahmebuchung und kann daher nicht zugeordnet werden.", IC48_Warning
                    End If
                Else
                    SPopu "Keine Rechnungsnummer vorhanden", "Die markierte Rechnung enthält noch keine Rechnungsnummer, die Buchung kann nicht zugeordnet werden", IC48_Warning
                End If
            End If
        End If
    End If
End If

Set RpSel = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCon = Nothing
Set RpCo1 = Nothing
Set RpCo4 = Nothing

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BuZu4 " & Err.Number
Resume Next

End Sub
