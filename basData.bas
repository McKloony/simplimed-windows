Private Function S_KaFn(ByRef RST As ADODB.Recordset, ByVal calendarName As String, ByRef calendarId As Integer) As Boolean
    If Not RST.RecordCount = 0 Then
        RST.MoveFirst
        While Not RST.EOF
            If RST.Fields("Ort") = calendarName Then
                calendarId = RST.Fields("ID4")
                S_KaFn = True
            End If
            RST.MoveNext
        Wend
    End If
End Function
Public Function S_KaNa() As String
On Error GoTo FiErr
'Generiert die TSE Klienten ein

Dim SQL3 As String
Dim GesZa As Long
Dim TmStr As String
Dim AktZa As Integer
Dim AktKa As Integer

AktZa = 1
AktKa = 1

If GlTyp < 2 Then
    SQL3 = "SELECT * FROM dbo.qrySimBuBa ORDER BY IDB"
Else
    SQL3 = "SELECT * FROM qrySimBuBa ORDER BY [IDB];"
End If

AktZa = 1

Set RS160 = New ADODB.Recordset 'Geldkonten
With RS160
    .CursorLocation = adUseClient
    .Source = SQL3
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With
GesZa = RS160.RecordCount

If GesZa > 0 Then
    Do
    If RS160.Fields("Kasse").Value <> vbNullString Then
        If CBool(RS160.Fields("Kasse").Value) = True Then
            TmStr = "Kasse" & AktKa
            RS160.Fields("TSEClient").Value = TmStr
            GlGeK(AktZa, 8) = TmStr
            AktKa = AktKa + 1
            Exit Do
        End If
    End If
    AktZa = AktZa + 1
    RS160.MoveNext
    Loop Until RS160.EOF
    RS160.UpdateBatch
    
    S_KaNa = TmStr
End If
RS160.Close
Set RS160 = Nothing

Exit Function

FiErr:
If GlDbg = True Then SErLog Err.Description & " S_KaNa " & Err.Number
Resume Next

End Function
