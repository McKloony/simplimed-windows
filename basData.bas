If RS123.RecordCount > 0 Then
    MaUng = RS123.Fields("Anzahl").Value
End If
RS123.Close
Set RS123 = Nothing
DoEvents

If MaUng > 0 Then
    TrLi3.Nodes("P802").Text = "<TextBlock><Bold>Mitarbeiter</Bold> <Run Foreground='Green' Text='[" & MaUng & "]'/></TextBlock>"
Else
    TrLi3.Nodes("P802").Text = "<TextBlock>Mitarbeiter <Run Foreground='Green' Text='[" & MaUng & "]'/></TextBlock>"
End If

For AktZa = 1 To UBound(GlMiK)
    TmNod = "G" & Format$(AktZa + 900, "000")
    
    Set RS123 = New ADODB.Recordset
    RS123.CursorLocation = adUseClient
    Select Case LiIdx
    Case 1: Set RS123 = DBCmRe3("qryMailInZah", "@IdxNr", "@IdStr", "@IdGel", 0, "o" & Format$(AktZa + 900, "000") & "o", 0)
    Case 2: Set RS123 = DBCmRe3("qryMailOuZah", "@IdxNr", "@IdStr", "@IdGel", 0, "o" & Format$(AktZa + 900, "000") & "o", 0)
    Case 3: Set RS123 = DBCmRe3("qryMailInZah", "@IdxNr", "@IdStr", "@IdGel", 0, "o" & Format$(AktZa + 900, "000") & "o", 0)
