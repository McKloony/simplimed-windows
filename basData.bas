Dim Frage As Integer

Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo6 = FM.repCont6
Set RpCo5 = FM.repCont5
Set RpCls = RpCo6.Columns
Set RpSel = RpCo6.SelectedRows

Tit1 = "Grenzwertzuordnung"

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        Set RpCol = RpCls.Find(Lbl_ID4)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            ParNr = RpRow.Record(RpCol.ItemIndex).Value
        Else
            ParNr = 0
        End If
        
        Set RpCol = RpCls.Find(Lbl_Ident)
        Tidnt = RpRow.Record(RpCol.ItemIndex).Value

        Set RpCol = RpCls.Find(Lbl_Ergebniswert)
        If IsNumeric(RpRow.Record(RpCol.ItemIndex).Value) Then
            ErgWe = RpRow.Record(RpCol.ItemIndex).Value
            If ErgWe >= 0 Then

                Mld1 = "Dem Parameter " & Tidnt & " ist kein Grenzwert zugeordnet!"
                Set RS118 = New ADODB.Recordset
                With RS118 'GoÄ Parameter
                    .CursorLocation = adUseClient
                    .Source = "qryLabLeist2"
                    .ActiveConnection = DB1
                    .CursorType = adOpenForwardOnly
                    .LockType = adLockReadOnly
                    .Open Options:=adCmdTableDirect
                End With
        
                RS118.Filter = "[ID0]=" & ParNr
                If RS118.RecordCount > 0 Then
                    S_LaSet
                    RS118.Filter = adFilterNone
                    RS118.Close
                    Set RS118 = Nothing
                Else
                    RS118.Filter = adFilterNone
                    RS118.Close
                    Set RS118 = Nothing
                    
                    Set RS118 = New ADODB.Recordset
                    With RS118 'GebüH Parameter
                        .CursorLocation = adUseClient
                        .Source = "qryLabLeist1"
                        .ActiveConnection = DB1
                        .CursorType = adOpenForwardOnly
                        .LockType = adLockReadOnly
                        .Open Options:=adCmdTableDirect
                    End With
                    RS118.Filter = "[ID0]=" & ParNr
                    If RS118.RecordCount > 0 Then
                        S_LaSet
                        RS118.Filter = adFilterNone
                        RS118.Close
                        Set RS118 = Nothing
                    Else
                        RS118.Filter = adFilterNone
                        RS118.Close
                        Set RS118 = Nothing
                    End If
                End If
            Else
                Mld1 = "Der von Ihnen eingegebene Wert ist negativ und kann daher nicht interpretiert werden"
                WindowMess Mld1, Dial3, Tit1, FM.hwnd
            End If
        Else
            Mld1 = "Der von Ihnen eingegebene Wert ist keine Zahl. Es kann deshalb kein Grenzwert zugeordnet werden"
            WindowMess Mld1, Dial2, Tit1, FM.hwnd
        End If
    End If
End If

Set RpCls = Nothing
Set RpSel = Nothing
Set RpCo6 = Nothing
Set RpCo5 = Nothing

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_LaEin " & Err.Number
Resume Next

End Sub
