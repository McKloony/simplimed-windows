Public Sub S_MaDet(ByVal IdxNr As Long, Optional ByVal PatNr As Long)
On Error GoTo GrErr
'Öffnet die Patientendetails zum Termin

Dim RpCon As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Dim EmaNr As Long
Dim KatNr As Long
Dim Datu1 As String
Dim Datu2 As String
Dim EmBet As String
Dim EmDat As String
Dim EmZei As String
Dim PaKur As String
Dim PaOrt As String
Dim PaPLZ As String
Dim PaTe1 As String
Dim PaTe2 As String
Dim PaTe4 As String
Dim PaBem As String
Dim TeKom As String
Dim AdGrp As String
Dim ZaZil As Integer
Dim AktPo As Integer
Dim AktTe As Integer
Dim AnzTe As Integer
Dim Sensi As Integer
Dim Geles As Boolean

Set FM = frmKatEM
