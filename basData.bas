Dim TxKtH As XtremeSuiteControls.FlatEdit
Dim TxNrS As XtremeSuiteControls.FlatEdit
Dim TxNrH As XtremeSuiteControls.FlatEdit
Dim TxBeS As XtremeSuiteControls.FlatEdit
Dim TxBeH As XtremeSuiteControls.FlatEdit
Dim TxBaX As XtremeSuiteControls.FlatEdit
Dim TxIdx As XtremeSuiteControls.FlatEdit
Dim CmWar As XtremeSuiteControls.ComboBox
Dim CmSte As XtremeSuiteControls.ComboBox
Dim CmTyp As XtremeSuiteControls.ComboBox
Dim CmBuT As XtremeSuiteControls.ComboBox
Dim CmGek As XtremeSuiteControls.ComboBox
Dim CmMan As XtremeSuiteControls.ComboBox
Dim CmMit As XtremeSuiteControls.ComboBox
Dim ChErl As XtremeSuiteControls.CheckBox
Dim ChSel As XtremeSuiteControls.CheckBox
Dim ChMai As XtremeSuiteControls.CheckBox
Dim ChGru As XtremeSuiteControls.CheckBox
Dim PuBu1 As XtremeSuiteControls.PushButton
Dim UpDo1 As XtremeSuiteControls.UpDown

Set RpCo1 = frmMain.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows

Set FM = frmBuEdit
Set TxIdx = FM.txtIdxNr
Set TxBaX = FM.txtBaIdx
Set TxBuD = FM.txtDatu1
Set TxBuB = FM.txtBuBet
Set TxBuK = FM.txtBuKom
Set TxKtS = FM.txtKonto
Set TxKtH = FM.txtHaben
Set TxNrS = FM.txtKtoNr
Set TxNrH = FM.txtKtoHa
Set TxBeS = FM.txtBezei
Set TxBeH = FM.txtBezHa
Set CmSte = FM.cmbBuStu
Set CmWar = FM.cmbWarun
Set CmTyp = FM.cmbBuTyp
Set CmMan = FM.cmbManda
Set CmMit = FM.cmbMitar
Set CmBuT = FM.cmbBuTex
Set CmGek = FM.cmbGegen
Set ChErl = FM.chkGewEr
Set PuBu1 = FM.btnDatu1
Set UpDo1 = FM.updCont1

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    
    Set RpCol = RpCls.Find(Ban_ID2)
    BaIdx = CLng(RpRow.Record(RpCol.ItemIndex).Value)

    Set RpCol = RpCls.Find(Ban_IDI)
    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
        GlNeB = True 'neue Buchung WICHTIG! hier belassen
        
        IdxWe = CLng(RpRow.Record(RpCol.ItemIndex).Value)
        
        Set RpCol = RpCls.Find(Ban_Ausgabe)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BaAus = LCase(RpRow.Record(RpCol.ItemIndex).Value)
        Else
            BaAus = "ja"
        End If
        Set RpCol = RpCls.Find(Ban_Datum)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BuDat = CDate(RpRow.Record(RpCol.ItemIndex).Value)
        Else
            BuDat = Format$(Date, "dd.mm.yyyy")
        End If
        Set RpCol = RpCls.Find(Ban_IDP)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            ManNr = RpRow.Record(RpCol.ItemIndex).Value
        Else
            ManNr = 0
        End If
        Set RpCol = RpCls.Find(Ban_IDM)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            MitNr = RpRow.Record(RpCol.ItemIndex).Value
        Else
            MitNr = 0
        End If
        Set RpCol = RpCls.Find(Ban_IDB)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            GeKId = RpRow.Record(RpCol.ItemIndex).Value
        Else
            GeKId = 1
        End If
        Set RpCol = RpCls.Find(Ban_KoBetrag)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BaBet = CDbl(RpRow.Record(RpCol.ItemIndex).Value)
        Else
            BaBet = 0
        End If
        Set RpCol = RpCls.Find(Ban_Buchtext)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BuTex = RpRow.Record(RpCol.ItemIndex).Value
        End If
        Set RpCol = RpCls.Find(Ban_IDK)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            KtoNr = RpRow.Record(RpCol.ItemIndex).Value
        End If
        Set RpCol = RpCls.Find(Ban_Konto)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            KtBez = RpRow.Record(RpCol.ItemIndex).Value
        End If
        Set RpCol = RpCls.Find(Ban_Steuer)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            KoStu = RpRow.Record(RpCol.ItemIndex).Value
        End If
        Set RpCol = RpCls.Find(Ban_Ermittlung)
        If LCase(RpRow.Record(RpCol.ItemIndex).Value) = "ja" Then
            Ermit = True
        End If
        Set RpCol = RpCls.Find(Ban_IDKurz)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            UmTex = RpRow.Record(RpCol.ItemIndex).Value
        End If
        Set RpCol = RpCls.Find(Ban_GuiID)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BaGui = RpRow.Record(RpCol.ItemIndex).Value
        Else
            BaGui = CreateID("B")
        End If

        GeTex = BuTex & Space$(1) & UmTex
        If Len(GeTex) > 250 Then
            GeTex = Left$(GeTex, 250)
        End If
        
        MaIdx = SCmX(CmMan, ManNr)
        MiIdx = SCmX(CmMit, MitNr)
        
        If BaBet < 0 Then
            BaBet = Abs(BaBet)
        End If

        If BaAus = "ja" Then
            BuTyp = 0
        Else
            BuTyp = 1
        End If
        
        If GlBuc = True Then 'einfache Buchhaltung verwenden
            For AktKo = 1 To UBound(GlGeK)
                If GeKId = GlGeK(AktKo, 0) Then
                    KtoGe = GlGeK(AktKo, 2)
                    KtBeG = GlGeK(AktKo, 1)
                End If
            Next AktKo
        Else
            For AktKo = 1 To UBound(GlSaK) 'Sachkonten mit Geldkontenzuordnung
                If GeKId = GlSaK(AktKo, 0) Then
                    KtoGe = GlSaK(AktKo, 2)
                    KtBeG = GlSaK(AktKo, 1)
                End If
            Next AktKo
        End If

        KtStG = SBuFo(KtoGe) 'Sachkontenformatierung
        KtoSt = SBuFo(KtoNr) 'Sachkontenformatierung

        If GlBuc = True Then 'einfache Buchhaltung verwenden
            TxKtS.Text = KtoSt & " " & KtBez
            TxKtH.Text = KtStG & " " & KtBeG
            TxNrS.Text = KtoSt
            TxNrH.Text = KtStG
            TxBeS.Text = KtBez
            TxBeH.Text = KtBeG
        Else
            If BuTyp = 0 Then 'Ausgabe
                TxKtS.Text = KtoSt & " " & KtBez
                TxKtH.Text = KtStG & " " & KtBeG
                TxNrS.Text = KtoSt
                TxNrH.Text = KtStG
                TxBeS.Text = KtBez
                TxBeH.Text = KtBeG
            Else
                TxKtS.Text = KtStG & " " & KtBeG
                TxKtH.Text = KtoSt & " " & KtBez
                TxNrS.Text = KtStG
                TxNrH.Text = KtoSt
                TxBeS.Text = KtBeG
                TxBeH.Text = KtBez
            End If
        End If

        With CmGek
            If .ListCount > 0 Then
                If GlBuc = True Then 'einfache Buchhaltung verwenden
                    For AktKo = 1 To UBound(GlGeK)
                        If GeKId = GlGeK(AktKo, 0) Then
                            .ListIndex = AktKo - 1
                        End If
                    Next AktKo
                Else
                    For AktKo = 1 To UBound(GlSaK) 'Sachkonten mit Geldkontenzuordnung
                        If GeKId = GlSaK(AktKo, 0) Then
                            .ListIndex = AktKo - 1
                        End If
                    Next AktKo
                End If
                .Enabled = False
            End If
        End With
        With CmTyp
            .ListIndex = BuTyp
            .Enabled = False
        End With
        With CmMan
            .ListIndex = MaIdx
            .Enabled = False
        End With
        With CmMit
            .ListIndex = MiIdx
            .Enabled = False
        End With
        CmWar.ListIndex = 0
        TxIdx.Text = IdxWe
        TxBaX.Text = BaIdx
        With TxBuD
            .Text = BuDat
            .Enabled = False
        End With
        With TxBuB
            .Text = Format$(BaBet, GlWa1)
            .Enabled = False
        End With
        CmBuT.Text = GeTex
        TxBuK.Text = vbNullString
        PuBu1.Enabled = False
        UpDo1.Enabled = False
        If Ermit = True Then
            ChErl.Value = xtpChecked
        End If
        For AktZa = 1 To UBound(GlStu)
            If CSng(GlStu(AktZa, 1)) = KoStu Then
                CmSte.ListIndex = AktZa - 1
                Exit For
            End If
        Next AktZa

        frmBuEdit.BaGui = BaGui
        frmBuEdit.Show
    End If
End If

Set RpCo1 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BaNeu " & Err.Number
Resume Next

End Sub
