    For Each ViEvt In ViEvs
        If ViEvt.Selected = True Then
            
            Set CaEvt = ViEvt.Event
            TerNr = CaEvt.id
            ReAbg = CaEvt.PrivateFlag
            
            S_TeDe TerNr
            With GlTDt
                PatNr = .PatNr
                ManNr = .TeMan
                MitNr = .TeMit
                GeBet = .GeBet
                TeBtr = .TeBet
                TeDat = Left$(.DaSta, 10)
            End With
            PatNa = S_AdIdx(PatNr, "IDKurz")

            If MitNr < 1 Then
                MitNr = GlMiA(GlSmI, 2)
            End If

            If ManNr < 1 Then
                ManNr = GlMan(GlSMa, 2)
            End If

            If PatNr < 1 Then
                SPopu "Kein Patient zugeordnet", "Diesem Termin wurde kein Patient zugeordnet", IC48_Information
                Exit Sub
            End If

            GlNeB = True 'neue Buchung WICHTIG! hier belassen

            For AktZa = 1 To UBound(GlErK) 'Erlöskonten
                If GlErK(AktZa, 0) = GlSE2 Then
                    TxKto.Text = GlErK(AktZa, 1)
                    TxBez.Text = GlErK(AktZa, 2)
                    TxKnr.Text = GlErK(AktZa, 0)
                    Exit For
                End If
            Next AktZa

            For AktZa = 1 To UBound(GlGeK) 'Geldkonten
                If GlGeK(AktZa, 0) = GlGkK Then 'Standardgeldkonto Kasse
                    CmGek.ListIndex = AktZa - 1
                    Exit For
                End If
            Next AktZa
            
            TmpNr = SCmX(CmBeh, ManNr)
            If TmpNr >= 0 Then
                CmBeh.ListIndex = TmpNr
            Else
                CmBeh.ListIndex = 0
            End If
            
            TmpNr = SCmX(CmMit, MitNr)
            If TmpNr >= 0 Then
                CmMit.ListIndex = TmpNr
            Else
                CmMit.ListIndex = GlSmI - 1
            End If
            
            ChGut.Enabled = True
            CmSte.ListIndex = GlStS - 1
            CmWar.ListIndex = GlStW - 1
            CmTyp.ListIndex = 1
            ChErl.Value = 0
            
            TxDat.Text = TeDat
            TxBuK.Text = vbNullString
            TxDum.Text = TerNr

            If PatNa <> vbNullString Then
                CmBuT.Text = PatNa
            Else
                CmBuT.Text = TeBtr
            End If

            TxBel.Text = S_BuBel(ManNr, Year(TeDat), GlGkK)
            DoEvents

            Set FM = frmBuEdit
            FM.PatNr = PatNr
            FM.Show
            DoEvents
            
            Exit For
        End If
    Next ViEvt

End If

Set CaCol = Nothing

Exit Sub

AdErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TeBu " & Err.Number
Resume Next

End Sub
