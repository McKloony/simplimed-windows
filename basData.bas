                                            DoEvents
                                            KoStu = CSng(RS130.Fields("Steuer").Value)
                                            BetBr = CDbl(RS130.Fields("VK").Value)
                                            If KoStu > 0 And KoStu < 1 Then
                                                KoStu = KoStu * 100
                                            End If
    
                                            BetNe = BaBet
                                            If BetNe > OpBe1 Then
                                                If OpBe2 > 0 Then
                                                    BetBu = BetBr
                                                Else
                                                    BetBu = BetNe / AnzSt
                                                End If
                                            ElseIf BetNe = OpBe1 Then
                                               BetBu = BetBr
                                            Else
                                                If BetNe > 0 Then
                                                    BetBu = BetNe / AnzSt
                                                End If
                                            End If
    
                                            If BetBu > 0 Then
