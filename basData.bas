Next RpItm

RST.MoveNext
Loop Until RST.EOF

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCo6 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TaRec " & Err.Number
Resume Next

