                        TmStr = KaVa1(5, AktZa) & " - " & KaVa1(6, AktZa)
                        CmZif.AddItem TmStr
                        GlEi1(AktZa) = TmStr
                    End If
                End If
            Case 9: 'Artikelliste (1-2)
                If KaVa1(1, AktZa) <> vbNullString Then
                    If KaVa1(2, AktZa) <> vbNullString Then
                        TmStr = KaVa1(1, AktZa) & " - " & KaVa1(2, AktZa)
                        CmZif.AddItem TmStr
                        GlEi1(AktZa) = TmStr
                    End If
                End If
            End Select
        Next AktZa
    End If
    
    If GeZa2 > 0 Then
        KaVa2 = RS113.GetRows
    
        ReDim GlEi2(GeZa2)
        AktZa = 0
