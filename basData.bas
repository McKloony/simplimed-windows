Set RS134 = New ADODB.Recordset 'Termine
With RS134
    .CursorLocation = adUseClient
    .Source = "qryTerNeu"
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdTableDirect
End With
    
frmStatus.Show
DoEvents
frmStatus.Caption = "Terminimport"
Set PrBr1 = frmStatus.prbStat1
Set PrBr2 = frmStatus.prbStat2
Set TxDum = frmStatus.txtDummy

Screen.MousePointer = vbHourglass

If clFil.FilVor(FiNam) = True Then
    TmpSt = clFil.FilCnRe(FiNam) 'UTF-8 Read
    If Len(TmpSt) > 3 Then
        AryZe = Split(TmpSt, vbCrLf) 'Zeilen aufsplitten
        AnzZe = UBound(AryZe)

        PrBr1.Min = 0
        PrBr1.Max = AnzZe
        
        For AktZe = 0 To AnzZe
            TerNr = 0
            TmpZe = AryZe(AktZe)

            If Left$(TmpZe, 13) = "Calendar-Name" Then
                Posit = InStr(1, TmpZe, ":", 1)
                KalNa = Mid$(TmpZe, Posit + 1, Len(TmpZe) - Posit)
                If Len(KalNa) > 200 Then
                    KalNa = Left$(KalNa, 200)
                End If
                For AktKa = 1 To UBound(GlRmu)
                    If KalNa = GlRmu(AktKa, 1) Then
                        KatVo = True
                        Exit For
                    End If
                Next AktKa
                If KatVo = False Then
                    KaGui = CreateID("R")
                    DBCmEx3 "qryKonAdd", "@GuiID", "@IdStr", "@IdMan", KaGui, KalNa, ManNr
                    AktKa = AktKa + 1
                End If
            End If
            
            If KatVo = False Then
                If Left$(TmpZe, 12) = "X-WR-CALNAME" Then
                    Posit = InStr(1, TmpZe, ":", 1)
                    KalNa = Mid$(TmpZe, Posit + 1, Len(TmpZe) - Posit)
                    If Len(KalNa) > 200 Then
                        KalNa = Left$(KalNa, 200)
                    End If
                    For AktKa = 1 To UBound(GlRmu)
                        If KalNa = GlRmu(AktKa, 1) Then
                            KatVo = True
                            Exit For
                        End If
                    Next AktKa
                    If KatVo = False Then
                        KaGui = CreateID("R")
                        DBCmEx3 "qryKonAdd", "@GuiID", "@IdStr", "@IdMan", KaGui, KalNa, ManNr
                    End If
                End If
            End If

            If TmpZe = "BEGIN:VEVENT" Then
                EvSta = True
                TerID = vbNullString
                DaSta = vbNullString
                DaEnd = vbNullString
                DaAdd = vbNullString
                TiSta = vbNullString
                TiEnd = vbNullString
                TiAdd = vbNullString
                TerBe = vbNullString
                TerOr = vbNullString
                TeKom = vbNullString
                AlDay = False
                KatVo = False
                Prior = 2
            End If

            If TmpZe = "END:VEVENT" Then
                EvEnd = True
            End If

            If Left$(TmpZe, 3) = "UID" Then
                Posit = InStr(1, TmpZe, ":", 1)
                TerID = Mid$(TmpZe, Posit + 1, Len(TmpZe) - Posit)
            End If
            
            If Left$(TmpZe, 13) = "X-WR-RELCALID" Then
                Posit = InStr(1, TmpZe, ":", 1)
                TerID = Mid$(TmpZe, Posit + 1, Len(TmpZe) - Posit)
            End If

            If Left$(TmpZe, 7) = "DTSTART" Then
                Posit = InStr(1, TmpZe, ":", 1)
                If Posit > 0 Then
                    DaSta = Mid$(TmpZe, Posit + 7, 2) & "." & Mid$(TmpZe, Posit + 5, 2) & "." & Mid$(TmpZe, Posit + 1, 4)
                    If Len(TmpZe) > 17 Then
                        TiSta = Mid$(TmpZe, Posit + 10, 2) & ":" & Mid$(TmpZe, Posit + 12, 2) & ":" & Mid$(TmpZe, Posit + 14, 2)
                    End If
                Else
                    Posit = InStr(1, TmpZe, ";", 1)
                    If Posit > 0 Then
                        DaSta = Mid$(TmpZe, Posit + 7, 2) & "." & Mid$(TmpZe, Posit + 5, 2) & "." & Mid$(TmpZe, Posit + 1, 4)
                        If Len(TmpZe) > 17 Then
                            TiSta = Mid$(TmpZe, Posit + 10, 2) & ";" & Mid$(TmpZe, Posit + 12, 2) & ";" & Mid$(TmpZe, Posit + 14, 2)
                        End If
                    End If
                End If
            End If

            If Left$(TmpZe, 5) = "DTEND" Then
                Posit = InStr(1, TmpZe, ":", 1)
                If Posit > 0 Then
                    DaEnd = Format$(CDate(Mid$(TmpZe, Posit + 7, 2) & "." & Mid$(TmpZe, Posit + 5, 2) & "." & Mid$(TmpZe, Posit + 1, 4)), "dd.mm.yyyy")
                    If Len(TmpZe) > 15 Then
                        TiEnd = Format$(Mid$(TmpZe, Posit + 10, 2) & ":" & Mid$(TmpZe, Posit + 12, 2) & ":" & Mid$(TmpZe, Posit + 14, 2), "hh:mm:ss")
                    End If
                Else
                    Posit = InStr(1, TmpZe, ";", 1)
                    If Posit > 0 Then
                        DaEnd = Format$(CDate(Mid$(TmpZe, Posit + 7, 2) & "." & Mid$(TmpZe, Posit + 5, 2) & "." & Mid$(TmpZe, Posit + 1, 4)), "dd.mm.yyyy")
                        If Len(TmpZe) > 15 Then
                            TiEnd = Format$(Mid$(TmpZe, Posit + 10, 2) & ";" & Mid$(TmpZe, Posit + 12, 2) & ";" & Mid$(TmpZe, Posit + 14, 2), "hh:mm:ss")
                        End If
                    End If
                End If
            End If

            If Left$(TmpZe, 7) = "DTSTAMP" Then
                Posit = InStr(1, TmpZe, ":", 1)
                If Posit > 0 Then
                    DaAdd = Format$(CDate(Mid$(TmpZe, Posit + 7, 2) & "." & Mid$(TmpZe, Posit + 5, 2) & "." & Mid$(TmpZe, Posit + 1, 4)), "dd.mm.yyyy")
                    If Len(TmpZe) > 17 Then
                        TiAdd = Format$(Mid$(TmpZe, Posit + 10, 2) & ":" & Mid$(TmpZe, Posit + 12, 2) & ":" & Mid$(TmpZe, Posit + 14, 2), "hh:mm:ss")
                    End If
                Else
                    Posit = InStr(1, TmpZe, ";", 1)
                    If Posit > 0 Then
                        DaAdd = Format$(CDate(Mid$(TmpZe, Posit + 7, 2) & "." & Mid$(TmpZe, Posit + 5, 2) & "." & Mid$(TmpZe, Posit + 1, 4)), "dd.mm.yyyy")
                        If Len(TmpZe) > 17 Then
                            TiAdd = Format$(Mid$(TmpZe, Posit + 10, 2) & ";" & Mid$(TmpZe, Posit + 12, 2) & ";" & Mid$(TmpZe, Posit + 14, 2), "hh:mm:ss")
                        End If
                    End If
                End If
            End If
            
            If Left$(TmpZe, 8) = "DURATION" Then
                Posit = InStr(1, TmpZe, ":", 1)
                If Posit > 0 Then
                    DuStr = Mid$(TmpZe, (Posit + 1), (Len(TmpZe) - Posit))
                    PoZei = InStr(1, DuStr, "T", 1)
                    If PoZei > 0 Then
                        PoStu = InStr(PoZei + 1, DuStr, "H", 1)
                        PoMin = InStr(PoZei + 1, DuStr, "M", 1)
                        If PoStu > 0 Then
                            ZaStu = Mid$(DuStr, PoZei + 1, PoStu - PoZei - 1)
                            If PoMin > 0 Then
                                ZaMin = Mid$(DuStr, PoStu + 1, PoMin - PoStu - 1)
                            Else
                                ZaMin = "0"
                            End If
                        ElseIf PoMin > 0 Then
                            ZaMin = Mid$(DuStr, PoZei + 1, PoMin - PoZei - 1)
                            ZaStu = "0"
                        End If
                    Else
                        PoZei = InStr(1, DuStr, "D", 1)
                        If PoZei > 0 Then
                            ZaTag = Val(Mid$(DuStr, 2, (PoZei - 2) + 1))
                            If ZaTag > 0 Then
                                ZaStu = ZaTag * 24
                            Else
                                ZaStu = 0
                            End If
                        Else
                            ZaStu = 0
                        End If
                    End If
                End If
                TiEnd = Format$(DateAdd("n", ZaMin, DateAdd("h", ZaStu, TimeValue(TiSta))), "hh:mm:ss")
                DaEnd = DaSta
            End If
            
            If Left$(TmpZe, 8) = "LOCATION" Then
                Posit = InStr(1, TmpZe, ":", 1)
                TerOr = Mid$(TmpZe, Posit + 1, Len(TmpZe) - Posit)
            End If
            
            If Left$(TmpZe, 14) = "X-LIC-LOCATION" Then
                Posit = InStr(1, TmpZe, ":", 1)
                TerOr = Mid$(TmpZe, Posit + 1, Len(TmpZe) - Posit)
            End If
            
            If Left$(TmpZe, 7) = "SUMMARY" Then
                Posit = InStr(1, TmpZe, ":", 1)
                TerBe = Mid$(TmpZe, Posit + 1, Len(TmpZe) - Posit)
            End If

            If Left$(TmpZe, 8) = "PRIORITY" Then
                Posit = InStr(1, TmpZe, ":", 1)
                TePri = CInt(Mid$(TmpZe, Posit + 1, Len(TmpZe) - Posit))
            End If
            
            If Left$(TmpZe, 11) = "DESCRIPTION" Then
                Posit = InStr(1, TmpZe, ":", 1)
                TeKom = Mid$(TmpZe, Posit + 1, Len(TmpZe) - Posit)
            End If
            
            If Left$(TmpZe, 1) = Chr$(32) Then
                TeKom = TeKom & " " & Mid$(TmpZe, 2, Len(TmpZe) - 1)
            End If
            
            If TeKom <> vbNullString Then
                If Len(TeKom) > 255 Then
                    TeKom = Left$(TeKom, 255)
                End If
            End If

            If EvSta = True And EvEnd = True Then
                If TerBe <> vbNullString Then
                    If Len(TerBe) > 250 Then
                        TerBe = Left$(TerBe, 250)
                    End If
                End If
                If TeKom <> vbNullString Then
                    If Len(TeKom) > 250 Then
                        TeKom = Left$(TeKom, 250)
                    End If
                End If

                If TerID = vbNullString Then
                    TerID = CreateID("T")
                End If

                If DaSta <> vbNullString Then
                    If DaEnd <> vbNullString Then

                        If DaAdd = vbNullString Then DaAdd = Format$(Date, "dd.mm.yyyy")
                        If TiSta = vbNullString Then TiSta = "00:00:00"
                        If TiEnd = vbNullString Then TiEnd = "00:00:00"
                        If TiSta = "00:00:00" Then AlDay = True
                        If TiEnd = "00:00:00" Then AlDay = True
        
                        Select Case TePri
                        Case "0": Prior = 2
                        Case "1": Prior = 1
                        Case "2": Prior = 2
                        End Select
        
                        Set RS115 = New ADODB.Recordset
                        RS115.CursorLocation = adUseClient
                        Set RS115 = DBCmRe1("qryTerGui3", "@IdStr", TerID)
                        If RS115.RecordCount > 0 Then
                            TerNr = RS115.Fields("ID2").Value
                        End If
                        RS115.Close
                        Set RS115 = Nothing
                        DoEvents
        
                        If TerNr > 0 Then
                            RS134.Close
                            Set RS134 = Nothing
                            If GlTyp < 2 Then
                                SQL1 = "SELECT * FROM dbo.qryTerLis WHERE [ID2] = " & TerNr
                            Else
                                SQL1 = "SELECT * FROM qryTerLis WHERE [ID2] = " & TerNr & ";"
                            End If
                            Set RS134 = New ADODB.Recordset
                            With RS134
                                .CursorLocation = adUseClient
                                .Source = SQL1
                                .ActiveConnection = DB1
                                .CursorType = adOpenDynamic
                                .LockType = adLockOptimistic
                                .Open Options:=adCmdText
                            End With
                        Else
                            RS134.AddNew
                        End If

                        If GlTyp < 2 Then
                            RS134.Fields("VonDat").Value = Format$(DaSta, "dd.mm.yyyy") & Chr$(32) & Format$(TiSta, "hh:mm:ss")
                            RS134.Fields("BisDat").Value = Format$(DaEnd, "dd.mm.yyyy") & Chr$(32) & Format$(TiEnd, "hh:mm:ss")
                            RS134.Fields("ZeiVon").Value = Format$(DaSta, "dd.mm.yyyy") & Chr$(32) & Format$(TiSta, "hh:mm:ss")
                            RS134.Fields("ZeiBis").Value = Format$(DaEnd, "dd.mm.yyyy") & Chr$(32) & Format$(TiEnd, "hh:mm:ss")
                            RS134.Fields("Datum").Value = Format$(DaAdd, "dd.mm.yyyy") & Chr$(32) & Format$(TiAdd, "hh:mm:ss")
                        Else
                            RS134.Fields("VonDat").Value = Format$(DaSta, "dd.mm.yyyy")
                            RS134.Fields("BisDat").Value = Format$(DaEnd, "dd.mm.yyyy")
                            RS134.Fields("ZeiVon").Value = Format$(TiSta, "hh:mm:ss")
                            RS134.Fields("ZeiBis").Value = Format$(TiEnd, "hh:mm:ss")
                            RS134.Fields("Datum").Value = Format$(DaAdd, "dd.mm.yyyy")
                        End If
                        RS134.Fields("Selekt").Value = AlDay
                        RS134.Fields("IDKurz").Value = TerBe
                        RS134.Fields("Kommentar").Value = TeKom
                        RS134.Fields("Raum").Value = TerOr
                        RS134.Fields("Priorität").Value = Prior
                        RS134.Fields("Replicated").Value = -1
                        RS134.Fields("IDR").Value = AktKa
                        RS134.Fields("IDP").Value = ManNr
                        RS134.Fields("IDM").Value = MitNr
                        RS134.Fields("IDSer").Value = 5 'Standardtermin
                        If TerNr = 0 Then
                            RS134.Fields("GuiID").Value = TerID
                        End If
                        RS134.Fields("LastModification").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                        RS134.Update
                        DoEvents
                        
                        If TerNr = 0 Then
                            Set RS115 = New ADODB.Recordset
                            RS115.CursorLocation = adUseClient
                            Set RS115 = DBCmRe1("qryTerGui3", "@IdStr", TerID)
                            If RS115.RecordCount > 0 Then
                                TerNr = RS115.Fields("ID2").Value
                            End If
                            RS115.Close
                            Set RS115 = Nothing
                            DoEvents
                        End If
        
                        EvSta = False
                        EvEnd = False
        
                        PrGui = CreateID("P")
                        MitNa = GlMiA(GlSmI, 1)
                        PrStr = "Termin importiert " & DaSta & " " & Format$(TiSta, "hh:mm:")
                        DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", TerNr, PrGui, TerID, Now, Now, PrStr, MitNa
                    End If
                End If
            End If
            
            PrBr1.Value = AktZe
            DoEvents
        Next AktZe
    End If

    '---
            
    If RS134.State = adStateOpen Then
        RS134.Close
        Set RS134 = Nothing
    End If

    If AnzTe > 0 Then
        GlNeK = GlKoX 'Protokolleintrag
        With GlNeK
            .PatNr = GlMan(GlSMa, 2)
            .IdxNr = 0
            .EiDat = Format$(Date, "dd.mm.yyyy")
            .EiZei = TimeValue(Now)
            .EiTyp = 104
            .TeStr = "Termine Importiert - (" & AnzTe & " Termine)"
            .ZiStr = Format$(Now, "hh:mm") & " Uhr"
            .NeuEi = True
            .KeiAk = True
            .Mitar = GlMiA(GlSmI, 2)
        End With
        S_Prot
    End If
End If

Unload frmStatus
Set frmStatus = Nothing
DoEvents

SUpTe True

Screen.MousePointer = vbNormal

Set CoDia = Nothing
Set RpSel = Nothing
Set RpCo1 = Nothing

Set clFil = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TeImT " & Err.Number
Exit Sub

End Sub
Private Function S_TeIn(ByVal ReSt2 As String, AryZe() As String, AryFe() As String, MaNum As Long) As Integer '~~~
On Error GoTo LiErr
'Abrufen der A Recors

Dim AktZe As Long 'Aktuelle Zeile
Dim AnzZe As Long 'Anzahl Zeilen
Dim GesZa As Long
Dim PatNr As Long
Dim PaNum As Long
Dim IdxNr As Long
Dim TerNr As Long
Dim Datu1 As Date
Dim Datu2 As Date
Dim Datu3 As Date
Dim Datu4 As Date
Dim ZeiSt As Date
Dim ZeiEn As Date
Dim NotDa As Date
Dim NotZe As Date
Dim AdrID As String
Dim KuEn1 As String
Dim KuEn2 As String
Dim PaSt1 As String
Dim PaSt2 As String
Dim PaStr As String
Dim KoStr As String
Dim TmBet As String
Dim GuiID As String
Dim DaTim As String
Dim Gesch As String
Dim PrGui As String
Dim PrStr As String
Dim MitNa As String
Dim AktZa As Integer
Dim MaIdx As Integer
Dim GeTyp As Integer
Dim NotVa As Integer
Dim TeNeu As Boolean
Dim FFirm As Variant
Dim FAnre As Variant
Dim FTite As Variant
Dim FName As Variant
Dim FVorn As Variant
Dim FStra As Variant
Dim FPOst As Variant
Dim FOrte As Variant
Dim FLand As Variant
Dim FGebo As Variant
Dim FEmai As Variant
Dim FTeTy As Variant
Dim FTele As Variant
Dim FKomm As Variant

If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
    NotVa = GlMiO(GlSMo, 39) 'Standardmitarbeiter Online-Terminbuchungs Sytem
Else
    NotVa = GlMaO(GlSMa, 25)
End If

If NotVa = 0 Then
    NotVa = 24
End If

If ReSt2 <> vbNullString Then
    Set RS121 = New ADODB.Recordset 'Termine
    With RS121
        .CursorLocation = adUseClient
        .Source = "qryTerNeu"
        .ActiveConnection = DB1
        .CursorType = adOpenKeyset
        .LockType = adLockOptimistic
        .Open Options:=adCmdTableDirect
    End With
    If RS121.Supports(adAddNew) Then
        AryZe = Split(ReSt2, "#") 'Zeilen aufsplitten
        AnzZe = UBound(AryZe) 'Anzahl A Protokolle
        For AktZe = 0 To AnzZe
            AryFe = Split(AryZe(AktZe), ";") 'Felder aufsplitten
            If UBound(AryFe) > 0 Then
                If IsDate(AryFe(2)) Then
                    AdrID = vbNullString
                    KoStr = vbNullString
                    PaSt1 = vbNullString
                    PaSt2 = vbNullString
                    TmBet = vbNullString
                    GuiID = vbNullString
                    PaStr = vbNullString
                    TeNeu = True
                    PatNr = 0
                    PaNum = 0

                    GuiID = AryFe(1)
                    Datu1 = AryFe(2)
                    Datu2 = AryFe(3)
                    ZeiSt = AryFe(4)
                    ZeiEn = AryFe(5)
                    TmBet = Replace(AryFe(6), "_", " ", 1, , 1)
                    FFirm = Replace(AryFe(7), Chr$(34), vbNullString, 1, , 1)
                    FAnre = Replace(AryFe(8), Chr$(34), vbNullString, 1, , 1)
                    FTite = Replace(AryFe(9), Chr$(34), vbNullString, 1, , 1)
                    FName = Replace(AryFe(10), Chr$(34), vbNullString, 1, , 1)
                    FVorn = Replace(AryFe(11), Chr$(34), vbNullString, 1, , 1)
                    FStra = Replace(AryFe(12), Chr$(34), vbNullString, 1, , 1)
                    FPOst = Replace(AryFe(13), Chr$(34), vbNullString, 1, , 1)
                    FOrte = Replace(AryFe(14), Chr$(34), vbNullString, 1, , 1)
                    FLand = Replace(AryFe(15), Chr$(34), vbNullString, 1, , 1)
                    FGebo = Replace(AryFe(16), Chr$(34), vbNullString, 1, , 1)
                    FTele = Replace(AryFe(17), Chr$(34), vbNullString, 1, , 1)
                    FTeTy = Replace(AryFe(18), Chr$(34), vbNullString, 1, , 1)
                    FEmai = Replace(AryFe(19), Chr$(34), vbNullString, 1, , 1)
                    FKomm = Replace(AryFe(20), Chr$(34), vbNullString, 1, , 1)
                    AdrID = AryFe(21)
                    Datu3 = AryFe(22)
                    Datu4 = AryFe(23)

                    If Len(TmBet) > 250 Then
                        TmBet = Left$(TmBet, 250)
                    End If
                    
                    DaTim = Format$(Datu3, "dd.mm.yyyy") & " " & Format$(Datu4, "hh:mm:ss")

                    If AdrID <> vbNullString Then
                        PaNum = CLng(Val(AdrID)) 'Buchung über PIN

                        Set RS148 = New ADODB.Recordset
                        RS148.CursorLocation = adUseClient
                        Set RS148 = DBCmRe1("qrySimAdIdx", "@IdxNr", PaNum)
                        GesZa = RS148.RecordCount
                        If GesZa > 0 Then
                            PatNr = RS148.Fields("ID0").Value
                            FFirm = RS148.Fields("Firma1").Value
                            FAnre = RS148.Fields("Anrede").Value
                            FTite = RS148.Fields("Titel").Value
                            FName = RS148.Fields("Name").Value
                            FVorn = RS148.Fields("Vorname").Value
                            FStra = RS148.Fields("Straße").Value
                            FPOst = RS148.Fields("PLZ").Value
                            FOrte = RS148.Fields("Ort").Value
                            FLand = RS148.Fields("Land").Value
                            FGebo = RS148.Fields("Geboren").Value
                            FTele = RS148.Fields("Telefon1").Value
                            PaStr = RS148.Fields("IDKurz").Value
                        End If
                        RS148.Close
                        Set RS148 = Nothing
                        
                        If FName = vbNullString Then
                            Set RS148 = New ADODB.Recordset
                            RS148.CursorLocation = adUseClient
                            Set RS148 = DBCmRe1("qryAdrIdx", "@IdxNr", PaNum)
                            GesZa = RS148.RecordCount
                            If GesZa > 0 Then
                                PatNr = RS148.Fields("ID0").Value
                                FFirm = RS148.Fields("Firma1").Value
                                FAnre = RS148.Fields("Anrede").Value
                                FTite = RS148.Fields("Titel").Value
                                FName = RS148.Fields("Name").Value
                                FVorn = RS148.Fields("Vorname").Value
                                FStra = RS148.Fields("Straße").Value
                                FPOst = RS148.Fields("PLZ").Value
                                FOrte = RS148.Fields("Ort").Value
                                FLand = RS148.Fields("Land").Value
                                FGebo = RS148.Fields("Geboren").Value
                                FTele = RS148.Fields("Telefon1").Value
                                PaStr = RS148.Fields("IDKurz").Value
                            End If
                            RS148.Close
                            Set RS148 = Nothing
                        End If
                    End If
                        
                    '----
                    
                    If FName <> vbNullString Then
                        If Len(FTite) > 1 Then
                            If Left$(FTite, 3) = "Dr." Then
                                FTite = "Dr."
                            ElseIf Left$(FTite, 3) = "Prof" Then
                                FTite = "Prof."
                            ElseIf Left$(FTite, 3) = "Dip" Then
                                FTite = vbNullString
                            ElseIf FTite = "HP" Or FTite = "Hp" Then
                                FTite = vbNullString
                                If FAnre = "Herrn und Frau" Then
                                    FAnre = "Herrn und Frau HP"
                                ElseIf FAnre Like "*Herr*" Then
                                    FAnre = "Herrn HP"
                                ElseIf FAnre Like "*Frau*" Then
                                    FAnre = "Frau HP"
                                End If
                            End If
                        End If
                        
                        If Len(FGebo) > 1 Then
                            KuEn1 = Mid$(Trim$(FGebo), 1, 10)
                            If Len(FOrte) > 1 Then
                                KuEn2 = Mid$(Trim$(FOrte), 1, 10)
                            Else
                                KuEn2 = vbNullString
                            End If
                        Else
                            If Len(FOrte) > 1 Then
                                KuEn1 = Mid$(Trim$(FOrte), 1, 10)
                                KuEn2 = Mid$(Trim$(FOrte), 1, 10)
                            Else
                                KuEn1 = vbNullString
                                KuEn2 = vbNullString
                            End If
                        End If
    
                        If Len(FName) > 1 Then
                            If Len(KuEn1) > 1 Then
                                PaSt1 = Mid$(Trim$(FName), 1, 25) & ", " & "(" & KuEn1 & ")"
                                PaSt2 = Mid$(Trim$(FName), 1, 25) & ", " & "(" & KuEn2 & ")"
                            Else
                                PaSt1 = Mid$(Trim$(FName), 1, 25)
                                PaSt2 = Mid$(Trim$(FName), 1, 25)
                            End If
                        Else
                            If Len(FFirm) > 1 Then
                                If Len(KuEn1) > 1 Then
                                    PaSt1 = Mid$(Trim$(FFirm), 1, 25) & ", " & "(" & KuEn1 & ")"
                                    PaSt2 = Mid$(Trim$(FFirm), 1, 25) & ", " & "(" & KuEn2 & ")"
                                Else
                                    If Len(FVorn) > 1 Then
                                        If Len(KuEn1) > 1 Then
                                            PaSt1 = Mid$(Trim$(FVorn), 1, 25) & ", " & "(" & KuEn1 & ")"
                                            PaSt2 = Mid$(Trim$(FVorn), 1, 25) & ", " & "(" & KuEn2 & ")"
                                        Else
                                            PaSt1 = Mid$(Trim$(FVorn), 1, 25)
                                            PaSt2 = Mid$(Trim$(FVorn), 1, 25)
                                        End If
                                    End If
                                End If
                            End If
                        End If
                        
                        If Len(FVorn) > 1 Then
                            If Len(FName) > 1 Then
                                If Len(KuEn1) > 1 Then
                                    PaSt1 = Mid$(Trim$(FName), 1, 20) & ", " & Mid$(Trim$(FVorn), 1, 15) & ", " & "(" & KuEn1 & ")"
                                    PaSt2 = Mid$(Trim$(FName), 1, 20) & ", " & Mid$(Trim$(FVorn), 1, 15) & ", " & "(" & KuEn2 & ")"
                                Else
                                    PaSt1 = Mid$(Trim$(FName), 1, 20) & ", " & Mid$(Trim$(FVorn), 1, 15)
                                    PaSt2 = Mid$(Trim$(FName), 1, 20) & ", " & Mid$(Trim$(FVorn), 1, 15)
                                End If
                            Else
                                If Len(FFirm) > 1 Then
                                    If Len(KuEn1) > 1 Then
                                        PaSt1 = Mid$(Trim$(FFirm), 1, 20) & ", " & Mid$(Trim$(FVorn), 1, 15) & ", " & "(" & KuEn1 & ")"
                                        PaSt2 = Mid$(Trim$(FFirm), 1, 20) & ", " & Mid$(Trim$(FVorn), 1, 15) & ", " & "(" & KuEn2 & ")"
                                    Else
                                        PaSt1 = Mid$(Trim$(FFirm), 1, 20) & ", " & Mid$(Trim$(FVorn), 1, 15)
                                        PaSt2 = Mid$(Trim$(FFirm), 1, 20) & ", " & Mid$(Trim$(FVorn), 1, 15)
                                    End If
                                Else
                                    If Len(KuEn1) > 1 Then
                                        PaSt1 = Mid$(Trim$(FVorn), 1, 30) & ", " & "(" & KuEn1 & ")"
                                        PaSt2 = Mid$(Trim$(FVorn), 1, 30) & ", " & "(" & KuEn2 & ")"
                                    Else
                                        PaSt1 = Mid$(Trim$(FVorn), 1, 30)
                                        PaSt2 = Mid$(Trim$(FVorn), 1, 30)
                                    End If
                                End If
                            End If
                        End If
                    End If
                    
                    '----

                    If PatNr = 0 Then
                        If PaSt1 <> vbNullString Then
                            Set RS148 = New ADODB.Recordset
                            RS148.CursorLocation = adUseClient
                            Set RS148 = DBCmRe1("qrySimAdKur", "@IdStr", PaSt1 & "%")
                            GesZa = RS148.RecordCount
                            If GesZa > 0 Then
                                PatNr = RS148.Fields("ID0").Value
                                PaStr = RS149.Fields("IDKurz").Value
                            End If
                            RS148.Close
                            Set RS148 = Nothing
                        End If
                    End If
                    
                    If PatNr = 0 Then
                        If PaSt2 <> vbNullString Then
                            Set RS148 = New ADODB.Recordset
                            RS148.CursorLocation = adUseClient
                            Set RS148 = DBCmRe1("qrySimAdKur", "@IdStr", PaSt2 & "%")
                            GesZa = RS148.RecordCount
                            If GesZa > 0 Then
                                PatNr = RS148.Fields("ID0").Value
                                PaStr = RS149.Fields("IDKurz").Value
                            End If
                            RS148.Close
                            Set RS148 = Nothing
                        End If
                    End If

                    If PatNr = 0 Then
                        If FEmai <> vbNullString Then
                            Set RS149 = New ADODB.Recordset
                            RS149.CursorLocation = adUseClient
                            Set RS149 = DBCmRe2("qrySimAdEm3", "@IdStr", "@IdNam", "%" & FEmai & "%", "%" & FVorn & "%")
                            If RS149.RecordCount > 0 Then
                                PatNr = RS149.Fields("ID0").Value
                                PaStr = RS149.Fields("IDKurz").Value
                            End If
                            RS149.Close
                            Set RS149 = Nothing
                        End If
                    End If

                    If PatNr = 0 Then
                        If FEmai <> vbNullString Then
                            Set RS150 = New ADODB.Recordset
                            RS150.CursorLocation = adUseClient
                            Set RS150 = DBCmRe2("qrySimAdEm4", "@IdStr", "@IdNam", "%" & FEmai & "%", "%" & FVorn & "%")
                            If RS150.RecordCount > 0 Then
                                PatNr = RS150.Fields("ID0").Value
                                PaStr = RS149.Fields("IDKurz").Value
                            End If
                            RS150.Close
                            Set RS150 = Nothing
                        End If
                    End If

                    If FKomm <> vbNullString Then
                        KoStr = SUmw(FKomm)
                    End If
                    
                    If Len(KoStr) > 250 Then
                        KoStr = Left$(KoStr, 250)
                    End If

                    If FAnre <> vbNullString Then
                        If FAnre = "Herrn" Then
                            Gesch = "M"
                            GeTyp = 2
                        ElseIf FAnre = "Frau" Then
                            Gesch = "W"
                            GeTyp = 3
                        Else
                            Gesch = "W"
                            GeTyp = 1
                        End If
                    Else
                        Gesch = "W"
                        GeTyp = 1
                    End If

                    If Format$(ZeiSt, "hh:mm") Like "00:00" Then
                        If Format$(ZeiEn, "hh:mm") Like "00:00" Then
                            TeNeu = False 'Warteliste
                        End If
                    End If

                    Set RS115 = New ADODB.Recordset
                    RS115.CursorLocation = adUseClient
                    Set RS115 = DBCmRe1("qryTerGui3", "@IdStr", GuiID)
                    If RS115.RecordCount > 0 Then
                        TeNeu = False 'Termin bereits in Datenbakn vorhanden
                    End If
                    RS115.Close
                    Set RS115 = Nothing
                    DoEvents

                    If TeNeu = True Then
                        If PaSt1 = vbNullString Then
                            If PaNum > 0 Then
                                PaStr = "PIN: " & Format$(PaNum, "000000") & " " & PaStr
                            End If
                        Else
                            If PaStr = vbNullString Then
                                PaStr = PaSt1
                            End If
                        End If

                        RS121.AddNew
                        If GlTyp < 2 Then
                            RS121.Fields("VonDat").Value = Format$(Datu1, "dd.mm.yyyy") & Chr$(32) & Format$(ZeiSt, "hh:mm:ss")
                            RS121.Fields("BisDat").Value = Format$(Datu2, "dd.mm.yyyy") & Chr$(32) & Format$(ZeiEn, "hh:mm:ss")
                            RS121.Fields("ZeiVon").Value = Format$(Datu1, "dd.mm.yyyy") & Chr$(32) & Format$(ZeiSt, "hh:mm:ss")
                            RS121.Fields("ZeiBis").Value = Format$(Datu2, "dd.mm.yyyy") & Chr$(32) & Format$(ZeiEn, "hh:mm:ss")
                        Else
                            RS121.Fields("VonDat").Value = Format$(Datu1, "dd.mm.yyyy")
                            RS121.Fields("BisDat").Value = Format$(Datu2, "dd.mm.yyyy")
                            RS121.Fields("ZeiVon").Value = Format$(ZeiSt, "hh:mm:ss")
                            RS121.Fields("ZeiBis").Value = Format$(ZeiEn, "hh:mm:ss")
                        End If
                        RS121.Fields("ID0").Value = PatNr
                        RS121.Fields("GuiID").Value = GuiID
                        RS121.Fields("IDKurz").Value = TmBet
                        RS121.Fields("Patient").Value = PaStr
                        RS121.Fields("Kommentar").Value = KoStr
                        RS121.Fields("IDSer").Value = 5
                        RS121.Fields("Geschlecht").Value = GeTyp
                        RS121.Fields("Firma1").Value = FFirm
                        RS121.Fields("Anrede").Value = FAnre
                        If Len(FTite) > 1 Then
                            RS121.Fields("Titel").Value = FTite
                        End If
                        RS121.Fields("Vorname").Value = FVorn
                        RS121.Fields("Name").Value = FName
                        RS121.Fields("Straße").Value = FStra
                        RS121.Fields("PLZ").Value = FPOst
                        RS121.Fields("Ort").Value = FOrte
                        RS121.Fields("Land").Value = FLand
                        RS121.Fields("Telefon1").Value = FTele
                        RS121.Fields("Telefon5").Value = FEmai
                        If FGebo <> vbNullString Then
                            If IsDate(FGebo) = True Then
                                RS121.Fields("Geboren").Value = CDate(FGebo)
                            End If
                        End If
                        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                            RS121.Fields("IDM").Value = MaNum
                            RS121.Fields("IDP").Value = GlMan(GlSMa, 2)
                        Else
                            RS121.Fields("IDM").Value = GlMiA(GlSmI, 2)
                            RS121.Fields("IDP").Value = MaNum
                        End If
                        RS121.Fields("IDR").Value = GlRmu(1, 2)
                        RS121.Fields("Priorität").Value = 2 'Priorität Normal
                        RS121.Fields("OnlTer").Value = 0
                        If GlOTS = True Then 'Online-Terminbuchungs System
                            RS121.Fields("OnlGes").Value = -1 'WICHTIG!
                        End If
                        If PatNr = 0 Then
                            RS121.Fields("Farbtyp").Value = 2
                        Else
                            RS121.Fields("Farbtyp").Value = 3
                        End If
                        If GlTyp < 2 Then
                            RS121.Fields("Datum").Value = Now
                        Else
                            RS121.Fields("Datum").Value = Date
                        End If
                        If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                            RS121.Fields("Replicated").Value = 1
                            RS121.Fields("DAVChange").Value = 1
                            RS121.Fields("LastModification").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                            RS121.Fields("DAVDate").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                        Else
                            RS121.Fields("Replicated").Value = 0
                            RS121.Fields("DAVChange").Value = 0
                        End If
                        NotDa = CDate(DateAdd("h", -NotVa, Datu1 & Chr$(32) & ZeiSt))
                        NotZe = TimeValue(DateAdd("h", -NotVa, Datu1 & Chr$(32) & ZeiSt))
                        RS121.Fields("NotifyValue").Value = NotVa
                        RS121.Fields("NotifySetDate").Value = NotDa
                        RS121.Fields("NotifySetTime").Value = NotDa
                        If GlTeE = True Then 'Email-Termin-Erinnerung
                            RS121.Fields("NotifyStatus").Value = 3 'Senden
                        End If
                        RS121.Update
                        DoEvents
                        
                        Set RS115 = New ADODB.Recordset
                        RS115.CursorLocation = adUseClient
                        Set RS115 = DBCmRe1("qryTerGui3", "@IdStr", GlTeG)
                        If RS115.RecordCount > 0 Then
                            TerNr = RS115.Fields("ID2").Value
                        Else
                            TerNr = 0
                        End If
                        RS115.Close
                        Set RS115 = Nothing

                        PrGui = CreateID("P")
                        MitNa = GlMiA(GlSmI, 1)
                        PrStr = "Onlinetermineabruf"
                        DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", TerNr, PrGui, GuiID, Now, Now, PrStr, MitNa
                                            Else
                        If PatNr > 0 Then
                            If KoStr <> vbNullString Then
                                KoStr = KoStr & " " & TmBet
                            Else
                                KoStr = TmBet
                            End If
                            If Len(KoStr) > 250 Then
                                KoStr = Left$(KoStr, 250)
                            End If
                            If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                                Ter_Edi PatNr, True, MaNum, GlMan(GlSMa, 2) 'Warteliste
                            Else
                                Ter_Edi PatNr, True, GlMiA(GlSmI, 2), MaNum 'Warteliste
                            End If
                            DoEvents
                            DBCmEx2 "qrySimAdWaA", "@IdStr", "@IdxNr", KoStr, PatNr
                            DoEvents
                            P_List "TeDe", 0, 2 'Warteliste aktualisieren
                        End If
                    End If
                    DoEvents

                    If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                        For AktZa = 1 To UBound(GlMiK) 'Alle Mitarbeiter
                            If MaNum = GlMiK(AktZa, 2) Then
                                MaIdx = AktZa
                                Exit For
                            End If
                        Next AktZa
                    Else
                        For AktZa = 1 To UBound(GlMan)
                            If MaNum = GlMan(AktZa, 2) Then
                                MaIdx = AktZa
                                Exit For
                            End If
                        Next AktZa
                    End If

                    With GlSyn
                        .PrTyp = "B" 'Termin Hinzugefügt
                        .DatSt = Format$(Datu1, "dd.mm.yyyy")
                        .DatEn = Format$(Datu2, "dd.mm.yyyy")
                        .ZeiSt = Format$(ZeiSt, "hh:mm:ss")
                        .ZeiEn = Format$(ZeiEn, "hh:mm:ss")
                        .TeBet = vbNullString
                        .GuiID = GuiID
                        .MaIdx = MaIdx
                        .MaNum = MaNum
                        .DaTim = DaTim
                        .GnzTa = 0
                    End With
                    S_TeSy
                End If
            End If
Skip:
        Next AktZe
    End If
    RS121.Close
    Set RS121 = Nothing

    S_TeIn = AnzZe
End If

Exit Function

LiErr:

If GlDbg = True Then
    SPopu "S_TeIn " & Err.Number, Err.Description, IC48_Warning
    SErLog Err.Description & " S_TeIn " & Err.Number & " - " & Err.Source
End If
Resume Next

End Function
Public Sub S_TeKe(ByVal KetNr As Long, ByVal PatNr As Long)
On Error GoTo AdErr
'Terminkette einfügen

Dim IdxNr As Long
Dim ManNr As Long
Dim MitNr As Long
Dim FarWe As Long
Dim Farbe As Long
Dim PaGeb As Date
Dim NotDa As Date
Dim NotZe As Date
Dim DaSta As Date
Dim DaEnd As Date
Dim SQL1 As String
Dim PrStr As String
Dim TmBet As String
Dim PaKur As String
Dim PaFma As String
Dim PaTit As String
Dim PaNam As String
Dim PaVor As String
Dim PaAnr As String
Dim PaTel As String
Dim PaEma As String
Dim PaStr As String
Dim PaPLZ As String
Dim PaOrt As String
Dim PaLan As String
Dim PaBrf As String
Dim MitNa As String
Dim PrGui As String
Dim RmuNr As Integer
Dim AdMin As Integer
Dim Nachl As Integer
Dim TeLen As Integer
Dim AnzPo As Integer
Dim AktTe As Integer
Dim AktZa As Integer
Dim NotVa As Integer
Dim MaIdx As Integer
Dim KeEin As Boolean
Dim Abbru As Boolean
Dim MitOK As Boolean
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow
Dim CaCol As XtremeCalendarControl.CalendarControl
Dim DaPro As XtremeCalendarControl.CalendarDataProvider
Dim CaLbs As XtremeCalendarControl.CalendarEventLabels
Dim CaLbl As XtremeCalendarControl.CalendarEventLabel

Set FM = frmKetten
Set RpCo5 = FM.repCont5
Set RpRws = RpCo5.Rows
Set RpCls = RpCo5.Columns

Set CaCol = frmMain.calCont1
Set DaPro = CaCol.DataProvider
Set CaLbs = DaPro.LabelList

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qryTerNeu"
Else
    SQL1 = "SELECT * FROM qryTerNeu;"
End If

If GlDay = "00:00:00" Then
    SPopu "Fehlende Startzeit", "Es wurde keine Terminzelle markiert, an der die Terminkette starten soll!", IC48_Warning
    Exit Sub
End If

AnzPo = RpRws.Count

If AnzPo > 0 Then
    For Each RpRow In RpRws
        If RpRow.GroupRow = False Then
            If IsNull(RpRow.Record(Ket_Fakto).Value) Then
                SPopu "Fehlender Mitarbeiter", "Einem Termin der Terminkette ist kein Mitarbeiter zugeordnet", IC48_Warning
                Abbru = True
                Exit For
            End If
            If RpRow.Record(Ket_Fakto).Value = vbNullString Then
                SPopu "Fehlender Mitarbeiter", "Einem Termin der Terminkette ist kein Mitarbeiter zugeordnet", IC48_Warning
                Abbru = True
                Exit For
            End If
            If RpRow.Record(Ket_Fakto).Value = 0 Then
                SPopu "Falscher Mitarbeiter", "Einem Termin der Terminkette ist ein falscher Mitarbeiter zugeordnet", IC48_Warning
                Abbru = True
                Exit For
            End If
            If IsNull(RpRow.Record(Ket_Anz).Value) Then
                SPopu "Fehlende Raumzuordnung", "Einem Termin der Terminkette ist kein Raum zugeordnet", IC48_Warning
                Abbru = True
                Exit For
            End If
            If RpRow.Record(Ket_Anz).Value = vbNullString Then
                SPopu "Fehlende Raumzuordnung", "Einem Termin der Terminkette ist kein Raum zugeordnet", IC48_Warning
                Abbru = True
                Exit For
            End If
            If RpRow.Record(Ket_Preis).Value = vbNullString Then
                SPopu "Fehlende Terminlänge", "Einem Termin der Terminkette hat keine Terminlänge", IC48_Warning
                Abbru = True
                Exit For
            End If
            If RpRow.Record(Ket_Preis).Value = 0 Then
                SPopu "Fehlende Terminlänge", "Einem Termin der Terminkette hat keine Terminlänge", IC48_Warning
                Abbru = True
                Exit For
            End If
        End If
    Next RpRow
    
    If Abbru = True Then
        Exit Sub
    End If
    
    GlTrM = False 'Terminbearbeitung direkt im Kalender
    GlTrB = False 'Terminbearbeitung direkt im Kalender

    Screen.MousePointer = vbHourglass
    DoEvents

    Set RS137 = New ADODB.Recordset
    With RS137
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With
    If RS137.Supports(adAddNew) = True Then
        If PatNr > 0 Then
            S_AdDe PatNr 'Adressendetails
            With GlADt
                PaKur = .AdKur
                PaFma = .AdFir
                PaNam = .AdNam
                PaVor = .AdVor
                PaAnr = .AdAnr
                PaTit = .AdTit
                PaStr = .AdStr
                PaPLZ = .AdPLZ
                PaOrt = .AdOrt
                PaLan = .AdLan
                PaTel = .AdTe1
                PaEma = .AdTe5
                PaGeb = .AdGeb
                PaBrf = .AdBrf
            End With
        End If

        For Each RpRow In RpRws
            If RpRow.GroupRow = False Then
                MitOK = False
                KeEin = CBool(RpRow.Record(Ket_Selekt).Checked)
                If KeEin = True Then
                    FarWe = 0
                    MitNr = 0
                    AktTe = AktTe + 1
                    GlTeG = CreateID("T")
                    If RpRow.Record(Ket_ID0).Value <> vbNullString Then
                        IdxNr = RpRow.Record(Ket_ID0).Value
                    Else
                        IdxNr = 0
                    End If
                    If RpRow.Record(Ket_Anz).Value <> vbNullString Then
                        If RpRow.Record(Ket_Anz).Value = 0 Then
                            RmuNr = 1
                        Else
                            RmuNr = RpRow.Record(Ket_Anz).Value
                        End If
                    Else
                        RmuNr = 1
                    End If
                    If RpRow.Record(Ket_Fakto).Value <> vbNullString Then
                        MitNr = RpRow.Record(Ket_Fakto).Value
                    Else
                        MitNr = 0
                    End If
                    If RpRow.Record(Ket_IDKurz).Value <> vbNullString Then
                        TmBet = RpRow.Record(Ket_IDKurz).Value
                    Else
                        TmBet = vbNullString
                    End If
                    If RpRow.Record(Ket_Preis).Value <> vbNullString Then
                        TeLen = Left$(RpRow.Record(Ket_Preis).Value, 3)
                    Else
                        TeLen = 1
                    End If
                    For AktZa = 1 To UBound(GlBtr)
                        If IdxNr = GlBtr(AktZa, 0) Then
                            FarWe = GlBtr(AktZa, 4)
                            Exit For
                        End If
                    Next AktZa
                    If MitNr > 0 Then
                        For AktZa = 1 To UBound(GlMiT)
                            If MitNr = GlMiT(AktZa, 2) Then
                                ManNr = GlMiT(AktZa, 7)
                                NotVa = GlMiT(AktZa, 39)
                                NotDa = CDate(DateAdd("h", -NotVa, GlDay))
                                NotZe = TimeValue(DateAdd("h", -NotVa, GlDay))
                                MitOK = True
                                Exit For
                            End If
                        Next AktZa
                    End If
                    If MitOK = False Then
                        MitNr = GlMiT(GlSMo, 2) 'Standardmitarbeiter Online-Terminbuchungs Sytem
                        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                            ManNr = GlMiT(GlSMo, 7)
                            NotVa = GlMiT(GlSMo, 39) 'Standardmitarbeiter Online-Terminbuchungs Sytem
                        Else
                            ManNr = GlMan(GlSMa, 2) 'Standardmandant
                            NotVa = GlMaT(GlSMa, 25)
                        End If
                        NotDa = CDate(DateAdd("h", -NotVa, GlDay))
                        NotZe = TimeValue(DateAdd("h", -NotVa, GlDay))
                    End If
                    If NotVa = 0 Then
                        NotVa = 24
                    End If
                    For AktZa = 1 To UBound(GlMaT)
                        If ManNr = GlMaT(AktZa, 2) Then
                            MaIdx = AktZa
                            Exit For
                        End If
                    Next AktZa
                    If FarWe > 0 Then 'Farbwert aus Terminbetreffs
                        For Each CaLbl In CaLbs
                            If CaLbl.Color = FarWe Then
                                Farbe = CaLbl.LabelID
                                Exit For
                            End If
                        Next CaLbl
                    End If
    
                    If AktTe = 1 Then
                        DaSta = GlDay
                        DaEnd = DateAdd("n", TeLen, GlDay)
                    Else
                        If Nachl > 0 Then
                            DaSta = DateAdd("n", Nachl, DaEnd)
                        Else
                            DaSta = DaEnd
                        End If
                        DaEnd = DateAdd("n", TeLen, DaSta)
                    End If
    
                    If RpRow.Record(Ket_Zeit).Value <> vbNullString Then
                        Nachl = Left$(RpRow.Record(Ket_Zeit).Value, 3)
                    Else
                        Nachl = 0
                    End If
                    AdMin = AdMin + (TeLen + Nachl)
    
                    RS137.AddNew
                    RS137.Fields("ID0").Value = PatNr
                    RS137.Fields("IDSer").Value = 5 'Standradtermin
                    RS137.Fields("IDR").Value = RmuNr
                    RS137.Fields("IDP").Value = ManNr
                    RS137.Fields("IDM").Value = MitNr
                    RS137.Fields("IDKurz").Value = TmBet
                    RS137.Fields("Farbe").Value = Farbe
                    If GlTyp < 2 Then
                        RS137.Fields("VonDat").Value = DaSta
                        RS137.Fields("BisDat").Value = DaEnd
                        RS137.Fields("ZeiVon").Value = DaSta
                        RS137.Fields("ZeiBis").Value = DaEnd
                    Else
                        RS137.Fields("VonDat").Value = Format$(DaSta, "dd.mm.yyyy")
                        RS137.Fields("BisDat").Value = Format$(DaEnd, "dd.mm.yyyy")
                        RS137.Fields("ZeiVon").Value = Format$(DaSta, "hh:mm")
                        RS137.Fields("ZeiBis").Value = Format$(DaEnd, "hh:mm")
                    End If
                    RS137.Fields("Farbtyp").Value = 3
                    RS137.Fields("Erinnerung").Value = GlTAl 'Terminerinnerung im Kalender anzeigen
                    RS137.Fields("Selekt").Value = False 'Ganztagstermin
                    RS137.Fields("Priorität").Value = 2
                    RS137.Fields("Vorwarn").Value = 5
                    RS137.Fields("GuiID").Value = GlTeG 'Termin GuiID
                    RS137.Fields("Datum").Value = Date
                    RS137.Fields("Change").Value = Date
                    RS137.Fields("Aufgabe").Value = 0
                    If PatNr > 0 Then
                        RS137.Fields("Patient").Value = PaKur
                        RS137.Fields("Firma1").Value = PaFma
                        RS137.Fields("Anrede").Value = PaAnr
                        RS137.Fields("Titel").Value = PaTit
                        RS137.Fields("Vorname").Value = PaVor
                        RS137.Fields("Name").Value = PaNam
                        RS137.Fields("Straße").Value = PaStr
                        RS137.Fields("PLZ").Value = PaPLZ
                        RS137.Fields("Ort").Value = PaOrt
                        RS137.Fields("Land").Value = PaLan
                        RS137.Fields("Telefon1").Value = PaTel
                        RS137.Fields("Telefon5").Value = PaEma
                        RS137.Fields("Geboren").Value = PaGeb
                        RS137.Fields("Briefanrede").Value = PaBrf
                    End If
                    If NotVa > 0 Then
                        RS137.Fields("NotifyValue").Value = NotVa
                        RS137.Fields("NotifySetDate").Value = NotDa
                        RS137.Fields("NotifySetTime").Value = NotDa
                    End If
                    If GlTeE = True Then 'Email-Termin-Erinnerung
                        RS137.Fields("NotifyStatus").Value = 3 'Senden
                    End If
                    If GlOTS = True Then 'Online-Terminbuchungs System
                        RS137.Fields("OnlGes").Value = 0
                    End If
                    If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                        RS137.Fields("Replicated").Value = 1
                        RS137.Fields("DAVChange").Value = 1
                        RS137.Fields("LastModification").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                        RS137.Fields("DAVDate").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                    Else
                        RS137.Fields("Replicated").Value = 0
                        RS137.Fields("DAVChange").Value = 0
                    End If
                    RS137.Update
                    DoEvents
                    
                    Set RS115 = New ADODB.Recordset
                    RS115.CursorLocation = adUseClient
                    Set RS115 = DBCmRe1("qryTerGui3", "@IdStr", GlTeG)
                    If RS115.RecordCount > 0 Then
                        GlTem = RS115.Fields("ID2").Value
                    Else
                        GlTem = 0
                    End If
                    RS115.Close
                    Set RS115 = Nothing
                    
                    DBCmEx2 "qryTerMas", "@IdMas", "@IdxNr", GlTem, GlTem
                    DoEvents
                    DBCmEx3 "qryTerAnz", "@TeAnz", "@TeAkt", "@IdxNr", AnzPo, AktTe, GlTem
                    DoEvents
    
                    If GlOTS = True Then 'Online-Terminbuchungs System
                        If GlDay >= Date Then
                            With GlSyn
                                .PrTyp = "B" 'Termin Hinzugefügt
                                .DatSt = Format$(GlDay, "dd.mm.yyyy")
                                .DatEn = Format$(GlDay, "dd.mm.yyyy")
                                .ZeiSt = Format$(GlDay, "hh:mm:ss")
                                .ZeiEn = Format$(GlDay, "hh:mm:ss")
                                .TeBet = vbNullString
                                .GuiID = GlTeG 'Termin GuiID
                                .MaIdx = MaIdx
                                .GnzTa = False
                                If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                                    .MaNum = MitNr
                                Else
                                    .MaNum = ManNr
                                End If
                            End With
                            S_TeSy
                            DoEvents
                        End If
                    End If
                    
                    PrGui = CreateID("P")
                    MitNa = GlMiA(GlSmI, 1)
                    PrStr = "Terminkette wurde eingefügt"
                    DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", GlTem, PrGui, GlTeG, Now, Now, PrStr, MitNa
                    DoEvents
                End If
            End If
        Next RpRow
    End If
    RS137.Close
    Set RS137 = Nothing
    
    DoEvents
    Screen.MousePointer = vbNormal
Else
    SPopu "Fehlende Termine", "Die Terminkette besitzt noch keine Termine!", IC48_Warning
End If

Unload frmKetten
DoEvents

DoEvents
S_TeLi
DoEvents
SUpTe
DoEvents

Exit Sub

AdErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TeKe " & Err.Number
Resume Next

End Sub
Public Sub S_TeKo(ByVal ClEin As Boolean, Optional ByVal TeAus As Boolean, Optional ByVal HitTy As Boolean = False)
On Error GoTo AdErr
'Kopiert Termine

Dim TmpZe As Date
Dim DaSta As Date
Dim DaEnd As Date
Dim ZeSta As Date
Dim ZeEnd As Date
Dim DayFi As Date
Dim DayLa As Date
Dim NotDa As Date
Dim NotZe As Date
Dim IdxNr As Long
Dim RowNr As Long
Dim ManNr As Long
Dim MitNr As Long
Dim RauNr As Long
Dim MasTe As Long
Dim SQL1 As String
Dim ZeStr As String
Dim TeBet As String
Dim PrStr As String
Dim PrGui As String
Dim MitNa As String
Dim GesBe As Single
Dim MaIdx As Integer
Dim AnzPo As Integer
Dim AktZa As Integer
Dim RaIdx As Integer
Dim MiDif As Integer
Dim ZeiRa As Integer
Dim RzAnz As Integer
Dim NotSt As Integer
Dim DayGa As Boolean
Dim SelOK As Boolean
Dim MiVor As Boolean
Dim MaVor As Boolean
Dim DaVor As Boolean
Dim NotVa As Integer
Dim CaCol As XtremeCalendarControl.CalendarControl
Dim CaEvt As XtremeCalendarControl.CalendarEvent
Dim CaEvs As XtremeCalendarControl.CalendarEvents
Dim CaHit As XtremeCalendarControl.CalendarHitTestInfo
Dim ViEvt As XtremeCalendarControl.CalendarViewEvent
Dim ViEvs As XtremeCalendarControl.CalendarViewEvents
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set CaCol = FM.calCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows

GlTrM = False 'Terminbearbeitung direkt im Kalender
GlTrB = False 'Terminbearbeitung direkt im Kalender

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qryTerNeu"
Else
    SQL1 = "SELECT * FROM qryTerNeu;"
End If

Screen.MousePointer = vbHourglass

If ClEin = True Then 'aus Array einfügen
    Set ViEvs = CaCol.ActiveView.GetSelectedEvents
    AnzPo = ViEvs.Count
    If AnzPo > 0 Then
        For Each ViEvt In ViEvs
            If ViEvt.Selected = True Then
                Set CaEvt = ViEvt.Event
                DaSta = CaEvt.StartTime
                ZeSta = CaEvt.StartTime
                DaEnd = CaEvt.EndTime
                ZeEnd = CaEvt.EndTime
                DaVor = True
                SelOK = True
                Exit For
            End If
        Next ViEvt
    End If
    Select Case GlBut
    Case RibTab_Ter_Kalend:
        If DaVor = False Then
            Set CaHit = CaCol.ActiveView.HitTest
            If CaHit.ViewEvent Is Nothing Then
                CaCol.ActiveView.GetSelection DayFi, DayLa, DayGa
                DaSta = DayFi
                ZeSta = DayFi
                DaEnd = DayLa
                ZeEnd = DayLa
                SelOK = True
            Else
                DaSta = CaHit.ViewEvent.Event.StartTime
                ZeSta = CaHit.ViewEvent.Event.StartTime
                DaEnd = CaHit.ViewEvent.Event.EndTime
                ZeEnd = CaHit.ViewEvent.Event.EndTime
                DayGa = CaHit.ViewEvent.Event.AllDayEvent
                CaHit.ViewEvent.Selected = False
                SelOK = False
            End If
        End If
        RauNr = GlClp(1, 3)
        MitNr = GlClp(1, 23)
        ManNr = GlClp(1, 18)
        MaIdx = GlSmI
    Case RibTab_Ter_Raeume:
        Set CaHit = CaCol.ActiveView.HitTest
        RaIdx = GlCaR + 1 'Kalendarresourceindex
        If DaVor = False Then
            If CaHit.ViewEvent Is Nothing Then
                CaCol.ActiveView.GetSelection DayFi, DayLa, DayGa
                DaSta = DayFi
                ZeSta = DayFi
                DaEnd = DayLa
                ZeEnd = DayLa
                SelOK = True
            Else
                DaSta = CaHit.ViewEvent.Event.StartTime
                ZeSta = CaHit.ViewEvent.Event.StartTime
                DaEnd = CaHit.ViewEvent.Event.EndTime
                ZeEnd = CaHit.ViewEvent.Event.EndTime
                DayGa = CaHit.ViewEvent.Event.AllDayEvent
                CaHit.ViewEvent.Selected = False
                SelOK = False
            End If
        End If
        RauNr = GlRmu(GlCaR + 1, 2)
        MitNr = GlClp(1, 23)
        ManNr = GlClp(1, 18)
        MaIdx = GlSmI
    Case RibTab_Ter_Mitarb:
        Set CaHit = CaCol.ActiveView.HitTest
        MaIdx = GlCaR + 1 'Kalendarresourceindex
        If DaVor = False Then
            If CaHit.ViewEvent Is Nothing Then
                CaCol.ActiveView.GetSelection DayFi, DayLa, DayGa
                DaSta = DayFi
                ZeSta = DayFi
                DaEnd = DayLa
                ZeEnd = DayLa
                SelOK = True
            Else
                DaSta = CaHit.ViewEvent.Event.StartTime
                ZeSta = CaHit.ViewEvent.Event.StartTime
                DaEnd = CaHit.ViewEvent.Event.EndTime
                ZeEnd = CaHit.ViewEvent.Event.EndTime
                DayGa = CaHit.ViewEvent.Event.AllDayEvent
                CaHit.ViewEvent.Selected = False
                SelOK = False
            End If
        End If
        RauNr = GlClp(1, 3)
        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
            MitNr = GlMiT(MaIdx, 2)
            ManNr = GlClp(1, 18)
        Else
            MitNr = GlClp(1, 23)
            ManNr = GlMaT(MaIdx, 2)
        End If
        GlCaR = 0
    End Select
    If ZeSta = "00:00:00" Then
        ZeSta = Format$(GlClp(1, 20), "hh:mm:ss")
    End If

    If GlMiA(MaIdx, 8) > 0 Then 'Hier alle aktiven Mitarbeiter
        ZeiRa = GlMiA(MaIdx, 8)
    Else
        ZeiRa = GlZeR 'Zeitrasterindex
    End If
    
    MiDif = GlTku(ZeiRa, 2)
    DoEvents
    SRast ZeiRa
    DoEvents

    ZeStr = Format$(ZeSta, "hh:mm")
    For AktZa = 1 To UBound(GlRas) 'Zeitrasterstartzeiten
        If TimeValue(GlRas(AktZa)) <= TimeValue(ZeStr) Then
            ZeSta = Format$(DaSta, "dd.mm.yyyy") & Space(1) & TimeValue(GlRas(AktZa))
        End If
    Next AktZa

    If GlSSt = True Then 'Starre Termintaktung
        ZeEnd = Format$(DaSta, "dd.mm.yyyy") & Space(1) & DateAdd("n", MiDif, ZeSta)
        TmpZe = DateAdd("n", GlClp(1, 5), ZeSta)
        If TimeValue(TmpZe) > TimeValue(ZeEnd) Then
            ZeEnd = Format$(DaSta, "dd.mm.yyyy") & Space(1) & TimeValue(TmpZe)
            DaEnd = Format$(DaSta, "dd.mm.yyyy") & Space(1) & TimeValue(TmpZe)
        End If
    Else
        ZeEnd = Format$(DaSta, "dd.mm.yyyy") & Space(1) & TimeValue(DateAdd("n", GlClp(1, 5), ZeSta))
        DaEnd = Format$(DaSta, "dd.mm.yyyy") & Space(1) & TimeValue(DateAdd("n", GlClp(1, 5), ZeSta))
    End If

    If SelOK = True Then
        If ClKop = True Then 'Cliparry kopiert
            If GlClp(1, 41) <> vbNullString Then
                NotVa = GlClp(1, 41)
            Else
                If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                    NotVa = GlMiT(GlSMo, 39) 'Standardmitarbeiter Online-Terminbuchungs Sytem
                Else
                    NotVa = GlMaT(GlSMa, 25)
                End If
            End If
            If NotVa = 0 Then
                NotVa = 24
            End If
            NotDa = CDate(DateAdd("h", -NotVa, DaSta))
            NotZe = CDate(DateAdd("h", -NotVa, DaSta))
            GlTeG = CreateID("T")
            
            For AktZa = 1 To UBound(GlMiT) 'Aktive Mitarbeiter + Terminspalte
                If MitNr = GlMiT(AktZa, 2) Then
                    MaIdx = AktZa
                    MiVor = True
                    Exit For
                End If
            Next AktZa
        
            For AktZa = 1 To UBound(GlMaT)
                If ManNr = GlMaT(AktZa, 2) Then
                    MaIdx = AktZa
                    MaVor = True
                    Exit For
                End If
            Next AktZa

            If MiVor = False Then
                MitNr = GlMiA(GlSmI, 2)
            End If
            If MaVor = False Then
                ManNr = GlMaT(GlSMa, 2)
            End If

            Set RS137 = New ADODB.Recordset
            With RS137
                .CursorLocation = adUseClient
                .Source = SQL1
                .ActiveConnection = DB1
                .CursorType = adOpenDynamic
                .LockType = adLockOptimistic
                .Open Options:=adCmdText
            End With

            If RS137.Supports(adAddNew) = True Then
                RS137.AddNew
                RS137.Fields("ID0").Value = GlClp(1, 1)
                RS137.Fields("IDSer").Value = GlClp(1, 2)
                Select Case GlBut
                Case RibTab_Ter_Kalend:
                            RS137.Fields("IDR").Value = RauNr
                            RS137.Fields("IDP").Value = ManNr
                            RS137.Fields("IDM").Value = MitNr
                Case RibTab_Ter_Raeume:
                            RS137.Fields("IDR").Value = RauNr
                            RS137.Fields("IDP").Value = ManNr
                            RS137.Fields("IDM").Value = MitNr
                Case RibTab_Ter_Mitarb:
                            RS137.Fields("IDR").Value = RauNr
                            RS137.Fields("IDM").Value = MitNr
                            RS137.Fields("IDP").Value = ManNr
                End Select
                MasTe = GlClp(1, 21)
                GesBe = GlClp(1, 26)
                RzAnz = GlClp(1, 27)
                RS137.Fields("VonDat").Value = DaSta
                RS137.Fields("BisDat").Value = DaEnd
                RS137.Fields("ZeiVon").Value = ZeSta
                RS137.Fields("ZeiBis").Value = ZeEnd
                RS137.Fields("IDKurz").Value = GlClp(1, 6)
                RS137.Fields("Patient").Value = GlClp(1, 7)
                RS137.Fields("Raum").Value = GlClp(1, 8)
                RS137.Fields("Farbe").Value = GlClp(1, 9)
                RS137.Fields("Farbtyp").Value = GlClp(1, 10)
                RS137.Fields("Erinnerung").Value = GlClp(1, 11)
                RS137.Fields("Selekt").Value = DayGa
                RS137.Fields("Erledigt").Value = GlClp(1, 14)
                RS137.Fields("Priorität").Value = GlClp(1, 15)
                RS137.Fields("Vorwarn").Value = GlClp(1, 16)
                RS137.Fields("Kommentar").Value = GlClp(1, 17)
                RS137.Fields("Datei").Value = GlClp(1, 19)
                RS137.Fields("MasTer").Value = MasTe
                RS137.Fields("Geschlecht").Value = GlClp(1, 24)
                RS137.Fields("Wiederholung").Value = GlClp(1, 25)
                RS137.Fields("GesBetrag").Value = GesBe
                RS137.Fields("GuiID").Value = GlTeG 'Termin GuiID
                RS137.Fields("Datum").Value = Now
                RS137.Fields("Change").Value = Now
                If DaSta >= Now Then
                    RS137.Fields("Aufgabe").Value = 0
                Else
                    RS137.Fields("Aufgabe").Value = GlClp(1, 13)
                End If
                If GlOTS = True Then 'Online-Terminbuchungs System
                    RS137.Fields("OnlGes").Value = 0
                End If
                If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                    RS137.Fields("Replicated").Value = 1
                    RS137.Fields("DAVChange").Value = 1
                    RS137.Fields("LastModification").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                    RS137.Fields("DAVDate").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                Else
                    RS137.Fields("Replicated").Value = 0
                    RS137.Fields("DAVChange").Value = 0
                End If
                RS137.Fields("Firma1").Value = GlClp(1, 28)
                RS137.Fields("Anrede").Value = GlClp(1, 29)
                RS137.Fields("Titel").Value = GlClp(1, 30)
                RS137.Fields("Vorname").Value = GlClp(1, 31)
                RS137.Fields("Name").Value = GlClp(1, 32)
                RS137.Fields("Straße").Value = GlClp(1, 33)
                RS137.Fields("PLZ").Value = GlClp(1, 34)
                RS137.Fields("Ort").Value = GlClp(1, 35)
                RS137.Fields("Land").Value = GlClp(1, 36)
                RS137.Fields("Telefon1").Value = GlClp(1, 37)
                RS137.Fields("Telefon5").Value = GlClp(1, 38)
                RS137.Fields("Geboren").Value = GlClp(1, 39)
                RS137.Fields("Briefanrede").Value = GlClp(1, 40)
                RS137.Fields("NotifyValue").Value = NotVa
                RS137.Fields("NotifySetDate").Value = NotDa
                RS137.Fields("NotifySetTime").Value = NotDa
                If GlTeE = True Then 'Email-Termin-Erinnerung
                    If NotDa >= Now Then
                        NotSt = 3 'Senden
                    Else
                        NotSt = 1 'nicht Senden
                    End If
                    RS137.Fields("NotifyStatus").Value = NotSt
                End If
                RS137.Update
            End If
            RS137.Close
            Set RS137 = Nothing
            
            Set RS115 = New ADODB.Recordset
            RS115.CursorLocation = adUseClient
            Set RS115 = DBCmRe1("qryTerGui3", "@IdStr", GlTeG)
            If RS115.RecordCount > 0 Then
                GlTem = RS115.Fields("ID2").Value
            Else
                GlTem = 0
            End If
            RS115.Close
            Set RS115 = Nothing

            DoEvents
            DBCmEx2 "qryAnKa1j", "@IdxNr", "@TerNr", GlClp(1, 0), GlTem
            DoEvents

            If GesBe > 0 Then
                Ter_Akt GlTem, MasTe 'Terminpreise aktualisieren
                DoEvents
            End If
            
            If MasTe > 0 Then
                If RzAnz > 0 Then
                    S_TeAk MasTe, RzAnz 'Aktualisiert die Folge einer Terminserie
                    DoEvents
                End If
            End If

            If GlOTS = True Then 'Online-Terminbuchungs System
                If DaSta >= Now Then
                    With GlSyn
                        .PrTyp = "B" 'Termin Hinzugefügt
                        .DatSt = Format$(DaSta, "dd.mm.yyyy")
                        .DatEn = Format$(DateAdd("d", GlClp(1, 4), DaSta), "dd.mm.yyyy")
                        .ZeiSt = Format$(ZeSta, "hh:mm:ss")
                        .ZeiEn = Format$(DateAdd("n", GlClp(1, 5), ZeSta), "hh:mm:ss")
                        .TeBet = vbNullString
                        .GuiID = GlTeG 'Termin GuiID
                        .GnzTa = DayGa
                        .MaIdx = MaIdx
                        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                            .MaNum = MitNr
                        Else
                            .MaNum = ManNr
                        End If
                    End With
                    S_TeSy
                    DoEvents
                End If
            End If

            PrGui = CreateID("P")
            MitNa = GlMiA(GlSmI, 1)
            If NotSt = 3 Then
                PrStr = "Termin wurde kopiert und eingefügt (mit Emailerinnerung)"
            Else
                PrStr = "Termin wurde kopiert und eingefügt"
            End If
            DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", GlTem, PrGui, GlTeG, Now, Now, PrStr, MitNa
            DoEvents
        End If
    End If
Else
    Select Case GlBut
    Case RibTab_Ter_Kalend:
        If HitTy = True Then
            Set CaHit = CaCol.ActiveView.HitTest
            If Not CaHit.HitCode = xtpCalendarHitTestDayViewTimeScale Then
                If Not CaHit.HitCode = xtpCalendarHitTestUnknown Then
                    IdxNr = CaHit.ViewEvent.Event.id
                End If
            End If
        Else
            Set ViEvs = CaCol.ActiveView.GetSelectedEvents
            AnzPo = ViEvs.Count
            If AnzPo > 0 Then
                For Each ViEvt In ViEvs
                    If ViEvt.Selected = True Then
                        Set CaEvt = ViEvt.Event
                        IdxNr = CaEvt.id
                        Exit For
                    End If
                Next ViEvt
            End If
        End If
    Case RibTab_Ter_Raeume:
        If HitTy = True Then
            Set CaHit = CaCol.ActiveView.HitTest
            If Not CaHit.HitCode = xtpCalendarHitTestDayViewTimeScale Then
                If Not CaHit.HitCode = xtpCalendarHitTestUnknown Then
                    IdxNr = CaHit.ViewEvent.Event.id
                End If
            End If
        Else
            Set ViEvs = CaCol.ActiveView.GetSelectedEvents
            AnzPo = ViEvs.Count
            If AnzPo > 0 Then
                For Each ViEvt In ViEvs
                    If ViEvt.Selected = True Then
                        Set CaEvt = ViEvt.Event
                        IdxNr = CaEvt.id
                        Exit For
                    End If
                Next ViEvt
            End If
        End If
    Case RibTab_Ter_Mitarb:
        If HitTy = True Then
            Set CaHit = CaCol.ActiveView.HitTest
            If Not CaHit.HitCode = xtpCalendarHitTestDayViewTimeScale Then
                If Not CaHit.HitCode = xtpCalendarHitTestUnknown Then
                    IdxNr = CaHit.ViewEvent.Event.id
                End If
            End If
        Else
            Set ViEvs = CaCol.ActiveView.GetSelectedEvents
            AnzPo = ViEvs.Count
            If AnzPo > 0 Then
                For Each ViEvt In ViEvs
                    If ViEvt.Selected = True Then
                        Set CaEvt = ViEvt.Event
                        IdxNr = CaEvt.id
                        Exit For
                    End If
                Next ViEvt
            End If
        End If
    Case RibTab_Ter_Listen:
        AnzPo = RpSel.Count
        If AnzPo > 0 Then
            For Each RpRow In RpSel
                If RpRow.GroupRow = False Then
                    Set RpCol = RpCls.Find(Ter_ID2)
                    IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                    Exit For
                End If
            Next RpRow
        End If
    Case RibTab_Ter_Akont:
        AnzPo = RpSel.Count
        If AnzPo > 0 Then
            For Each RpRow In RpSel
                If RpRow.GroupRow = False Then
                    Set RpCol = RpCls.Find(Ter_ID2)
                    IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                    Exit For
                End If
            Next RpRow
        End If
    Case RibTab_Ter_Warte:
        AnzPo = RpSel.Count
        If AnzPo > 0 Then
            For Each RpRow In RpSel
                If RpRow.GroupRow = False Then
                    Set RpCol = RpCls.Find(Ter_ID2)
                    IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                    Exit For
                End If
            Next RpRow
        End If
    End Select

    Set RS137 = New ADODB.Recordset
    RS137.CursorLocation = adUseClient
    Set RS137 = DBCmRe1("qryTermin", "@IdxNr", IdxNr)
    If RS137.RecordCount > 0 Then
        ClKop = True 'Cliparry kopiert
        ReDim GlClp(1, 41)
        GlClp(1, 0) = RS137.Fields("ID2").Value
        GlClp(1, 1) = RS137.Fields("ID0").Value
        GlClp(1, 2) = RS137.Fields("IDSer").Value
        GlClp(1, 3) = RS137.Fields("IDR").Value
        GlClp(1, 4) = Abs(DateDiff("d", TimeValue(RS137.Fields("BisDat").Value), TimeValue(RS137.Fields("VonDat").Value))) 'Datumsdifferenz
        GlClp(1, 5) = Abs(DateDiff("n", TimeValue(RS137.Fields("ZeiBis").Value), TimeValue(RS137.Fields("ZeiVon").Value))) 'Zeitdifferenz
        GlClp(1, 6) = RS137.Fields("IDKurz").Value
        GlClp(1, 7) = RS137.Fields("Patient").Value
        GlClp(1, 9) = RS137.Fields("Farbe").Value
        GlClp(1, 10) = RS137.Fields("Farbtyp").Value
        GlClp(1, 11) = RS137.Fields("Erinnerung").Value
        GlClp(1, 12) = RS137.Fields("Selekt").Value 'Alldayevent
        GlClp(1, 13) = RS137.Fields("Aufgabe").Value
        GlClp(1, 14) = RS137.Fields("Erledigt").Value
        GlClp(1, 15) = RS137.Fields("Priorität").Value
        GlClp(1, 16) = RS137.Fields("Vorwarn").Value
        GlClp(1, 20) = TimeValue(RS137.Fields("ZeiVon").Value)
        GlClp(1, 21) = RS137.Fields("MasTer").Value 'MasTe
        GlClp(1, 25) = RS137.Fields("Wiederholung").Value
        GlClp(1, 26) = CSng(RS137.Fields("GesBetrag").Value)
        GlClp(1, 27) = CInt(RS137.Fields("RzAnz").Value)
        If RS137.Fields("Raum").Value <> vbNullString Then
            If GlOTS = True Then 'Online-Terminbuchungs System
                GlClp(1, 8) = GlMiA(GlSmI, 1)
            Else
                GlClp(1, 8) = RS137.Fields("Raum").Value
            End If
        End If
        If RS137.Fields("Kommentar").Value <> vbNullString Then GlClp(1, 17) = RS137.Fields("Kommentar").Value
        If RS137.Fields("Datei").Value <> vbNullString Then GlClp(1, 19) = RS137.Fields("Datei").Value
        If RS137.Fields("IDP").Value <> vbNullString Then
            GlClp(1, 18) = RS137.Fields("IDP").Value
        Else
            GlClp(1, 18) = GlMan(GlSMa, 2)
        End If
        If RS137.Fields("IDM").Value <> vbNullString Then
            GlClp(1, 23) = RS137.Fields("IDM").Value
        Else
            GlClp(1, 23) = GlMiA(GlSmI, 2)
        End If
        If RS137.Fields("Geschlecht").Value <> vbNullString Then
            GlClp(1, 24) = RS137.Fields("Geschlecht").Value
        Else
            GlClp(1, 24) = GlMiA(GlSmI, 2)
        End If
        If RS137.Fields("Firma1").Value <> vbNullString Then GlClp(1, 28) = RS137.Fields("Firma1").Value
        If RS137.Fields("Anrede").Value <> vbNullString Then GlClp(1, 29) = RS137.Fields("Anrede").Value
        If RS137.Fields("Titel").Value <> vbNullString Then GlClp(1, 30) = RS137.Fields("Titel").Value
        If RS137.Fields("Vorname").Value <> vbNullString Then GlClp(1, 31) = RS137.Fields("Vorname").Value
        If RS137.Fields("Name").Value <> vbNullString Then GlClp(1, 32) = RS137.Fields("Name").Value
        If RS137.Fields("Straße").Value <> vbNullString Then GlClp(1, 33) = RS137.Fields("Straße").Value
        If RS137.Fields("PLZ").Value <> vbNullString Then GlClp(1, 34) = RS137.Fields("PLZ").Value
        If RS137.Fields("Ort").Value <> vbNullString Then GlClp(1, 35) = RS137.Fields("Ort").Value
        If RS137.Fields("Land").Value <> vbNullString Then GlClp(1, 36) = RS137.Fields("Land").Value
        If RS137.Fields("Telefon1").Value <> vbNullString Then GlClp(1, 37) = RS137.Fields("Telefon1").Value
        If RS137.Fields("Telefon5").Value <> vbNullString Then GlClp(1, 38) = RS137.Fields("Telefon5").Value
        If RS137.Fields("Geboren").Value <> vbNullString Then GlClp(1, 39) = RS137.Fields("Geboren").Value
        If RS137.Fields("Briefanrede").Value <> vbNullString Then GlClp(1, 40) = RS137.Fields("Briefanrede").Value
        If RS137.Fields("NotifyValue").Value <> vbNullString Then GlClp(1, 41) = RS137.Fields("NotifyValue").Value
    End If
    RS137.Close
    Set RS137 = Nothing
    
    DoEvents
    If TeAus = True Then
        STeLo True
    End If
End If

If ClKop = True Then
    If ClEin = True Then
        If SelOK = True Then
            If GlClp(1, 6) <> vbNullString Then
                If GlClp(1, 7) <> vbNullString Then
                    If GlTTe = True Then 'Telefonnummer Terminbetreff
                        TeBet = GlClp(1, 7) & Chr$(32) & GlClp(1, 6) & Chr$(32) & GlClp(1, 19)
                    Else
                        TeBet = GlClp(1, 7) & Chr$(32) & GlClp(1, 6)
                    End If
                Else
                    TeBet = GlClp(1, 6)
                End If
            ElseIf GlClp(1, 7) <> vbNullString Then
                If GlTTe = True Then 'Telefonnummer Terminbetreff
                    TeBet = GlClp(1, 7) & Chr$(32) & GlClp(1, 19)
                Else
                    TeBet = GlClp(1, 7)
                End If
            End If
        
            Set CaEvt = CaCol.DataProvider.CreateEventEx(GlTem)
            With CaEvt
                If GlTDe = True Then 'Erweiterter Terminbetreff
                    .Body = Format$(TimeValue(ZeSta), "hh:mm") & " - " & Format$(TimeValue(DateAdd("n", GlClp(1, 5), ZeSta)), "hh:mm")
                End If
                Select Case GlBut:
                Case RibTab_Ter_Raeume: .ScheduleID = RaIdx 'RauNr
                Case RibTab_Ter_Mitarb: .ScheduleID = MaIdx 'ManNr
                End Select
                .StartTime = Format$(DaSta, "dd.mm.yyyy") & Chr$(32) & TimeValue(ZeSta)
                .EndTime = Format$(DateAdd("d", GlClp(1, 4), DaSta), "dd.mm.yyyy") & Chr$(32) & TimeValue(DateAdd("n", GlClp(1, 5), ZeSta))
                .Label = GlClp(1, 9)
                .Subject = TeBet
                .AllDayEvent = GlClp(1, 12)
                .PrivateFlag = GlClp(1, 12)
                .MeetingFlag = GlClp(1, 14)
                .Importance = GlClp(1, 15)
                If GlClp(1, 8) <> vbNullString Then .Location = GlClp(1, 8)
                If GlClp(1, 11) <> vbNullString Then .Reminder = GlClp(1, 11)
                If GlClp(1, 10) <> vbNullString Then .BusyStatus = GlClp(1, 10) - 1
            End With
        
            With CaCol
                .DataProvider.AddEvent CaEvt
                .Populate
                .RedrawControl
            End With
        Else
            SPopu "Termin Einfügen", "Bitte fügen Sie den Termin über die Symbolleiste ein", IC48_Information
        End If
    End If
End If

Screen.MousePointer = vbNormal

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing
Set CaCol = Nothing

Exit Sub

AdErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TeKo " & Err.Number
Resume Next

End Sub
Private Function S_TeLg(ByVal ProTy As String, ByRef TmStr As String, ByVal MitNr As Long) As Integer
On Error Resume Next
'Setzt Datum und Uhrzeit für die Protokolleinträge

Dim DaTim As String
Dim AnzPo As Integer

DaTim = Format$(Date, "dd.mm.yyyy") & " " & Format$(Now, "hh:mm:ss")

Set RS161 = New ADODB.Recordset
RS161.CursorLocation = adUseClient
If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
    Set RS161 = DBCmRe3("qrySimAbTe8", "@IdxNr", "@IdMit", "@IdStr", 800, MitNr, ProTy)
Else
    Set RS161 = DBCmRe3("qrySimAbTe2", "@IdxNr", "@IdMan", "@IdStr", 800, MitNr, ProTy)
End If
AnzPo = RS161.RecordCount

If AnzPo > 0 Then
    Do
    TmStr = TmStr & RS161.Fields("IDKurz").Value
    RS161.MoveNext
    Loop Until RS161.EOF
End If
RS161.Close
Set RS161 = Nothing

TmStr = Replace(TmStr, vbCrLf, vbNullString, 1)
DoEvents

If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
    DBCmEx4 "qrySimAbTe3", "@IdKom", "@IdxNr", "@IdMit", "@IdStr", DaTim, 800, MitNr, ProTy
Else
    DBCmEx4 "qrySimAbTe4", "@IdKom", "@IdxNr", "@IdMan", "@IdStr", DaTim, 800, MitNr, ProTy
End If

S_TeLg = AnzPo

End Function


Public Sub S_TeLi()
On Error GoTo KoErr
'Lädt die Termine in den Kalender

Dim ZeiSt As Date
Dim ZeiEn As Date
Dim AnzPo As Long
Dim AnzRe As Long
Dim VoWar As Long
Dim AnzTy As Long
Dim IdxNr As Long
Dim SeIdx As Long
Dim DatSt As String
Dim DatEn As String
Dim ZeStr As String
Dim KoStr As String
Dim Folge As String
Dim DaSt1 As String
Dim DaSt2 As String
Dim TeBet As String
Dim TeOrt As String
Dim AktZa As Integer
Dim TypZa As Integer
Dim AnzTa As Integer
Dim BuSta As Integer
Dim RzAnz As Integer
Dim RzAkt As Integer

Dim CmBrs As XtremeCommandBars.CommandBars
Dim CaCol As XtremeCalendarControl.CalendarControl
Dim CaEvt As XtremeCalendarControl.CalendarEvent
Dim CaEvs As XtremeCalendarControl.CalendarEvents
Dim CaRms As XtremeCalendarControl.CalendarReminders
Dim CaWid As XtremeCalendarControl.CalendarRecurrencePattern
Dim WiSta As XtremeCalendarControl.CalendarEventRecurrenceState
Dim EvCat As XtremeCalendarControl.CalendarEventCategory
Dim EvCas As XtremeCalendarControl.CalendarEventCategories

Set FM = frmMain
Set CmBrs = FM.comBar01
Set CaCol = FM.calCont1
Set DaPi7 = FM.dtpDatu7
Set CaRms = CaCol.Reminders
Set DaPro = CaCol.DataProvider
Set CaLbs = DaPro.LabelList
Set EvCas = DaPro.EventCategories

GlTrL = True

TypZa = 0
GlTrM = False 'Terminbearbeitung direkt im Kalender
GlTrB = False 'Terminbearbeitung direkt im Kalender

DatSt = GlDFi & " 00:00:00" 'Kompatibilität zu SQL Server
DatEn = GlDLa & " 23:59:00"

CaCol.DataProvider.RemoveAllEvents
DoEvents

If GlTAl = True Then 'Terminerinnerung im Kalender anzeigen
    CaRms.DismissAll
    DoEvents
End If

Set RS138 = New ADODB.Recordset
RS138.CursorLocation = adUseClient

If GlTmS = True Then 'Terminkalender zeigt Stornierte
    Select Case GlCaF 'Kalenderfilterauswahl
    Case 1:
        Set RS138 = DBCmRe2("qryTerCal2", "@IdSta", "@IdEnd", DatSt, DatEn)
    Case 2:
        If GlTRa = True Then 'Mitarbeiter / Mandanten in Raumbelegung aktivieren
            If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                Set RS138 = DBCmRe4("qryTerCaRMi2", "@IdSta", "@IdEnd", "@IdxNr", "@IdMit", DatSt, DatEn, GlRmu(GlCaS, 2), GlRmu(GlCaS, 4))
            Else
                Set RS138 = DBCmRe4("qryTerCaRMa2", "@IdSta", "@IdEnd", "@IdxNr", "@IdMan", DatSt, DatEn, GlRmu(GlCaS, 2), GlRmu(GlCaS, 4))
            End If
        Else
            Set RS138 = DBCmRe3("qryTerCaRa2", "@IdSta", "@IdEnd", "@IdxNr", DatSt, DatEn, GlRmu(GlCaS, 2))
        End If
    Case 3:
        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
            Set RS138 = DBCmRe3("qryTerCaMi2", "@IdSta", "@IdEnd", "@IdxNr", DatSt, DatEn, GlMiT(GlCaS, 2)) 'Aktive Mitarbeiter + Terminspalte
        Else
            Set RS138 = DBCmRe3("qryTerCaMa2", "@IdSta", "@IdEnd", "@IdxNr", DatSt, DatEn, GlMaT(GlCaS, 2))
        End If
    End Select
Else
    Select Case GlCaF 'Kalenderfilterauswahl
    Case 1:
        Set RS138 = DBCmRe2("qryTerCal", "@IdSta", "@IdEnd", DatSt, DatEn)
    Case 2:
        If GlTRa = True Then 'Mitarbeiter / Mandanten in Raumbelegung aktivieren
            If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                Set RS138 = DBCmRe4("qryTerCaRMi", "@IdSta", "@IdEnd", "@IdxNr", "@IdMit", DatSt, DatEn, GlRmu(GlCaS, 2), GlRmu(GlCaS, 4))
            Else
                Set RS138 = DBCmRe4("qryTerCaRMa", "@IdSta", "@IdEnd", "@IdxNr", "@IdMan", DatSt, DatEn, GlRmu(GlCaS, 2), GlRmu(GlCaS, 4))
            End If
        Else
            Set RS138 = DBCmRe3("qryTerCaRa", "@IdSta", "@IdEnd", "@IdxNr", DatSt, DatEn, GlRmu(GlCaS, 2))
        End If
    Case 3:
        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
            Set RS138 = DBCmRe3("qryTerCaMi", "@IdSta", "@IdEnd", "@IdxNr", DatSt, DatEn, GlMiT(GlCaS, 2)) 'Aktive Mitarbeiter + Terminspalte
        Else
            Set RS138 = DBCmRe3("qryTerCaMa", "@IdSta", "@IdEnd", "@IdxNr", DatSt, DatEn, GlMaT(GlCaS, 2))
        End If
    End Select
End If

AnzPo = RS138.RecordCount

If AnzPo > 0 Then
    GlTeV = True 'Termine vorhanden
    Do
    IdxNr = RS138.Fields("ID2").Value
    If RS138.Fields("ZeiVon").Value <> vbNullString Then
        ZeiSt = TimeValue(RS138.Fields("ZeiVon").Value)
    Else
        ZeiSt = TimeValue("00:00:00")
    End If
    If RS138.Fields("ZeiBis").Value <> vbNullString Then
        ZeiEn = TimeValue(RS138.Fields("ZeiBis").Value)
    Else
        ZeiEn = TimeValue("00:00:00")
    End If
    If RS138.Fields("Kommentar").Value <> vbNullString Then
        KoStr = RS138.Fields("Kommentar").Value
    Else
        KoStr = vbNullString
    End If
    If RS138.Fields("Raum").Value <> vbNullString Then
        TeOrt = RS138.Fields("Raum").Value
    Else
        TeOrt = vbNullString
    End If
    If RS138.Fields("IDSer").Value > 0 Then
        SeIdx = RS138.Fields("IDSer").Value
    Else
        SeIdx = 0
    End If
    If RS138.Fields("Farbtyp").Value <> vbNullString Then
        BuSta = RS138.Fields("Farbtyp").Value
    Else
        BuSta = 3
    End If
    If RS138.Fields("RzAnz").Value <> vbNullString Then
        If RS138.Fields("RzAnz").Value > 0 Then
            RzAnz = RS138.Fields("RzAnz").Value
            RzAkt = RS138.Fields("RzAkt").Value
            Folge = Format$(RzAkt, "00") & "/" & Format$(RzAnz, "00")
        Else
            RzAnz = 0
            Folge = vbNullString
        End If
    Else
        RzAnz = 0
        Folge = vbNullString
    End If
    If Folge <> vbNullString Then
        ZeStr = Format$(ZeiSt, "hh:mm") & " - " & Format$(ZeiEn, "hh:mm") & " - " & Folge
    Else
        ZeStr = Format$(ZeiSt, "hh:mm") & " - " & Format$(ZeiEn, "hh:mm")
    End If

    If RS138.Fields("Vorwarn").Value <> vbNullString Then
        Select Case RS138.Fields("Vorwarn").Value
        Case 1: VoWar = 0
        Case 2: VoWar = 1
        Case 3: VoWar = 2
        Case 4: VoWar = 5
        Case 5: VoWar = 10
        Case 6: VoWar = 15
        Case 7: VoWar = 30
        Case 8: VoWar = 60
        Case 9: VoWar = 120
        Case 10: VoWar = 300
        Case 11: VoWar = 600
        Case 12: VoWar = 1440
        Case 13: VoWar = 2880
        Case 14: VoWar = 7200
        Case 15: VoWar = 10080
        Case 16: VoWar = 20160
        End Select
    Else
        VoWar = 0
    End If

    If RS138.Fields("IDKurz").Value <> vbNullString Then
        If RS138.Fields("Patient").Value <> vbNullString Then
            If GlTTe = True Then 'Telefonnummer Terminbetreff
                TeBet = RS138.Fields("Patient").Value & Chr$(32) & RS138.Fields("IDKurz").Value & Chr$(32) & RS138.Fields("Telefon1").Value
            Else
                TeBet = RS138.Fields("Patient").Value & Chr$(32) & RS138.Fields("IDKurz").Value
            End If
        Else
            If GlTTe = True Then 'Telefonnummer Terminbetreff
                TeBet = RS138.Fields("IDKurz").Value & Chr$(32) & RS138.Fields("Telefon1").Value
            Else
                TeBet = RS138.Fields("IDKurz").Value
            End If
        End If
    ElseIf RS138.Fields("Patient").Value <> vbNullString Then
        If GlTTe = True Then 'Telefonnummer Terminbetreff
            TeBet = RS138.Fields("Patient").Value & Chr$(32) & RS138.Fields("Telefon1").Value
        Else
            TeBet = RS138.Fields("Patient").Value
        End If
    Else
        TeBet = vbNullString
    End If

    Set CaEvt = CaCol.DataProvider.CreateEventEx(IdxNr)
    With CaEvt
        .CustomIcons.removeAll
        If GlTDe = True Then 'Erweiterter Terminbetreff
            If TeOrt <> vbNullString Then
                If KoStr <> vbNullString Then
                    .Body = TeOrt & Chr$(32) & KoStr
                Else
                    .Body = TeOrt
                End If
            Else
                If KoStr <> vbNullString Then
                    .Body = KoStr
                End If
            End If
        End If
        Select Case GlBut
        Case RibTab_Ter_Raeume:
            If RS138.Fields("IDR").Value > 0 Then
                For AktZa = 1 To UBound(GlRmu)
                    If RS138.Fields("IDR").Value = GlRmu(AktZa, 2) Then
                        .ScheduleID = AktZa
                        Exit For
                    End If
                Next AktZa
            Else
                .ScheduleID = GlRmu(1, 0)
            End If
        Case RibTab_Ter_Mitarb:
                If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                    If RS138.Fields("IDM").Value > 0 Then 'Aktive Mitarbeiter + Terminspalte
                        For AktZa = 1 To UBound(GlMiT)
                            If RS138.Fields("IDM").Value = GlMiT(AktZa, 2) Then
                                .ScheduleID = AktZa
                                Exit For
                            End If
                        Next AktZa
                    Else
                        .ScheduleID = GlMiT(1, 0)
                    End If
                Else
                    If RS138.Fields("IDP").Value > 0 Then
                        For AktZa = 1 To UBound(GlMaT)
                            If RS138.Fields("IDP").Value = GlMaT(AktZa, 2) Then
                                .ScheduleID = AktZa
                                Exit For
                            End If
                        Next AktZa
                    Else
                        .ScheduleID = GlMaT(1, 0)
                    End If
                End If
        End Select
        .Subject = TeBet
        .Location = ZeStr
        If RS138.Fields("VonDat").Value <> vbNullString Then
            .StartTime = DateValue(Left$(RS138.Fields("VonDat").Value, 10)) & Chr$(32) & ZeiSt
        End If
        If RS138.Fields("BisDat").Value <> vbNullString Then
            .EndTime = DateValue(Left$(RS138.Fields("BisDat").Value, 10)) & Chr$(32) & ZeiEn
        End If
        If RS138.Fields("Farbe").Value > 0 Then
            .Label = RS138.Fields("Farbe").Value 'Farbindex der CaLbs
        End If
        If GlTAl = True Then 'Terminerinnerung im Kalender anzeigen
            .Reminder = CBool(RS138.Fields("Erinnerung").Value)
        Else
            If DateValue(Left$(RS138.Fields("VonDat").Value, 10)) >= Date Then
                If RS138.Fields("Erinnerung").Value = -1 Then
                    .CustomIcons.Add IC16_Bell
                End If
            End If
        End If
        .BusyStatus = BuSta - 1
        Select Case BuSta
        Case 1: .CustomIcons.Add IC16_Pin_Green
        Case 2: .CustomIcons.Add IC16_Pin_Gray
        Case 3:
        Case 4: .CustomIcons.Add IC16_Pin_Red
        End Select
        If CBool(RS138.Fields("Passiv").Value) = True Then
            .CustomIcons.Add IC16_Doc_Del
            .Label = 20
        End If
        If CBool(RS138.Fields("Selekt").Value) = True Then
            .AllDayEvent = True
        Else
            .AllDayEvent = False
        End If
        If CBool(RS138.Fields("Erledigt").Value) = True Then
            .MeetingFlag = True
        Else
            .MeetingFlag = False
        End If
        If RS138.Fields("Wiederholung").Value <> vbNullString Then
            If CBool(RS138.Fields("Wiederholung").Value) = True Then 'Leistungen vorhanden
                If CBool(RS138.Fields("Aufgabe").Value) = True Then 'Abgerechnet
                    .PrivateFlag = True
                    .CustomIcons.Add IC16_Mail_Close
                Else
                    .CustomIcons.Add IC16_Mail_Open
                End If
            End If
        End If
        If RS138.Fields("Buchung").Value <> vbNullString Then
            If CBool(RS138.Fields("Buchung").Value) = True Then 'Buchung abgeleitet
                .CustomIcons.Add IC16_Doc_Line
            End If
        End If
        Select Case RS138.Fields("Priorität").Value
        Case 1: .Importance = xtpCalendarImportanceHigh
                .CustomIcons.Add IC16_Calendar_Add
        Case 2: .Importance = xtpCalendarImportanceNormal
        Case 3: .Importance = xtpCalendarImportanceLow
                .CustomIcons.Add IC16_Calendar_Clock
        End Select
        If CBool(RS138.Fields("Abhaken").Value) = True Then
            .CustomIcons.Add IC16_Sign_Check
        End If
        If RS138.Fields("OnlTer").Value <> vbNullString Then
            If CBool(RS138.Fields("OnlTer").Value) = True Then
                .CustomIcons.Add IC16_Phone_Mobil
            End If
        End If
        If GlTGs = True Then
            If RS138.Fields("Geschlecht").Value > 0 Then
                Select Case RS138.Fields("Geschlecht").Value
                Case 1:
                Case 2: .CustomIcons.Add IC16_User_Norm
                Case 3: .CustomIcons.Add IC16_User_Woman
                Case 4: .CustomIcons.Add IC16_Shoolboy
                Case 5: .CustomIcons.Add IC16_User_Norm
                Case 6: .CustomIcons.Add IC16_User_Woman
                Case 7: .CustomIcons.Add IC16_Dog
                End Select
            End If
        End If
        .ReminderMinutesBeforeStart = VoWar
    End With

    If SeIdx < 5 Then
        Set RS114 = New ADODB.Recordset
        RS114.CursorLocation = adUseClient
        Set RS114 = DBCmRe1("qryTerSeL", "@IdxNr", IdxNr)
        If RS114.RecordCount > 0 Then
            Set CaWid = CaEvt.CreateRecurrence
            With CaWid
                .MasterEventId = RS114.Fields("ID2").Value
                .StartTime = Format$(RS114.Fields("SerVon").Value, "hh:mm:ss")
                .StartDate = Format$(RS114.Fields("VonDat").Value, "dd.mm.yyyy")
                .DurationMinutes = RS114.Fields("DauMin").Value
                .Options.RecurrenceType = RS114.Fields("SerTyp").Value
                Select Case SeIdx
                Case 1:
                    If RS114.Fields("IntVal").Value > 0 Then
                        .Options.DailyEveryWeekDayOnly = False
                        .Options.DailyIntervalDays = RS114.Fields("IntVal").Value
                    Else
                        .Options.DailyEveryWeekDayOnly = True
                    End If
                Case 2:
                    .Options.WeeklyIntervalWeeks = RS114.Fields("IntVal").Value
                    .Options.WeeklyDayOfWeekMask = RS114.Fields("TagWho").Value
                Case 3:
                    If .Options.RecurrenceType = xtpCalendarRecurrenceMonthly Then
                        .Options.MonthlyDayOfMonth = RS114.Fields("WhoTag").Value
                        .Options.MonthlyIntervalMonths = RS114.Fields("IntVal").Value
                    ElseIf .Options.RecurrenceType = xtpCalendarRecurrenceMonthNth Then
                        .Options.MonthNthWhichDay = RS114.Fields("WhoTag").Value
                        .Options.MonthNthWhichDayMask = RS114.Fields("TagMon").Value
                        .Options.MonthNthIntervalMonths = RS114.Fields("IntVal").Value
                    End If
                Case 4:
                    If .Options.RecurrenceType = xtpCalendarRecurrenceYearly Then
                        .Options.YearlyDayOfMonth = RS114.Fields("WhoTag").Value
                        .Options.YearlyMonthOfYear = RS114.Fields("MonJah").Value
                    ElseIf .Options.RecurrenceType = xtpCalendarRecurrenceYearNth Then
                        .Options.YearNthWhichDay = RS114.Fields("WhoTag").Value
                        .Options.YearNthWhichDayMask = RS114.Fields("TagWie").Value
                        .Options.YearNthMonthOfYear = RS114.Fields("MonJah").Value
                    End If
                End Select
                .EndMethod = RS114.Fields("EndTyp").Value
                If .EndMethod = xtpCalendarPatternEndNoDate Then

                ElseIf .EndMethod = xtpCalendarPatternEndAfterOccurrences Then
                    .EndAfterOccurrences = RS114.Fields("AnzTag").Value
                ElseIf .EndMethod = xtpCalendarPatternEndDate Then
                    .EndDate = Format$(RS114.Fields("BisDat").Value, "dd.mm.yyyy")
                End If
            End With
            CaEvt.UpdateRecurrence CaWid
        End If
        RS114.Close
        Set RS114 = Nothing
    End If
    CaCol.DataProvider.AddEvent CaEvt

    RS138.MoveNext
    Loop Until RS138.EOF
End If

RS138.Close
Set RS138 = Nothing

CaCol.Populate
DoEvents

With DaPi7
    .SelectRange DatSt, DatEn
    .RedrawControl
End With
DoEvents

SMark

Set CaRms = Nothing
Set CaCol = Nothing

GlTrL = False

Exit Sub

KoErr:
If GlDbg = True Then SErLog Err.Description & " S_TeLi " & Err.Number & " " & DatSt & " " & DatEn
Resume Next

End Sub
Public Sub S_TeMa(Optional ByVal DocMa As Boolean = False)
On Error GoTo GrErr
'Sendet eine Email an Patienten im Termin

Dim TerNr As Long
Dim PatNr As Long
Dim DaNam As String
Dim FiNam As String
Dim EmAdr As String
Dim EmNam As String
Dim EmBrf As String
Dim EmTex As String
Dim AbEmr As String
Dim SigNa As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim TmGui As String
Dim EmVer As Boolean
Dim Frage As Integer
Dim AktZa As Integer
Dim GesZa As Integer
Dim Mld1, Mld2, Tit1 As String
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCo6 = FM.repCont6
If GlWaZ = True Then 'Wartezimmer Kontextmenü
    Set RpCls = RpCo6.Columns
    Set RpSel = RpCo6.SelectedRows
Else
    Set RpCls = RpCo1.Columns
    Set RpSel = RpCo1.SelectedRows
End If

If GlEKV = False Then 'Emailkonten vorhanden
    TeTit = "E-Mail-Versand"
    TeMai = "Es ist kein E-Mail-Konto vorhanden"
    TeInh = "Um E-Mails versenden zu können, ist es notwendig mind. ein E-Mail-Konto hinzuzufügen."
    TeFus = "Um ein E-Mail-Konto hinzuzufügen, wechseln Sie in das Modul: Textverarbeitung und dann oben auf Emails. Dort klicken Sie auf die Schaltfläche Emailkonten."
    SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
    Exit Sub
End If

Set clFil = New clsFile

GesZa = RpSel.Count
Tit1 = "Email versenden"

If GesZa > 1 Then
    Mld1 = "Soll nun eine Nachricht an die Patienten die in den " & GesZa & " markierten Terminen hinterlegt sind gesendet werden?"
ElseIf GesZa = 1 Then
    Mld1 = "Soll nun eine Nachricht an den Patienten der in dem markierten Termin hinterlegt ist gesendet werden?"
ElseIf GesZa = 0 Then
    Exit Sub
End If

If GlMkt(1, 13) <> vbNullString Then
    AbEmr = GlMkt(1, 13)
Else
    If GlThe(GlSMa, 16) <> vbNullString Then
        AbEmr = GlThe(GlSMa, 16)
    End If
End If

If GlMiA(GlSmI, 11) <> vbNullString Then
    SigNa = GlMiA(GlSmI, 11)
Else
    SigNa = GlMiA(GlSmI, 1)
End If

Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
If Frage = 6 Then
    If DocMa = False Then
        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                Set RpCol = RpCls.Find(Ter_ID0)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    PatNr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Ter_ID2)
                    TerNr = RpRow.Record(RpCol.ItemIndex).Value
                    S_AdDe PatNr 'Adressendetails
                    With GlADt
                        EmBrf = .AdBrf
                        If EmAdr = vbNullString Then
                            EmAdr = .AdTe5
                        Else
