Set CmJah = CmBrs.FindControl(CmJah, SY_SuJah, , True)
Set CmGlk = CmBrs.FindControl(CmGlk, SY_SuBuh, , True)

AnzPo = RpSel.Count
BuJah = CmJah.Text

If AnzPo > 1 Then
    Mld1 = "Möchten Sie die " & AnzPo & " markierten Buchungen duplizieren?"
Else
    Mld1 = "Möchten Sie die markierte Buchung duplizieren?"
End If
Tit1 = "Buchung duplizieren"

If AnzPo > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then
        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                Set RpCol = RpCls.Find(Buh_ID0)
                IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Buh_IDT)
                ManNr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Buh_IDB)
                GeKto = RpRow.Record(RpCol.ItemIndex).Value
                BuBel = S_BuBel(ManNr, BuJah, GeKto)
                DoEvents
                DBCmEx2 "qrySimBuKop", "@IdxNr", "@IdBel", IdxNr, BuBel
                DoEvents
                GlNeK = GlKoX 'Protokolleintrag
                With GlNeK
                    .PatNr = GlMan(GlSMa, 2)
                    .IdxNr = 0
                    .EiDat = Format$(Date, "dd.mm.yyyy")
                    .EiZei = TimeValue(Now)
                    .EiTyp = 104
