Public Sub S_BaSuc()
On Error GoTo LiErr
'Durchsucht die Umsätze nach offenen Posten

Dim SQL1 As String
Dim GesZa As Long
Dim IdxNr As Long
Dim OpNum As Long
Dim ReNum As Long
Dim PatNr As Long
Dim PaNum As Long
Dim AktZa As Long
Dim ManNr As Long
Dim MitNr As Long
Dim MaNum As Long
Dim SuStr As String
Dim ReNu1 As String
Dim ReNu2 As String
Dim ReNu3 As String
Dim ReNu4 As String
Dim ReNu5 As String
Dim ReNu6 As String
Dim ReStr As String
Dim BuJah As String
Dim Krite As String
Dim TmGui As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim OpBet As Single
Dim BuBet As Single
Dim PaStr As String
Dim SuZa1 As Integer
Dim SuZa2 As Integer
Dim SuZa3 As Integer
Dim SuZa4 As Integer
Dim SuZa5 As Integer
Dim SuZa6 As Integer
Dim IdBnk As Integer
Dim Posit As Integer
Dim AnzOp As Integer
Dim AnzBu As Integer
Dim LenSu As Integer
Dim Frage As Integer
Dim BuZug As Boolean
Dim OpoZu As Boolean
Dim Mld1, Tit1 As String
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmJah As XtremeCommandBars.CommandBarComboBox
Dim CmGlk As XtremeCommandBars.CommandBarComboBox

TeTit = "Zuordnungs-Assistent"
TeMai = "Sollen jetzt die offenen Posten und die Buchungsregeln automatisch zugeordnet werdne?"
TeInh = "Der Zuordnungs-Assistent wird nun versuchen auf der Basis der Umsatztexte Ihre offenen Posten den eingehenden Zahlungen zuzuordnen. Wurden Buchungsregeln definiert, so wird ebenfalls versucht, diese auf die restlichen Kontoumsätze anzuwenden und die in den Regeln hinterlegten Sachkontennummern zuzuweisen."
TeFus = "Wurden offene Posten sowie Sachkonten zugeordnet, können Sie diese einzeln oder gemeinschaftlich buchen. Offene Posten die nicht automatisch zugeordnet werden konnten, können rechts über das Flyoutfenster manuell zugeordnet werden. Dasselbe gilt für die Buchungsvorlagen."

SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, False, FM.hwnd
If GlMes <> 33565 Then
    Exit Sub
End If

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

Set FM = frmMain
Set CmBrs = FM.comBar01
Set CmAcs = CmBrs.Actions

Set CmJah = CmBrs.FindControl(CmJah, SY_SuJah, , True)
Set CmGlk = CmBrs.FindControl(CmGlk, SY_SuBuh, , True)

IdBnk = CmGlk.ItemData(CmGlk.ListIndex)
BuJah = CmJah.Text

If GlTyp < 2 Then
    Krite = "((YEAR(Datum) = " & BuJah & "))"
Else
    Krite = "((Year([Datum]) = " & BuJah & "))"
End If

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qrySimOP ORDER BY Datum"
Else
    SQL1 = "SELECT * FROM qrySimOP ORDER BY [Datum];"
End If

Set RS120 = New ADODB.Recordset 'Es werden nur die unausgeglichenen Posten durchsucht
With RS120
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenForwardOnly
    .LockType = adLockReadOnly
    .Open Options:=adCmdText
End With
GesZa = RS120.RecordCount

If GesZa > 0 Then
    frmStatus.Show
    DoEvents
    frmStatus.Caption = "Umsatzassistent"
    Set Lbl01 = frmStatus.lblLab01
    Set PrBr1 = frmStatus.prbStat1
    Set PrBr2 = frmStatus.prbStat2
    Set TxDum = frmStatus.txtDummy
    Lbl01.Caption = "Bitte warten..."
    PrBr1.Min = 0
    PrBr1.Max = GesZa
        
    Do
    OpNum = RS120.Fields("ID1").Value
    ReNum = RS120.Fields("IDR").Value
    PatNr = RS120.Fields("ID0").Value
    If RS120.Fields("IDP").Value <> vbNullString Then
        ManNr = RS120.Fields("IDP").Value
    Else
        ManNr = 0
    End If
    If RS120.Fields("IDT").Value <> vbNullString Then
        MitNr = RS120.Fields("IDT").Value
    Else
        MitNr = 0
    End If
    If RS120.Fields("Patient").Value <> vbNullString Then
        PaStr = RS120.Fields("Patient").Value
    Else
        PaStr = vbNullString
    End If
    If RS120.Fields("GuiID").Value <> vbNullString Then
        TmGui = RS120.Fields("GuiID").Value
    Else
        TmGui = CreateID("P")
    End If
    ReStr = RS120.Fields("RechNr").Value

    If Len(ReStr) > 3 Then
