Public Function S_KrDi(ByVal ReNum As Long, Optional ByVal ReAbg As Boolean) As String
On Error GoTo SuErr
'Lädt die Diagnose in das Diagnosefeld der Rechnung

Dim DiaDa As Date
Dim IdxNr As Long
Dim StrDa As String
Dim StrDi As String
Dim StrId As String
Dim TmStr As String
Dim AktPo As Integer

Set FM = frmMain
Set TxDe6 = FM.txtDeta6
Set LiVw1 = FM.lstView1
Set LiIts = LiVw1.ListItems

TxDe6.Text = vbNullString
LiIts.Clear

If ReAbg = True Then
    TxDe6.Enabled = False
Else
    If TxDe6.Enabled = False Then
        TxDe6.Enabled = True
    End If
End If

Set RS129 = New ADODB.Recordset
RS129.CursorLocation = adUseClient
Set RS129 = DBCmRe1("qrySimReIdx", "@IdxNr", ReNum)
If RS129.RecordCount > 0 Then
    If RS129.Fields("Diagnose").Value <> vbNullString Then
        TxDe6.Text = RS129.Fields("Diagnose").Value
    Else
        TxDe6.Text = vbNullString
    End If
Else
    TxDe6.Text = vbNullString
End If
RS129.Close
Set RS129 = Nothing

Set RS128 = New ADODB.Recordset
RS128.CursorLocation = adUseClient
If GlDSo = True Then 'Katalogdiagnosen alphabetisch sortieren
    Set RS128 = DBCmRe1("qrySimAbDiag", "@IdxNr", ReNum)
Else
    Set RS128 = DBCmRe1("qrySimAbDia5", "@IdxNr", ReNum)
End If
If RS128.RecordCount > 0 Then
    Do
    IdxNr = RS128.Fields("ID2").Value
    If RS128.Fields("IDKurz").Value <> vbNullString Then
        StrId = RS128.Fields("GOID").Value
        StrDi = RS128.Fields("IDKurz").Value
        AktPo = AktPo + 1
        If RS128.Fields("Datum").Value <> vbNullString Then
            DiaDa = RS128.Fields("Datum").Value
            StrDa = Left$(DiaDa, 10)

            If GldId = True Then
                If GlICD = True Then
                    Set LiItm = LiIts.Add(AktPo, "D" & IdxNr, StrDa & ": " & StrDi & " (" & Trim$(StrId) & ")", IC16_Doc_Norm)
                    TmStr = TmStr & "; " & StrDa & ": " & StrDi & " (" & Trim$(StrId) & ")"
                Else
                    Set LiItm = LiIts.Add(AktPo, "D" & IdxNr, StrDa & ": " & StrDi, IC16_Doc_Norm)
                    TmStr = TmStr & "; " & StrDa & ": " & StrDi
                End If
            Else
                If GlICD = True Then
                    Set LiItm = LiIts.Add(AktPo, "D" & IdxNr, StrDi & " (" & Trim$(StrId) & ")", IC16_Doc_Norm)
                    TmStr = TmStr & "; " & StrDi & " (" & Trim$(StrId) & ")"
                Else
                    Set LiItm = LiIts.Add(AktPo, "D" & IdxNr, StrDi, IC16_Doc_Norm)
                    TmStr = TmStr & "; " & StrDi
                End If
            End If
        Else
            If GlICD = True Then
                Set LiItm = LiIts.Add(AktPo, "D" & IdxNr, StrDi & " (" & Trim$(StrId) & ")", IC16_Doc_Norm)
                TmStr = TmStr & "; " & StrDi & " (" & Trim$(StrId) & ")"
            Else
                Set LiItm = LiIts.Add(AktPo, "D" & IdxNr, StrDi, IC16_Doc_Norm)
                TmStr = TmStr & "; " & StrDi
            End If
        End If
    End If
    RS128.MoveNext
    Loop Until RS128.EOF
End If
RS128.Close
Set RS128 = Nothing

If TmStr <> vbNullString Then
    S_KrDi = LTrim$(TmStr)
Else
    S_KrDi = vbNullString
End If

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KrDi " & Err.Number
Resume Next

End Function
