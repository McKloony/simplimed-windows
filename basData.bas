Public Sub S_BaBuc()
On Error GoTo LiErr
'Generiert eine Buchung aus zugeordnetem Umsazu

Dim ReNum As Long
Dim IdKon As Long
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim BaAus As String
Dim BaBez As String
Dim BaSel As String
Dim BaIDZ As Integer
Dim AnzPo As Integer
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows
    
AnzPo = RpSel.Count

If AnzPo = 0 Then
    TeTit = "Umsätze Buchen"
    TeMai = "Es wurde noch kein Umsatz markiert"
    TeInh = "Um einen Umsatz zuordnen zu buchen ist es erforderlich mind. einen Umsazu zu markieren"
    TeFus = "Bitte wählen Sie einen Umsatz, dem entweder ein offener Posten oder ein Sachkonto zugeordnet wurden."
    SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
    Exit Sub
End If

If AnzPo > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        
        Set RpCol = RpCls.Find(Ban_IDZ)
        BaIDZ = CInt(RpRow.Record(RpCol.ItemIndex).Value)
        
        Set RpCol = RpCls.Find(Ban_Ausgabe)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BaAus = LCase(RpRow.Record(RpCol.ItemIndex).Value)
        Else
            BaAus = "ja"
        End If
        Set RpCol = RpCls.Find(Ban_IDK)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            IdKon = RpRow.Record(RpCol.ItemIndex).Value
        Else
            IdKon = 0
        End If
        Set RpCol = RpCls.Find(Ban_IDR)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            ReNum = RpRow.Record(RpCol.ItemIndex).Value
        Else
            ReNum = 0
        End If
        Set RpCol = RpCls.Find(Ban_Bezahlt)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BaBez = LCase(RpRow.Record(RpCol.ItemIndex).Value)
        Else
            BaBez = "ja"
        End If
        Set RpCol = RpCls.Find(Ban_Selekt)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BaSel = LCase(RpRow.Record(RpCol.ItemIndex).Value)
        Else
            BaSel = "ja"
        End If

        If AnzPo = 1 Then
            If BaIDZ < 0 Then
                TeTit = "Umsatz Buchen"
                TeMai = "Dieser Umsatz kann kann nicht gebucht werden"
                TeInh = "Dieser Umsatz wurde gekennzeichnet und kann daher nicht gebucht werden."
                TeFus = "Um die Kennzeichnung aufzuheben ist es erforderlich, den Umsatz ein weiters Mal zu kennzeichnen."
                SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
                Exit Sub
            End If
        
            If BaBez = "ja" Then
                TeTit = "Umsätze Buchen"
                TeMai = "Dieser Umsatz wurde bereits gebucht"
                TeInh = "Für diesen Umsatz wurde bereits eine Buchung generiert."
                TeFus = "Noch nicht gebuchte Umsätze, denen aber ein offener Posten oder ein Sachkonto zugeordnet wurden, werden in fetter Schrift dargestellt."
                SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
                Exit Sub
            End If
            
            If BaSel = "nein" Then
                TeTit = "Umsätze Buchen"
                TeMai = "Dieser Umsatz kann kann noch nicht gebucht werden"
                TeInh = "Diesem Umsatz wurden bisher weder ein offener Posten noch eine Buchungsvorlage zugeordnet."
                TeFus = " Umsätze, denen ein offener Posten oder ein Sachkonto zugeordnet wurden, werden in fetter Schriftdargestellt."
                SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
                Exit Sub
            End If
    
            If ReNum > 0 Then
                frmOPAusg.Show vbModal
            ElseIf IdKon > 0 Then
                S_BaNeu
            End If
        Else
            TeTit = "Umsätze Buchen"
            TeMai = "Sollen für die " & AnzPo & " markierten Umsätze nun die Buchungen generiert werden?"
            TeInh = "Wurden den Umsätzen entweder ein offener Posten oder eine Buchungsvorlage zugeordnet, können nun die Erlös- oder Ausgabebuchungen generiert werden."
            TeFus = "Wurde dem Umsatz ein offener Posten zugeordnet, wird für die Buchung das eingestellte Standarderlöskonto verwendet. Ansonsten wird das zugeordnete Sachkonto verwendet."
            SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, False, FM.hwnd
            If GlMes = 33565 Then
                S_BaGen
            End If
        End If
    End If
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BaBuc " & Err.Number
Resume Next

End Sub
Public Sub S_BaDop()
On Error GoTo LiErr
'Durchsucht die importierten Kontoumsätze nach doppelten Einträgen

Dim SQL1 As String
Dim GesZa As Long
Dim IdxNr As Long
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qrySimBaDo3 ORDER BY Suche"
Else
    SQL1 = "SELECT * FROM qrySimBaDo3 ORDER BY [Suche];"
End If

Set RS130 = New ADODB.Recordset
RS130.CursorLocation = adUseClient
Set RS130 = DBCmRe0(SQL1, True) 'Doppelte Kontobuchungen
GesZa = RS130.RecordCount
If GesZa > 0 Then
    TeTit = "Doppelte Umsatzeinträge"
    TeMai = "Es wurden " & GesZa & " doppelte Umsatzeinträge. Sollen diese jetzt entfernt werden?"
    TeInh = "Beim Export der Umsätze des Kreditinstitutes kann sich der Zeitraum überschneiden, so dass einige Umsatzeinträge bereits vorhanden sind. Diese werden standardmäßig gekennzeichnet und können optional entfernt werden."
    TeFus = "Die Prüfung auf doppelte Umsatzeinträge prüft die Betreff eines Umsatzes. Ist dieser mind. zweimal vorhanden, wird dieser Eintrag entsprechend farbig kennzeichnet und kann zu einem späteren Zeitpunkt entfernt werden."
    SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, False, FM.hwnd
    Do
    IdxNr = RS130.Fields("ID2").Value
    DBCmEx2 "qrySimBaSel", "@IdSel", "@IdxNr", -1, IdxNr
    If GlMes = 33565 Then
        DBCmEx1 "qrySimBaLo", "@IdxNr", IdxNr
    End If
    RS130.MoveNext
    Loop Until RS130.EOF
End If
RS130.Close
Set RS130 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BaDop " & Err.Number
Resume Next

End Sub

