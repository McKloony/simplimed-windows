                        End If
                        If SumVK > 0 Then
                            DBCmEx2 "qryLabAuSm2", "@IdBet", "@IdxNr", SumVK, AufNr
                        End If

                        If AuGed = False Then
                            DBCmEx2 "qryLabAuMar", "@AuSel", "@IdxNr", -1, AufNr
                            Set RS128 = New ADODB.Recordset 'Ist Bericht schon vorhanden?
                            RS128.CursorLocation = adUseClient
                            Set RS128 = DBCmRe1("qryLabBeNum", "@IdStr", AuStr)
                            If RS128.RecordCount > 0 Then
                                BerID = RS128.Fields("ID0").Value
                            Else
                                NeuAn = True
                            End If
                            RS128.Close
                            Set RS128 = Nothing
    
                            Set RS120 = New ADODB.Recordset
