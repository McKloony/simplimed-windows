                Set CmBrs = Nothing
                Set RpCo2 = Nothing
                Set clFil = Nothing
                Exit Sub
            End If
        End With

        Set RS125 = New ADODB.Recordset 'Patienten
        RS125.CursorLocation = adUseClient
        RS125.Open FiNam, "Provider=MSPersist", , , Options:=adCmdFile
        AnzPa = RS125.RecordCount
    End If
    
    If AnzPa > 0 Then
