Private Sub S_AdEn()
On Error GoTo OpErr
'Entschlüsselt die Adressendaten aus dem Array

Dim AkAdr As Long
Dim FIDKu As String
Dim FName As String
Dim FVorn As String
Dim FStra As String
Dim FBfri As String

For AkAdr = 0 To GlAdA - 1
    If AdAry(Adr_IDKurz, AkAdr) <> vbNullString Then
        If Left$(AdAry(Adr_IDKurz, AkAdr), 1) = "#" Then
            FIDKu = Right$(AdAry(Adr_IDKurz, AkAdr), Len(AdAry(Adr_IDKurz, AkAdr)) - 1)
            AdAry(Adr_IDKurz, AkAdr) = SCrypt(FIDKu, False)
        End If
    End If
    If AdAry(Adr_Name, AkAdr) <> vbNullString Then
        If Left$(AdAry(Adr_Name, AkAdr), 1) = "#" Then
            FName = Right$(AdAry(Adr_Name, AkAdr), Len(AdAry(Adr_Name, AkAdr)) - 1)
            AdAry(Adr_Name, AkAdr) = SCrypt(FName, False)
        End If
    End If
    If AdAry(Adr_Vorname, AkAdr) <> vbNullString Then
        If Left$(AdAry(Adr_Vorname, AkAdr), 1) = "#" Then
            FVorn = Right$(AdAry(Adr_Vorname, AkAdr), Len(AdAry(Adr_Vorname, AkAdr)) - 1)
            AdAry(Adr_Vorname, AkAdr) = SCrypt(FVorn, False)
        End If
    End If
    If AdAry(Adr_Straße, AkAdr) <> vbNullString Then
        If Left$(AdAry(Adr_Straße, AkAdr), 1) = "#" Then
            FStra = Right$(AdAry(Adr_Straße, AkAdr), Len(AdAry(Adr_Straße, AkAdr)) - 1)
            AdAry(Adr_Straße, AkAdr) = SCrypt(FStra, False)
        End If
    End If
    If AdAry(Adr_Briefanrede, AkAdr) <> vbNullString Then
        If Left$(AdAry(Adr_Briefanrede, AkAdr), 1) = "#" Then
            FBfri = Right$(AdAry(Adr_Briefanrede, AkAdr), Len(AdAry(Adr_Briefanrede, AkAdr)) - 1)
            AdAry(Adr_Briefanrede, AkAdr) = SCrypt(FBfri, False)
        End If
    End If
Next AkAdr

Exit Sub

OpErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_AdEn " & Err.Number
Resume Next

End Sub
