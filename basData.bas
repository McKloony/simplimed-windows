Public Sub S_LaPV()
On Error GoTo KoErr
'Parameterabgleich

Dim BerNr As Long
Dim LaKat As Long
Dim RowNr As Long 'Zeilennummer
Dim AnzPo As Integer
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow
Dim Frage As Integer
Dim Mld1, Tit1 As String

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCo5 = FM.repCont5

Select Case GlBut:
Case RibTab_LabBericht:
        Set RpCls = RpCo5.Columns
        Set RpSel = RpCo5.SelectedRows
Case RibTab_LabBerichte:
        Set RpCls = RpCo1.Columns
        Set RpSel = RpCo1.SelectedRows
End Select

AnzPo = RpSel.Count

If AnzPo > 1 Then
    Mld1 = "Möchten Sie für die " & AnzPo & " markierten Berichte jetzt einen Parameterabgleich durchführen?"
Else
    Mld1 = "Möchten Sie für den markierten Bericht jetzt einen Parameterabgleich durchführen?"
End If
Tit1 = "Parameterabgleich"

Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
If Frage = 6 Then
    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            RowNr = RpRow.Index
            Set RpCol = RpCls.Find(Lab_ID0)
            BerNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Lab_ID3)
            LaKat = RpRow.Record(RpCol.ItemIndex).Value

            If GlLiP = True Then 'Laborimport Einheitspreis verwendet
                If GlLiF = True Then 'Laborimport Multiplikator verwendet
                    DBCmEx4 "qryLabTeV7", "@BerNr", "@KatNr", "@IdPre", "@IdMul", BerNr, LaKat, GlLaP, GlLaF
                    DBCmEx4 "qryLabTeV8", "@BerNr", "@KatNr", "@IdPre", "@IdMul", BerNr, LaKat, GlLaP, GlLaF
                Else
                    DBCmEx3 "qryLabTeV3", "@BerNr", "@KatNr", "@IdPre", BerNr, LaKat, GlLaP
                    DBCmEx3 "qryLabTeV4", "@BerNr", "@KatNr", "@IdPre", BerNr, LaKat, GlLaP
                End If
            ElseIf GlLiF = True Then 'Laborimport Multiplikator verwendet
                DBCmEx3 "qryLabTeV5", "@BerNr", "@KatNr", "@IdMul", BerNr, LaKat, GlLaF
                DBCmEx3 "qryLabTeV6", "@BerNr", "@KatNr", "@IdMul", BerNr, LaKat, GlLaF
            Else
                DBCmEx2 "qryLabTeV1", "@BerNr", "@KatNr", BerNr, LaKat
                DBCmEx2 "qryLabTeV2", "@BerNr", "@KatNr", BerNr, LaKat
            End If

        End If
    Next RpRow
    
    DoEvents
    SUpLa RowNr
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing
Set RpCo5 = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_LaPV " & Err.Number
Resume Next

End Sub
Public Sub S_LaReA()
On Error GoTo SuErr
'Erstellt Rechnungen auf Basis von Aufträgen

Dim RowNr As Long 'Zeilennummer
Dim AufNr As Long 'Auftragsnummer
Dim BehNr As Long 'Behandlernummer
Dim PatNr As Long 'Patientennummer
Dim ReKun As Long 'Rechnungsnummer
Dim RePat As Long 'Rechnungsnummer
Dim BeDat As Date 'Berichtdatum
Dim BeKos As Single 'Befundungskosten
Dim SumVK As Single 'Patientenpreis
Dim SumWV As Single 'Wiederverkaufsumme
Dim AuStr As String 'Auftragsnummer
Dim Behan As String 'Behandlername
Dim KomNa As String 'Komplettname
Dim AuWäh As String 'Währungsstring
Dim PatNa As String
Dim PatVo As String
Dim ReStr As String
Dim BeUnf As Boolean
Dim ReErz As Boolean
Dim AuSel As Boolean
Dim AuTyp As Integer 'Auftragstyp
Dim AnzPo As Integer
Dim WärNr As Integer 'Währungsnummer
Dim AktBe As Integer 'Aktuelle Berichtzahl
Dim Frage As Integer
Dim Mld1, Tit1 As String

Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo6 = FM.repCont6
Set RpCo5 = FM.repCont5
Set RpCls = RpCo5.Columns
Set RpSel = RpCo5.SelectedRows
Set PrBr1 = frmStatus.prbStat1
Set PrBr2 = frmStatus.prbStat2
Set TxDum = frmStatus.txtDummy

AnzPo = RpSel.Count
If AnzPo > 1 Then
    Mld1 = "Möchten Sie für die " & AnzPo & " markierten Aufträge jetzt Rechnungen erstellen?"
Else
    Mld1 = "Möchten Sie für den markierten Auftrag jetzt Rechnungen erstellen?"
End If
Tit1 = "Rechnungen Erstellen"
AktBe = 1

If AnzPo > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then
        Set RpRow = RpSel(0)
        If RpRow.GroupRow = False Then
            RowNr = RpRow.Index
            
            PrBr1.Min = 0
            PrBr1.Max = AnzPo
            frmStatus.Show
            DoEvents
            
            For Each RpRow In RpSel
                If RpRow.GroupRow = False Then
                    Set RpCol = RpCls.Find(Lau_IDA)
                    AuStr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Lau_ID1)
                    AufNr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Lau_Typ)
                    AuTyp = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Lau_ID0)
                    BehNr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Lau_IP0)
                    PatNr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Lau_Datum)
                    BeDat = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Lau_Kunde)
                    Behan = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Lau_Name)
                    PatNa = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Lau_Vorname)
                    PatVo = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Lau_BefKosten)
                    BeKos = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Lau_Währung)
                    WärNr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Lau_W)
                    AuWäh = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Lau_Selekt)
                    If RpRow.Record(RpCol.ItemIndex).Checked = True Then
                        AuSel = True
                    Else
                        AuSel = False
                    End If
                    KomNa = PatNa & ", " & PatVo

                    Set RS128 = New ADODB.Recordset
                    RS128.CursorLocation = adUseClient
                    Set RS128 = DBCmRe1("qryLabBeNum", "@IdStr", AuStr)
                    If RS128.RecordCount > 0 Then
                        If RS128.Fields("F").Value = 0 Then
                            BeUnf = True
                        Else
                            BeUnf = False
                        End If
                    End If
                    RS128.Close
                    Set RS128 = Nothing
                    
                    ReErz = False
                    If AuSel = False Then
                        ReErz = True
                    Else
                        Mld1 = "Für den Auftrag " & AuStr & " wurden Bereits Rechnungspositionen erzeugt. Soll trotzdem eine neue Rechnung angelegt werden?"
                        Tit1 = "Rechnungserzeugung"
                        Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
                        If Frage = 6 Then
                            ReErz = True
                        End If
                    End If
                    
                    If ReErz = True Then
                        If AuTyp > 2 Then
                            ReKun = S_LaVo(BehNr, "L")
                            If ReKun = 0 Then
                                S_LaNu BehNr, "L", , , BehNr
                                ReKun = S_LaVo(BehNr, "L")
                            End If
                            RePat = S_LaVo(PatNr, "L")
                            If RePat = 0 Then
                                S_LaNu PatNr, "L", AuStr, BeUnf, BehNr
                                RePat = S_LaVo(PatNr, "L")
                            End If
                        Else
                            ReKun = S_LaVo(BehNr, "L")
                            If ReKun = 0 Then
                                S_LaNu BehNr, "L", , , BehNr
                                ReKun = S_LaVo(BehNr, "L")
                            End If
                        End If
                        Select Case AuTyp
                        Case 1:
                                DBCmEx2 "qryLabRe1", "@IdxNr", "@ReNum", AufNr, ReKun
                        Case 2:
                                DBCmEx2 "qryLabRe2", "@IdxNr", "@ReNum", AufNr, ReKun
                        Case Else:
                                DBCmEx2 "qryLabRe5", "@IdStr", "@IdxNr", Behan, PatNr
                                DBCmEx2 "qryLabRe3", "@IdxNr", "@ReNum", AufNr, RePat
                                DBCmEx2 "qryLabRe2", "@IdxNr", "@ReNum", AufNr, ReKun
                                DBCmEx2 "qryLabRe4", "@IdxNr", "@ReNum", AufNr, RePat
                        End Select
                        If BeKos > 0 Then
                            S_LaBf BehNr, AufNr, ReKun, BeDat, KomNa, BeKos, AuWäh, WärNr
                        End If

                        Set RS127 = New ADODB.Recordset 'Rechnungssummen ermitteln Kunden
                        RS127.CursorLocation = adUseClient
                        If GlIgL = True Then 'Keine Preisberechnung bei IgL
                            Set RS127 = DBCmRe1("qrySimAbSm1", "@IdxNr", ReKun)
                        Else
                            Set RS127 = DBCmRe1("qrySimAbSm", "@IdxNr", ReKun)
                        End If
                        If RS127.RecordCount > 0 Then
                            SumVK = RS127.Fields("VK").Value
                            SumWV = RS127.Fields("LA").Value
                        Else
                            SumVK = 0
                            SumWV = 0
                        End If
                        RS127.Close
                        Set RS127 = Nothing
                        
                        'Rechnungssummen aktualisieren
                        If SumVK > 0 Then DBCmEx2 "qrySimReSm1", "@IdBet", "@IdxNr", SumVK, ReKun
                        If SumWV > 0 Then DBCmEx2 "qrySimReSm2", "@IdBet", "@IdxNr", SumWV, ReKun
                        
                        If AuTyp > 2 Then
                            Set RS126 = New ADODB.Recordset 'Rechnungssummen ermitteln Patienten
                            RS126.CursorLocation = adUseClient
                            If GlIgL = True Then 'Keine Preisberechnung bei IgL
                                Set RS126 = DBCmRe1("qrySimAbSm1", "@IdxNr", RePat)
                            Else
                                Set RS126 = DBCmRe1("qrySimAbSm", "@IdxNr", RePat)
                            End If
                            If RS126.RecordCount > 0 Then
                                SumVK = RS126.Fields("VK").Value
                                SumWV = RS126.Fields("LA").Value
                            Else
                                SumVK = 0
                                SumWV = 0
                            End If
                            RS126.Close
                            Set RS126 = Nothing
                            'Rechnungssummen aktualisieren
                            If SumVK > 0 Then DBCmEx2 "qrySimReSm1", "@IdBet", "@IdxNr", SumVK, RePat
                            If SumWV > 0 Then DBCmEx2 "qrySimReSm2", "@IdBet", "@IdxNr", SumWV, RePat
                        End If
                        
                        DBCmEx2 "qryLabAuSel", "@AuSel", "@IdxNr", -1, AufNr
                    End If
        
                    DoEvents
                    PrBr1.Value = AktBe
                    AktBe = AktBe + 1
                End If
            Next RpRow
            
            DBCmEx0 "qrySimAbRe"
            
            If GlJet = True Then SDBSav
            
            Unload frmStatus
            Set frmStatus = Nothing
            DoEvents
            
            SUpRe
            SUpAu RowNr
            SMark
        End If
    End If
End If

Set RpCls = Nothing
Set RpSel = Nothing
Set RpCo6 = Nothing
Set RpCo5 = Nothing

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_LaReA " & Err.Number
Resume Next

End Sub
Public Sub S_LaReB(ByVal NeuRe As Boolean)
On Error GoTo SuErr
'Erstellt Rechnungen auf Basis von Berichten

Dim RowNr As Long 'Zeilennummer
Dim IdxNr As Long 'Auftragsnummer
Dim MaNum As Long 'Behandlernummer
Dim PatNr As Long 'Patientennummer
Dim ReNum As Long 'Rechnungsnummer
Dim StMan As Long
Dim StMit As Long
Dim BeDat As Date 'Berichtdatum
Dim AuStr As String 'Auftragsnummer
Dim ReStr As String
Dim BfStr As String
Dim NeReB As Double
Dim ReAbg As Boolean
Dim AnzPo As Integer
Dim AktBe As Integer 'Aktuelle Berichtzahl

Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCo5 = FM.repCont5
Set RpCo6 = FM.repCont6

Set PrBr1 = frmStatus.prbStat1
Set PrBr2 = frmStatus.prbStat2
Set TxDum = frmStatus.txtDummy

Select Case GlBut:
Case RibTab_LabBericht:
        Set RpCls = RpCo5.Columns
        Set RpSel = RpCo5.SelectedRows
Case RibTab_LabBerichte:
        Set RpCls = RpCo1.Columns
        Set RpSel = RpCo1.SelectedRows
End Select

StMan = GlMan(GlSMa, 2)
StMit = GlMiA(GlSmI, 2)

AnzPo = RpSel.Count
AktBe = 1

If AnzPo > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        RowNr = RpRow.Index
        
        PrBr1.Min = 0
        PrBr1.Max = AnzPo
        frmStatus.Show
        DoEvents
        
        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                Set RpCol = RpCls.Find(Lab_Auftrag)
                AuStr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Lab_ID0)
                IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Lab_IDP)
                PatNr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Lab_IP0)
                If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                    MaNum = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    MaNum = StMan
                End If
                Set RpCol = RpCls.Find(Lab_Ausgang)
                BeDat = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Lab_Befundung)
                BfStr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Lab_F)
                If RpRow.Record(RpCol.ItemIndex).Checked = True Then
                    ReAbg = True
                Else
                    ReAbg = False
                End If

                If ReAbg = False Then
                    If NeuRe = True Then
                        ReStr = S_ReVo(Date, "L", MaNum, StMit, GlReN)
                        ReNum = K_ReNe(ReStr, Date, PatNr, 0, "L", MaNum, StMit)
                        DoEvents
                    Else
                        If GlRMa = True Then 'getrennter Mandentenrechnungsnummernkreis
                            ReNum = S_ReOf(PatNr, MaNum, "L") 'Ist noch ein unabgeschlossene Rechnung vorhanden?
                        Else
                            ReNum = S_ReOf(PatNr, 0, "L") 'Ist noch ein unabgeschlossene Rechnung vorhanden?
                        End If
                        DoEvents
                        If ReNum = 0 Then
                            ReStr = S_ReVo(Date, "L", MaNum, StMit, GlReN)
                            ReNum = K_ReNe(ReStr, Date, PatNr, 0, "L", MaNum, StMit)
                            DoEvents
                        End If
                    End If
                    DoEvents
                    DBCmEx4 "qryLabRe7", "@PatNr", "@ReNum", "@IdDat", "@BerNr", PatNr, ReNum, BeDat, IdxNr
                    DoEvents
                    NeReB = S_ReBet(ReNum, -10, ReAbg, 0)
                    DoEvents
                    DBCmEx2 "qryLabBeMar", "@BeSel", "@IdxNr", -1, IdxNr
                End If
                
                DoEvents
                PrBr1.Value = AktBe
                AktBe = AktBe + 1
            End If
        Next RpRow

        DBCmEx0 "qrySimAbRe"
        
        If GlJet = True Then SDBSav
        
        Unload frmStatus
        Set frmStatus = Nothing
        DoEvents
        
        SUpRe
        SUpLa RowNr
        SMark
    End If
End If

Set RpCls = Nothing
Set RpSel = Nothing
Set RpCo1 = Nothing
Set RpCo5 = Nothing
Set RpCo6 = Nothing

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_LaReB " & Err.Number
Resume Next

End Sub
