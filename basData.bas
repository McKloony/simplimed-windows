Public Function S_MeAr(ByVal PatNr As Long) As Integer
On Error GoTo SuErr
'Lädt die Arzneimittel in das Array

Dim LetRe As Integer
Dim MedZa As Integer
Dim RezZa As Integer
Dim GesZa As Integer
Dim AktZa As Integer

Set RS155 = New ADODB.Recordset
RS155.CursorLocation = adUseClient
Set RS155 = DBCmRe1("qrySimAbDiRe", "@IdxNr", PatNr)
RezZa = RS155.RecordCount
If RezZa > 0 Then
    GesZa = RezZa
    ReDim MeAry(4, RezZa - 1)
    Do
    MeAry(0, AktZa) = 0
    MeAry(1, AktZa) = 0
    MeAry(2, AktZa) = 0
    MeAry(3, AktZa) = RS155.Fields("IDD").Value
    MeAry(4, AktZa) = RS155.Fields("GOID").Value
    AktZa = AktZa + 1
    RS155.MoveNext
    Loop Until RS155.EOF
End If
RS155.Close
Set RS155 = Nothing

If RezZa = 0 Then
    Set RS125 = New ADODB.Recordset
    RS125.CursorLocation = adUseClient
    Set RS125 = DBCmRe1("qrySimAbDiMd", "@IdxNr", PatNr) 'Aufnahmediagnosen
    GesZa = RS125.RecordCount
    If MedZa > 0 Then
        GesZa = MedZa
        MeAry = RS125.GetRows 'Array Füllen
    End If
    RS125.Close
    Set RS125 = Nothing
End If

S_MeAr = GesZa

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_MeAr " & Err.Number
Resume Next

End Function

Public Function S_OPAn(ByVal NeuDa As Date, Optional ByVal DaAnp As Boolean = False, Optional ByVal MaNum As Long, Optional ByVal EiKto As Long, Optional ByVal GeKto As Integer, Optional ByVal OpBuA As Boolean = True, Optional ByVal OpPru As Boolean = False) As Integer
On Error GoTo LiErr
'Legt offene Posten an

Dim RowNr As Long 'Zeilennummer
Dim PatNr As Long 'Patientennummer
Dim ReNum As Long 'Rechnungsnummer
Dim ManNr As Long 'Behandlernummer
Dim MitNr As Long
Dim GutNr As Long
Dim BuBel As Long
Dim ReJah As Long
Dim AkJah As Long
Dim NeJah As Long
Dim BuJah As Long
Dim GeKoB As Long 'Geldkonto Bankkonto
Dim GeKoK As Long 'Geldkonto Kasse
Dim ErKoB As Long 'Erlöskonto Bankkonto
Dim ErKoK As Long 'Erlöskonto Kasse
Dim EinNr As Long 'Eintragsnummer
Dim GegKt As Long
Dim ErKId As Long
Dim ReDaN As Date 'Neuse Rechnungsdatum
Dim FaDaN As Date 'Neuse Fälligkeitsdatum
Dim ReDat As Date 'Rechnungsdatum
Dim FalDa As Date 'Fälligkeit
Dim MaDat As Date 'Mahnfristdatum
Dim AnBet As Double 'Anzahlungsbetrag
Dim ReBet As Double 'Rechnungsbetrag
Dim BzBet As Double 'Anzahlungen
Dim ReStu As Single 'Steuer
Dim BesSo As Single
Dim BezBe As Double 'bezahlter Betrag für Gutschrift
Dim GutBe As Double
Dim BetBr As Double
Dim BetBu As Double
Dim BetOP As Double
Dim KuStr As String
Dim ReStr As String 'Rechnungsstring
Dim PaNam As String 'Patientenname
Dim BuKom As String 'Kommentar
Dim TyStr As String 'Belegtyp
Dim ReTyp As String 'Belegtyp
Dim PaBLZ As String 'Bankleitzahl
Dim PaKto As String 'Kontonummer
Dim PaBIC As String 'BIC
Dim PaIBN As String 'IBAN
Dim ReKom As String 'Kommentar
Dim GuStr As String 'Gutschriftnummer
Dim TmGui As String
Dim KtStr As String 'Kontenbezeichnung
Dim KaStr As String 'Kassenkennung
Dim AnzPo As Integer
Dim AbgRe As Integer 'Anzahl Abgeschlos.
Dim Warun As Integer 'Währung
Dim ZaInt As Integer 'Intervall
Dim ZieTa As Integer 'Zieltage
Dim ZaZil As Integer 'Zahlungsziel
Dim ZaGel As Integer 'Geldkonto
Dim EinZa As Integer 'Eintragsanzahl
Dim AktZ1 As Integer
Dim AktZ2 As Integer
Dim AktZ3 As Integer
Dim AktZ4 As Integer
Dim AnzSt As Integer
Dim Posit As Integer
Dim AnzOp As Integer
Dim AnzBu As Integer
Dim GegNr As Integer
Dim Versa As Integer
Dim ZiMah As Boolean 'Mahnbar
Dim Verre As Boolean 'Verrechnung
Dim OPGen As Boolean 'Posten generieren
Dim BuGen As Boolean 'Buchung generieren
Dim ReAbg As Boolean 'Rechnung abgeschlossen
Dim TSEBu As Boolean
Dim Kasse As Boolean
Dim SQL1 As String
Dim Mld1, Tit1 As String
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo4 = FM.repCont4
Set RpCo3 = FM.repCont3

Select Case GlBut
Case RibTab_Abrechnung:
    Set RpCls = RpCo3.Columns
    Set RpSel = RpCo3.SelectedRows
Case RibTab_Rechnungen:
    Set RpCls = RpCo4.Columns
    Set RpSel = RpCo4.SelectedRows
End Select

Tit1 = "Rechnung abgeschlossen"
AnzPo = RpSel.Count

If IsDate(NeuDa) = False Then
    NeuDa = Date
End If

NeJah = Year(NeuDa)

Screen.MousePointer = vbHourglass
DoEvents

If AnzPo > 0 Then
    Set RS122 = New ADODB.Recordset
    With RS122 'neuer Posten
        .CursorLocation = adUseClient
        .Source = "qrySimOPNe"
        .ActiveConnection = DB1
        .CursorType = adOpenStatic
        .LockType = adLockOptimistic
        .Open Options:=adCmdTableDirect
    End With
    
    Set RS121 = New ADODB.Recordset
    With RS121 'neue Buchung
        .CursorLocation = adUseClient
        .Source = "qrySimBuNe"
        .ActiveConnection = DB1
        .CursorType = adOpenStatic
        .LockType = adLockOptimistic
        .Open Options:=adCmdTableDirect
    End With
    
    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            ReNum = 0
            ReAbg = False
            OPGen = True  'Posten generieren
            Verre = False 'Verrechnung
            ZiMah = True  'Mahnbar
            ZaGel = 0
            ZieTa = 14
            ZaInt = 7
            
            Set RpCol = RpCls.Find(Rec_ID0)
            PatNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_ID1)
            ReNum = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Type)
            TyStr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_RechNr)
            ReStr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Datum)
            ReDat = CDate(RpRow.Record(RpCol.ItemIndex).Value)
            ReJah = Year(ReDat)
            AkJah = Year(Date)
            
            Select Case GlBut
            Case RibTab_Abrechnung:
                Set RpCol = RpCls.Find(Rec_Selekt)
                ReAbg = CBool(RpRow.Record(RpCol.ItemIndex).Value)
            Case RibTab_Rechnungen:
                Set RpCol = RpCls.Find(Rec_Selekt)
                If LCase(RpRow.Record(RpCol.ItemIndex).Value) = "ja" Then
                    ReAbg = True
                Else
                    ReAbg = False
                End If
            End Select

            If OpPru = True Then 'Prüfen ob offener Posten existiert
                If ReAbg = True Then 'Rechnung bereits abgerechnet
                    Set RS118 = New ADODB.Recordset
                    RS118.CursorLocation = adUseClient
                    Set RS118 = DBCmRe1("qrySimOPRe", "@IdxNr", ReNum)
                    If RS118.RecordCount = 0 Then
                        ReAbg = False
                        NeuDa = ReDat
                        DBCmEx2 "qrySimReSto", "@IdSto", "@IdxNr", False, ReNum 'Stornierung rückgängig
                        DoEvents
                        DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", 0, ReNum 'Bezahltbetrag anpassen
                        DoEvents
                        If GlBuL = True Then 'echtes Löschen erlauben
                            DBCmEx1 "qrySimBuLoP", "@IdxNr", ReNum 'Buchung löschen
                        Else
                            DBCmEx2 "qrySimBuStr", "@IdSto", "@IdxNr", True, ReNum 'Buchung Stornieren
                        End If
                        DBCmEx2 "qrySimAbLoT", "@IdTyp", "@ReNum", 6, ReNum 'Anzahlungen entfernen
                        DoEvents
                        DBCmEx2 "qrySimReSm3", "@IdBet", "@IdxNr", 0, ReNum 'Anzahlungen Nullen
                        DoEvents
                        DBCmEx3 "qrySimBaRec", "@IdBez", "@IdSel", "@IdxNr", 0, 0, ReNum 'Bankzuordnung
                        DoEvents
                        S_BuBa ReNum
                        DoEvents
                    End If
                    RS118.Close
                    Set RS118 = Nothing
                    DoEvents
                End If
            End If

            If ReAbg = False Then 'Rechnung nicht abgeschlossen
                Set RS119 = New ADODB.Recordset
                RS119.CursorLocation = adUseClient
                Set RS119 = DBCmRe1("qrySimReIdx", "@IdxNr", ReNum)
                If RS119.RecordCount > 0 Then
                    DoEvents
                    PatNr = RS119.Fields("ID0").Value
                    If ReStr = "-" Then
                        ReStr = RS119.Fields("RechNr").Value
                    ElseIf Len(ReStr) < 3 Then
                        ReStr = RS119.Fields("RechNr").Value
                    End If
                    If RS119.Fields("Fallig").Value <> vbNullString Then
                        If IsDate(RS119.Fields("Fallig").Value) = True Then
                            FalDa = RS119.Fields("Fallig").Value
                        Else
                            FalDa = Date
                        End If
                    Else
                        FalDa = Date
                    End If
                    If RS119.Fields("IDKurz").Value <> vbNullString Then
                        PaNam = RS119.Fields("IDKurz").Value
                    Else
                        PaNam = vbNullString
                    End If
                    If RS119.Fields("GesBetrag").Value <> vbNullString Then
                        ReBet = Round(RS119.Fields("GesBetrag").Value, 2)
                    Else
                        ReBet = 0
                    End If
                    If RS119.Fields("Anzahlung").Value <> vbNullString Then
                        AnBet = Round(RS119.Fields("Anzahlung").Value, 2)
                    Else
                        AnBet = 0
                    End If
                    If RS119.Fields("Bezahlt").Value <> vbNullString Then
                        BzBet = Round(RS119.Fields("Bezahlt").Value, 2)
                    Else
                        BzBet = 0
                    End If
                    Warun = RS119.Fields("Währung").Value
                    If RS119.Fields("IDZ").Value > 0 Then
                        ZaZil = RS119.Fields("IDZ").Value 'Zahlungsziel
                    Else
                        ZaZil = 1
                    End If
                    If RS119.Fields("Type").Value <> vbNullString Then
                        ReTyp = RS119.Fields("Type").Value
                    Else
                        ReTyp = "R"
                    End If
                    If RS119.Fields("Steuer").Value <> vbNullString Then
                        ReStu = Round(RS119.Fields("Steuer").Value, 2)
                    Else
                        ReStu = 0
                    End If
                    If RS119.Fields("Konto").Value <> vbNullString Then
                        PaKto = RS119.Fields("Konto").Value
                    Else
                        PaKto = vbNullString
                    End If
                    If RS119.Fields("BLZ").Value <> vbNullString Then
                        PaBLZ = RS119.Fields("BLZ").Value
                    Else
                        PaBLZ = vbNullString
                    End If
                    If RS119.Fields("BIC").Value <> vbNullString Then
                        PaBIC = RS119.Fields("BIC").Value
                    Else
                        PaBIC = vbNullString
                    End If
                    If RS119.Fields("IBAN").Value <> vbNullString Then
                        PaIBN = RS119.Fields("IBAN").Value
                    Else
                        PaIBN = vbNullString
                    End If
                    If RS119.Fields("IDP").Value > 0 Then
                        ManNr = RS119.Fields("IDP").Value
                    Else
                        ManNr = GlMan(GlSMa, 2)
                    End If
                    If RS119.Fields("IDM").Value > 0 Then
                        MitNr = RS119.Fields("IDM").Value
                    Else
                        MitNr = GlMiA(GlSmI, 2)
                    End If
                    If RS119.Fields("GuiID").Value > 0 Then
                        TmGui = RS119.Fields("GuiID").Value
                    Else
                        TmGui = CreateID("B")
                    End If
                    If RS119.Fields("Kommentar").Value <> vbNullString Then
                        BuKom = Trim$(RS119.Fields("Kommentar").Value)
                    Else
                        BuKom = vbNullString
                    End If
                    If RS119.Fields("GuStr").Value <> vbNullString Then
                        GuStr = Trim$(RS119.Fields("GuStr").Value)
                    Else
                        GuStr = vbNullString
                    End If
                    If RS119.Fields("GutNr").Value > 0 Then
                        GutNr = RS119.Fields("GutNr").Value
                    Else
                        GutNr = 0
                    End If
                    If (ReBet - BzBet) > 0 Then
                        BetOP = Round(ReBet - BzBet, 2)
                    Else
                        BetOP = 0
                    End If
                    If RS119.Fields("Versand").Value <> vbNullString Then
                        If RS119.Fields("Versand").Value > 0 Then
                            Versa = RS119.Fields("Versand").Value
                        Else
                            Versa = 0
                        End If
                    Else
                        Versa = 0
                    End If
                    For AktZ1 = 1 To UBound(GlZah)
                        If GlZah(AktZ1, 0) = ZaZil Then
                            ZieTa = GlZah(AktZ1, 2)
                            ZiMah = GlZah(AktZ1, 3) 'Mahnbar
                            ZaInt = GlZah(AktZ1, 4)
                            ZaGel = GlZah(AktZ1, 5) 'Geldkonto des Zahlungsziels
                            Exit For
                        End If
                    Next AktZ1
                    
                    If ZieTa = 0 Then
                        ZieTa = 14
                    End If

                    If OpBuA = False Then 'Posten / Buchung generieren
                        OPGen = False 'Posten generieren
                        BuGen = False 'Buchung generieren
                    Else
                        If ZiMah = True Then 'Mahnbar
                            OPGen = True 'Posten generieren
                            BuGen = False 'Buchung generieren
                        Else
                            OPGen = False 'Posten generieren
                            BuGen = True 'Buchung generieren
                        End If
                    End If

                    If MaNum > 0 Then
                        ManNr = MaNum
                    End If

                    If GlMVo = True Then 'mandantenbezogene Vorgaben verwenden
                        For AktZ2 = 1 To UBound(GlMan)
                            If ManNr = GlMan(AktZ2, 2) Then 'Mandantennummer
                                If GlMan(AktZ2, 26) <> vbNullString Then ErKId = GlMan(AktZ2, 26) 'Standarderlöskonto Bank
                                S_KoDe ErKId
                                ErKoB = GlKto.KtoNr
                                If GlMan(AktZ2, 27) <> vbNullString Then ErKId = GlMan(AktZ2, 27) 'Standarderlöskonto Kasse
                                S_KoDe ErKId
                                ErKoK = GlKto.KtoNr
                                If GlMan(AktZ2, 28) <> vbNullString Then GeKoB = GlMan(AktZ2, 28) 'Standardgeldkonto Bankkonto
                                If GlMan(AktZ2, 29) <> vbNullString Then GeKoK = GlMan(AktZ2, 29) 'Standardgeldkonto Kasse
                                Exit For
                            End If
                        Next AktZ2
                    Else
                        ErKoB = GlSE2 'Standarderlöskonto Bankkonto
                        ErKoK = GlSE1 'Standarderlöskonto Kasse
                        GeKoB = GlGkB 'Standardgeldkonto Bankkonto
                        GeKoK = GlGkK 'Standardgeldkonto Kasse
                    End If

                    If GeKto > 0 Then
                        GegNr = GeKto
                    Else
                        If ZaGel > 0 Then
                            GegNr = ZaGel
                        Else
                            If ZiMah = True Then 'Mahnbar
                                GegNr = GeKoB
                            Else
                                GegNr = GeKoK
                            End If
                        End If
                    End If

                    For AktZ3 = 1 To UBound(GlGeK) 'Geldkonten
                        If GlGeK(AktZ3, 0) = GegNr Then
                            If GlGeK(AktZ3, 2) <> vbNullString Then
                                GegKt = CLng(GlGeK(AktZ3, 2))
                                Kasse = CBool(GlGeK(AktZ3, 5))
                                Verre = CBool(GlGeK(AktZ3, 7)) 'Verrechnung
                                KaStr = CStr(GlGeK(AktZ3, 8))
                            Else
                                GegKt = 0
                                Verre = False 'Verrechnung
                            End If
                            Exit For
                        End If
                    Next AktZ3

                    If Verre = True Then 'Verrechnung
                        OPGen = False 'Posten generieren
                        BuGen = False 'Buchung generieren
                    End If

                    For AktZ4 = 1 To UBound(GlErK) 'Erlöskonten
                        If GlErK(AktZ4, 0) = ErKoB Then
                            KtStr = GlErK(AktZ4, 1)
                            Posit = InStr(1, KtStr, Chr$(32), 1)
                            If Posit > 0 Then
                                KtStr = Mid$(KtStr, Posit + 1, Len(KtStr) - Posit)
                            End If
                            Exit For
                        End If
                    Next AktZ4
                    
                    If KtStr = vbNullString Then
                        KtStr = "Umsatzerlöse Allgemein"
                    End If

                    Select Case ReTyp
                    Case "M": 'Rechnungsauftrag
                    Case "V": 'Kostenvoranschlag
                    Case Else:
                        If DaAnp = True Then 'Rechnungsdatum Anpassen
                            If GlRnm = True Then 'Neustart der Rechnungsnummer am Jahresanfang
                                If NeJah <> ReJah Then
                                    ReDaN = CDate("31.12." & ReJah)
                                    If GlLog = True Then SLogi "S_OPAn: Datumsanpassung korrigiert auf " & ReDaN & " (ReNum: " & ReNum & ")"
                                Else
                                    ReDaN = NeuDa
                                End If
                            Else
                                ReDaN = NeuDa
                            End If
                            FaDaN = DateAdd("d", ZieTa, ReDaN)
                        Else
                            ReDaN = ReDat
                            FaDaN = FalDa
                        End If

                        MaDat = FaDaN 'WICHTIG!

                        Select Case ReTyp
                        Case "U": 'Gutschriften
                            OPGen = False
                            BzBet = 0
                        Case "A": 'Abrechnungsstelle
                            ZiMah = False 'Mahnbar
                        End Select
                        DoEvents

                        If OPGen = True Then
                            If ReBet - BzBet > 0 Then
                                RS122.AddNew 'neuer Posten
                                RS122.Fields("ID0").Value = PatNr
                                RS122.Fields("IDR").Value = ReNum
                                RS122.Fields("IDP").Value = ManNr
                                RS122.Fields("IDT").Value = MitNr
                                RS122.Fields("RechNr").Value = ReStr
                                RS122.Fields("Intervall").Value = ZaInt
                                RS122.Fields("Datum").Value = ReDaN
                                RS122.Fields("Fällig").Value = FaDaN
                                RS122.Fields("Betrag").Value = ReBet
                                RS122.Fields("Bezahlt").Value = BzBet
                                RS122.Fields("Offen").Value = BetOP
                                RS122.Fields("Währung").Value = Warun
                                RS122.Fields("Mahnbar").Value = ZiMah 'Mahnbar
                                RS122.Fields("GuiID").Value = TmGui
                                RS122.Fields("IDM").Value = 0
                                RS122.Fields("Mahnfrist").Value = MaDat
                                RS122.Fields("Steuer").Value = ReStu
                                RS122.Fields("Versand").Value = Versa
                                If BuKom <> vbNullString Then
                                    RS122.Fields("Kommentar").Value = Trim$(BuKom)
                                End If
                                If ZaZil = 3 Then 'Lastschriftverfahren
                                    If PaKto <> vbNullString Then RS122.Fields("Konto").Value = PaKto
                                    If PaBLZ <> vbNullString Then RS122.Fields("BLZ").Value = PaBLZ
                                    If PaBIC <> vbNullString Then RS122.Fields("BIC").Value = PaBIC
                                    If PaIBN <> vbNullString Then RS122.Fields("IBAN").Value = PaIBN
                                End If
                                RS122.Update
                                AnzOp = AnzOp + 1
                            ElseIf ReBet = BzBet Then
                                DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", -1, ReNum 'Rechung Bezahlt Kennzeichnen
                            End If

                        Else

                            If BuGen = True Then 'Buchung generieren
                                If BetOP > 0 Then 'offener Betrag
                                    BuJah = Year(ReDaN)

                                    If GlSpl = True Then 'Steuerspalte eingeblendet
                                        AnzSt = 0
                                        Set RS130 = New ADODB.Recordset
                                        RS130.CursorLocation = adUseClient
                                        Set RS130 = DBCmRe1("qrySimAbSm2", "@IdxNr", ReNum)
                                        AnzSt = RS130.RecordCount 'Anzahl Steuersätze

                                        If AnzSt > 0 Then
                                            Do
                                            BuBel = S_BuBel(ManNr, BuJah, GegNr)
                                            DoEvents

                                            ReStu = Round(RS130.Fields("Steuer").Value, 2)
                                            If RS130.Fields("VK").Value > 0 Then
                                                BetBr = Round(RS130.Fields("VK").Value, 2) 'Bruttobetrag
                                            Else
                                                BetBr = 0
                                            End If

                                            If AnzSt > 1 Then 'mehrere Posten und mehrere Steuersätze
                                                If ReBet <> BetOP Then 'Rechnungsbetrag ist ungleich offener Betrag
                                                    BetBu = Round(BetOP / AnzSt, 2)
                                                Else
                                                    BetBu = BetBr 'jeweile Bruttosumme der jeden Steuersatz
                                                End If
                                            Else 'mehrere Posten und ein Steuersatz
                                                BetBu = BetOP
                                            End If
                                            
                                            If ReTyp = "U" Then 'Gutschriften
                                                If ZiMah = True Then 'Mahnbar
                                                    BetBu = 0 'keine Buchung generieren
                                                End If
                                            End If
                                            
                                            If ZiMah = False Then 'Mahnbar
                                                If Kasse = True Then
                                                    If GlTSe > 0 Then 'TSE Aktiviert
                                                        Select Case GlTSe
                                                        Case 1: TSEBu = TSESet(BetBu, ReStu, KaStr)
                                                        Case 2: TSEBu = TSEGen(BetBu, ReStu, KaStr)
                                                        End Select
                                                        If TSEBu = False Then
                                                            BetBu = 0 'WICHTIG!
                                                        End If
                                                    End If
                                                End If
                                            End If

                                            If BetBu > 0 Then
                                                RS121.AddNew 'neue Buchung
                                                If ZiMah = True Then 'Mahnbar
                                                    If GlBuc = True Then 'einfache Buchhaltung verwenden
                                                        If EiKto > 0 Then
                                                            RS121.Fields("IDK").Value = EiKto
                                                        Else
                                                            RS121.Fields("IDK").Value = ErKoB
                                                        End If
                                                        RS121.Fields("IDG").Value = 0
                                                    Else
                                                        If EiKto > 0 Then
                                                            RS121.Fields("IDG").Value = EiKto
                                                        Else
                                                            RS121.Fields("IDG").Value = ErKoB
                                                        End If
                                                        RS121.Fields("IDK").Value = GegKt
                                                        RS121.Fields("Doppelt").Value = -1
                                                    End If
                                                Else
                                                    If GlBuc = True Then 'einfache Buchhaltung verwenden
                                                        If EiKto > 0 Then
                                                            RS121.Fields("IDK").Value = EiKto
                                                        Else
                                                            RS121.Fields("IDK").Value = ErKoK
                                                        End If
                                                        RS121.Fields("IDG").Value = 0
                                                    Else
                                                        If EiKto > 0 Then
                                                            RS121.Fields("IDG").Value = EiKto
                                                        Else
                                                            RS121.Fields("IDG").Value = ErKoK
                                                        End If
                                                        RS121.Fields("IDK").Value = GegKt
                                                        RS121.Fields("Doppelt").Value = -1
                                                    End If
                                                End If
                                                RS121.Fields("IDB").Value = GegNr
                                                RS121.Fields("IDP").Value = PatNr
                                                RS121.Fields("IDA").Value = 2
                                                RS121.Fields("IDR").Value = ReNum
                                                RS121.Fields("IDT").Value = ManNr
                                                RS121.Fields("IDM").Value = MitNr
                                                RS121.Fields("RechNr").Value = ReStr
                                                RS121.Fields("IDKurz").Value = KtStr
                                                RS121.Fields("Steuer").Value = ReStu
                                                RS121.Fields("Buchtext").Value = "Beleg: (" & ReStr & ")"
                                                RS121.Fields("Selekt").Value = True
                                                RS121.Fields("Währung").Value = Warun
                                                RS121.Fields("Beleg").Value = BuBel
                                                RS121.Fields("Datum").Value = ReDaN
                                                RS121.Fields("GuiID").Value = TmGui
                                                RS121.Fields("Einnahme").Value = BetBu
                                                If BuKom <> vbNullString Then
                                                    RS121.Fields("Kommentar").Value = BuKom
                                                End If
                                                If ZiMah = False Then 'Mahnbar
                                                    If TSEBu = True Then
                                                        If GlTyp < 2 Then
                                                            RS121.Fields("TSEString").Value = GlTSB.SigQr
                                                            RS121.Fields("TSEStrSig").Value = GlTSB.SigSt
                                                        End If
                                                        RS121.Fields("TSEZahl").Value = GlTSB.TraZe
                                                        RS121.Fields("TSESign").Value = GlTSB.SigZe
                                                        RS121.Fields("TSELog").Value = GlTSB.ZeLog
                                                    End If
                                                End If
                                                RS121.Update
                                            End If
                                            BetBu = 0
                                            RS130.MoveNext
                                            Loop Until RS130.EOF
                                            AnzBu = AnzBu + 1
                                            DoEvents
                                            
                                            If ZiMah = False Then 'Mahnbar
                                                DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", -1, ReNum
                                                DoEvents
                                                DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", ReBet, ReNum
                                                DoEvents
                                            End If
                                        End If

                                    Else

                                        If ZiMah = False Then 'Mahnbar
                                            If Kasse = True Then
                                                If GlTSe > 0 Then 'TSE Aktiviert
                                                    Select Case GlTSe
                                                    Case 1: TSEBu = TSESet(BetOP, ReStu, KaStr)
                                                    Case 2: TSEBu = TSEGen(BetOP, ReStu, KaStr)
                                                    End Select
                                                    If TSEBu = False Then
                                                        ReBet = 0 'WICHTIG!
                                                    End If
                                                End If
                                            End If
                                        End If

                                        If ReBet > 0 Then
                                            BuBel = S_BuBel(ManNr, BuJah, GegNr)
                                            DoEvents
                                            
                                            If ReTyp = "U" Then 'Gutschriften
                                                RS121.AddNew 'neue Buchung
                                                RS121.Fields("IDA").Value = 1 'Ausgabe
                                                RS121.Fields("IDKurz").Value = "Gutschrift"
                                                RS121.Fields("Ausgabe").Value = ReBet
                                                RS121.Fields("Buchtext").Value = "Gutschrift für (" & GuStr & ")"
                                            Else
                                                RS121.AddNew 'neue Buchung
                                                RS121.Fields("IDA").Value = 2 'Einnahme
                                                RS121.Fields("IDKurz").Value = KtStr
                                                RS121.Fields("Einnahme").Value = BetOP
                                                RS121.Fields("Buchtext").Value = "Beleg: (" & ReStr & ")"
                                            End If
                                            If ZiMah = True Then 'Mahnbar
                                                If GlBuc = True Then 'einfache Buchhaltung verwenden
                                                    If EiKto > 0 Then
                                                        RS121.Fields("IDK").Value = EiKto
                                                    Else
                                                        RS121.Fields("IDK").Value = ErKoB
                                                    End If
                                                    RS121.Fields("IDG").Value = 0
                                                Else
                                                    If EiKto > 0 Then
                                                        RS121.Fields("IDG").Value = EiKto
                                                    Else
                                                        RS121.Fields("IDG").Value = ErKoB
                                                    End If
                                                    RS121.Fields("IDK").Value = GegKt
                                                    RS121.Fields("Doppelt").Value = -1
                                                End If
                                            Else
                                                If GlBuc = True Then 'einfache Buchhaltung verwenden
                                                    If EiKto > 0 Then
                                                        RS121.Fields("IDK").Value = EiKto
                                                    Else
                                                        RS121.Fields("IDK").Value = ErKoK
                                                    End If
                                                    RS121.Fields("IDG").Value = 0
                                                Else
                                                    If EiKto > 0 Then
                                                        RS121.Fields("IDG").Value = EiKto
                                                    Else
                                                        RS121.Fields("IDG").Value = ErKoK
                                                    End If
                                                    RS121.Fields("IDK").Value = GegKt
                                                    RS121.Fields("Doppelt").Value = -1
                                                End If
                                            End If
                                            RS121.Fields("IDB").Value = GegNr
                                            RS121.Fields("IDP").Value = PatNr
                                            RS121.Fields("IDR").Value = ReNum
                                            RS121.Fields("IDT").Value = ManNr
                                            RS121.Fields("IDM").Value = MitNr
                                            RS121.Fields("GuiID").Value = TmGui
                                            RS121.Fields("RechNr").Value = ReStr
                                            RS121.Fields("Datum").Value = ReDaN
                                            RS121.Fields("Währung").Value = Warun
                                            RS121.Fields("Steuer").Value = ReStu
                                            RS121.Fields("Beleg").Value = BuBel
                                            If BuKom <> vbNullString Then
                                                RS121.Fields("Kommentar").Value = BuKom
                                            End If
                                            If ZiMah = False Then
                                                If TSEBu = True Then
                                                    If GlTyp < 2 Then
                                                        RS121.Fields("TSEString").Value = GlTSB.SigQr
                                                        RS121.Fields("TSEStrSig").Value = GlTSB.SigSt
                                                    End If
                                                    RS121.Fields("TSEZahl").Value = GlTSB.TraZe
                                                    RS121.Fields("TSESign").Value = GlTSB.SigZe
                                                    RS121.Fields("TSELog").Value = GlTSB.ZeLog
                                                End If
                                            End If
                                            RS121.Update
                                            AnzBu = AnzBu + 1
                                            DoEvents

                                            If ReTyp = "U" Then 'Gutschriften
                                                If GutNr > 0 Then
                                                    BezBe = Round(S_ReIdx(GutNr, "Bezahlt"), 2)
                                                    If BezBe > 0 Then
                                                        GutBe = Round(BezBe - ReBet, 2)
                                                        If GutBe >= 0 Then
                                                            DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", GutBe, GutNr
                                                        End If
                                                    End If
                                                End If
                                            Else
                                                If ZiMah = False Then 'Mahnbar
                                                    DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", -1, ReNum
                                                    DoEvents
                                                    DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", ReBet, ReNum
                                                End If
                                            End If
                                        End If

                                    End If
                                Else
                                    Mld1 = "Zur Rechnung " & ReStr & " ist bereits ein bezahlter Betrag " & Format$(BzBet, GlWa1) & " vermerkt!"
                                    SPopu Tit1, Mld1, IC48_Forbidden
                                End If
                            Else
                                DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", ReBet, ReNum
                            End If
                        End If
                    End Select
                    DoEvents

                    KuStr = "Rechnung " & ReStr & " vom " & ReDaN
                    If GlRKr = True Then 'Rechnungsvermerk im Krankenblatt
                        DBCmEx7 "qrySimAbAnfu", "@PatNr", "@IdxNr", "@IdRec", "@IdStr", "@IdGui", "@IdDat", "@IdZei", PatNr, 106, ReNum, KuStr, TmGui, ReDaN, TimeValue(Now)
                        DoEvents
                    End If
                    DBCmEx2 "qrySimAbDru", "@IdAbg", "@IdxNr", -1, ReNum
                    DoEvents
                    If GlTSe > 0 Then 'TSE Aktiviert
                        If TSEBu = True Then
                            If GlTyp < 2 Then
                                DBCmEx6 "qrySimReTSE1", "@SigSt", "@IdStr", "@IdLog", "@IdZah", "@IdSig", "@IdxNr", GlTSB.SigSt, GlTSB.SigQr, GlTSB.ZeLog, GlTSB.TraZe, GlTSB.SigZe, ReNum 'TSE Signatur
                            End If
                        End If
                    End If

                    Set RS115 = New ADODB.Recordset 'Alle Positionen dieser Rechnung für Artikel Sollbestand
                    RS115.CursorLocation = adUseClient
                    Set RS115 = DBCmRe2("qrySimAbIdT", "@IdxNr", "@IdTyp", ReNum, 9) 'Nur Artikel
                    If RS115.RecordCount > 0 Then
                    DoEvents
                    Do
                    If RS115.Fields("ID4").Value > 0 Then
                        If RS115.Fields("x").Value > 0 Then
                            EinNr = RS115.Fields("ID4").Value
                            EinZa = RS115.Fields("x").Value
                            Set RS116 = New ADODB.Recordset
                            RS116.CursorLocation = adUseClient
                            Set RS116 = DBCmRe1("qryKat12A", "@IdxNr", EinNr)
                            If RS116.RecordCount > 0 Then
                                DoEvents
                                If RS116.Fields("Bestand_Soll").Value <> vbNullString Then
                                    BesSo = Round(RS116.Fields("Bestand_Soll").Value, 2) 'Sollbestabd
                                Else
                                    BesSo = 0
                                End If
                                DBCmEx2 "qryAnKat4c", "@IdBes", "@IdxNr", BesSo - EinZa, EinNr
                            End If
                            RS116.Close
                            Set RS116 = Nothing
                        End If
                    End If
                    RS115.MoveNext
                    Loop Until RS115.EOF
                    End If
                    RS115.Close
                    Set RS115 = Nothing
                    
                End If
                RS119.Close
                Set RS119 = Nothing
            Else
                AbgRe = AbgRe + 1
            End If
        End If
    Next RpRow

    RS121.Close
    RS122.Close
    Set RS121 = Nothing
    Set RS122 = Nothing

    If GlJet = True Then SDBSav

    If AnzOp > 0 Then
        Mld1 = "Es wurden " & AnzOp & " neue offene Posten angelegt"
        SPopu Tit1, Mld1, IC48_Information
    ElseIf AnzBu > 0 Then
        Mld1 = "Es wurden " & AnzBu & " neue Buchungen in der Buchführung angelegt"
        SPopu Tit1, Mld1, IC48_Information
    ElseIf AbgRe > 0 Then
        If OpPru = True Then
            If OpBuA = False Then
                If AbgRe = 1 Then
                    Mld1 = "Für diese Rechnung existiert bereits ein offener Posten"
                Else
                    Mld1 = "Für diese Rechnungen existieren bereits offene Posten"
                End If
                SPopu Tit1, Mld1, IC48_Information
            End If
        End If
    End If
End If

S_OPAn = AbgRe

DoEvents
Screen.MousePointer = vbNormal

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing
Set RpCo4 = Nothing

Exit Function

LiErr:
If GlDbg = True Then SErLog Err.Description & " S_OPAn " & Err.Number
Resume Next

End Function
Public Sub S_OPAu(ByVal BetBz As Double, ByVal BuDat As Date, ByVal MaNum As Long, ByVal MiNum As Long, ByVal KtoID As Long, ByVal KtoNr As Long, KtoSt As String, ByVal GeKId As Integer, ByVal GeKNr As Long, ByVal GeKBe As String, ByVal StKID As Long, ByVal StKNr As Long, ByVal StKBe As String)
On Error GoTo KoErr
'Gleicht einen offenen Posten aus

Dim OpNum As Long   'Postennummer
Dim RowNr As Long   'Zeilennummer
Dim PatNr As Long
Dim ManNr As Long
Dim MitNr As Long
Dim ReNum As Long   'Rechnungsnummer
Dim BuBel As Long
Dim BuJah As Long
Dim OpDat As Date   'Datum offener Posten
Dim ReStu As Single 'Steuer
Dim BuStu As Single 'Steuer
Dim BetRe As Double 'Rechnungsbetrag
Dim BetOP As Double 'Offener Betrag
Dim BetGe As Double
Dim BetDf As Double
Dim BetAn As Double
Dim BetBu As Double
Dim BetBr As Double
Dim BetNe As Double
Dim BetSt As Double
Dim ReStr As String 'Rechnungsnummer
Dim PaNam As String 'Patientenname
Dim TmGui As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim TSENa As String  'Kassenkennung
Dim AnzPo As Integer 'Anzahl Posten
Dim AktPo As Integer
Dim BuTyp As Integer
Dim Warun As Integer
Dim AktZa As Integer
Dim AktKo As Integer
Dim AnzSt As Integer
Dim Posit As Integer
Dim Frage As Integer
Dim OpAus As Boolean
Dim TeAus As Boolean
Dim OpBel As Boolean
Dim Kasse As Boolean
Dim Verre As Boolean
Dim Gefun As Boolean 'Geldkonto gefunden
Dim TSEBu As Boolean
Dim Mld1, Tit1 As String
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows

BuTyp = 2 'Einnahme
AnzPo = RpSel.Count

BetBz = Round(BetBz, 2)

If AnzPo > 0 Then
    If AnzPo > 1 Then
        Load frmStatus
        frmStatus.Caption = "Postenausgleich"
        Set Lbl01 = frmStatus.lblLab01
        Set PrBr1 = frmStatus.prbStat1
        Set PrBr2 = frmStatus.prbStat2
        Set TxDum = frmStatus.txtDummy
        Lbl01.Caption = "Bitte warten..."
        PrBr1.Min = 0
        PrBr1.Max = AnzPo
        frmStatus.Show
        DoEvents
    End If

    Set RS121 = New ADODB.Recordset
    With RS121 'neue Buchung
        .CursorLocation = adUseClient
        .Source = "qrySimBuNe"
        .ActiveConnection = DB1
        .CursorType = adOpenStatic
        .LockType = adLockOptimistic
        .Open Options:=adCmdTableDirect
    End With

    If RS121.Supports(adAddNew) Then
        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                RowNr = RpRow.Index
                
                Set RpCol = RpCls.Find(OPo_OffBetrag)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    BetOP = Round(RpRow.Record(RpCol.ItemIndex).Value, 2)
                Else
                    BetOP = 0
                End If
                Set RpCol = RpCls.Find(OPo_ID1)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    OpNum = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    OpNum = 0
                End If
                Set RpCol = RpCls.Find(OPo_ID0)
                If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                    PatNr = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    PatNr = 0
                End If
                Set RpCol = RpCls.Find(OPo_IDR)
                If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                    ReNum = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    ReNum = 0
                End If
                Set RpCol = RpCls.Find(OPo_Beleg)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    If RpRow.Record(RpCol.ItemIndex).Value <> "0" Then
                        OpBel = True
                    Else
                        OpBel = False
                    End If
                Else
                    OpBel = False
                End If
                Set RpCol = RpCls.Find(OPo_RechNr)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    ReStr = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    ReStr = vbNullString
                End If
                Set RpCol = RpCls.Find(OPo_ReBetrag)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    BetRe = Round(RpRow.Record(RpCol.ItemIndex).Value, 2)
                Else
                    BetRe = 0
                End If
                Set RpCol = RpCls.Find(OPo_Patient)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    PaNam = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    PaNam = vbNullString
                End If
                Set RpCol = RpCls.Find(OPo_Datum)
                If IsDate(RpRow.Record(RpCol.ItemIndex).Value) = True Then
                    OpDat = CDate(RpRow.Record(RpCol.ItemIndex).Value)
                Else
                    OpDat = Date
                End If
                Set RpCol = RpCls.Find(OPo_Währung)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    Warun = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    Warun = 1
                End If
                Set RpCol = RpCls.Find(OPo_Steuer)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    ReStu = Round(RpRow.Record(RpCol.ItemIndex).Value, 2)
                Else
                    ReStu = 0
                End If
                Set RpCol = RpCls.Find(OPo_Bezahlt)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    BetAn = Round(RpRow.Record(RpCol.ItemIndex).Value, 2)
                Else
                    BetAn = 0
                End If
                Set RpCol = RpCls.Find(OPo_Gebuehr)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    BetGe = Round(RpRow.Record(RpCol.ItemIndex).Value, 2)
                Else
                    BetGe = 0
                End If
                Set RpCol = RpCls.Find(OPo_IDP)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    ManNr = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    ManNr = GlMan(GlSMa, 2)
                End If
                Set RpCol = RpCls.Find(OPo_IDT)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    MitNr = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    MitNr = GlMiA(GlSmI, 2)
                End If
                Set RpCol = RpCls.Find(OPo_GuiID)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    TmGui = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    TmGui = CreateID("B")
                End If
                Set RpCol = RpCls.Find(OPo_Selekt)
                OpAus = CBool(RpRow.Record(RpCol.ItemIndex).Value)

                If MaNum > 0 Then
                    ManNr = MaNum
                End If
                If MiNum > 0 Then
                    MitNr = MiNum
                End If

                Set RS117 = New ADODB.Recordset
                Set RS117 = DBCmRe1("qrySimOpSel", "@IdxNr", OpNum)
                If RS117.RecordCount > 0 Then
                    TeAus = CBool(RS117.Fields("Selekt").Value)
                Else
                    TeAus = OpAus
                End If
                RS117.Close
                Set RS117 = Nothing
                DoEvents
                
                If OpAus <> TeAus Then
                    Unload frmStatus
                    Set frmStatus = Nothing
                    Screen.MousePointer = vbNormal
                    
                    Set RpSel = RpCo1.SelectedRows
                    If RpSel.Count > 0 Then
                        Set RpRow = RpSel(0)
                        RowNr = RpRow.Index
                        SUpOp RowNr
                    End If

                    TeTit = "Posten bereits gebucht"
                    TeMai = "Der Posten " & ReStr & " wurde bereits gebucht"
                    TeInh = "Der Posten " & ReStr & " wurde bereits anderweitig gebucht, dieser Vorgang wird daher unterbrochen, um die Postenliste zu aktualisieren."
                    TeFus = "Gegebenenfalls wurden eine oder mehrere der markierten Posten in zwischenzeitlich an einem anderen Arbeitsplatz gebucht."
                    
                    SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, True, FM.hwnd
                    Exit Sub
                End If
                
                If ReNum > 0 Then
                    Gefun = False
                    If OpBel = False Then
                        If OpAus = False Then 'Posten ausgeglichen / Kontoauszug bezahlen
                            BuJah = Year(BuDat)
                            If AnzPo > 1 Then 'mehrere Posten selektiert
                                If GlMVo = True Then 'mandantenbezogene Vorgaben verwenden
                                    For AktZa = 1 To UBound(GlMan)
                                        If ManNr = GlMan(AktZa, 2) Then 'Mandantennummer
                                            If GlMan(AktZa, 28) <> vbNullString Then GeKId = GlMan(AktZa, 28) 'Geldkonto Bank
                                            If GlMan(AktZa, 26) <> vbNullString Then KtoID = GlMan(AktZa, 26) 'Erlöskonto Bank
                                            If GlMan(AktZa, 37) <> vbNullString Then StKID = GlMan(AktZa, 37) 'Steuerkonto
                                            Exit For
                                        End If
                                    Next AktZa
                                End If
                            End If

                            For AktZa = 1 To UBound(GlGeK) 'Geldkonten
                                If GlGeK(AktZa, 0) = GeKId Then
                                    Kasse = CBool(GlGeK(AktZa, 5))
                                    Verre = CBool(GlGeK(AktZa, 7))
                                    TSENa = CStr(GlGeK(AktZa, 8))
                                    Gefun = True
                                    Exit For
                                End If
                            Next AktZa

                            If Gefun = False Then
                                S_KoDe GeKId
                                With GlKto
                                    GeKNr = .KtoNr
                                    GeKBe = .KtBez
                                    GeKId = .KtBnk
                                End With
                                For AktZa = 1 To UBound(GlGeK) 'Geldkonten
                                    If GlGeK(AktZa, 0) = GeKId Then
                                        Kasse = CBool(GlGeK(AktZa, 5))
                                        Verre = CBool(GlGeK(AktZa, 7))
                                        TSENa = CStr(GlGeK(AktZa, 8))
                                        Exit For
                                    End If
                                Next AktZa
                            End If

                            If AnzPo > 1 Then 'mehrere Posten selektiert
                                If GlMVo = True Then 'mandantenbezogene Vorgaben verwenden
                                    If GlBuc = True Then 'einfache Buchhaltung verwenden
                                        For AktZa = 1 To UBound(GlGeK) 'Geldkonten
                                            If GlGeK(AktZa, 0) = GeKId Then
                                                GeKBe = GlGeK(AktZa, 1)
                                                GeKNr = GlGeK(AktZa, 2)
                                                Exit For
                                            End If
                                        Next AktZa
                                    Else
                                        S_KoDe GeKId
                                        With GlKto
                                            GeKNr = .KtoNr
                                            GeKBe = .KtBez
                                        End With
                                    End If
                                    S_KoDe KtoID
                                    With GlKto
                                        KtoNr = .KtoNr
                                        KtoSt = .KtBez
                                    End With
                                    S_KoDe StKID
                                    With GlKto
                                        StKNr = .KtoNr
                                        StKBe = .KtBez
                                    End With
                                End If
                            End If

                            If GlSpl = True Then 'Steuerspalte eingeblendet
                                AnzSt = 0
                                Set RS130 = New ADODB.Recordset
                                RS130.CursorLocation = adUseClient
                                Set RS130 = DBCmRe1("qrySimAbSm2", "@IdxNr", ReNum)
                                AnzSt = RS130.RecordCount 'Anzahl Steuersätze

                                If AnzSt > 0 Then
                                    Do
                                    BuBel = S_BuBel(ManNr, BuJah, GeKId)
                                    DoEvents
                                    
                                    ReStu = CSng(RS130.Fields("Steuer").Value)
                                    If RS130.Fields("VK").Value > 0 Then
                                        BetBr = Round(RS130.Fields("VK").Value, 2) 'Bruttobetrag
                                    Else
                                        BetBr = 0
                                    End If

                                    If AnzPo > 1 Then 'mehrere Posten
                                        If AnzSt > 1 Then 'mehrere Posten und mehrere Steuersätze
                                            If BetRe <> BetOP Then 'Rechnungsbetrag ist ungleich offener Betrag
                                                BetBu = Round(BetOP / AnzSt, 2)
                                            Else
                                                BetBu = BetBr 'jeweile Bruttosumme der jeden Steuersatz
                                            End If
                                        Else 'mehrere Posten und ein Steuersatz
                                            BetBu = BetOP
                                        End If
                                    Else 'ein Posten
                                        If AnzSt > 1 Then 'ein Posten und mehrere Steuersätze
                                            If BetRe <> BetBz Then 'Rechnungsbetrag ist ungleich bezahlter Betrag
                                                BetBu = Round(BetBz / AnzSt, 2)
                                            Else
                                                BetBu = BetBr 'jeweile Bruttosumme der jeden Steuersatz
                                            End If
                                        Else 'ein Posten und ein Steuersatz
                                            BetBu = BetBz 'bezahlter Betrag
                                        End If
                                    End If

                                    If Kasse = True Then
                                        If GlTSe > 0 Then 'TSE Aktiviert
                                            Select Case GlTSe
                                            Case 1: TSEBu = TSESet(BetBu, ReStu, TSENa)
                                            Case 2: TSEBu = TSEGen(BetBu, ReStu, TSENa)
                                            End Select
                                            If TSEBu = False Then
                                                BetBu = 0 'WICHTIG!
                                            End If
                                        End If
                                    End If

                                    If BetBu > 0 Then
                                        RS121.AddNew 'neue Buchung
                                        RS121.Fields("IDP").Value = PatNr
                                        RS121.Fields("IDB").Value = GeKId
                                        If GlBuc = True Then 'einfache Buchhaltung verwenden
                                            RS121.Fields("IDK").Value = KtoNr
                                            RS121.Fields("IDG").Value = GeKNr
                                            RS121.Fields("IDKurz").Value = KtoSt
                                            RS121.Fields("IDGegen").Value = GeKBe
                                        Else
                                            RS121.Fields("IDK").Value = GeKNr
                                            RS121.Fields("IDG").Value = KtoNr
                                            RS121.Fields("IDKurz").Value = GeKBe
                                            RS121.Fields("IDGegen").Value = KtoSt
                                            RS121.Fields("Doppelt").Value = -1
                                        End If
                                        RS121.Fields("IDA").Value = BuTyp
                                        RS121.Fields("IDR").Value = ReNum
                                        RS121.Fields("IDT").Value = ManNr
                                        RS121.Fields("IDM").Value = MitNr
                                        RS121.Fields("RechNr").Value = ReStr
                                        RS121.Fields("Steuer").Value = ReStu
                                        RS121.Fields("Buchtext").Value = "Beleg: (" & ReStr & ")"
                                        RS121.Fields("Selekt").Value = True
                                        RS121.Fields("Währung").Value = Warun
                                        RS121.Fields("Beleg").Value = BuBel
                                        RS121.Fields("Datum").Value = BuDat 'Dialogdatum
                                        RS121.Fields("Einnahme").Value = BetBu
                                        RS121.Fields("GuiID").Value = TmGui
                                        If BetAn > 0 Then
                                            RS121.Fields("Kommentar").Value = "Anzahlung oder Restbetrag : € " & Format$(BetAn, GlWa1)
                                        End If
                                        If Kasse = True Then
                                            If TSEBu = True Then
                                                If GlTyp < 2 Then
                                                    RS121.Fields("TSEString").Value = GlTSB.SigQr
                                                    RS121.Fields("TSEStrSig").Value = GlTSB.SigSt
                                                End If
                                                RS121.Fields("TSEZahl").Value = GlTSB.TraZe
                                                RS121.Fields("TSESign").Value = GlTSB.SigZe
                                                RS121.Fields("TSELog").Value = GlTSB.ZeLog
                                            End If
                                        End If
                                        RS121.Update
                                    End If
                                    BetBu = 0
                                    RS130.MoveNext
                                    Loop Until RS130.EOF
                                End If
                                RS130.Close
                                Set RS130 = Nothing
                            
                            Else 'Steuerspalte nicht eingeblendet

                                BuBel = S_BuBel(ManNr, BuJah, GeKId)
                                DoEvents

                                If AnzPo > 1 Then 'mehrere Posten vorhanden
                                    BetBz = BetOP
                                End If

                                If GlSpB = True Then 'Umsatzsteuer Splittbuchung
                                    If ReStu > 0 Then
                                        BetSt = Round((BetBz * ReStu) / (ReStu + 100), 2)
                                        BetNe = Round(BetBz - BetSt, 2)
                                        BuStu = 0
                                    Else
                                        BetSt = 0
                                        BetNe = BetBz
                                        BuStu = 0
                                    End If
                                Else
                                    BetSt = 0
                                    BuStu = ReStu
                                End If

                                If Kasse = True Then
                                    If GlTSe > 0 Then 'TSE Aktiviert
                                        Select Case GlTSe
                                        Case 1: TSEBu = TSESet(BetBz, BuStu, TSENa)
                                        Case 2: TSEBu = TSEGen(BetBz, BuStu, TSENa)
                                        End Select
                                        If TSEBu = False Then
                                            BetBz = 0 'WICHTIG!
                                        End If
                                    End If
                                End If

                                If BetBz > 0 Then
                                    RS121.AddNew 'neue Buchung
                                    RS121.Fields("IDP").Value = PatNr
                                    RS121.Fields("IDB").Value = GeKId
                                    If GlBuc = True Then 'einfache Buchhaltung verwenden
                                        RS121.Fields("IDK").Value = KtoNr
                                        RS121.Fields("IDG").Value = GeKNr
                                        RS121.Fields("IDKurz").Value = KtoSt
                                        RS121.Fields("IDGegen").Value = GeKBe
                                    Else
                                        RS121.Fields("IDK").Value = GeKNr
                                        RS121.Fields("IDG").Value = KtoNr
                                        RS121.Fields("IDKurz").Value = GeKBe
                                        RS121.Fields("IDGegen").Value = KtoSt
                                        RS121.Fields("Doppelt").Value = -1
                                    End If
                                    RS121.Fields("IDA").Value = BuTyp
                                    RS121.Fields("IDR").Value = ReNum
                                    RS121.Fields("IDT").Value = ManNr
                                    RS121.Fields("IDM").Value = MitNr
                                    RS121.Fields("RechNr").Value = ReStr
                                    RS121.Fields("Steuer").Value = BuStu
                                    RS121.Fields("Buchtext").Value = "Beleg: (" & ReStr & ")"
                                    RS121.Fields("Selekt").Value = True
                                    RS121.Fields("Währung").Value = Warun
                                    RS121.Fields("Beleg").Value = BuBel
                                    RS121.Fields("Datum").Value = BuDat
                                    If GlSpB = True Then 'Umsatzsteuer Splittbuchung
                                        RS121.Fields("Einnahme").Value = BetNe
                                    Else
                                        RS121.Fields("Einnahme").Value = BetBz
                                    End If
                                    RS121.Fields("GuiID").Value = TmGui
                                    If BetAn > 0 Then
                                        RS121.Fields("Kommentar").Value = "Anzahlung oder Restbetrag : € " & Format$(BetAn, GlWa1)
                                    End If
                                    If Kasse = True Then
                                        If TSEBu = True Then
                                            If GlTyp < 2 Then
                                                RS121.Fields("TSEString").Value = GlTSB.SigQr
                                                RS121.Fields("TSEStrSig").Value = GlTSB.SigSt
                                            End If
                                            RS121.Fields("TSEZahl").Value = GlTSB.TraZe
                                            RS121.Fields("TSESign").Value = GlTSB.SigZe
                                            RS121.Fields("TSELog").Value = GlTSB.ZeLog
                                        End If
                                    End If
                                    RS121.Update
                                    
                                    If GlSpB = True Then 'Umsatzsteuer Splittbuchung
                                        If ReStu > 0 Then
                                            BuBel = S_BuBel(ManNr, BuJah, GeKId)
                                            DoEvents

                                            RS121.AddNew 'neue Buchung
                                            RS121.Fields("IDP").Value = PatNr
                                            RS121.Fields("IDB").Value = GeKId
                                            If GlBuc = True Then 'einfache Buchhaltung verwenden
                                                RS121.Fields("IDK").Value = KtoNr
                                                RS121.Fields("IDG").Value = GeKNr
                                                RS121.Fields("IDKurz").Value = KtoSt
                                                RS121.Fields("IDGegen").Value = GeKBe
                                            Else
                                                RS121.Fields("IDK").Value = KtoNr
                                                RS121.Fields("IDG").Value = StKNr
                                                RS121.Fields("IDKurz").Value = KtoSt
                                                RS121.Fields("IDGegen").Value = StKBe
                                                RS121.Fields("Doppelt").Value = -1
                                            End If
                                            RS121.Fields("IDA").Value = BuTyp
                                            RS121.Fields("IDR").Value = ReNum
                                            RS121.Fields("IDT").Value = ManNr
                                            RS121.Fields("IDM").Value = MitNr
                                            RS121.Fields("RechNr").Value = ReStr
                                            RS121.Fields("Steuer").Value = BuStu
                                            RS121.Fields("Buchtext").Value = "Beleg: (" & ReStr & ")"
                                            RS121.Fields("Selekt").Value = True
                                            RS121.Fields("Währung").Value = Warun
                                            RS121.Fields("Beleg").Value = BuBel
                                            RS121.Fields("Datum").Value = BuDat
                                            RS121.Fields("Einnahme").Value = BetSt 'Steuerbetrag
                                            RS121.Fields("GuiID").Value = TmGui
                                            If Kasse = True Then
                                                If TSEBu = True Then
                                                    If GlTyp < 2 Then
                                                        RS121.Fields("TSEString").Value = GlTSB.SigQr
                                                        RS121.Fields("TSEStrSig").Value = GlTSB.SigSt
                                                    End If
                                                    RS121.Fields("TSEZahl").Value = GlTSB.TraZe
                                                    RS121.Fields("TSESign").Value = GlTSB.SigZe
                                                    RS121.Fields("TSELog").Value = GlTSB.ZeLog
                                                End If
                                            End If
                                            RS121.Update
                                        End If
                                    End If
                                End If
                                                            
                            End If
    
                            If AnzPo > 1 Then
                                BetDf = Round(BetOP - BetRe, 2) 'Rechnungsbetrag
                            Else
                                BetDf = Round(BetOP - BetBz, 2) 'Dialogbetrag
                            End If
                            If BetDf < 0.02 Then 'Rundungsfehler ausgleichen
                                BetBu = 0
                            Else
                                BetBu = BetDf
                            End If
                            
                            If BetBu <= 0 Then
                                DBCmEx2 "qrySimOPAu1", "@PaSum", "@IdxNr", BetRe, OpNum 'Rechnungsbetrag
                                DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", BetRe, ReNum 'Rechnungsbetrag
                                DBCmEx2 "qrySimOPAu3", "@PaSel", "@IdxNr", -1, OpNum
                                DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", -1, ReNum 'Rechung Bezahlt Kennzeichnen
                            Else
                                DBCmEx2 "qrySimOPAu1", "@PaSum", "@IdxNr", BetBz, OpNum 'Dialogbetrag
                                DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", BetRe - BetBu, ReNum
                            End If
                            DBCmEx2 "qrySimOPAu2", "@PaSum", "@IdxNr", BetBu, OpNum
                            DBCmEx2 "qrySimOPAu4", "@IdDat", "@IdxNr", BuDat, OpNum 'Dialogdatum
    
                            GlNeK = GlKoX 'Protokolleintrag
                            With GlNeK
                                .PatNr = ManNr
                                .IdxNr = 0
                                .EiDat = Format$(Date, "dd.mm.yyyy")
                                .EiZei = TimeValue(Now)
                                .EiTyp = 104
                                .ZiStr = Format$(Now, "hh:mm") & " Uhr"
                                .NeuEi = True
                                .KeiAk = True
                                .Mitar = GlMiA(GlSmI, 2)
                                .TeStr = "Offener Posten ausgeglichen - " & ReStr & " - " & PaNam
                            End With
                            S_Prot

                            If AnzPo = 1 Then
                                If BetBz > BetOP Then
                                    TeTit = "Guthaben hinzufügen"
                                    TeMai = "Soll der überschüssige Betrag als Guthaben hinzugefügt werden?"
                                    TeInh = "Der vom Patienten beglichene Betrag von " & Format$(BetBz, GlWa1) & " ist größer als der noch zu zahlende Betrag von " & Format$(BetOP, GlWa1) & ". Soll dem Patienten dieser Betrag als Guthaben hinzugefügt werden?"
                                    TeFus = "Ein vorhandenes Guthaben kann zu einem späteren Zeitpunkt mit einer anderen Rechnnung des Patienten verrechnet werden."
                                    SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, False, FM.hwnd
                                    If GlMes = 33565 Then
                                        S_PaGu PatNr, BetBz - BetOP
                                    End If
                                End If
                            End If
                        Else
                            Mld1 = "Dem markierten offenen Posten wurde bereits ausgeglichen."
                            Tit1 = "Kontoauszug bereits ausgeglichen"
                            SPopu Tit1, Mld1, IC48_Forbidden
                        End If
                    Else
                        Mld1 = "Dem markierten offenen Posten wurde bereits eine Kontoauszugsbuchung zugeordnet."
                        Tit1 = "Kontoauszug zugeordnet"
                        SPopu Tit1, Mld1, IC48_Forbidden
                    End If
                End If
            
            End If

            If AnzPo > 1 Then
                AktPo = AktPo + 1
                If TxDum.Text = "B" Then Exit For 'Abbrechen
                PrBr1.Value = AktPo
                DoEvents
            End If
        Next RpRow
        
        If AktPo > 1 Then
            Unload frmStatus
            Set frmStatus = Nothing
            DoEvents
        End If
    End If
    
    RS121.Close
    Set RS121 = Nothing
    
    If GlJet = True Then SDBSav
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing

Exit Sub

KoErr:
If GlDbg = True Then SErLog Err.Description & " S_OPAu " & Err.Number
Resume Next

End Sub
Public Sub S_OPBe()
On Error GoTo LiErr
'Hebt die Zuordnung wieder auf

Dim OpNum As Long
Dim RowNr As Long
Dim AnzPo As Long
Dim PatNr As Long
Dim ReNum As Long
Dim BuNum As Long
Dim PaStr As String
Dim BeStr As String
Dim OpAuf As Boolean
Dim OpAus As Boolean
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows

AnzPo = RpSel.Count
If AnzPo > 1 Then
    Mld1 = "Möchten Sie für die " & AnzPo & " markierten Posten die Zuordnung der Kontoumsätze aufheben?"
Else
    Mld1 = "Möchten Sie für den markierten Posten die Zuordnung des Kontoauszuges aufheben?"
End If
Tit1 = "Zuordnung Aufheben"

If AnzPo > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then
        Screen.MousePointer = vbHourglass
    
        OpAuf = True
        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                RowNr = RpRow.Index
                Set RpCol = RpCls.Find(OPo_ID1)
                OpNum = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(OPo_IDR)
                ReNum = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(OPo_Patient)
                PaStr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(OPo_ID0)
                PatNr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(OPo_Selekt)
                OpAus = CBool(RpRow.Record(RpCol.ItemIndex).Value)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    BeStr = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    BeStr = vbNullString
                End If
                If OpAus = True Then
                    OpAuf = False
                    Mld1 = "Dieser Posten wurde bereits ausgeglichen, Aufhebung nicht möglich."
                    SPopu Tit1, Mld1, IC48_Information
                End If
                If BeStr = vbNullString Then
                    OpAuf = False
                    Mld1 = "Dieser Posten besitzt keine Zuordnung."
                    SPopu Tit1, Mld1, IC48_Information
                End If
                If OpAuf = True Then
                    DoEvents
                    DBCmEx2 "qrySimOPBel", "@IdStr", "@IdxNr", "0", OpNum
                    DoEvents
                    DBCmEx3 "qrySimBaRec", "@IdBez", "@IdSel", "@IdxNr", 0, 0, ReNum
                    DoEvents
                    S_BuBa OpNum, True
                    DoEvents
                End If
            End If
        Next RpRow
        SUpOp RowNr
        
        DoEvents
        P_List "BaPo", 0, 1
        
        Screen.MousePointer = vbNormal
    End If
End If

If Frage = 6 Then
    GlNeK = GlKoX 'Protokolleintrag
    With GlNeK
        If PatNr > 0 Then
            .PatNr = PatNr
        Else
            .PatNr = GlMan(GlSMa, 2)
        End If
        .IdxNr = 0
        .EiDat = Format$(Date, "dd.mm.yyyy")
        .EiZei = TimeValue(Now)
        .EiTyp = 104
        .TeStr = "Offener Posten Zuordnung aufgehoben - " & PaStr
        .ZiStr = Format$(Now, "hh:mm") & " Uhr"
        .NeuEi = True
        .KeiAk = True
        .Mitar = GlMiA(GlSmI, 2)
    End With
    S_Prot
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_OPBe " & Err.Number
Resume Next

End Sub
Public Function S_OPIdx(ByVal IdxNr As Long, ByVal FelNa As String) As String
On Error GoTo LoErr
'Gibt Postendetails wieder

Set RS127 = New ADODB.Recordset
RS127.CursorLocation = adUseClient
Set RS127 = DBCmRe1("qrySimOPIdx", "@IdxNr", IdxNr)
If RS127.RecordCount > 0 Then
    DoEvents
    If RS127.Fields(FelNa).Value <> vbNullString Then
        S_OPIdx = RS127.Fields(FelNa).Value
    Else
        Select Case FelNa
        Case "Währung": S_OPIdx = GlWar(GlStW, 0)
        Case "Steuer": S_OPIdx = 0
        Case "Bezahlt": S_OPIdx = 0
        Case Else: S_OPIdx = vbNullString
        End Select
    End If
Else
    Select Case FelNa
    Case "Währung": S_OPIdx = GlWar(GlStW, 0)
    Case "Steuer": S_OPIdx = 0
    Case "Bezahlt": S_OPIdx = 0
    Case Else: S_OPIdx = vbNullString
    End Select
End If
RS127.Close
Set RS127 = Nothing

Exit Function

LoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_OPIdx " & Err.Number
Resume Next

End Function
Public Sub S_OPMa(ByVal MaErh As Boolean, Optional ByVal Aktua As Boolean = False, Optional ByVal KeiFr As Boolean = False)
On Error GoTo LiErr
'Erhöht die Mahnstufe

Dim OpNum As Long
Dim RowNr As Long
Dim Fallg As Date
Dim MaFrA As Date 'Alte Mahnfrist
Dim MaFrN As Date 'Neue Mahnfrist
Dim AnzPo As Long
Dim AktPo As Long
Dim BetOf As Double
Dim MaGeb As Single
Dim StuNe As Integer 'Neue Mahnstufe
Dim StuAl As Integer 'Alte Mahnstufe
Dim ZaInt As Integer
Dim Mahnb As Boolean
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows

AktPo = 1
AnzPo = RpSel.Count

If AnzPo > 0 Then
    ReDim GloMa(AnzPo)
    
    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            RowNr = RpRow.Index
            GloMa(AktPo) = RowNr

            Set RpCol = RpCls.Find(OPo_ID1)
            OpNum = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(OPo_Fällig)
            Fallg = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(OPo_Intervall)
            ZaInt = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(OPo_Stufe)
            StuAl = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(OPo_Mahnbar)
            Mahnb = CBool(RpRow.Record(RpCol.ItemIndex).Value)
            Set RpCol = RpCls.Find(OPo_OffBetrag)
            BetOf = CDbl(RpRow.Record(RpCol.ItemIndex).Value)
            Set RpCol = RpCls.Find(OPo_Gebuehr)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                MaGeb = CSng(RpRow.Record(RpCol.ItemIndex).Value)
            Else
                MaGeb = 0
            End If
            Set RpCol = RpCls.Find(OPo_Mahnfrist)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                If IsDate(RpRow.Record(RpCol.ItemIndex).Value) = True Then
                    MaFrA = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    MaFrA = Date
                End If
            Else
                MaFrA = Date
            End If
            If MaFrA < Date Then
                MaFrA = Date
            End If
            If MaErh = True Then 'Mahnstufe eröhen
                MaFrN = DateAdd("d", ZaInt, Date)
                StuNe = StuAl + 1
            Else
                MaFrN = MaFrA
                StuNe = StuAl - 1
            End If
            If StuNe < 0 Then
                StuNe = 0
            End If

            If MaErh = True Then 'Mahnstufe eröhen
                If Mahnb = True Then
                    If StuNe < 5 Then
                        DBCmEx2 "qrySimOPAn1", "@PaStu", "@IdxNr", StuNe, OpNum
                        If KeiFr = True Then
                            DBCmEx2 "qrySimOPAn2", "@PaDat", "@IdxNr", MaFrN, OpNum
                        End If
                        If Aktua = False Then
                            Select Case StuNe
                            Case 1: DBCmEx2 "qrySimOPMa1", "@MaDat", "@IdxNr", Date, OpNum
                            Case 2: DBCmEx2 "qrySimOPMa2", "@MaDat", "@IdxNr", Date, OpNum
                            Case 3: DBCmEx2 "qrySimOPMa3", "@MaDat", "@IdxNr", Date, OpNum
                            Case 4: DBCmEx2 "qrySimOPMa4", "@MaDat", "@IdxNr", Date, OpNum
                            Case 5: DBCmEx2 "qrySimOPMa5", "@MaDat", "@IdxNr", Date, OpNum
                            End Select
                        End If
                    Else
                        DBCmEx2 "qrySimOPAn9", "@IdMah", "@IdxNr", False, OpNum
                        If StuAl < 5 Then
                            DBCmEx2 "qrySimOPAn1", "@PaStu", "@IdxNr", 5, OpNum
                        End If
                    End If
                    If GlDru.MaGeb >= 0 Then
                        DBCmEx2 "qrySimOPGeb", "@IdGeb", "@IdxNr", GlDru.MaGeb, OpNum
                    End If
                End If
            Else
                DBCmEx2 "qrySimOPAn1", "@PaStu", "@IdxNr", StuNe, OpNum
                If KeiFr = False Then
                    DBCmEx2 "qrySimOPAn2", "@PaDat", "@IdxNr", MaFrN, OpNum
                End If
                If StuNe < 5 Then
                    If Mahnb = False Then
                        DBCmEx2 "qrySimOPAn9", "@IdMah", "@IdxNr", True, OpNum
                    End If
                End If
                Select Case StuNe + 1
                Case 1: DBCmEx1 "qrySimOPNu1", "@IdxNr", OpNum
                Case 2: DBCmEx1 "qrySimOPNu2", "@IdxNr", OpNum
                Case 3: DBCmEx1 "qrySimOPNu3", "@IdxNr", OpNum
                Case 4: DBCmEx1 "qrySimOPNu4", "@IdxNr", OpNum
                Case 5: DBCmEx1 "qrySimOPNu5", "@IdxNr", OpNum
                End Select
                DBCmEx2 "qrySimOPGeb", "@IdGeb", "@IdxNr", 0, OpNum
            End If

            AktPo = AktPo + 1
        End If
    Next RpRow

    If Aktua = True Then
        SUpOp RowNr
    End If
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then SErLog Err.Description & " S_OPMa " & Err.Number
Resume Next

End Sub
