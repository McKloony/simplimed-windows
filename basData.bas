            IdxNr = RpRow.Record(RpCol.ItemIndex).Value
            If GlGrI = True Then 'Gruppierung Laborbericht
                If GlTyp < 2 Then
                    SQL1 = "SELECT * FROM dbo.qryLabTes WHERE IDB = " & IdxNr & " ORDER BY Gruppe, Ident"
                Else
                    SQL1 = "SELECT * FROM qryLabTes WHERE [IDB] = " & IdxNr & " ORDER BY [Gruppe], [Ident];"
                End If
            Else
                If GlTyp < 2 Then
                    SQL1 = "SELECT * FROM dbo.qryLabTes WHERE IDB = " & IdxNr & " ORDER BY Ident"
                Else
                    SQL1 = "SELECT * FROM qryLabTes WHERE [IDB] = " & IdxNr & " ORDER BY [Ident];"
                End If
            End If
        Case RibTab_LabAuftrag:
            Set RpRow = RpSel(0)
            RowNr = RpRow.Index
            Set RpCol = RpCls.Find(Lau_ID1)
            IdxNr = RpRow.Record(RpCol.ItemIndex).Value
            If GlTyp < 2 Then
                SQL1 = "SELECT * FROM dbo.qryLabPos WHERE IDA = " & IdxNr
            Else
                SQL1 = "SELECT * FROM qryLabPos WHERE [IDA] = " & IdxNr & ";"
            End If
        End Select
        
        Set RS149 = New ADODB.Recordset
        With RS149
            .CursorLocation = adUseClient
            .Source = SQL1
            .ActiveConnection = DB1
            .CursorType = adOpenDynamic
            .LockType = adLockOptimistic
            .Open Options:=adCmdText
        End With
        If RS149.RecordCount > 0 Then
            If RS149.Supports(adUpdate) Then
                RS149.MoveFirst
                For Each RpRec In RpRcs
                    For Each RpItm In RpRec
                        If Left$(RpItm.Tag, 1) = "@" Then
                            TmTag = Mid$(RpItm.Tag, 2, Len(RpItm.Tag) - 1)
                            If RpItm.HasCheckbox = True Then
                                RS149.Fields(TmTag).Value = RpItm.Checked
                            Else
                                If IsNumeric(RpItm.Value) Then
                                    If InStr(1, RpItm.Value, ".", 1) > 0 Then
                                        TmpPr = Replace(RpItm.Value, ".", "", 1)
                                        TmpPr = Mid$(TmpPr, 1, Len(TmpPr) - 3) & "." & Right$(TmpPr, 2)
                                        RS149.Fields(TmTag).Value = TmpPr
                                    Else
                                        If InStr(1, RpItm.Value, ",", 1) > 0 Then
                                            TmpPr = Replace(RpItm.Value, ",", ".", 1)
                                            RS149.Fields(TmTag).Value = TmpPr
                                        Else
                                            RS149.Fields(TmTag).Value = RpItm.Value
                                        End If
                                    End If
                                Else
                                    RS149.Fields(TmTag).Value = RpItm.Value
                                End If
                            End If
                        End If
                    Next RpItm
                    RS149.Update
                    RS149.MoveNext
                Next RpRec
            End If
        End If
        RS149.Close
        Set RS149 = Nothing
        
        If GlJet = True Then SDBSav
        
        Set RpSel = RpCo6.SelectedRows
        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            KrRow = RpRow.Index
        End If
        
        Select Case GlBut
        Case RibTab_LabBericht:
            SUpLa RowNr, KrRow
        Case RibTab_LabAuftrag:
            SUpAu RowNr, KrRow
        End Select
    End If
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpRcs = Nothing
Set RpCo5 = Nothing
Set RpCo6 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_LaSa " & Err.Number
Resume Next

End Sub
