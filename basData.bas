Public Sub S_TeRec(Optional ByVal NeuRe As Boolean = False)
On Error GoTo AdErr
'Erstellt Rechnungen auf Basis von Terminen aus dem Terminkalender

Dim TeDat As Date
Dim TerNr As Long
Dim AnzPo As Long
Dim AnzTe As Long
Dim ReNum As Long
Dim PatNr As Long
Dim MaNum As Long
Dim MiNum As Long
Dim MasTe As Long
Dim GeBet As Double
Dim ReBet As Double
Dim NeReB As Double
Dim PatNa As String
Dim PatKu As String
Dim ReStr As String
Dim ReTyp As String
Dim TeGui As String
Dim PrGui As String
Dim MitNa As String
Dim PrStr As String
Dim Frage As Integer
Dim ReAbg As Boolean
Dim EinOk As Boolean
Dim ReMel As Boolean
Dim ReNeu As Boolean
Dim CaCol As XtremeCalendarControl.CalendarControl
Dim CaEvt As XtremeCalendarControl.CalendarEvent
Dim CaEvs As XtremeCalendarControl.CalendarEvents
Dim CaHit As XtremeCalendarControl.CalendarHitTestInfo
Dim ViEvt As XtremeCalendarControl.CalendarViewEvent
Dim ViEvs As XtremeCalendarControl.CalendarViewEvents

Set FM = frmMain
Set CaCol = FM.calCont1

Set ViEvs = CaCol.ActiveView.GetSelectedEvents
AnzTe = ViEvs.Count

Screen.MousePointer = vbHourglass

Select Case GlReT 'Standardbelegtyp
Case "R": ReTyp = "R"
Case "V": ReTyp = "R"
Case "L": ReTyp = "L"
Case "A": ReTyp = "A"
Case "U": ReTyp = "R"
Case "M": ReTyp = "M"
Case "G": ReTyp = "G"
Case "I": ReTyp = "I"
Case Else: ReTyp = "R"
End Select

If AnzTe > 0 Then
    For Each ViEvt In ViEvs
        If ViEvt.Selected = True Then
            EinOk = True
            Set CaEvt = ViEvt.Event
            TerNr = CaEvt.id
            ReAbg = CaEvt.PrivateFlag
            
            S_TeDe TerNr
            With GlTDt
                PatNr = .PatNr
                TeGui = .TeGui
                MiNum = .TeMit
                MaNum = .TeMan
                MasTe = .TeSer
                GeBet = .GeBet
                TeDat = Left$(.DaSta, 10)
            End With
            PatNa = S_AdIdx(PatNr, "IDKurz")

            If MiNum < 1 Then
                MiNum = MiNum = GlMiA(GlSmI, 2)
            End If
            If MaNum < 1 Then
                MaNum = GlMan(GlSMa, 2)
            End If
            If PatNr < 1 Then
                SPopu "Kein Patient zugeordnet", "Diesem Termin wurde kein Patient zugeordnet", IC48_Information
                ReAbg = True
            End If

            Set RS134 = New ADODB.Recordset 'wurden überhaupt Leistungen zugeordnet?
            RS134.CursorLocation = adUseClient
            Set RS134 = DBCmRe1("qryAnKa1e", "@IdxNr", TerNr)
            If RS134.RecordCount = 0 Then
                ReAbg = True
                SPopu "Keine Leistungen zugeordnet", "Diesem Termin wurden keine Leistungen zugeordnet", IC48_Information
            End If
            RS134.Close
            Set RS134 = Nothing

            If ReAbg = False Then 'Leistungen vorhanden
                If GlTrS = True Then 'Terminleistungen nur für passende Referenzrechnung
                    ReNum = S_ReTe(MasTe)
                Else
                    If NeuRe = True Then
                        ReStr = S_ReVo(Date, ReTyp, MaNum, MiNum, GlReN)
                        ReNum = K_ReNe(ReStr, Date, PatNr, 0, ReTyp, MaNum, MiNum)
                        ReNeu = True
                    Else
                        If GlRMa = True Then 'getrennter Mandentenrechnungsnummernkreis
                            ReNum = S_ReOf(PatNr, MaNum, ReTyp) 'ist noch eine unabgeschlossene Rechnung vorhanden?
                        Else
                            ReNum = S_ReOf(PatNr, 0, ReTyp) 'ist noch eine unabgeschlossene Rechnung vorhanden?
                        End If
                        DoEvents
                        ReStr = S_ReIdx(ReNum, "RechNr")
                    End If
                End If
                If ReNum = 0 Then
                    ReStr = S_ReVo(Date, ReTyp, MaNum, MiNum, GlReN)
                    ReNum = K_ReNe(ReStr, Date, PatNr, 0, ReTyp, MaNum, MiNum)
                    ReNeu = True
                End If
                DoEvents

                ReBet = CSng(S_ReIdx(ReNum, "GesBetrag"))
                NeReB = ReBet + GeBet
                DoEvents

                DBCmEx6 "qryAnKa1m", "@IdDat", "@IdRec", "@IdMit", "@IdMan", "@TerNr", "@IdPat", TeDat, ReNum, MiNum, MaNum, TerNr, PatNr
                DoEvents
                DBCmEx2 "qryAnKa1c", "@IdBol", "@IdxNr", -1, TerNr
                DoEvents

                PrGui = CreateID("P")
                MitNa = GlMiA(GlSmI, 1)
                If ReNeu = True Then
                    PrStr = "Termin abgerechnet: " & ReStr & " (" & Format$(ReNum, "00000") & ") Rechnung hinzugefügt"
                Else
                    PrStr = "Termin abgerechnet: " & ReStr & " (" & Format$(ReNum, "00000") & ") Rechnung erweitert"
                End If
                DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", TerNr, PrGui, TeGui, Now, Now, PrStr, MitNa
                DoEvents

                If GlTAk = True Then 'Terminakontozahlungen aktiviert
                    S_PaGu PatNr, , GeBet
                    DoEvents
                End If
                DBCmEx2 "qryTerAuf", "@IdAuf", "@IdxNr", -1, TerNr
                DoEvents
                
                S_ReTer ReNum
                DoEvents
                SPopu "Termin Abgerechnet", "Die Terminleistungen wurden abgerechnet", IC48_Information
                DoEvents
                
                If GlPop = True Then 'Rechnungsobergrenze
                    If NeReB > GlObG Then
                        SReMe
                    End If
                End If
            End If
                                    
            Exit For
        End If
    Next ViEvt
    
    DoEvents
    S_TeLi
    DoEvents
    SUpTe
    DoEvents
    SUpRe
End If

Screen.MousePointer = vbNormal

Set CaCol = Nothing

Exit Sub

AdErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TeRec " & Err.Number
Resume Next

End Sub
Public Sub S_TeReL(Optional ByVal NeuRe As Boolean = False)
On Error GoTo GrErr
'Erstellt Rechnungen auf Basis von Terminlisteneinträgen

Dim TeDat As Date
Dim RowNr As Long
Dim TerNr As Long
Dim AltPa As Long
Dim PatNr As Long
Dim ReNum As Long
Dim MasTe As Long
Dim AnzPo As Long
Dim AnzTe As Long
Dim MaNum As Long
Dim MiNum As Long
Dim ManNr As Long
Dim GeBet As Double
Dim ReBet As Double
Dim NeReB As Double
Dim ReStr As String
Dim ReTyp As String
Dim TeGui As String
Dim PatNa As String
Dim PrGui As String
Dim MitNa As String
Dim PrStr As String
Dim ReMel As Boolean
Dim EinOk As Boolean
Dim TeAbg As Boolean
Dim ReNeu As Boolean
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCo6 = FM.repCont6
Set RpCo4 = FM.repCont4
If GlWaZ = True Then 'Wartezimmer Kontextmenü
    Set RpCls = RpCo6.Columns
    Set RpSel = RpCo6.SelectedRows
Else
    Set RpCls = RpCo1.Columns
    Set RpSel = RpCo1.SelectedRows
End If

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

AnzTe = RpSel.Count

Select Case GlReT 'Standardbelegtyp
Case "R": ReTyp = "R"
Case "V": ReTyp = "R"
Case "L": ReTyp = "L"
Case "A": ReTyp = "A"
Case "U": ReTyp = "R"
Case "M": ReTyp = "M"
Case "G": ReTyp = "G"
Case "I": ReTyp = "I"
Case Else: ReTyp = "R"
End Select

ReNeu = NeuRe 'WICHTIG!

For Each RpRow In RpSel
    If RpRow.GroupRow = False Then
        EinOk = True
        RowNr = RpRow.Index
        
        Set RpCol = RpCls.Find(Ter_ID0)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            PatNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Ter_ID2)
            TerNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Ter_GuiID)
            TeGui = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Ter_IDP)
            If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                MaNum = RpRow.Record(RpCol.ItemIndex).Value
            Else
                MaNum = GlMan(GlSMa, 2)
            End If
            Set RpCol = RpCls.Find(Ter_IDM)
            If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                MiNum = RpRow.Record(RpCol.ItemIndex).Value
            Else
                MiNum = GlMiA(GlSmI, 2)
            End If
            Set RpCol = RpCls.Find(Ter_VonDat)
            TeDat = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Ter_TerBet)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                GeBet = Round(RpRow.Record(RpCol.ItemIndex).Value, 2)
            Else
                GeBet = 0
            End If
            Set RpCol = RpCls.Find(Ter_Patient)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                PatNa = RpRow.Record(RpCol.ItemIndex).Value
            Else
                PatNa = vbNullString
            End If
            Set RpCol = RpCls.Find(Ter_MasTer)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                MasTe = RpRow.Record(RpCol.ItemIndex).Value
            Else
                MasTe = TerNr
            End If
            Set RpCol = RpCls.Find(Ter_Aufgabe)
            If RpRow.Record(RpCol.ItemIndex).Icon > 0 Then
                If RpRow.Record(RpCol.ItemIndex).Icon = IC16_Mail_Close Then
                    TeAbg = True
                Else
                    TeAbg = False
                End If
            Else
                TeAbg = True
            End If

            Set RS134 = New ADODB.Recordset 'wurden überhaupt Leistungen zugeordnet?
            RS134.CursorLocation = adUseClient
            Set RS134 = DBCmRe1("qryAnKa1e", "@IdxNr", TerNr)
            If RS134.RecordCount = 0 Then
                TeAbg = True
            End If
            RS134.Close
            Set RS134 = Nothing

            If TeAbg = False Then
                If GlTrS = True Then 'Terminleistungen nur für passene Referenzrechnung
                    ReNum = S_ReTe(MasTe)
                Else
                    If ReNeu = True Then
                        ReStr = S_ReVo(Date, ReTyp, MaNum, MiNum, GlReN)
                        ReNum = K_ReNe(ReStr, Date, PatNr, MasTe, ReTyp, MaNum, MiNum)
                        If AltPa = PatNr Then
                            ReNeu = False 'WICHTIG!
                        End If
                    Else
                        If GlRMa = True Then 'getrennter Mandentenrechnungsnummernkreis
                            ReNum = S_ReOf(PatNr, MaNum, ReTyp) 'ist noch eine unabgeschlossene Rechnung vorhanden?
                        Else
                            ReNum = S_ReOf(PatNr, 0, ReTyp) 'ist noch eine unabgeschlossene Rechnung vorhanden?
                        End If
                        DoEvents
                        ReStr = S_ReIdx(ReNum, "RechNr")
                    End If
                End If
                If ReNum = 0 Then 'keine unabgeschlossene Rechnung vorhanden
                    ReStr = S_ReVo(Date, ReTyp, MaNum, MiNum, GlReN)
                    ReNum = K_ReNe(ReStr, Date, PatNr, MasTe, ReTyp, MaNum, MiNum)
                End If
                DoEvents

                ReBet = CDbl(S_ReIdx(ReNum, "GesBetrag"))
                ReBet = Round(ReBet, 2)
                NeReB = ReBet + GeBet
                DoEvents
                
                DBCmEx6 "qryAnKa1m", "@IdDat", "@IdRec", "@IdMit", "@IdMan", "@TerNr", "@IdPat", TeDat, ReNum, MiNum, MaNum, TerNr, PatNr
                DoEvents
                DBCmEx2 "qryAnKa1c", "@IdBol", "@IdxNr", -1, TerNr
                DoEvents
                
                PrGui = CreateID("P")
                MitNa = GlMiA(GlSmI, 1)
                If ReNeu = True Then
                    PrStr = "Termin abgerechnet: " & ReStr & " (" & Format$(ReNum, "00000") & ") Rechnung hinzugefügt"
                Else
                    PrStr = "Termin abgerechnet: " & ReStr & " (" & Format$(ReNum, "00000") & ") Rechnung erweitert"
                End If
                DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", TerNr, PrGui, TeGui, Now, Now, PrStr, MitNa
                DoEvents

                If GlTAk = True Then 'Terminakontozahlungen aktiviert
                    S_PaGu PatNr, , GeBet
                    DoEvents
                End If
                DBCmEx2 "qryTerAuf", "@IdAuf", "@IdxNr", -1, TerNr
                DoEvents
                
                S_ReTer ReNum
            Else
                If GlRMa = True Then 'getrennter Mandentenrechnungsnummernkreis
                    ReNum = S_ReOf(PatNr, MaNum, ReTyp) 'ist einem der markierten Termin keine Rechnungsnummer zugeweisen?
                Else
                    ReNum = S_ReOf(PatNr, 0, ReTyp) 'ist einem der markierten Termin keine Rechnungsnummer zugeweisen?
                End If
                If ReNum = 0 Then
                    DBCmEx2 "qryTerAuf", "@IdAuf", "@IdxNr", -1, TerNr
                End If
            End If
            AltPa = PatNr 'WICHTIG!
        End If
    End If
Next RpRow

Screen.MousePointer = vbHourglass
clFen.FenDsk 2

Set RpSel = RpCo4.SelectedRows
If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    RowNr = RpRow.Index
    SUpRe RowNr
End If

Set RpSel = RpCo1.SelectedRows
If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    RowNr = RpRow.Index
    SUpTe RowNr
End If

clFen.FenDsk 3
Screen.MousePointer = vbNormal

If GlPop = True Then 'Rechnungsobergrenze
    If NeReB > GlObG Then
        SReMe
    End If
End If

GlWaZ = False 'WICHTIG!

Set RpSel = Nothing
Set RpCo1 = Nothing
Set RpCo4 = Nothing
Set RpCo6 = Nothing

Set clFen = Nothing

Exit Sub

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TeReL " & Err.Number
Resume Next

End Sub

Public Sub S_Term(ByVal TerNr As Long, ByVal AcTyp As Integer)
On Error GoTo SuErr
'Dupliziert oder Löscht den markierten Termin

Dim Datu1 As Date
Dim Datu2 As Date
Dim Zeit1 As Date
Dim Zeit2 As Date
Dim NotDa As Date
Dim NotZe As Date
Dim MaNum As Long
Dim MasTe As Long
Dim TeNum As Long
Dim PrStr As String
Dim MitNa As String
Dim TmGui As String
Dim PrGui As String
Dim GesBe As Double
Dim TmBet As Variant
Dim AktZa As Integer
Dim MaIdx As Integer
Dim RzAnz As Integer
Dim RzAkt As Integer
Dim AnzTe As Integer
Dim NotVa As Integer
Dim GnzTa As Boolean

Select Case AcTyp
Case 1: 'Duplizieren

    TmGui = CreateID("T")
    DBCmEx2 "qryTerKop", "@IdxNr", "@GuiSt", TerNr, TmGui 'Copy Procedure
    DoEvents
    If GlOTS = True Then 'Online-Terminbuchungs System
        DBCmEx2 "qryTerOnGe", "@OnlGe", "@IdxNr", 0, TerNr '[OnlGes]
        DoEvents
    End If

    S_TeDe TerNr
    With GlTDt
        TmBet = .TeBet
        MasTe = .TeMas
        GnzTa = .GnzTa
        Datu1 = .DaSta
        Datu2 = .DaEnd
        Zeit1 = .ZeSta
        Zeit2 = .ZeEnd
        RzAnz = .RzAnz
        GesBe = .GeBet
        NotVa = .NotVa
    End With
    DoEvents

    NotDa = CDate(DateAdd("h", -NotVa, Datu1))

    Set RS115 = New ADODB.Recordset
    RS115.CursorLocation = adUseClient
    Set RS115 = DBCmRe1("qryTerGui3", "@IdStr", TmGui)
    If RS115.RecordCount > 0 Then
        TeNum = RS115.Fields("ID2").Value
    Else
        TeNum = 0
    End If
    RS115.Close
    Set RS115 = Nothing
    DoEvents

    DBCmEx3 "qryTerNotDat", "@IdDat", "@IdTim", "@IdxNr", NotDa, NotDa, TeNum
    DBCmEx2 "qryTerNotVal", "@IdSet", "@IdxNr", NotVa, TeNum
    If GlTeE = True Then 'Email-Termin-Erinnerung
        DBCmEx2 "qryTerNotStat", "@IdSet", "@IdxNr", 3, TeNum
    End If
    DoEvents

    If GesBe > 0 Then
        Ter_Akt TeNum, MasTe
        DoEvents
    End If

    If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
        MaNum = S_TeDx(TerNr, "IDM")
        For AktZa = 1 To UBound(GlMiT) 'Aktive Mitarbeiter + Terminspalte
            If MaNum = GlMiT(AktZa, 2) Then
                MaIdx = AktZa
                Exit For
            End If
        Next AktZa
    Else
        MaNum = S_TeDx(TerNr, "IDP")
        For AktZa = 1 To UBound(GlMan)
            If MaNum = GlMan(AktZa, 2) Then
                MaIdx = AktZa
                Exit For
            End If
        Next AktZa
    End If

    If RzAnz > 0 Then
        Set RS121 = New ADODB.Recordset
        RS121.CursorLocation = adUseClient
        Set RS121 = DBCmRe1("qryTerSer01", "@IdxNr", MasTe)
        AnzTe = RS121.RecordCount
        RS121.Close
        Set RS121 = Nothing
        DoEvents
        DBCmEx3 "qryTerAnz", "@TeAnz", "@TeAkt", "@IdxNr", RzAnz, AnzTe, TeNum
    End If

    If GlOTS = True Then 'Online-Terminbuchungs System
        If Datu1 >= Date Then
            With GlSyn
                .PrTyp = "B" 'Termin Hinzugefügt
                .DatSt = Format$(Datu1, "dd.mm.yyyy")
                .DatEn = Format$(Datu2, "dd.mm.yyyy")
                .ZeiSt = Format$(Zeit1, "hh:mm:ss")
                .ZeiEn = Format$(Zeit2, "hh:mm:ss")
                .TeBet = vbNullString
                .GuiID = TmGui
                .GnzTa = GnzTa
                .MaIdx = MaIdx
                .MaNum = MaNum
            End With
            S_TeSy
            DoEvents
        End If
    End If
    
    PrStr = "Termin wurde dupliziert und eingefügt"
    MitNa = GlMiA(GlSmI, 1)
    PrGui = CreateID("P")
    DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", TeNum, PrGui, TmGui, Now, Now, PrStr, MitNa
    DoEvents
    
Case 2: 'Einzeltermine löschen

    Set RS137 = New ADODB.Recordset
    RS137.CursorLocation = adUseClient
    Set RS137 = DBCmRe1("qryTermin", "@IdxNr", TerNr)
    If RS137.RecordCount > 0 Then
        GnzTa = CBool(RS137.Fields("Selekt").Value)
        Datu1 = CDate(RS137.Fields("VonDat").Value)
        Datu2 = CDate(RS137.Fields("BisDat").Value)
        Zeit1 = CDate(RS137.Fields("ZeiVon").Value)
        Zeit2 = CDate(RS137.Fields("ZeiBis").Value)
        If RS137.Fields("RzAnz").Value <> vbNullString Then
            RzAnz = CLng(RS137.Fields("RzAnz").Value)
        Else
            RzAnz = 0
        End If
        If RS137.Fields("MasTer").Value <> vbNullString Then
            MasTe = CLng(RS137.Fields("MasTer").Value)
        Else
            MasTe = 0
        End If
        TmBet = S_TeDx(TerNr, "IDKurz")
        If RS137.Fields("GuiID").Value <> vbNullString Then
            TmGui = RS137.Fields("GuiID").Value
        Else
            TmGui = CreateID("T")
        End If
        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
            MaNum = RS137.Fields("IDM").Value
            For AktZa = 1 To UBound(GlMiT) 'Aktive Mitarbeiter + Terminspalte
                If MaNum = GlMiT(AktZa, 2) Then
                    MaIdx = AktZa
                    Exit For
                End If
            Next AktZa
        Else
            MaNum = RS137.Fields("IDP").Value
            For AktZa = 1 To UBound(GlMan)
                If MaNum = GlMan(AktZa, 2) Then
                    MaIdx = AktZa
                    Exit For
                End If
            Next AktZa
        End If
    End If
    RS137.Close
    Set RS137 = Nothing
    DoEvents

    If GlBuL = True Then 'echtes Löschen erlauben
        If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
            DBCmEx2 "qryTerPaSe", "@IdPas", "@IdxNr", 1, TerNr
            DBCmEx1 "qryTerRep1", "@IdxNr", TerNr
            DBCmEx3 "qryDAVTeCh3", "@IdSet", "@IdDat", "@IdxNr", 1, Now, TerNr
        Else
            DBCmEx1 "qryTerLoe", "@IdxNr", TerNr
        End If
    Else
        DBCmEx2 "qryTerPaSe", "@IdPas", "@IdxNr", -1, TerNr
        If GlOTS = True Then 'Online-Terminbuchungs System
            DBCmEx2 "qryTerOnGe", "@OnlGe", "@IdxNr", 0, TerNr '[OnlGes]
        End If
        If GlTeE = True Then 'Email-Termin-Erinnerung
            DBCmEx2 "qryTerNotStat", "@IdSet", "@IdxNr", 1, TerNr
            DoEvents
            PrStr = "Emailerinnerung wurde deaktiviert"
            MitNa = GlMiA(GlSmI, 1)
            PrGui = CreateID("P")
            DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", TerNr, PrGui, TmGui, Now, Now, PrStr, MitNa
            DoEvents
        End If
        If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
            DBCmEx1 "qryTerRep1", "@IdxNr", TerNr
            DBCmEx3 "qryDAVTeCh3", "@IdSet", "@IdDat", "@IdxNr", 1, Now, TerNr
        End If
    End If
    DoEvents

    If RzAnz > 0 Then
        RzAkt = 1
        Set RS121 = New ADODB.Recordset
        RS121.CursorLocation = adUseClient
        Set RS121 = DBCmRe1("qryTerSer01", "@IdxNr", MasTe)
        AnzTe = RS121.RecordCount
        If AnzTe > 0 Then
            Do
            TeNum = RS121.Fields("ID2").Value
            DBCmEx2 "qryTerAnk", "@TeAkt", "@IdxNr", RzAkt, TeNum
            RzAkt = RzAkt + 1
            RS121.MoveNext
            Loop Until RS121.EOF
        End If
        RS121.Close
        Set RS121 = Nothing
        DoEvents
    End If

    DoEvents
    If GlOTS = True Then
        If Datu1 >= Date Then
            With GlSyn
                .PrTyp = "D"
                .DatSt = Format$(Datu1, "dd.mm.yyyy")
                .DatEn = Format$(Datu2, "dd.mm.yyyy")
                .ZeiSt = Format$(Zeit1, "hh:mm:ss")
                .ZeiEn = Format$(Zeit2, "hh:mm:ss")
                .GuiID = TmGui
                .GnzTa = GnzTa
                .MaIdx = MaIdx
                .MaNum = MaNum
            End With
            S_TeSy
            DoEvents
        End If
    End If
    
    PrStr = "Termin wurde entfernt"
    MitNa = GlMiA(GlSmI, 1)
    PrGui = CreateID("P")
    DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", TerNr, PrGui, TmGui, Now, Now, PrStr, MitNa
    DoEvents
    
Case 3: 'Serientermine löschen

    If GlOTS = True Then
        Set RS137 = New ADODB.Recordset
        RS137.CursorLocation = adUseClient
        Set RS137 = DBCmRe1("qryTerSer01", "@IdxNr", TerNr)
        If RS137.RecordCount > 0 Then
            Do
            GnzTa = CBool(RS137.Fields("Selekt").Value)
            Datu1 = CDate(RS137.Fields("VonDat").Value)
            Datu2 = CDate(RS137.Fields("BisDat").Value)
            Zeit1 = CDate(RS137.Fields("ZeiVon").Value)
            Zeit2 = CDate(RS137.Fields("ZeiBis").Value)
            TmBet = S_TeDx(TerNr, "IDKurz")
            If RS137.Fields("GuiID").Value <> vbNullString Then
                TmGui = RS137.Fields("GuiID").Value
            Else
                TmGui = CreateID("T")
            End If
            If GlMPl = True Then
                MaNum = RS137.Fields("IDM").Value
                For AktZa = 1 To UBound(GlMiT) 'Aktive Mitarbeiter + Terminspalte
                    If MaNum = GlMiT(AktZa, 2) Then
                        MaIdx = AktZa
                        Exit For
                    End If
                Next AktZa
            Else
                MaNum = RS137.Fields("IDP").Value
                For AktZa = 1 To UBound(GlMan)
                    If MaNum = GlMan(AktZa, 2) Then
                        MaIdx = AktZa
                        Exit For
                    End If
                Next AktZa
            End If
            If Datu1 >= Date Then
                With GlSyn
                    .PrTyp = "D"
                    .DatSt = Format$(Datu1, "dd.mm.yyyy")
                    .DatEn = Format$(Datu2, "dd.mm.yyyy")
                    .ZeiSt = Format$(Zeit1, "hh:mm:ss")
                    .ZeiEn = Format$(Zeit2, "hh:mm:ss")
                    .GuiID = TmGui
                    .GnzTa = GnzTa
                    .MaIdx = MaIdx
                    .MaNum = MaNum
                End With
                S_TeSy
                DoEvents
            End If
            RS137.MoveNext
            Loop Until RS137.EOF
        End If
        RS137.Close
        Set RS137 = Nothing
    End If
    DoEvents
    DBCmEx1 "qryTerSeX", "@IdxNr", TerNr
    
    PrStr = "Terminserie wurde entfernt"
    MitNa = GlMiA(GlSmI, 1)
    PrGui = CreateID("P")
    DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", TerNr, PrGui, TmGui, Now, Now, PrStr, MitNa
    DoEvents
    
Case 4: 'die ganze Terminserie löschen

    Set RS137 = New ADODB.Recordset
    RS137.CursorLocation = adUseClient
    Set RS137 = DBCmRe1("qryTerSer01", "@IdxNr", TerNr)
    If RS137.RecordCount > 0 Then
        Do
        GnzTa = CBool(RS137.Fields("Selekt").Value)
        Datu1 = CDate(RS137.Fields("VonDat").Value)
        Datu2 = CDate(RS137.Fields("BisDat").Value)
        Zeit1 = CDate(RS137.Fields("ZeiVon").Value)
        Zeit2 = CDate(RS137.Fields("ZeiBis").Value)
        TmBet = S_TeDx(TerNr, "IDKurz")
        If RS137.Fields("GuiID").Value <> vbNullString Then
            TmGui = RS137.Fields("GuiID").Value
        Else
            TmGui = CreateID("T")
        End If
        If GlMPl = True Then
            MaNum = RS137.Fields("IDM").Value
            For AktZa = 1 To UBound(GlMiT) 'Aktive Mitarbeiter + Terminspalte
                If MaNum = GlMiT(AktZa, 2) Then
                    MaIdx = AktZa
                    Exit For
                End If
            Next AktZa
        Else
            MaNum = RS137.Fields("IDP").Value
            For AktZa = 1 To UBound(GlMan)
                If MaNum = GlMan(AktZa, 2) Then
                    MaIdx = AktZa
                    Exit For
                End If
            Next AktZa
        End If
        If GlOTS = True Then
            If Datu1 >= Date Then
                With GlSyn
                    .PrTyp = "D"
                    .DatSt = Format$(Datu1, "dd.mm.yyyy")
                    .DatEn = Format$(Datu2, "dd.mm.yyyy")
                    .ZeiSt = Format$(Zeit1, "hh:mm:ss")
                    .ZeiEn = Format$(Zeit2, "hh:mm:ss")
                    .GuiID = TmGui
                    .GnzTa = GnzTa
                    .MaIdx = MaIdx
                    .MaNum = MaNum
                End With
                S_TeSy
                DoEvents
            End If
        End If
        RS137.MoveNext
        Loop Until RS137.EOF
    End If
    RS137.Close
    Set RS137 = Nothing
    DoEvents

    If GlBuL = True Then 'echtes Löschen erlauben
        DBCmEx1 "qryTerSeLo", "@IdxNr", TerNr
    Else
        DBCmEx2 "qryTerSePa", "@IdPas", "@IdxNr", True, TerNr
        If GlOTS = True Then 'Online-Terminbuchungs System
            DBCmEx2 "qryTerOnGe", "@OnlGe", "@IdxNr", 0, TerNr '[OnlGes]
            DoEvents
        End If
    End If
    DBCmEx1 "qryAnKa1i", "@IdxNr", TerNr
    DoEvents
    
    PrStr = "Terminserie wurde entfernt"
    MitNa = GlMiA(GlSmI, 1)
    PrGui = CreateID("P")
    DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", TerNr, PrGui, TmGui, Now, Now, PrStr, MitNa
    DoEvents
End Select
DoEvents

GlNeK = GlKoX 'Protokolleintrag
If TmBet = vbNullString Then TmBet = "kein Terminbetreff"
With GlNeK
    .PatNr = GlMan(GlSMa, 2)
    .IdxNr = 0
    .EiDat = Format$(Date, "dd.mm.yyyy")
    .EiZei = TimeValue(Now)
    .EiTyp = 104
    .TeStr = PrStr & " - " & Format$(Datu1, "dd.mm.yyyy") & " - " & Format$(Zeit1, "hh:mm") & " - " & TmGui
    .ZiStr = Format$(Now, "hh:mm") & " Uhr"
    .NeuEi = True
    .KeiAk = True
    .Mitar = GlMiA(GlSmI, 2)
End With
S_Prot

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_Term " & Err.Number
Resume Next

End Sub
Public Sub S_TeSa(ByVal CaEvt As XtremeCalendarControl.CalendarEvent, Optional ByVal NeuTe As Boolean = False)
On Error GoTo KoErr
'Speichert die Änderungen im Kalender

Dim DatSt As Date
Dim DatEn As Date
Dim ZeiSt As Date
Dim ZeiEn As Date
Dim NotDa As Date
Dim NotZe As Date
Dim TerNr As Long
Dim AktTa As Long
Dim MitNr As Long
Dim ManNr As Long
Dim SheId As Long
Dim SQL1 As String
Dim TmGui As String
Dim PrGui As String
Dim PrStr As String
Dim TmBet As String
Dim MitNa As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim TeFra As String
Dim TeGef As Boolean
Dim TeDop As Boolean
Dim GnzTa As Boolean
Dim AnMiT As Boolean
Dim NotVa As Integer
Dim NotSt As Integer
Dim MaIdx As Integer
Dim AktZa As Integer
Dim Frage As Integer
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmCon As XtremeCommandBars.CommandBarControl
Dim DaPi1 As XtremeCalendarControl.DatePicker
Dim CaCol As XtremeCalendarControl.CalendarControl

Set FM = frmMain
Set CaCol = FM.calCont1
Set CmBrs = FM.comBar01
Set DaPi1 = FM.dtpDatu7

TeTit = "Email-Termin-Erinnerung"
TeMai = "Soll die Email-Termin-Erinnerung aktiviert werden?"
TeInh = "Die Deaktivierung dieses Dialoges hat zur Folge, dass immer automatisch eine E-Mail-Erinnerung aktiviert wird."
TeFus = "Wenn der Termin an eine Position verschoben wird, an der die Terminzeit außerhalb E-Mail-Erinnerungszeit ist, wird keine E-Mail-Erinnerung aktiviert."
TeFra = "Diesen Dialog zukünftig nicht mehr anzeigen"

If GlTrM = True Or GlTrB = True Then 'Terminbearbeitung direkt im Kalender
    GlTrM = False 'Terminbearbeitung direkt im Kalender
    GlTrB = False 'Terminbearbeitung direkt im Kalender

    If NeuTe = True Then 'neuer Termin
        GlTeG = CreateID("T")
        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
            If GlOTS = True Then 'Online-Terminbuchungs Sytem
                ManNr = GlMiA(GlSMo, 2) 'Standardmitarbeiter Online-Terminbuchungs Sytem
                NotVa = GlMiK(GlSMo, 39)
            Else
                ManNr = GlMiA(GlSmI, 2)
                NotVa = GlMiK(GlSmI, 39)
            End If
        Else
            ManNr = GlMan(GlSMa, 2)
            NotVa = 24
        End If
        If GlTyp < 2 Then
            SQL1 = "SELECT * FROM dbo.qryTerNeu"
        Else
            SQL1 = "SELECT * FROM qryTerNeu;"
        End If
    Else
        TerNr = CaEvt.id
        S_TeDe TerNr
        With GlTDt
            ManNr = .TeMan
            MitNr = .TeMit
            NotVa = .NotVa
        End With
        If GlTyp < 2 Then
            SQL1 = "SELECT * FROM dbo.qryTerBele WHERE (ID2 = " & TerNr & ")"
        Else
            SQL1 = "SELECT * FROM qryTerBele WHERE ([ID2] = " & TerNr & ");"
        End If
    End If
    
    Set RS139 = New ADODB.Recordset
    With RS139
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With

    If NeuTe = True Then 'neuer Termin
        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
            For AktZa = 1 To UBound(GlMiT) 'Aktive Mitarbeiter + Terminspalte
                If MitNr = GlMiT(AktZa, 2) Then
                    MaIdx = AktZa
                    Exit For
                End If
            Next AktZa
        Else
            For AktZa = 1 To UBound(GlMaT)
                If ManNr = GlMaT(AktZa, 2) Then
                    MaIdx = AktZa
                    Exit For
                End If
            Next AktZa
        End If

        If RS139.Supports(adAddNew) = True Then
            TmGui = GlTeG 'Termin GuiID

            RS139.AddNew
            With CaEvt
                GnzTa = .AllDayEvent
                DatSt = Left$(.StartTime, 10)
                DatEn = Left$(.EndTime, 10)
                TmBet = .Subject
                If GnzTa = False Then
                    ZeiSt = Right$(.StartTime, 8)
                    ZeiEn = Right$(.EndTime, 8)
                Else
                    ZeiSt = "08:00:00"
                    ZeiEn = "09:00:00"
                End If
                NotDa = CDate(DateAdd("h", -NotVa, DatSt & Chr$(32) & ZeiSt))
                NotZe = TimeValue(DateAdd("h", -NotVa, DatSt & Chr$(32) & ZeiSt))

                If GlTyp < 2 Then
                    RS139.Fields("ZeiVon").Value = DatSt & Chr$(32) & ZeiSt
                    RS139.Fields("ZeiBis").Value = DatEn & Chr$(32) & ZeiEn
                    RS139.Fields("VonDat").Value = DatSt & Chr$(32) & ZeiSt
                    RS139.Fields("BisDat").Value = DatEn & Chr$(32) & ZeiEn
                    RS139.Fields("NotifySetDate").Value = NotDa
                    RS139.Fields("NotifySetTime").Value = NotZe
                Else
                    RS139.Fields("ZeiVon").Value = ZeiSt
                    RS139.Fields("ZeiBis").Value = ZeiEn
                    RS139.Fields("VonDat").Value = DatSt
                    RS139.Fields("BisDat").Value = DatEn
                    RS139.Fields("NotifySetDate").Value = NotDa
                    RS139.Fields("NotifySetTime").Value = NotZe
                End If

                RS139.Fields("NotifyValue").Value = NotVa
                RS139.Fields("IDKurz").Value = TmBet
                RS139.Fields("Selekt").Value = GnzTa
                RS139.Fields("IDSer").Value = 5 'Standardtermin
                RS139.Fields("GuiID").Value = TmGui
                RS139.Fields("Farbe").Value = 1
                RS139.Fields("Farbtyp").Value = 3
                RS139.Fields("Priorität").Value = 2
                RS139.Fields("Datum").Value = Now
                RS139.Fields("Change").Value = Now
                
                Select Case GlBut:
                Case RibTab_Ter_Kalend:
                        RS139.Fields("IDR").Value = GlRmu(1, 2)
                        RS139.Fields("IDP").Value = GlMan(GlSMa, 2)
                        RS139.Fields("IDM").Value = GlMiA(GlSmI, 2)
                Case RibTab_Ter_Raeume:
                        If .ScheduleID > 0 Then
                            SheId = GlRmu(.ScheduleID, 2)
                        Else
                            SheId = GlRmu(1, 2)
                        End If
                        RS139.Fields("IDR").Value = SheId
                        RS139.Fields("IDP").Value = GlMan(GlSMa, 2)
                        RS139.Fields("IDM").Value = GlMiA(GlSmI, 2)
                Case RibTab_Ter_Mitarb:
                        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                            If .ScheduleID > 0 Then
                                MitNr = GlMiT(.ScheduleID, 2) 'Aktive Mitarbeiter + Terminspalte
                            Else
                                MitNr = GlMiT(1, 2)
                            End If
                            RS139.Fields("IDR").Value = GlRmu(1, 2)
                            RS139.Fields("IDP").Value = GlMan(GlSMa, 2)
                            RS139.Fields("IDM").Value = MitNr
                        Else
                            If .ScheduleID > 0 Then
                                ManNr = GlMaT(.ScheduleID, 2)
                            Else
                                ManNr = GlMaT(1, 2)
                            End If
                            RS139.Fields("IDR").Value = GlRmu(1, 2)
                            RS139.Fields("IDM").Value = GlMiA(GlSmI, 2)
                            RS139.Fields("IDP").Value = ManNr
                        End If
                End Select
            End With
                        
            RS139.Fields("Aufgabe").Value = 0
            If GlOTS = True Then 'Online-Terminbuchungs System
                RS139.Fields("OnlGes").Value = 0
            End If

            If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                RS139.Fields("Replicated").Value = 1
                RS139.Fields("DAVChange").Value = 1
                RS139.Fields("LastModification").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                RS139.Fields("DAVDate").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
            Else
                RS139.Fields("Replicated").Value = 0
                RS139.Fields("DAVChange").Value = 0
            End If
            If GlTeE = True Then 'Email-Termin-Erinnerung
                If NotSt = 3 Then
                    If GlTrE = True Then 'Email-Termin-Erinnerung Speichern dauerhaft
                        SMeFr TeTit, TeMai, TeInh, TeFus, True, 1, False, FM.hwnd, TeFra
                        If GlMso = True Then 'Mesage Dialog Option
                            IniSetVal "TerSys", "TeErSp", 0
                            GlMso = False
                            GlTrE = False
                        End If
                        If GlMes = 33565 Then
                            RS139.Fields("NotifyStatus").Value = NotSt
                        Else
                            RS139.Fields("NotifyStatus").Value = 0
                        End If
                    Else
                        RS139.Fields("NotifyStatus").Value = NotSt
                    End If
                Else
                    RS139.Fields("NotifyStatus").Value = NotSt
                End If
            Else
                RS139.Fields("NotifyStatus").Value = 0
            End If
            RS139.Update
            
            Set RS140 = New ADODB.Recordset
            RS140.CursorLocation = adUseClient
            Set RS140 = DBCmRe1("qryTerGui3", "@IdStr", TmGui)
            If RS140.RecordCount > 0 Then
                GlTem = RS140.Fields("ID2").Value
            Else
                GlTem = -1
            End If
            RS140.Close
            Set RS140 = Nothing
            DoEvents
            TerNr = GlTem
        End If

    Else 'Verschieben

        If RS139.RecordCount > 0 Then
            If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                MitNr = RS139.Fields("IDM").Value
                For AktZa = 1 To UBound(GlMiT)
                    If MitNr = GlMiT(AktZa, 2) Then
                        MaIdx = AktZa
                        Exit For
                    End If
                Next AktZa
            Else
                ManNr = RS139.Fields("IDP").Value
                For AktZa = 1 To UBound(GlMaT)
                    If ManNr = GlMaT(AktZa, 2) Then
                        MaIdx = AktZa
                        Exit For
                    End If
                Next AktZa
            End If

            If RS139.Fields("GuiID").Value <> vbNullString Then
                TmGui = RS139.Fields("GuiID").Value
            Else
                TmGui = CreateID("T")
                RS139.Fields("GuiID").Value = TmGui
            End If

            If RS139.Fields("NotifyValue").Value <> vbNullString Then
                If IsNumeric(RS139.Fields("NotifyValue").Value) = True Then
                    If CInt(RS139.Fields("NotifyValue").Value) > 0 Then
                        NotVa = RS139.Fields("NotifyValue").Value
                    Else
                        NotVa = 24
                    End If
                Else
                    NotVa = 24
                End If
            Else
                NotVa = 24
            End If

            With CaEvt
                TmBet = .Subject
                DatSt = Left$(.StartTime, 10)
                DatEn = Left$(.EndTime, 10)
                ZeiSt = Right$(.StartTime, 8)
                ZeiEn = Right$(.EndTime, 8)
                GnzTa = .AllDayEvent

                NotDa = CDate(DateAdd("h", -NotVa, DatSt & Chr$(32) & ZeiSt))
                NotZe = TimeValue(DateAdd("h", -NotVa, DatSt & Chr$(32) & ZeiSt))

                If GlTyp < 2 Then
                    RS139.Fields("ZeiVon").Value = DatSt & Chr$(32) & ZeiSt
                    RS139.Fields("ZeiBis").Value = DatEn & Chr$(32) & ZeiEn
                    RS139.Fields("VonDat").Value = DatSt & Chr$(32) & ZeiSt
                    RS139.Fields("BisDat").Value = DatEn & Chr$(32) & ZeiEn
                    RS139.Fields("NotifySetDate").Value = NotDa
                    RS139.Fields("NotifySetTime").Value = NotZe
                Else
                    RS139.Fields("ZeiVon").Value = ZeiSt
                    RS139.Fields("ZeiBis").Value = ZeiEn
                    RS139.Fields("VonDat").Value = DatSt
                    RS139.Fields("BisDat").Value = DatEn
                    RS139.Fields("NotifySetDate").Value = NotDa
                    RS139.Fields("NotifySetTime").Value = NotZe
                End If

                RS139.Fields("NotifyValue").Value = NotVa
                RS139.Fields("Selekt").Value = GnzTa
                                    
                Select Case GlBut:
                Case RibTab_Ter_Raeume:
                        If .ScheduleID > 0 Then
                            SheId = GlRmu(.ScheduleID, 2)
                        Else
                            SheId = GlRmu(1, 2)
                        End If
                        RS139.Fields("IDR").Value = SheId
                Case RibTab_Ter_Mitarb:
                        If .ScheduleID <> MaIdx Then
                            AnMiT = True
                        End If
                        If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                            If .ScheduleID > 0 Then
                                MitNr = GlMiT(.ScheduleID, 2) 'Aktive Mitarbeiter + Terminspalte
                            Else
                                MitNr = GlMiT(1, 2)
                            End If
                            RS139.Fields("IDM").Value = MitNr
                        Else
                            If .ScheduleID > 0 Then
                                ManNr = GlMaT(.ScheduleID, 2)
                            Else
                                ManNr = GlMaT(1, 2)
                            End If
                            RS139.Fields("IDP").Value = ManNr
                        End If
                End Select
                If GlTrB = True Then 'Terminbearbeitung direkt im Kalender
                    RS139.Fields("IDKurz").Value = .Subject
                End If
            End With
            
            If GlOTS = True Then 'Online-Terminbuchungs System
                RS139.Fields("OnlGes").Value = 0
            End If

            If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                RS139.Fields("Replicated").Value = 1
                RS139.Fields("DAVChange").Value = 1
                RS139.Fields("LastModification").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                RS139.Fields("DAVDate").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
            Else
                RS139.Fields("Replicated").Value = 0
                RS139.Fields("DAVChange").Value = 0
            End If
            If GlTeE = True Then 'Email-Termin-Erinnerung
                If NotDa >= Now Then
                    NotSt = 3 'Senden
                Else
                    NotSt = 1 'nicht Senden
                End If
                If NotSt = 3 Then
                    If GlTrE = True Then 'Email-Termin-Erinnerung Speichern dauerhaft
                        SMeFr TeTit, TeMai, TeInh, TeFus, True, 1, False, FM.hwnd, TeFra
                        If GlMso = True Then 'Mesage Dialog Option
                            IniSetVal "TerSys", "TeErSp", 0
                            GlMso = False
                            GlTrE = False
                        End If
                        If GlMes = 33565 Then
                            RS139.Fields("NotifyStatus").Value = NotSt
                        Else
                            RS139.Fields("NotifyStatus").Value = 0
                        End If
                    Else
                        RS139.Fields("NotifyStatus").Value = NotSt
                    End If
                Else
                    RS139.Fields("NotifyStatus").Value = NotSt
                End If
            Else
                RS139.Fields("NotifyStatus").Value = 0
            End If
            RS139.Update
        End If
    End If
    RS139.Close
    Set RS139 = Nothing

    If GlOTS = True Then 'Online-Terminbuchungs System
        If DatSt >= Date Then
            With GlSyn
                .DatSt = Format$(DatSt, "dd.mm.yyyy")
                .DatEn = Format$(DatEn, "dd.mm.yyyy")
                .ZeiSt = Format$(ZeiSt, "hh:mm:ss")
                .ZeiEn = Format$(ZeiEn, "hh:mm:ss")
                .TeBet = vbNullString
                .GuiID = TmGui
                .GnzTa = GnzTa
                If NeuTe = True Then 'neuer Termin
                    .PrTyp = "B"
                    If GlMPl = True Then 'Mitarbeiterplan anstelle von Mandantenplan
                        .MaIdx = GlSMo 'Standardmitarbeiter Online-Terminbuchungs Sytem
