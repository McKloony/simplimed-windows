                    If GlClp(AktPo, 13) <> vbNullString Then RS123.Fields("GesBetrag").Value = GlClp(AktPo, 13)
                    If GlClp(AktPo, 14) <> vbNullString Then RS123.Fields("Provision").Value = GlClp(AktPo, 14)
                    If GlClp(AktPo, 15) <> vbNullString Then RS123.Fields("IDU").Value = GlClp(AktPo, 15)
                    RS123.Fields("ID0").Value = GlClp(AktPo, 16)
