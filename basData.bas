            End If
            Set RpCol = RpCls.Find(Ban_GuiID)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                BaGui = RpRow.Record(RpCol.ItemIndex).Value
            Else
                BaGui = vbNullString
            End If

            If ChZuo.Value = xtpChecked Then
                If CmZuo.ListIndex = 0 Then 'Ja
                    DBCmEx3 "qrySimBaBez", "@IdBez", "@IdSel", "@IdxNr", -1, -1, BaIdx
                Else
                    DBCmEx3 "qrySimBaBez", "@IdBez", "@IdSel", "@IdxNr", 0, -1, BaIdx
                    If GlBuL = True Then 'echtes Löschen erlauben
                        DBCmEx1 "qrySimBuLoG", "@IdStr", BaGui
                    Else
                        DBCmEx2 "qrySimBuStg", "@IdSto", "@IdStr", True, BaGui
                    End If
                End If
            
            End If

            If BaSel = "nein" Then
                If ChKen.Value = xtpChecked Then
                    DBCmEx2 "qrySimBaSel", "@IdSel", "@IdxNr", Kennz, BaIdx
                End If
            End If

            If BaBez = "nein" Then
                If ChTyp = xtpChecked Then
                    Select Case CmTyp.ListIndex
                    Case 0: If BuBet > 0 Then BuBet = BuBet * (-1)
                    Case 1: If BuBet < 0 Then BuBet = BuBet * (-1)
                    End Select
                End If
                If ChGeg.Value = xtpChecked Then
                    DBCmEx2 "qrySimBaBnk", "@IdBnk", "@IdxNr", BnkNr, BaIdx
                End If
                If ChMit.Value = xtpChecked Then
                    DBCmEx2 "qrySimBaMan", "@IdMan", "@IdxNr", MitNr, BaIdx 'ManNr / MitNr vertauscht lassen
                End If
                If ChMan.Value = xtpChecked Then
                    DBCmEx2 "qrySimBaMit", "@IdMit", "@IdxNr", ManNr, BaIdx 'ManNr / MitNr vertauscht lassen
                End If
                If ChTyp = xtpChecked Then
                    DBCmEx2 "qrySimBaBet", "@IdBet", "@IdxNr", BuBet, BaIdx
                End If
            End If
        End If
    Next RpRow
End If

Set RpSel = Nothing
Set RpCo1 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BaAnp " & Err.Number
Resume Next

End Sub
