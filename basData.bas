Set FM = frmMain
Set CmBrs = FM.comBar01

OutGb = CBool(IniGetVal("System", "OutGeb"))

SOuOp 'Outlook
DoEvents

Set NaSpa = OutOb.GetNamespace("MAPI") 'NameSpace

If GlMaF = True Then
    Set MapFo = NaSpa.GetDefaultFolder(olFolderCalendar)
Else
    Set MapFo = NaSpa.PickFolder
End If
    
If TypeName(MapFo) = "Nothing" Then
    Exit Sub
ElseIf MapFo.DefaultItemType <> olAppointmentItem Then
    Exit Sub
End If

Set KoIts = MapFo.Items
GesZa = KoIts.Count

If GesZa > 0 Then
    Set RS121 = New ADODB.Recordset 'Termine
    With RS121
        .CursorLocation = adUseClient
        .Source = "qryTerNeu"
        .ActiveConnection = DB1
        .CursorType = adOpenKeyset
        .LockType = adLockOptimistic
        .Open Options:=adCmdTableDirect
    End With
    If RS121.Supports(adAddNew) Then
                   
        Load frmStatus
        frmStatus.Caption = "Outlookimport"
        Set PrBr1 = frmStatus.prbStat1
        Set PrBr2 = frmStatus.prbStat2
        Set TxDum = frmStatus.txtDummy
        PrBr1.Min = 0
        PrBr1.Max = GesZa
        frmStatus.Show
        DoEvents
        
        For Each KoItm In KoIts
            With KoItm
                RS121.AddNew
                If .Subject <> vbNullString Then
                    RS121.Fields("IDKurz").Value = .Subject
                Else
                    RS121.Fields("IDKurz").Value = "Outlooktermin"
                End If
                If .start <> vbNullString Then
                    RS121.Fields("VonDat").Value = DateValue(.start)
                    RS121.Fields("ZeiVon").Value = TimeValue(.start)
                End If
                If .End <> vbNullString Then
                    RS121.Fields("BisDat").Value = DateValue(.End)
                    RS121.Fields("ZeiBis").Value = TimeValue(.End)
                End If
                If .BusyStatus <> vbNullString Then RS121.Fields("Farbtyp").Value = .BusyStatus - 1
                If .AllDayEvent <> vbNullString Then RS121.Fields("Selekt").Value = CBool(.AllDayEvent)
                If .ReminderSet <> vbNullString Then RS121.Fields("Erinnerung").Value = .ReminderSet
                If .Body <> vbNullString Then
                    If Len(.Body) > 250 Then
                        RS121.Fields("Kommentar").Value = Left$(.Body, 249)
                    Else
                        RS121.Fields("Kommentar").Value = .Body
                    End If
                End If
                If .Location <> vbNullString Then RS121.Fields("Raum").Value = .Location
                If .Importance <> vbNullString Then
                    Select Case .Importance
                    Case 2: Prior = 1
                    Case 1: Prior = 2
                    Case 0: Prior = 3
                    End Select
                Else
                    Prior = 2
                End If
                OuTer(11, AktZa) = Prior
                If .ReminderMinutesBeforeStart <> vbNullString Then
                    Select Case .ReminderMinutesBeforeStart
                    Case 0: VoWar = 1
                    Case 1: VoWar = 2
                    Case 2: VoWar = 3
                    Case 5: VoWar = 4
                    Case 10: VoWar = 5
                    Case 15: VoWar = 6
                    Case 30: VoWar = 7
                    Case 60: VoWar = 8
                    Case 120: VoWar = 9
                    Case 300: VoWar = 10
                    Case 600: VoWar = 11
                    Case 1440: VoWar = 12
                    Case 2880: VoWar = 13
                    Case 7200: VoWar = 14
                    Case 10080: VoWar = 15
                    Case 20160: VoWar = 16
                    End Select
                Else
                    VoWar = 0
                End If
                RS121.Fields("Priorität").Value = Prior
                RS121.Fields("Vorwarn").Value = VoWar
                If .LastModificationTime <> vbNullString Then
                    RS121.Fields("LastModification").Value = Format$(DateValue(.LastModificationTime), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(.LastModificationTime), "hh:mm:ss")
                Else
                    RS121.Fields("LastModification").Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                End If
                If .BillingInformation <> vbNullString Then
                    RS121.Fields("GuiID").Value = .BillingInformation 'GuiID
                Else
                    RS121.Fields("GuiID").Value = CreateID("T")
                End If
                RS121.Fields("IDR").Value = GlRmu(1, 0)
                RS121.Fields("IDP").Value = ManNr
                RS121.Fields("IDM").Value = MitNr
                RS121.Fields("IDSer").Value = 5 'Standardtermin
                RS121.Fields("Replacated").Value = -1 'Synchronisiert
            End With
            AktZa = AktZa + 1
            DoEvents
            If TxDum.Text = "B" Then Exit For 'Abbrechen
            PrBr1.Value = AktZa
        Next KoItm
        
        Unload frmStatus
        Set frmStatus = Nothing
        DoEvents
        
        RS121.Update
    End If

    RS121.Close
    Set RS121 = Nothing
End If
DoEvents

SUpTe
DoEvents

Set KoItm = Nothing
Set NaSpa = Nothing
Set MapFo = Nothing
Set KoIts = Nothing

Set CmBrs = Nothing

Set clAnw = Nothing

Exit Sub

LiErr:
If GlDbg = True Then
    MsgBox Err.Description, 48, "S_TeImO " & Err.Number
    SErLog Err.Description & " S_TeImO " & Err.Number & " - " & Err.Source
End If
Resume Next

