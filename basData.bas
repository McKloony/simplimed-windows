                DBCmEx2 "qryTerRmu", "@IdRmu", "@IdxNr", RmuNr, TerNr
                If PrStr = vbNullString Then
                    PrStr = "Raumzuordnung"
                Else
                    PrStr = PrStr & ", Raumzuordnung"
                End If
            End If

            If ChMan.Value = xtpChecked Then
                DBCmEx2 "qryTerMan", "@IdMan", "@IdxNr", mAnDa, TerNr
                If PrStr = vbNullString Then
                    PrStr = "Mandant"
                Else
                    PrStr = PrStr & ", Mandant"
                End If
            End If
            
            If ChMit.Value = xtpChecked Then
                DBCmEx2 "qryTerMit", "@IdMit", "@IdxNr", Mitar, TerNr
                If PrStr = vbNullString Then
                    PrStr = "Mitarbeiter"
                Else
                    PrStr = PrStr & ", Mitarbeiter"
                End If
            End If

            If ChRef.Value = xtpChecked Then
                DBCmEx2 "qryTerMas", "@IdMas", "@IdxNr", MasTe, TerNr
                DBCmEx2 "qryTerMas1", "@MasTe", "@IdxNr", MasAl, MasTe
                If PrStr = vbNullString Then
                    PrStr = "Referenznummer"
                Else
                    PrStr = PrStr & ", Referenznummer"
                End If
            End If
            
            If ChZeS.Value = xtpChecked Then
                DBCmEx2 "qryTerZei1", "@ZeSta", "@IdxNr", ZeSta, TerNr
                If PrStr = vbNullString Then
                    PrStr = "Startzeit"
                Else
                    PrStr = PrStr & ", Startzeit"
                End If
            End If
            
            If ChZeE.Value = xtpChecked Then
                DBCmEx2 "qryTerZei2", "@ZeEnd", "@IdxNr", ZeEnd, TerNr
                If PrStr = vbNullString Then
                    PrStr = "Endzeit"
                Else
                    PrStr = PrStr & ", Endzeit"
                End If
            End If

            If ChFa1.Value = xtpChecked Then
                DBCmEx2 "qryTerFal1", "@IdDat", "@IdxNr", Fali1, TerNr
                If PrStr = vbNullString Then
                    PrStr = "Fälligkeit1"
                Else
                    PrStr = PrStr & ", Fälligkeit1"
                End If
            End If
            
            If ChFa2.Value = xtpChecked Then
                DBCmEx2 "qryTerFal2", "@IdDat", "@IdxNr", Fali2, TerNr
                If PrStr = vbNullString Then
                    PrStr = "Fälligkeit2"
                Else
                    PrStr = PrStr & ", Fälligkeit2"
                End If
            End If

            If ChRep.Value = xtpChecked Then
                If CmRep.ListIndex = 0 Then
                    If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                        DBCmEx1 "qryTerRep2", "@IdxNr", TerNr
                        DBCmEx1 "qryTerRep3", "@IdxNr", TerNr '[LastModification]
                    Else
                        DBCmEx1 "qryTerRep1", "@IdxNr", TerNr
                    End If
                    DBCmEx3 "qryDAVTeCh3", "@IdSet", "@IdDat", "@IdxNr", 1, Now, TerNr
                Else
                    DBCmEx1 "qryTerRep1", "@IdxNr", TerNr
                    DBCmEx1 "qryTerRep3", "@IdxNr", TerNr
                    DBCmEx3 "qryDAVTeCh3", "@IdSet", "@IdDat", "@IdxNr", 0, Now, TerNr
                End If
                If PrStr = vbNullString Then
                    PrStr = "Synchronisation"
                Else
                    PrStr = PrStr & ", Synchronisation"
                End If
                If TmGui = vbNullString Then
                    TmGui = CreateID("T")
                    DBCmEx2 "qryTerGuiSet", "@IdStr", "@IdxNr", TmGui, TerNr
                End If
            End If

            If ChPas.Value = xtpChecked Then
                If Passi > 0 Then
                    Select Case Passi
                    Case 1:
                        DBCmEx2 "qryTerPaSe", "@IdPas", "@IdxNr", -1, TerNr '[Passiv]
                    Case 2:
                        DBCmEx2 "qryTerPaSe", "@IdPas", "@IdxNr", 0, TerNr
                        If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                            DBCmEx1 "qryTerRep2", "@IdxNr", TerNr
                            DBCmEx1 "qryTerRep3", "@IdxNr", TerNr '[LastModification]
                            DBCmEx3 "qryDAVTeCh3", "@IdSet", "@IdDat", "@IdxNr", 1, Now, TerNr
                        Else
                            DBCmEx1 "qryTerRep1", "@IdxNr", TerNr
                            DBCmEx3 "qryDAVTeCh3", "@IdSet", "@IdDat", "@IdxNr", 0, Now, TerNr
                        End If
                    End Select
                    If PrStr = vbNullString Then
                        PrStr = "Stornierung"
                    Else
                        PrStr = PrStr & ", Stornierung"
                    End If
                End If
            End If
            
            If ChAbg.Value = xtpChecked Then
                Select Case CmAbg.ListIndex
                Case 0: 'Keine Leistungen vorhanden
                    DBCmEx2 "qryTerWied1", "@IdWid", "@IdxNr", 0, TerNr
                    DBCmEx2 "qryTerAuf", "@IdAuf", "@IdxNr", 0, TerNr
                Case 1: 'Leistungen vorhanden
                    Set RS134 = New ADODB.Recordset 'wurden überhaupt Leistungen zugeordnet?
                    RS134.CursorLocation = adUseClient
                    Set RS134 = DBCmRe1("qryAnKa1e", "@IdxNr", TerNr)
                    If RS134.RecordCount > 0 Then
                        DBCmEx2 "qryTerWied1", "@IdWid", "@IdxNr", -1, TerNr
                        DBCmEx2 "qryTerAuf", "@IdAuf", "@IdxNr", 0, TerNr
                        DBCmEx2 "qryAnKa1c", "@IdBol", "@IdxNr", 0, TerNr
                    Else
                        DBCmEx2 "qryTerWied1", "@IdWid", "@IdxNr", 0, TerNr
                    End If
                    RS134.Close
                    Set RS134 = Nothing
                Case 2: 'Bereits abgerechnet
                    Set RS134 = New ADODB.Recordset 'Wurden überhaupt Leistungen zugeordnet?
                    RS134.CursorLocation = adUseClient
                    Set RS134 = DBCmRe1("qryAnKa1e", "@IdxNr", TerNr)
                    If RS134.RecordCount > 0 Then
                        DBCmEx2 "qryTerWied1", "@IdWid", "@IdxNr", -1, TerNr
                        DBCmEx2 "qryTerAuf", "@IdAuf", "@IdxNr", -1, TerNr
                        DBCmEx2 "qryAnKa1c", "@IdBol", "@IdxNr", -1, TerNr
                    Else
                        DBCmEx2 "qryTerWied1", "@IdWid", "@IdxNr", 0, TerNr
                    End If
                    RS134.Close
                    Set RS134 = Nothing
                End Select
                If PrStr = vbNullString Then
                    PrStr = "Leistungen"
                Else
                    PrStr = PrStr & ", Leistungen"
                End If
            End If
            
            If ChNot.Value = xtpChecked Then
                NotDa = CDate(DateAdd("h", -NotVa, DaSta & Chr$(32) & ZeSta))
                DBCmEx3 "qryTerNotDat", "@IdDat", "@IdTim", "@IdxNr", NotDa, NotDa, TerNr
                DBCmEx2 "qryTerNotVal", "@IdSet", "@IdxNr", NotVa, TerNr
                If GlTeE = True Then 'Email-Termin-Erinnerung
                    DBCmEx2 "qryTerNotStat", "@IdSet", "@IdxNr", 3, TerNr
                End If
                If PrStr = vbNullString Then
                    PrStr = "Emailerinnerung aktiviert"
                Else
                    PrStr = PrStr & ", Emailerinnerung aktiviert"
                End If
            End If
            
            If ChKen.Value = xtpChecked Then
                TmGui = CreateID("T")
                DBCmEx2 "qryTerGuiSet", "@IdStr", "@IdxNr", TmGui, TerNr
                If PrStr = vbNullString Then
                    PrStr = "Terminkennung"
                Else
                    PrStr = PrStr & ", Terminkennung"
                End If
            End If

            AktPo = AktPo + 1
            PrGui = CreateID("P")
            MitNa = GlMiA(GlSmI, 1)
            If PrStr = vbNullString Then
                PrStr = "Terminanpassung"
            Else
                PrStr = "Terminanpassung: " & PrStr
            End If
            DBCmEx7 "qryTerPrAd", "@IdxNr", "@GuiId", "@TerId", "@IdDat", "@IdZei", "@IdStr", "@IdKom", TerNr, PrGui, TmGui, Now, Now, PrStr, MitNa
            DoEvents
        End If
    Next RpRow
End If

Set RpCls = Nothing
Set RpSel = Nothing
Set RpCo1 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TeAnp " & Err.Number
Resume Next

End Sub
Public Sub S_TeAu(ByVal BuDat As Date, ByVal MaNum As Long, ByVal MiNum As Long, ByVal ErKId As Long, ByVal ErKNr As Long, ErKBe As String, ByVal GeKId As Long, ByVal GeKNr As Long, ByVal GeKBe As String, ByVal StKID As Long, ByVal StKNr As Long, ByVal StKBe As String)
On Error GoTo KoErr
'Gleicht einen offenen Posten aus

Dim TerDa As Date
Dim FaDa1 As Date
Dim FaDa2 As Date
Dim ZaZil As Long
Dim TerNr As Long
Dim MasNr As Long
Dim RowNr As Long   'Zeilennummer
Dim PatNr As Long
Dim ManNr As Long
Dim MitNr As Long
Dim BuBel As Long
Dim BuJah As Long
Dim GeBet As Double
Dim SeBet As Double
Dim BzBet As Double
Dim TSENa As String  'Kassenkennung
Dim PaNam As String 'Patientenname
Dim BelNr As String 'Belegnummer
Dim KomTe As String
Dim AnzPo As Integer 'Anzahl Posten
Dim AktPo As Integer
Dim BuTyp As Integer
Dim FoWär As Integer
Dim Frage As Integer
Dim AktZa As Integer
Dim AktKo As Integer
Dim Kasse As Boolean
Dim Verre As Boolean
Dim Gefun As Boolean 'Geldkonto gefunden
Dim Mld1, Tit1 As String
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows

If RpSel.Count = 0 Then Exit Sub

AnzPo = RpSel.Count

If MiNum > 0 Then
    MitNr = MiNum
Else
    MitNr = GlMiA(GlSmI, 2)
End If

If AnzPo > 0 Then
    If AnzPo > 1 Then
        Load frmStatus
        frmStatus.Caption = "Postenaugleich"
        Set PrBr1 = frmStatus.prbStat1
        Set PrBr2 = frmStatus.prbStat2
        Set TxDum = frmStatus.txtDummy
        PrBr1.Min = 0
        PrBr1.Max = AnzPo
        frmStatus.Show
        DoEvents
    End If
    
    Set RS121 = New ADODB.Recordset
    With RS121 'neue Buchung
        .CursorLocation = adUseClient
        .Source = "qrySimBuNe"
        .ActiveConnection = DB1
        .CursorType = adOpenStatic
        .LockType = adLockOptimistic
        .Open Options:=adCmdTableDirect
    End With
        
    If RS121.Supports(adAddNew) Then
        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                Gefun = False
                RowNr = RpRow.Index
                                    
                Set RpCol = RpCls.Find(Ter_ID2)
                TerNr = RpRow.Record(RpCol.ItemIndex).Value
                If MaNum > 0 Then
                    ManNr = MaNum
                Else
                    Set RpCol = RpCls.Find(Ter_IDP)
                    ManNr = RpRow.Record(RpCol.ItemIndex).Value
                End If
                Set RpCol = RpCls.Find(Ter_ID0)
                PatNr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Ter_Patient)
                PaNam = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Ter_VonDat)
                TerDa = CDate(RpRow.Record(RpCol.ItemIndex).Value)
                Set RpCol = RpCls.Find(Ter_TerBet)
                GeBet = CDbl(Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1))
                Set RpCol = RpCls.Find(Ter_SerBet)
                SeBet = CDbl(Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1))
                Set RpCol = RpCls.Find(Ter_BezBet)
                BzBet = CDbl(Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1))
                Set RpCol = RpCls.Find(Ter_Fallig1)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    FaDa1 = CDate(RpRow.Record(RpCol.ItemIndex).Value)
                End If
                Set RpCol = RpCls.Find(Ter_Fallig2)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    FaDa2 = CDate(RpRow.Record(RpCol.ItemIndex).Value)
                Else
                    For AktZa = 1 To UBound(GlZah) 'Standardzahlungsziel
                        If GlZah(AktZa, 0) = GlStZ Then
                            ZaZil = GlZah(AktZa, 2)
                            Exit For
                        End If
                    Next AktZa
                    FaDa2 = DateAdd("d", ZaZil, TerDa)
                End If
                Set RpCol = RpCls.Find(Ter_MasTer)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    MasNr = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    MasNr = 0
                End If

                If AnzPo > 1 Then 'mehrere Posten selektiert
                    If GlMVo = True Then 'mandantenbezogene Vorgaben verwenden
                        For AktZa = 1 To UBound(GlMan)
                            If ManNr = GlMan(AktZa, 2) Then 'Mandantennummer
                                If GlMan(AktZa, 28) <> vbNullString Then GeKId = GlMan(AktZa, 28) 'Geldkonto Bank
                                If GlMan(AktZa, 26) <> vbNullString Then ErKId = GlMan(AktZa, 26) 'Erlöskonto Bank
                                If GlMan(AktZa, 37) <> vbNullString Then StKID = GlMan(AktZa, 37) 'Steuerkonto
                                Exit For
                            End If
                        Next AktZa
                    End If
                End If

                For AktZa = 1 To UBound(GlGeK) 'Geldkonten
                    If GlGeK(AktZa, 0) = GeKId Then
                        Kasse = CBool(GlGeK(AktZa, 5))
                        Verre = CBool(GlGeK(AktZa, 7))
                        TSENa = CStr(GlGeK(AktZa, 8))
                        Gefun = True
                        Exit For
                    End If
                Next AktZa
                
                If Gefun = False Then
                    S_KoDe GeKId
                    With GlKto
                        GeKNr = .KtoNr
                        GeKBe = .KtBez
                        GeKId = .KtBnk
                    End With
                    For AktZa = 1 To UBound(GlGeK) 'Geldkonten
                        If GlGeK(AktZa, 0) = GeKId Then
                            Kasse = CBool(GlGeK(AktZa, 5))
                            Verre = CBool(GlGeK(AktZa, 7))
                            TSENa = CStr(GlGeK(AktZa, 8))
                            Exit For
                        End If
                    Next AktZa
                End If

                If AnzPo > 1 Then 'mehrere Posten selektiert
                    If GlMVo = True Then 'mandantenbezogene Vorgaben verwenden
                        If GlBuc = True Then 'einfache Buchhaltung verwenden
                            For AktZa = 1 To UBound(GlGeK) 'Geldkonten
                                If GlGeK(AktZa, 0) = GeKId Then
                                    GeKBe = GlGeK(AktZa, 1)
                                    GeKNr = GlGeK(AktZa, 2)
                                    Exit For
                                End If
                            Next AktZa
                        Else
                            S_KoDe GeKId
                            With GlKto
                                GeKNr = .KtoNr
                                GeKBe = .KtBez
                            End With
                        End If
                        S_KoDe ErKId
                        With GlKto
                            ErKNr = .KtoNr
                            ErKBe = .KtBez
                        End With
                        S_KoDe StKID
                        With GlKto
                            StKNr = .KtoNr
                            StKBe = .KtBez
                        End With
                    End If
                End If

                DBCmEx2 "qryTerFal1", "@IdDat", "@IdxNr", FaDa1, TerNr
                DoEvents
                
                If MasNr > 0 Then
                    DBCmEx2 "qryTerBez2", "@IdBet", "@IdxNr", SeBet, MasNr
                ElseIf TerNr > 0 Then
                    DBCmEx2 "qryTerBez1", "@IdBet", "@IdxNr", SeBet, TerNr
                End If
                
                BuJah = Year(Date)
                BuBel = S_BuBel(ManNr, BuJah, GeKId)
                DoEvents
                
                FoWär = S_AdIdi(PatNr, "Währung")
                DoEvents
            
                RS121.AddNew 'neue Buchung
                RS121.Fields("IDP").Value = PatNr
                RS121.Fields("IDB").Value = GeKId
                If GlBuc = True Then 'einfache Buchhaltung verwenden
                    RS121.Fields("IDK").Value = ErKNr
                    RS121.Fields("IDG").Value = 0
                    RS121.Fields("IDKurz").Value = ErKBe
                Else
                    RS121.Fields("IDK").Value = GeKNr
                    RS121.Fields("IDG").Value = ErKNr
                    RS121.Fields("IDKurz").Value = GeKBe
                    RS121.Fields("IDGegen").Value = ErKBe
                    RS125.Fields("Doppelt").Value = -1
                End If
                RS121.Fields("IDA").Value = BuTyp
                RS121.Fields("IDT").Value = ManNr
                RS121.Fields("IDM").Value = MitNr
                RS121.Fields("Datum").Value = BuDat
                RS121.Fields("Steuer").Value = 0
                RS121.Fields("Buchtext").Value = "Beleg: (" & BuBel & ")"
                RS121.Fields("Selekt").Value = True
                RS121.Fields("Währung").Value = FoWär
                RS121.Fields("Einnahme").Value = SeBet
                RS121.Fields("Beleg").Value = BuBel
                RS121.Update
            End If
            
            If AnzPo > 1 Then
                AktPo = AktPo + 1
                If TxDum.Text = "B" Then Exit For 'Abbrechen
                PrBr1.Value = AktPo
            End If
            
        Next RpRow
    End If
    RS121.Close
    Set RS121 = Nothing
    
    If AnzPo > 1 Then
        Unload frmStatus
        Set frmStatus = Nothing
        DoEvents
    End If
    
    If GlJet = True Then SDBSav
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TeAu " & Err.Number
Resume Next

End Sub
Private Function S_TeBa(ByVal PrTyp As String, ByVal TmStr As String, ByVal UsNam As String, ByVal UsPas As String, ByVal UseId As String, ByVal MitNr As String) As Integer
On Error GoTo LiErr '~~~
'Senden der Informationen für den OTS Reset

Dim RetW3 As String
Dim Stat3 As String
Dim ReTr3 As String
Dim AkZa2 As Integer
Dim ReStA As Boolean
Dim AryLo() As String

Dim clCal As New clsCalendar

Set FS = frmStatus
Set Lbl01 = FS.lblLab01

AryLo = Split(TmStr, "#")

For AkZa2 = 0 To UBound(AryLo)
    If AryLo(AkZa2) <> vbNullString Then ' create a log file
        If AryLo(AkZa2) <> vbNullString Then
            clCal.SendLogFile PrTyp, UsNam, UsPas, AryLo(AkZa2), Stat3, RetW3, ReTr3, UseId ' send the log file
            ReStA = CBool(Stat3)
            If ReStA = False Then
                Lbl01.Caption = "Feher: " & PrTyp & " " & RetW3 & " " & ReTr3
                If GlDbg = True Then
                    SErLog "S_TeBa" & " " & PrTyp & " " & TmStr & Chr$(10) & RetW3 & Chr$(10) & ReTr3 & Chr$(10) & Chr$(10)
                End If
            End If
        End If
    End If
Next

S_TeBa = AkZa2

Exit Function

LiErr:
If GlDbg = True Then
    SPopu "S_TeBa " & Err.Number, Err.Description, IC48_Warning
    SErLog Err.Description & " S_TeBa " & Err.Number & " - " & Err.Source
End If
Resume Next

End Function
Public Sub S_TeBe()
On Error GoTo GrErr
'Termin bereinigen

Dim RowNr As Long
Dim TerNr As Long
Dim AnzTe As Long
Dim Frage As Integer
Dim Mld1, Mld2, Tit1 As String
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
