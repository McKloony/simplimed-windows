Public Sub S_Tabe(Optional DatSe As String = vbNullString, Optional ByVal DatTa As String = vbNullString, Optional ByVal DatUs As String = vbNullString, Optional ByVal DatPa As String = vbNullString)
On Error GoTo KoErr
'Listet alle gefundenen Datenbanken auf einem SQL Server auf

Dim DatNa As String
Dim DaTab As String
Dim DaSer As String
Dim TmStr As String
Dim AktZa As Integer
Dim AktSo As Integer
Dim AktDa As Integer
Dim DatDa() As String
Dim CmDat As XtremeSuiteControls.ComboBox

Set FM = frmSQLCon
Set CmDat = FM.cmbDatNa

CmDat.Clear
DoEvents

Screen.MousePointer = vbHourglass

DaSer = IniGetVal("System", "DatSer")
DaTab = IniGetVal("System", "DatTab")

If DatSe <> vbNullString Then
    SDBStb True, DatSe, DatTa, DatUs, DatPa
    DoEvents
    Set ShmRS = DB2.OpenSchema(adSchemaCatalogs)
Else
    Set ShmRS = DB1.OpenSchema(adSchemaCatalogs)
End If

If ShmRS.RecordCount > 0 Then
    ShmRS.MoveFirst
    Do
    DatNa = ShmRS.Fields(0).Value
    Select Case DatNa
    Case "master":
    Case "model":
    Case "msdb":
    Case "tempdb":
    Case Else:
        ReDim Preserve DatDa(AktDa)
        DatDa(AktDa) = DatNa
        AktDa = AktDa + 1
    End Select
    ShmRS.MoveNext
    Loop Until ShmRS.EOF

    For AktZa = UBound(DatDa) - 1 To LBound(DatDa) Step -1
        For AktSo = LBound(DatDa) To AktZa
            If DatDa(AktSo) > DatDa(AktSo + 1) Then
                TmStr = DatDa(AktSo)
                DatDa(AktSo) = DatDa(AktSo + 1)
                DatDa(AktSo + 1) = TmStr
            End If
        Next AktSo
    Next AktZa
    
    For AktDa = 0 To UBound(DatDa)
        CmDat.AddItem DatDa(AktDa), AktDa
        CmDat.ItemData(AktDa) = AktDa + 1
    Next AktDa
    
    If DatSe <> vbNullString Then
        CmDat.ListIndex = 0
    End If
    For AktZa = 0 To UBound(DatDa)
        If LCase(DatDa(AktZa)) = LCase(DaTab) Then
            CmDat.ListIndex = AktZa
            Exit For
        End If
    Next AktZa
End If

ShmRS.Close
Set ShmRS = Nothing

If DatSe <> vbNullString Then
    SDBStb False
End If

Screen.MousePointer = vbNormal

Exit Sub

KoErr:
Exit Sub

End Sub

