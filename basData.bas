Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCo6 = FM.repCont6
If GlWaZ = True Then 'Wartezimmer Kontextmenü
    Set RpCls = RpCo6.Columns
    Set RpSel = RpCo6.SelectedRows
Else
    Set RpCls = RpCo1.Columns
    Set RpSel = RpCo1.SelectedRows
End If

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

AnzTe = RpSel.Count
Tit1 = "Termine bereinigen"

If AnzTe > 1 Then
    Mld1 = "Sollen jetzt die " & AnzTe & " markierten Termine DSGVO konform bereinigt werden?"
ElseIf AnzTe = 1 Then
    Mld1 = "Soll jetzt der markierte Termin DSGVO konform bereinigt werden?"
ElseIf AnzTe = 0 Then
    Exit Sub
End If

Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
If Frage = 6 Then
    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            RowNr = RpRow.Index
            Set RpCol = RpCls.Find(Ter_ID2)
            TerNr = RpRow.Record(RpCol.ItemIndex).Value
            DBCmEx2 "qryTerVe1", "@IdStr", "@IdxNr", "***gelöscht***", TerNr
        End If
    Next RpRow
    
    Screen.MousePointer = vbHourglass
    clFen.FenDsk 2

    Set RpSel = RpCo1.SelectedRows
    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        RowNr = RpRow.Index
        SUpTe RowNr
    End If

    clFen.FenDsk 3
    Screen.MousePointer = vbNormal
End If

Set RpSel = Nothing
Set RpCo1 = Nothing
Set RpCo6 = Nothing

Set clFen = Nothing

Exit Sub

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TeBe " & Err.Number
Resume Next

End Sub
