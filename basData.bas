Public Function S_KrPr(ByVal AbRow As Integer, ByVal AbCol As Integer, ByVal AbNew As Single) As Boolean
On Error GoTo LiErr
'Überprüft ob neuer Rechnungsbetrag kleiner ist als Anzahlungsbetrag

Dim BeBet As Double 'Bezaltbetrag
Dim ReBet As Double 'Krankenblattgesamtbetrag
Dim KraBe As Double 'Krankenblattbetrag
Dim KrAnz As Single 'Krankenblattanzahl
Dim KrMul As Single 'Krankenblattmultiplikator
Dim KrLok As Boolean
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo6 = FM.repCont6
Set RpCo3 = FM.repCont3
Set RpCo3 = FM.repCont3

If RpCo3.Records.Count > 0 Then
    Set RpSel = RpCo3.SelectedRows
    Set RpRow = RpSel(0)
    Set RpCls = RpCo3.Columns
    Set RpCol = RpCls.Find(Rec_Bezahlt)
    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
        BeBet = RpRow.Record(RpCol.ItemIndex).Value
    Else
        BeBet = 0
    End If
End If

Set RpSel = RpCo6.SelectedRows
Set RpCls = RpCo6.Columns
Set RpRws = RpCo6.Rows

If RpRws.Count > 0 Then
    For Each RpRow In RpRws
        If RpRow.GroupRow = False Then
            If AbRow = RpRow.Index Then
                Select Case AbCol
                Case Kra_Anz:
                    Set RpCol = RpCls.Find(Kra_Faktor)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        KrMul = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        KrMul = 0
                    End If
                    Set RpCol = RpCls.Find(Kra_Betrag)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        KraBe = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        KraBe = 0
                    End If
                    KrAnz = AbNew
                Case Kra_Faktor:
                    Set RpCol = RpCls.Find(Kra_Anz)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        KrAnz = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        KrAnz = 0
                    End If
                    Set RpCol = RpCls.Find(Kra_Betrag)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        KraBe = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        KraBe = 0
                    End If
                    KrMul = AbNew
                Case Kra_Betrag:
                    Set RpCol = RpCls.Find(Kra_Anz)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        KrAnz = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        KrAnz = 0
                    End If
                    Set RpCol = RpCls.Find(Kra_Faktor)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        KrMul = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        KrMul = 0
                    End If
                    KraBe = AbNew
                End Select
            Else
                Set RpCol = RpCls.Find(Kra_Anz)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    KrAnz = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    KrAnz = 0
                End If
                Set RpCol = RpCls.Find(Kra_Faktor)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    KrMul = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    KrMul = 0
                End If
                Set RpCol = RpCls.Find(Kra_Betrag)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    KraBe = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    KraBe = 0
                End If
            End If
            ReBet = ReBet + (KraBe * KrAnz * KrMul) 'Neuer Krankenblattbetrag
        End If
    Next RpRow
End If

If ReBet < BeBet Then
    S_KrPr = True
Else
    S_KrPr = False
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing
Set RpCo6 = Nothing

Exit Function

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KrPr " & Err.Number
Resume Next

End Function
Private Sub S_KrRec(ByRef RST As ADODB.Recordset)
On Error GoTo LiErr
'Fügt der Rechnungstabelle die Datensätze an

Dim MitNr As Long
Dim ManNr As Long
Dim KrDat As Date
Dim Ausri As String
Dim NeNam As String
Dim DaNam As String
Dim IdStr As String
Dim StrDa As String
Dim StrZe As String
Dim GrTag As String
Dim GrWek As String
Dim GrMon As String
Dim GrQua As String
Dim KrTyp As Integer
Dim AktZa As Integer
Dim QurTa As Integer
Dim Posi1 As Integer
Dim Posi2 As Integer
Dim Lange As Integer
Dim EinOk As Boolean
Dim RpCoK As XtremeReportControl.ReportControl

Set FM = frmMain
Set RpCoK = FM.repContK
Set RpRcs = RpCoK.Records

EinOk = True

Do
If RST.Fields("Datum").Value = vbNullString Then
    KrDat = Date
Else
    KrDat = RST.Fields("Datum").Value
End If
StrDa = Left$(KrDat, 10)

If RST.Fields("IDM").Value > 0 Then
    MitNr = RST.Fields("IDM").Value
Else
    MitNr = 0
End If
For AktZa = 1 To UBound(GlMiA)
    If MitNr = GlMiA(AktZa, 2) Then
        ManNr = GlMiA(AktZa, 7)
        Exit For
    End If
Next AktZa

If RST.Fields("Druckdatum").Value <> vbNullString Then
    StrZe = Format$(TimeValue(RST.Fields("Druckdatum").Value), "hh:mm:ss")
Else
    StrZe = vbNullString
End If

'If GlRsK = True Then 'Mandantenbezogene Datenbegrenzung für Krankenblatt
'    If ManNr <> GlReM Then 'Standardmandant Mandantenrestriktionen
'        If ManNr = 0 Then
'            EinOk = True
'        Else
'            EinOk = False
'        End If
'    End If
'End If

If CDate(KrDat) >= CDate("01.01." & Year(KrDat)) And KrDat <= CDate("31.03." & Year(KrDat)) Then
    QurTa = 1
ElseIf CDate(KrDat) >= CDate("01.04." & Year(KrDat)) And KrDat <= CDate("30.06." & Year(KrDat)) Then
    QurTa = 2
ElseIf CDate(KrDat) >= CDate("01.07." & Year(KrDat)) And KrDat <= CDate("30.09." & Year(KrDat)) Then
    QurTa = 3
ElseIf CDate(KrDat) >= CDate("01.10." & Year(KrDat)) And KrDat <= CDate("31.12." & Year(KrDat)) Then
    QurTa = 4
Else
    QurTa = 0
End If

GrTag = Year(KrDat) & "-" & Format$(Month(KrDat), "00") & "-" & Format$(Day(KrDat), "00")
GrWek = Year(KrDat) & "-" & Format$(DatePart("ww", KrDat), "00")
GrMon = Year(KrDat) & "-" & Format$(Month(KrDat), "00")
GrQua = Year(KrDat) & "-" & Format$(QurTa, "00")

If RST.Fields("Typ").Value > 0 Then
    KrTyp = RST.Fields("Typ").Value
Else
    KrTyp = 0
End If

If RST.Fields("Provision").Value <> vbNullString Then
    Ausri = Mid$(RST.Fields("Provision").Value, 5, 1)
Else
    Ausri = vbNullString
End If

If EinOk = True Then
    Set RpRec = RpRcs.Add()
    
    Set RpItm = RpRec.AddItem(RST.Fields("ID2").Value)
    With RpItm
        .Tag = "_ID2"
        .Focusable = False
    End With
    Set RpItm = RpRec.AddItem(RST.Fields("ID0").Value)
    With RpItm
        .Tag = "_ID0"
        .Focusable = False
    End With
    Set RpItm = RpRec.AddItem(RST.Fields("RechNr").Value)
    With RpItm
        .Tag = "_RechNr"
        .Focusable = False
    End With
    Set RpItm = RpRec.AddItem(RST.Fields("ID3").Value)
    With RpItm
        .Tag = "_ID3"
        .Focusable = False
    End With
    Set RpItm = RpRec.AddItem(KrTyp)
    With RpItm 'Krankenblatttyp
        .Tag = vbNullString
        .Focusable = False
    End With
    Set RpItm = RpRec.AddItem(RST.Fields("Provision").Value)
    With RpItm 'Eintragsformatierung
        .Tag = vbNullString
        .Focusable = False
    End With
    Set RpItm = RpRec.AddItem(RST.Fields("ID4").Value)
    With RpItm
        .Tag = "_ID4"
        .Focusable = False
    End With
    Set RpItm = RpRec.AddItem(RST.Fields("IDR").Value)
    With RpItm
        .Tag = "_IDR"
        .Focusable = False
    End With
    Set RpItm = RpRec.AddItem(CDate(StrDa))
    With RpItm
        .Tag = "_Datum"
        .Focusable = False
    End With
    Set RpItm = RpRec.AddItem(StrZe)
    With RpItm
        .Tag = "_Druckdatum"
        .Focusable = False
    End With
    Set RpItm = RpRec.AddItem(RST.Fields("Typ").Value)
    With RpItm
        .Tag = "_Typ"
        .Focusable = False
        .Alignment = xtpAlignmentCenter
    End With
    Set RpItm = RpRec.AddItem(RST.Fields("Ziffer").Value)
    With RpItm
        .Tag = "_Ziffer"
        If KrTyp = 6 Then 'Zahlung
            .Focusable = False
        Else
            .Focusable = GlDiB 'Direktbearbeitung
        End If
    End With
    
    Select Case KrTyp
    Case 6: 'Zahlung
        Set RpItm = RpRec.AddItem(RST.Fields("Bezeichnung").Value)
        With RpItm
            .Tag = "_Bezeichnung"
            .Focusable = False
        End With
    Case 24: 'Textdokument
        DaNam = RST.Fields("Kommentar").Value
        IdStr = RST.Fields("Bezeichnung").Value
        Lange = Len(DaNam)
        Posi1 = InStrRev(DaNam, "#_", Lange, 1)
        Posi2 = InStrRev(DaNam, ".", Lange, 1)
        If Posi1 > 0 Then
            If IdStr <> vbNullString Then
                NeNam = Mid$(DaNam, Posi1 + 2, Posi2 - (Posi1 + 2)) & " - " & IdStr
            Else
                NeNam = Mid$(DaNam, Posi1 + 2, Posi2 - (Posi1 + 2))
            End If
        Else
            If IdStr <> vbNullString Then
                NeNam = IdStr
            Else
                If IdStr <> vbNullString Then
                    NeNam = "Textdokument" & " - " & IdStr
                Else
                    NeNam = "Textdokument"
                End If
            End If
        End If
        Set RpItm = RpRec.AddItem(NeNam)
        With RpItm
            .Tag = "_Typname"
            .Focusable = False
        End With
    Case 101: 'Rezept
        If RST.Fields("Kommentar").Value <> vbNullString Then
            Set RpItm = RpRec.AddItem(RST.Fields("Kommentar").Value)
        Else
            Set RpItm = RpRec.AddItem(RST.Fields("Bezeichnung").Value)
        End If
        With RpItm
            .Tag = "_Bezeichnung"
            .Focusable = False
        End With
    Case 102: 'Dateien
        DaNam = RST.Fields("Kommentar").Value
        If RST.Fields("Bezeichnung").Value <> vbNullString Then
            IdStr = RST.Fields("Bezeichnung").Value
        Else
            IdStr = vbNullString
        End If
        Lange = Len(DaNam)
        Posi1 = InStrRev(DaNam, "#_", Lange, 1)
        Posi2 = InStrRev(DaNam, ".", Lange, 1)
        If Posi1 > 0 Then
            If IdStr <> vbNullString Then
                NeNam = Mid$(DaNam, Posi1 + 2, Posi2 - (Posi1 + 2)) & " - " & IdStr
            Else
                NeNam = Mid$(DaNam, Posi1 + 2, Posi2 - (Posi1 + 2))
            End If
        ElseIf Mid$(DaNam, 8, 1) = "_" Then
            If IdStr <> vbNullString Then
                NeNam = IdStr
            Else
                NeNam = "Dateidokument"
            End If
        Else
            If IdStr <> vbNullString Then
                NeNam = "Dateidokument" & " - " & IdStr
            Else
                If Posi1 > 0 Then
                    NeNam = Mid$(DaNam, Posi1 + 1, Posi2 - (Posi1 + 1))
                Else
                    NeNam = "Dateidokument" & " - " & DaNam
                End If
            End If
        End If
        Set RpItm = RpRec.AddItem(NeNam)
        With RpItm
            .Tag = "_Typname"
            .Focusable = False
        End With
    Case 104: 'Protokoll
        Set RpItm = RpRec.AddItem(RST.Fields("Bezeichnung").Value)
        With RpItm
            .Tag = "_Bezeichnung"
            .Focusable = False
        End With
    Case 105: 'Bilddatei
        DaNam = RST.Fields("Kommentar").Value
        IdStr = RST.Fields("Bezeichnung").Value
        Lange = Len(DaNam)
        If Lange > 0 Then
            Posi1 = InStrRev(DaNam, "#_", Lange, 1)
            Posi2 = InStrRev(DaNam, ".", Lange, 1)
        Else
            Posi1 = 0
            Posi2 = 0
        End If
        If Posi1 > 0 Then
            If IdStr <> vbNullString Then
                NeNam = Mid$(DaNam, Posi1 + 2, Posi2 - (Posi1 + 2)) & " - " & IdStr
            Else
                NeNam = Mid$(DaNam, Posi1 + 2, Posi2 - (Posi1 + 2))
            End If
        ElseIf Mid$(DaNam, 8, 1) = "_" Then
            If IdStr <> vbNullString Then
                NeNam = IdStr
            Else
                If IdStr <> vbNullString Then
                    NeNam = "Bilddokument" & " - " & IdStr
                Else
                    NeNam = Mid$(DaNam, Posi1 + 2, Posi2 - (Posi1 + 2))
                End If
            End If
        Else
            If DaNam <> vbNullString Then
                NeNam = Mid$(DaNam, Posi1 + 1, Posi2 - (Posi1 + 1))
            End If
        End If
        Set RpItm = RpRec.AddItem(NeNam)
        With RpItm
            .Tag = "_Typname"
            .Focusable = False
        End With
    Case 106: 'Rechnung
        Set RpItm = RpRec.AddItem(RST.Fields("Bezeichnung").Value)
        With RpItm
            .Tag = "_Bezeichnung"
            .Focusable = False
        End With
    Case 108: 'Email
        Set RpItm = RpRec.AddItem(RST.Fields("Kommentar").Value)
        With RpItm
            .Tag = "_Bezeichnung"
            .Focusable = False
        End With
    Case Else:
        If KrTyp < 10 Then
            Set RpItm = RpRec.AddItem(RST.Fields("Bezeichnung").Value)
            With RpItm
                .Tag = "_Bezeichnung"
                .Focusable = False
            End With
        Else
            Set RpItm = RpRec.AddItem(RST.Fields("Kommentar").Value)
            With RpItm
                .Tag = "_Kommentar"
                .Focusable = GlDiB 'Direktbearbeitung
                Select Case Ausri
                Case "L": .Alignment = xtpAlignmentLeft Or xtpAlignmentWordBreak
                Case "R": .Alignment = xtpAlignmentRight Or xtpAlignmentWordBreak
                Case "Z": .Alignment = xtpAlignmentCenter Or xtpAlignmentWordBreak
                Case Else: .Alignment = xtpAlignmentLeft Or xtpAlignmentWordBreak
                End Select
            End With
        End If
    End Select
    
    Set RpItm = RpRec.AddItem(vbNullString)
    With RpItm
        .HasCheckbox = True
        .Alignment = xtpAlignmentIconCenter
        .Tag = "_Analog"
        If RST.Fields("Analog").Value = 0 Then
            .Checked = False
        Else
            If RST.Fields("Analog").Value <> vbNullString Then
                .Checked = True
            Else
                .Checked = False
            End If
        End If
    End With
    Set RpItm = RpRec.AddItem(RST.Fields("Anz").Value)
    With RpItm
        .Tag = "_Anz"
        If KrTyp = 6 Then 'Zahlung
            .Focusable = False
        Else
            .Focusable = GlDiB 'Direktbearbeitung
        End If
    End With
    Set RpItm = RpRec.AddItem(Format$(RST.Fields("Faktor").Value, GlWa1))
    With RpItm
        .Tag = "_Faktor"
        .Alignment = xtpAlignmentRight
        If KrTyp = 6 Then 'Zahlung
            .Focusable = False
        Else
            .Focusable = GlDiB 'Direktbearbeitung
        End If
    End With
    
    Set RpItm = RpRec.AddItem(Format$(RST.Fields("Betrag").Value, GlWa1))
    With RpItm
        .Tag = "_Betrag"
        .Focusable = False
        .Alignment = xtpAlignmentRight
    End With
    
    Set RpItm = RpRec.AddItem(Format$(RST.Fields("GesBetrag").Value, GlWa1))
    With RpItm
        .Tag = "_GesBetrag"
        .Focusable = False
        .Alignment = xtpAlignmentRight
    End With
    
    Set RpItm = RpRec.AddItem(Format$(RST.Fields("WVBetrag").Value, GlWa1))
    With RpItm
        .Tag = "_WVBetrag"
        .Focusable = False
        .Alignment = xtpAlignmentRight
    End With
    
    Set RpItm = RpRec.AddItem(Format$(RST.Fields("LaBetrag").Value, GlWa1))
    With RpItm
        .Tag = "_LaBetrag"
        .Alignment = xtpAlignmentRight
        If KrTyp = 6 Then
            .Focusable = False
        Else
            If RST.Fields("Gedruckt").Value = -1 Then
                .Focusable = False
            Else
                .Focusable = True
            End If
        End If
    End With

    Set RpItm = RpRec.AddItem(Format$(RST.Fields("Steuersatz").Value, GlWa1))
    With RpItm
        .Tag = "_Steuersatz"
        If KrTyp = 6 Then 'Zahlung
            .Focusable = False
        Else
            .Focusable = GlDiB 'Direktbearbeitung
        End If
    End With
    
    Set RpItm = RpRec.AddItem(RST.Fields("Zeit").Value)
    With RpItm
        .Tag = "_Zeit"
        If KrTyp = 6 Then 'Zahlung
            .Focusable = False
        Else
            If RST.Fields("Gedruckt").Value = -1 Then
                .Focusable = False
            Else
                .Focusable = GlDiB 'Direktbearbeitung
            End If
        End If
    End With
    
    If RST.Fields("Einheit").Value <> vbNullString Then
        Set RpItm = RpRec.AddItem(RST.Fields("Einheit").Value)
    Else
        Set RpItm = RpRec.AddItem(Space$(1))
    End If
    With RpItm
        .Tag = "_Einheit"
        If KrTyp = 6 Then 'Zahlung
            .Focusable = False
        Else
            .Focusable = GlDiB 'Direktbearbeitung
        End If
    End With
    Set RpItm = RpRec.AddItem(RST.Fields("Währung").Value)
    With RpItm
        .Tag = "_Währung"
        .Focusable = False
    End With
    If RST.Fields("IDD").Value <> vbNullString Then
        Set RpItm = RpRec.AddItem(CLng(Val(RST.Fields("IDD").Value)))
    Else
        Set RpItm = RpRec.AddItem(vbNullString)
    End If
    With RpItm
        .Tag = "_IDD"
        .Focusable = False
    End With
    If RST.Fields("IDM").Value <> vbNullString Then
        Set RpItm = RpRec.AddItem(CLng(Val(RST.Fields("IDM").Value)))
    Else
        Set RpItm = RpRec.AddItem(vbNullString)
    End If
    With RpItm
        .Tag = "_IDM"
        .Focusable = False
    End With
    Set RpItm = RpRec.AddItem(vbNullString)
    With RpItm
        .Alignment = xtpAlignmentIconTop
        .HasCheckbox = True
        .Focusable = False
    End With
    If RST.Fields("Gedruckt").Value = -1 Then
        RpItm.Checked = True
    End If
    With RpItm
        .Tag = "_Gedruckt"
        .Focusable = False
    End With
    Set RpItm = RpRec.AddItem(RST.Fields("Selekt").Value)
    With RpItm
        .Tag = "_Selekt"
        .Focusable = False
    End With
    If KrTyp > 10 Then
        Set RpItm = RpRec.AddItem(RST.Fields("Bezeichnung").Value)
        With RpItm
            .Tag = "_Bezeichnung"
            .Focusable = False
        End With
    Else
        Set RpItm = RpRec.AddItem(RST.Fields("Kommentar").Value)
        With RpItm
            .Tag = "_Kommentar"
            .Focusable = GlDiB 'Direktbearbeitung
        End With
    End If
    Set RpItm = RpRec.AddItem(RST.Fields("Kommentar2").Value)
    With RpItm
        .Tag = "_Kommentar2"
        .Focusable = False
    End With

    Select Case KrTyp
    Case 24: Set RpItm = RpRec.AddItem(RST.Fields("Kommentar").Value) 'Textdokument
    Case 102: Set RpItm = RpRec.AddItem(RST.Fields("Kommentar").Value) 'Datei
    Case 105: Set RpItm = RpRec.AddItem(RST.Fields("Kommentar").Value) 'Bilddatei
    Case 108: Set RpItm = RpRec.AddItem(RST.Fields("Kommentar").Value) 'Email
    Case Else: Set RpItm = RpRec.AddItem(vbNullString)
    End Select
    With RpItm
        .Tag = "_Typname"
        .Focusable = False
    End With

    Set RpItm = RpRec.AddItem(GrQua)
    Set RpItm = RpRec.AddItem(GrMon)
    Set RpItm = RpRec.AddItem(GrWek)
    Set RpItm = RpRec.AddItem(GrTag)
    
    Set RpItm = RpRec.AddItem(vbNullString)
    With RpItm
        .Alignment = xtpAlignmentIconTop
        .HasCheckbox = True
        .Focusable = False
    End With
    If RST.Fields("Lock").Value = -1 Then
        RpItm.Checked = True
    Else
        RpItm.Checked = False
    End If
    Set RpItm = RpRec.AddItem(RST.Fields("Storniert").Value)
    With RpItm
        .Tag = "_Storniert"
        .Focusable = False
    End With
    If KrTyp > 10 Then
        Select Case KrTyp
        Case 24: 'Textdokument
        Case 101: 'Rezept
        Case 102: 'Datei
        Case 104: 'Protokoll
        Case 105: 'Bilddokument
        Case 106: 'Rechnung
        Case Else:
            If RST.Fields("Bezeichnung").Value <> vbNullString Then
                RpRec.PreviewText = RST.Fields("Bezeichnung").Value
            End If
        End Select
    Else
        If RST.Fields("Kommentar").Value <> vbNullString Then
            RpRec.PreviewText = RST.Fields("Kommentar").Value
        End If
    End If
End If

RST.MoveNext
Loop Until RST.EOF

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCoK = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KrRec " & Err.Number
Resume Next

End Sub
Public Sub S_KrSa()
On Error GoTo LiErr
'Speichert die Daten aus der Tabelle

Dim SQL3 As String
Dim ReNum As Long
Dim RowNr As Long
Dim KrRow As Long
Dim KeyNr As Long
Dim TmpPr As String
Dim TmTag As String
Dim Krit1 As String
Dim Krit2 As String
Dim ReBet As Double 'Rechnungsgesamtbetrag
Dim BeBet As Double 'Bezahlbetrag
Dim GuBet As Double 'Guthabenbetrag
Dim PoBet As Double 'Abrechnungspositionsbetrag
Dim NeReB As Double
Dim ReAbg As Boolean
Dim AktZa As Integer
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCoK As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo3 = FM.repCont3
Set RpCo4 = FM.repCont4
Set RpCo6 = FM.repCont6
Set RpCoK = FM.repContK
Set RpRws = RpCo3.Rows
Set RpCls = RpCo3.Columns
Set RpSel = RpCo3.SelectedRows
Select Case GlBut
Case RibTab_Krankenbla: Set RpRcs = RpCoK.Records
Case RibTab_Abrechnung: Set RpRcs = RpCo6.Records
End Select

Krit1 = SDaFi1(1)
Krit2 = SDaFi2(1)

If GlSav = True Then
    Select Case GlBut
    Case RibTab_Krankenbla:

        Select Case GlBut
        Case RibTab_Krankenbla: Set RpSel = RpCoK.SelectedRows
        Case RibTab_Abrechnung: Set RpSel = RpCo6.SelectedRows
        End Select

        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            KrRow = RpRow.Index
        End If
        
        SQL3 = SKrSo(Krit1, Krit2, ReNum)
        
    Case RibTab_Abrechnung:
    
        If RpCo3.Records.Count = 0 Then
            Exit Sub
        End If
        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            RowNr = RpRow.Index
            Set RpCol = RpCls.Find(Rec_ID1)
            ReNum = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Selekt)
            ReAbg = CBool(RpRow.Record(RpCol.ItemIndex).Value)

            Set RpCol = RpCls.Find(Rec_Betrag)
            Select Case GlStD 'Standard-Dezimaltrennzeichen
            Case 0: ReBet = CSng(Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1))
            Case 1: ReBet = CSng(RpRow.Record(RpCol.ItemIndex).Value)
            End Select
                        
            Set RpCol = RpCls.Find(Rec_Bezahlt)
            Select Case GlStD 'Standard-Dezimaltrennzeichen
            Case 0: BeBet = CDbl(Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1))
            Case 1: BeBet = CDbl(RpRow.Record(RpCol.ItemIndex).Value)
            End Select
            
            Set RpCol = RpCls.Find(Rec_Rabatt)
            Select Case GlStD 'Standard-Dezimaltrennzeichen
            Case 0: GuBet = CSng(Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1))
            Case 1: GuBet = CSng(RpRow.Record(RpCol.ItemIndex).Value)
            End Select

            Select Case GlBut
            Case RibTab_Krankenbla: Set RpSel = RpCoK.SelectedRows
            Case RibTab_Abrechnung: Set RpSel = RpCo6.SelectedRows
            End Select
            If RpSel.Count > 0 Then
                Set RpRow = RpSel(0)
                KrRow = RpRow.Index
            End If
            
            If GlTyp < 2 Then
                SQL3 = "SELECT * FROM dbo.qrySimAbSav WHERE IDR = " & ReNum & " ORDER BY Sorter, ID3"
            Else
                SQL3 = "SELECT * FROM qrySimAbSav WHERE [IDR] = " & ReNum & " ORDER BY [Sorter], [ID3];"
            End If
        End If
    End Select

    Set RS123 = New ADODB.Recordset
    With RS123
        .CursorLocation = adUseClient
        .Source = SQL3
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With
    If RS123.RecordCount > 0 Then
        If RS123.Supports(adUpdate) Then
            RS123.MoveFirst
            For Each RpRec In RpRcs
                KeyNr = RpRec.Item(Kra_ID2).Value
                RS123.MoveFirst
                Krit1 = "[ID2] = " & KeyNr
                RS123.Find Criteria:=Krit1, SkipRecords:=0, SearchDirection:=adSearchForward
                If Not (RS123.BOF Or RS123.EOF) Then
                    For Each RpItm In RpRec
                        If Left$(RpItm.Tag, 1) = "@" Then
                            TmTag = Mid$(RpItm.Tag, 2, Len(RpItm.Tag) - 1)
                            If RpItm.HasCheckbox = True Then
                                If TmTag = "Analog" Then
                                    If RpItm.Checked = True Then
                                        RS123.Fields(TmTag).Value = 1
                                    Else
                                        RS123.Fields(TmTag).Value = 0
                                    End If
                                Else
                                    RS123.Fields(TmTag).Value = RpItm.Checked
                                End If
                            Else
                                If IsNumeric(RpItm.Value) Then
                                    If TmTag = "Steuersatz" Then
                                        RS123.Fields("Steuer").Value = CSng(RpItm.Value)
                                    Else
                                        If TmTag = "Ziffer" Then
                                            RS123.Fields("GONr").Value = RpItm.Value
                                        Else
                                            Select Case GlStD 'Standard-Dezimaltrennzeichen
                                            Case 0:
                                                If InStr(1, RpItm.Value, ".", 1) > 0 Then
                                                    TmpPr = Replace(RpItm.Value, ".", vbNullString, 1)
                                                    TmpPr = Mid$(TmpPr, 1, Len(TmpPr) - 3) & "." & Right$(TmpPr, 2)
                                                    RS123.Fields(TmTag).Value = TmpPr
                                                Else
                                                    If InStr(1, RpItm.Value, ",", 1) > 0 Then
                                                        TmpPr = Replace(RpItm.Value, ",", ".", 1)
                                                        Select Case TmTag
                                                        Case "Faktor": RS123.Fields("Multi").Value = TmpPr
                                                        Case "Anz": RS123.Fields("x").Value = TmpPr
                                                        Case Else: RS123.Fields(TmTag).Value = TmpPr
                                                        End Select
                                                    Else
                                                        Select Case TmTag
                                                        Case "Faktor": RS123.Fields("Multi").Value = CSng(RpItm.Value)
                                                        Case "Anz": RS123.Fields("x").Value = CInt(RpItm.Value)
                                                        Case Else: RS123.Fields(TmTag).Value = CSng(RpItm.Value)
                                                        End Select
                                                    End If
                                                End If
                                            Case 1:
                                                Select Case TmTag
                                                Case "Faktor": RS123.Fields("Multi").Value = CSng(RpItm.Value)
                                                Case "Anz": RS123.Fields("x").Value = CInt(RpItm.Value)
                                                Case Else: RS123.Fields(TmTag).Value = CSng(RpItm.Value)
                                                End Select
                                            End Select
                                        End If
                                    End If
                                Else
                                    If GlBut = RibTab_Krankenbla Then
                                        If TmTag = "Kommentar" Then
                                            RS123.Fields(TmTag).Value = RpRec(Kra_Bezeichnung).Value
                                        Else
                                            RS123.Fields(TmTag).Value = RpItm.Value
                                        End If
                                    Else
                                        If TmTag = "Bezeichnung" Then
                                            RS123.Fields("IDKurz").Value = RpItm.Value
                                        Else
                                            RS123.Fields(TmTag).Value = RpItm.Value
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    Next RpItm
                    RS123.Update
                    RS123.MoveNext
                End If
            Next RpRec
        End If
    End If
    RS123.Close
    Set RS123 = Nothing

    If GlJet = True Then SDBSav
    
    NeReB = S_ReBet(ReNum, Round(ReBet, 2), ReAbg, GuBet)
    
    Select Case GlBut
    Case RibTab_Krankenbla:
            SUpKr KrRow
    Case RibTab_Abrechnung:
            Set RpSel = RpCo3.SelectedRows
            If RpSel.Count > 0 Then
                Set RpRow = RpSel(0)
                RowNr = RpRow.Index
                SUpAb RowNr, KrRow
            End If
            
            If GlVrz = False Then
                Set RpSel = RpCo4.SelectedRows
                If RpSel.Count > 0 Then
                    Set RpRow = RpSel(0)
                    RowNr = RpRow.Index
                    SUpRe RowNr
                End If
            Else
                GlVzA = True
            End If
    End Select
    
    If GlPop = True Then 'Rechnungsobergrenze
        If NeReB > GlObG Then
            SReMe
        End If
    End If

    GlSav = False
End If

Set RpRcs = Nothing
Set RpSel = Nothing
Set RpRws = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing
Set RpCo4 = Nothing
Set RpCo6 = Nothing
Set RpCoK = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KrSa " & Err.Number
Resume Next

