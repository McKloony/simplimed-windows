                    RS123.Fields("Ident").Value = GlClp(AktPo, 2)
                    RS123.Fields("GONr").Value = GlClp(AktPo, 3)
                    RS123.Fields("Faktor").Value = GlClp(AktPo, 4)
                    RS123.Fields("Bezeichnung").Value = GlClp(AktPo, 5)
                    RS123.Fields("x").Value = GlClp(AktPo, 6)
                    RS123.Fields("Einheit").Value = GlClp(AktPo, 7)
                    RS123.Fields("Zuweisung").Value = GlClp(AktPo, 8)
                    If GlClp(AktPo, 9) <> vbNullString Then RS123.Fields("Höchstwert").Value = GlClp(AktPo, 9)
