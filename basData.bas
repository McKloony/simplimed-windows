Public Sub S_AdTx(Optional ByVal MsTyp As String, Optional ByVal ExpOr As Boolean)
On Error GoTo LiErr
'Exporiert / Importiert Adressen im THEDEX Format

Dim IdxNr As Long
Dim AnzSe As Long
Dim AnzAd As Long
Dim GesZa As Integer
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCo2 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo2 = FM.repCont2
Set RpSel = RpCo2.SelectedRows
Set RpCls = RpCo2.Columns

Tit1 = "THEDEX Abgleich"

If ExpOr = True Then 'Exportieren

    AnzSe = RpSel.Count
    If AnzSe > 0 Then
        DBCmEx0 "qryAdrMark"
        DoEvents
        
        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                IdxNr = AdAry(Adr_ID0, RpRow.Index)
                DBCmEx2 "qryAdrKo4", "@IdDru", "@IdxNr", -1, IdxNr
            End If
        Next RpRow
    
        Set RS127 = New ADODB.Recordset
        With RS127
            .CursorLocation = adUseClient
            .Source = "qrySimAdDru"
            .ActiveConnection = DB1
            .CursorType = adOpenForwardOnly
            .LockType = adLockReadOnly
            .Open Options:=adCmdTableDirect
        End With
        AnzAd = RS127.RecordCount
        
        If AnzAd > 0 Then
            Do
            With GlTDx
                If RS127.Fields("Mandant").Value <> vbNullString Then
                    .CSenderInternalIdentification = RS127.Fields("Mandant").Value
                Else
                    .CSenderInternalIdentification = RS127.Fields("ID0").Value
                End If
                If RS127.Fields("Name").Value <> vbNullString Then .CLastName = RS127.Fields("Name").Value
                If RS127.Fields("Vorname").Value <> vbNullString Then .CFirstName = RS127.Fields("Vorname").Value
                If RS127.Fields("Geboren").Value <> vbNullString Then .CBirthday = Format$(RS127.Fields("Geboren").Value, "ddmmyyyy")
                If RS127.Fields("Geschlecht").Value <> vbNullString Then
                    Select Case LCase(RS127.Fields("Geschlecht").Value)
                    Case "m": .CSex = "M"
                    Case "w": .CSex = "W"
                    Case Else: .CSex = vbNullString
                    End Select
                End If
                If RS127.Fields("Straße").Value <> vbNullString Then .CStreet = RS127.Fields("Straße").Value
                If RS127.Fields("PLZ").Value <> vbNullString Then .CZip = RS127.Fields("PLZ").Value
                If RS127.Fields("Ort").Value <> vbNullString Then .CTown = RS127.Fields("Ort").Value
                If RS127.Fields("LK").Value <> vbNullString Then .CCountryCode = RS127.Fields("LK").Value
                If RS127.Fields("Land").Value <> vbNullString Then .CCountry = RS127.Fields("Land").Value
                If RS127.Fields("Telefon1").Value <> vbNullString Then .CTelephone = RS127.Fields("Telefon1").Value
                If RS127.Fields("Telefon3").Value <> vbNullString Then .CFax = RS127.Fields("Telefon3").Value
                If RS127.Fields("KVNummer").Value <> vbNullString Then .InsuranceID = RS127.Fields("KVNummer").Value
                .InsuranceStatus = "P"
                If RS127.Fields("Kartennummer").Value <> vbNullString Then .InsuranceClientID = RS127.Fields("Kartennummer").Value
                .ClinicDepartment = vbNullString
                .ClinicRoomNumber = vbNullString
                .CustomerAccount = vbNullString
                If RS127.Fields("Telefon5").Value <> vbNullString Then .Email = RS127.Fields("Telefon5").Value
                If RS127.Fields("Telefon4").Value <> vbNullString Then .CellularPhone = RS127.Fields("Telefon4").Value
            End With
            
            DoEvents
            SAdTx MsTyp, True
    
            RS127.MoveNext
            Loop Until RS127.EOF
        End If
        
        RS127.Close
        Set RS127 = Nothing
    End If
    
    SPopu "THEDEX Export", "Es wurden " & AnzAd & " THEDEX Nachrichten exportiert", IC48_Information
    
Else 'Importieren

    Set RS126 = New ADODB.Recordset
    RS126.CursorLocation = adUseClient
    Set RS126 = DBCmRe1("qrySimAdMan", "@IdStr", GlTDx.CSenderInternalIdentification)
    GesZa = RS126.RecordCount
    
    Select Case MsTyp
    Case "ClientNew":
        If GesZa > 0 Then
            Mld1 = "Der Patient " & GlTDx.CFirstName & Chr$(32) & GlTDx.CLastName & " existiert bereits. Soll wirklich ein neuer Datensatz angelegt werden?"
            Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
            If Frage = 6 Then
                S_AdXe "ClientNew"
            End If
        Else
            S_AdXe "ClientNew"
        End If
    Case "ClientChange":
        If GesZa > 0 Then
            Mld1 = "Soll der Patient " & GlTDx.CFirstName & Chr$(32) & GlTDx.CLastName & " wirklich geändert werden?"
            Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
            If Frage = 6 Then
                S_AdXe "ClientChange"
            End If
        Else
            S_AdXe "ClientNew"
        End If
    Case "ClientDelete":
        If GesZa > 0 Then
            Mld1 = "Soll der Patient " & GlTDx.CFirstName & Chr$(32) & GlTDx.CLastName & " wirklich gelöscht werden?"
            Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
            If Frage = 6 Then
                S_AdXe "ClientDelete"
            End If
        End If
    Case "ClientReport":
        If GesZa > 0 Then
            Mld1 = "Soll der Patient " & GlTDx.CFirstName & Chr$(32) & GlTDx.CLastName & " wirklich geändert werden?"
            Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
            If Frage = 6 Then
                S_AdXe "ClientChange"
            End If
        Else
            S_AdXe "ClientNew"
        End If
    Case "ClientInfo":
        If GesZa > 0 Then
            Mld1 = "Soll der Patient " & GlTDx.CFirstName & Chr$(32) & GlTDx.CLastName & " wirklich geändert werden?"
            Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
            If Frage = 6 Then
                S_AdXe "ClientChange"
            End If
        Else
            S_AdXe "ClientNew"
        End If
    End Select
    
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo2 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_AdTx " & Err.Number
Resume Next

End Sub
Private Sub S_AdXe(ByVal MsTyp As String)
On Error GoTo LiErr

Dim SQL1 As String
Dim PaGeb As String

If GlTDx.CBirthday <> vbNullString Then
    If IsDate(Left$(GlTDx.CBirthday, 2) & "." & Mid$(GlTDx.CBirthday, 3, 2) & "." & Right$(GlTDx.CBirthday, 4)) Then
        PaGeb = Left$(GlTDx.CBirthday, 2) & "." & Mid$(GlTDx.CBirthday, 3, 2) & "." & Right$(GlTDx.CBirthday, 4)
    Else
        PaGeb = vbNullString
    End If
Else
    PaGeb = vbNullString
End If

Select Case MsTyp
Case "ClientNew":
        Set RS127 = New ADODB.Recordset 'Neuer Patient anlegen
        With RS127
            .ActiveConnection = DB1
            .CursorLocation = adUseClient
            .CursorType = adOpenDynamic
            .LockType = adLockOptimistic
            .Source = "qryAdrNeu"
            .Open Options:=adCmdTableDirect
        End With
        If RS127.Supports(adAddNew) Then
            GlAdG = CreateID("A")
            RS127.AddNew
            RS127.Fields("Mandant") = GlTDx.CSenderInternalIdentification
            RS127.Fields("IDKurz") = GlTDx.CLastName & ", " & GlTDx.CFirstName & ", " & GlTDx.CTown
            If GlTDx.CLastName <> vbNullString Then RS127.Fields("Name") = GlTDx.CLastName
            If GlTDx.CFirstName <> vbNullString Then RS127.Fields("Vorname") = GlTDx.CFirstName
            If PaGeb <> vbNullString Then RS127.Fields("Geboren") = PaGeb
            If GlTDx.CSex <> vbNullString Then RS127.Fields("Geschlecht") = GlTDx.CSex
            If GlTDx.CStreet <> vbNullString Then RS127.Fields("Straße") = GlTDx.CStreet
            If GlTDx.CZip <> vbNullString Then RS127.Fields("PLZ") = GlTDx.CZip
