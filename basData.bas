Public Sub S_TxSer(Optional ByVal ManNr As Long = 0)
On Error GoTo WoErr
'Einlesen der Daten für die Datenfelder

Dim MaAbs As String 'Briefabsendezeile
Dim MaBkR As String 'Briefkopf Rechts
Dim MaBkL As String 'Briefkopf Links
Dim MaBkN As String 'Briefkopf Name
Dim MaBkA As String 'Briefkopf Adresse
Dim MaBkB As String 'Briefkopf Bank
Dim MaFir As String 'Mandantenfirma
Dim MaTit As String 'Mandantentitel
Dim MaVor As String 'Mandantenvorname
Dim MaNam As String 'Mandantennachname
Dim MaKom As String 'Mandantenkomplettname
Dim MaThe As String 'Mandatetherapieverfahren
Dim MaEma As String 'Mandantenemailadresse
Dim MaGID As String 'Gläubigeridentifikation
Dim AktZa As Integer

If ManNr = 0 Then
    ManNr = GlMan(GlSMa, 2)
End If

For AktZa = 1 To UBound(GlSer) 'Variable Löschen!
    GlSer(AktZa, 2) = vbNullString
Next AktZa

Set RS130 = New ADODB.Recordset
RS130.CursorLocation = adUseClient
Set RS130 = DBCmRe1("qryAdrIdx", "@IdxNr", ManNr)
If RS130.RecordCount > 0 Then
    If RS130.Fields("Anamnese").Value <> vbNullString Then
        MaThe = RS130.Fields("Anamnese").Value
    Else
        MaThe = vbNullString
    End If
    If RS130.Fields("R_Firma1").Value <> vbNullString Then
        MaFir = RS130.Fields("R_Firma1").Value
    Else
        MaFir = vbNullString
    End If
    If RS130.Fields("Titel").Value <> vbNullString Then
        MaTit = RS130.Fields("Titel").Value
    Else
        MaTit = vbNullString
    End If
    If RS130.Fields("Vorname").Value <> vbNullString Then
        MaVor = RS130.Fields("Vorname").Value
    Else
        MaVor = vbNullString
    End If
    If RS130.Fields("Name").Value <> vbNullString Then
        MaNam = RS130.Fields("Name").Value
    Else
        MaNam = vbNullString
    End If
    If RS130.Fields("Telefon5").Value <> vbNullString Then
        MaEma = RS130.Fields("Telefon5").Value
    Else
        MaEma = vbNullString
    End If
    If MaVor <> vbNullString Then
        MaKom = MaVor & Chr$(32) & MaNam
    Else
        MaKom = MaNam
    End If
    
    If MaFir <> vbNullString Then
        If InStr(1, MaNam, MaFir, 1) > 0 Then
            If MaTit <> vbNullString Then
                MaAbs = MaTit & Chr$(32) & MaVor & Chr$(32) & MaNam
            Else
                MaAbs = MaVor & Chr$(32) & MaNam
            End If
        Else
            MaAbs = MaFir & " - " & Left$(MaVor, 1) & ". " & MaNam
        End If
    Else
        If MaTit <> vbNullString Then
            MaAbs = MaTit & Chr$(32) & MaKom
        Else
            MaAbs = MaKom
        End If
    End If
    
    MaAbs = MaAbs & " - " & RS130.Fields("Straße").Value
    MaAbs = MaAbs & " - " & RS130.Fields("PLZ").Value
    MaAbs = MaAbs & Chr$(32) & RS130.Fields("Ort").Value

    If RS130.Fields("R_Firma1").Value <> vbNullString Then
        MaBkN = RS130.Fields("R_Firma1").Value & vbCrLf
    End If
    If RS130.Fields("Titel").Value <> vbNullString Then
        MaBkN = MaBkN & RS130.Fields("Titel").Value & Chr$(32) & RS130.Fields("Vorname").Value & Chr$(32) & RS130.Fields("Name").Value
    Else
        MaBkN = MaBkN & RS130.Fields("Vorname").Value & Chr$(32) & RS130.Fields("Name").Value
    End If
    If RS130.Fields("Beruf").Value <> vbNullString Then
        MaBkN = MaBkN & vbCrLf & RS130.Fields("Beruf").Value
    End If
    
    MaBkR = MaBkR & vbCrLf & RS130.Fields("Straße").Value
    MaBkR = MaBkR & vbCrLf & RS130.Fields("PLZ").Value
    MaBkR = MaBkR & Chr$(32) & RS130.Fields("Ort").Value
    If RS130.Fields("Telefon2").Value <> vbNullString Then MaBkR = MaBkR & vbCrLf & vbCrLf & "Telefon: " & RS130.Fields("Telefon2").Value
    If RS130.Fields("Telefon3").Value <> vbNullString Then MaBkR = MaBkR & vbCrLf & "Telefax: " & RS130.Fields("Telefon3").Value
    MaBkL = MaBkN & vbCrLf & MaBkR
    If RS130.Fields("Telefon5").Value <> vbNullString Then MaBkR = MaBkR & vbCrLf & "Email: " & RS130.Fields("Telefon5").Value
    
    If RS130.Fields("Bank").Value <> vbNullString Then
        MaBkR = MaBkR & vbCrLf & vbCrLf & "Kreditins.: " & RS130.Fields("Bank").Value
        If RS130.Fields("BIC").Value <> vbNullString Then
            MaBkR = MaBkR & vbCrLf & "BIC: " & RS130.Fields("BIC").Value
        ElseIf RS130.Fields("BLZ").Value <> vbNullString Then
            MaBkR = MaBkR & vbCrLf & "BLZ: " & RS130.Fields("BLZ").Value
        End If
        If RS130.Fields("IBAN").Value <> vbNullString Then
            MaBkR = MaBkR & vbCrLf & "IBAN: " & RS130.Fields("IBAN").Value
        ElseIf RS130.Fields("Konto").Value <> vbNullString Then
            MaBkR = MaBkR & vbCrLf & "Kto.: " & RS130.Fields("Konto").Value
        End If
    End If

    MaBkA = MaBkA & RS130.Fields("Straße").Value
    MaBkA = MaBkA & " - " & RS130.Fields("PLZ").Value
    MaBkA = MaBkA & " - " & RS130.Fields("Ort").Value
    If RS130.Fields("Telefon2").Value <> vbNullString Then MaBkA = MaBkA & vbCrLf & "Telefon: " & RS130.Fields("Telefon2").Value
    If RS130.Fields("Telefon3").Value <> vbNullString Then MaBkA = MaBkA & " - " & "Telefax: " & RS130.Fields("Telefon3").Value
    If RS130.Fields("Telefon5").Value <> vbNullString Then MaBkA = MaBkA & " - " & "Email: " & RS130.Fields("Telefon5").Value
    MaBkA = MaBkA & vbCrLf
    
    If RS130.Fields("Bank").Value <> vbNullString Then
        MaBkB = "Kreditins.: " & RS130.Fields("Bank").Value
        If RS130.Fields("BIC").Value <> vbNullString Then
            MaBkB = MaBkB & Chr$(32) & "(BIC: " & RS130.Fields("BIC").Value & ")"
        ElseIf RS130.Fields("BLZ").Value <> vbNullString Then
            MaBkB = MaBkB & Chr$(32) & "(BLZ: " & RS130.Fields("BLZ").Value & ")"
        End If
        If RS130.Fields("IBAN").Value <> vbNullString Then
            MaBkB = MaBkB & Chr$(32) & "IBAN: " & RS130.Fields("IBAN").Value
        ElseIf RS130.Fields("Konto").Value <> vbNullString Then
            MaBkB = MaBkB & Chr$(32) & "Kto.: " & RS130.Fields("Konto").Value
        End If
        If RS130.Fields("GID").Value <> vbNullString Then
            MaGID = RS130.Fields("GID").Value
        Else
            MaGID = vbNullString
        End If
    End If
End If
RS130.Close
Set RS130 = Nothing

GlSer(55, 2) = MaAbs
GlSer(56, 2) = MaBkR
GlSer(57, 2) = MaBkN
GlSer(58, 2) = MaBkA
GlSer(59, 2) = MaBkB
GlSer(85, 2) = MaGID
GlSer(86, 2) = MaBkL
GlSer(87, 2) = MaEma
GlSer(77, 2) = MaKom
GlSer(63, 2) = MaThe
GlSer(78, 2) = GlTxD.FrStr
GlSer(79, 2) = GlTxD.DiStr
GlSer(76, 2) = GlMiA(GlSmI, 4) & Chr$(32) & GlMiA(GlSmI, 3)
GlSer(74, 2) = Format$(Date, "ddd") & ". " & Format$(Date, "dd.") & Chr$(32) & Format$(Date, "mmmm") & Chr$(32) & Format$(Date, "yyyy")

Exit Sub

WoErr:
If GlDbg = True Then SErLog Err.Description & " S_TxEin " & Err.Number
Exit Sub

End Sub
Public Function S_TxSet(ByVal FSQL As String) As Boolean
On Error GoTo LiErr
'Weißt dem ReportControl die gefilterten Adressen zu

Dim GesZa As Long
Dim CmBrs As XtremeCommandBars.CommandBars
Dim RpCo9 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set RpCo9 = FM.repCont9
Set RpRcs = RpCo9.Records

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

Screen.MousePointer = vbHourglass
clFen.FenDsk 2

With RpCo9
    .EditItem Nothing, Nothing
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    If .Records.Count > 0 Then .Records.DeleteAll
    .Populate
End With

Set RS145 = New ADODB.Recordset
With RS145
    .CursorLocation = adUseClient
    .Source = FSQL
    .ActiveConnection = DB1
    .CursorType = adOpenForwardOnly
    .LockType = adLockReadOnly
    .Open Options:=adCmdText
End With
GesZa = RS145.RecordCount

If GesZa > 0 Then
    Set RS126 = New ADODB.Recordset 'Felderdefinition
    RS126.CursorLocation = adUseClient

    RS126.Fields.Append "ID0", adInteger
    RS126.Fields.Append "IDKurz", adVarChar, 100
    RS126.Fields.Append "Geboren", adDate
    RS126.Fields.Append "Drucken", adBoolean
    RS126.Fields.Append "Selekt", adBoolean
    RS126.Fields.Append "Telefon1", adVarChar, 100
    RS126.Fields.Append "Telefon2", adVarChar, 100
    RS126.Fields.Append "Telefon3", adVarChar, 100
    RS126.Fields.Append "Telefon4", adVarChar, 100
    RS126.Fields.Append "Telefon5", adVarChar, 100
    RS126.Fields.Append "Telefon6", adVarChar, 100
    
    If RS126.State = adStateClosed Then RS126.Open

    If RS126.Supports(adAddNew) = True Then
        RS145.MoveFirst
        Do
        RS126.AddNew
        RS126.Fields("ID0").Value = RS145.Fields("ID0").Value
        If RS145.Fields("IDKurz").Value <> vbNullString Then RS126.Fields("IDKurz").Value = RS145.Fields("IDKurz").Value
        If RS145.Fields("Geboren").Value <> vbNullString Then RS126.Fields("Geboren").Value = RS145.Fields("Geboren").Value
        If RS145.Fields("Drucken").Value <> vbNullString Then RS126.Fields("Drucken").Value = RS145.Fields("Drucken").Value
        If RS145.Fields("Telefon1").Value <> vbNullString Then RS126.Fields("Telefon1").Value = RS145.Fields("Telefon1").Value
        If RS145.Fields("Telefon2").Value <> vbNullString Then RS126.Fields("Telefon2").Value = RS145.Fields("Telefon2").Value
        If RS145.Fields("Telefon3").Value <> vbNullString Then RS126.Fields("Telefon3").Value = RS145.Fields("Telefon3").Value
        If RS145.Fields("Telefon4").Value <> vbNullString Then RS126.Fields("Telefon4").Value = RS145.Fields("Telefon4").Value
        If RS145.Fields("Telefon5").Value <> vbNullString Then RS126.Fields("Telefon5").Value = RS145.Fields("Telefon5").Value
        RS126.Update
        RS145.MoveNext
        Loop Until RS145.EOF
        RS126.MoveFirst
        
        CmAcs(Tex_PaAlle).Enabled = True
        DoEvents
        
        SeAry = RS126.GetRows 'Array Füllen
        DoEvents
        
        RpCo9.SetVirtualMode GesZa
        DoEvents
        
        Set RpRec = RpCo9.Records(0)
        Set RpItm = RpRec.AddItem(vbNullString)
        Set RpItm = RpRec.AddItem(vbNullString)
        RpItm.Icon = IC16_IDCard_Norm
        Set RpItm = RpRec.AddItem(vbNullString)
        Set RpItm = RpRec.AddItem(vbNullString)
        Set RpItm = RpRec.AddItem(vbNullString)
        RpItm.Icon = IC16_Check
        
        DoEvents
        With RpCo9
            .Populate
            .SetCustomDraw xtpCustomBeforeDrawRow
        End With
        
        Set RpRws = RpCo9.Rows
        RpRws.Row(0).Selected = False
        
        S_TxSet = True
    End If
    
    RS126.Close
    Set RS126 = Nothing
End If
RS145.Close
Set RS145 = Nothing

clFen.FenDsk 3
Screen.MousePointer = vbNormal

Set RpItm = Nothing
Set RpRec = Nothing
Set RpCo9 = Nothing

Set clFen = Nothing

Exit Function

LiErr:
If GlDbg = True Then SErLog Err.Description & " S_TxSet " & Err.Number
Resume Next

End Function
