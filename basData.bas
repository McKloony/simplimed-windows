If CDate(KrDat) >= CDate("01.01." & Year(KrDat)) And KrDat <= CDate("31.03." & Year(KrDat)) Then
    QurTa = 1
ElseIf CDate(KrDat) >= CDate("01.04." & Year(KrDat)) And KrDat <= CDate("30.06." & Year(KrDat)) Then
    QurTa = 2
ElseIf CDate(KrDat) >= CDate("01.07." & Year(KrDat)) And KrDat <= CDate("30.09." & Year(KrDat)) Then
    QurTa = 3
ElseIf CDate(KrDat) >= CDate("01.10." & Year(KrDat)) And KrDat <= CDate("31.12." & Year(KrDat)) Then
