Public Sub S_BuAnf()
On Error GoTo KoErr
'Lädt die Anfangsbestandsbuchungen

Dim ManNr As Long
Dim KtoSo As Long
Dim KtoHa As Long
Dim GesZa As Long
Dim SQL1 As String
Dim KSoSt As String
Dim KHaSt As String
Dim GegKt As String
Dim GegSt As String
Dim KoStr As String
Dim BuJah As String
Dim Lange As Integer
Dim AktZa As Integer
Dim ComBu As XtremeSuiteControls.ComboBox
Dim ComTh As XtremeSuiteControls.ComboBox
Dim RpCo1 As XtremeReportControl.ReportControl

Set FM = frmBuAnf
Set ComBu = FM.cmbBuJah
Set ComTh = FM.cmbBehan
Set RpCo1 = FM.repCont1
Set RpRcs = RpCo1.Records

BuJah = ComBu.Text
ManNr = ComTh.ItemData(ComTh.ListIndex)

If ManNr > 0 Then
    If GlTyp < 2 Then
        SQL1 = "SELECT * FROM dbo.qrySimBuAf WHERE Jahr = " & BuJah & " AND IDT = " & ManNr
    Else
        SQL1 = "SELECT * FROM qrySimBuAf WHERE [Jahr] = " & BuJah & " AND [IDT] = " & ManNr & ";"
    End If
Else
    If GlTyp < 2 Then
        SQL1 = "SELECT * FROM dbo.qrySimBuAf WHERE Jahr = " & BuJah
    Else
        SQL1 = "SELECT * FROM qrySimBuAf WHERE [Jahr] = " & BuJah & ";"
    End If
End If

With RpCo1
    .EditItem Nothing, Nothing
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    If .Records.Count > 0 Then .Records.DeleteAll
    .Populate
End With

Set RS130 = New ADODB.Recordset
With RS130
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenForwardOnly
    .LockType = adLockReadOnly
    .Open Options:=adCmdText
End With
GesZa = RS130.RecordCount

If GesZa > 0 Then
    Do
    If RS130.Fields("IDKurz").Value <> vbNullString Then
        KoStr = RS130.Fields("IDKurz").Value
    Else
        KoStr = vbNullString
    End If
    If RS130.Fields("IDK").Value <> vbNullString Then
        KtoSo = RS130.Fields("IDK").Value
    Else
        KtoSo = 0
    End If
    If GlBuc = True Then 'einfache Buchhaltung verwenden
        If RS130.Fields("IDG").Value <> vbNullString Then
            KtoHa = RS130.Fields("IDB").Value
        Else
            KtoHa = 0
        End If
    Else
        If RS130.Fields("IDB").Value <> vbNullString Then
            KtoHa = RS130.Fields("IDG").Value
        Else
            KtoHa = 0
        End If
    End If

    KSoSt = SBuFo(KtoSo) 'Sachkontenformatierung
    KHaSt = SBuFo(KtoHa) 'Sachkontenformatierung

    For AktZa = 1 To UBound(GlGeK)
        If GlGeK(AktZa, 0) = KtoHa Then
            GegSt = GlGeK(AktZa, 1)
            GegKt = GlGeK(AktZa, 2)
            Exit For
        End If
    Next AktZa

    Set RpRec = RpRcs.Add()
    Set RpItm = RpRec.AddItem(RS130.Fields("ID0").Value)
    Set RpItm = RpRec.AddItem(KSoSt)
    RpItm.Alignment = xtpAlignmentCenter
    If GlBuc = True Then 'einfache Buchhaltung verwenden
        Set RpItm = RpRec.AddItem(GegKt)
    Else
        Set RpItm = RpRec.AddItem(KHaSt)
    End If
    RpItm.Alignment = xtpAlignmentCenter
    Set RpItm = RpRec.AddItem(RS130.Fields("Datum").Value)
    RpItm.Alignment = xtpAlignmentCenter
    If RS130.Fields("Ausgabe").Value > 0 Then
        Set RpItm = RpRec.AddItem(Format$(RS130.Fields("Ausgabe").Value, GlWa1))
    Else
        Set RpItm = RpRec.AddItem(Format$(0, GlWa1))
    End If
    RpItm.Alignment = xtpAlignmentRight
    If RS130.Fields("Einnahme").Value > 0 Then
        Set RpItm = RpRec.AddItem(Format$(RS130.Fields("Einnahme").Value, GlWa1))
    Else
        Set RpItm = RpRec.AddItem(Format$(0, GlWa1))
    End If
    RpItm.Alignment = xtpAlignmentRight
    Set RpItm = RpRec.AddItem(Format$(RS130.Fields("Steuer").Value, GlWa1))
    If GlBuc = True Then 'einfache Buchhaltung verwenden
        Set RpItm = RpRec.AddItem(GegSt)
    Else
        Set RpItm = RpRec.AddItem(KoStr)
    End If
    Set RpItm = RpRec.AddItem(RS130.Fields("IDT").Value)
    RS130.MoveNext
    Loop Until RS130.EOF
End If
RS130.Close
Set RS130 = Nothing

RpCo1.Populate

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCo1 = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BuAnf " & Err.Number
Resume Next

End Sub
