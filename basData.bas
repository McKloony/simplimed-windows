                                    RS120.Fields("Ausgang").Value = Date
                                    RS120.Fields("Name").Value = PatNa
                                    RS120.Fields("Vorname").Value = PatVo
                                    RS120.Fields("Geboren").Value = PatGe
                                    RS120.Fields("Geschlecht").Value = PatGs
                                    RS120.Fields("Befundart").Value = "Eigenbefund"
                                    RS120.Fields("IDP").Value = PatNr
                                    RS120.Fields("IP0").Value = BehNr
                                    RS120.Fields("Gebührenordnung").Value = GebTy
                                    RS120.Fields("Befund").Value = AuBef
                                    RS120.Fields("GuiID").Value = GuiID
                                    RS120.Update
                                End If
                            End If
                            RS120.Close
                            Set RS120 = Nothing
                            
                            If NeuAn = True Then
                                Set RS127 = New ADODB.Recordset 'Neuer Bericht ID
                                RS127.CursorLocation = adUseClient
                                Set RS127 = DBCmRe1("qryLabBeGui", "@IdStr", GuiID)
                                If RS127.RecordCount > 0 Then
                                    BerID = RS127.Fields("ID0").Value
                                Else
                                    BerID = 0
                                End If
                                RS127.Close
                                Set RS127 = Nothing
                            End If
                        
                            Set RS121 = New ADODB.Recordset 'Parameter des Laborauftrags
                            RS121.CursorLocation = adUseClient
                            Set RS121 = DBCmRe1("qryLabAuPa", "@IdxNr", AufNr)
                            GesZa = RS121.RecordCount
                            ParZa = ParZa + GesZa
    
