Else
    BnkNr = CmGlk.ItemData(CmGlk.ListIndex)
End If

Set RS140 = New ADODB.Recordset
RS140.CursorLocation = adUseClient

If GlBGe = True Then 'Getrennter Geldkonten Belegnummernkreis
    If GlBMa = True Then 'Getrennter Mandanten Belegnummernkreis
        Set RS140 = DBCmRe4("qrySimBuBl4", "@IdBel", "@IdJah", "@IdMan", "@IdBnk", BelNr, BuJah, ManNr, BnkNr)
    Else
        Set RS140 = DBCmRe3("qrySimBuBl3", "@IdBel", "@IdJah", "@IdBnk", BelNr, BuJah, BnkNr)
    End If
Else
    If GlBMa = True Then 'Getrennter Mandanten Belegnummernkreis
        Set RS140 = DBCmRe3("qrySimBuBl2", "@IdBel", "@IdJah", "@IdMan", BelNr, BuJah, ManNr)
    Else
        Set RS140 = DBCmRe2("qrySimBuBl1", "@IdBel", "@IdJah", BelNr, BuJah)
