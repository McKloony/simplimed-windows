Exit Sub

End Sub
Public Sub S_AdKo()
On Error GoTo KoErr
'Kopiert die ausgewählten Adressen

Dim RowNr As Long
Dim AnzFe As Long
Dim IdxNr As Long
Dim AdPIN As Long
Dim IdStr As String
Dim FldNr As Integer
Dim KFirm As String
Dim KName As String
Dim KVorn As String
Dim KOrte As String
Dim Passi As Boolean
Dim Frage As Integer
Dim FldWe() As Variant
Dim Mld1, Tit1 As String
Dim RpCo2 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo2 = FM.repCont2
Set RpCls = RpCo2.Columns
Set RpSel = RpCo2.SelectedRows

Tit1 = "Eintrag kopieren"
Mld1 = "Möchten Sie diesen Eintrag wirklich kopieren?"

If RpSel.Count > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then

        Set RS127 = New ADODB.Recordset
        With RS127
            .ActiveConnection = DB1
            .CursorLocation = adUseClient
            .CursorType = adOpenStatic
            .LockType = adLockBatchOptimistic
            .Source = "qryAdrNeu"
            .Open Options:=adCmdTableDirect
            Set .ActiveConnection = Nothing
        End With
        
        AnzFe = RS127.Fields.Count
        ReDim FldWe(AnzFe)

        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                AdPIN = Adr_Let()
                IdxNr = AdAry(Adr_ID0, RpRow.Index)
                Select Case GlBut
                Case RibTab_Adressen: If AdAry(Adr_Firma1, RpRow.Index) <> vbNullString Then KFirm = AdAry(Adr_Firma1, RpRow.Index)
                Case RibTab_Mitarbeit:
                Case RibTab_Mandanten:
                Case RibTab_Verordner: If AdAry(Adr_Firma1, RpRow.Index) <> vbNullString Then KFirm = AdAry(Adr_Firma1, RpRow.Index)
                End Select
                If AdAry(Adr_Name, RpRow.Index) <> vbNullString Then KName = AdAry(Adr_Name, RpRow.Index)
                If AdAry(Adr_Vorname, RpRow.Index) <> vbNullString Then KVorn = AdAry(Adr_Vorname, RpRow.Index)
                If AdAry(Adr_Ort, RpRow.Index) <> vbNullString Then KOrte = AdAry(Adr_Ort, RpRow.Index)
                Passi = AdAry(Adr_Passiv, RpRow.Index)
                GlAdG = CreateID("A")
                IdStr = AErSu(KFirm, KName, KVorn, KOrte, IdxNr)

                If Passi = False Then
                    Set RS129 = New ADODB.Recordset
                    RS129.CursorLocation = adUseClient
                    Set RS129 = DBCmRe1("qryAdrIdx", "@IdxNr", IdxNr)
                    Set RS129.ActiveConnection = Nothing
    
                    If RS129.RecordCount > 0 Then
                        FldNr = 1
                        For Each FL101 In RS129.Fields
                            If Not IsNull(FL101.Value) Then
                                If FL101.Type = adBoolean Then
                                    If FL101.Value = True Then
                                        FldWe(FldNr) = -1
                                    Else
                                        FldWe(FldNr) = 0
                                    End If
                                Else
                                    FldWe(FldNr) = FL101.Value
                                End If
                            End If
                            FldNr = FldNr + 1
                        Next FL101
                        
                        If RS127.Supports(adAddNew) Then
                            FldNr = 1
                            RS127.AddNew
                            For Each FL101 In RS129.Fields
                                Select Case FL101.Name
                                Case "ID0":
                                Case "Geboren":
                                Case "Mandant": RS127.Fields(FL101.Name).Value = Format$(AdPIN, "000000")
                                Case "Diagnose":
                                Case "upsize_ts":
                                Case "GuiID": RS127.Fields(FL101.Name).Value = GlAdG
                                Case "IDKurz": RS127.Fields(FL101.Name).Value = IdStr
                                Case "Geändert": RS127.Fields(FL101.Name).Value = Date
                                Case "Replicated":
                                    If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                                        RS127.Fields(FL101.Name).Value = 1
                                    Else
                                        RS127.Fields(FL101.Name).Value = 0
                                    End If
                                Case "DAVChange":
                                    If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                                        RS127.Fields(FL101.Name).Value = 1
                                    Else
                                        RS127.Fields(FL101.Name).Value = 0
                                    End If
                                Case "LastModification":
                                    If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                                        RS127.Fields(FL101.Name).Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                                    End If
                                Case "DAVDate":
                                    If GlESy = True Then 'CalDAV / CardDAV / Exchange Synchronisation
                                        RS127.Fields(FL101.Name).Value = Format$(DateValue(Now), "dd.mm.yyyy") & Chr$(32) & Format$(TimeValue(Now), "hh:mm:ss")
                                    End If
                                Case Else:
                                    If Not FL101.Type = 128 Then
                                        If Not FldWe(FldNr) = vbNullString Then
                                            RS127.Fields(FL101.Name).Value = FldWe(FldNr)
                                        End If
                                    End If
                                End Select
                                FldNr = FldNr + 1
                            Next FL101
                        End If
                    End If
                    
                    RS129.Close
                    Set RS129 = Nothing
                End If
            End If
        Next RpRow
                
        If Passi = False Then
            If RS127.Supports(adUpdateBatch) Then
                Set RS127.ActiveConnection = DB1
                RS127.UpdateBatch
                Set RS127.ActiveConnection = Nothing
            End If
            RS127.Close
            Set RS127 = Nothing
        
            With GlSuP
                .SuIdx = 11
                .GuiID = GlAdG
            End With

            Select Case GlBut
            Case RibTab_Adressen: GlPaK = "P801"
            Case RibTab_Mandanten: GlPaK = "P805"
            Case RibTab_Verordner: GlPaK = "P806"
            Case RibTab_Mitarbeit: GlPaK = "P807"
            End Select
            GlzPa = "P809"
            S_AdSuc
        End If
    End If
End If

Set RpSel = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo2 = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_AdKo " & Err.Number
Resume Next

End Sub
Public Sub S_AdLis(Optional ByVal AdVor As Boolean = False)
On Error GoTo LiErr
'Füllt die Tabelle mit Daten

