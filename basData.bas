Public Function S_AdFil(ByVal FSQL As String) As Boolean
On Error GoTo LiErr
'Weißt dem ReportControl die gefilterten Adressen zu

Dim AktZa As Integer
Dim CmBrs As XtremeCommandBars.CommandBars
Dim RpCo2 As XtremeReportControl.ReportControl
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set RpCo2 = FM.repCont2
Set CmBrs = FM.comBar01
Set RpRcs = RpCo2.Records
Set CmAcs = CmBrs.Actions
Set CmSta = CmBrs.StatusBar

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

Screen.MousePointer = vbHourglass
clFen.FenDsk 2

Set RS147 = New ADODB.Recordset
With RS147
    .CursorLocation = adUseClient
    .Source = FSQL
    .ActiveConnection = DB1
    .CursorType = adOpenForwardOnly
    .LockType = adLockReadOnly
    .Open Options:=adCmdText
End With
GlAdA = RS147.RecordCount

If GlAdA > 0 Then 'Anzahl gefundener Adressen
    With RpCo2
        .EditItem Nothing, Nothing
        If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
        If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
        If .Records.Count > 0 Then .Records.DeleteAll
        .Populate
    End With
    
    Select Case GlBut
    Case RibTab_Adressen: CmAcs(SY_AD_Adresse_Vollst).Enabled = True
    Case RibTab_Mandanten: CmAcs(SY_MA_Mandant_Vollst).Enabled = True
    Case RibTab_Verordner: CmAcs(SY_VE_Verord_Vollst).Enabled = True
    Case RibTab_Mitarbeit: CmAcs(SY_MI_Mitarb_Vollst).Enabled = True
    End Select
    DoEvents
    
    AdAry = RS147.GetRows 'Array Füllen
    DoEvents

    RpCo2.SetVirtualMode GlAdA 'Anzahl gefundener Adressen
    DoEvents

    Set RpRec = RpCo2.Records(0)
    For AktZa = 0 To 31
        Set RpItm = RpRec.AddItem(vbNullString)
    Next AktZa

    DoEvents
    With RpCo2
        .Populate
        .SetCustomDraw xtpCustomBeforeDrawRow
    End With
    
    Set RpRws = RpCo2.Rows
    RpRws.Row(0).Selected = True
    If GlFoc = True Then
        Set RpCo2.FocusedRow = RpRws.Row(0)
    End If
    S_AdFil = True
Else
    GlAdA = 0
    If GlAdA > 0 Then
        Erase AdAry
    End If
    RpCo2.SetVirtualMode 0
    
    DoEvents
    With RpCo2
        .Populate
        .SetCustomDraw xtpCustomBeforeDrawRow
    End With
    
    SPopu "Keine Adressen gefunden", "Es wurden keine Adressen gefunden, die dem Suchkriterium entsprechen", IC48_Information
End If

RS147.Close
Set RS147 = Nothing

SMark

clFen.FenDsk 3
Screen.MousePointer = vbNormal

Set RpRec = Nothing
Set RpCo2 = Nothing
Set CmSta = Nothing
Set CmBrs = Nothing

Set clFen = Nothing

GlPaK = "P804"

Exit Function

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_AdFil " & Err.Number
Resume Next

End Function
Public Sub S_AdFin(ByVal SuStr As String, ByVal SuFel As Integer, ByVal FrmSe As Integer)
