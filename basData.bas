Public Sub S_TeFa()
On Error GoTo LoErr
'Neuzuordnung des Terminfarbindex

Dim SQL1 As String
Dim AnzTe As Long
Dim AktTe As Long
Dim TeBtr As String
Dim AktZa As Integer
Dim Frage As Integer
Dim Mld1, Tit1 As String

Set FM = frmMain
Set CaCol = FM.calCont1
Set DaPro = CaCol.DataProvider
Set CaLbs = DaPro.LabelList

AktTe = 0
Tit1 = "Terminfarbzuordnung"
Mld1 = "Sollen die Terminfarben nun auf Grundlage der terminbetreffs neu zugeordnet werden?"

Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
If Frage = 6 Then
    If GlTS1 = True Then 'Sortierung Terminliste Aufsteigend
        If GlTyp < 2 Then
            SQL1 = "SELECT * FROM dbo.qryTerLis ORDER BY SorDat, SorTim"
        Else
            SQL1 = "SELECT * FROM qryTerLis ORDER BY [VonDat], [ZeiVon];"
        End If
    Else
        If GlTyp < 2 Then
            SQL1 = "SELECT * FROM dbo.qryTerLis ORDER BY SorDat DESC, SorTim DESC"
        Else
            SQL1 = "SELECT * FROM qryTerLis ORDER BY [VonDat] DESC, [ZeiVon] DESC;"
        End If
    End If
    
    Set RS137 = New ADODB.Recordset
    With RS137
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With
    AnzTe = RS137.RecordCount
    
    If AnzTe > 0 Then
        frmStatus.Show
        DoEvents
        frmStatus.Caption = "Terminfarbzuordnungen"
        Set PrBr1 = frmStatus.prbStat1
        Set PrBr2 = frmStatus.prbStat2
        Set TxDum = frmStatus.txtDummy
        PrBr1.Min = 0
        PrBr1.Max = AnzTe
        frmStatus.Show
        DoEvents
        Do
        If RS137.Fields("IDKurz").Value <> vbNullString Then
            TeBtr = RS137.Fields("IDKurz").Value
        Else
            TeBtr = vbNullString
        End If
        If TeBtr <> vbNullString Then
            For AktZa = 1 To UBound(GlBtr)
                If TeBtr Like GlBtr(AktZa, 1) Then
                    RS137.Fields("Farbe").Value = AktZa + 20
                    RS137.Update
                    Exit For
                End If
            Next AktZa
        End If
        AktTe = AktTe + 1
        PrBr1.Value = AktTe
        RS137.MoveNext
        Loop Until RS137.EOF
    End If
    RS137.Close
    Set RS137 = Nothing
    DoEvents
    Unload frmStatus
    Set frmStatus = Nothing
End If

Exit Sub

LoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TeFa " & Err.Number
Resume Next

End Sub
