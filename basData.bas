            PaStr = MaAry(Mai_Patient, RpRow.Index)
        Else
            PaStr = vbNullString
        End If
        KoStr = InputBox("Bitte geben Sie den gewünschten Kommentar ein:", "Kommentar", PaStr)
        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                IdxNr = MaAry(Mai_IDA, RpRow.Index)
                If KoStr <> vbNullString Then
                    Select Case GlMKa 'Mailkatalog (1=Posteingang 2=Postaisgang)
                    Case 1: DBCmEx3 "qryMailInPat", "@IdPat", "@IdStr", "@IdxNr", 0, KoStr, IdxNr
                    Case 2: DBCmEx3 "qryMailOutPat", "@IdPat", "@IdStr", "@IdxNr", 0, KoStr, IdxNr
                    Case 3: DBCmEx3 "qryMailInPat", "@IdPat", "@IdStr", "@IdxNr", 0, KoStr, IdxNr
                    Case 4: DBCmEx3 "qryMailOutPat", "@IdPat", "@IdStr", "@IdxNr", 0, KoStr, IdxNr
                    End Select
                End If
            End If
        Next RpRow
    End If
End If

If RowNr > 0 Then
    If RpRws.Count > 0 Then
        RowFi = RpCo0.TopRowIndex
    End If
End If

DoEvents
S_MaLis

If RowNr > 0 Then
    If RpRws.Count > 0 Then
        If RowNr >= RpRws.Count Then
            RowNr = RpRws.Count - 1
        End If
        RpCo0.TopRowIndex = RowFi
        RpRws.Row(0).Selected = False
        RpRws.Row(RowNr).EnsureVisible
        RpRws.Row(RowNr).Selected = True
        If GlFoc = True Then
            Set RpCo0.FocusedRow = RpRws.Row(RowNr)
        End If
    End If
End If

Set RpSel = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCo0 = Nothing

Exit Sub

LoErr:
If GlDbg = True Then SErLog Err.Description & " S_MaKom " & Err.Number
Resume Next

End Sub
Public Sub S_MaKPo(ByVal LiTyp As Integer)
On Error GoTo KoErr
'Lädt Details in die Detailansicht

Dim GesZa As Long
Dim IdxNr As Long
Dim MitNr As Long
Dim GrpNr As Long
Dim AktZa As Integer
Dim IdPrv As Integer
Dim IdPsf As Integer
Dim IdPo1 As Integer
Dim IdPo2 As Integer
Dim AlKon As Boolean
Dim Lab30 As XtremeSuiteControls.Label
Dim CmMi2 As XtremeSuiteControls.ComboBox
Dim CmGrp As XtremeSuiteControls.ComboBox
Dim CmPrv As XtremeSuiteControls.ComboBox
Dim CmPsf As XtremeSuiteControls.ComboBox
Dim CmVe1 As XtremeSuiteControls.ComboBox
Dim CmVe2 As XtremeSuiteControls.ComboBox
Dim CmAlt As XtremeSuiteControls.ComboBox
Dim ChAut As XtremeSuiteControls.CheckBox
Dim ChKop As XtremeSuiteControls.CheckBox
Dim ChAlt As XtremeSuiteControls.CheckBox
Dim ChChk As XtremeSuiteControls.CheckBox
Dim ChMas As XtremeSuiteControls.CheckBox
Dim ChAno As XtremeSuiteControls.CheckBox
Dim TxPo1 As XtremeSuiteControls.FlatEdit
Dim TxPo2 As XtremeSuiteControls.FlatEdit
Dim TxSv1 As XtremeSuiteControls.FlatEdit
Dim TxSv2 As XtremeSuiteControls.FlatEdit
Dim TxUsN As XtremeSuiteControls.FlatEdit
Dim TxUsP As XtremeSuiteControls.FlatEdit
Dim CmBrs As XtremeCommandBars.CommandBars
Dim RpCon As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMailKont
Set Lab30 = FM.lblLab30
Set CmMit = FM.cmbMitar
Set CmMi2 = FM.cmbMita2
Set CmGrp = FM.cbmEmGrp
Set CmPrv = FM.cmbProvi
Set CmPsf = FM.cmbPostf
Set CmVe1 = FM.cmbVer01
Set CmVe2 = FM.cmbVer02
Set CmAlt = FM.cmbAlter
Set TxPo1 = FM.txtPort1
Set TxPo2 = FM.txtPort2
Set TxSv1 = FM.txtEMPOP
Set TxSv2 = FM.txtESMTP
Set TxUsN = FM.txtUsNam
Set TxUsP = FM.txtUsPas
Set ChAut = FM.chkEmAut
Set ChKop = FM.chkKopie
Set ChAlt = FM.chkAlter
Set ChChk = FM.chkAdChk
Set ChMas = FM.chkEmMas
Set ChAno = FM.chkAnony
Set CmGrp = FM.cbmEmGrp
Set CmBrs = FM.comBar02
Set RpCon = FM.repCont1
Set RpCls = RpCon.Columns
Set RpSel = RpCon.SelectedRows

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        Set RpCol = RpCls.Find(EMK_IDK)
        IdxNr = RpRow.Record(RpCol.ItemIndex).Value
    
        Select Case LiTyp
        Case 1:
            Set RS126 = New ADODB.Recordset
            RS126.CursorLocation = adUseClient
            Set RS126 = DBCmRe1("qryMailKonEd", "@IdxNr", IdxNr)
            GesZa = RS126.RecordCount
            If GesZa > 0 Then
                If RS126.Fields("Em_Prov").Value <> vbNullString Then
                    If RS126.Fields("Em_Prov").Value > 0 Then
                        CmPrv.ListIndex = SCmX(CmPrv, RS126.Fields("Em_Prov").Value)
                    End If
                End If
                If RS126.Fields("Em_Verf").Value <> vbNullString Then
                    If RS126.Fields("Em_Verf").Value > 0 Then
                        CmPsf.ListIndex = SCmX(CmPsf, RS126.Fields("Em_Verf").Value)
                        IdPsf = RS126.Fields("Em_Verf").Value
                    Else
                        CmPsf.ListIndex = 1
                        IdPsf = 2 'POP3
                        AlKon = True 'altes Konto
                    End If
                End If
                If RS126.Fields("Em_TLS1").Value <> vbNullString Then
                    If AlKon = True Then
                        CmVe1.ListIndex = GlPro(14, 4)
                    Else
                        CmVe1.ListIndex = SCmX(CmVe1, RS126.Fields("Em_TLS1").Value)
                    End If
                End If
                If RS126.Fields("Em_TLS2").Value <> vbNullString Then
                    If AlKon = True Then
                        CmVe2.ListIndex = GlPro(14, 5)
                    Else
                        CmVe2.ListIndex = SCmX(CmVe2, RS126.Fields("Em_TLS2").Value)
                    End If
                End If
                If RS126.Fields("Em_Back").Value <> vbNullString Then
                    CmAlt.ListIndex = SCmX(CmAlt, RS126.Fields("Em_Back").Value)
                End If
                Select Case IdPsf
                Case 1: 'IMAP
                    If RS126.Fields("Em_IMAP").Value <> vbNullString Then
                        TxSv1.Text = RS126.Fields("Em_IMAP").Value
                    End If
                    Lab30.Caption = "IMAP-Server :"
                Case 2: 'POP3
                    If RS126.Fields("Em_POP").Value <> vbNullString Then
                        TxSv1.Text = RS126.Fields("Em_POP").Value
                    End If
                    Lab30.Caption = "POP3-Server :"
                End Select
                If RS126.Fields("Em_SMTP").Value <> vbNullString Then
                    TxSv2.Text = RS126.Fields("Em_SMTP").Value
                End If
                If RS126.Fields("Em_Port1").Value <> vbNullString Then
                    TxPo1.Text = RS126.Fields("Em_Port1").Value
                End If
                If RS126.Fields("Em_Port2").Value <> vbNullString Then
                    TxPo2.Text = RS126.Fields("Em_Port2").Value
                End If
                If RS126.Fields("Em_SeNam").Value <> vbNullString Then
                    FM.txtName.Text = RS126.Fields("Em_SeNam").Value
                Else
                    FM.txtName.Text = vbNullString
                End If
                If RS126.Fields("Em_Adresse").Value <> vbNullString Then
                    FM.txtEmAdr.Text = RS126.Fields("Em_Adresse").Value
                Else
                    FM.txtEmAdr.Text = vbNullString
                End If
                If RS126.Fields("Em_Repl").Value <> vbNullString Then
                    FM.txtAnAdr.Text = RS126.Fields("Em_Repl").Value
                Else
                    FM.txtAnAdr.Text = vbNullString
                End If
                If RS126.Fields("Em_User").Value <> vbNullString Then
                    TxUsN.Text = RS126.Fields("Em_User").Value
                Else
                    TxUsN.Text = vbNullString
                End If
                If RS126.Fields("Em_Pass").Value <> vbNullString Then
                    TxUsP.Text = RS126.Fields("Em_Pass").Value
                Else
                    TxUsP.Text = vbNullString
                End If
                If CBool(RS126.Fields("Em_Aut").Value) = True Then
                    ChAut.Value = xtpChecked
                Else
                    ChAut.Value = xtpUnchecked
                End If
                If CBool(RS126.Fields("Anonym").Value) = True Then
                    ChAno.Value = xtpChecked
                Else
                    ChAno.Value = xtpUnchecked
                End If
                If CBool(RS126.Fields("Selekt").Value) = True Then 'Emails auf Server belassen
                    ChKop.Value = xtpChecked
                    If IdPsf = 1 Then 'IMAP4
                        ChChk.Enabled = True 'Als gelesen kennzeichnen
                        If CBool(RS126.Fields("Em_Chk").Value) = True Then
                            ChChk.Value = xtpChecked
                        Else
                            ChChk.Value = xtpUnchecked
                        End If
                    Else
                        ChChk.Value = xtpUnchecked
                        ChChk.Enabled = False 'Als gelesen kennzeichnen
                    End If
                Else
                    ChKop.Value = xtpUnchecked
                    ChChk.Value = xtpUnchecked
                    ChChk.Enabled = False 'Als gelesen kennzeichnen
                End If
                If RS126.Fields("IDM").Value > 0 Then
                    MitNr = RS126.Fields("IDM").Value
                    For AktZa = 1 To UBound(GlMiA)
                        If MitNr = GlMiA(AktZa, 2) Then
                            CmMit.ListIndex = AktZa - 1
                            Exit For
                        End If
                    Next AktZa
                Else
                    CmMit.ListIndex = GlSmI - 1
                End If
                Select Case IdPsf
                Case 1: ChAlt.Enabled = True 'Nur neue Emails abrufen
                        CmAlt.Enabled = True
                        If CBool(RS126.Fields("Em_Neu").Value) = True Then
                            ChAlt.Value = xtpChecked
                        Else
                            ChAlt.Value = xtpUnchecked
                        End If
                Case 2: CmAlt.Enabled = False 'Nur neue Emails abrufen
                        ChAlt.Enabled = False
                        ChAlt.Value = xtpUnchecked
                End Select
                If CBool(RS126.Fields("Em_Mas").Value) = True Then
                    ChMas.Value = xtpChecked
                Else
                    ChMas.Value = xtpUnchecked
                End If
            End If
            RS126.Close
            Set RS126 = Nothing
        Case 2:
            Set RS126 = New ADODB.Recordset
            RS126.CursorLocation = adUseClient
            Set RS126 = DBCmRe1("qryMailSpEd", "@IdxNr", IdxNr)
            GesZa = RS126.RecordCount
            If GesZa > 0 Then
                If RS126.Fields("IDKurz").Value <> vbNullString Then
                    FM.txtFiNam.Text = RS126.Fields("IDKurz").Value
                Else
                    FM.txtFiNam.Text = vbNullString
                End If
                If RS126.Fields("Subject").Value <> vbNullString Then
                    FM.txtEmBet.Text = RS126.Fields("Subject").Value
                Else
                    FM.txtEmBet.Text = vbNullString
                End If
                If RS126.Fields("SenderMail").Value <> vbNullString Then
                    FM.txtEmAbs.Text = RS126.Fields("SenderMail").Value
                Else
                    FM.txtEmAbs.Text = vbNullString
                End If
                If RS126.Fields("ID1").Value > 0 Then
                    GrpNr = RS126.Fields("ID1").Value
                    For AktZa = 1 To UBound(GlEmG)
                        If GrpNr = GlEmG(AktZa, 0) Then
                            FM.cbmEmGrp.ListIndex = AktZa - 1
                            Exit For
                        End If
                    Next AktZa
                    If GrpNr = 802 Then FM.cbmEmGrp.ListIndex = AktZa - 1
                    If GrpNr = 803 Then FM.cbmEmGrp.ListIndex = AktZa
                    If GrpNr = 804 Then FM.cbmEmGrp.ListIndex = AktZa + 1
                    If GrpNr = 805 Then FM.cbmEmGrp.ListIndex = AktZa + 2
                Else
                    FM.cbmEmGrp.ListIndex = 0
                End If
                If RS126.Fields("IDM").Value > 0 Then
                    MitNr = RS126.Fields("IDM").Value
                    For AktZa = 1 To UBound(GlMiK)
                        If MitNr = GlMiK(AktZa, 2) Then
                            FM.cmbMita2.ListIndex = AktZa - 1
                            Exit For
                        End If
                    Next AktZa
                Else
                    FM.cmbMita2.ListIndex = 0
                End If
            End If
            RS126.Close
            Set RS126 = Nothing
        End Select
    End If
Else
    If LiTyp = 1 Then
        IdPrv = CmPrv.ListIndex + 1
        CmVe1.ListIndex = GlPro(IdPrv, 4)
        CmVe2.ListIndex = GlPro(IdPrv, 5)
        IdPsf = CmPsf.ItemData(CmPsf.ListIndex)
        IdPo1 = CmVe1.ItemData(CmVe1.ListIndex)
        IdPo2 = CmVe2.ItemData(CmVe2.ListIndex)
                        
        Select Case IdPsf
        Case 1: Lab30.Caption = "IMAP-Server :"
                If GlPro(IdPrv, 2) <> vbNullString Then
                    TxSv1.Text = GlPro(IdPrv, 2)
                Else
                    TxSv1.Text = vbNullString
                End If
                Select Case IdPo1
                Case 0: TxPo1.Text = 143
                Case 1: TxPo1.Text = 993
                Case 2: TxPo1.Text = 143
                End Select
        Case 2: Lab30.Caption = "POP3-Server :"
                If GlPro(IdPrv, 1) <> vbNullString Then
                    TxSv1.Text = GlPro(IdPrv, 1)
                Else
                    TxSv1.Text = vbNullString
                End If
                Select Case IdPo1
                Case 0: TxPo1.Text = 110
                Case 1: TxPo1.Text = 995
                Case 2: TxPo1.Text = 110
                End Select
        End Select
        
        Select Case IdPsf
        Case 1: ChAlt.Enabled = True
                If ChAlt.Value = xtpChecked Then
                    CmAlt.Enabled = True
                Else
                    CmAlt.Enabled = False
                End If
        Case 2: CmAlt.Enabled = False
                ChAlt.Enabled = False
        End Select
        
        If GlPro(IdPrv, 3) <> vbNullString Then
            TxSv2.Text = GlPro(IdPrv, 3)
        Else
            TxSv2.Text = vbNullString
        End If
        Select Case IdPo2
        Case 0: TxPo2.Text = 465
        Case 1: TxPo2.Text = 587
        Case 2: TxPo2.Text = 587
        End Select
        
        FM.txtName.Text = vbNullString
        FM.txtEmAdr.Text = vbNullString
        FM.txtAnAdr.Text = vbNullString
        TxUsN.Text = vbNullString
        TxUsP.Text = vbNullString
    End If
End If

Set CmBrs = Nothing
Set RpSel = Nothing
Set RpRow = Nothing
Set RpRws = Nothing
Set RpCol = Nothing
Set RpCls = Nothing
Set RpCon = Nothing

Exit Sub

KoErr:
If GlDbg = True Then SErLog Err.Description & " S_MaKPo " & Err.Number
Resume Next

End Sub
Private Sub S_MaKRc(ByRef RST As ADODB.Recordset, ByVal KaTyp As Integer)
On Error GoTo KoErr
'Lädt Mailkonten

Dim RpCon As XtremeReportControl.ReportControl

Set FM = frmMailKont
Set RpCon = FM.repCont1
Set RpRcs = RpCon.Records

Select Case KaTyp
Case 1:
    Do
    Set RpRec = RpRcs.Add()
    Set RpItm = RpRec.AddItem(RST.Fields("IDK").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("IDM").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Em_POP").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Em_SMTP").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Em_SeNam").Value)
    RpItm.Icon = IC16_Doc_Norm
    Set RpItm = RpRec.AddItem(RST.Fields("Em_Adresse").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Em_Repl").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Em_User").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Em_Pass").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Em_Port1").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Em_Port2").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Em_Aut").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Selekt").Value)
    RST.MoveNext
    Loop Until RST.EOF
Case 2:
    Do
    Set RpRec = RpRcs.Add()
    Set RpItm = RpRec.AddItem(RST.Fields("IDA").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("ID1").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Subject").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("SenderMail").Value)
    RpItm.Icon = IC16_Doc_Norm
    Set RpItm = RpRec.AddItem(RST.Fields("Selekt").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("TreKey").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("IDM").Value)
    RST.MoveNext
    Loop Until RST.EOF
End Select

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCon = Nothing

Exit Sub

KoErr:
If GlDbg = True Then SErLog Err.Description & " S_MaKRc " & Err.Number
Resume Next

End Sub
