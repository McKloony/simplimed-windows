Public Sub S_LaSet()
On Error GoTo SuErr
'Setzt die patologische Kennung bei Eingabe

Dim AkRow As Long
Dim GreWe As String
Dim GePat As String
Dim ErgWe As Single
Dim Mld1, Tit1 As String

Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo6 = FM.repCont6
Set RpCo5 = FM.repCont5
Set RpCls = RpCo5.Columns
Set RpSel = RpCo5.SelectedRows

Tit1 = "Grenzwertzuordnung"
Mld1 = "Für diesen Parameter wurde kein Grenzwert definiert."

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        Set RpCol = RpCls.Find(Lab_Geschlecht)
        GePat = RpRow.Record(RpCol.ItemIndex).Value
        
        Set RpCls = RpCo6.Columns
        Set RpSel = RpCo6.SelectedRows
        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            If RpRow.GroupRow = False Then
                Set RpCol = RpCls.Find(Lbl_Ergebniswert)
                ErgWe = RpRow.Record(RpCol.ItemIndex).Value

                Select Case GePat
                Case "M":
                    If Not IsNull(RS118.Fields("GrM6a").Value) Then
                        If ErgWe <= RS118.Fields("GrM1b").Value Then
                            GreWe = "  --"
                        ElseIf ErgWe <= RS118.Fields("GrM2b").Value Then
                            GreWe = "  -"
                        ElseIf ErgWe >= RS118.Fields("GrM3a").Value And ErgWe <= RS118.Fields("GrM3b").Value Then
                            GreWe = "  (-)"
                        ElseIf ErgWe > RS118.Fields("GrM3b").Value And ErgWe < RS118.Fields("GrM4a").Value Then
                            GreWe = "  (*)"
                        ElseIf ErgWe >= RS118.Fields("GrM4a").Value And ErgWe <= RS118.Fields("GrM4b").Value Then
                            GreWe = "  (+)"
                        ElseIf ErgWe > RS118.Fields("GrM4b").Value And ErgWe <= RS118.Fields("GrM5b").Value Then
                            GreWe = "  +"
                        ElseIf ErgWe >= RS118.Fields("GrM6a").Value Then
                            GreWe = "  ++"
                        Else
                            GreWe = "  (*)"
                        End If
                    Else
                        GreWe = vbNullString
                        WindowMess Mld1, Dial2, Tit1, FM.hwnd
                    End If
                Case "K":
                    If Not IsNull(RS118.Fields("GrK6a").Value) Then
                        If ErgWe <= RS118.Fields("GrK1b").Value Then
                            GreWe = "  --"
                        ElseIf ErgWe <= RS118.Fields("GrK2b").Value Then
                            GreWe = "  -"
                        ElseIf ErgWe >= RS118.Fields("GrK3a").Value And ErgWe <= RS118.Fields("GrK3b").Value Then
                            GreWe = "  (-)"
                        ElseIf ErgWe > RS118.Fields("GrK3b").Value And ErgWe < RS118.Fields("GrK4a").Value Then
                            GreWe = "  (*)"
                        ElseIf ErgWe >= RS118.Fields("GrK4a").Value And ErgWe <= RS118.Fields("GrK4b").Value Then
                            GreWe = "  (+)"
                        ElseIf ErgWe > RS118.Fields("GrK4b").Value And ErgWe <= RS118.Fields("GrK5b").Value Then
                            GreWe = "  +"
                        ElseIf ErgWe >= RS118.Fields("GrK6a").Value Then
                            GreWe = "  ++"
                        Else
                            GreWe = "  (*)"
                        End If
                    Else
                        GreWe = vbNullString
                        WindowMess Mld1, Dial2, Tit1, FM.hwnd
                    End If
                Case Else:
                    If Not IsNull(RS118.Fields("GrF6a").Value) Then
                        If ErgWe <= RS118.Fields("GrF1b").Value Then
                            GreWe = "  --"
                        ElseIf ErgWe <= RS118.Fields("GrF2b").Value Then
                            GreWe = "  -"
                        ElseIf ErgWe >= RS118.Fields("GrF3a").Value And ErgWe <= RS118.Fields("GrF3b").Value Then
                            GreWe = "  (-)"
                        ElseIf ErgWe > RS118.Fields("GrF3b").Value And ErgWe < RS118.Fields("GrF4a").Value Then
                            GreWe = "  (*)"
                        ElseIf ErgWe >= RS118.Fields("GrF4a").Value And ErgWe <= RS118.Fields("GrF4b").Value Then
                            GreWe = "  (+)"
                        ElseIf ErgWe > RS118.Fields("GrF4b").Value And ErgWe <= RS118.Fields("GrF5b").Value Then
                            GreWe = "  +"
                        ElseIf ErgWe >= RS118.Fields("GrF6a").Value Then
                            GreWe = "  ++"
                        Else
                            GreWe = "  (*)"
                        End If
                    Else
                        GreWe = vbNullString
                        WindowMess Mld1, Dial2, Tit1, FM.hwnd
                    End If
                End Select

                Set RpCol = RpCls.Find(Lbl_Grenzwert)
                RpRow.Record(RpCol.ItemIndex).Value = GreWe
                RpRow.Record(RpCol.ItemIndex).Tag = "@Grenzwert" 'Tag geändert

            End If
        End If
    End If
End If

Set RpCls = Nothing
Set RpSel = Nothing
Set RpCo6 = Nothing
Set RpCo5 = Nothing

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_LaSet " & Err.Number
Resume Next

End Sub
Public Sub S_LaZu()
On Error GoTo LdErr
'Fasst doppelte Laborberichte zusammen

Dim GesBe As Long   'Gesamtzahl doppelter Berichte
Dim GesTe As Long   'Gesamtzahl der Parameter im Bericht
Dim BerZa As Long   'Akteller Bericht
Dim TesZa As Long   'Aktueller Parameter
Dim BerNr As Long   'Zuzuordnende Berichtnummer
Dim IdxNr As Long   'Aktuelle Berichtnummer
Dim LoBer As Long   'Zu löschender Bericht
Dim AuStr As String 'Auftragsnummer
Dim BefAr As String 'Befundart
Dim LaStr As String 'Labornummer
Dim Befng As String 'Befundung
Dim Bfdng As Boolean
Dim SQL1 As String
Dim SQL2 As String
Dim Frage As Integer
Dim Mld1, Tit1 As String

Tit1 = "Zusammenfassen"
Mld1 = "Möchten Sie jetzt doppelte Berichte in einen Bericht zusammenfassen? Dabei werden Berichte ohne Inhalt gelöscht."

Frage = WindowMess(Mld1, Dial1, Tit1, frmMain.hwnd)
If Frage = 6 Then
    Set FM = frmStatus
    Set PrBr1 = FM.prbStat1
    Set PrBr2 = FM.prbStat2
    Set TxDum = FM.txtDummy
    
    Set RS111 = New ADODB.Recordset 'doppelte Laborberichte
    With RS111
        .CursorLocation = adUseClient
        .Source = "qryLabDo1"
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdTableDirect
    End With
    GesBe = RS111.RecordCount
    
    If GesBe > 0 Then
        FM.Show
        BerZa = 1
        PrBr2.Min = 0
        PrBr2.Max = GesBe
        FM.Caption = "Testdaten zusammenfassen..."
        DoEvents
    
        Do
        Befng = vbNullString
        LoBer = 0
        AuStr = RS111.Fields("IDA").Value 'Auftragsnummer
        LaStr = RS111.Fields("Labor").Value 'Labornummer
        BerNr = RS111.Fields("ID0").Value 'zuzuordnende Berichtnummer
        BefAr = RS111.Fields("Befund").Value 'Befundart

        If BefAr <> "Eigenbefund" Then
            DBCmEx2 "qryLabDo4", "@Befun", "@IdStr", BefAr, AuStr
        End If
        If BefAr = "Endbefund" Then
            DBCmEx2 "qryLabDo4", "@Befun", "@IdStr", BefAr, AuStr
        End If
        If LaStr <> AuStr Then
            DBCmEx2 "qryLabDo5", "@Labor", "@IdStr", LaStr, AuStr
        End If
        
        SQL1 = "SELECT * FROM qryLabBeNe WHERE [Auftrag] ='" & AuStr & "';"
        Set RS112 = New ADODB.Recordset 'jeweiliger Laborbericht
        With RS112
            .CursorLocation = adUseClient
            .Source = SQL1
            .ActiveConnection = DB1
            .CursorType = adOpenDynamic
            .LockType = adLockOptimistic
            .Open Options:=adCmdText
        End With
        If RS112.RecordCount > 0 Then
            Do
            IdxNr = RS112.Fields("ID0").Value 'aktuelle Berichtnummer
            
            DBCmEx1 "qryLabNuLo", "@IdxNr", IdxNr 'Leere Testwerte löschen
            DoEvents
            
            If BerNr <> IdxNr Then
                LoBer = IdxNr 'zu löschender Bericht
            End If
            
            If GlGrI = True Then 'Gruppierung Laborbericht
                If GlTyp < 2 Then
                    SQL2 = "SELECT * FROM dbo.qryLabTes WHERE IDB = " & IdxNr & " ORDER BY Gruppe, Ident"
                Else
                    SQL2 = "SELECT * FROM qryLabTes WHERE [IDB] = " & IdxNr & " ORDER BY [Gruppe], [Ident];"
                End If
            Else
                If GlTyp < 2 Then
                    SQL2 = "SELECT * FROM dbo.qryLabTes WHERE IDB = " & IdxNr & " ORDER BY Ident"
                Else
                    SQL2 = "SELECT * FROM qryLabTes WHERE [IDB] = " & IdxNr & " ORDER BY [Ident];"
                End If
            End If
            Set RS113 = New ADODB.Recordset 'dazugehörige Testdaten
            With RS113
                .CursorLocation = adUseClient
                .Source = SQL2
                .ActiveConnection = DB1
                .CursorType = adOpenDynamic
                .LockType = adLockOptimistic
                .Open Options:=adCmdText
            End With
            GesTe = RS113.RecordCount
            If GesTe > 0 Then
                TesZa = 1
                PrBr1.Min = 0
                PrBr1.Max = GesTe
                Do
                RS113.Fields("IDB").Value = BerNr
                RS113.Update
                RS113.MoveNext
                
                DoEvents
                If TesZa < GesTe Then PrBr1.Value = TesZa
                TesZa = TesZa + 1
                Loop Until RS113.EOF
            End If
            RS113.Close
            Set RS113 = Nothing
            
            If Len(Befng) > 250 Then
                Befng = Left$(Befng, 250)
            End If
            If Not IsNull(RS112.Fields("Befundung").Value) Or RS112.Fields("Befundung").Value <> vbNullString Then
                If Befng = vbNullString Then
                    Befng = Trim$(RS112.Fields("Befundung").Value)
                Else
                    If Len(Befng) > 250 Then
                        Befng = Left$(Befng, 250)
                    End If
                    Befng = Befng & vbCrLf & vbCrLf & Trim$(RS112.Fields("Befundung").Value)
                End If
                If InStr(1, Left$(Befng, 2), vbCrLf, 1) <> 0 Then
                    Befng = Replace(Befng, vbCrLf, "")
                End If
            End If
            RS112.MoveNext
            Loop Until RS112.EOF

            If Befng <> vbNullString Then
                RS112.MoveFirst
                Do
                If Len(Befng) > 250 Then
                    Befng = Left$(Befng, 250)
                    RS112.Fields("Befund").Value = -1
                End If
                RS112.Fields("Befundung").Value = Befng
                RS112.Update
                RS112.MoveNext
                Loop Until RS112.EOF
            End If
        End If
        RS112.Close
        Set RS112 = Nothing

        DBCmEx1 "qryLabBeLo", "@IdxNr", LoBer 'Bericht löschen
        DoEvents
        
        If BerZa < GesBe Then PrBr2.Value = BerZa
        BerZa = BerZa + 1

        RS111.MoveNext
        Loop Until RS111.EOF
    Else
        Mld1 = "Es existieren momentan keine doppelten Berichte"
        Tit1 = "Zusammenfassen"
        WindowMess Mld1, Dial2, Tit1, FM.hwnd
    End If
    RS111.Close
    Set RS111 = Nothing
    
    Unload frmStatus
    Set frmStatus = Nothing
    DoEvents
    
    If GesBe > 0 Then
        SUpLa
        Mld1 = "Die Zusammenfassung ist abgeschlossen"
        WindowMess Mld1, Dial2, Tit1, FM.hwnd
    End If
End If

Exit Sub

LdErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_LaZu " & Err.Number
Resume Next

End Sub
Public Sub S_LaVe(ByVal IdxNr As Long)
On Error GoTo SuErr
'Vergleicht die Laborergebnosse eines Patienten

Dim BerNr As Long
Dim BerZa As Long
Dim AkDat As String
Dim TmBez As String
Dim TmDat As String
Dim TmErg As String
Dim AnBer As Integer
Dim AnPar As Integer
Dim AnWer As Integer
Dim AkBer As Integer
Dim AkSpa As Integer
Dim AkCol As Integer
Dim DatOk As Boolean
Dim RpCon As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmLaVer
Set RpCon = FM.repCont1
Set RpCls = RpCon.Columns
Set RpRcs = RpCon.Records

Set RS155 = New ADODB.Recordset 'Laborberichte
RS155.CursorLocation = adUseClient
Set RS155 = DBCmRe1("qryLabBePat", "@IdxNr", IdxNr)
AnBer = RS155.RecordCount

Set RS156 = New ADODB.Recordset 'Einzelne Parameter
RS156.CursorLocation = adUseClient
Set RS156 = DBCmRe1("qryLabTeGr", "@IdxNr", IdxNr)
AnPar = RS156.RecordCount

Set RS157 = New ADODB.Recordset 'Einzelne Parameter
RS157.CursorLocation = adUseClient
Set RS157 = DBCmRe1("qryLabTePa", "@IdxNr", IdxNr)
AnWer = RS157.RecordCount
    
If AnBer > 0 Then
    If AnPar > 0 Then
        If AnWer > 0 Then
            DatOk = True
        End If
    End If
End If

If DatOk = True Then
    With RpCon
        .EditItem Nothing, Nothing
        If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
        If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
        If .Records.Count > 0 Then .Records.DeleteAll
        If .Columns.Count > 0 Then .Columns.DeleteAll
        .Populate
    End With
    
    '------------------------------Spaltenköpfe------------------------------
    Set RpCol = RpCls.Add(0, "Parameter", 250, True)
    RpCol.Alignment = xtpAlignmentLeft
    RpCol.Tag = 0
    
    Do
    BerNr = RS155.Fields("ID0").Value
    If RS155.Fields("L-Eingang").Value <> vbNullString Then
        AkDat = Format$(RS155.Fields("L-Eingang").Value, "dd.mm.yyyy")
    Else
        If RS155.Fields("L-Ausgang").Value <> vbNullString Then
            AkDat = Format$(RS155.Fields("L-Ausgang").Value, "dd.mm.yyyy")
        End If
    End If
    AkBer = AkBer + 1
    Set RpCol = RpCls.Add(AkBer, AkDat, 90, True)
    RpCol.Alignment = xtpAlignmentRight
    RpCol.HeaderAlignment = xtpAlignmentCenter
    RpCol.Tag = BerNr
    RS155.MoveNext
    Loop Until RS155.EOF
    
    Set RpCol = RpCls.Add(AnBer + 1, "Ident", 80, True)
    RpCol.Alignment = xtpAlignmentLeft
    RpCol.HeaderAlignment = xtpAlignmentCenter
    RpCol.Tag = AnBer + 1
    
    Set RpCol = RpCls.Add(AnBer + 2, "Einheit", 90, True)
    RpCol.Alignment = xtpAlignmentLeft
    RpCol.HeaderAlignment = xtpAlignmentCenter
    RpCol.Tag = AnBer + 2
    
    If GlGrY = True Then 'Gruppierung Laborbericht Anzeigen
        Set RpCol = RpCls.Add(AnBer + 3, "Gruppe", 120, True)
        RpCol.Alignment = xtpAlignmentLeft
        RpCol.HeaderAlignment = xtpAlignmentCenter
        RpCol.Tag = AnBer + 3
    End If

    '------------------------------Datensätze------------------------------
    Do
    Set RpRec = RpRcs.Add()
    If RS156.Fields("Testbezeichnung").Value <> vbNullString Then
        Set RpItm = RpRec.AddItem(RS156.Fields("Testbezeichnung").Value)
    Else
        Set RpItm = RpRec.AddItem(vbNullString)
    End If
    RpItm.Focusable = False
    
    For AkSpa = 1 To AnBer
        Set RpItm = RpRec.AddItem(vbNullString)
        RpItm.Focusable = False
    Next AkSpa
    
    If RS156.Fields("Ident").Value <> vbNullString Then
        Set RpItm = RpRec.AddItem(RS156.Fields("Ident").Value)
    Else
        Set RpItm = RpRec.AddItem(vbNullString)
    End If
    RpItm.Focusable = False
    If RS156.Fields("Einheit").Value <> vbNullString Then
        Set RpItm = RpRec.AddItem(RS156.Fields("Einheit").Value)
    Else
        Set RpItm = RpRec.AddItem(vbNullString)
    End If
    RpItm.Focusable = False
    If RS156.Fields("Gruppe").Value <> vbNullString Then
        Set RpItm = RpRec.AddItem(RS156.Fields("Gruppe").Value)
    Else
        Set RpItm = RpRec.AddItem(vbNullString)
    End If
    RpItm.Focusable = False
    
    RS156.MoveNext
    Loop Until RS156.EOF
        
    '------------------------------Werte------------------------------
    Do
    BerZa = RS157.Fields("ID0").Value
    If RS157.Fields("Testbezeichnung").Value <> vbNullString Then
        TmBez = RS157.Fields("Testbezeichnung").Value
    Else
        TmBez = "keine Parameterbezeichnung"
    End If
    If RS157.Fields("L-Eingang").Value <> vbNullString Then
        TmDat = Format$(RS157.Fields("L-Eingang").Value, "dd.mm.yyyy")
    Else
        If RS157.Fields("L-Ausgang").Value <> vbNullString Then
            TmDat = Format$(RS157.Fields("L-Ausgang").Value, "dd.mm.yyyy")
        End If
    End If
    If RS157.Fields("Ergebniswert").Value <> vbNullString Then
        TmErg = RS157.Fields("Ergebniswert").Value
    Else
        TmErg = "0"
    End If
    If RS157.Fields("Grenzwert").Value <> vbNullString Then
        TmErg = TmErg & " " & RS157.Fields("Grenzwert").Value
    End If

    For Each RpRec In RpRcs
        If RpRec.Item(0).Value = TmBez Then
            AkCol = 1
            For Each RpCol In RpCls
                If RpCol.Caption = TmDat Then
                    If RpCol.Tag = BerZa Then
                        RpRec.Item(RpCol.Index).Value = TmErg
                    End If
                End If
            Next RpCol
        End If
    Next RpRec
    
    RS157.MoveNext
    Loop Until RS157.EOF
    
    If GlGrI = True Then 'Gruppierung Laborbericht
        With RpCon
            .GroupsOrder.Add .Columns(AnBer + 3)
            .GroupsOrder(0).SortAscending = True
        End With
    End If
End If

DoEvents
RpCon.Populate

RS155.Close
RS156.Close
RS157.Close
Set RS155 = Nothing
Set RS156 = Nothing
Set RS157 = Nothing

Set RpCol = Nothing
Set RpCls = Nothing
Set RpCon = Nothing

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_LaVe " & Err.Number
Resume Next

End Sub
