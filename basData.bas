Dim KrLok As Boolean
Dim GlVor() As String
Dim FiNam() As String
Dim Frage As Integer
Dim Mld1, Mld2, Mld3, Tit1 As String
Dim CmBrs As XtremeCommandBars.CommandBars
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCoK As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set CmBrs = FM.comBar01
Set RpCo4 = FM.repCont4
Set RpCo6 = FM.repCont6
Set RpCoK = FM.repContK
Set RpCo3 = FM.repCont3
Set CmAcs = CmBrs.Actions

If GlAdr <= 0 Then
    Exit Sub
End If

Tit1 = "Einträge Entfernen"
Mld3 = "Dieser Eintrag kann nicht entfernt werden, weil der Rechnungsbetrag dann geringer als die Summe aller für diese Rechnung geleisteten Zahlungen ist"

If GlRch(0, 19) = 0 Then
    WindowMess "Sie besitzen keine Berechtigung für diesen Vorgang", Dial3, Tit1, FM.hwnd
    Exit Sub
End If

If RpCo3.Records.Count > 0 Then
    Set RpSel = RpCo3.SelectedRows
    Set RpRow = RpSel(0)
    Set RpCls = RpCo3.Columns
    Set RpCol = RpCls.Find(Rec_ID0)
    PatNr = RpRow.Record(RpCol.ItemIndex).Value
    Set RpCol = RpCls.Find(Rec_ID1)
    ReNum = RpRow.Record(RpCol.ItemIndex).Value
    Set RpCol = RpCls.Find(Rec_RechNr)
    ReStr = RpRow.Record(RpCol.ItemIndex).Value
    Set RpCol = RpCls.Find(Rec_IDKurz)
    PaStr = RpRow.Record(RpCol.ItemIndex).Value
    Set RpCol = RpCls.Find(Rec_Betrag)
    ReBet = Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1)
    Set RpCol = RpCls.Find(Rec_Rabatt)
    RabBe = Format$(RpRow.Record(RpCol.ItemIndex).Value, GlWa1)
    Set RpCol = RpCls.Find(Rec_Selekt)
    ReAbg = CBool(RpRow.Record(RpCol.ItemIndex).Value)
    Set RpCol = RpCls.Find(Rec_Bezahlt)
    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
        BezBe = RpRow.Record(RpCol.ItemIndex).Value
    Else
        BezBe = 0
    End If
End If

Select Case GlBut
Case RibTab_Krankenbla:
        Set RpSel = RpCoK.SelectedRows
        Set RpCls = RpCoK.Columns
Case RibTab_Abrechnung:
        Set RpSel = RpCo6.SelectedRows
        Set RpCls = RpCo6.Columns
End Select

If GlBut = RibTab_Abrechnung Then
    If ReAbg = True Then
        Tit1 = "Eintrag Entfernen"
        Mld1 = "Bei einer bereits abgeschlossenen Rechnung ist es nicht möglich, einzelne Einträge zu entfernen, ohne die Rechnung vorher wieder zu entriegeln."
        WindowMess Mld1, Dial3, Tit1, FM.hwnd
        Exit Sub
    End If
End If

If EiAus = True Then
    AnzRo = UBound(GlClp)
    ReNum = GlClR
    For AktPo = 1 To AnzRo
        If GlClp(AktPo, 2) <> 6 Then
            If GlBuL = True Then 'echtes Löschen erlauben
                DBCmEx1 "qrySimAbLo", "@IdxNr", GlClp(AktPo, 18)
            Else
                DBCmEx2 "qrySimAbSto", "@IdSto", "@IdxNr", True, GlClp(AktPo, 18)
            End If
        End If
    Next AktPo
    GlClR = 0
    Frage = 6
Else
    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        AnzPo = RpSel.Count
        KrRow = RpRow.Index - 1
        
        If AnzPo > 1 Then
            Mld1 = "Möchten Sie die " & AnzPo & " markierten Einträge wirklich entfernen?"
        Else
            Mld1 = "Möchten Sie den aktuellen Eintrag wirklich entfernen?"
        End If
    
        Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
        If Frage = 6 Then
    
            For Each RpRow In RpSel
                If RpRow.GroupRow = False Then
                    Set RpCol = RpCls.Find(Kra_ID2)
                    IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Kra_Typ)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        KrTyp = RpRow.Record(RpCol.ItemIndex).Value
                    End If
                    Set RpCol = RpCls.Find(Kra_WVBetrag)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        ZalBe = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        ZalBe = 0
                    End If
                    Set RpCol = RpCls.Find(Kra_GesBetrag)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        KraBe = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        KraBe = 0
                    End If
                    Set RpCol = RpCls.Find(Kra_Bezeichnung)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        KoStr = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        KoStr = vbNullString
                    End If
                    Set RpCol = RpCls.Find(Kra_Zusatztext)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        BuGui = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        BuGui = vbNullString
                    End If
                    If GlBut = RibTab_Krankenbla Then
                        Set RpCol = RpCls.Find(Kra_Lock)
                        If RpRow.Record(RpCol.ItemIndex).Checked = True Then
                            KrLok = True
                        Else
                            KrLok = False
                        End If
                    End If
                    
                    If KrLok = False Then
                        Select Case KrTyp
                        Case 2: 'Gebührenziffer
                            If (ReBet - KraBe) - BezBe < 0 Then
                                WindowMess Mld3, Dial2, Tit1, FM.hwnd
                                Exit Sub
                            End If
                        Case 3: 'Laborleistung
                            If (ReBet - KraBe) - BezBe < 0 Then
                                WindowMess Mld3, Dial2, Tit1, FM.hwnd
                                Exit Sub
                            End If
                        Case 4: 'Medikament
                            If (ReBet - KraBe) - BezBe < 0 Then
                                WindowMess Mld3, Dial2, Tit1, FM.hwnd
                                Exit Sub
                            End If
                        Case 7: 'Provisionseintrag
                            If (ReBet - KraBe) - BezBe < 0 Then
                                WindowMess Mld3, Dial2, Tit1, FM.hwnd
                                Exit Sub
                            End If
                        Case 8: 'IGeL Leistungen
                            If (ReBet - KraBe) - BezBe < 0 Then
                                WindowMess Mld3, Dial2, Tit1, FM.hwnd
                                Exit Sub
                            End If
                        Case 9: 'Umsatzsteuerleistung
                            If (ReBet - KraBe) - BezBe < 0 Then
                                WindowMess Mld3, Dial2, Tit1, FM.hwnd
                                Exit Sub
                            End If
                        Case 6: 'Anzahlungen
                            Set RS121 = New ADODB.Recordset
                            RS121.CursorLocation = adUseClient
                            Set RS121 = DBCmRe1("qrySimBuGui", "@IdStr", BuGui)
                            If RS121.RecordCount > 0 Then
                                GutBe = RS121.Fields("Einnahme").Value
                            Else
                                GutBe = ZalBe 'Falls bei manuellen Guthaben eine andere GuiID vorhanden ist
                            End If
                            RS121.Close
                            Set RS121 = Nothing
                            
                            If BezBe - ZalBe <= 0 Then 'Ändert den Bezahltbetrag in der Rechnung
                                DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", 0, ReNum
                            Else
                                DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", BezBe - ZalBe, ReNum
                            End If
                            
                            If BezBe - ZalBe <= 0 Then 'Ändert den Anzahlungsbetrag in der Rechnung
                                DBCmEx2 "qrySimReSm3", "@IdBet", "@IdxNr", 0, ReNum
                            Else
                                DBCmEx2 "qrySimReSm3", "@IdBet", "@IdxNr", BezBe - ZalBe, ReNum
                            End If
                            
                            DoEvents
                            If GlBuL = True Then 'Echtes Löschen erlauben
                                DBCmEx1 "qrySimBuLoG", "@IdStr", BuGui
                            Else
                                DBCmEx2 "qrySimBuStg", "@IdSto", "@IdStr", True, BuGui
                            End If
                            DoEvents
                            
                            If Left$(KoStr, 8) = "Guthaben" Then
                                TeTit = "Guthaben hinzufügen"
                                TeMai = "Soll dem Patienten der Zahlungsbetrag als Guthaben hinzugefügt werden?"
                                TeInh = "Es wurde eine Zahlung mit dem Betreff 'Guthaben verrechnet' in diese Rechnung eingefügt. Wenn diese Zahlung gelöscht wird, kann der Betrag von " & Format$(ZalBe, GlWa1) & " dem Patienten als Guthaben hinzugefügt werden."
                                TeFus = "Sollte die Zahlung versehentlich mit dem genannten Betreff eingefügt worden sein, darf der Zahlungsbetrag nicht als Guthaben hinzugefügt werden."
                                SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, False, FM.hwnd
                                If GlMes = 33565 Then
                                    S_PaGu PatNr, GutBe
                                End If
                            End If

                            DoEvents
                            BezBe = BezBe - ZalBe
                            BezBe = BezBe - ZalBe

                            GlNeK = GlKoX 'Protokolleintrag
                            With GlNeK
                                .PatNr = PatNr
                                .IdxNr = 0
                                .EiDat = Format$(Date, "dd.mm.yyyy")
                                .EiZei = TimeValue(Now)
                                .EiTyp = 104
                                .TeStr = "Akontozahlung gelöscht - " & ReStr & Chr$(32) & PaStr & " - (" & Format$(ZalBe, GlWa1) & ")"
                                .ZiStr = Format$(Now, "hh:mm") & " Uhr"
                                .NeuEi = True
                                .KeiAk = True
                                .Mitar = GlMiA(GlSmI, 2)
                            End With
                            S_Prot
                        Case 101: 'Rezepte
                            Tit1 = "Rezept Entfernen"
                            Mld2 = "Soll der zu diesem Eintrag gehörende Beleg in der Belegverwaltung ebenfalls gelöscht werden?"
                            Frage = WindowMess(Mld2, Dial1, Tit1, FM.hwnd)
                            If Frage = 6 Then
                                Set RpCol = RpCls.Find(Kra_IDR)
                                RzNum = RpRow.Record(RpCol.ItemIndex).Value
                                DBCmEx1 "qrySimRzLo", "@IdxNr", RzNum
                                DoEvents
                                GlNeK = GlKoX 'Protokolleintrag
                                With GlNeK
                                    .PatNr = PatNr
                                    .IdxNr = 0
                                    .EiDat = Format$(Date, "dd.mm.yyyy")
                                    .EiZei = TimeValue(Now)
                                    .EiTyp = 104
                                    .TeStr = "Rezept gelöscht - " & PaStr
                                    .ZiStr = Format$(Now, "hh:mm") & " Uhr"
                                    .NeuEi = True
                                    .KeiAk = True
                                    .Mitar = GlMiA(GlSmI, 2)
                                End With
                                S_Prot
                            End If
                        Case 102: 'Datei
                            If FiLoe = False Then FiLoe = True
                            AktZa = AktZa + 1
                            ReDim Preserve FiNam(AktZa)
                            Set RpCol = RpCls.Find(Kra_Typname)
                            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                                FilNa = RpRow.Record(RpCol.ItemIndex).Value
                            End If
                            FiNam(AktZa) = FilNa
                        Case 24: 'Textdokumente
                            If WoLoe = False Then WoLoe = True
                            AktZa = AktZa + 1
                            ReDim Preserve GlVor(AktZa)
                            Set RpCol = RpCls.Find(Kra_Typname)
                            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                                FilNa = RpRow.Record(RpCol.ItemIndex).Value
                            End If
                            GlVor(AktZa) = FilNa
                        Case 104: 'Protokolleintrag
                            If LoeRe = False Then
                                Tit1 = "Protokollvermerk Entfernen"
                                Mld2 = "Bei diesem Eintrag handelt es sich um einen Protokollvermerk, dieser kann nicht gelöscht werden."
                                WindowMess Mld2, Dial2, Tit1, FM.hwnd
                                Exit Sub
                            End If
                        Case 105: 'Bilddatei
                            If FiLoe = False Then FiLoe = True
                            AktZa = AktZa + 1
                            ReDim Preserve FiNam(AktZa)
                            Set RpCol = RpCls.Find(Kra_Typname)
                            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                                FilNa = RpRow.Record(RpCol.ItemIndex).Value
                            End If
                            FiNam(AktZa) = FilNa
                        End Select
                        DoEvents
                        If GlBuL = True Then 'echtes Löschen erlauben
                            DBCmEx1 "qrySimAbLo", "@IdxNr", IdxNr
                        Else
                            DBCmEx2 "qrySimAbSto", "@IdSto", "@IdxNr", True, IdxNr
                        End If
                    Else
                        Tit1 = "GoBD Verriegelung"
                        Mld2 = "Dieser Eintrag wurde bereits abgeschlossen!"
                        SPopu Tit1, Mld2, IC48_Information
                    End If
                End If
            Next RpRow
                        
            If WoLoe = True Then
                Set clFil = New clsFile
                With clFil
                    For AktZa = 1 To AnzPo
                        If AktZa <= UBound(GlVor) Then
                            DaNaO = Left$(GlVor(AktZa), Len(GlVor(AktZa)) - 3) & "bmp"
                            If .FilVor(GlDox & GlVor(AktZa)) = True Then
                                .DaLoe = GlDox & GlVor(AktZa) & vbNullChar
                                .FilLoe
                            End If
                            If .FilVor(GlDox & DaNaO) = True Then
                                .DaLoe = GlDox & DaNaO & vbNullChar
                                .FilLoe
                            End If
                        End If
                    Next AktZa
                End With
                Set clFil = Nothing
            End If
            
            If FiLoe = True Then
                Set clFil = New clsFile
                With clFil
                    For AktZa = 1 To AnzPo
                        If AktZa <= UBound(FiNam) Then
                            If .FilVor(GlDox & FiNam(AktZa)) = True Then
                                .DaLoe = GlDox & FiNam(AktZa) & vbNullChar
                                .FilLoe
                            ElseIf .FilVor(GlBPf & FiNam(AktZa)) = True Then
                                .DaLoe = GlBPf & FiNam(AktZa) & vbNullChar
                                .FilLoe
                            End If
                        End If
                    Next AktZa
                End With
                Set clFil = Nothing
            End If
        End If
    End If
End If

If Frage = 6 Then
    If EiAus = True Then
        NeReB = S_ReBet(ReNum, -10, ReAbg, 0)
    Else
        NeReB = S_ReBet(ReNum, Round(ReBet, 2), ReAbg, RabBe)
    End If
    DoEvents
    Select Case GlBut
    Case RibTab_Krankenbla:
                SUpKr KrRow
    Case RibTab_Tagesproto:
                SUpPr KrRow
    Case RibTab_Abrechnung:
                Set RpSel = RpCo3.SelectedRows
                If RpSel.Count > 0 Then
                    Set RpRow = RpSel(0)
                    RowNr = RpRow.Index
                    SUpAb RowNr, KrRow
                End If
                
                If GlVrz = False Then
                    Set RpSel = RpCo4.SelectedRows
                    If RpSel.Count > 0 Then
                        Set RpRow = RpSel(0)
                        RowNr = RpRow.Index
                        SUpRe RowNr
                    End If
                Else
                    GlVzA = True
                End If
    Case RibTab_Rechnungen:
                Set RpSel = RpCo4.SelectedRows
                If RpSel.Count > 0 Then
                    Set RpRow = RpSel(0)
                    RowNr = RpRow.Index
                    SUpRe RowNr
                End If
    End Select
    
    DoEvents
    
    Select Case GlBut
    Case RibTab_Krankenbla:
            If WoLoe = True Then SKrVo
            If FiLoe = True Then SKrVo
            If NeReB > GlObG Then SReMe
    Case RibTab_Abrechnung:
            If WoLoe = True Then SAbDa
            If FiLoe = True Then SAbDa
            If NeReB > GlObG Then SReMe
    End Select

    GlNeK = GlKoX 'Protokolleintrag
    With GlNeK
        .PatNr = GlMan(GlSMa, 2)
        .IdxNr = 0
        .EiDat = Format$(Date, "dd.mm.yyyy")
        .EiZei = TimeValue(Now)
        .EiTyp = 104
        .TeStr = "Krankenblatteintrag gelöscht - Typ: " & KrTyp & " - " & ReStr & Chr$(32) & PaStr
        .ZiStr = Format$(Now, "hh:mm") & " Uhr"
        .NeuEi = True
        .KeiAk = True
        .Mitar = GlMiA(GlSmI, 2)
    End With
    S_Prot
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing
Set RpCo4 = Nothing
Set RpCo6 = Nothing
Set RpCoK = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KrLo " & Err.Number
Resume Next

End Sub
Public Sub S_KrPa()
On Error GoTo LiErr
'Lädt die Adresen in den Dialog

Dim GesZa As Long
Dim AktZa As Long
Dim SQL1 As String
Dim TmpSt As String
Dim Posit As Integer
Dim CmPat As XtremeSuiteControls.ComboBox

Set FM = frmKraDa
Set CmPat = FM.cmbPatie

CmPat.Clear
DoEvents

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qrySimAdSu ORDER BY IDKurz"
Else
    SQL1 = "SELECT * FROM qrySimAdSu ORDER BY [IDKurz];"
End If
Set RS156 = New ADODB.Recordset
With RS156
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenForwardOnly
    .LockType = adLockReadOnly
    .Open Options:=adCmdText
End With

GesZa = RS156.RecordCount

If GesZa > 0 Then
    Do
    TmpSt = RS156.Fields("IDKurz").Value
    Posit = InStr(1, TmpSt, "(", 1)
    If Posit > 0 Then
        TmpSt = Left$(TmpSt, Posit - 1) & " [" & Format$(RS156.Fields("ID0").Value, "00000") & "]"
    Else
        TmpSt = TmpSt & " [" & Format$(RS156.Fields("ID0").Value, "00000") & "]"
    End If
    CmPat.AddItem TmpSt
    CmPat.ItemData(AktZa) = RS156.Fields("ID0").Value
    AktZa = AktZa + 1
    RS156.MoveNext
    Loop Until RS156.EOF
    CmPat.ListIndex = 0
End If

RS156.Close
Set RS156 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KrPa " & Err.Number
Resume Next

End Sub


