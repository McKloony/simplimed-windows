            .Fields("Feldkennung").Value = "3000"
            .Fields("Feldinhalt").Value = RS127.Fields("ID0").Value
            If RS127.Fields("Name").Value <> vbNullString Then
                .AddNew 'Name
                .Fields("Feldkennung").Value = "3101"
                .Fields("Feldinhalt").Value = SUmw(RS127.Fields("Name").Value, True, False, True)
            End If
            If RS127.Fields("Vorname").Value <> vbNullString Then
                .AddNew 'Vorname
                .Fields("Feldkennung").Value = "3102"
                .Fields("Feldinhalt").Value = SUmw(RS127.Fields("Vorname").Value, True, False, True)
            End If
            If RS127.Fields("Geboren").Value <> vbNullString Then
                .AddNew 'Geboren
                .Fields("Feldkennung").Value = "3103"
                .Fields("Feldinhalt").Value = Format$(RS127.Fields("Geboren").Value, "ddmmyyyy")
            End If
            If RS127.Fields("Titel").Value <> vbNullString Then
                .AddNew 'Titel
                .Fields("Feldkennung").Value = "3104"
                .Fields("Feldinhalt").Value = SUmw(RS127.Fields("Titel").Value)
            End If
            If RS127.Fields("Kartennummer").Value <> vbNullString Then
                .AddNew 'Versichertennummer
                .Fields("Feldkennung").Value = "3105"
                .Fields("Feldinhalt").Value = RS127.Fields("Kartennummer").Value
            End If
            If RS127.Fields("Abteilung").Value <> vbNullString Then
                .AddNew 'Versichertenart MFR
                .Fields("Feldkennung").Value = "3108"
                .Fields("Feldinhalt").Value = RS127.Fields("Abteilung").Value
            End If
            If RS127.Fields("PLZ").Value <> vbNullString Then
                .AddNew 'Ort
                .Fields("Feldkennung").Value = "3106"
                .Fields("Feldinhalt").Value = RS127.Fields("PLZ").Value & Chr$(32) & SUmw(RS127.Fields("Ort").Value)
            End If
            If RS127.Fields("Straße").Value <> vbNullString Then
                .AddNew 'Straße
                .Fields("Feldkennung").Value = "3107"
                .Fields("Feldinhalt").Value = SUmw(RS127.Fields("Straße").Value)
            End If
            If RS127.Fields("Geschlecht").Value <> vbNullString Then
                .AddNew 'Geschlecht
                .Fields("Feldkennung").Value = "3110"
                Gesch = LCase(RS127.Fields("Geschlecht").Value)
                Select Case Left$(Gesch, 1)
                Case "m": .Fields("Feldinhalt").Value = 1
                Case "w": .Fields("Feldinhalt").Value = 2
                Case "k": .Fields("Feldinhalt").Value = 3
                End Select
            End If
            If RS127.Fields("Größe").Value <> vbNullString Then
                .AddNew 'Größe
                .Fields("Feldkennung").Value = "3622"
                .Fields("Feldinhalt").Value = RS127.Fields("Größe").Value
            End If
            If RS127.Fields("Gewicht").Value <> vbNullString Then
                .AddNew 'Gewicht
                .Fields("Feldkennung").Value = "3623"
                .Fields("Feldinhalt").Value = RS127.Fields("Gewicht").Value
            End If
            If RS127.Fields("Telefon1").Value <> vbNullString Then
                .AddNew 'Telefon1
                .Fields("Feldkennung").Value = "3626"
                .Fields("Feldinhalt").Value = SUmw(RS127.Fields("Telefon1").Value)
            End If
            If RS127.Fields("Telefon5").Value <> vbNullString Then
                .AddNew 'Telefon5
                .Fields("Feldkennung").Value = "3619"
                .Fields("Feldinhalt").Value = RS127.Fields("Telefon5").Value
            End If
            If RS127.Fields("Beruf").Value <> vbNullString Then
                .AddNew 'Beruf
                .Fields("Feldkennung").Value = "3620"
                .Fields("Feldinhalt").Value = SUmw(RS127.Fields("Beruf").Value)
            End If
            If RS127.Fields("BGNummer").Value <> vbNullString Then
                .AddNew 'BGNummer
                .Fields("Feldkennung").Value = "3603"
                .Fields("Feldinhalt").Value = RS127.Fields("BGNummer").Value
            End If
            If RS127.Fields("Arbeitgeber").Value <> vbNullString Then
                .AddNew 'Arbeitgeber
                .Fields("Feldkennung").Value = "3625"
                .Fields("Feldinhalt").Value = SUmw(RS127.Fields("Arbeitgeber").Value)
            End If
            If RS127.Fields("Nationalität").Value <> vbNullString Then
                .AddNew 'Nationalität
                .Fields("Feldkennung").Value = "3627"
                .Fields("Feldinhalt").Value = SUmw(RS127.Fields("Nationalität").Value)
            End If
             If RS127.Fields("Muttersprache").Value <> vbNullString Then
                .AddNew 'Muttersprache
                .Fields("Feldkennung").Value = "3628"
                .Fields("Feldinhalt").Value = SUmw(RS127.Fields("Muttersprache").Value)
            End If
            If RS127.Fields("HausarztNr").Value <> vbNullString Then
                .AddNew 'HausarztNr
                .Fields("Feldkennung").Value = "3630"
                .Fields("Feldinhalt").Value = RS127.Fields("HausarztNr").Value
            End If
            If RS127.Fields("Risikofaktoren").Value <> vbNullString Then
                .AddNew 'Risikofaktoren
                .Fields("Feldkennung").Value = "3654"
                .Fields("Feldinhalt").Value = SUmw(RS127.Fields("Risikofaktoren").Value)
            End If
            If RS127.Fields("Allergien").Value <> vbNullString Then
                .AddNew 'Allergien
                .Fields("Feldkennung").Value = "3656"
                .Fields("Feldinhalt").Value = SUmw(RS127.Fields("Allergien").Value)
            End If
            If RS127.Fields("Unfälle").Value <> vbNullString Then
                .AddNew 'Unfälle
                .Fields("Feldkennung").Value = "3658"
                .Fields("Feldinhalt").Value = SUmw(RS127.Fields("Unfälle").Value)
            End If
            If RS127.Fields("Operationen").Value <> vbNullString Then
                .AddNew 'Operationen
                .Fields("Feldkennung").Value = "3660"
                .Fields("Feldinhalt").Value = SUmw(RS127.Fields("Operationen").Value)
            End If
            If RS127.Fields("Dauertherapie").Value <> vbNullString Then
                .AddNew 'Dauertherapie
                .Fields("Feldkennung").Value = "3670"
                .Fields("Feldinhalt").Value = SUmw(RS127.Fields("Dauertherapie").Value)
            End If
            If RS127.Fields("Diagnose").Value <> vbNullString Then
                .AddNew 'Diagnose
                .Fields("Feldkennung").Value = "6205"
                .Fields("Feldinhalt").Value = Left$(SUmw(RS127.Fields("Diagnose").Value), 60)
            End If
            If RS127.Fields("Bemerkung").Value <> vbNullString Then
                .AddNew 'Kommentar
                .Fields("Feldkennung").Value = "6227"
                .Fields("Feldinhalt").Value = Left$(SUmw(RS127.Fields("Bemerkung").Value), 60)
            End If
        End With
        
        If RS128.RecordCount > 0 Then
            RS128.MoveFirst
            Do
            Lange = 9 + Len(RS128.Fields("Feldinhalt").Value)
            If TmpSt = vbNullString Then
                TmpSt = Format$(Lange, "000") & RS128.Fields("Feldkennung").Value & RS128.Fields("Feldinhalt").Value & vbCrLf
            Else
                TmpSt = TmpSt & Format$(Lange, "000") & RS128.Fields("Feldkennung").Value & RS128.Fields("Feldinhalt").Value & vbCrLf
            End If
            RS128.MoveNext
            Loop Until RS128.EOF
            DoEvents
            StrLe = Format$(Len(TmpSt), "00000")
            TmpSt = Replace(TmpSt, "@@@@@", StrLe, 1)
            With clFil
                .StrDa = TmpSt
                RetWe = .FilWrSt
            End With
        End If
    End If
    RS127.Close
    RS128.Close
    Set RS127 = Nothing
    Set RS128 = Nothing
    
    If GlGDD = True Then 'GDT-Speicherung ohne Speichern-Dialog
        SPopu "GDT-Datei Exportiert", "Die GDT-Datei: " & DaNam & " wurde exportiert", IC48_Information
    End If

    Screen.MousePointer = vbNormal
End If

Set CoDia = Nothing

Set clFil = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_AdGDT " & Err.Number
Exit Sub

End Sub
