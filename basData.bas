Public Sub S_LaAu()
On Error GoTo SuErr
'Schlägt eine neue Auftragsnummer vor

Dim AkTau As Long
Dim AktJa As Long
Dim AuDat As Date
Dim SQL1 As String
Dim AkMon As String
Dim AkTag As String
Dim AkJah As String
Dim SuStr As String
Dim NeuAu As String

Dim TxAuf As XtremeSuiteControls.FlatEdit
Dim LiVie As XtremeSuiteControls.ListBox

Set FM = frmNeuAuf
Set TxAuf = FM.txtAuftr
Set TxDa1 = FM.txtDatu1
Set LiVie = FM.lstList1

If LiVie.SelCount > 0 Then
    If IsDate(TxDa1.Text) Then
        AuDat = TxDa1.Text
    Else
        AuDat = Date
    End If
    
    AktJa = Year(AuDat)
    AkJah = Right$(Year(AuDat), 2)
    AkJah = Right$(AkJah, 1)
    AkMon = Format$(Month(AuDat), "00")
    AkTag = Format$(Day(AuDat), "00")
    
    If GlTyp < 2 Then
        SQL1 = "SELECT * FROM dbo.qryLabAuSu WHERE IDA Like '" & AkJah & AkMon & AkTag & "%'"
    Else
        SQL1 = "SELECT * FROM qryLabAuSu WHERE [IDA] Like '" & AkJah & AkMon & AkTag & "%';"
    End If

    Set RS120 = New ADODB.Recordset
    With RS120
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdText
    End With
    If RS120.RecordCount > 0 Then
        AkTau = Right(RS120.Fields("IDA").Value, 3) + 1
    Else
        AkTau = 1
    End If
    RS120.Close
    Set RS120 = Nothing
    
    NeuAu = AkJah & AkMon & AkTag & Format$(AkTau, "000")
    
    TxAuf.Text = NeuAu
End If

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_LaAu " & Err.Number
Resume Next

End Sub
