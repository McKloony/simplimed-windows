                                                RS121.Fields("GuiID").Value = BaGui
                                                RS121.Fields("Kommentar").Value = BuKom
                                                RS121.Update
                                                DoEvents
                                                DBCmEx7 "qrySimBaKon", "@IdxWe", "@IdKon", "@KoStr", "@BuTex", "@IdStu", "@IdErm", "@IdxNr", 0, KtoNr, KtoBe, BuTex, KoStu, Ermit, BaIdx
                                            End If
                                            
                                            If ReNu5 > 0 Then
                                                BetBu = 0
                                                AnzSt = 0
                                                Warun = CInt(S_OPIdx(OpNu5, "Währung"))
                                                ReStu = CSng(S_OPIdx(OpNu5, "Steuer"))
                                                DoEvents
                                                BuBel = S_BuBel(ManNr, BuJah, GeKId)
                                                DoEvents
                                                
                                                BetNe = BetNe - OpBe4 'WICHTIG!
                                                If BetNe > OpBe5 Then
                                                    BetBu = OpBe5
                                                Else
                                                    If BetNe > 0 Then
                                                        BetBu = BetNe
                                                    End If
                                                End If

                                                If BetBu > 0 Then
                                                    BuTex = "Beleg: (" & ReSt5 & ")"
                                                    RS121.AddNew 'neue Buchung
                                                    RS121.Fields("IDP").Value = PatNr
                                                    RS121.Fields("IDB").Value = GeKId
                                                    If GlBuc = True Then 'einfache Buchhaltung verwenden
                                                        RS121.Fields("IDK").Value = KtoNr
                                                        RS121.Fields("IDG").Value = GeKNr
                                                        RS121.Fields("IDKurz").Value = KtoBe
                                                        RS121.Fields("IDGegen").Value = GeKBe
                                                    Else
                                                        RS121.Fields("IDK").Value = GeKNr
                                                        RS121.Fields("IDG").Value = KtoNr
                                                        RS121.Fields("IDKurz").Value = GeKBe
                                                        RS121.Fields("IDGegen").Value = KtoBe
                                                        RS121.Fields("Doppelt").Value = -1
                                                    End If
                                                    RS121.Fields("IDA").Value = BuTyp
                                                    RS121.Fields("IDR").Value = ReNu5
                                                    RS121.Fields("IDT").Value = ManNr
                                                    RS121.Fields("IDM").Value = MitNr
                                                    RS121.Fields("RechNr").Value = ReSt5
                                                    RS121.Fields("Steuer").Value = ReStu
                                                    RS121.Fields("Buchtext").Value = BuTex
                                                    RS121.Fields("Selekt").Value = True
                                                    RS121.Fields("Währung").Value = Warun
                                                    RS121.Fields("Beleg").Value = BuBel
                                                    RS121.Fields("Datum").Value = KoDat 'Kontoauszugsdatum
                                                    RS121.Fields("Einnahme").Value = BetBu
                                                    RS121.Fields("GuiID").Value = BaGui
                                                    RS121.Fields("Kommentar").Value = BuKom
                                                    RS121.Update
                                                    DoEvents
                                                    DBCmEx7 "qrySimBaKon", "@IdxWe", "@IdKon", "@KoStr", "@BuTex", "@IdStu", "@IdErm", "@IdxNr", 0, KtoNr, KtoBe, BuTex, KoStu, Ermit, BaIdx
                                                End If

                                            End If
                                        End If
                                    End If
                                End If
                            Else
                                SPopu "Kein gültiger offener Posten", "Dieser Buchung ist kein gültiger offener Posten zugeordnet!", IC48_Forbidden
                            End If
                        End If

                    End If

                    BetNe = BetUm
                    If OpNu1 > 0 Then
                        BetAn = CDbl(S_OPIdx(OpNu1, "Bezahlt"))
                        DoEvents
                        If BetNe >= OpBe1 Then
                            BetBu = OpBe1 + BetAn
                            BetDf = 0
                        Else
                            BetBu = BetNe + BetAn
                            If (OpBe1 - BetNe) < 0.02 Then 'Rundungsfehler ausgleichen
                                BetDf = 0
                            Else
                                BetDf = OpBe1 - BetNe
                            End If
                        End If
                        DBCmEx2 "qrySimOPAu1", "@PaSum", "@IdxNr", BetBu, OpNu1
                        DBCmEx2 "qrySimOPAu2", "@PaSum", "@IdxNr", BetDf, OpNu1
                        DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", BetBu, ReNu1
                        DBCmEx2 "qrySimOPAu4", "@IdDat", "@IdxNr", KoDat, OpNu1 'Kontoauszugsdatum
                        DBCmEx3 "qrySimBaBez", "@IdBez", "@IdSel", "@IdxNr", -1, -1, BaIdx
                        DBCmEx2 "qrySimOpBel", "@IdStr", "@IdxNr", "0", OpNu1
                        If BetDf <= 0 Then
                            DBCmEx2 "qrySimOPAu3", "@PaSel", "@IdxNr", -1, OpNu1
                            DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", -1, ReNu1 'Rechung Bezahlt Kennzeichnen
                        End If

                        If OpNu2 > 0 Then
                            BetAn = CDbl(S_OPIdx(OpNu2, "Bezahlt"))
                            DoEvents
                            BetNe = BetNe - OpBe1 'WICHTIG!
                            If BetNe >= OpBe2 Then
                                BetBu = OpBe2 + BetAn
                                BetDf = 0
                            Else
                                BetBu = BetNe + BetAn
                                If (OpBe2 - BetNe) < 0.02 Then 'Rundungsfehler ausgleichen
                                    BetDf = 0
                                Else
                                    BetDf = OpBe2 - BetNe
                                End If
                            End If
                            DBCmEx2 "qrySimOPAu1", "@PaSum", "@IdxNr", BetBu, OpNu2
                            DBCmEx2 "qrySimOPAu2", "@PaSum", "@IdxNr", BetDf, OpNu2
                            DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", BetBu, ReNu2
                            DBCmEx2 "qrySimOPAu4", "@IdDat", "@IdxNr", KoDat, OpNu2 'Kontoauszugsdatum
                            DBCmEx3 "qrySimBaBez", "@IdBez", "@IdSel", "@IdxNr", -1, -1, BaIdx
                            DBCmEx2 "qrySimOpBel", "@IdStr", "@IdxNr", "0", OpNu2
                            If BetDf <= 0 Then
                                DBCmEx2 "qrySimOPAu3", "@PaSel", "@IdxNr", -1, OpNu2
                                DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", -1, ReNu2 'Rechung Bezahlt Kennzeichnen
                            End If

                            If OpNu3 > 0 Then
                                BetAn = CDbl(S_OPIdx(OpNu3, "Bezahlt"))
                                DoEvents
                                BetNe = BetNe - OpBe2 'WICHTIG!
                                If BetNe >= OpBe3 Then
                                    BetBu = OpBe3 + BetAn
                                    BetDf = 0
                                Else
                                    BetBu = BetNe + BetAn
                                    If (OpBe3 - BetNe) < 0.02 Then 'Rundungsfehler ausgleichen
                                        BetDf = 0
                                    Else
                                        BetDf = OpBe3 - BetNe
                                    End If
                                End If
                                DBCmEx2 "qrySimOPAu1", "@PaSum", "@IdxNr", BetBu, OpNu3
                                DBCmEx2 "qrySimOPAu2", "@PaSum", "@IdxNr", BetDf, OpNu3
                                DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", BetBu, ReNu3
                                DBCmEx2 "qrySimOPAu4", "@IdDat", "@IdxNr", KoDat, OpNu3 'Kontoauszugsdatum
                                DBCmEx3 "qrySimBaBez", "@IdBez", "@IdSel", "@IdxNr", -1, -1, BaIdx
                                DBCmEx2 "qrySimOpBel", "@IdStr", "@IdxNr", "0", OpNu3
                                If BetDf <= 0 Then
                                    DBCmEx2 "qrySimOPAu3", "@PaSel", "@IdxNr", -1, OpNu3
                                    DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", -1, ReNu3
                                End If
                                
                                If OpNu4 > 0 Then
                                    BetAn = CDbl(S_OPIdx(OpNu4, "Bezahlt"))
                                    DoEvents
                                    BetNe = BetNe - OpBe3 'WICHTIG!
                                    If BetNe >= OpBe4 Then
                                        BetBu = OpBe4 + BetAn
                                        BetDf = 0
                                    Else
                                        BetBu = BetNe + BetAn
                                        If (OpBe4 - BetNe) < 0.02 Then 'Rundungsfehler ausgleichen
                                            BetDf = 0
                                        Else
                                            BetDf = OpBe4 - BetNe
                                        End If
                                    End If
                                    DBCmEx2 "qrySimOPAu1", "@PaSum", "@IdxNr", BetBu, OpNu4
                                    DBCmEx2 "qrySimOPAu2", "@PaSum", "@IdxNr", BetDf, OpNu4
                                    DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", BetBu, ReNu4
                                    DBCmEx2 "qrySimOPAu4", "@IdDat", "@IdxNr", KoDat, OpNu4 'Kontoauszugsdatum
                                    DBCmEx3 "qrySimBaBez", "@IdBez", "@IdSel", "@IdxNr", -1, -1, BaIdx
                                    DBCmEx2 "qrySimOpBel", "@IdStr", "@IdxNr", "0", OpNu4
                                    If BetDf <= 0 Then
                                        DBCmEx2 "qrySimOPAu3", "@PaSel", "@IdxNr", -1, OpNu4
                                        DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", -1, ReNu4
                                    End If

                                    If OpNu5 > 0 Then
                                        BetAn = CDbl(S_OPIdx(OpNu5, "Bezahlt"))
                                        DoEvents
                                        BetNe = BetNe - OpBe4 'WICHTIG!
                                        If BetNe >= OpBe5 Then
                                            BetBu = OpBe5 + BetAn
                                            BetDf = 0
                                        Else
                                            BetBu = BetNe + BetAn
                                            If (OpBe5 - BetNe) < 0.02 Then 'Rundungsfehler ausgleichen
                                                BetDf = 0
                                            Else
                                                BetDf = OpBe5 - BetNe
                                            End If
                                        End If
                                        DBCmEx2 "qrySimOPAu1", "@PaSum", "@IdxNr", BetBu, OpNu5
                                        DBCmEx2 "qrySimOPAu2", "@PaSum", "@IdxNr", BetDf, OpNu5
                                        DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", BetBu, ReNu5
                                        DBCmEx2 "qrySimOPAu4", "@IdDat", "@IdxNr", KoDat, OpNu5 'Kontoauszugsdatum
                                        DBCmEx3 "qrySimBaBez", "@IdBez", "@IdSel", "@IdxNr", -1, -1, BaIdx
                                        DBCmEx2 "qrySimOpBel", "@IdStr", "@IdxNr", "0", OpNu5
                                        If BetDf <= 0 Then
                                            DBCmEx2 "qrySimOPAu3", "@PaSel", "@IdxNr", -1, OpNu5
                                            DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", -1, ReNu5
                                        End If
                            
                                    End If
                                End If
                            End If
                        End If
                    End If

                    GlNeK = GlKoX 'Protokolleintrag
                    With GlNeK
                        .PatNr = ManNr
                        .IdxNr = 0
                        .EiDat = Format$(Date, "dd.mm.yyyy")
                        .EiZei = TimeValue(Now)
                        .EiTyp = 104
                        .ZiStr = Format$(Now, "hh:mm") & " Uhr"
                        .NeuEi = True
                        .KeiAk = True
                        .Mitar = GlMiA(GlSmI, 2)
                        .TeStr = "Offener Posten ausgeglichen - " & ReSt1 & " - " & PaNam
                    End With
                    S_Prot

                    If BetUm > (OpBe1 + OpBe2 + OpBe3 + OpBe4 + OpBe5) Then
                        Tit1 = "Posten ausgleichen"
                        Mld1 = "Der vom Patienten beglichene Betrag ist größer als der noch zu zahlende Betrag. Möchte Sie dem Patienten den überschüssigen Betrag gutschreiben?"
                        Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
                        If Frage = 6 Then
                            S_PaGu PatNr, BetUm - (OpBe1 + OpBe2 + OpBe3 + OpBe4 + OpBe5)
                        End If
                    End If
                End If
            End If
            
        End If
    Next RpRow

    RS121.Close
    Set RS121 = Nothing

    DoEvents
    Select Case RbTab.id
    Case RibTab_Kat_EinBan: P_List "BaPo", 0, 1
    Case RibTab_Kat_KetBan: P_List "BaPo", 0, 2, False, CmSu1.Text
    End Select
    
    DoEvents
    Screen.MousePointer = vbNormal

    If GlJet = True Then SDBSav
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing

Exit Sub

KoErr:
If GlDbg = True Then SErLog Err.Description & " S_KoAu " & Err.Number
Resume Next

End Sub

Public Sub S_KoBu()
On Error GoTo LiErr
'Generiert Pre-Buchungen

Dim IdxNr As Long
Dim BuDat As Date
Dim KtIdS As Long
Dim KtNrH As Long
Dim BaIdx As Long
Dim GeKto As Long
Dim ManNr As Long
Dim MitNr As Long
Dim RowNr As Long
Dim BuJah As Long
Dim BuBel As Long
Dim BuAus As String
Dim KtBeS As String
Dim KtBeH As String
Dim KtStS As String
Dim KtStH As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim BuStr As String
Dim TmStr As String
Dim BaGui As String
Dim KoStu As Single
Dim BuBet As Double
Dim AnzKo As Integer
Dim AnzVo As Integer
Dim AktKo As Integer
Dim AktZa As Integer
Dim BuAbg As Boolean
Dim Ermit As Boolean
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpSel As XtremeReportControl.ReportSelectedRows
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows

AnzKo = RpSel.Count

If AnzKo > 1 Then
    TeTit = "Pre-Buchungen ableiten"
    TeMai = "Sollen jetzt vorläufige Buchungen abgeleitet werden?"
    TeInh = "Sollen für die " & AnzKo & " markierten Kontoauszugseinträge " & AnzKo & " vorläufige Buchungen generiert werden?"
    TeFus = "Das automatisch Ableiten der markierten Kontoauszugseinträge, erzeugt dieselbe Anzahl Buchungen mit demselben Buchungssaldo zum Beispiel für einen bestimmten Zeitraum. Für die so erstellten vorläufigen Buchungen muss dann später nur noch das entsprechende Sachkonto angepasst werden."

    SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, False, FM.hwnd
    If GlMes = 33565 Then

        Set RS121 = New ADODB.Recordset
        With RS121 'neue Buchung
            .CursorLocation = adUseClient
            .Source = "qrySimBuNe"
            .ActiveConnection = DB1
            .CursorType = adOpenStatic
            .LockType = adLockOptimistic
            .Open Options:=adCmdTableDirect
        End With
        
        Set RpRow = RpSel(0)
        If RpRow.GroupRow = False Then
            Set RpRow = RpSel(0)
            RowNr = RpRow.Index
        End If

        Screen.MousePointer = vbHourglass

        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                BaIdx = 0

                Set RpCol = RpCls.Find(Ban_Bezahlt)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    If LCase(RpRow.Record(RpCol.ItemIndex).Value) = "ja" Then
                        BuAbg = True
                    Else
                        BuAbg = False
                    End If
                End If

                If BuAbg = False Then
                    Set RpCol = RpCls.Find(Ban_ID2)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                            BaIdx = RpRow.Record(RpCol.ItemIndex).Value
                        End If
                    End If
                    Set RpCol = RpCls.Find(Ban_IDB)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        KtIdS = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        KtIdS = 0
                    End If
                    Set RpCol = RpCls.Find(Ban_Steuer)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        KoStu = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        KoStu = 0
                    End If
                    Set RpCol = RpCls.Find(Ban_Ermittlung)
                    If LCase(RpRow.Record(RpCol.ItemIndex).Value) = "ja" Then
                        Ermit = True
                    End If
                    Set RpCol = RpCls.Find(Ban_GuiID)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                            BaGui = RpRow.Record(RpCol.ItemIndex).Value
                        Else
                            BaGui = CreateID("B")
                            DBCmEx2 "qrySimBaGui", "@IdStr", "@IdxNr", BaGui, BaIdx
                        End If
                    Else
                        BaGui = CreateID("B")
                        DBCmEx2 "qrySimBaGui", "@IdStr", "@IdxNr", BaGui, BaIdx
                    End If
                    Set RpCol = RpCls.Find(Ban_IDKurz)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        BuStr = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        BuStr = vbNullString
                    End If
                    Set RpCol = RpCls.Find(Ban_Datum)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        BuDat = CDate(RpRow.Record(RpCol.ItemIndex).Value)
                    Else
                        BuDat = Format$(Date, "dd.mm.yyyy")
                    End If
                    Set RpCol = RpCls.Find(Ban_Ausgabe)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        BuAus = LCase(RpRow.Record(RpCol.ItemIndex).Value)
                    Else
                        BuAus = "ja"
                    End If
                    Set RpCol = RpCls.Find(Ban_KoBetrag)
                    If IsNumeric(RpRow.Record(RpCol.ItemIndex).Value) = True Then
                        BuBet = Round(RpRow.Record(RpCol.ItemIndex).Value, 2)
                        If BuAus = "ja" Then
                            BuBet = Round(Mid$(BuBet, 2, Len(BuBet) - 1), 2)
                        End If
                    Else
                        BuBet = Format$(0, GlWa1)
                    End If
                    Set RpCol = RpCls.Find(Ban_IDP)
                    If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                        ManNr = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        ManNr = GlMan(GlSMa, 2)
                    End If
                    Set RpCol = RpCls.Find(Ban_IDM)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                            MitNr = RpRow.Record(RpCol.ItemIndex).Value
                        Else
                            MitNr = GlMiA(GlSmI, 2)
                        End If
                    Else
                        MitNr = GlMiA(GlSmI, 2)
                    End If

                    If GlMVo = True Then 'mandantenbezogene Vorgaben verwenden
                        For AktZa = 1 To UBound(GlMan)
                            If ManNr = GlMan(AktZa, 2) Then 'Mandantennummer
                                If GlMan(AktZa, 28) <> vbNullString Then KtIdS = GlMan(AktZa, 28) 'Standardgeldkonto Bankkonto
                                If GlMan(AktZa, 26) <> vbNullString Then KtNrH = SBuFo(9999)
                                Exit For
                            End If
                            
                        Next AktZa
                    Else
                        KtIdS = GlGkB 'Standardgeldkonto Bankkonto
                        KtNrH = SBuFo(9999)
                    End If

                    If GlBuc = True Then 'einfache Buchhaltung verwenden
                        For AktZa = 1 To UBound(GlGeK) 'Geldkonten
                            If GlGeK(AktZa, 0) = KtIdS Then
                                KtBeS = GlGeK(AktZa, 1)
                                KtStS = GlGeK(AktZa, 2)
                                Exit For
                            End If
                        Next AktZa
                    Else
                        For AktZa = 1 To UBound(GlGeK) 'Geldkonten
                            If GlGeK(AktZa, 0) = KtIdS Then
                                For AktKo = 1 To UBound(GlSaK) 'Sachkonten mit Geldkontenzuordnung
                                    If GlGeK(AktZa, 6) = GlSaK(AktKo, 5) Then
                                        KtBeS = GlSaK(AktKo, 1)
                                        KtStS = GlSaK(AktKo, 2)
                                        Exit For
                                    End If
                                Next AktKo
                            End If
                        Next AktZa
                    End If

                    KtBeH = "vorläufige Buchung"
                    BuJah = Year(BuDat)
                    BuBel = S_BuBel(ManNr, BuJah, KtIdS)
                    DoEvents
                    If Len(BuStr) > 200 Then
                        BuStr = Left$(BuStr, 200)
                    End If

                    RS121.AddNew 'neue Buchung
                    RS121.Fields("IDP").Value = 0
                    RS121.Fields("IDB").Value = KtIdS
                    If GlBuc = True Then 'einfache Buchhaltung verwenden
                        RS121.Fields("IDK").Value = KtNrH
                        RS121.Fields("IDG").Value = 0
                        RS121.Fields("IDKurz").Value = KtBeH
                        If BuAus = "ja" Then
                            RS121.Fields("Ausgabe").Value = BuBet
                        Else
                            RS121.Fields("Einnahme").Value = BuBet
                        End If
                    Else
                        If BuAus = "ja" Then
                            RS121.Fields("IDK").Value = KtStH
                            RS121.Fields("IDG").Value = KtStS
                            RS121.Fields("IDKurz").Value = KtBeH
                            RS121.Fields("IDGegen").Value = KtBeS
                        Else
                            RS121.Fields("IDK").Value = KtStS
                            RS121.Fields("IDG").Value = KtNrH
                            RS121.Fields("IDKurz").Value = KtBeS
                            RS121.Fields("IDGegen").Value = KtBeH
                        End If
                        RS121.Fields("Einnahme").Value = 0
                        RS121.Fields("Einnahme").Value = BuBet
                        RS121.Fields("Doppelt").Value = -1
                    End If
                    If BuAus = "ja" Then
                        RS121.Fields("IDA").Value = 1
                    Else
                        RS121.Fields("IDA").Value = 2
                    End If
                    RS121.Fields("IDT").Value = ManNr
                    RS121.Fields("IDM").Value = MitNr
                    RS121.Fields("Steuer").Value = 0
                    RS121.Fields("Buchtext").Value = BuStr
                    RS121.Fields("Selekt").Value = True
                    RS121.Fields("Währung").Value = GlWar(GlStW, 0)
                    RS121.Fields("Beleg").Value = BuBel
                    RS121.Fields("Datum").Value = BuDat
                    RS121.Fields("GuiID").Value = BaGui
                    RS121.Update
                    DoEvents
                    DBCmEx3 "qrySimBaBez", "@IdBez", "@IdSel", "@IdxNr", -1, -1, BaIdx
                    DoEvents
                    DBCmEx7 "qrySimBaKon", "@IdxWe", "@IdKon", "@KoStr", "@BuTex", "@IdStu", "@IdErm", "@IdxNr", 0, KtIdS, KtBeS, BuStr, KoStu, Ermit, BaIdx
                    DoEvents
                End If
            End If
        Next RpRow
        
        RS121.Close
        Set RS121 = Nothing

        Screen.MousePointer = vbNormal

        SUpBa RowNr
    End If
Else
    SPopu "Zu wenig Einträge markiert", "Es wurde nur ein Kontoauszugseintrag markiert", IC48_Warning
End If

Set RpSel = Nothing
Set RpCo1 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KoBu " & Err.Number
Resume Next

End Sub
Public Sub S_KoDe(ByVal IdxNr As Long)
On Error GoTo KoErr
'Liefert Detailinformationen für ein Sachkonto

Set RS132 = New ADODB.Recordset
RS132.CursorLocation = adUseClient
Set RS132 = DBCmRe1("qrySimBuKtI", "@IdxNr", IdxNr)
If RS132.RecordCount > 0 Then
    GlKto = GlKTx
    With GlKto
        If RS132.Fields("IDK").Value <> vbNullString Then
            .KtoNr = SBuFo(RS132.Fields("IDK").Value)
        Else
            .KtoNr = SBuFo(0)
        End If
        If RS132.Fields("IDKurz").Value <> vbNullString Then
            .KtBez = RS132.Fields("IDKurz").Value
        Else
            .KtBez = vbNullString
        End If
        If RS132.Fields("Buchtext").Value <> vbNullString Then
            .BuTex = RS132.Fields("Buchtext").Value
        Else
            .BuTex = vbNullString
        End If
        If RS132.Fields("IDA").Value <> vbNullString Then
            .KtTyp = RS132.Fields("IDA").Value
        Else
            .KtTyp = 2
        End If
        If RS132.Fields("IDB").Value <> vbNullString Then
            .KtBnk = RS132.Fields("IDB").Value
        Else
            .KtBnk = 1
        End If
        If RS132.Fields("Geldkonto").Value <> vbNullString Then
            .GldKt = CBool(RS132.Fields("Geldkonto").Value)
        Else
            .GldKt = False
        End If
        If RS132.Fields("Steuerkonto").Value <> vbNullString Then
            .StKto = CBool(RS132.Fields("Steuerkonto").Value)
        Else
            .StKto = False
        End If
        If RS132.Fields("Steuer").Value <> vbNullString Then
            .Steue = Round(RS132.Fields("Steuer").Value, 2)
        Else
            .Steue = 0
        End If
        If RS132.Fields("Privat").Value <> vbNullString Then
            .Priva = CBool(RS132.Fields("Privat").Value)
        Else
            .Priva = False
        End If
    End With
End If
RS132.Close
Set RS132 = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KoDe " & Err.Number
Resume Next

End Sub

