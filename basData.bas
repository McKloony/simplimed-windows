Public Sub S_BuBer()
On Error GoTo SuErr
'Markierte Buchungen bereinigen

Dim RowNr As Long
Dim IdxNr As Long
Dim BlNum As Long
Dim AnzPo As Integer
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows

AnzPo = RpSel.Count

If AnzPo > 1 Then
    Mld1 = "Möchten Sie die " & AnzPo & " markierten Buchungen jetzt DSGVO konform bereinigen??"
Else
    Mld1 = "Möchten Sie die markierte Buchung jetzt DSGVO konform bereinigen?"
End If
Tit1 = "Buchung bereinigen"

If AnzPo > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then
        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                Set RpCol = RpCls.Find(Buh_ID0)
                IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Buh_Beleg)
                BlNum = CLng(RpRow.Record(RpCol.ItemIndex).Value)
                DBCmEx1 "qrySimBuBt2", "@IdxNr", IdxNr
                DoEvents
                GlNeK = GlKoX 'Protokolleintrag
                With GlNeK
                    .PatNr = GlMan(GlSMa, 2)
                    .IdxNr = 0
                    .EiDat = Format$(Date, "dd.mm.yyyy")
                    .EiZei = TimeValue(Now)
                    .EiTyp = 104
                    .TeStr = "Buchung bereinigt Beleg: " & Format$(BlNum, "000000")
                    .ZiStr = Format$(Now, "hh:mm") & " Uhr"
                    .NeuEi = True
                    .KeiAk = True
                    .Mitar = GlMiA(GlSmI, 2)
                End With
                S_Prot
            End If
        Next RpRow

        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            RowNr = RpRow.Index
            SUpBu RowNr
        End If
    End If
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BuBer " & Err.Number
Resume Next

End Sub
Public Sub S_BuIm()
On Error GoTo SuErr
'Importriert die markierten Buchungen

Dim RowNr As Long
Dim AnzBu As Long
Dim KtoNr As Long
Dim KtoSt As String
Dim FiNam As String
Dim DaExt As String
Dim DaNam As String
Dim DaPfa As String
Dim TmGui As String
Dim TmpSt As String
Dim AktZe As Integer
Dim AktFe As Integer
Dim Lange As Integer
Dim AryZe() As String
Dim AryDe() As String
Dim AryFe() As String
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set CoDia = FM.comDialo
Set RpCo1 = FM.repCont1
Set RpSel = RpCo1.SelectedRows

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

With CoDia
    .CancelError = True
    .DialogStyle = 1
    .DefaultExt = "*.csv"
    .Filter = "CSV-Dateien (*.csv)|*.csv|XML-Dateien (*.xml)|*.xml|Alle Dateien (*.*)|*.*"
    .DialogTitle = "Wo befindet sich die Importdatei?"
    .InitDir = GlIPf
    .FileName = vbNullString
    .ShowOpen
    FiNam = .FileName
    If .FileTitle = vbNullString Then
        Set CoDia = Nothing
        Set RpCol = Nothing
        Set RpCo1 = Nothing
        Set clFil = Nothing
        Exit Sub
    End If
End With

With clFil
    .FilPfa FiNam
    DaNam = .DaNam
    DaExt = .DaExt
    DaPfa = .DaPfa
End With

If Not IsNull(FiNam) And Not FiNam = vbNullString Then
    Select Case LCase(DaExt)
    Case "csv":
        Set RS136 = New ADODB.Recordset 'Buchungen
        With RS136
            .CursorLocation = adUseClient
            .Source = "qrySimBuNe"
            .ActiveConnection = DB1
            .CursorType = adOpenForwardOnly
            .LockType = adLockReadOnly
            .Open Options:=adCmdTableDirect
        End With
                
        Set RS137 = New ADODB.Recordset 'neues Recordset erstellen Buchungen
        RS137.CursorLocation = adUseClient
        For Each FL101 In RS136.Fields
            RS137.Fields.Append FL101.Name, FL101.Type, FL101.DefinedSize
        Next FL101
        If RS137.State = adStateClosed Then RS137.Open
        
        RS136.Close
        Set RS136 = Nothing
        
        With clFil
            .FilPfa FiNam
            TmpSt = .FilReSt
        End With

        If Len(TmpSt) > 3 Then
            AryZe = Split(TmpSt, vbCrLf) 'Zeilen aufsplitten
            AryDe = Split(AryZe(0), ";") 'Feldnamen aufsplitten

            For AktZe = 1 To UBound(AryZe) - 1
                If AryZe(AktZe) <> vbNullString Then
                    AryFe = Split(AryZe(AktZe), ";") 'Felder aufsplitten
                    RS137.AddNew
                    For AktFe = 0 To UBound(AryDe) - 1
                        For Each FL101 In RS137.Fields
                            AryDe(AktFe) = Replace(AryDe(AktFe), Chr$(34), vbNullString, 1)
                            If FL101.Name = AryDe(AktFe) Then

                                If UBound(AryFe) >= AktFe Then
                                    If AryFe(AktFe) <> vbNullString Then
                                        If AryFe(AktFe) <> Space$(1) Then
                                            AryFe(AktFe) = Replace(AryFe(AktFe), Chr$(34), vbNullString, 1)
    
                                            Select Case FL101.Name
                                            Case "ID2":
                                            Case "IDK":
                                                If AryFe(AktFe) <> vbNullString Then
                                                    If IsNumeric(AryFe(AktFe)) = True Then
                                                        KtoNr = CLng(AryFe(AktFe))
                                                        KtoSt = SBuFo(KtoNr) 'Sachkontenformatierung
                                                        RS137.Fields(FL101.Name).Value = KtoSt
                                                    Else
                                                        RS137.Fields(FL101.Name).Value = 0
                                                    End If
                                                Else
                                                    RS137.Fields(FL101.Name).Value = 0
                                                End If
                                            Case "Berichtdatum":
                                                If IsDate(Left$(AryFe(AktFe), 10)) = True Then
                                                    RS137.Fields(FL101.Name).Value = CDate(Left$(AryFe(AktFe), 10))
                                                End If
                                            Case "LastModification":
                                                If IsDate(Left$(AryFe(AktFe), 10)) = True Then
                                                    RS137.Fields(FL101.Name).Value = CDate(Left$(AryFe(AktFe), 10))
                                                End If
                                            Case Else:
                                                Select Case FL101.Type
                                                Case adBigInt:
                                                    If AryFe(AktFe) <> vbNullString Then
                                                        If IsNumeric(AryFe(AktFe)) = True Then
                                                            RS137.Fields(FL101.Name).Value = CLng(AryFe(AktFe))
                                                        Else
                                                            RS137.Fields(FL101.Name).Value = 0
                                                        End If
                                                    Else
                                                        RS137.Fields(FL101.Name).Value = 0
                                                    End If
                                                Case adBoolean:
                                                    If AryFe(AktFe) <> vbNullString Then
                                                        RS137.Fields(FL101.Name).Value = CBool(AryFe(AktFe))
                                                    Else
                                                        RS137.Fields(FL101.Name).Value = 0
                                                    End If
                                                Case adChar: RS137.Fields(FL101.Name).Value = CStr(AryFe(AktFe))
                                                Case adVarChar: RS137.Fields(FL101.Name).Value = CStr(AryFe(AktFe))
                                                Case adCurrency: RS137.Fields(FL101.Name).Value = CSng(AryFe(AktFe))
                                                Case adDate:
                                                    If IsDate(AryFe(AktFe)) = True Then
                                                        RS137.Fields(FL101.Name).Value = CDate(AryFe(AktFe))
                                                    Else
                                                        RS137.Fields(FL101.Name).Value = Date
                                                    End If
                                                Case adDecimal:
                                                    If AryFe(AktFe) <> vbNullString Then
                                                        RS137.Fields(FL101.Name).Value = CSng(AryFe(AktFe))
                                                    Else
                                                        RS137.Fields(FL101.Name).Value = 0
                                                    End If
                                                Case adDouble:
                                                    If AryFe(AktFe) <> vbNullString Then
                                                        RS137.Fields(FL101.Name).Value = CDbl(AryFe(AktFe))
                                                    Else
                                                        RS137.Fields(FL101.Name).Value = 0
                                                    End If
                                                Case adInteger:
                                                    If AryFe(AktFe) <> vbNullString Then
                                                        If IsNumeric(AryFe(AktFe)) = True Then
                                                            RS137.Fields(FL101.Name).Value = CLng(AryFe(AktFe))
                                                        Else
                                                            RS137.Fields(FL101.Name).Value = 0
                                                        End If
                                                    Else
                                                        RS137.Fields(FL101.Name).Value = 0
                                                    End If
                                                Case adSingle:
                                                    If AryFe(AktFe) <> vbNullString Then
                                                        RS137.Fields(FL101.Name).Value = CSng(Replace(AryFe(AktFe), Chr$(32), Chr$(44), 1, 1))
                                                    Else
                                                        RS137.Fields(FL101.Name).Value = 0
                                                    End If
                                                Case adSmallInt:
                                                    If AryFe(AktFe) <> vbNullString Then
                                                        If IsNumeric(AryFe(AktFe)) = True Then
                                                            RS137.Fields(FL101.Name).Value = CInt(AryFe(AktFe))
                                                        Else
                                                            RS137.Fields(FL101.Name).Value = 0
                                                        End If
                                                    Else
                                                        RS137.Fields(FL101.Name).Value = 0
                                                    End If
                                                Case Else:
                                                    RS137.Fields(FL101.Name).Value = AryFe(AktFe)
                                                End Select
                                            End Select
        
                                        End If
                                    End If
                                End If
                            End If
                        Next FL101
                    Next AktFe
                    RS137.Update
                End If
                DoEvents
            Next AktZe
            AnzBu = RS137.RecordCount
            RS137.MoveFirst
        End If
    
        Set RS136 = New ADODB.Recordset 'Buchungen
        With RS136
            .CursorLocation = adUseClient
            .Source = "qrySimBuNe"
            .ActiveConnection = DB1
            .CursorType = adOpenDynamic
            .LockType = adLockOptimistic
            .Open Options:=adCmdTableDirect
        End With

        If AnzBu > 0 Then 'Buchungen
            Do
            RS136.AddNew
            For Each FL101 In RS137.Fields
                If RS137.Fields(FL101.Name).Value <> vbNullString Then
                    Select Case FL101.Name
                    Case "ID0":
                    Case "IDT": RS136.Fields(FL101.Name).Value = GlMan(GlSMa, 2)
                    Case "IDM": RS136.Fields(FL101.Name).Value = GlMiA(GlSmI, 2)
                    Case "Datum": If IsDate(Left$(RS137.Fields(FL101.Name).Value, 10)) = True Then RS136.Fields(FL101.Name).Value = CDate(Left$(RS137.Fields(FL101.Name).Value, 10))
                    Case Else: RS136.Fields(FL101.Name).Value = RS137.Fields(FL101.Name).Value
                    End Select
                End If
            Next FL101
            RS136.Update
            DoEvents
            RS137.MoveNext
            Loop Until RS137.EOF
            
            RS137.Close
            Set RS137 = Nothing
        End If
    
        RS136.Close
        Set RS136 = Nothing
    Case "xml":
        Set RS121 = New ADODB.Recordset 'Patienten
        With RS121
            .CursorLocation = adUseClient
            .Source = "qrySimBuNe"
            .ActiveConnection = DB1
            .CursorType = adOpenKeyset
            .LockType = adLockOptimistic
            .Open Options:=adCmdTableDirect
        End With

        Set RS125 = New ADODB.Recordset 'Buchungen
        RS125.CursorLocation = adUseClient
        RS125.Open FiNam, "Provider=MSPersist", , , Options:=adCmdFile
        If RS125.RecordCount > 0 Then
            Do
            TmGui = CreateID("K")
            RS121.AddNew
            For Each FL101 In RS125.Fields
                If RS125.Fields(FL101.Name).Value <> vbNullString Then
                    Select Case FL101.Name
                    Case "ID0":
                    Case "W":
                    Case "Buchungsart":
                    Case "Gegenkonto":
                    Case "IDArt":
                    Case "IDBank":
                    Case "Monat":
                    Case "upsize_ts":
                    Case "GuiID": RS121.Fields("GuiID").Value = TmGui
                    Case "RechNr": RS121.Fields("RechNr").Value = Trim$(RS125.Fields("RechNr").Value)
                    Case "Buchtext": RS121.Fields("Buchtext").Value = Trim$(RS125.Fields("Buchtext").Value)
                    Case "Kontenbezeichnung": RS121.Fields("IDKurz").Value = Trim$(RS125.Fields("Kontenbezeichnung").Value)
                    Case "Konto": RS121.Fields("IDK").Value = RS125.Fields("Konto").Value
                    Case "Gegenkonto": RS121.Fields("IDB").Value = RS125.Fields("Gegenkonto").Value
                    Case "Einnahme": RS121.Fields("Einnahme").Value = Replace(RS125.Fields("Einnahme").Value, ",", ".", 1)
                    Case "Ausgabe": RS121.Fields("Ausgabe").Value = Replace(RS125.Fields("Ausgabe").Value, ",", ".", 1)
                    Case "Steuer": RS121.Fields("Steuer").Value = RS125.Fields("Steuer").Value
                    Case Else: RS121.Fields(FL101.Name).Value = RS125.Fields(FL101.Name).Value
                    End Select
                End If
            Next FL101
            RS121.Update
            RS125.MoveNext
            Loop Until RS125.EOF
        End If
        RS125.Close
        Set RS125 = Nothing
        
        RS121.Close
        Set RS121 = Nothing
    End Select
    
    If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
        RowNr = RpRow.Index
        SUpBu RowNr
    Else
        SUpBu
    End If
End If

Set CoDia = Nothing
Set RpSel = Nothing
Set RpCo1 = Nothing

Set clFil = Nothing

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BuIm " & Err.Number
Exit Sub

End Sub
