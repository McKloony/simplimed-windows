Set CmBCC = FM.cmbEmBCC
Set TxBet = FM.txtEmBet
Set TxCCM = FM.txtEmCCM
Set CmBrs = FM.comBar02
Set CmAcs = CmBrs.Actions
Set CmSta = CmBrs.StatusBar
Set CmPgs = CmSta.FindPane(5)
Set RbBar = CmBrs.Item(1)
Set RpCo0 = frmMain.repCont0
Set RpCls = RpCo0.Columns
Set RpSel = RpCo0.SelectedRows

Set clFen = New clsFenster
Set clMai = New clsMailing
Set clFil = New clsFile

clFen.hwnd = FM.hwnd
clFil.hwnd = FM.hwnd

Set CmAtt = CmBrs.FindControl(CmAtt, SY_SuCm3, , True)

If GlEKV = False Then 'Emailkonten vorhanden
    TeTit = "E-Mail-Versand"
    TeMai = "Es ist kein E-Mail-Konto vorhanden"
    TeInh = "Um E-Mails versenden zu können, ist es notwendig mind. ein E-Mail-Konto hinzuzufügen."
    TeFus = "Um ein E-Mail-Konto hinzuzufügen, wechseln Sie in das Modul: Textverarbeitung und dann oben auf Emails. Dort klicken Sie auf die Schaltfläche Emailkonten."
    SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
    Exit Sub
End If

PaNum = FM.mPaNr
MitNr = GlMiA(GlSmI, 2) 'Standardmitarbeiter
GesZa = UBound(GlMkt)

If GlMiA(GlSmI, 25) <> vbNullString Then
    If Right$(LCase(GlMiA(GlSmI, 25)), 3) <> "txn" Then
        SigDa = GlVor & GlMiA(GlSmI, 25)
    End If
End If

If GesZa > 0 Then
    For AktZa = 1 To GesZa
        If CLng(GlMkt(AktZa, 1)) = MitNr Then
            If CBool(GlMkt(AktZa, 20)) = True Then 'Standardemailkonto
                KoGef = True
                Exit For
            End If
        End If
    Next AktZa
End If

If KoGef = False Then
    SPopu "Kein Emailkonto", "Es wurde kein Standardemailkonto gefunden", IC48_Warning
    Exit Sub
End If

MaAci = CmAcs(TX_Mail_NoHTML).Checked = True
MaBes = CmAcs(TX_Mail_Notific).Checked = True

TmGui = CreateID("M")
DaNam = TmGui & EmExt
FiNam = GlDpf & "Emails\" & DaNam

If CmEmp.Text = vbNullString Then
    SPopu "Kein Empfänger", "Es wurde kein Empfänger einteragen", IC48_Information
    Exit Sub
Else
    EmpAd = CmEmp.Text
    If Len(EmpAd) > 250 Then
        EmpAd = Left$(EmpAd, 250)
    End If
    If SEmAd(EmpAd) = False Then 'Gültigkeitsprüfung
        Exit Sub
    End If
End If

If TxBet.Text = vbNullString Then
    SPopu "Kein Betreff", "Es wurde kein Betreff eingetragen", IC48_Information
    Exit Sub
Else
    MaBet = TxBet.Text
    If Len(MaBet) > 250 Then
        MaBet = Left$(MaBet, 250)
    End If
End If

If TxCCM.Text <> vbNullString Then
    EmCCM = TxCCM.Text
    If SEmAd(EmCCM) = False Then 'Gültigkeitsprüfung
        Exit Sub
    End If
End If

If CmBCC.Text <> vbNullString Then
    EmBCC = CmBCC.Text
End If

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    RowNr = RpRow.Index
Else
    RowNr = 0
End If

If RowNr > 0 Then
    IdxNr = MaAry(Mai_IDA, RowNr)
Else
    IdxNr = 0
End If

MaHtm = TxCoN.SaveToMemoryBuffer(MaHtm, 4, 0) 'HTML Umwandlung
MaTex = TxCoN.SaveToMemoryBuffer(MaTex, 1, 0) 'ANSII Umwandlung

If Len(MaTex) > 250 Then
    EmKom = Left$(MaTex, 250) 'Emailkommentar
Else
    EmKom = MaTex
End If

EmKom = Replace(EmKom, vbCrLf, Space$(1), 1)
EmKom = Trim$(EmKom)

Screen.MousePointer = vbHourglass
DoEvents

If MaHtm <> vbNullString Then
    MaHtm = Replace(MaHtm, "</sup>", vbNullString, 1)
    MaHtm = Replace(MaHtm, "<sup>", vbNullString, 1)

    If PaNum > 0 Then
        PatNr = PaNum
        PaStr = S_AdIdx(PatNr, "IDKurz")
    Else
        Set RS131 = New ADODB.Recordset 'Patientenfilter
        RS131.CursorLocation = adUseClient
        Set RS131 = DBCmRe1("qrySimAdEma", "@IdStr", EmpAd)
        AdrZa = RS131.RecordCount
        If AdrZa > 0 Then
            PatNr = RS131.Fields("ID0").Value
            PaStr = RS131.Fields("Name").Value & ", " & RS131.Fields("Vorname").Value
        End If
        RS131.Close
        Set RS131 = Nothing
    End If

    If PatNr = 0 Then
        Set RS132 = New ADODB.Recordset 'Patientenfilter
        RS132.CursorLocation = adUseClient
        Set RS132 = DBCmRe1("qrySimAdEm2", "@IdStr", EmpAd)
        If RS132.RecordCount > 0 Then
            PatNr = RS132.Fields("ID0").Value
            PaStr = RS132.Fields("Name").Value & ", " & RS132.Fields("Vorname").Value
        End If
        RS132.Close
        Set RS132 = Nothing
    End If

    If PatNr = 0 Then
        Set RS132 = New ADODB.Recordset 'Patientenfilter Zugehörige
        RS132.CursorLocation = adUseClient
        Set RS132 = DBCmRe1("qryMailAdFil", "@IdStr", EmpAd)
        If RS132.RecordCount > 0 Then
            PatNr = RS132.Fields("ID0").Value
            PaStr = RS132.Fields("Name").Value & ", " & RS132.Fields("Vorname").Value
        End If
        RS132.Close
        Set RS132 = Nothing
    End If

    Set RS130 = New ADODB.Recordset
    With RS130
        .CursorLocation = adUseClient
        .Source = "qryMailOuAd"
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdTableDirect
    End With
    If RS130.Supports(adAddNew) = True Then
        If CmAcs(TX_Mail_Prioritaet).Checked = True Then
            Prior = 1
        Else
            Prior = 3
        End If
        If CmAtt.ListCount > 0 Then
            MaAtt = True
        End If
                
        With clMai
            If GlMkt(AktZa, 7) <> vbNullString Then
                .moSMTP = GlMkt(AktZa, 7)
            Else
                SPopu "Kein SMTP-Server", "Es wurde kein SMTP-Serveradresse eingetragen", IC48_Warning
                Exit Sub
            End If
            If GlMkt(AktZa, 9) <> vbNullString Then
                .moPor2 = GlMkt(AktZa, 9)
            Else
                SPopu "Kein SMTP-Port", "Es wurde kein SMTP-Port eingetragen", IC48_Warning
                Exit Sub
            End If
            If CBool(GlMkt(AktZa, 15)) = True Then
                If GlMkt(AktZa, 10) <> vbNullString Then
                    .moUsNa = GlMkt(AktZa, 10)
                Else
                    SPopu "Kein Usernamen", "Es wurde kein Benutzername eingetragen", IC48_Warning
                    Exit Sub
                End If
                If GlMkt(AktZa, 11) <> vbNullString Then
                    .moUsPa = GlMkt(AktZa, 11)
                Else
                    SPopu "Kein Userpaswort", "Es wurde kein Benutzerpasswort eingetragen", IC48_Warning
                    Exit Sub
                End If
            End If
            If GlMkt(AktZa, 13) <> vbNullString Then
                .moSeAd = GlMkt(AktZa, 13)
            End If
            If GlMkt(AktZa, 12) <> vbNullString Then
                .moSeNa = GlMkt(AktZa, 12)
            End If
            If GlMkt(AktZa, 14) <> vbNullString Then
                .moSeRe = GlMkt(AktZa, 14)
            End If
            .moAnon = 0
            .moAsyn = 1
            .moPrio = Prior
            .moReAd = EmpAd
            .moReBc = EmBCC
            .moReCc = EmCCM
            .moReNa = PaStr
            .moBest = MaBes
            .moAtVo = MaAtt
            .moSubj = MaBet
            .moFiln = FiNam
            .moImag = SigDa
            .moTLSs = CInt(GlMkt(AktZa, 4))
            .moAuUs = CBool(GlMkt(AktZa, 15))
            .moProg = True 'Prograssbar
            If MaAci = True Then
                .moFrmt = 0
                .moTxHt = MaTex
                .moTxAc = MaTex
            Else
                If MaHtm <> vbNullString Then
                    .moFrmt = 1
                    .moTxHt = MaHtm
                    If MaTex <> vbNullString Then
                        .moTxAc = MaTex
                    End If
                Else
                    .moFrmt = 0
                    .moTxHt = MaTex
                    .moTxAc = MaTex
                End If
            End If
            RetWe = .MaiSen()
            DoEvents
            NeTLS = .moTLSs
        End With

        If RetWe = 0 Then
            MaSiz = FileLen(FiNam)
