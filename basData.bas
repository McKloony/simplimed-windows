                                                    RS125.Fields(FL101.Name).Value = GruKy
                                                End If
                                            End Select
                                        End If
                                    End If
                                End If
                            Next FL101
                        Next AktFe
                        RS125.Update
                    End If
                    PrBr1.Value = AktZe
                    DoEvents
                Next AktZe
            End If

            AnzPa = RS125.RecordCount
            RS125.MoveFirst
        End If
    Else
        With CoDia
            .CancelError = True
            .DialogStyle = 1
            .DefaultExt = "*.xml"
            .Filter = "XML-Dateien (*.xml)|*.xml|Access-Datenbanken (*.mdb)|*.mdb|Alle Dateien (*.*)|*.*"
            .DialogTitle = "Wo befindet sich die Importdatei?"
            .InitDir = GlIPf
            .FileName = vbNullString
            .ShowOpen
