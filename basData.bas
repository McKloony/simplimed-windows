Public Sub S_BelNe()
On Error GoTo SuErr
'Legt einen neuen Beleg an

Dim BeTex As String
Dim RzAbs As Boolean

RzAbs = CBool(IniGetVal("System", "RzAbse")) 'Rezeptabsender

If IsNumeric(GlNeZ.GesBe) = True Then
    If CDbl(GlNeZ.GesBe) < 2147483647 Then
        BeTex = WinZaUm(CLng(GlNeZ.GesBe))
    End If
End If

Set RS126 = New ADODB.Recordset
With RS126
    .CursorLocation = adUseClient
    .Source = "qrySimRzNe"
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdTableDirect
End With

If RS126.Supports(adAddNew) Then
    RS126.AddNew
    RS126.Fields("ID0").Value = GlNeZ.PatNr
    RS126.Fields("Type").Value = GlNeZ.BelNr '12 / 17
    RS126.Fields("Datum").Value = GlNeZ.BeDat
    RS126.Fields("Absender").Value = RzAbs
    RS126.Fields("GuiID").Value = GlNeZ.GuiID
    If GlNeZ.MaNum > 0 Then RS126.Fields("IDP").Value = GlNeZ.MaNum
    If GlNeZ.MitNr > 0 Then RS126.Fields("IDM").Value = GlNeZ.MitNr
    If GlNeZ.Steue > 0 Then RS126.Fields("GesBrut").Value = GlNeZ.Steue
    If GlNeZ.GesBe > 0 Then RS126.Fields("GesBetrag").Value = GlNeZ.GesBe
    If GlNeZ.TSETz > 0 Then RS126.Fields("TSEZahl").Value = GlNeZ.TSETz
    If GlNeZ.TSESz > 0 Then RS126.Fields("TSESign").Value = GlNeZ.TSESz
    If GlTyp < 2 Then
        If GlNeZ.TSESt <> vbNullString Then RS126.Fields("TSEStrSig").Value = GlNeZ.TSESt
        If GlNeZ.TSEQr <> vbNullString Then RS126.Fields("TSEString").Value = GlNeZ.TSEQr
    End If
    If GlNeZ.TSELg <> vbNullString Then RS126.Fields("TSELog").Value = GlNeZ.TSELg
    If GlNeZ.KoTex <> vbNullString Then RS126.Fields("Kommentar").Value = GlNeZ.KoTex
    If BeTex <> vbNullString Then RS126.Fields("BetrText").Value = BeTex
    RS126.Update
End If
RS126.Close
Set RS126 = Nothing
DoEvents

GlNeZ = GlNeY

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BelNe " & Err.Number
Resume Next

End Sub

