Public Function S_Opti(ByVal TypDa As Integer) As String
On Error GoTo FiErr
'Liefert Datenstring für Optionsdialog

Dim DaStr As String
Dim AktZa As Integer

Select Case TypDa
Case 1: 'Kataloge
        For AktZa = 1 To UBound(GlGKa)
            If DaStr = vbNullString Then
                DaStr = GlGKa(AktZa, 1)
            Else
                DaStr = DaStr & ";" & GlGKa(AktZa, 1)
            End If
        Next AktZa
Case 2: 'Behandler
        For AktZa = 1 To UBound(GlThe)
            If DaStr = vbNullString Then
                DaStr = GlThe(AktZa, 13)
            Else
                DaStr = DaStr & ";" & GlThe(AktZa, 13)
            End If
        Next AktZa
Case 3: 'Zahlungsziele
        For AktZa = 1 To UBound(GlZah)
            If DaStr = vbNullString Then
                DaStr = GlZah(AktZa, 1)
            Else
                DaStr = DaStr & ";" & GlZah(AktZa, 1)
            End If
        Next AktZa
Case 4: 'Währungen
        For AktZa = 1 To UBound(GlWar)
            If DaStr = vbNullString Then
                DaStr = GlWar(AktZa, 1)
            Else
                DaStr = DaStr & ";" & GlWar(AktZa, 1)
            End If
        Next AktZa
Case 6: 'Steuersätze
        For AktZa = 1 To UBound(GlStu)
            If DaStr = vbNullString Then
                DaStr = GlStu(AktZa, 1)
            Else
                DaStr = DaStr & ";" & GlStu(AktZa, 1)
            End If
        Next AktZa
End Select

S_Opti = DaStr

Exit Function

FiErr:
If GlDbg = True Then SErLog Err.Description & " S_Opti " & Err.Number
Resume Next

End Function
Public Sub S_OPZu()
On Error GoTo LiErr
'Holt den offenen Posten wieder zurück

Dim BuDat As Date
Dim IdxNr As Long
Dim OpNum As Long
Dim RowNr As Long
Dim AnzPo As Long
Dim ReNum As Long
Dim PatNr As Long
Dim ManNr As Long
Dim ReBet As Single
Dim ReStr As String
Dim PaStr As String
Dim TmGui As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim BuTex As String
Dim BuBet As Double
Dim BezBe As Double
Dim NeReB As Double
Dim RaBet As Double
Dim BuSto As Boolean
Dim BuLok As Boolean
Dim BuAbg As Boolean
Dim BuVor As Integer
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo1 = FM.repCont1
Set RpCls = RpCo1.Columns
Set RpSel = RpCo1.SelectedRows

AnzPo = RpSel.Count
Tit1 = "Posten wiederherstellen"

Select Case GlBut
Case RibTab_Mahnwesen:
        If AnzPo > 1 Then
            Mld1 = "Sollen die " & AnzPo & " markierten Posten wiederhergestellt werden?"
        Else
            Mld1 = "Soll der markierte Posten wiederhergestellt werden?"
        End If
        If AnzPo > 0 Then
            Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
            If Frage = 6 Then
                Screen.MousePointer = vbHourglass

                For Each RpRow In RpSel
                    If RpRow.GroupRow = False Then
                        RowNr = RpRow.Index
                        BuSto = True
                        
                        Set RpCol = RpCls.Find(OPo_ID1)
                        OpNum = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(OPo_ReBetrag)
                        ReBet = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(OPo_RechNr)
                        ReStr = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(OPo_IDR)
                        ReNum = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(OPo_Patient)
                        PaStr = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(OPo_ID0)
                        PatNr = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(OPo_GuiID)
                        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                            TmGui = RpRow.Record(RpCol.ItemIndex).Value
                        Else
                            TmGui = vbNullString
                        End If
                        DoEvents
                        
                        If TmGui <> vbNullString Then
                            BuVor = S_BuPr(0, TmGui)
                        Else
                            BuVor = 1
                        End If
                        DoEvents
                        Select Case BuVor
                        Case 1:
                            TeTit = "Posten wiederherstellen"
                            TeMai = "Dieser Posten sollte nicht wiederhergestellt werden"
                            TeInh = "Zum Posten: " & ReStr & " wurde bereits eine Erlösbuchung generiert. Dieser Posten sollte daher nicht wiederhergestellt werden. Soll dieser Posten dennoch wiederhergestellt werden?"
                            TeFus = "Posten, zu denen bereits eine Erlösbuchung existiert, sollten nicht wiederhergestellt werden. Sollte dieser dennoch wiederhergestellt werden, wird die zugehörige Erlösbuchung ebenfalls storniert."
                            SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, False, FM.hwnd
                            If GlMes <> 33565 Then
                                BuSto = False
                            End If
                        Case 2:
                            BuSto = False
                            TeTit = "Posten wiederherstellen"
                            TeMai = "Dieser Posten kann nicht wiederhergestellt werden"
                            TeInh = "Zum Posten: " & ReStr & " wurde bereits eine Erlösbuchung generiert und festgeschrieben. Dieser Posten kann daher nicht wiederhergestellt werden."
                            TeFus = "Posten, zu denen bereits eine Erlösbuchung existiert und die bereits festgeschrieben wurden, können nicht wiederhergestellt werden. Legen Sie stattdessen eine Gutschrift an, um die möglicherweise fehlerhafte Rechnung damit zu berichtigen."
                            SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True, FM.hwnd
                        End Select

                        If BuSto = True Then
                            If GlBuL = True Then 'echtes Löschen erlauben
                                DBCmEx1 "qrySimBuLoP", "@IdxNr", ReNum 'Erlösbuchung
                            Else
                                DBCmEx2 "qrySimBuStr", "@IdSto", "@IdxNr", True, ReNum 'Erlösbuchung
                            End If
                            DoEvents
                            DBCmEx2 "qrySimOPAu1", "@PaSum", "@IdxNr", 0, OpNum 'Bezahlter Betrag Posten
                            DoEvents
                            DBCmEx2 "qrySimOPAu2", "@PaSum", "@IdxNr", ReBet, OpNum 'Offener Betrag Posten
                            DoEvents
                            DBCmEx2 "qrySimOPAu3", "@PaSel", "@IdxNr", 0, OpNum 'Kennzeichnung des Postens
                            DoEvents
                            DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", 0, ReNum 'Rechung Bezahlt Kennzeichnen
                            DoEvents
                            DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", 0, ReNum 'Bezahlter Betrag Rechung
                            DoEvents
                            DBCmEx2 "qrySimOPBel", "@IdStr", "@IdxNr", "0", OpNum 'Belegnummer Posten
                            DoEvents
                            DBCmEx3 "qrySimBaRec", "@IdBez", "@IdSel", "@IdxNr", 0, 0, ReNum 'Kennzeichung Banking
                            DoEvents
                            S_BuBa OpNum, True 'Zuordnungen Banking
                            DoEvents
                        End If
                    End If
                Next RpRow
                SUpOp RowNr
                
                Screen.MousePointer = vbNormal
            End If
        End If
Case RibTab_Buchungen:
    If AnzPo > 1 Then
        Mld1 = "Möchten Sie für die " & AnzPo & " markierten Buchungen die offenen Posten wiederherstellen?"
    Else
        Mld1 = "Möchten Sie dür die markierte Buchung den offenen Posten wiederherstellen?"
    End If
    If GlBuL = True Then 'Echtes Löschen erlauben
        TeTit = "Buchung Entfernen"
        TeMai = "Diese Buchung darf nicht gelöscht werden"
        TeInh = "Es ist nicht möglich, die markierte Buchung zu löschen, da diese zum Beispiel durch das Eintragen einer Zahlung, dem Ausgleich eines offenen Postens, dem Drucken einer Quittung oder dem Eintragen eines Guthabens automatsch generiert wurde."
        TeFus = "Bitte klicken Sie auf Buchung Ableiten und erstellen Sie ein Ristorno (Gegenbuchung) für die fehlerhafte Buchung, um diese unwirksam zu machen."
    Else
        TeTit = "Buchung Stornieren"
        TeMai = "Diese Buchung darf nicht storniert werden"
        TeInh = "Es ist nicht möglich, die markierte Buchung zu stornieren, da diese zum Beispiel durch das Eintragen einer Zahlung, dem Ausgleich eines offenen Postens, dem Drucken einer Quittung oder dem Eintragen eines Guthabens automatsch generiert wurde."
        TeFus = "Bitte klicken Sie auf Buchung Ableiten und erstellen Sie ein Ristorno (Gegenbuchung) für die fehlerhafte Buchung, um diese unwirksam zu machen."
    End If
    If AnzPo > 0 Then
        Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
        If Frage = 6 Then
            Screen.MousePointer = vbHourglass

            For Each RpRow In RpSel
                If RpRow.GroupRow = False Then
                    RowNr = RpRow.Index
                    Set RpCol = RpCls.Find(Buh_IDR)
                    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                        ReNum = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(Buh_ID0)
                        IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(Buh_Datum)
                        BuDat = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(Buh_Buchtext)
                        PaStr = RpRow.Record(RpCol.ItemIndex).Value
                        Set RpCol = RpCls.Find(Buh_IDT)
                        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                            If IsNumeric(RpRow.Record(RpCol.ItemIndex).Value) = True Then
                                ManNr = RpRow.Record(RpCol.ItemIndex).Value
                            Else
                                ManNr = 0
                            End If
                        Else
                            ManNr = 0
                        End If
                        Set RpCol = RpCls.Find(Buh_Lock)
                        If RpRow.Record(RpCol.ItemIndex).Checked = True Then
                            BuLok = True
                        Else
                            BuLok = False
                        End If
                        Set RpCol = RpCls.Find(Buh_Einnahme)
                        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                            BuBet = RpRow.Record(RpCol.ItemIndex).Value
                        Else
                            BuBet = 0
                        End If
                        Set RpCol = RpCls.Find(Buh_GuiID)
                        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                            TmGui = RpRow.Record(RpCol.ItemIndex).Value
                        Else
                            TmGui = vbNullString
                        End If
                        Set RpCol = RpCls.Find(Buh_Buchtext)
                        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                            BuTex = RpRow.Record(RpCol.ItemIndex).Value
                        Else
                            BuTex = vbNullString
                        End If

                        If BuLok = False Then 'GoBD Festschreibung
                            Set RS128 = New ADODB.Recordset
                            RS128.CursorLocation = adUseClient
                            Set RS128 = DBCmRe1("qrySimBuIdx", "@IdxNr", IdxNr)
                            If RS128.RecordCount > 0 Then
                                BuAbg = CBool(RS128.Fields("Selekt").Value) 'Buchung abgeleitet
                                If BuAbg = True Then
                                    If ReNum > 0 Then
                                        Set RS119 = New ADODB.Recordset
                                        RS119.CursorLocation = adUseClient
                                        Set RS119 = DBCmRe1("qrySimReIdx", "@IdxNr", ReNum)
                                        If RS119.RecordCount > 0 Then
                                            If RS119.Fields("GesBetrag").Value <> vbNullString Then
                                                ReBet = RS119.Fields("GesBetrag").Value
                                            Else
                                                ReBet = 0
                                            End If
                                            If RS119.Fields("Bezahlt").Value <> vbNullString Then
                                                BezBe = RS119.Fields("Bezahlt").Value
                                            Else
                                                BezBe = 0
                                            End If
                                            If RS119.Fields("Rabatt").Value <> vbNullString Then
                                                RaBet = RS119.Fields("Rabatt").Value
                                            Else
                                                RaBet = 0
                                            End If
                                            If BuAbg = False Then 'Buchung abgeleitet
                                                If BezBe - BuBet <= 0 Then
                                                    DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", 0, ReNum
                                                    DBCmEx2 "qrySimReSm3", "@IdBet", "@IdxNr", 0, ReNum
                                                Else
                                                    DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", BezBe - BuBet, ReNum
                                                    DBCmEx2 "qrySimReSm3", "@IdBet", "@IdxNr", BezBe - BuBet, ReNum
                                                End If
                                                DoEvents
                                                NeReB = S_ReBet(ReNum, Round(ReBet, 2), BuAbg, RaBet)
                                                DoEvents
                                            End If
                                            If GlBuL = True Then 'Echtes Löschen erlauben
                                                DBCmEx1 "qrySimBuLo", "@IdxNr", IdxNr
                                            Else
                                                DBCmEx2 "qrySimBuSto", "@IdSto", "@IdxNr", True, IdxNr
                                            End If
                                            DoEvents
                                            DBCmEx1 "qrySimOPZu", "@IdxNr", ReNum
                                            DoEvents
                                            DBCmEx1 "qrySimAbLoG", "@IdStr", TmGui
                                            DoEvents
                                            DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", 0, ReNum 'Rechung Bezahlt Kennzeichnen
                                            DoEvents
                                            DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", 0, ReNum
                                            DoEvents
                                            S_BuBa ReNum
                                        Else
                                            If BuAbg = True Then
                                                SMeFr TeTit, TeMai, TeInh, TeFus, False, 1, True
                                            Else
                                                If GlBuL = True Then 'Echtes Löschen erlauben
                                                    DBCmEx1 "qrySimBuLo", "@IdxNr", IdxNr
                                                Else
                                                    DBCmEx2 "qrySimBuSto", "@IdSto", "@IdxNr", True, IdxNr
                                                End If
                                                DoEvents
                                                DBCmEx1 "qrySimOPZu", "@IdxNr", ReNum
                                                DoEvents
                                                DBCmEx1 "qrySimAbLoG", "@IdStr", TmGui
                                                DoEvents
                                                DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", 0, ReNum 'Rechung Bezahlt Kennzeichnen
                                                DoEvents
                                                DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", 0, ReNum
                                                DoEvents
                                                S_BuBa ReNum
                                            End If
                                        End If
                                        RS119.Close
                                        Set RS119 = Nothing
                                    Else
                                        If GlBuL = True Then 'Echtes Löschen erlauben
                                            DBCmEx1 "qrySimBuLo", "@IdxNr", IdxNr
                                        Else
                                            DBCmEx2 "qrySimBuSto", "@IdSto", "@IdxNr", True, IdxNr
                                        End If
                                        DoEvents
                                        DBCmEx1 "qrySimOPZu", "@IdxNr", ReNum
                                        DoEvents
                                        DBCmEx1 "qrySimAbLoG", "@IdStr", TmGui
                                        DoEvents
                                        DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", 0, ReNum
                                        DoEvents
                                        DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", 0, ReNum
                                        DoEvents
                                        S_BuBa ReNum
                                    End If
                                Else
                                    If GlBuL = True Then 'Echtes Löschen erlauben
                                        DBCmEx1 "qrySimBuLo", "@IdxNr", IdxNr
                                    Else
                                        DBCmEx2 "qrySimBuSto", "@IdSto", "@IdxNr", True, IdxNr
                                    End If
                                    DoEvents
                                    DBCmEx1 "qrySimOPZu", "@IdxNr", ReNum
                                    DoEvents
                                    DBCmEx1 "qrySimAbLoG", "@IdStr", TmGui
                                    DoEvents
                                    DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", 0, ReNum
                                    DoEvents
                                    DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", 0, ReNum
                                    DoEvents
                                    S_BuBa ReNum
                                End If
                            Else
                                If GlBuL = True Then 'Echtes Löschen erlauben
                                    DBCmEx1 "qrySimBuLo", "@IdxNr", IdxNr
                                Else
                                    DBCmEx2 "qrySimBuSto", "@IdSto", "@IdxNr", True, IdxNr
                                End If
                                DoEvents
                                DBCmEx1 "qrySimOPZu", "@IdxNr", ReNum
                                DoEvents
                                DBCmEx1 "qrySimAbLoG", "@IdStr", TmGui
                                DoEvents
                                DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", 0, ReNum 'Rechung Bezahlt Kennzeichnen
                                DoEvents
                                DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", 0, ReNum
                                DoEvents
                                S_BuBa ReNum
                            End If
                            RS128.Close
                            Set RS128 = Nothing
                            DoEvents
                            GlNeK = GlKoX 'Protokolleintrag
                            With GlNeK
                                .PatNr = ManNr
                                .IdxNr = 0
                                .EiDat = Format$(Date, "dd.mm.yyyy")
                                .EiZei = TimeValue(Now)
                                .EiTyp = 104
                                .TeStr = "Buchung storniert - " & BuTex & Chr$(32) & Format$(BuDat, "dd.mm.yyyy")
                                .ZiStr = Format$(Now, "hh:mm") & " Uhr"
                                .NeuEi = True
                                .KeiAk = True
                                .Mitar = GlMiA(GlSmI, 2)
                            End With
                            S_Prot
                        Else
                            Tit1 = "GoBD Verriegelung"
                            Mld1 = "Diese Buchung wurde bereits verriegelt."
                            SPopu Tit1, Mld1, IC48_Information
                        End If
                    End If
                End If
            Next RpRow
            SUpBu RowNr
            
            Screen.MousePointer = vbNormal
        End If
    End If
End Select

If Frage = 6 Then
    GlNeK = GlKoX 'Protokolleintrag
    With GlNeK
        If PatNr > 0 Then
            .PatNr = PatNr
        Else
            .PatNr = GlMan(GlSMa, 2)
        End If
        .IdxNr = 0
        .EiDat = Format$(Date, "dd.mm.yyyy")
        .EiZei = TimeValue(Now)
        .EiTyp = 104
        .TeStr = "Offener Posten wiederhergestellt - " & PaStr
        .ZiStr = Format$(Now, "hh:mm") & " Uhr"
        .NeuEi = True
        .KeiAk = True
        .Mitar = GlMiA(GlSmI, 2)
    End With
    S_Prot
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_OPZu " & Err.Number
Resume Next

End Sub
Public Sub S_PaGu(ByVal PatNr As Long, Optional ByVal AdBet As Double, Optional ByVal SuBet As Double)
On Error GoTo LiErr
'Guthaben Operationen

Dim GuBet As Double
Dim AnBet As Double
Dim Mld1, Tit1 As String

Tit1 = "Guthabenänderung"

Set RS126 = New ADODB.Recordset
RS126.CursorLocation = adUseClient
Set RS126 = DBCmRe1("qryAdrIdx", "@IdxNr", PatNr)
If RS126.RecordCount > 0 Then
    DoEvents
    If RS126.Fields("Guthaben").Value <> vbNullString Then
        GuBet = RS126.Fields("Guthaben").Value
    Else
        GuBet = 0
    End If
End If
RS126.Close
Set RS126 = Nothing

If AdBet > 0 Then
    Mld1 = "Dem aktuellen Guthaben von " & Format$(GuBet, GlWa1) & " wird der Betrag von " & Format$(AdBet, GlWa1) & " hinzugefügt"
    AnBet = Format$(GuBet + AdBet, GlWa1)
    DBCmEx2 "qrySimPatGu", "@IdGut", "@IdxNr", AnBet, PatNr
    SPopu Tit1, Mld1, IC48_Information
ElseIf SuBet > 0 Then
    If Round(GuBet, 2) >= Round(SuBet, 2) Then
        Mld1 = "Dem aktuellen Guthaben von " & Format$(GuBet, GlWa1) & " wird der Betrag von " & Format$(SuBet, GlWa1) & " abgezogen"
        DBCmEx2 "qrySimPatGu", "@IdGut", "@IdxNr", Round(GuBet, 2) - Round(SuBet, 2), PatNr
        SPopu Tit1, Mld1, IC48_Information
    Else
        Mld1 = "Der Buchungsbetrag von " & Format$(SuBet, GlWa1) & " ist größer als der Guthabenbetrag von " & Format$(GuBet, GlWa1) & " und kann daher nicht verrechnet werden."
        SPopu Tit1, Mld1, IC48_Warning
    End If
End If

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_PaGu " & Err.Number
Resume Next

End Sub
Public Sub S_PaTe(ByVal AdBet As Single, ByVal TerNr As Long, ByVal MasNr As Long)
On Error GoTo LiErr

If MasNr > 0 Then
    DBCmEx2 "qryTerBez2", "@IdBet", "@IdxNr", AdBet, MasNr
ElseIf TerNr > 0 Then
    DBCmEx2 "qryTerBez1", "@IdBet", "@IdxNr", AdBet, TerNr
End If

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_PaTe " & Err.Number
Resume Next

End Sub
Private Sub S_PoRec(ByRef RST As ADODB.Recordset)
