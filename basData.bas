            .ActiveConnection = DB1
            .CursorType = adOpenKeyset
            .LockType = adLockOptimistic
            .Open Options:=adCmdTableDirect
        End With
        If RS121.Supports(adAddNew) Then
            Screen.MousePointer = vbHourglass
            AktZa = 1
            
            Do
            AnzGe = 0
            PaKur = RS125.Fields("IDKurz").Value
            IdxNr = RS125.Fields("ID0").Value
            PaGui = RS125.Fields("GuiID").Value

            RS121.AddNew
            For Each FL101 In RS125.Fields
                TmpWe = RS125.Fields(FL101.Name).Value
                Select Case FL101.Name
                Case "ID0":
                Case "ID3":
                    If TmpWe <> vbNullString And Not IsNull(TmpWe) Then
                        RS121.Fields(FL101.Name).Value = CLng(TmpWe)
                    Else
                        RS121.Fields(FL101.Name).Value = GlGKa(GlStK, 0) 'Standardgebührenkatalog
                    End If
                Case "IDZ":
                    If TmpWe <> vbNullString And Not IsNull(TmpWe) Then
                        RS121.Fields(FL101.Name).Value = CLng(TmpWe)
                    Else
                        RS121.Fields(FL101.Name).Value = GlZah(GlStZ, 0) 'Standardzahlungsziel
                    End If
                Case "Arzt":
                    RS121.Fields(FL101.Name).Value = IsArz
                Case "Geboren":
                    If IsDate(TmpWe) = True Then
                        RS121.Fields(FL101.Name).Value = CDate(TmpWe)
                    End If
                Case "R_Geboren":
                    If IsDate(TmpWe) = True Then
