Dim Frage As Integer
Dim Mld1, Tit1 As String

Set FM = frmMain

AnzPo = UBound(GlClp)
AnzTa = UBound(GlTag)

If PatNr = 0 Then
    PatNr = GlAdr
End If

If AnzPo > 0 Then
    If AnzTa > 0 Then
        If GlTyp < 2 Then
            SQL3 = "SELECT * FROM dbo.qrySimAbSav WHERE IDR = " & ReNum & " ORDER BY ID3 DESC"
        Else
            SQL3 = "SELECT * FROM qrySimAbSav WHERE [IDR] = " & ReNum & " ORDER BY [ID3] DESC;"
        End If
        
        Set RS123 = New ADODB.Recordset 'Krenkanblatt
        With RS123
            .CursorLocation = adUseClient
            .Source = SQL3
            .ActiveConnection = DB1
            .CursorType = adOpenDynamic
            .LockType = adLockOptimistic
            .Open Options:=adCmdText
        End With
        
        If RS123.RecordCount > 0 Then
            SorNr = RS123.Fields("ID3").Value
        Else
            SorNr = 0
        End If
        
        For AktTa = 1 To AnzTa 'Behandlungstage
            Set RS127 = New ADODB.Recordset
            RS127.CursorLocation = adUseClient
            Set RS127 = DBCmRe2("qrySimAbFil", "@IdxNr", "@IdDat", ReNum, GlTag(AktTa))

            For AktPo = 1 To AnzPo 'Zeilen im Krankenblatt
                If GlClp(AktPo, 2) = 6 Then
                
                ElseIf GlClp(AktPo, 2) = 7 Then
                
                Else
                    EiTex = GlClp(AktPo, 4)
                    ReStu = GlClp(AktPo, 20)
                    If ReStu > 0 And ReStu < 1 Then
                        ReStu = ReStu * 100
                    End If
                    RS127.Filter = "[IDKurz] Like '*" & EiTex & "*'"
                    If RS127.RecordCount = 0 Then
                        KrGui = CreateID("K")
                        SorNr = SorNr + 1
                        RS123.AddNew
                        RS123.Fields("ID0").Value = PatNr
                        RS123.Fields("IDR").Value = ReNum
                        RS123.Fields("ID3").Value = SorNr
                        RS123.Fields("ID1").Value = GlClp(AktPo, 2)
                        RS123.Fields("Datum").Value = GlTag(AktTa) & Space$(1) & TimeValue(Now)
                        RS123.Fields("Druckdatum").Value = GlTag(AktTa) & Space$(1) & TimeValue(Now)
                        RS123.Fields("GONr").Value = GlClp(AktPo, 3)
                        RS123.Fields("IDKurz").Value = GlClp(AktPo, 4)
                        RS123.Fields("x").Value = GlClp(AktPo, 6)
                        If IsNumeric(GlClp(AktPo, 8)) Then RS123.Fields("Betrag").Value = GlClp(AktPo, 8)
                        If IsNumeric(GlClp(AktPo, 9)) Then RS123.Fields("GesBetrag").Value = GlClp(AktPo, 9)
                        If IsNumeric(GlClp(AktPo, 7)) Then RS123.Fields("Multi").Value = GlClp(AktPo, 7)
                        If IsNumeric(GlClp(AktPo, 10)) Then RS123.Fields("WVBetrag").Value = GlClp(AktPo, 10)
                        RS123.Fields("Kommentar").Value = GlClp(AktPo, 11)
                        RS123.Fields("Zeit").Value = GlClp(AktPo, 12)
                        RS123.Fields("Kommentar2").Value = KrGui
                        RS123.Fields("Währung").Value = GlClp(AktPo, 14)
                        RS123.Fields("IDM").Value = GlClp(AktPo, 15)
                        If GlDiZ = False Then 'Gebührendiagnosezuordnungen auslassen
                            RS123.Fields("IDD").Value = Dia_Su(ReNum, GlClp(AktPo, 16))
                        End If
                        RS123.Fields("Analog").Value = GlClp(AktPo, 17)
                        RS123.Fields("Steuer").Value = ReStu
                        RS123.Fields("RechNr").Value = GlClp(AktPo, 21)
                        RS123.Update
                    End If
                End If
            Next AktPo
        Next AktTa
        
        RS123.Close
        RS127.Close
        Set RS123 = Nothing
        Set RS127 = Nothing
    Else
        Mld1 = "Sie müssen erst einen Tag markieren, um einen Eintrag zu kopieren"
        Tit1 = "Kein Tag markiert"
        WindowMess Mld1, Dial2, Tit1, FM.hwnd
    End If
Else
    Mld1 = "Sie müssen erst eine Zeile markieren, um einen Eintrag zu kopieren"
    Tit1 = "Keine Zeile markiert"
    WindowMess Mld1, Dial2, Tit1, FM.hwnd
End If

S_KrKo = KrGui

Exit Function

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_KrKo " & Err.Number
Resume Next

End Function
