Public Sub S_LaPo()
On Error GoTo KoErr

Dim SQL1 As String
Dim GesZa As Long
Dim IdxNr As Long
Dim GrCap As String
Dim GrPre As Single
Dim GrAnz As Integer
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow
Dim RpRws As XtremeReportControl.ReportRows

Set FM = frmMain
Set RpCo6 = FM.repCont6
Set RpCo5 = FM.repCont5
Set RpCls = RpCo5.Columns
Set RpSel = RpCo5.SelectedRows

With RpCo6
    .EditItem Nothing, Nothing
    If .SortOrder.Count > 0 Then .SortOrder.DeleteAll
    If .GroupsOrder.Count > 0 Then .GroupsOrder.DeleteAll
    If .Records.Count > 0 Then .Records.DeleteAll
    .Populate
End With

If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    If RpRow.GroupRow = False Then
        If GlBut = RibTab_LabBericht Or GlBut = RibTab_LabBerichte Then
            Set RpCol = RpCls.Find(Lab_ID0)
            IdxNr = RpRow.Record(RpCol.ItemIndex).Value
            If GlGrI = True Then 'Gruppierung Laborbericht
                If GlTyp < 2 Then
                    SQL1 = "SELECT * FROM dbo.qryLabTes WHERE IDB = " & IdxNr & " ORDER BY Gruppe, Ident"
                Else
                    SQL1 = "SELECT * FROM qryLabTes WHERE [IDB] = " & IdxNr & " ORDER BY [Gruppe], [Ident];"
                End If
            Else
                If GlTyp < 2 Then
                    SQL1 = "SELECT * FROM dbo.qryLabTes WHERE IDB = " & IdxNr & " ORDER BY Ident"
                Else
                    SQL1 = "SELECT * FROM qryLabTes WHERE [IDB] = " & IdxNr & " ORDER BY [Ident];"
                End If
            End If
        ElseIf GlBut = RibTab_LabAuftrag Or GlBut = RibTab_LabAuftrage Then
            Set RpCol = RpCls.Find(Lau_ID1)
            IdxNr = RpRow.Record(RpCol.ItemIndex).Value
            If GlTyp < 2 Then
                SQL1 = "SELECT * FROM dbo.qryLabPos WHERE IDA = " & IdxNr
            Else
                SQL1 = "SELECT * FROM qryLabPos WHERE [IDA] = " & IdxNr & ";"
            End If
        End If

        Set RS149 = New ADODB.Recordset
        With RS149
            .CursorLocation = adUseClient
            .Source = SQL1
            .ActiveConnection = DB1
            .CursorType = adOpenForwardOnly
            .LockType = adLockReadOnly
            .Open Options:=adCmdText
        End With
        GesZa = RS149.RecordCount
        
        DoEvents
        S_LaSpl
        DoEvents
    
        If GesZa > 0 Then
            S_LaRec RS149
            DoEvents
            RpCo6.Populate
        End If
        RS149.Close
        Set RS149 = Nothing
                
        If GlGrI = True Then 'Gruppierung Laborbericht
            With RpCo6
                .GroupsOrder.Add .Columns(Lbl_Gruppe)
                .GroupsOrder(0).SortAscending = True
                .Populate
                DoEvents
                
                Set RpRws = RpCo6.Rows
                                                        
                For Each RpRow In RpRws
                    If RpRow.GroupRow = True Then
                        Set RpGrw = RpRow
                        Set ChRws = RpGrw.Childs
                        GrAnz = ChRws.Count
                        For Each ChRow In ChRws
                            If IsNumeric(ChRow.Record.Item(Lbl_Betrag).Value) Then
                                GrPre = GrPre + ChRow.Record.Item(Lbl_Betrag).Value
                            End If
                        Next ChRow
                        If Len(RpGrw.GroupCaption) > 0 Then
                            GrCap = RpGrw.GroupCaption
                            RpGrw.GroupCaption = GrCap & " - Anzahl: " & GrAnz & " - Summe: " & Format$(GrPre, GlWa1)
                            If GlExL = True Then
                                RpGrw.Expanded = True
                            Else
                                RpGrw.Expanded = False
                            End If
                        End If
                    End If
                    GrPre = 0
                Next RpRow
                .Redraw
            End With
        End If
    End If
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo5 = Nothing
Set RpCo6 = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_LaPo " & Err.Number
Resume Next

End Sub
