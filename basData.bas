Dim CmSaK As XtremeSuiteControls.ComboBox
Dim CmTyp As XtremeSuiteControls.ComboBox
Dim CmAus As XtremeSuiteControls.ComboBox
Dim CmReS As XtremeSuiteControls.ComboBox
Dim ChGeg As XtremeSuiteControls.CheckBox
Dim ChDat As XtremeSuiteControls.CheckBox
Dim ChMan As XtremeSuiteControls.CheckBox
Dim ChMit As XtremeSuiteControls.CheckBox
Dim ChTyp As XtremeSuiteControls.CheckBox
Dim ChSto As XtremeSuiteControls.CheckBox
Dim ChAus As XtremeSuiteControls.CheckBox
Dim ChSaK As XtremeSuiteControls.CheckBox
Dim ChSte As XtremeSuiteControls.CheckBox
Dim ChBel As XtremeSuiteControls.CheckBox
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmBuAnp
Set TxDa1 = FM.txtDatu1
Set TxBel = FM.txtBeleg
Set CmGeg = FM.cmbGegen
Set CmSaK = FM.cmbSaKon
Set CmMan = FM.cmbManda
Set CmMit = FM.cmbMitar
Set CmTyp = FM.cmbBuTyp
Set CmSto = FM.cmbStorn
Set CmAus = FM.cmbAuswe
Set CmReS = FM.cmbReStu
Set ChGeg = FM.chkGegen
Set ChDat = FM.chkDatum
Set ChMan = FM.chkManda
Set ChMit = FM.chkMitar
Set ChTyp = FM.chkReTyp
Set ChSto = FM.chkStorn
Set ChAus = FM.chkAuswe
Set ChSaK = FM.chkSaKon
Set ChSte = FM.chkSteue
Set ChBel = FM.chkBeleg
Set RpCo1 = frmMain.repCont1
Set RpSel = RpCo1.SelectedRows
Set RpCls = RpCo1.Columns
        
AktPo = 1
AnzPo = RpSel.Count

BuDat = CDate(TxDa1.Text)

GeKId = CmGeg.ItemData(CmGeg.ListIndex)
ErKId = CmSaK.ItemData(CmSaK.ListIndex)
If GlKnF = True Then 'Sachkontenformatierung sechsstellig
    ErKNr = Left$(CmSaK.Text, 6)
    GeKNr = Left$(CmGeg.Text, 6)
    ErKBe = Mid$(CmSaK.Text, 8, Len(CmSaK.Text) - 7)
    GeKBe = Mid$(CmGeg.Text, 8, Len(CmGeg.Text) - 7)
Else
    ErKNr = Left$(CmSaK.Text, 4)
    GeKNr = Left$(CmGeg.Text, 4)
    ErKBe = Mid$(CmSaK.Text, 6, Len(CmSaK.Text) - 5)
    GeKBe = Mid$(CmGeg.Text, 6, Len(CmGeg.Text) - 5)
End If

mAnDa = CmMan.ItemData(CmMan.ListIndex)
Mitar = CmMit.ItemData(CmMit.ListIndex)
BuTyp = CmTyp.ItemData(CmTyp.ListIndex)

If CmSto.ListIndex = 0 Then
    Stron = True
Else
    Stron = False
End If

If CmAus.ListIndex = 0 Then
    Auswe = True
Else
    Auswe = False
End If

If TxBel.Text <> vbNullString Then
    If IsNumeric(TxBel.Text) = True Then
        BuBel = CLng(TxBel.Text)
    Else
        BuBel = 1
    End If
Else
    BuBel = 1
End If

If CmReS.ListIndex >= 0 Then
    StuZa = CmReS.ItemData(CmReS.ListIndex)
    For AktZa = 1 To UBound(GlStu)
        If GlStu(AktZa, 0) = StuZa Then
            Steue = CDec(GlStu(AktZa, 1))
            Exit For
        End If
    Next AktZa
End If

If AnzPo > 0 Then
    ReDim GloBu(AnzPo)

    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            RowNr = RpRow.Index
            GloBu(AktPo) = RowNr

            Set RpCol = RpCls.Find(Buh_ID0)
            BuNum = RpRow.Record(RpCol.ItemIndex).Value
            
            Set RpCol = RpCls.Find(Buh_Lock)
            If RpRow.Record(RpCol.ItemIndex).Checked = True Then
                BuLok = True
            Else
                BuLok = False
            End If
            
            Set RpCol = RpCls.Find(Buh_Einnahme)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                If CDbl(RpRow.Record(RpCol.ItemIndex).Value) > 0 Then
                    BeEin = Round(RpRow.Record(RpCol.ItemIndex).Value, 2)
                Else
                    BeEin = 0
                End If
            Else
                BeEin = 0
            End If
            
            Set RpCol = RpCls.Find(Buh_Ausgabe)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                If CDbl(RpRow.Record(RpCol.ItemIndex).Value) > 0 Then
                    BeAus = Round(RpRow.Record(RpCol.ItemIndex).Value, 2)
                Else
                    BeAus = 0
                End If
            Else
                BeAus = 0
            End If

            If BuLok = False Then
                If ChDat.Value = xtpChecked Then
                    DBCmEx2 "qrySimBuDan", "@IdDat", "@IdxNr", BuDat, BuNum
                End If
                
                If ChTyp.Value = xtpChecked Then
                    DBCmEx2 "qrySimBuTyp", "@IdTyp", "@IdxNr", BuTyp, BuNum
                    If BuTyp = 1 Then 'Ausgabe
                        If BeEin > 0 Then
                            DBCmEx2 "qrySimBuEin", "@IdEin", "@IdxNr", 0, BuNum
                            DBCmEx2 "qrySimBuAus", "@IdAus", "@IdxNr", BeEin, BuNum
                        End If
                    Else
                        If BeAus > 0 Then
                            DBCmEx2 "qrySimBuEin", "@IdEin", "@IdxNr", BeAus, BuNum
                            DBCmEx2 "qrySimBuAus", "@IdAus", "@IdxNr", 0, BuNum
                        End If
                    End If
                End If

                If ChGeg.Value = xtpChecked Then 'Geldkontenanpassung
                    DBCmEx2 "qrySimBuBnk", "@IdBnk", "@IdxNr", GeKId, BuNum
                    If GlBuc = True Then 'einfache Buchhaltung verwenden
                        DBCmEx2 "qrySimBuHaK", "@IdHaK", "@IdxNr", 0, BuNum
                        DBCmEx2 "qrySimBuHaB", "@IdStr", "@IdxNr", vbNullString, BuNum
                    Else
                        DBCmEx2 "qrySimBuSaK", "@IdSaK", "@IdxNr", GeKNr, BuNum
                        DBCmEx2 "qrySimBuSaB", "@IdStr", "@IdxNr", GeKBe, BuNum
                    End If
                End If

                If ChSaK.Value = xtpChecked Then 'sachkontenanpassung
                    If GlBuc = True Then 'einfache Buchhaltung verwenden
                        DBCmEx2 "qrySimBuSaK", "@IdSaK", "@IdxNr", ErKNr, BuNum
                        DBCmEx2 "qrySimBuSaB", "@IdStr", "@IdxNr", ErKBe, BuNum
                    Else
                        DBCmEx2 "qrySimBuHaK", "@IdHaK", "@IdxNr", ErKNr, BuNum
                        DBCmEx2 "qrySimBuHaB", "@IdStr", "@IdxNr", ErKBe, BuNum
                    End If
                End If

                If ChMan.Value = xtpChecked Then
                    DBCmEx2 "qrySimBuMan", "@IdMan", "@IdxNr", mAnDa, BuNum
                End If
                
                If ChMit.Value = xtpChecked Then
                    DBCmEx2 "qrySimBuMta", "@IdMit", "@IdxNr", Mitar, BuNum
                End If
    
                If ChSto.Value = xtpChecked Then
                    DBCmEx2 "qrySimBuSto", "@IdSto", "@IdxNr", Stron, BuNum
                End If
                
                If ChAus.Value = xtpChecked Then
                    DBCmEx2 "qrySimBuErm", "@IdAus", "@IdxNr", Auswe, BuNum
                End If
            
                If ChSte.Value = xtpChecked Then
                    DBCmEx2 "qrySimBuSte", "@IdSte", "@IdxNr", Steue, BuNum
                End If
                
                If ChBel.Value = xtpChecked Then
                    DBCmEx2 "qrySimBuBe3", "@IdBel", "@IdxNr", BuBel, BuNum
                End If
            Else
                SPopu "GoBD Festschreibung", "Die markierte Buchung wurde bereits festgeschrieben.", IC48_Information
            End If
            
            BuBel = BuBel + 1
            AktPo = AktPo + 1
        End If
    Next RpRow
    
    DoEvents
    GlNeK = GlKoX 'Protokolleintrag
    With GlNeK
        .PatNr = GlMan(GlSMa, 2)
        .IdxNr = 0
        .EiDat = Format$(Date, "dd.mm.yyyy")
        .EiZei = TimeValue(Now)
        .EiTyp = 104
        .TeStr = "Buchungen angepasst - Gegenkonto: " & ChGeg.Value & " Datum: " & ChDat.Value & " Buchungstyp: " & ChTyp.Value & " Storniert: " & ChSto.Value & " Auswertung: " & ChAus.Value & " Sachkonto: " & ChSaK.Value & " Steuersatz: " & ChSte.Value & " Beleg: " & ChBel.Value
        .ZiStr = Format$(Now, "hh:mm") & " Uhr"
        .NeuEi = True
        .KeiAk = True
        .Mitar = GlMiA(GlSmI, 2)
    End With
    S_Prot
End If

Set RpCls = Nothing
Set RpSel = Nothing
Set RpCo1 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BuAnp " & Err.Number
Resume Next

End Sub
Public Sub S_BuAnS()
On Error GoTo KoErr
'Speichert eine Anfangsbuchung

Dim ManNr As Long
Dim MitNr As Long
Dim KtoSo As Long
Dim KtoHa As Long
Dim BuJah As String
Dim KtStr As String
Dim BuGui As String
Dim BuBet As Double
Dim KonBa As Integer
Dim KonWa As Integer
Dim TxBet As XtremeSuiteControls.FlatEdit
Dim TxKto As XtremeSuiteControls.FlatEdit
Dim TxKtR As XtremeSuiteControls.FlatEdit
Dim TxBez As XtremeSuiteControls.FlatEdit
Dim TxKtH As XtremeSuiteControls.FlatEdit
Dim TxBeH As XtremeSuiteControls.FlatEdit
Dim ComBu As XtremeSuiteControls.ComboBox
Dim ComWa As XtremeSuiteControls.ComboBox
Dim ComGe As XtremeSuiteControls.ComboBox
Dim ComTh As XtremeSuiteControls.ComboBox
Dim CmBrs As XtremeCommandBars.CommandBars
Dim CmCom As XtremeCommandBars.CommandBarComboBox

Set FM = frmBuAnf
Set ComBu = FM.cmbBuJah
Set ComWa = FM.cmbWarun
Set ComGe = FM.cmbGegen
Set ComTh = FM.cmbBehan
Set TxBet = FM.txtBetra
Set TxKto = FM.txtKonto
Set TxKtR = FM.txtKtoNr
Set TxBez = FM.txtBezei
Set TxKtH = FM.txtKtoHa
Set TxBeH = FM.txtBezHa
Set CmBrs = frmMain.comBar01
Set CmAcs = CmBrs.Actions

BuJah = ComBu.Text
KonWa = ComWa.ItemData(ComWa.ListIndex)
KonBa = ComGe.ItemData(ComGe.ListIndex)

If TxBet.Text <> vbNullString Then
    If IsNumeric(TxBet.Text) = True Then
        BuBet = Round(CDbl(TxBet.Text), 2)
    Else
        BuBet = 0
    End If
Else
    BuBet = 0
End If

ManNr = ComTh.ItemData(ComTh.ListIndex)

MitNr = GlMiA(GlSmI, 2)

If TxKtR.Text <> vbNullString Then
    If CLng(TxKtR.Text) > 0 Then
        KtoSo = CLng(TxKtR.Text)
    Else
        KtoSo = 0
    End If
Else
    KtoSo = 0
End If

If TxKtH.Text <> vbNullString Then
    If CLng(TxKtH.Text) > 0 Then
        KtoHa = CLng(TxKtH.Text)
    Else
        KtoHa = 0
    End If
Else
    KtoHa = 0
End If

If GlBuc = True Then 'einfache Buchhaltung verwenden
    If TxBez.Text <> vbNullString Then
        KtStr = TxBez.Text
    End If
Else
    If TxBeH.Text <> vbNullString Then
        KtStr = TxBeH.Text
    End If
End If

If BuBet <> 0 Then
    If KtoSo > 0 Then
        BuGui = CreateID("B")
        Set RS125 = New ADODB.Recordset
        With RS125 'Neue Buchung
            .CursorLocation = adUseClient
            .Source = "qrySimBuNe"
            .ActiveConnection = DB1
            .CursorType = adOpenDynamic
            .LockType = adLockOptimistic
            .Open Options:=adCmdTableDirect
        End With
        If RS125.Supports(adAddNew) Then RS125.AddNew
        RS125.Fields("Datum").Value = "01.01." & BuJah
        RS125.Fields("Buchtext").Value = "Anfangsbestand"
        RS125.Fields("Kommentar").Value = "Anfangsbestand"
        RS125.Fields("IDKurz").Value = KtStr
        RS125.Fields("IDK").Value = KtoSo
        RS125.Fields("IDB").Value = KonBa
        If GlBuc = True Then 'einfache Buchhaltung verwenden
            RS125.Fields("IDG").Value = 0
        Else
            RS125.Fields("IDG").Value = KtoHa
            RS125.Fields("Doppelt").Value = -1
        End If
        RS125.Fields("IDT").Value = ManNr
        RS125.Fields("IDM").Value = MitNr
        RS125.Fields("Währung").Value = KonWa
        RS125.Fields("Steuer").Value = 0
        RS125.Fields("Anfang").Value = -1
        RS125.Fields("Ermittlung").Value = -1
        RS125.Fields("GuiID").Value = BuGui
        If BuBet < 0 Then
            BuBet = BuBet * (-1)
            RS125.Fields("Einnahme").Value = Format$(0, GlWa1)
            RS125.Fields("Ausgabe").Value = BuBet
        Else
            RS125.Fields("Einnahme").Value = BuBet
            RS125.Fields("Ausgabe").Value = Format$(0, GlWa1)
        End If
        RS125.Fields("IDA").Value = 1
        RS125.Update
        RS125.Close
        Set RS125 = Nothing
        TxBet.Text = GlWa2
    Else
        SPopu "Keine Sachkontennummer", "Es wurde kein Sachkonto angegeben", IC48_Information
    End If
Else
    SPopu "Keine Anfangsbestand", "Es wurde kein Anfangsbestand angegeben", IC48_Information
End If

Set CmBrs = Nothing

Exit Sub

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BuAnS " & Err.Number
Resume Next

End Sub
