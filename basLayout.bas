Private Function SReSu(ByVal SuStr As String)
On Error GoTo ReErr

Dim RetWe As String
Dim AkStr As String
Dim AktZa As Integer
Dim GesZa As Integer
Dim Lange As Integer
Dim Posi1 As Integer
Dim Posi2 As Integer

GesZa = UBound(InAry)

For AktZa = 1 To GesZa
    AkStr = InAry(AktZa)
    Lange = Len(AkStr)
    Posi1 = InStrRev(AkStr, SuStr, -1, vbTextCompare)
    If Posi1 > 0 Then
        Posi2 = InStr(1, AkStr, "=", vbTextCompare)
        If Posi2 > 0 Then
            If Posi2 <= Lange Then
                RetWe = Mid$(AkStr, Posi2 + 1, Lange - Posi2)
            End If
        End If
    End If
Next AktZa

SReSu = RetWe

Exit Function

ReErr:
If GlDbg = True Then SErLog Err.Description & " SReSu " & Err.Number
Resume Next

End Function
