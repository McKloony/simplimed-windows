Private Sub SDruck3(ByVal ForNa As String, ByVal EmVer As Integer, ByVal EmAdr As String, ByVal EmBet As String, ByVal EmTex As String, Optional ByVal Krite As String, Optional KopTe As String, Optional ByVal Gesam As Boolean = False, Optional ByVal DaNam As String, Optional ByVal OhGra As Integer)
On Error GoTo InErr
'Drucken

Dim ManNr As Long
Dim MitNr As Long
Dim FiNam As String
Dim MxStr As String
Dim ExPas As String
Dim AnzPo As Integer
Dim Kopie As Integer
Dim KoPos As Integer
Dim AktPo As Integer
Dim ExVer As Boolean
Dim FaxNu As Variant
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmMain
Set RpCo5 = FM.repCont5

Set clLis = New clsLisLab

Select Case GlBut
Case RibTab_Rezeptmodul:
        Set RpCls = RpCo5.Columns
        Set RpSel = RpCo5.SelectedRows
        AnzPo = RpSel.Count
Case RibTab_Belegmodul:
        Set RpCls = RpCo5.Columns
        Set RpSel = RpCo5.SelectedRows
        AnzPo = RpSel.Count
End Select

AktPo = 1

If GlFrn <> vbNullString Then 'Formulareordner
    FiNam = GlFrn & S_FoCh(ForNa) 'Formulardaten auslesen
Else
    FiNam = GlFrO & S_FoCh(ForNa) 'Formulardaten auslesen
End If

With clLis
    .MandVo = True
    .MitaVo = GlMiV
    .ArztVo = GlArV
End With

With clLis
    .FilNam = FiNam
    .PfaTmp = GlTmp
    .Gesamt = Gesam
    .DruVor = GlDrV
    .DruDia = False
    .OhnGra = OhGra
    If GlMaV = True Then 'Mandanten vorhanden
        .MandVo = True
        Set RpRow = RpSel(0)
        Set RpCol = RpCls.Find(Rzp_IDP)
        ManNr = RpRow.Record(RpCol.ItemIndex).Value
        For AktPo = 1 To UBound(GlThe)
            If ManNr = GlThe(AktPo, 0) Then
                .MandNr = AktPo
                Exit For
            End If
        Next AktPo
    End If
    If GlMiV = True Then 'Mitarbeiter vorhanden
        Set RpRow = RpSel(0)
        Set RpCol = RpCls.Find(Rzp_IDM)
        MitNr = RpRow.Record(RpCol.ItemIndex).Value
        For AktPo = 1 To UBound(GlMiK)
            If MitNr = GlMiK(AktPo, 2) Then
                .MitaNr = AktPo
                Exit For
            End If
        Next AktPo
    End If
    Set RpCol = RpCls.Find(Rzp_EM_Pass)
    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
        ExPas = RpRow.Record(RpCol.ItemIndex).Value
    Else
        ExPas = vbNullString
    End If
    Set RpCol = RpCls.Find(Rzp_EM_Aut)
    ExVer = CBool(RpRow.Record(RpCol.ItemIndex).Value)
    If EmVer > 0 Then
        .ForNam = ForNa
        .EmlAdr = EmAdr
        .EmlBet = EmBet
        .EmlTex = EmTex
        .EmlDia = True
        .EmlSen = EmVer
    End If
    .LLPrUn 5
End With

Set clLis = Nothing

Exit Sub

InErr:
If GlDbg = True Then MsgBox Err.Description, 48, "SDruck3 " & Err.Number
Resume Next

End Sub
