For Each RpRow In RpSel
    GesRe = 0 'Reset Values
    RetPo = 0
    NeuRe = True
    ManOK = False

    If RpRow.GroupRow = False Then
        RowNr = RpRow.Index
        GloRe(AktRe) = RowNr
        
        Set RpCol = RpCls.Find(Rec_ID1)
