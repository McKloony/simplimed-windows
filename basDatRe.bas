AktPo = 1
AnzPo = RpSel.Count

ReDim GloRe(AnzPo)

If AnzPo > 1 Then
    frmStatus.Show
    DoEvents
    frmStatus.Caption = "Rechnungsstatus"
    Set Lbl01 = frmStatus.lblLab01
