IdBnk = CmGlk.ItemData(CmGlk.ListIndex)

Select Case GlBut
Case RibTab_Rezeptmodul:
    With RpCo5
        .EditItem Nothing, Nothing
        If .Records.Count > 0 Then .Records.DeleteAll
        .Populate
    End With
Case RibTab_Belegmodul:
    With RpCo5
        .EditItem Nothing, Nothing
        If .Records.Count > 0 Then .Records.DeleteAll
        .Populate
    End With
Case RibTab_Fragebogen:
    With RpCo5
        .EditItem Nothing, Nothing
        If .Records.Count > 0 Then .Records.DeleteAll
        .Populate
    End With
Case RibTab_LabBericht:
    With RpCo5
        .EditItem Nothing, Nothing
        If .Records.Count > 0 Then .Records.DeleteAll
        .Populate
    End With
Case RibTab_LabAuftrag:
    With RpCo5
        .EditItem Nothing, Nothing
        If .Records.Count > 0 Then .Records.DeleteAll
        .Populate
    End With
Case RibTab_LabBerichte:
    With RpCo1
        .EditItem Nothing, Nothing
        If .Records.Count > 0 Then .Records.DeleteAll
        .Populate
    End With
Case RibTab_LabAuftrage:
    With RpCo1
        .EditItem Nothing, Nothing
        If .Records.Count > 0 Then .Records.DeleteAll
        .Populate
    End With
