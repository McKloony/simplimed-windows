Resume Next

End Function
Public Sub S_DaExX(ByRef RST As ADODB.Recordset, ByVal FiNam As String, ByVal ExTyp As Integer, ByVal ExNam As String)
On Error GoTo SuErr
'DATEV XML Beleglink Export

Dim BuDat As Date
Dim GesZa As Long
Dim NaSpa As String
Dim CreDa As String
Dim GuiID As String
Dim ReStr As String
Dim BeStr As String
Dim GeStr As String
Dim DaStr As String
Dim DaNam As String
Dim DaExt As String
Dim BuGui As String
Dim BeGui As String
Dim AktNa As Integer
Dim AktZa As Integer
Dim BlgZa As Integer
Dim BeVor As Boolean 'Beleg vorhanden
Dim BeAry() As Variant 'Belegexport

Const BuSys = "SimpliMed"

Dim objRoot As IXMLDOMNode
Dim objDOM As New MSXML2.DOMDocument60
Dim objMainAtt As MSXML2.IXMLDOMAttribute
Dim objChildAtt As MSXML2.IXMLDOMAttribute
Dim objElement As MSXML2.IXMLDOMElement
Dim objMainNode As MSXML2.IXMLDOMNode
Dim objChildNode As MSXML2.IXMLDOMNode

Dim Levl0 As MSXML2.IXMLDOMNode
Dim Levl1 As MSXML2.IXMLDOMNode
Dim Levl2 As MSXML2.IXMLDOMNode
Dim Levl3 As MSXML2.IXMLDOMNode
Dim Levl4 As MSXML2.IXMLDOMNode
Dim Levl5 As MSXML2.IXMLDOMNode

Dim xmlDoc As Object
Dim rootElement As Object
Dim headerElement As Object
Dim contentElement As Object
Dim documentElement As Object
Dim repositoryElement As Object
Dim levelElement As Object

If RST.EOF Or RST.BOF Then Exit Sub

ReDim BeAry(1)

GesZa = RST.RecordCount
CreDa = Format$(Date, "yyyy-mm-dd") & "T" & Format$(Now, "hh:mm:ss") '"2018-06-11T09:23:48Z"

' Create XML Document
Set xmlDoc = CreateObject("MSXML2.DOMDocument.6.0")
xmlDoc.async = False
xmlDoc.preserveWhiteSpace = True
xmlDoc.appendChild xmlDoc.createProcessingInstruction("xml", "version=""1.0"" encoding=""utf-8""")

' Add Root Element
Set rootElement = xmlDoc.CreateNode(1, "archive", "http://xml.datev.de/bedi/tps/document/v04.0")
rootElement.setAttribute "xmlns:xsi", "http://www.w3.org/2001/XMLSchema-instance"
rootElement.setAttribute "xsi:schemaLocation", "http://xml.datev.de/bedi/tps/document/v04.0 document_v040.xsd"
rootElement.setAttribute "version", "4.0"
rootElement.setAttribute "generatingSystem", BuSys
xmlDoc.appendChild rootElement
rootElement.appendChild xmlDoc.createTextNode(vbCrLf)
rootElement.appendChild xmlDoc.createTextNode(vbTab)

' Add Header Element
Set headerElement = xmlDoc.CreateNode(1, "header", "http://xml.datev.de/bedi/tps/document/v04.0")
rootElement.appendChild headerElement
rootElement.appendChild xmlDoc.createTextNode(vbCrLf)
rootElement.appendChild xmlDoc.createTextNode(vbTab)
    
Dim dateElement As Object
Set dateElement = xmlDoc.CreateNode(1, "date", "http://xml.datev.de/bedi/tps/document/v04.0")
dateElement.Text = CreDa
headerElement.appendChild dateElement
headerElement.appendChild xmlDoc.createTextNode(vbCrLf)
headerElement.appendChild xmlDoc.createTextNode(vbTab)
headerElement.appendChild xmlDoc.createTextNode(vbTab)

' Add Content Element
Set contentElement = xmlDoc.CreateNode(1, "content", "http://xml.datev.de/bedi/tps/document/v04.0")
rootElement.appendChild contentElement
rootElement.appendChild xmlDoc.createTextNode(vbCrLf)
rootElement.appendChild xmlDoc.createTextNode(vbTab)
rootElement.appendChild xmlDoc.createTextNode(vbTab)
    
' Add Documents
'----run loop here for all document tags----

Do
BeVor = False 'Beleg vorhanden
DaNam = vbNullString
BuGui = vbNullString
BeStr = vbNullString
BeGui = vbNullString

Select Case ExTyp
Case 1:
    BeStr = RST.Fields("Beleg").Value
    ReStr = RST.Fields("RechNr").Value
    DaNam = RST.Fields("Datei").Value
Case 2:
    BeStr = RST.Fields("Nummer").Value
    ReStr = RST.Fields("Belegzeichen").Value
    DaNam = RST.Fields("Datei").Value
Case 3:
    BeStr = RST.Fields("Z?hler").Value
    ReStr = RST.Fields("Rechnung").Value
End Select

BuDat = CDate(RST.Fields("Datum").Value)
DaStr = Format$(RST.Fields("Datum").Value, "dd.mm.yyyy")

If DaNam <> vbNullString Then
    If Len(DaNam) > 46 Then
        DaExt = Right$(DaNam, 4)
        DaNam = Left$(DaNam, 41) & DaExt
    End If
Else
    If ReStr <> vbNullString Then
        DaNam = "Rechnung_Beleg_" & ReStr & ".pdf"
    End If
End If

If DaNam <> vbNullString Then
    BuGui = RST.Fields("GuiID").Value
    BeGui = LCase(Mid$(BuGui, 2, 8) & Chr$(45) & Mid$(BuGui, 10, 4) & Chr$(45) & Mid$(BuGui, 14, 4) & Chr$(45) & Mid$(BuGui, 18, 4) & Chr$(45) & Mid$(BuGui, 22, 12))
    For AktZa = 1 To UBound(BeAry)
        If BeAry(AktZa) = DaNam Then
            BeVor = True 'Beleg vorhanden
            Exit For
        End If
    Next AktZa
    If BeVor = False Then 'Beleg vorhanden
        BelZa = BelZa + 1
        ReDim Preserve BeAry(BelZa)
        BeAry(BelZa) = DaNam
    End If
End If

If BeVor = False And DaNam <> vbNullString Then 'Beleg vorhanden
    If ReStr <> vbNullString Then
        GeStr = "Beleg: " & ReStr & ", Datum: " & DaStr
    ElseIf BeStr <> vbNullString Then
        GeStr = "Beleg: " & BeStr & ", Datum: " & DaStr
    Else
        GeStr = "Datum: " & DaStr
    End If
    
    Set documentElement = xmlDoc.CreateNode(1, "document", "http://xml.datev.de/bedi/tps/document/v04.0")
    documentElement.setAttribute "guid", BeGui
    contentElement.appendChild documentElement
    contentElement.appendChild xmlDoc.createTextNode(vbCrLf)
    contentElement.appendChild xmlDoc.createTextNode(vbTab)
    contentElement.appendChild xmlDoc.createTextNode(vbTab)
        
    ' Add Keywords
    Dim keywordsElement As Object
    Set keywordsElement = xmlDoc.CreateNode(1, "keywords", "http://xml.datev.de/bedi/tps/document/v04.0")
    keywordsElement.Text = GeStr
    documentElement.appendChild keywordsElement
    documentElement.appendChild xmlDoc.createTextNode(vbCrLf)
    documentElement.appendChild xmlDoc.createTextNode(vbTab)
    documentElement.appendChild xmlDoc.createTextNode(vbTab)
   
    ' Add Extension
    Dim extensionElement As Object
    Set extensionElement = xmlDoc.CreateNode(1, "extension", "http://xml.datev.de/bedi/tps/document/v04.0")
    extensionElement.setAttribute "xsi:type", "File"
    extensionElement.setAttribute "name", DaNam
    documentElement.appendChild extensionElement
    documentElement.appendChild xmlDoc.createTextNode(vbCrLf)
    documentElement.appendChild xmlDoc.createTextNode(vbTab)
    documentElement.appendChild xmlDoc.createTextNode(vbTab)

    ' Add Repository
    Set repositoryElement = xmlDoc.CreateNode(1, "repository", "http://xml.datev.de/bedi/tps/document/v04.0")
    documentElement.appendChild repositoryElement
    documentElement.appendChild xmlDoc.createTextNode(vbCrLf)
    documentElement.appendChild xmlDoc.createTextNode(vbTab)
    documentElement.appendChild xmlDoc.createTextNode(vbTab)
    documentElement.appendChild xmlDoc.createTextNode(vbTab)

    '--------LOOP REPOSITORY LEVELS HERE-----
    
    Dim levelNames(2) As String
    levelNames(0) = BuSys
    levelNames(1) = "Belege"
    levelNames(2) = Year(BuDat) & "/" & Month(BuDat)
        
    For AktNa = 0 To 2
        Set levelElement = xmlDoc.CreateNode(1, "level", "http://xml.datev.de/bedi/tps/document/v04.0")
        levelElement.setAttribute "id", AktNa + 1
        levelElement.setAttribute "name", levelNames(AktNa)
        repositoryElement.appendChild levelElement
        repositoryElement.appendChild xmlDoc.createTextNode(vbCrLf)
        repositoryElement.appendChild xmlDoc.createTextNode(vbTab)
        repositoryElement.appendChild xmlDoc.createTextNode(vbTab)
        repositoryElement.appendChild xmlDoc.createTextNode(vbTab)
    Next AktNa
End If

RST.MoveNext
Loop Until RST.EOF

If RST.EOF = False Then
    BuDat = CDate(RST.Fields("Datum").Value)
    DaStr = Format$(Date, "dd.mm.yyyy")
    DaNam = ExNam
    BuGui = CreateID("E")
    BeGui = LCase(Mid$(BuGui, 2, 8) & Chr$(45) & Mid$(BuGui, 10, 4) & Chr$(45) & Mid$(BuGui, 14, 4) & Chr$(45) & Mid$(BuGui, 18, 4) & Chr$(45) & Mid$(BuGui, 22, 12))
    GeStr = "DATEV-Buchungsdatei " & DaStr
      
    Set documentElement = xmlDoc.CreateNode(1, "document", "http://xml.datev.de/bedi/tps/document/v04.0")
    documentElement.setAttribute "guid", BeGui
    contentElement.appendChild documentElement
    contentElement.appendChild xmlDoc.createTextNode(vbCrLf)
    contentElement.appendChild xmlDoc.createTextNode(vbTab)
    contentElement.appendChild xmlDoc.createTextNode(vbTab)
         
    ' Add Keywords
    Dim keywordsElement2 As Object
    Set keywordsElement2 = xmlDoc.CreateNode(1, "keywords", "http://xml.datev.de/bedi/tps/document/v04.0")
    keywordsElement2.Text = GeStr
    documentElement.appendChild keywordsElement2
    documentElement.appendChild xmlDoc.createTextNode(vbCrLf)
    documentElement.appendChild xmlDoc.createTextNode(vbTab)
    documentElement.appendChild xmlDoc.createTextNode(vbTab)
    
    ' Add Extension
    Dim extensionElement2 As Object
    Set extensionElement2 = xmlDoc.CreateNode(1, "extension", "http://xml.datev.de/bedi/tps/document/v04.0")
    extensionElement2.setAttribute "xsi:type", "File"
    extensionElement2.setAttribute "name", DaNam
    documentElement.appendChild extensionElement2
    documentElement.appendChild xmlDoc.createTextNode(vbCrLf)
    documentElement.appendChild xmlDoc.createTextNode(vbTab)
    documentElement.appendChild xmlDoc.createTextNode(vbTab)
    
    ' Add Repository
    Set repositoryElement = xmlDoc.CreateNode(1, "repository", "http://xml.datev.de/bedi/tps/document/v04.0")
    documentElement.appendChild repositoryElement
    documentElement.appendChild xmlDoc.createTextNode(vbCrLf)
    documentElement.appendChild xmlDoc.createTextNode(vbTab)
    documentElement.appendChild xmlDoc.createTextNode(vbTab)
    documentElement.appendChild xmlDoc.createTextNode(vbTab)

    '--------LOOP REPOSITORY LEVELS HERE-----

    Dim levelNames2(2) As String
    levelNames2(0) = BuSys
    levelNames2(1) = "Belege"
    levelNames2(2) = Year(BuDat) & "/" & Month(BuDat)
        
    For AktNa = 0 To 2
        Set levelElement = xmlDoc.CreateNode(1, "level", "http://xml.datev.de/bedi/tps/document/v04.0")
        levelElement.setAttribute "id", AktNa + 1
        levelElement.setAttribute "name", levelNames2(AktNa)
        repositoryElement.appendChild levelElement
        repositoryElement.appendChild xmlDoc.createTextNode(vbCrLf)
        repositoryElement.appendChild xmlDoc.createTextNode(vbTab)
        repositoryElement.appendChild xmlDoc.createTextNode(vbTab)
        repositoryElement.appendChild xmlDoc.createTextNode(vbTab)
    Next AktNa
End If

DoEvents
xmlDoc.Save FiNam

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_DaExX " & Err.Number
Resume Next

End Sub
Public Function S_DaKoK(ByVal GeKto As Integer) As Long
On Error Resume Next

Dim SaKto As Long
Dim AktZa As Integer

For AktZa = 1 To UBound(GlGeK) 'Geldkonten
    If GlGeK(AktZa, 0) = GeKto Then 'Standardgeldkonto Bankkonto
        If GlGeK(AktZa, 2) <> vbNullString Then
            SaKto = S_DaExF(GlGeK(AktZa, 2))
        Else
            If GldKt = True Then 'DATEV Schnittstelle Sachkonten vierstellig
                SaKto = 1200
            Else
                SaKto = 120000
            End If
        End If
        Exit For
    End If
Next AktZa

S_DaKoK = SaKto

End Function

Private Function S_DaKoW(ByVal WarId As Long) As String
On Error Resume Next

Select Case WarId
Case 1: S_DaKoW = "EUR" 'EUR
Case 2: S_DaKoW = "EUR" 'EUR
Case Else: S_DaKoW = "???" 'Unbekannt
End Select

End Function

Private Function S_DaKoZ(TmVal As Variant) As Long
On Error Resume Next

If IsNull(TmVal) = True Then
    S_DaKoZ = 0
Else
    S_DaKoZ = Val(TmVal)
End If
  
End Function
