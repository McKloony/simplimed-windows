        Set RpItm = RpRec.AddItem(Format$(RS144.Fields("BezBetrag").Value, GlWa1))
        RpItm.Alignment = xtpAlignmentRight
        Set RpItm = RpRec.AddItem(Format$(RS144.Fields("BezBetrag2").Value, GlWa1))
        If RS144.Fields("BezBetrag2").Value > 0 Then
            Set RpItm = RpRec.AddItem(Format$(RS144.Fields("SerBetrag").Value - RS144.Fields("BezBetrag").Value - RS144.Fields("BezBetrag2").Value, GlWa1))
        Else
            Set RpItm = RpRec.AddItem(Format$(RS144.Fields("SerBetrag").Value - RS144.Fields("BezBetrag").Value, GlWa1))
        End If
        RpItm.Alignment = xtpAlignmentRight
        Set RpItm = RpRec.AddItem(RS144.Fields("Fallig1").Value)
        RpItm.Alignment = xtpAlignmentCenter
        Set RpItm = RpRec.AddItem(RS144.Fields("Fallig2").Value)
        RpItm.Alignment = xtpAlignmentCenter
        Set RpItm = RpRec.AddItem(RS144.Fields("Farbe").Value)
        With RpItm
            .Tag = "_Farbe"
            .Focusable = False
        End With
        RS144.MoveNext
        Loop Until RS144.EOF
        Rpc12.Populate
        If RpRws.Count > 0 Then
            RpRws(0).Selected = False
        End If
    End Select
End If

RS144.Close
Set RS144 = Nothing

Set RpRws = Nothing
Set Rpc12 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then SErLog Err.Description & " S_StSt3 " & Err.Number
Resume Next

End Sub
Public Sub S_TeExT()
On Error GoTo LiErr
'Exporiert die Termine SMT

Dim TerNr As Long
Dim AnzTe As Long 'Anzahl Termine
Dim AktZa As Long
Dim ArGes As Long
Dim AkZei As Long
Dim AkSpa As Long
Dim ArSpa As Long
Dim BehNr As Long 'Behandlernummer
Dim SQL1 As String
Dim DaNam As String 'Dateinamen
Dim TmStr As String 'Tempstring
Dim AnwNa As String 'Anmwendername
Dim EmAdr As String 'Emailadresse
Dim FilNa As String 'Filename
Dim DaPfa As String 'Pfadnamen
Dim ZeiTe As Boolean
Dim Umlau As Boolean
Dim ZeiBu As Boolean
Dim ZeiUm As Boolean
Dim RetWe As Boolean
Dim AktEi As Integer
Dim BloZa As Integer
Dim AkBlo As Integer
Dim Frage As Integer
Dim TeAry As Variant
Dim TmAry() As String
Dim Mld1, Tit1 As String
Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Const BlGro = 100

Set FM = frmMain
Set CoDia = FM.comDialo
Set RpCo1 = FM.repCont1
Set RpSel = RpCo1.SelectedRows
Set RpCls = RpCo1.Columns

ZeiUm = CBool(IniGetVal("System", "PADZei"))
Umlau = CBool(IniGetVal("System", "PADUml"))
Mld1 = "Die Datei existiert bereits, soll diese überschrieben werden?"
Tit1 = "Stammdatenexport"
AktEi = 1

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

Set RpRow = RpSel(0)
Set RpCol = RpCls.Find(Ter_IDP)
BehNr = RpRow.Record(RpCol.ItemIndex).Value

S_AdDe BehNr 'Adressendetails
With GlADt
    AnwNa = .AdVor & Chr$(32) & .AdNam
    If .AdTe5 <> vbNullString Then
        EmAdr = .AdTe5
    Else
        EmAdr = vbNullString
    End If
End With

AnwNa = SUmw(AnwNa, True, True, True, True)

DaNam = AnwNa & "_" & Format$(DatePart("d", Date, vbMonday), "00") & Format$(DatePart("m", Date, vbMonday), "00") & DatePart("yyyy", Date, vbMonday) & "_X.smt"

With CoDia
    .CancelError = True
    .DialogStyle = 1
    .DefaultExt = "*.smt"
    .Filter = "SimpliMed Termine (*.smt)|*.smt|Alle Dateien (*.*)|*.*"
    .DialogTitle = "Bitte Name und Ordner der Abrechnungsdatei angeben"
    .FileName = GlEPf & DaNam
    .InitDir = GlEPf
    .ShowSave
    FilNa = .FileName
    If .FileTitle = vbNullString Then
        Set CoDia = Nothing
        Set RpSel = Nothing
        Set RpCls = Nothing
        Set RpCo1 = Nothing
        Set clFil = Nothing
        Exit Sub
    End If
End With
If Right$(FilNa, 4) <> ".smt" Then
    FilNa = FilNa & ".smt"
End If

With clFil
    .FilPfa FilNa
    DaPfa = .DaPfa

    If .FilVor(FilNa) = True Then
        Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
        If Frage = 6 Then
            .DaLoe = FilNa & vbNullChar
            .FilLoe
        Else
            Exit Sub
        End If
    End If
End With

If Not IsNull(FilNa) And Not FilNa = vbNullString Then
    frmStatus.Show
    DoEvents
    frmStatus.Caption = "Termineexport"
    Set Lbl01 = frmStatus.lblLab01
    Set PrBr1 = frmStatus.prbStat1
    Set PrBr2 = frmStatus.prbStat2
    Set TxDum = frmStatus.txtDummy
    Lbl01.Caption = "Bitte warten..."

    DBCmEx1 "qryTerDrAu", "@IdDru", 0 'remarkieren aller noch markierter Termine
    DoEvents
    
    PrBr2.Min = 0
    PrBr2.Max = RpSel.Count
    
    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            Set RpCol = RpCls.Find(Ter_ID2)
            TerNr = RpRow.Record(RpCol.ItemIndex).Value
            DBCmEx2 "qryTerDru", "@IdDru", "@IdxNr", -1, TerNr '[Drucken] markieren
            DoEvents
            AktZa = AktZa + 1
        End If
    PrBr2.Value = RpRow.Index
    DoEvents
    Next RpRow
            
    '---

    Set RS127 = New ADODB.Recordset
    RS127.CursorLocation = adUseClient
    Set RS127 = DBCmRe0("qryTerLiDr")
    AnzTe = RS127.RecordCount
    
    If AnzTe > 0 Then
        TeAry = RS127.GetRows 'Zuweisen der Termine
        DoEvents
        
        If ZeiTe = False Then
            For Each FL101 In RS127.Fields 'Überschriften
                If TmStr = vbNullString Then
                    TmStr = FL101.Name & Chr$(59)
                Else
                    TmStr = TmStr & FL101.Name & Chr$(59)
                End If
            Next FL101
            If ZeiUm = True Then
                TmStr = TmStr & vbCrLf
            Else
                TmStr = TmStr & "|"
            End If
            ZeiTe = True
        End If
        
        ArGes = UBound(TeAry, 2)
        ArSpa = UBound(TeAry, 1)
    
        If ArGes > BlGro Then
            BloZa = Fix(ArGes / BlGro) + 1
            ReDim TmAry(BloZa)
            AktZa = 0
            PrBr1.Min = 0
            PrBr1.Max = BlGro
            PrBr2.Min = 0
            PrBr2.Max = BloZa + 1
            
            For AkBlo = 0 To BloZa
                PrBr2.Value = AkBlo + 1
                For AkZei = 0 To BlGro  'Zeilen
                    For AkSpa = 0 To ArSpa 'Spalten
                        If AktZa <= ArGes Then
                            If TeAry(AkSpa, AktZa) <> vbNullString Then
                                TmAry(AkBlo) = TmAry(AkBlo) & SUmw(TeAry(AkSpa, AktZa), False, Umlau) & Chr$(59)
                            Else
                                TmAry(AkBlo) = TmAry(AkBlo) & Space$(1) & Chr$(59)
                            End If
                        End If
                    Next AkSpa
                    AktZa = AktZa + 1
                    If ZeiUm = True Then
                        TmAry(AkBlo) = TmAry(AkBlo) & vbCrLf
                    Else
                        If TmAry(AkBlo) <> vbNullString Then
                            If Right$(TmAry(AkBlo), 2) <> "||" Then
                                TmAry(AkBlo) = TmAry(AkBlo) & "|"
                            End If
                        End If
                    End If
                    DoEvents
                    If TxDum.Text = "B" Then Exit For 'Abbrechen
                    PrBr1.Value = AkZei
                Next AkZei
                If TmStr = vbNullString Then
                    TmStr = TmAry(AkBlo)
                Else
                    TmStr = TmStr & TmAry(AkBlo)
                End If
            Next AkBlo
        Else
            PrBr1.Min = 0
            PrBr1.Max = ArGes
            PrBr2.Min = 0
            PrBr2.Max = AnzTe + 1
            
            For AkZei = 0 To ArGes 'Zeilen
                PrBr2.Value = AkZei + 1
                For AkSpa = 0 To ArSpa 'Spalten
                    If TeAry(AkSpa, AkZei) <> vbNullString Then
                        TmStr = TmStr & SUmw(TeAry(AkSpa, AkZei), False, Umlau) & Chr$(59)
                    Else
                        TmStr = TmStr & Space$(1) & Chr$(59)
                    End If
                Next AkSpa
                If ZeiUm = True Then
                    TmStr = TmStr & vbCrLf
                Else
                    TmStr = TmStr & "|"
                End If
                DoEvents
                If TxDum.Text = "B" Then Exit For 'Abbrechen
                PrBr1.Value = AkZei
            Next AkZei
        End If
        RS127.Close
        Set RS127 = Nothing

        '---
        
        DoEvents
        Unload frmStatus
        Set frmStatus = Nothing
        
        DoEvents
        If Len(TmStr) > 10 Then
            With clFil
                .FilPfa FilNa
                .StrDa = TmStr
                RetWe = .FilWrSt
                .StrDa = vbNullString
            End With
        End If
    End If

    '---
    
    DBCmEx1 "qryTerDrAu", "@IdDru", 0 'remarkieren aller noch markierter Termine
    DoEvents
    
    MsgBox "Es wurden " & AnzTe & " Termine exportiert"
End If

DoEvents
GlNeK = GlKoX 'Protokolleintrag
With GlNeK
    .PatNr = BehNr
    .IdxNr = 0
    .EiDat = Format$(Date, "dd.mm.yyyy")
    .EiZei = TimeValue(Now)
    .EiTyp = 104
    .TeStr = "Exportiert - SMT Datei - (" & AnzTe & " Termine)"
    .ZiStr = Format$(Now, "hh:mm") & " Uhr"
    .NeuEi = True
    .KeiAk = True
    .Mitar = GlMiA(GlSmI, 2)
End With
S_Prot

Set CoDia = Nothing
Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo1 = Nothing

Set clFil = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TeExT " & Err.Number
Exit Sub

End Sub

Public Sub S_TeImT(ByVal ManNr As Long, MitNr As Long)
On Error GoTo LiErr
'Termineimport smt-Datei

Dim StMit As Long
Dim AktZe As Long
Dim AktFe As Long
Dim AnzPo As Long
Dim AnzTe As Long
Dim AktTe As Long
Dim FiNam As String 'Filename
Dim DaExt As String 'Dateiendung
