    If ReAbs = True Then
        TmpSt = TmpSt & Chr$(34) & "1" & Chr$(34) & ExSep 'Festschreibung
    Else
        TmpSt = TmpSt & Chr$(34) & "0" & Chr$(34) & ExSep 'Festschreibung
    End If
Case "txt":
    TmpSt = vbNullString
    TmpSt = TmpSt & Format$(ReDat, "dd.mm.yyyy") & ExSep 'Belegdatum
    TmpSt = TmpSt & Format$(ReDat, "dd.mm.yyyy") & ExSep 'Buchungsdatum
    TmpSt = TmpSt & vbNullString & ExSep 'Belegnummernkreis
    TmpSt = TmpSt & ReStr & ExSep 'Belegnummer
    TmpSt = TmpSt & BuStr & ExSep 'Buchungstext
