                                End If
                            Else
                                TmpSt = TmpSt & vbCrLf
                            End If
                            DoEvents
                            If TxDum.Text = "B" Then Exit For 'Abbrechen
                            PrBr1.Value = AkZei
                        Next AkZei
                    End If
    
                    DoEvents
                    With clFil
                        .StrDa = TmpSt
                        RetWe = .FilWrSt
                    End With

                End If
                
                DoEvents
                Unload frmStatus
                Set frmStatus = Nothing
                
            End If
            RS122.Close
            Set RS122 = Nothing
            
            Screen.MousePointer = vbNormal
        End If
    End If
End If

