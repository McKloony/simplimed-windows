Public Function S_ReTxe(ByVal IdxNr As Long) As Date
On Error GoTo KoErr
'Ermittelt den Ersttermin für Einzelbriefübergabe

Dim SQL1 As String
Dim GesZa As Long
Dim LeiDa As Date

If GlTyp < 2 Then
    SQL1 = "SELECT * FROM dbo.qrySimAbKra03 WHERE ID0=" & IdxNr & " ORDER BY Datum, ID3" 'Datum aufsteigend
Else
    SQL1 = "SELECT * FROM qrySimAbKra03 WHERE [ID0]=" & IdxNr & " ORDER BY [Datum], [ID3];" 'Datum aufsteigend
End If

Set RS126 = New ADODB.Recordset
With RS126
    .CursorLocation = adUseClient
    .Source = SQL1
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdText
End With
GesZa = RS126.RecordCount
If GesZa > 0 Then
    If RS126.Fields("Datum").Value <> vbNullString Then
        If IsDate(RS126.Fields("Datum").Value) = True Then
            LeiDa = Format$(RS126.Fields("Datum").Value, "dd.mm.yyyy")
        Else
            LeiDa = Date
        End If
    Else
        LeiDa = Date
    End If
Else
    LeiDa = Date
End If
RS126.Close
Set RS126 = Nothing

S_ReTxe = LeiDa

Exit Function

KoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReTxe " & Err.Number
Resume Next

End Function
Public Function S_ReVo(ByVal NeuDa As Date, ByVal ReTyp As String, Optional ByVal MaNum As Long, Optional ByVal MiNum As Long, Optional ByVal ReNum As Boolean = True) As String
On Error GoTo SuErr
'Schlägt eine neue Rechnungsnummer vor

Dim NeuRe As Long
Dim ReJah As Long
Dim AktZa As Long
Dim GesZa As Long
Dim SQL1 As String
Dim AkJah As String
Dim AkMon As String
Dim NeuSt As String

AkJah = Right$(Year(NeuDa), 2)
AkMon = Format$(Month(NeuDa), "00")

If IsDate(NeuDa) = True Then
    ReJah = Year(NeuDa)
Else
    ReJah = Year(Date)
End If
 
If ReTyp = "U" Or ReTyp = "V" Or ReTyp = "M" Then

    Set RS120 = New ADODB.Recordset
    RS120.CursorLocation = adUseClient
    
    If GlRMa = True Then 'getrennter Mandentenrechnungsnummernkreis
        If GlRnm = True Then 'Neustart Rechnungsnummer am Jahrenanfang
            Set RS120 = DBCmRe3("qrySimReVt2", "@IdxNr", "@IdJah", "@IdStr", MaNum, ReJah, ReTyp)
        Else
            Set RS120 = DBCmRe2("qrySimReVt1", "@IdxNr", "@IdStr", MaNum, ReTyp)
        End If
    Else
        If GlRnm = True Then 'Neustart Rechnungsnummer am Jahrenanfang
            Set RS120 = DBCmRe2("qrySimReVt3", "@IdJah", "@IdStr", ReJah, ReTyp)
        Else
            Set RS120 = DBCmRe1("qrySimReVt0", "@IdStr", ReTyp)
        End If
    End If

Else

    If GlTyp < 2 Then
        SQL1 = "SELECT * FROM dbo.qrySimReVor ORDER BY PLZ DESC"
    Else
        SQL1 = "SELECT * FROM qrySimReVor ORDER BY [PLZ] DESC;"
    End If
    Set RS120 = New ADODB.Recordset
    RS120.CursorLocation = adUseClient
    
    If GlRMa = True Then 'getrennter Mandentenrechnungsnummernkreis
        If GlRnm = True Then 'Neustart Rechnungsnummer am Jahrenanfang
            Set RS120 = DBCmRe2("qrySimReVo2", "@IdxNr", "@IdJah", MaNum, ReJah)
        Else
            Set RS120 = DBCmRe1("qrySimReVo1", "@IdxNr", MaNum)
        End If
    Else
        If GlRnm = True Then 'Neustart Rechnungsnummer am Jahrenanfang
            Set RS120 = DBCmRe1("qrySimReVo3", "@IdJah", ReJah)
        Else
            Set RS120 = DBCmRe0(SQL1, True)
        End If
    End If

End If

GesZa = RS120.RecordCount

If GesZa > 0 Then
    If Len(RS120.Fields("PLZ").Value) > 0 Then
        NeuRe = Val(RS120.Fields("PLZ").Value) + 1
    Else
        NeuRe = Val(S_ReNx()) + 1
    End If
    
    ReDim GlRec(GesZa, 6)
    Do
    GlRec(AktZa, 1) = RS120.Fields("RechNr").Value
    GlRec(AktZa, 2) = RS120.Fields("IDKurz").Value
    GlRec(AktZa, 3) = RS120.Fields("Datum").Value
    GlRec(AktZa, 4) = RS120.Fields("Storniert").Value
    GlRec(AktZa, 5) = RS120.Fields("Selekt").Value
    GlRec(AktZa, 6) = RS120.Fields("Type").Value
    AktZa = AktZa + 1
    RS120.MoveNext
    Loop Until RS120.EOF
Else
    ReDim GlRec(0, 6)
    NeuRe = 1
End If

RS120.Close
Set RS120 = Nothing

If ReNum = True Then
    Select Case GlRFm
    Case 2: NeuSt = AkJah & "-" & AkMon & "-" & Format$(NeuRe, "000000")
    Case 3: NeuSt = AkJah & AkMon & "-" & Format$(NeuRe, "000000")
    Case 4: NeuSt = AkJah & "-" & Format$(NeuRe, "000000")
    Case 5: NeuSt = AkJah & AkMon & "-" & Format$(NeuRe, "0000")
    End Select
Else
    NeuSt = "-"
End If

S_ReVo = NeuSt

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReVo " & Err.Number
Resume Next

End Function
Public Function S_ReVr(ByVal ReStr As String, ByVal ReTyp As String, ByVal ManNr As Long, ByVal ReDat As Date) As Boolean
On Error GoTo SuErr
'Rechnungsnummer bereits vorhanden?

Dim GesZa As Long
Dim ReNum As Long
Dim RePru As String
Dim AkJah As Integer
Dim Posit As Integer
Dim Lange As Integer
Dim ReVor As Boolean

AkJah = Year(ReDat)
Lange = Len(ReStr)
If Lange > 6 Then
    Posit = InStrRev(ReStr, "-", Len(ReStr), 1)
    If Posit > 0 Then
        ReNum = CLng(Mid$(ReStr, Posit + 1, Lange - Posit))
        RePru = Format$(ReNum, "00000000")
        
        If ReTyp = "U" Or ReTyp = "V" Or ReTyp = "M" Then
            Set RS125 = New ADODB.Recordset
            RS125.CursorLocation = adUseClient
            If GlRMa = True Then 'Rechnungsnummern-Kreis für jeden Mandanten
                If GlRnm = True Then 'Neustart der Rechnungsnummer am Jahresanfang
                    Set RS125 = DBCmRe4("qrySimRePr8", "@IdStr", "@IdJah", "@IdMan", "@IdTyp", RePru, AkJah, ManNr, ReTyp)
                Else
                    Set RS125 = DBCmRe3("qrySimRePr6", "@IdStr", "@IdMan", "@IdTyp", RePru, ManNr, ReTyp)
                End If
            Else
                If GlRnm = True Then 'Neustart der Rechnungsnummer am Jahresanfang
                    Set RS125 = DBCmRe3("qrySimRePr7", "@IdStr", "@IdJah", "@IdTyp", RePru, AkJah, ReTyp)
                Else
                    Set RS125 = DBCmRe2("qrySimRePr5", "@IdStr", "@IdTyp", RePru, ReTyp)
                End If
            End If
            GesZa = RS125.RecordCount
            If GesZa > 0 Then
                ReVor = True
            End If
            RS125.Close
            Set RS125 = Nothing
        Else
            Set RS125 = New ADODB.Recordset
            RS125.CursorLocation = adUseClient
            If GlRMa = True Then 'Rechnungsnummern-Kreis für jeden Mandanten
                If GlRnm = True Then 'Neustart der Rechnungsnummer am Jahresanfang
                    Set RS125 = DBCmRe3("qrySimRePr4", "@IdStr", "@IdJah", "@IdMan", RePru, AkJah, ManNr)
                Else
                    Set RS125 = DBCmRe2("qrySimRePr2", "@IdStr", "@IdMan", RePru, ManNr)
                End If
            Else
                If GlRnm = True Then 'Neustart der Rechnungsnummer am Jahresanfang
                    Set RS125 = DBCmRe2("qrySimRePr3", "@IdStr", "@IdJah", RePru, AkJah)
                Else
                    Set RS125 = DBCmRe1("qrySimRePr1", "@IdStr", RePru)
                End If
            End If
            GesZa = RS125.RecordCount
            If GesZa > 0 Then
                ReVor = True
            End If
            RS125.Close
            Set RS125 = Nothing
        End If
        
    Else
        ReVor = True
    End If
Else
    ReVor = True
End If

S_ReVr = ReVor

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReVr " & Err.Number
Resume Next

End Function
