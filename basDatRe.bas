                    Else
                        ReAbg = False
                    End If
                    Set RpCol = RpCls.Find(Rec_IDKurz)
                    PatSt = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Rec_Lock)
