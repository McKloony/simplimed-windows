Private Function S_WaRec(ByRef RST As ADODB.Recordset, Optional ByVal SuStr As String) As Long
On Error GoTo LiErr

Dim ZeVon As Date
Dim ZeAkt As Date
Dim ZeiAn As Date
Dim MiDif As Integer
Dim RpCo6 As XtremeReportControl.ReportControl

Set FM = frmMain
Set RpCo6 = frmMain.repCont6
Set RpRcs = RpCo6.Records

S_WaRec = 0

Do
If RST.Fields("Wartezimmer").Value <> vbNullString Then
    If CInt(RST.Fields("Wartezimmer").Value) = 1 Then
        If IsDate(RST.Fields("ZeiVon").Value) = True Then
            If IsDate(RST.Fields("ZeiAN").Value) = True Then
                ZeiAn = TimeValue(RST.Fields("ZeiAN").Value)
                ZeVon = TimeValue(RST.Fields("ZeiVon").Value)
                ZeAkt = TimeValue(Now)
                If ZeiAn > ZeVon Then
                    MiDif = DateDiff("n", ZeiAn, ZeAkt)
                Else
                    MiDif = DateDiff("n", ZeVon, ZeAkt)
                End If
            Else
                ZeVon = TimeValue(RST.Fields("ZeiVon").Value)
                ZeAkt = TimeValue(Now)
                MiDif = DateDiff("n", ZeVon, ZeAkt)
            End If
        Else
            MiDif = 0
        End If
    Else
        MiDif = 0
    End If
Else
    MiDif = 0
End If
Set RpRec = RpRcs.Add()
Set RpItm = RpRec.AddItem(RST.Fields("ID0").Value)
Set RpItm = RpRec.AddItem(RST.Fields("ID2").Value)
Set RpItm = RpRec.AddItem(RST.Fields("IDR").Value)
Set RpItm = RpRec.AddItem(RST.Fields("IDSer").Value)
Set RpItm = RpRec.AddItem(vbNullString) 'Ter_Icon
If CBool(RST.Fields("OnlTer").Value) = True Then
    RpItm.Icon = IC16_Phone_Mobil
Else
    RpItm.Icon = IC16_Calendar_Day
End If
Set RpItm = RpRec.AddItem(vbNullString) 'Ter_Aufgabe - Abgerechnet Ja / Nein
If RST.Fields("Wiederholung").Value = -1 Then
    If RST.Fields("Aufgabe").Value = -1 Then
        RpItm.Icon = IC16_Mail_Close
    Else
        RpItm.Icon = IC16_Mail_Open
    End If
End If
Set RpItm = RpRec.AddItem(vbNullString) 'Ter_Status
Select Case RST.Fields("Farbtyp").Value
Case 1: RpItm.Icon = IC16_Pin_Green
Case 2: RpItm.Icon = IC16_Pin_Gray
Case 3:
Case 4: RpItm.Icon = IC16_Pin_Red
End Select
Set RpItm = RpRec.AddItem(RST.Fields("ZeiAN").Value)
RpItm.Format = "%H:%M"
Set RpItm = RpRec.AddItem(RST.Fields("ZeiVon").Value)
RpItm.Format = "%H:%M"
Set RpItm = RpRec.AddItem(RST.Fields("ZeiBis").Value)
RpItm.Format = "%H:%M"
Set RpItm = RpRec.AddItem(RST.Fields("ZeiAB").Value)
RpItm.Format = "%H:%M"
Set RpItm = RpRec.AddItem(RST.Fields("Priorität").Value)
RpItm.Alignment = xtpAlignmentCenter
If CInt(RST.Fields("Priorität").Value) = 1 Then
    RpItm.ForeColor = vbRed
End If
Set RpItm = RpRec.AddItem(RST.Fields("Farbe").Value)
Set RpItm = RpRec.AddItem(RST.Fields("Patient").Value)
Set RpItm = RpRec.AddItem(Format$(RST.Fields("RzAkt").Value, "00") & "/" & Format$(RST.Fields("RzAnz").Value, "00"))
RpItm.Alignment = xtpAlignmentCenter
Set RpItm = RpRec.AddItem(MiDif) 'War_Verzug
RpItm.Alignment = xtpAlignmentCenter
If MiDif > 5 Then
    RpItm.ForeColor = vbRed
End If
Set RpItm = RpRec.AddItem(RST.Fields("IDP").Value)
Set RpItm = RpRec.AddItem(RST.Fields("IDM").Value)
Set RpItm = RpRec.AddItem(RST.Fields("IDR").Value)
If RST.Fields("IDKurz").Value <> vbNullString Then
    Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
Else
    Set RpItm = RpRec.AddItem("Termin")
End If
Set RpItm = RpRec.AddItem(RST.Fields("GuiID").Value)
Set RpItm = RpRec.AddItem(RST.Fields("Kommentar").Value)
Set RpItm = RpRec.AddItem(RST.Fields("Wiederholung").Value) 'Ter_Wiederholung -  Leistungen vorhanden Ja / Nein
Set RpItm = RpRec.AddItem(RST.Fields("Wartezimmer").Value)
If RST.Fields("Kommentar").Value <> vbNullString Then
    If RST.Fields("IDSer").Value < 6 Then
        RpRec.PreviewText = RST.Fields("Kommentar").Value
    End If
End If

If SuStr <> vbNullString Then
    If RST.Fields("GuiID").Value = SuStr Then
        S_WaRec = RpRec.Index
    End If
End If

For Each RpItm In RpRec
    RpItm.Focusable = False
    If RST.Fields("Wartezimmer").Value <> vbNullString Then
        If CInt(RST.Fields("Wartezimmer").Value) > 1 Then
            RpItm.Bold = True
        End If
    End If
Next RpItm

RST.MoveNext
Loop Until RST.EOF

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCo6 = Nothing

Exit Function

LiErr:
If GlDbg = True Then SErLog Err.Description & " S_WaRec " & Err.Number
Resume Next

End Function

