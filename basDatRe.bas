                        Else
                            DBCmEx6 "qrySimAbDiA1", "@PatNr", "@IdxNr", "@IdCod", "@IdStr", "@IdGrp", "@IdRef", GlNeR.PatNr, NeuRe, CoStr, KuStr, DiGrp, DiRef
