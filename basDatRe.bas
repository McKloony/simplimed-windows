                            Else
                                If DiDat <= LetDa Then
                                    DiaEi = False
                                Else
                                    DiaEi = True
                                End If
                            End If
                        End If
                        RS130.Close
                        Set RS130 = Nothing
                    Else
                        DiaEi = True
                    End If
                Else
                    CoStr = vbNullString
                    KuStr = vbNullString
                    DiaEi = False
                End If
                If DiaEi = True Then
                    If RS125.Fields("Datum").Value <> vbNullString Then
                        DBCmEx7 "qrySimAbDiA4", "@PatNr", "@IdxNr", "@IdCod", "@IdStr", "@IdDat", "@IdGrp", "@IdRef", GlNeR.PatNr, NeuRe, CoStr, KuStr, DiDat, DiGrp, DiRef
                    Else
                        DBCmEx6 "qrySimAbDiA1", "@PatNr", "@IdxNr", "@IdCod", "@IdStr", "@IdGrp", "@IdRef", GlNeR.PatNr, NeuRe, CoStr, KuStr, DiGrp, DiRef
                    End If
                End If
                RS125.MoveNext
                Loop Until RS125.EOF
            End If
            RS125.Close
            Set RS125 = Nothing
        End If
    End If
ElseIf GlNeR.ReTyp = 4 Then
    DBCmEx2 "qrySimReGu", "@IdStr", "@IdxNr", GlNeR.ReStr, GlNeR.GutNr
End If

If GlNeR.ReStu > 0 Then
    RetWe = SendMessage(CmTyp.hwnd, CB_SETCURSEL, 8, ByVal 0&)
End If

GlNeK = GlKoX 'Protokolleintrag
With GlNeK
