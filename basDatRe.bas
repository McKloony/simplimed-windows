Public Sub S_AbRec(ByRef RST As ADODB.Recordset)
On Error GoTo LiErr
'Fügt der Tabelle Rechnungen hinzu

Dim KrDat As Date
Dim ManNr As Long
Dim MitNr As Long
Dim StrDa As String
Dim ReStu As Single
Dim Diffe As Double
Dim ReSto As Boolean
Dim EinOk As Boolean
Dim RpCo3 As XtremeReportControl.ReportControl

Set FM = frmMain
Set RpCo3 = FM.repCont3
Set RpRcs = RpCo3.Records
    
Do
If RST.Fields("Storniert").Value <> vbNullString Then
    ReSto = CBool(RST.Fields("Storniert").Value)
Else
    ReSto = False
End If
If RST.Fields("IDP").Value <> vbNullString Then
    ManNr = CLng(RST.Fields("IDP").Value)
Else
    ManNr = GlMan(GlSMa, 2)
End If
If RST.Fields("IDM").Value <> vbNullString Then
    MitNr = CLng(RST.Fields("IDM").Value)
Else
    MitNr = GlMiA(GlSmI, 2)
End If
If RST.Fields("Steuer").Value <> vbNullString Then
    ReStu = CSng(RST.Fields("Steuer").Value)
Else
    ReStu = 0
End If
If RST.Fields("Datum").Value <> vbNullString Then
    KrDat = RST.Fields("Datum").Value
Else
    KrDat = Date
End If
If RST.Fields("Bezahlt").Value = 0 Then
    Diffe = RST.Fields("Betrag").Value
Else
    If RST.Fields("Bezahlt").Value <> vbNullString Then
        Diffe = RST.Fields("Betrag").Value - RST.Fields("Bezahlt").Value
    Else
        Diffe = RST.Fields("Betrag").Value
    End If
End If
StrDa = Left$(KrDat, 10)

If GlSrA = False Then 'Zeige stornierte Rechnungen (Abrechnung)
    If ReSto = False Then
        If GlRst = False Then 'Mandantenbezogene Datenbegrenzung
            EinOk = True
        Else
            If ManNr = GlReM Then 'Standardmandant Mandantenrestriktionen
                EinOk = True
            Else
                If ManNr = 0 Then
                    EinOk = True
                Else
                    EinOk = False
                End If
            End If
        End If
    Else
        EinOk = False
    End If
Else
    If GlRst = False Then 'Mandantenbezogene Datenbegrenzung
        EinOk = True
    Else
        If ManNr = GlReM Then 'Standardmandant Mandantenrestriktionen
            EinOk = True
        Else
            If ManNr = 0 Then
                EinOk = True
            Else
                EinOk = False
            End If
        End If
    End If
End If

If EinOk = True Then
    Set RpRec = RpRcs.Add()
    Set RpItm = RpRec.AddItem(RST.Fields("ID1").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("ID0").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("RechNr").Value)
    If RST.Fields("Selekt").Value = 0 Then
        RpItm.Icon = IC16_Mail_Open
    Else
        RpItm.Icon = IC16_Mail_Close
    End If
    Set RpItm = RpRec.AddItem(CDate(StrDa))
    Set RpItm = RpRec.AddItem(RST.Fields("Selekt").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Type").Value)
    RpItm.Alignment = xtpAlignmentCenter
    If RST.Fields("Versand").Value <> vbNullString Then
        Select Case CInt(RST.Fields("Versand").Value)
        Case 1: Set RpItm = RpRec.AddItem("M")
        Case 2: Set RpItm = RpRec.AddItem("D")
        Case Else: Set RpItm = RpRec.AddItem(vbNullString)
        End Select
    Else
        Set RpItm = RpRec.AddItem(vbNullString)
    End If
    Set RpItm = RpRec.AddItem(Format$(RST.Fields("Betrag").Value, GlWa1))
    RpItm.Alignment = xtpAlignmentRight
    Set RpItm = RpRec.AddItem(Format$(RST.Fields("Bezahlt").Value, GlWa1))
    RpItm.Alignment = xtpAlignmentRight
    Set RpItm = RpRec.AddItem(Format$(Diffe, GlWa1))
    RpItm.Alignment = xtpAlignmentRight
    Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Offen").Value)
    RpItm.Alignment = xtpAlignmentRight
    Set RpItm = RpRec.AddItem(Format$(RST.Fields("Laborpreis").Value, GlWa1))
    RpItm.Alignment = xtpAlignmentRight
    Set RpItm = RpRec.AddItem(RST.Fields("Fallig").Value)
    RpItm.Alignment = xtpAlignmentCenter
    Set RpItm = RpRec.AddItem(RST.Fields("Währung").Value)
    Set RpItm = RpRec.AddItem(Format$(RST.Fields("IDR").Value, "0000"))
    Set RpItm = RpRec.AddItem(RST.Fields("ID3").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("IDZ").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Versicherer").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Zahlziel").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Drucken").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("IDW").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Symbol").Value)
    RpItm.Alignment = xtpAlignmentCenter
    Set RpItm = RpRec.AddItem(RST.Fields("Faktor").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Ziel").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Kommentar").Value)
    Set RpItm = RpRec.AddItem(ManNr)
    Set RpItm = RpRec.AddItem(RST.Fields("Berichtdatum").Value)
    RpItm.Alignment = xtpAlignmentCenter
    Set RpItm = RpRec.AddItem(RST.Fields("Kopie").Value)
    Set RpItm = RpRec.AddItem(Format$(RST.Fields("Steuer").Value, GlWa1))
    Set RpItm = RpRec.AddItem(Month(DateValue(KrDat)))
    Set RpItm = RpRec.AddItem(Format$(RST.Fields("IDT").Value, "0000"))
    RpItm.Alignment = xtpAlignmentRight
    Set RpItm = RpRec.AddItem(ReSto)
    Set RpItm = RpRec.AddItem(RST.Fields("PKU").Value)
    RpItm.Alignment = xtpAlignmentCenter
    Set RpItm = RpRec.AddItem(vbNullString)
    RpItm.HasCheckbox = True
    RpItm.Alignment = xtpAlignmentIconCenter
    If RST.Fields("Gruppe").Value = -1 Then
        RpItm.Checked = True
    Else
        RpItm.Checked = False
    End If
    Set RpItm = RpRec.AddItem(vbNullString)
    RpItm.HasCheckbox = True
    RpItm.Alignment = xtpAlignmentIconCenter
    If RST.Fields("Beendet").Value = -1 Then
        RpItm.Checked = True
    Else
        RpItm.Checked = False
    End If
    Set RpItm = RpRec.AddItem(Format$(RST.Fields("Rabatt").Value, GlWa1))
    Set RpItm = RpRec.AddItem(MitNr)
    Set RpItm = RpRec.AddItem(RST.Fields("GuStr").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("GutNr").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("GuiID").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("AufNr").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("AuStr").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("IdTit").Value)
    Set RpItm = RpRec.AddItem(vbNullString)
    RpItm.HasCheckbox = True
    RpItm.Alignment = xtpAlignmentIconCenter
    If RST.Fields("OPLoe").Value = -1 Then
        RpItm.Checked = True
    Else
        RpItm.Checked = False
    End If
    Set RpItm = RpRec.AddItem(vbNullString)
    RpItm.HasCheckbox = True
    RpItm.Alignment = xtpAlignmentIconCenter
    If RST.Fields("Lock").Value = -1 Then
        RpItm.Checked = True
    Else
        RpItm.Checked = False
    End If
    Set RpItm = RpRec.AddItem(RST.Fields("IDO").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("RzDat").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("RzNum").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("RzTex").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Grund").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("IDF").Value)
    If RST.Fields("Kommentar").Value <> vbNullString Then
        RpRec.PreviewText = RST.Fields("Kommentar").Value
    End If
End If

RST.MoveNext
Loop Until RST.EOF

Set RpItm = Nothing
Set RpRec = Nothing
Set RpRcs = Nothing
Set RpCo3 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_AbRec " & Err.Number
Resume Next

End Sub
Public Sub S_AbSch()
