Set RpCo7 = frmKatDL.repCont7
Set RpRws = RpCo7.Rows
Set RpCls = RpCo7.Columns
Set RpSel = RpCo7.SelectedRows

Set clFen = New clsFenster
clFen.hwnd = FM.hwnd

AnzPo = RpSel.Count

Tit1 = "Eintrag Entfernen"
If AnzPo > 1 Then
    Mld1 = "Möchten Sie die " & AnzPo & " markierten Einträge wirklich löschen?"
ElseIf AnzPo = 1 Then
    Mld1 = "Möchten Sie den markierten Eintrag wirklich löschen?"
End If

If AnzPo > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then
        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                Set RpCol = RpCls.Find(Med_ID2)
                IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Med_IDKurz)
                SuStr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Med_GOID)
                SuPZN = RpRow.Record(RpCol.ItemIndex).Value

                DBCmEx1 "qrySimAbDiLo", "@IdxNr", IdxNr
                DoEvents
        
                Set RpCls = RpCo5.Columns
                Set RpSel = RpCo5.SelectedRows
                Set RpRow = RpSel(0)
                If RpRow.GroupRow = False Then
                    Set RpCol = RpCls.Find(Rzp_ID1)
                    RzNum = RpRow.Record(RpCol.ItemIndex).Value
        
                    If GlTyp < 2 Then
                        SQL1 = "SELECT * FROM dbo.qrySimRzEdit WHERE ID1 = " & RzNum
                    Else
                        SQL1 = "SELECT * FROM qrySimRzEdit WHERE [ID1] = " & RzNum & ";"
                    End If
                    Set RS120 = New ADODB.Recordset
                    With RS120
                        .CursorLocation = adUseClient
                        .Source = SQL1
                        .ActiveConnection = DB1
                        .CursorType = adOpenDynamic
                        .LockType = adLockOptimistic
                        .Open Options:=adCmdText
                    End With
                    If RS120.RecordCount > 0 Then
                        DoEvents
                        TmStr = RS120.Fields("Rezepttext").Value
                        TxStr = Replace(TmStr, SuStr, vbNullString, 1, , 1)
                        TxStr = Replace(TxStr, SuPZN, vbNullString, 1, , 1)
                        RS120.Fields("Rezepttext").Value = TxStr
                        RS120.Update
                    End If
                    RS120.Close
                    Set RS120 = Nothing
                End If
            End If
        Next RpRow

        Screen.MousePointer = vbHourglass
        clFen.FenDsk 2

        DoEvents
        S_RzLa
        
        clFen.FenDsk 3
        Screen.MousePointer = vbNormal
    End If
End If

Set RpSel = Nothing
Set RpRow = Nothing
Set RpRws = Nothing
Set RpCls = Nothing
Set RpCo5 = Nothing
Set RpCo7 = Nothing

Set clFen = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_RzEn " & Err.Number
Resume Next

End Sub
Public Sub S_RzKn()
On Error GoTo LiErr
'Arzneimittel einlesen beim Anlegen eines neun Rezeptes

Dim RezNr As Long
Dim PatNr As Long
Dim BelNr As Long
Dim AktPo As Integer
Dim RpRow As XtremeReportControl.ReportRow
Dim RpRws As XtremeReportControl.ReportRows
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpCo5 As XtremeReportControl.ReportControl
Dim ChRzM As XtremeSuiteControls.CheckBox

Set FM = frmRzNeu
Set ChRzM = FM.chkRzMar
Set LiVw1 = FM.lstView1
Set LiIts = LiVw1.ListItems
Set RpCo5 = frmMain.repCont5
Set RpRws = RpCo5.Rows
Set RpCls = RpCo5.Columns
Set RpSel = RpCo5.SelectedRows

AktPo = 0

If GlBut = RibTab_Startseite Then
    Exit Sub
End If

If RpRws.Count > 0 Then
    Set RpRow = RpRws(0)
    Set RpCol = RpCls.Find(Rzp_ID1)
    RezNr = RpRow.Record(RpCol.ItemIndex).Value
    Set RpCol = RpCls.Find(Rzp_ID0)
    PatNr = RpRow.Record(RpCol.ItemIndex).Value
    Set RpCol = RpCls.Find(Rzp_Type)
    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
        BelNr = RpRow.Record(RpCol.ItemIndex).Value
    Else
        Select Case GlBut
        Case RibTab_Rezeptmodul: BelNr = Right$(IniGetVal("System", "RzForm"), 2)
        Case RibTab_Belegmodul: BelNr = Right$(IniGetVal("System", "BlForm"), 2)
        End Select
    End If
      
    If GlRzM = True Then ChRzM.Value = xtpChecked
      
    Set RS154 = New ADODB.Recordset
    RS154.CursorLocation = adUseClient
    Set RS154 = DBCmRe1("qrySimAbDiMe", "@IdxNr", RezNr)

    Set RS155 = New ADODB.Recordset
    RS155.CursorLocation = adUseClient
    Set RS155 = DBCmRe1("qrySimAbDiRe", "@IdxNr", PatNr)
    If RS155.RecordCount > 0 Then
        DoEvents
        Do
        With LiVw1
            AktPo = AktPo + 1
            Set LiItm = LiIts.Add(AktPo, , RS155.Fields("GOID").Value, IC16_Doc_Norm)
            LiItm.SubItems(1) = RS155.Fields("IDKurz").Value
            If RS155.Fields("IDD").Value <> vbNullString Then
                LiItm.SubItems(2) = RS155.Fields("IDD").Value
            Else
                LiItm.SubItems(2) = 0
            End If
            If GlRzM = True Then
                If RS154.RecordCount > 0 Then
                    RS154.MoveFirst
                    Do
                    If RS154.Fields("GOID").Value = RS155.Fields("GOID").Value Then
                        LiItm.Checked = True
                    End If
                    RS154.MoveNext
                    Loop Until RS154.EOF
                End If
            End If
        End With
        RS155.MoveNext
        Loop Until RS155.EOF
    End If
    
    RS154.Close
    RS155.Close
    Set RS154 = Nothing
    Set RS155 = Nothing
Else
    Set RS155 = New ADODB.Recordset
    RS155.CursorLocation = adUseClient
    Set RS155 = DBCmRe1("qrySimAbDiRe", "@IdxNr", GlAdr)
    If RS155.RecordCount > 0 Then
        DoEvents
        Do
        With LiVw1
            AktPo = AktPo + 1
            Set LiItm = LiIts.Add(AktPo, , RS155.Fields("GOID").Value, IC16_Doc_Norm)
            LiItm.SubItems(1) = RS155.Fields("IDKurz").Value
            If RS155.Fields("IDD").Value <> vbNullString Then
                LiItm.SubItems(2) = RS155.Fields("IDD").Value
            Else
                LiItm.SubItems(2) = 0
            End If
        End With
        RS155.MoveNext
        Loop Until RS155.EOF
