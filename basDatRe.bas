                    ZaZil = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    ZaZil = 14
                End If
                NeFal = CDate(NeuDa + ZaZil)

                Select Case IdTyp 'neuer Rechnungstyp
                Case "V": SPopu Tit1, Mld1, IC48_Lock
                Case "U": SPopu Tit1, Mld1, IC48_Lock
                Case "M": SPopu Tit1, Mld1, IC48_Lock
                Case Else:
                    Select Case ReTyp 'alter Rechnungstyp
                    Case "U":
                        SPopu Tit1, Mld1, IC48_Lock 'Gutschrift
                    Case "V": 'Kostenvoranschlag
                        ReStr = S_ReVo(Date, IdTyp, MaNum, MiNum, True)
                        DoEvents
                        Posit = InStrRev(ReStr, "-", -1, 1)
