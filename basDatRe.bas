            End If
            If RS125.Fields("R_Ort").Value <> vbNullString Then
                PaOrt = RS125.Fields("R_Ort").Value
            Else
                PaOrt = "Ort"
            End If
            If RS125.Fields("R_PLZ").Value <> vbNullString Then
                PaPLZ = RS125.Fields("R_PLZ").Value
            Else
                PaPLZ = "12345"
            End If
            If RS125.Fields("R_Briefanrede").Value <> vbNullString Then
                EmBrf = RS125.Fields("R_Briefanrede").Value
            ElseIf RS125.Fields("Briefanrede").Value <> vbNullString Then
                EmBrf = RS125.Fields("Briefanrede").Value
            Else
                EmBrf = "Sehr geehrte Damen und Herren"
            End If
            If RS125.Fields("Telefon5").Value <> vbNullString Then
                PaEma = RS125.Fields("Telefon5").Value
            ElseIf RS125.Fields("Telefon6").Value <> vbNullString Then
                PaEma = RS125.Fields("Telefon6").Value
            Else
                PaEma = "keine@mailadresse"
            End If
            If RS125.Fields("IBAN").Value <> vbNullString Then
                PaIBA = Left$(RS125.Fields("IBAN").Value, 6) & Right$(RS125.Fields("IBAN").Value, 4)
            Else
                PaIBA = "DE02300209000106531065" 'Beispiel TargoBank
            End If

            If PaFrm <> vbNullString Then
                If PaNam <> vbNullString Then
                    If PaVor <> vbNullString Then
                        PaReg = PaFrm & Space$(1) & PaVor & Space$(1) & PaNam
                    Else
                        PaReg = PaFrm & Space$(1) & PaNam
                    End If
                Else
                    If PaVor <> vbNullString Then
                        PaReg = PaFrm & Space$(1) & PaVor
                    Else
                        PaReg = PaFrm
                    End If
                End If
            ElseIf PaNam <> vbNullString Then
                If PaVor <> vbNullString Then
                    PaReg = PaVor & Space$(1) & PaNam
                Else
                    PaReg = PaNam
                End If
            ElseIf PaVor <> vbNullString Then
                PaReg = PaVor
            ElseIf GlThe(AktZa, 13) <> vbNullString Then
                PaReg = RS125.Fields("IDKurz").Value
            End If
            
            Select Case ZaTyp
            Case 1: RePay = "58" 'SEPA-Überweisung oder 42
            Case 2: RePay = "58" 'SEPA-Überweisung oder 42
            Case 3: RePay = "59" 'SEPA Direct Debit (SEPA-Lastschrift) oder 49
            Case 4: RePay = "10" 'Barzahlung
            Case 6: RePay = "42" 'Zahlung auf Bankkonto
            Case 7: RePay = "48" 'Bank card
            Case Else: RePay = "97" 'Not defined
            End Select
            
            If TyStr = "U" Then
                ReTyp = "381"
            Else
                ReTyp = "380"
            End If
                        
            If ReStu > 0 Then
                If ReStu > 7 Then
                    StTyp = "S"
                Else
                    StTyp = "AA"
                End If
            Else
                StTyp = "Z" 'E, Z
            End If
            
            PatID = Format$(PatNr, "00000000")
            
            Set RS126 = New ADODB.Recordset
            RS126.CursorLocation = adUseClient
            Set RS126 = DBCmRe1("qryPrSimRe2", "@IdStr", ReNum)
            AnzPo = RS126.RecordCount
            If AnzPo > 0 Then
                PrBr2.Min = 0
                PrBr2.Max = AnzPo
                Do 'Leistungen
                If IsNull(RS126.Fields("Gesamtbetrag").Value) = False Then
                    If RS126.Fields("Gesamtbetrag").Value > 0 Then
                        LeCod = "C62" 'C62=Einheit/Stick H87=Stück
                        LePos = RS126.Fields("Position").Value
                        LeAnz = RS126.Fields("Anzahl").Value
                        LeBez = RS126.Fields("Behandlungsdatum").Value & " " & RS126.Fields("Bezeichnung").Value & " " & RS126.Fields("Ziffer").Value
                        LeStu = RS126.Fields("Steuersatz").Value
                        LeEin = RS126.Fields("Einzelbetrag").Value
                        LeGes = RS126.Fields("Gesamtbetrag").Value
                        If GlSpl = False Then 'Steuerspalte eingeblendet
                            LeStu = ReStu
                        End If
                        If LeStu > 0 Then
                            LeEin = LeEin - Round(LeEin * (LeStu / 100#), 2)
                            LeGes = LeGes - Round(LeGes * (LeStu / 100#), 2)
                        End If
                        
                        LeGes = Format(LeAnz * LeEin, "0.00")
                        GesRe = GesRe + LeGes
                        
                        RetPo = clXRe.AddInvoiceLine(LePos, LeBez, LeAnz, LeCod, LeEin, LeGes, LeStu, NeuRe)
                        NeuRe = False
                        DoEvents
                    End If
                End If
                AktPo = AktPo + 1
                If AktPo < AnzPo Then
                    PrBr2.Value = AktPo
                End If
                RS126.MoveNext
                Loop Until RS126.EOF
            End If
            RS126.Close
            Set RS126 = Nothing
            DoEvents
        
            StBet = Round(ReBet * (ReStu / 100#), 2)
            NeBet = GesRe

            StBet = Round(NeBet * (ReStu / 100#), 2)
            ReBet = NeBet + StBet
            
            If Dialo = False Then
                DaNam = "XRechnung_Beleg_" & ReStr & ".xml"
                FiNam = ExpOr & DaNam
                If AnzRe > 1 Then
                    ReDim Preserve FilNa(AktRe)
                    FilNa(AktRe) = FiNam
                End If
            Else
                If AnzRe > 1 Then
                    DaNam = "XRechnung_Beleg_" & ReStr & ".xml"
                    FiNam = ExpOr & DaNam
                End If
            End If

            With clFil
                If .FilVor(FiNam) = True Then
                    .DaLoe = FiNam & vbNullChar
                    .FilLoe
                End If
            End With
            DoEvents
            
            If ReRab > "0" Then
                GeRab = GesRe
                NeBet = Format(GeRab - Format((NeBet / 100) * ReRab, "0.00"), "0.00")
                ReRab = Format(GeRab - NeBet, "0.00")
                ReBet = NeBet
            Else
                GeRab = NeBet
            End If
            
            If ReRab > "0" And ReStu > "0" Then
            StBet = Format((NeBet / 100) * ReStu, "0.00")
            ReBet = Format(NeBet + StBet, "0.00")
            End If
            
            NeBet = Format(NeBet, "0.00")
            StBet = Format(StBet, "0.00")
            ReBet = Format(ReBet, "0.00")
            
            With clXRe
                .PrepaidAmount = BeBet
                .InvoiceNumber = ReStr
                .InvoiceTax = ReStu
                .InvoiceTaxCategory = StTyp
                .InvoicePayment = RePay
                .InvoiceTypeCode = ReTyp 'Rechnungstypcode
                .InvoiceDate = Format$(ReDat, "yyyy-mm-dd") 'Rechnungsdatum
                .DueDate = Format$(FaDat, "yyyy-mm-dd") 'Fälligkeitsdatum
                .CurrencyCode = "EUR"
                .SellerEndpointID = MaIBA
                .SellerIBAN = MaIBA
                .SellerBIC = MaBIC
                .SellerStreet = MaStr
                .SellerPostalZone = MaPLZ
                .SellerCity = MaOrt
                .SellerCountryCode = "DE"
                .SellerRegName = MaReg
                .SellerCompanyID = MaSID
                .SellerContactName = MaKon
                .SellerTelephone = MaTel
                .SellerEmail = MaEma
                .SellerUID = MaUID
                .SellerAssignedId = MaGID
                .BuyerReference = PatID
                .BuyerEndpointID = PaEma
                .BuyerStreet = PaStr
                .BuyerCity = PaOrt
                .BuyerPostalZone = PaPLZ
                .BuyerCountrySubentity = "-" 'Bundesland
                .BuyerCountryCode = "DE"
                .BuyerRegistrationName = PaReg
                .BuyerAccountNumberID = PaIBA
                .BuyerAccountShortID = Left$(PaIBA, 6) & Right$(PaIBA, 4)
                .BuyerCompanyID = "-"
                .PaymentMandate = PatID
                .AllowanceTotalAmount = ReRab
            End With

            ' Berechne und fülle die Summen aus
            With clXRe
                .TaxAmount = StBet 'Gesamtbetrag aller Steuern
                .TaxableAmount = NeBet 'Nettobetrag
                .LineExtensionAmount = GeRab 'Summe aller Nettobeträge
                .TaxExclusiveAmount = NeBet
                .TaxInclusiveAmount = ReBet
                .PayableAmount = ReBet - BeBet
                .GenerateXMLFile FiNam
            End With
            
            If GlDru.EmVer > 0 Then 'Emailversand
                If GlDru.EmSep = True Then 'Emailempfängerseparation
                    'If VerDo = True Then 'Dokument verschlüsseln
                                                
                    'End If
                    If GlDru.EmVer = 3 Then 'Emailversand
                        If PaEma <> vbNullString Then
                            With GlTxV
                                .TxStr = GlEmT(1, 3)
                                .DaStr = ReDat
                                .Datum = ReDat
                                .ReStr = ReStr
                                .MitNr = MitNr
                                .ManNr = ManNr
                                .PatNr = PatNr
                            End With
                            EmBet = SEmTx()
                            With GlTxV
                                .TxStr = GlEmT(1, 1)
                                .Datum = ReDat
                                .DaStr = ReDat
                                .ReStr = ReStr
                                .MitNr = MitNr
                                .ManNr = ManNr
                                .PatNr = PatNr
                            End With
                            EmTex = SEmTx()
                            MeTex = vbCrLf & EmBrf & vbCrLf & vbCrLf & EmTex & vbCrLf & vbCrLf & EmSig
                            EmRet = SEmSe(PaEma, EmBet, MeTex, FiNam, , PaReg, False, True)
                        End If
                    ElseIf GlDru.EmVer = 6 Then
                        DoStr = SMCUp(FiNam, PatNr) 'Downloadlink
                        DoEvents
                        If DoStr <> vbNullString Then
                            Lange = Len(DoStr)
                            Posit = InStr(1, DoStr, ";", 1)
                            If Posit > 0 Then
                                DoLnk = Left$(DoStr, Posit - 1)
                                PoLnk = Mid$(DoStr, Posit + 1, Lange - Posit)
                                With GlTxV
                                    .TxStr = GlEmT(12, 3)
                                    .Datum = ReDat
                                    .DaStr = ReDat
                                    .ReStr = ReStr
                                    .MitNr = MitNr
                                    .ManNr = ManNr
                                    .PatNr = PatNr
                                End With
                                EmBet = SEmTx()
                                With GlTxV
                                    .TxStr = GlEmT(12, 1)
