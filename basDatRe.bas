    If GlThe(AktZa, 19) <> vbNullString Then
        MaFrm = GlThe(AktZa, 19)
    Else
        MaFrm = vbNullString
    End If
    If GlThe(AktZa, 1) <> vbNullString Then
        MaVor = GlThe(AktZa, 1)
    Else
        MaVor = vbNullString
    End If
    If GlThe(AktZa, 2) <> vbNullString Then
        MaNam = GlThe(AktZa, 2)
    Else
        MaNam = vbNullString
    End If
    If GlThe(AktZa, 3) <> vbNullString Then
        MaStr = GlThe(AktZa, 3)
    Else
        MaStr = "Straße"
    End If
    If GlThe(AktZa, 4) <> vbNullString Then
        MaPLZ = GlThe(AktZa, 4)
    Else
        MaPLZ = "12345"
    End If
    If GlThe(AktZa, 5) <> vbNullString Then
        MaOrt = GlThe(AktZa, 5)
    Else
        MaOrt = "Ort"
    End If
    If GlThe(AktZa, 18) <> vbNullString Then
        MaIBA = GlThe(AktZa, 18)
    Else
        MaIBA = "DE89370400440532013000"
    End If
    If GlThe(AktZa, 31) <> vbNullString Then
        MaBIC = GlThe(AktZa, 31)
    Else
        MaBIC = "COBADEFFXXX"
    End If
    If GlThe(AktZa, 33) <> vbNullString Then
        MaGID = GlThe(AktZa, 33)
    Else
        MaGID = "DE98ZZZ099999999991"
    End If
    If GlThe(AktZa, 11) <> vbNullString Then
        MaSID = GlThe(AktZa, 11)
    Else
        If GlThe(AktZa, 33) <> vbNullString Then
            MaSID = GlThe(AktZa, 33)
        Else
            MaSID = "DE123456789"
        End If
    End If
    If GlThe(AktZa, 6) <> vbNullString Then
        MaTel = GlThe(AktZa, 6)
    Else
        If GlThe(AktZa, 7) <> vbNullString Then
            MaTel = GlThe(AktZa, 7)
        Else
            MaTel = "1234"
        End If
    End If
    If GlThe(AktZa, 16) <> vbNullString Then
        MaEma = GlThe(AktZa, 16)
    Else
        MaEma = "keine@mailadresse.de"
    End If
    If GlThe(AktZa, 48) <> vbNullString Then
        MaUID = GlThe(AktZa, 48)
    Else
        MaUID = "DE123456789"
    End If
    If MaNam <> vbNullString Then
        If MaVor <> vbNullString Then
            MaKon = MaVor & Space$(1) & MaNam
        Else
            MaKon = MaNam
        End If
    ElseIf MaVor <> vbNullString Then
        MaKon = MaVor
    ElseIf GlThe(AktZa, 13) <> vbNullString Then
        MaKon = GlThe(AktZa, 13)
    Else
        MaKon = "Name"
    End If
    If MaFrm <> vbNullString Then
        If MaNam <> vbNullString Then
            If MaVor <> vbNullString Then
                MaReg = MaFrm & Space$(1) & MaVor & Space$(1) & MaNam
            Else
                MaReg = MaFrm & Space$(1) & MaNam
            End If
        Else
            If MaVor <> vbNullString Then
                MaReg = MaFrm & Space$(1) & MaVor
            Else
                MaReg = MaFrm
            End If
        End If
    ElseIf MaNam <> vbNullString Then
        If MaVor <> vbNullString Then
            MaReg = MaVor & Space$(1) & MaNam
        Else
            MaReg = MaNam
        End If
    ElseIf MaVor <> vbNullString Then
        MaReg = MaVor
    ElseIf GlThe(AktZa, 13) <> vbNullString Then
        MaReg = GlThe(AktZa, 13)
    End If

    If RST.Fields("R_Name").Value <> vbNullString Then
        PaNam = RST.Fields("R_Name").Value
    End If
    If RST.Fields("R_Vorname").Value <> vbNullString Then
        PaVor = RST.Fields("R_Vorname").Value
    End If
    If RST.Fields("R_Firma1").Value <> vbNullString Then
        PaFrm = RST.Fields("R_Firma1").Value
    End If
    If RST.Fields("R_Straße").Value <> vbNullString Then
        PaStr = RST.Fields("R_Straße").Value
    Else
        PaStr = "Straße"
    End If
    If RST.Fields("R_Ort").Value <> vbNullString Then
        PaOrt = RST.Fields("R_Ort").Value
    Else
        PaOrt = "Ort"
    End If
    If RST.Fields("R_PLZ").Value <> vbNullString Then
        PaPLZ = RST.Fields("R_PLZ").Value
    Else
        PaPLZ = "12345"
    End If
    If RST.Fields("Telefon5").Value <> vbNullString Then
        PaEma = RST.Fields("Telefon5").Value
    ElseIf RST.Fields("Telefon6").Value <> vbNullString Then
        PaEma = RST.Fields("Telefon6").Value
    Else
        PaEma = "keine@mailadresse"
    End If
    If RST.Fields("IBAN").Value <> vbNullString Then
        PaIBA = Left$(RST.Fields("IBAN").Value, 6) & Right$(RST.Fields("IBAN").Value, 4)
    Else
        PaIBA = "DE02300209000106531065" 'Beispiel TargoBank
    End If

    If PaFrm <> vbNullString Then
        If PaNam <> vbNullString Then
            If PaVor <> vbNullString Then
                PaReg = PaFrm & Space$(1) & PaVor & Space$(1) & PaNam
            Else
                PaReg = PaFrm & Space$(1) & PaNam
            End If
        Else
            If PaVor <> vbNullString Then
                PaReg = PaFrm & Space$(1) & PaVor
            Else
                PaReg = PaFrm
            End If
        End If
    ElseIf PaNam <> vbNullString Then
        If PaVor <> vbNullString Then
            PaReg = PaVor & Space$(1) & PaNam
        Else
            PaReg = PaNam
        End If
    ElseIf PaVor <> vbNullString Then
        PaReg = PaVor
    ElseIf GlThe(AktZa, 13) <> vbNullString Then
        PaReg = RST.Fields("IDKurz").Value
    End If
    
    Select Case ZaTyp
    Case 1: RePay = "58" 'SEPA-Überweisung oder 42
    Case 2: RePay = "58" 'SEPA-Überweisung oder 42
    Case 3: RePay = "59" 'SEPA Direct Debit (SEPA-Lastschrift) oder 49
    Case 4: RePay = "10" 'Barzahlung
    Case 6: RePay = "42" 'Zahlung auf Bankkonto
    Case 7: RePay = "48" 'Bank card
    Case Else: RePay = "97" 'Not defined
    End Select
    
    If TyStr = "U" Then
        ReTyp = "381"
    Else
        ReTyp = "380"
    End If
                
    If ReStu > 0 Then
        If ReStu > 7 Then
            StTyp = "S"
        Else
            StTyp = "AA"
        End If
    Else
        StTyp = "Z" 'E, Z
    End If
    
    PatID = Format$(PatNr, "00000000")

    AnzPo = RSD.RecordCount
    If AnzPo > 0 Then
        Do 'Leistungen
        If IsNull(RSD.Fields("Gesamtbetrag").Value) = False Then
            If RSD.Fields("Gesamtbetrag").Value > 0 Then
                LeCod = "C62" 'C62=Einheit/Stick H87=Stück
                LePos = RSD.Fields("Position").Value
                LeAnz = RSD.Fields("Anzahl").Value
                LeBez = RSD.Fields("Behandlungsdatum").Value & " " & RSD.Fields("Bezeichnung").Value & " " & RSD.Fields("Ziffer").Value
                LeStu = RSD.Fields("Steuersatz").Value
                LeEin = RSD.Fields("Einzelbetrag").Value
                LeGes = RSD.Fields("Gesamtbetrag").Value
                If GlSpl = False Then 'Steuerspalte eingeblendet
                    LeStu = ReStu
                End If
                If LeStu > 0 Then
                    LeEin = LeEin - Round(LeEin * (LeStu / 100#), 2)
                    LeGes = LeGes - Round(LeGes * (LeStu / 100#), 2)
                End If
                
                LeGes = Format(LeAnz * LeEin, "0.00")
                GesRe = GesRe + LeGes
                
                RetWe = clXRe.AddInvoiceLine(LePos, LeBez, LeAnz, LeCod, LeEin, LeGes, LeStu, NeuRe)
                NeuRe = False
                DoEvents
            End If
        End If
        RSD.MoveNext
        Loop Until RSD.EOF
    End If
    DoEvents

    StBet = Round(ReBet * (ReStu / 100#), 2)
    NeBet = GesRe

    StBet = Round(NeBet * (ReStu / 100#), 2)
    ReBet = NeBet + StBet

    If ReRab > "0" Then
        GeRab = GesRe
        NeBet = Format(GeRab - Format((NeBet / 100) * ReRab, "0.00"), "0.00")
        ReRab = Format(GeRab - NeBet, "0.00")
        ReBet = NeBet
    Else
        GeRab = NeBet
    End If
    
    If ReRab > "0" And ReStu > "0" Then
    StBet = Format((NeBet / 100) * ReStu, "0.00")
    ReBet = Format(NeBet + StBet, "0.00")
    End If
    
    NeBet = Format(NeBet, "0.00")
    StBet = Format(StBet, "0.00")
    ReBet = Format(ReBet, "0.00")
    
    With clXRe
        .PrepaidAmount = BeBet
        .InvoiceNumber = ReStr
        .InvoiceTax = ReStu
        .InvoiceTaxCategory = StTyp
        .InvoicePayment = RePay
        .InvoiceTypeCode = ReTyp 'Rechnungstypcode
        .InvoiceDate = Format$(ReDat, "yyyy-mm-dd") 'Rechnungsdatum
        .DueDate = Format$(FaDat, "yyyy-mm-dd") 'Fälligkeitsdatum
        .CurrencyCode = "EUR"
        .SellerEndpointID = MaIBA
        .SellerIBAN = MaIBA
        .SellerBIC = MaBIC
        .SellerStreet = MaStr
        .SellerPostalZone = MaPLZ
        .SellerCity = MaOrt
        .SellerCountryCode = "DE"
        .SellerRegName = MaReg
        .SellerCompanyID = MaSID
        .SellerContactName = MaKon
        .SellerTelephone = MaTel
        .SellerEmail = MaEma
        .SellerUID = MaUID
        .SellerAssignedId = MaGID
        .BuyerReference = PatID
        .BuyerEndpointID = PaEma
        .BuyerStreet = PaStr
        .BuyerCity = PaOrt
        .BuyerPostalZone = PaPLZ
        .BuyerCountrySubentity = "-" 'Bundesland
        .BuyerCountryCode = "DE"
        .BuyerRegistrationName = PaReg
        .BuyerAccountNumberID = PaIBA
        .BuyerAccountShortID = Left$(PaIBA, 6) & Right$(PaIBA, 4)
        .BuyerCompanyID = "-"
        .PaymentMandate = PatID
        .AllowanceTotalAmount = ReRab
    End With
    
    With clXRe
        .TaxAmount = StBet 'Gesamtbetrag aller Steuern
        .TaxableAmount = NeBet 'Nettobetrag
        .LineExtensionAmount = GeRab 'Summe aller Nettobeträge
        .TaxExclusiveAmount = NeBet
        .TaxInclusiveAmount = ReBet
        .PayableAmount = ReBet - BeBet
        .GenerateXMLFile FiNam
    End With
End If

Set clXRe = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_XRech " & Err.Number
Exit Sub

End Sub
