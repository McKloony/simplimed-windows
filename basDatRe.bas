                    End If
                    MeStr = MeStr & KunNr & ReNum & "600" & DiaKa & Space$(63) & vbCrLf
                    ZeiGe = ZeiGe + 1
                    ReZei = ReZei + 1
                    Loop Until StaWe >= Len(TmpDi)
                    
                End If
                RS128.MoveNext
                Loop Until RS128.EOF
            End If
            RS128.Close
            Set RS128 = Nothing

            HoSum = 0
            KoSum = 0
            AnSum = 0
            
            Do 'Leistungen
