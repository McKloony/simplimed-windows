                                                        RS123.Fields(FL101.Name).Value = RS127.Fields(FL101.Name).Value
                                                    Else
                                                        RS123.Fields(FL101.Name).Value = Month(Date) & "/" & Day(Date) & "/" & Year(Date)
                                                    End If
                                                Else
                                                    RS123.Fields(FL101.Name).Value = Month(Date) & "/" & Day(Date) & "/" & Year(Date)
                                                End If
                                        Case Else:
                                                RS123.Fields(FL101.Name).Value = RS127.Fields(FL101.Name).Value
                                        End Select
                                    End If
                                Next FL101
                                RS123.Update
                                DoEvents
                                RS127.MoveNext
                                Loop Until RS127.EOF
                            End If
                            RS127.Filter = adFilterNone
                        End If
                        
                        If AnzDi > 0 Then
                            RS129.Filter = "[IDR]=" & OrgRe
                            If RS129.RecordCount > 0 Then
                                Do 'Diagnosen
                                RS124.AddNew
                                For Each FL101 In RS129.Fields
                                    If RS129.Fields(FL101.Name).Value <> vbNullString Then
                                        If RS129.Fields(FL101.Name).Value <> Space$(1) Then
                                            Select Case FL101.Name
                                            Case "ID2":
                                            Case "ID0": RS124.Fields(FL101.Name).Value = PatNr
                                            Case "IDR": RS124.Fields(FL101.Name).Value = ReNum
                                            Case Else: RS124.Fields(FL101.Name).Value = RS129.Fields(FL101.Name).Value
                                            End Select
                                        End If
                                    End If
                                Next FL101
                                RS124.Update
                                DoEvents
                                RS129.MoveNext
                                Loop Until RS129.EOF
                            End If
                            RS129.Filter = adFilterNone
                        End If
    
                    End If
                    PrBr1.Value = AktRe
                    DoEvents
                    RS126.MoveNext
                Loop Until RS126.EOF
                DoEvents
            End If
            
            '---
            
            RS125.MoveFirst
            AktGu = 0
            DoEvents
            
            PrBr2.Min = 0
            PrBr2.Max = AnzPa
            
            Do 'Patienten
                OrgPa = RS125.Fields("ID0").Value
                PaGui = RS125.Fields("GuiID").Value
                PaKur = RS125.Fields("IDKurz").Value
                If PaGui = vbNullString Then
                    PaGui = CreateID("A")
                End If
                AktPa = AktPa + 1
                
                Set RS120 = New ADODB.Recordset 'Patient vorhanden?
                RS120.CursorLocation = adUseClient
                Set RS120 = DBCmRe1("qryAdrGui", "@IdStr", PaGui)
                AnzGe = RS120.RecordCount
                If AnzGe > 0 Then 'Patient existiert bereits
                    PatNr = RS120.Fields("ID0").Value
                Else
                    PatNr = 0
                End If
                RS120.Close
                Set RS120 = Nothing
                                
                If AnzGe = 0 Then
                    Set RS120 = New ADODB.Recordset 'Patient beriets vorhanden?
                    RS120.CursorLocation = adUseClient
                    Set RS120 = DBCmRe1("qryAdrKur", "@IdStr", PaKur)
                    AnzGe = RS120.RecordCount
                    If AnzGe > 0 Then 'Patient existiert bereits
                        PatNr = RS120.Fields("ID0").Value
                    Else
                        PatNr = 0
                    End If
                    RS120.Close
                    Set RS120 = Nothing
                End If
                
                '---

                If PatNr > 0 Then
                    If AnzPo > 0 Then 'Krankenblatteinträge
                        RS127.Filter = "[ID0]=" & OrgPa
                        If RS127.RecordCount > 0 Then
                            Do
                            If RS127.Fields("IDR").Value = 0 Or RS127.Fields("IDR").Value = vbNullString Then
                                RS123.AddNew
                                For Each FL101 In RS127.Fields
                                    If RS127.Fields(FL101.Name).Value <> vbNullString Then
                                        Select Case FL101.Name
                                        Case "ID2":
                                        Case "ID0": RS123.Fields(FL101.Name).Value = PatNr
                                        Case "IDR": RS123.Fields(FL101.Name).Value = 0
                                        Case "GuiID": RS123.Fields(FL101.Name).Value = CreateID("K")
                                        Case "Analog":
                                                If RS127.Fields(FL101.Name).Value <> vbNullString Then
                                                    If RS127.Fields(FL101.Name).Value = "False" Then
                                                        RS123.Fields(FL101.Name).Value = 0
                                                    ElseIf RS127.Fields(FL101.Name).Value = "True" Then
                                                        If GlTyp < 2 Then
                                                            RS123.Fields(FL101.Name).Value = 1
                                                        Else
                                                            RS123.Fields(FL101.Name).Value = -1
                                                        End If
                                                    Else
                                                        RS123.Fields(FL101.Name).Value = RS127.Fields(FL101.Name).Value
                                                    End If
                                                Else
                                                    RS123.Fields(FL101.Name).Value = 0
                                                End If
                                        Case "Datum":
                                                If IsDate(RS127.Fields(FL101.Name).Value) Then
                                                    If CDate(RS127.Fields(FL101.Name).Value) > "01.01.2000" Then
                                                        RS123.Fields(FL101.Name).Value = RS127.Fields(FL101.Name).Value
                                                    Else
                                                        RS123.Fields(FL101.Name).Value = Month(Date) & "/" & Day(Date) & "/" & Year(Date)
                                                    End If
                                                Else
                                                    RS123.Fields(FL101.Name).Value = Month(Date) & "/" & Day(Date) & "/" & Year(Date)
                                                End If
                                        Case Else:
                                                RS123.Fields(FL101.Name).Value = RS127.Fields(FL101.Name).Value
                                        End Select
                                    End If
                                Next FL101
                                RS123.Update
                                DoEvents
                            End If
                            RS127.MoveNext
                            Loop Until RS127.EOF
                        End If
                        RS127.Filter = adFilterNone
                    End If
                    
                    '---

                    If AnzDi > 0 Then 'Krankenblattkatalogdiagnosen
                        RS129.Filter = "[ID0]=" & OrgPa
                        If RS129.RecordCount > 0 Then
                            Do
                            If RS129.Fields("IDR").Value = 0 Or RS129.Fields("IDR").Value = vbNullString Then
                                RS124.AddNew
                                For Each FL101 In RS129.Fields
                                    If RS129.Fields(FL101.Name).Value <> vbNullString Then
                                        If RS129.Fields(FL101.Name).Value <> Space$(1) Then
                                            Select Case FL101.Name
                                            Case "ID2":
                                            Case "ID0": RS124.Fields(FL101.Name).Value = PatNr
                                            Case "IDR": RS124.Fields(FL101.Name).Value = 0
                                            Case Else: RS124.Fields(FL101.Name).Value = RS129.Fields(FL101.Name).Value
                                            End Select
                                        End If
                                    End If
                                Next FL101
                                RS124.Update
                            End If
                            DoEvents
                            RS129.MoveNext
                            Loop Until RS129.EOF
                        End If
                        RS129.Filter = adFilterNone
                    End If
                    
                    '---

                    If AnzRz > 0 Then 'Rezepte
                        RS131.Filter = "[ID0]=" & OrgPa
                        If RS131.RecordCount > 0 Then
                            Do
                            RS130.AddNew
                            For Each FL101 In RS131.Fields
                                If RS131.Fields(FL101.Name).Value <> vbNullString Then
                                    If RS131.Fields(FL101.Name).Value <> Space$(1) Then
                                        Select Case FL101.Name
                                        Case "ID1":
                                        Case "ID0": RS130.Fields(FL101.Name).Value = PatNr
                                        Case "IDP": RS130.Fields(FL101.Name).Value = ManNr
                                        Case "IDM": RS130.Fields(FL101.Name).Value = MitNr
                                        Case Else: RS130.Fields(FL101.Name).Value = RS131.Fields(FL101.Name).Value
                                        End Select
                                    End If
                                End If
                            Next FL101
                            RS130.Update
                            DoEvents
                            RS131.MoveNext
                            Loop Until RS131.EOF
                        End If
                        RS131.Filter = adFilterNone
                    End If
                    
                    '---

                    If AnzOp > 0 Then 'Posten
                        RS133.Filter = "[ID0]=" & OrgPa
                        If RS133.RecordCount > 0 Then
                            Do
                            RS132.AddNew
                            For Each FL101 In RS133.Fields
                                If RS133.Fields(FL101.Name).Value <> vbNullString Then
                                    If RS133.Fields(FL101.Name).Value <> Space$(1) Then
                                        Select Case FL101.Name
                                        Case "ID1":
                                        Case "ID0": RS132.Fields(FL101.Name).Value = PatNr
                                        Case "IDP": RS132.Fields(FL101.Name).Value = ManNr
                                        Case "IDT": RS132.Fields(FL101.Name).Value = MitNr
                                        Case Else: RS132.Fields(FL101.Name).Value = RS133.Fields(FL101.Name).Value
                                        End Select
                                    End If
                                End If
                            Next FL101
                            RS132.Update
                            DoEvents
                            RS133.MoveNext
                            Loop Until RS133.EOF
                        End If
                        RS133.Filter = adFilterNone
                    End If
                    
                    '---

                    If AnzTe > 0 Then 'Termine
                        RS135.Filter = "[ID0]=" & OrgPa
                        If RS135.RecordCount > 0 Then
                            Do
                            RS134.AddNew
                            For Each FL101 In RS135.Fields
                                If RS135.Fields(FL101.Name).Value <> vbNullString Then
                                    If RS135.Fields(FL101.Name).Value <> Space$(1) Then
                                        Select Case FL101.Name
                                        Case "ID1":
                                        Case "ID0": RS134.Fields(FL101.Name).Value = PatNr
                                        Case "IDP": RS134.Fields(FL101.Name).Value = ManNr
                                        Case "IDM": RS134.Fields(FL101.Name).Value = MitNr
                                        Case Else: RS134.Fields(FL101.Name).Value = RS135.Fields(FL101.Name).Value
                                        End Select
                                    End If
                                End If
                            Next FL101
                            RS134.Update
                            DoEvents
                            RS135.MoveNext
                            Loop Until RS135.EOF
                        End If
                        RS135.Filter = adFilterNone
                    End If
                    
                    '---

                    If AnzBu > 0 Then 'Buchungen
                        RS137.Filter = "[ID0]=" & OrgPa
                        If RS137.RecordCount > 0 Then
                            Do
                            RS136.AddNew
                            For Each FL101 In RS137.Fields
                                If RS137.Fields(FL101.Name).Value <> vbNullString Then
                                    If RS137.Fields(FL101.Name).Value <> Space$(1) Then
                                        Select Case FL101.Name
                                        Case "ID0":
                                        Case "ID1":
                                        Case "IDP": RS136.Fields(FL101.Name).Value = PatNr
                                        Case "IDT": RS136.Fields(FL101.Name).Value = ManNr
                                        Case "IDM": RS136.Fields(FL101.Name).Value = MitNr
                                        Case "Datum": If IsDate(Left$(RS137.Fields(FL101.Name).Value, 10)) = True Then RS136.Fields(FL101.Name).Value = CDate(Left$(RS137.Fields(FL101.Name).Value, 10))
                                        Case Else: RS136.Fields(FL101.Name).Value = RS137.Fields(FL101.Name).Value
                                        End Select
                                    End If
                                End If
                            Next FL101
                            RS136.Update
                            DoEvents
                            RS137.MoveNext
                            Loop Until RS137.EOF
                        End If
                        RS137.Filter = adFilterNone
                    End If
                    
                    '---
                    
                End If
                PrBr2.Value = AktPa
                DoEvents
                AktGu = AktGu + 1
                RS125.MoveNext
            Loop Until RS125.EOF

            RS123.Close
            RS124.Close
            RS130.Close
            RS132.Close
            RS134.Close
            RS136.Close
            Set RS123 = Nothing
            Set RS124 = Nothing
            Set RS130 = Nothing
            Set RS132 = Nothing
            Set RS134 = Nothing
            Set RS136 = Nothing
        End If
    End If
End If
  
RS125.Close
RS126.Close
If AnzPo > 0 Then RS127.Close
If AnzDi > 0 Then RS129.Close
If AnzRz > 0 Then RS131.Close
If AnzOp > 0 Then RS133.Close
If AnzTe > 0 Then RS135.Close
If AnzBu > 0 Then RS137.Close
Set RS125 = Nothing
Set RS126 = Nothing
Set RS127 = Nothing
Set RS129 = Nothing
Set RS131 = Nothing
Set RS133 = Nothing
Set RS135 = Nothing
Set RS137 = Nothing

DoEvents
DBCmEx0 "qryWarAbPos" 'Übertragen [ID2] auf [ID3]

If AnzRe > 0 Then
    GlNeK = GlKoX 'Protokolleintrag
    With GlNeK
        .PatNr = GlMan(GlSMa, 2)
        .IdxNr = 0
        .EiDat = Format$(Date, "dd.mm.yyyy")
        .EiZei = TimeValue(Now)
        .EiTyp = 104
        .TeStr = "Rechnungen Importiert - (" & AnzRe & " Rechnungen)"
        .ZiStr = Format$(Now, "hh:mm") & " Uhr"
        .NeuEi = True
        .KeiAk = True
        .Mitar = GlMiA(GlSmI, 2)
    End With
    S_Prot
End If

Unload frmStatus
Set frmStatus = Nothing
DoEvents

SUpAd True

Set CoDia = Nothing
Set RpSel = Nothing
Set RpCo2 = Nothing
Set CmBrs = Nothing

Set clFil = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_PaImT " & Err.Number
Exit Sub

End Sub
Public Function S_ReAn(ByVal KeiAn As Boolean, Optional ByVal ReAbs As Boolean = False, Optional ByVal NeuDa As Date) As Boolean
On Error GoTo LiErr
'Passt das Rechnungsdatum an und legt Rechnungsnummer an

Dim NeFal As Date
Dim ReDat As Date
Dim FaDat As Date
Dim RowNr As Long
Dim ReNum As Long
Dim NeuRe As Long
Dim AnzPo As Long
Dim ManNr As Long
Dim MitNr As Long
Dim SQL1 As String
Dim JahSt As String
Dim NeMon As String
Dim NeuSt As String
Dim ReStr As String
Dim ReTyp As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim NeJah As Integer
Dim AkJah As Integer
Dim ReJah As Integer
Dim ZaZil As Integer
Dim AktPo As Integer
Dim ForNr As Integer
Dim ReAbg As Boolean
Dim TeAbg As Boolean
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo4 = FM.repCont4
Set RpCo3 = FM.repCont3

Select Case GlBut
Case RibTab_Abrechnung:
        Set RpSel = RpCo3.SelectedRows
        Set RpCls = RpCo3.Columns
        Set RpRow = RpSel(0)
Case RibTab_Rechnungen:
        Set RpSel = RpCo4.SelectedRows
        Set RpCls = RpCo4.Columns
        Set RpRow = RpSel(0)
End Select

Set RpCol = RpCls.Find(Rec_IDP)
ManNr = RpRow.Record(RpCol.ItemIndex).Value
Set RpCol = RpCls.Find(Rec_IDM)
If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
    If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
        MitNr = RpRow.Record(RpCol.ItemIndex).Value
    Else
        MitNr = 0
    End If
Else
    MitNr = 0
End If

AktPo = 1
AnzPo = RpSel.Count
AkJah = Year(Date)

If AnzPo > 0 Then
    ReDim GloRe(AnzPo)

    If AnzPo > 1 Then
        frmStatus.Show
        DoEvents
        frmStatus.Caption = "Rechnungsanpassung"
        Set PrBr1 = frmStatus.prbStat1
        Set PrBr2 = frmStatus.prbStat2
        Set TxDum = frmStatus.txtDummy
        PrBr1.Min = 0
        PrBr1.Max = AnzPo
    End If

    Select Case GlBut
    Case RibTab_Abrechnung:
            Set RpSel = RpCo3.SelectedRows
            Set RpCls = RpCo3.Columns
    Case RibTab_Rechnungen:
            Set RpSel = RpCo4.SelectedRows
            Set RpCls = RpCo4.Columns
    End Select

    Screen.MousePointer = vbHourglass
    DoEvents

    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            RowNr = RpRow.Index
            If AktPo <= AnzPo Then
                GloRe(AktPo) = RowNr
            End If
            For ForNr = 0 To 105
                If GlFrm(2, ForNr) = GlDru.ForNa Then
                    ForNr = ForNr + 1
                    Exit For
                End If
            Next ForNr

            Set RpCol = RpCls.Find(Rec_ID1)
            ReNum = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Ziel)
            If IsNull(RpRow.Record(RpCol.ItemIndex).Value) = False Then
                ZaZil = RpRow.Record(RpCol.ItemIndex).Value
            Else
                ZaZil = 14
            End If
            Set RpCol = RpCls.Find(Rec_RechNr)
            ReStr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Type)
            ReTyp = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Datum)
            ReDat = CDate(RpRow.Record(RpCol.ItemIndex).Value)
            Set RpCol = RpCls.Find(Rec_Fallig)
            FaDat = CDate(RpRow.Record(RpCol.ItemIndex).Value)
            ReJah = Year(ReDat)
            
            Select Case GlBut
            Case RibTab_Abrechnung:
                    Set RpCol = RpCls.Find(Rec_Selekt)
                    ReAbg = CBool(RpRow.Record(RpCol.ItemIndex).Value)
            Case RibTab_Rechnungen:
                    Set RpCol = RpCls.Find(Rec_Selekt)
                    If LCase(RpRow.Record(RpCol.ItemIndex).Value) = "ja" Then
                        ReAbg = True
                    Else
                        ReAbg = False
                    End If
            End Select

            If ZaZil = 0 Then
                ZaZil = 14
            End If
            
            If ReAbg = False Then 'Rechnung abgeschlossen?
                Set RS117 = New ADODB.Recordset
                Set RS117 = DBCmRe1("qrySimReAbg", "@IdxNr", ReNum)
                If RS117.RecordCount > 0 Then
                    TeAbg = CBool(RS117.Fields("Selekt").Value)
                Else
                    TeAbg = ReAbg
                End If
                RS117.Close
                Set RS117 = Nothing
                DoEvents
            Else
                TeAbg = ReAbg
            End If

            If ReAbg <> TeAbg Then
                Unload frmStatus
                Set frmStatus = Nothing
                Screen.MousePointer = vbNormal
                                
                Select Case GlBut
                Case RibTab_Abrechnung:
                        Set RpSel = RpCo3.SelectedRows
                        If RpSel.Count > 0 Then
                            Set RpRow = RpSel(0)
                            RowNr = RpRow.Index
                            SUpAb RowNr
                        End If
                        Set RpSel = RpCo4.SelectedRows
                        If RpSel.Count > 0 Then
                            Set RpRow = RpSel(0)
                            RowNr = RpRow.Index
                            SUpRe RowNr
                        End If
                Case RibTab_Rechnungen:
                        Set RpSel = RpCo4.SelectedRows
                        If RpSel.Count > 0 Then
                            Set RpRow = RpSel(0)
                            RowNr = RpRow.Index
                            SUpRe RowNr
                        End If
                End Select
                DoEvents
                S_ReAn = True

                TeTit = "Rechnung bereits abgeschlossen"
                TeMai = "Die Rechnung " & ReStr & " wurde bereits abgeschlossen"
                TeInh = "Die Rechnung " & ReStr & " wurde bereits anderweitig abgeschlossen, dieser Vorgang wird daher unterbrochen, um die Rechnungsliste zu aktualisieren."
                TeFus = "Gegebenenfalls wurden eine oder mehrere der markierten Rechnungen in zwischenzeitlich an einem anderen Arbeitsplatz abgeschlossen."
                
                SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, True, FM.hwnd
                Exit Function
            End If

            If KeiAn = True Then 'keine Datumsanpassung
                NeuDa = ReDat 'WICHTIG!
                If FaDat <= NeuDa Then
                    NeFal = CDate(NeuDa + ZaZil)
                Else
                    NeFal = FaDat
                End If
            Else
                NeFal = CDate(NeuDa + ZaZil)
            End If

            NeJah = Year(NeuDa)
            JahSt = Right$(Year(NeuDa), 2)
            NeMon = Format$(Month(NeuDa), "00")

            If GlRnm = True Then 'Neustart der Rechnungsnummer am Jahresanfang
                If NeJah <> ReJah Then
                    If Len(ReStr) > 4 Then
                        If KeiAn = False Then
                            NeuDa = CDate("31.12." & ReJah)
                            If GlLog = True Then SLogi "S_ReAn: Datumsanpassung blockiert/korrigiert auf " & NeuDa & " (ReNum: " & ReNum & ")"
                            NeJah = Year(ReDat)
                            NeMon = Format$(Month(NeuDa), "00")
                            NeFal = CDate(NeuDa + ZaZil)
                        End If
                    End If
                End If
            End If

            If Len(ReStr) < 8 Then
                If ReTyp = "U" Or ReTyp = "V" Or ReTyp = "M" Then
                    Set RS120 = New ADODB.Recordset
                    RS120.CursorLocation = adUseClient
                    If GlRMa = True Then 'getrennter Mandentenrechnungsnummernkreis
                        If GlRnm = True Then 'Neustart Rechnungsnummer am Jahrenanfang
                            Set RS120 = DBCmRe3("qrySimReVt2", "@IdxNr", "@IdJah", "@IdStr", ManNr, NeJah, ReTyp)
                        Else
                            Set RS120 = DBCmRe2("qrySimReVt1", "@IdxNr", "@IdStr", ManNr, ReTyp)
                        End If
                    Else
                        If GlRnm = True Then 'Neustart Rechnungsnummer am Jahrenanfang
                            Set RS120 = DBCmRe2("qrySimReVt3", "@IdJah", "@IdStr", NeJah, ReTyp)
                        Else
                            Set RS120 = DBCmRe1("qrySimReVt0", "@IdStr", ReTyp)
                        End If
                    End If
                Else
                    If GlTyp < 2 Then
                        SQL1 = "SELECT * FROM dbo.qrySimReVor ORDER BY PLZ DESC"
                    Else
                        SQL1 = "SELECT * FROM qrySimReVor ORDER BY [PLZ] DESC;"
                    End If
                    Set RS120 = New ADODB.Recordset
                    RS120.CursorLocation = adUseClient
                    If GlRMa = True Then 'getrennter Mandentenrechnungsnummernkreis
                        If GlRnm = True Then 'Neustart Rechnungsnummer am Jahrenanfang
                            Set RS120 = DBCmRe2("qrySimReVo2", "@IdxNr", "@IdJah", ManNr, NeJah)
                        Else
                            Set RS120 = DBCmRe1("qrySimReVo1", "@IdxNr", ManNr)
                        End If
                    Else
                        If GlRnm = True Then 'Neustart Rechnungsnummer am Jahrenanfang
                            Set RS120 = DBCmRe1("qrySimReVo3", "@IdJah", NeJah)
                        Else
                            Set RS120 = DBCmRe0(SQL1, True)
                        End If
                    End If
                End If
        
                If RS120.RecordCount > 0 Then
                    If Len(RS120.Fields("PLZ").Value) > 0 Then
                        If IsNumeric(RS120.Fields("PLZ").Value) Then
                            NeuRe = Val(RS120.Fields("PLZ").Value) + 1
                        Else
                            NeuRe = Val(S_ReNx()) + 1
                        End If
                    Else
                        NeuRe = Val(S_ReNx()) + 1
                    End If
                Else
                    NeuRe = 1
                End If
                
                RS120.Close
                Set RS120 = Nothing
            End If
            If ReAbs = True Then
                If ReAbg = False Then
                    DBCmEx2 "qrySimReDa1", "@ReDat", "@IdxNr", NeuDa, ReNum
                    DoEvents
                    DBCmEx2 "qrySimReDa2", "@FaDat", "@IdxNr", NeFal, ReNum
                    DoEvents
                    DBCmEx2 "qrySimReMa2", "@PaSel", "@IdxNr", True, ReNum
                    DoEvents
                    DBCmEx2 "qrySimAbDru", "@IdAbg", "@IdxNr", True, ReNum
                    DoEvents
                    DBCmEx2 "qrySimReBer", "@IdDat", "@IdxNr", Date, ReNum
                    DoEvents
                    DBCmEx2 "qrySimReFor", "@IdFor", "@IdxNr", ForNr, ReNum
                End If
                If Len(ReStr) < 3 Then 'Bindestrich
                    Select Case GlRFm 'Rechnungsnummernformat
                    Case 2: NeuSt = JahSt & "-" & NeMon & "-" & Format$(NeuRe, "000000")
                    Case 3: NeuSt = JahSt & NeMon & "-" & Format$(NeuRe, "000000")
                    Case 4: NeuSt = JahSt & "-" & Format$(NeuRe, "000000")
                    Case 5: NeuSt = JahSt & NeMon & "-" & Format$(NeuRe, "0000")
                    End Select
                    DBCmEx2 "qrySimReNu", "@IdStr", "@IdxNr", NeuSt, ReNum
                    DoEvents
                    DBCmEx2 "qrySimReNp", "@IdStr", "@IdxNr", Format$(NeuRe, "00000000"), ReNum
                    DoEvents
                    NeuRe = NeuRe + 1
                End If
            End If

            AktPo = AktPo + 1
        End If
        
        If AnzPo > 1 Then
            If TxDum.Text = "B" Then Exit For 'Abbrechen
            PrBr1.Value = AktPo
        End If
    Next RpRow
    
    If AnzPo > 1 Then
        Unload frmStatus
        Set frmStatus = Nothing
        DoEvents
    End If
    
    Screen.MousePointer = vbNormal
End If

Set RpCls = Nothing
Set RpSel = Nothing
Set RpCo3 = Nothing
Set RpCo4 = Nothing

Exit Function

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReAn " & Err.Number
