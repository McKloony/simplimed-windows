Public Sub S_ReAnL()
On Error GoTo LiErr
'Lädt die Adresen in den Dialog

Dim GesZa As Long
Dim AktZa As Long
Dim TheNr As Long
Dim SQL1 As String
Dim TmpSt As String
Dim Posit As Integer
Dim CmPat As XtremeSuiteControls.ComboBox
Dim CmMan As XtremeSuiteControls.ComboBox

Set FM = frmReAnd
Set CmPat = FM.cmbPatie
Set CmMan = FM.cmbManda

CmPat.Clear
DoEvents

TheNr = CmMan.ItemData(CmMan.ListIndex)
Set RS156 = New ADODB.Recordset
RS156.CursorLocation = adUseClient
Set RS156 = DBCmRe1("qrySimAdBeh", "@IdxNr", TheNr)

GesZa = RS156.RecordCount

If GesZa > 0 Then
    Do
    TmpSt = RS156.Fields("IDKurz").Value
    Posit = InStr(1, TmpSt, "(", 1)
    If Posit > 0 Then
        TmpSt = Left$(TmpSt, Posit - 1) & " [" & Format$(RS156.Fields("ID0").Value, "00000") & "]"
    Else
        TmpSt = TmpSt & " [" & Format$(RS156.Fields("ID0").Value, "00000") & "]"
    End If
    CmPat.AddItem TmpSt
    CmPat.ItemData(AktZa) = RS156.Fields("ID0").Value
    AktZa = AktZa + 1
    RS156.MoveNext
    Loop Until RS156.EOF
    CmPat.ListIndex = 0
End If

RS156.Close
Set RS156 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReAnL " & Err.Number
Resume Next

End Sub
