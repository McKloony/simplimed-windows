                                TmStr = vbNullString
                                For AkSpa = 0 To ArSpa 'Spalten
                                    If AktZa <= ArGes Then
                                        If AdrAy(AkSpa, AktZa) <> vbNullString Then
                                            TmStr = AdrAy(AkSpa, AktZa)
                                            TmStr = Replace$(TmStr, Chr$(13) & Chr$(10), Space$(1), 1)
                                            Select Case AkSpa
                                            Case 0:
                                                TmAry(AkBlo) = TmAry(AkBlo) & "P" & Format$(TmStr, "000000") & Chr$(59)
                                            Case Else:
                                                If Len(TmStr) > 250 Then
                                                    TmAry(AkBlo) = TmAry(AkBlo) & SNaFi(Left$(TmStr, 250), False, False, True, True) & Chr$(59)
                                                Else
