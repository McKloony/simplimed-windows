    .IdxNr = 0
    .EiDat = Format$(Date, "dd.mm.yyyy")
    .EiZei = TimeValue(Now)
    .EiTyp = 104
    .TeStr = "Rechnung hinzugefügt - " & GlNeR.ReStr & " (manuell)"
    .ZiStr = Format$(Now, "hh:mm") & " Uhr"
