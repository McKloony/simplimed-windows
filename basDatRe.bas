    TmpSt = TmpSt & KSoSt & ExSep 'Sachkonto
    TmpSt = TmpSt & KHaSt & ExSep 'Geldkonto
    If RST.Fields("Steuer").Value > 0 Then 'Steuerschlüssel
        ReStu = CSng(RST.Fields("Steuer").Value)
        If ReStu > 0 And ReStu < 1 Then
            ReStu = ReStu * 100
        End If
        TmpSt = TmpSt & Format$(ReStu, "00") & "00" & ExSep
    Else
        TmpSt = TmpSt & "0000"
    End If
    TmpSt = TmpSt & KtStr & ExSep 'Kostenstelle 1
    TmpSt = TmpSt & "" & ExSep 'Kostenstelle 2
    TmpSt = TmpSt & S_DaKoW(S_DaKoZ(RST.Fields("Währung").Value)) & ExSep 'Währung
End Select
GesSt = GesSt & TmpSt & vbCrLf 'abschließender Zeilenumbruch

RST.MoveNext
Loop Until RST.EOF

DoEvents
S_DaExP = GesSt

Exit Function

SuErr:
