                End If
            End If
            RS121.Close
            Set RS121 = Nothing
        End If
        
    End If
    DoEvents
    Adr_Er1 PaGui 'WICHTIG!
    
    DoEvents
    RS125.MoveNext
    PrBr1.Value = AktPa
    DoEvents
    Loop Until RS125.EOF
    
    '---

    frmStatus.Show
    DoEvents
    frmStatus.Caption = "Rechnungsimport"
    Set PrBr1 = frmStatus.prbStat1
    Set PrBr2 = frmStatus.prbStat2
    Set TxDum = frmStatus.txtDummy

    '---

    Set RS122 = New ADODB.Recordset 'Rechnungen
    With RS122
        .CursorLocation = adUseClient
        .Source = "qrySimReTop"
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdTableDirect
    End With
    If RS122.Supports(adAddNew) Then
        AktRe = 0
        PrBr2.Min = 0
        PrBr2.Max = AnzRe
        ReDim TmGui(AnzRe)
        
        Do
        AktRe = AktRe + 1
        PaGui = RS126.Fields("GuiID").Value 'aus qrySimReExp02
        PaKur = RS126.Fields("IDKurz").Value 'aus qrySimReExp02
        If PaGui = vbNullString Then
            PaGui = CreateID("A")
        End If

        Set RS120 = New ADODB.Recordset 'neue ID0 ermitteln
        RS120.CursorLocation = adUseClient
        Set RS120 = DBCmRe1("qryAdrGui", "@IdStr", PaGui)
        AnzGe = RS120.RecordCount
        If AnzGe > 0 Then
            PatNr = RS120.Fields("ID0").Value
            KatNr = RS120.Fields("ID3").Value
            ZaZil = RS120.Fields("IDZ").Value
            Kopie = RS120.Fields("Kopien").Value
        Else
            PatNr = 0
            Kopie = 1
            KatNr = GlGKa(GlStK, 0)
            ZaZil = GlZah(GlStZ, 0)
        End If
        RS120.Close
        Set RS120 = Nothing

        If AnzGe = 0 Then
            Set RS120 = New ADODB.Recordset 'Patient beriets vorhanden?
            RS120.CursorLocation = adUseClient
            Set RS120 = DBCmRe1("qryAdrKur", "@IdStr", PaKur)
            AnzGe = RS120.RecordCount
            If AnzGe > 0 Then 'Patient existiert bereits
                PatNr = RS120.Fields("ID0").Value
                KatNr = RS120.Fields("ID3").Value
                ZaZil = RS120.Fields("IDZ").Value
                Kopie = RS120.Fields("Kopien").Value
            Else
                PatNr = 0
                Kopie = 1
                KatNr = GlGKa(GlStK, 0)
                ZaZil = GlZah(GlStZ, 0)
            End If
            RS120.Close
            Set RS120 = Nothing
        End If

        If PatNr > 0 Then
            RS122.AddNew
            TmGui(AktRe) = CreateID("R")
            RS122.Fields("GuiID").Value = TmGui(AktRe) 'neue GuiID

            For Each FL101 In RS126.Fields
                If RS126.Fields(FL101.Name).Value <> vbNullString Then
                    Select Case FL101.Name
                    Case "GuiID":
                    Case "PLZ":
                    Case "RechNr":
                            If OrReN = True Then
                                ReStr = RS126.Fields(FL101.Name).Value
                                Posit = InStrRev(ReStr, "-", -1, 1)
                                If Posit > 0 Then
                                    TmpNr = Mid$(ReStr, Posit + 1, Len(ReStr))
                                    PlStr = Format$(TmpNr, "00000000")
                                Else
                                    PlStr = "-"
                                End If
                            Else
                                ReStr = S_ReVo(Date, "I", ManNr, StMit, True)
                                Posit = InStrRev(ReStr, "-", -1, 1)
                                If Posit > 0 Then
                                    TmpNr = Mid$(ReStr, Posit + 1, Len(ReStr))
                                    PlStr = Format$(TmpNr, "00000000")
                                Else
                                    PlStr = "-"
                                End If
                            End If
                            RS122.Fields(FL101.Name).Value = ReStr
                            RS122.Fields("PLZ").Value = PlStr
                    Case "Datum":
                            If OrReN = True Then
                                 ReDat = RS126.Fields(FL101.Name).Value
                            Else
                                ReDat = Date
                            End If
                            RS122.Fields(FL101.Name).Value = ReDat
                    Case "IDR": 'Rechnungsnummer auslassen und später zu qryWarRechNr zuordnen
                    Case "ID1": 'Rechnungsnummer auslassen und später zu qryWarRechNr zuordnen
                    Case "ID0": RS122.Fields(FL101.Name).Value = PatNr
                    Case "ID3": RS122.Fields(FL101.Name).Value = KatNr
                    Case "IDZ": RS122.Fields(FL101.Name).Value = ZaZil
                    Case "Ziel": RS122.Fields(FL101.Name).Value = 14
                    Case "Offen": RS122.Fields(FL101.Name).Value = -1
                    Case "Kopie": RS122.Fields(FL101.Name).Value = Kopie
                    Case "Intervall": RS122.Fields(FL101.Name).Value = 14
                    Case "Mahnbar": RS122.Fields(FL101.Name).Value = -1
                    Case "Fallig": RS122.Fields(FL101.Name).Value = Date + 14
                    Case "Wahrung": RS122.Fields("Währung").Value = RS126.Fields(FL101.Name).Value
                    Case "W?hrung": RS122.Fields("Währung").Value = RS126.Fields(FL101.Name).Value
                    Case "Type":
                            If TyStr <> vbNullString Then
                                RS122.Fields(FL101.Name).Value = TyStr
                            Else
                                RS122.Fields(FL101.Name).Value = "I"
                            End If
                    Case Else:
                            If Left$(FL101.Name, 3) <> "Exp" Then
                                If RS126.Fields(FL101.Name).Value <> vbNullString Then
                                    RS122.Fields(FL101.Name).Value = RS126.Fields(FL101.Name).Value
                                End If
                            End If
                    End Select
                    RS122.Fields("IDP").Value = ManNr
                    RS122.Fields("IDM").Value = MitNr
                    RS122.Fields("Offen").Value = 0
                    If ReAbs = True Then RS122.Fields("Selekt").Value = -1
                End If
            Next FL101
            RS122.Update
        End If
        
        DoEvents
        RS126.MoveNext
        PrBr2.Value = AktRe
        DoEvents
        Loop Until RS126.EOF
        RS122.Close
        Set RS122 = Nothing
                      
        '---
              
        DoEvents
        DBCmEx0 "qryWarRechNr"
        DoEvents
              
        '---
                
        Set RS123 = New ADODB.Recordset 'Positionen
        With RS123
            .CursorLocation = adUseClient
            .Source = "qrySimAbNe"
            .ActiveConnection = DB1
            .CursorType = adOpenDynamic
            .LockType = adLockOptimistic
            .Open Options:=adCmdTableDirect
        End With
        
        Set RS124 = New ADODB.Recordset 'Diagnosen
        With RS124
            .CursorLocation = adUseClient
            .Source = "qrySimAbDiNe"
            .ActiveConnection = DB1
            .CursorType = adOpenDynamic
            .LockType = adLockOptimistic
            .Open Options:=adCmdTableDirect
        End With
        
        If RS123.Supports(adAddNew) Then
            AktRe = 0
            PrBr1.Min = 0
            PrBr1.Max = AnzRe
            
            RS126.MoveFirst
            DoEvents
            
            Do 'Rechnungen
                AktRe = AktRe + 1
                OrgRe = RS126.Fields("ID1").Value
                
                Set RS120 = New ADODB.Recordset 'Neue ID0 und ID1 ermitteln
                RS120.CursorLocation = adUseClient
                Set RS120 = DBCmRe1("qrySimReGui", "@IdStr", TmGui(AktRe))
                AnzGe = RS120.RecordCount
                If AnzGe > 0 Then
                    PatNr = RS120.Fields("ID0").Value
                    ReNum = RS120.Fields("ID1").Value
                Else
                    PatNr = 0
                    ReNum = 0
                End If
                RS120.Close
                Set RS120 = Nothing
                
                If PatNr > 0 Then
                    If AnzPo > 0 Then
                        RS127.Filter = "[IDR]=" & OrgRe
                        If RS127.RecordCount > 0 Then
                            Do 'Positionen
                            RS123.AddNew
                            For Each FL101 In RS127.Fields
                                If RS127.Fields(FL101.Name).Value <> vbNullString Then
                                    Select Case FL101.Name
                                    Case "ID2":
                                    Case "ID0": RS123.Fields(FL101.Name).Value = PatNr
                                    Case "IDR": RS123.Fields(FL101.Name).Value = ReNum
                                    Case "GuiID": RS123.Fields(FL101.Name).Value = CreateID("R")
                                    Case "IDKurz":
                                            If RS127.Fields(FL101.Name).Value <> vbNullString Then
                                                If Len(RS127.Fields(FL101.Name).Value) > 250 Then
                                                    RS123.Fields(FL101.Name).Value = Left$(RS127.Fields(FL101.Name).Value, 250)
                                                Else
                                                    RS123.Fields(FL101.Name).Value = RS127.Fields(FL101.Name).Value
                                                End If
                                            Else
                                                RS123.Fields(FL101.Name).Value = vbNullString
                                            End If
                                    Case "Analog":
                                            If RS127.Fields(FL101.Name).Value <> vbNullString Then
                                                If RS127.Fields(FL101.Name).Value = "False" Then
                                                    RS123.Fields(FL101.Name).Value = 0
                                                ElseIf RS127.Fields(FL101.Name).Value = "True" Then
                                                    If GlTyp < 2 Then
                                                        RS123.Fields(FL101.Name).Value = 1
                                                    Else
                                                        RS123.Fields(FL101.Name).Value = -1
                                                    End If
                                                Else
                                                    RS123.Fields(FL101.Name).Value = RS127.Fields(FL101.Name).Value
                                                End If
                                            Else
                                                RS123.Fields(FL101.Name).Value = 0
                                            End If
                                    Case "Datum":
                                            If IsDate(RS127.Fields(FL101.Name).Value) Then
                                                If CDate(RS127.Fields(FL101.Name).Value) > "01.01.2000" Then
                                                    RS123.Fields(FL101.Name).Value = RS127.Fields(FL101.Name).Value
                                                Else
                                                    RS123.Fields(FL101.Name).Value = Month(Date) & "/" & Day(Date) & "/" & Year(Date)
                                                End If
                                            Else
                                                RS123.Fields(FL101.Name).Value = Month(Date) & "/" & Day(Date) & "/" & Year(Date)
                                            End If
                                    Case Else:
                                            RS123.Fields(FL101.Name).Value = RS127.Fields(FL101.Name).Value
                                    End Select
                                End If
                            Next FL101
                            RS123.Update
                            DoEvents
                            RS127.MoveNext
                            Loop Until RS127.EOF
                        End If
                        RS127.Filter = adFilterNone
                    End If
                    
                    If AnzDi > 0 Then
                        RS129.Filter = "[IDR]=" & OrgRe
                        If RS129.RecordCount > 0 Then
                            Do 'Diagnosen
                            RS124.AddNew
                            For Each FL101 In RS129.Fields
                                If RS129.Fields(FL101.Name).Value <> vbNullString Then
                                    If RS129.Fields(FL101.Name).Value <> Space$(1) Then
                                        Select Case FL101.Name
                                        Case "ID2":
                                        Case "ID0": RS124.Fields(FL101.Name).Value = PatNr
                                        Case "IDR": RS124.Fields(FL101.Name).Value = ReNum
                                        Case Else: RS124.Fields(FL101.Name).Value = RS129.Fields(FL101.Name).Value
                                        End Select
                                    End If
                                End If
                            Next FL101
                            RS124.Update
                            DoEvents
                            RS129.MoveNext
                            Loop Until RS129.EOF
                        End If
                        RS129.Filter = adFilterNone
                    End If

                End If
                PrBr1.Value = AktRe
                DoEvents
                RS126.MoveNext
            Loop Until RS126.EOF
            
            RS123.Close
            RS124.Close
            Set RS123 = Nothing
            Set RS124 = Nothing
        End If
    End If
End If
  
RS125.Close
RS126.Close
If AnzPo > 0 Then RS127.Close
If AnzDi > 0 Then RS129.Close

Set RS125 = Nothing
Set RS126 = Nothing
Set RS127 = Nothing
Set RS129 = Nothing

DoEvents
DBCmEx0 "qryWarAbPos" 'Übertragen [ID2] auf [ID3]

If AnzRe > 0 Then
    GlNeK = GlKoX 'Protokolleintrag
    With GlNeK
        .PatNr = GlMan(GlSMa, 2)
        .IdxNr = 0
        .EiDat = Format$(Date, "dd.mm.yyyy")
        .EiZei = TimeValue(Now)
        .EiTyp = 104
        .TeStr = "Rechnungen Importiert - (" & AnzRe & " Rechnungen)"
        .ZiStr = Format$(Now, "hh:mm") & " Uhr"
        .NeuEi = True
        .KeiAk = True
        .Mitar = GlMiA(GlSmI, 2)
    End With
    S_Prot
End If

Unload frmStatus
Set frmStatus = Nothing
DoEvents

Set RpSel = RpCo4.SelectedRows
If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    RowNr = RpRow.Index
    SUpRe RowNr
End If

Set CoDia = Nothing
Set RpSel = Nothing
Set RpCo3 = Nothing
Set RpCo4 = Nothing
Set CmBrs = Nothing

Set clFil = Nothing

