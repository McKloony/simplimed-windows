If GlDbg = True Then MsgBox Err.Description, 48, "S_ReAnp " & Err.Number
Resume Next

End Sub
Public Function S_ReBet(ByVal ReNum As Long, ByVal ReBet As Single, ByVal ReAbg As Boolean, ByVal ReRab As Single) As Double
On Error GoTo LiErr
'Passt den Rechnungsbetrag an

Dim GeSum As Double
Dim AnSum As Double
Dim RaBet As Double
Dim CmBrs As XtremeCommandBars.CommandBars

Set FM = frmMain
Set CmBrs = FM.comBar01
Set CmAcs = CmBrs.Actions

If ReNum = 0 Then Exit Function
    
ReBet = Format$(ReBet, GlWa1)

Set RS130 = New ADODB.Recordset
RS130.CursorLocation = adUseClient
If GlIgL = True Then 'neine Preisberechnung bei IgL
    Set RS130 = DBCmRe1("qrySimAbSm1", "@IdxNr", ReNum)
Else
    Set RS130 = DBCmRe1("qrySimAbSm", "@IdxNr", ReNum)
End If

If RS130.RecordCount > 0 Then
    If RS130("VK").Value > 0 Then
        If ReRab > 0 Then
            RaBet = Round(RS130("VK").Value * ReRab / 100, 2)
            GeSum = Round(RS130("VK").Value - RaBet, 2)
        Else
            RaBet = 0
            GeSum = Round(RS130("VK").Value, 2)
        End If
    Else
        GeSum = Format$(0, GlWa1)
    End If
    If RS130("WV").Value > 0 Then
        AnSum = Round(Round(RS130("WV").Value, 2), 2)
    Else
        AnSum = Format$(0, GlWa1)
    End If
    If GeSum <> ReBet Then
        DBCmEx2 "qrySimReSm1", "@IdBet", "@IdxNr", GeSum, ReNum
        If ReAbg = True Then
            If ReNum > 0 Then
                DBCmEx2 "qrySimOPAn3", "@Betra", "@IdxNr", GeSum, ReNum
                DBCmEx2 "qrySimOPAn4", "@Betra", "@IdxNr", GeSum, ReNum
                DBCmEx2 "qrySimBuAn", "@Betra", "@IdxNr", GeSum, ReNum
            End If
        End If
    End If
Else
    GeSum = Format$(0, GlWa1)
    AnSum = Format$(0, GlWa1)
    If GeSum <> ReBet Then
        DBCmEx2 "qrySimReSm1", "@IdBet", "@IdxNr", GeSum, ReNum
        If ReAbg = True Then
            If ReNum > 0 Then
                DBCmEx2 "qrySimOPAn3", "@Betra", "@IdxNr", GeSum, ReNum
                DBCmEx2 "qrySimOPAn4", "@Betra", "@IdxNr", GeSum, ReNum
                DBCmEx2 "qrySimBuAn", "@Betra", "@IdxNr", GeSum, ReNum
            End If
        End If
    End If
End If

DoEvents
SAnza

S_ReBet = Round(GeSum, 2)

If AnSum > GeSum Then
    SPopu "Zu hoher Anzahlungsbetrag", "Die Gesamtsumme aller Akontozahlungen in dieser Rechnung ist höher als der Rechnunsgbetrag", IC48_Information
End If

Exit Function

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReBet " & Err.Number
Resume Next

End Function
Public Sub S_ReDop()
On Error GoTo LiErr
'Prüft auf doppelte Abrechnungstage

Dim ReNum As Long
Dim RowNr As Long
Dim AnzPo As Long
Dim PatNr As Long
Dim PaStr As String
Dim ReStr As String
Dim StrDa As String
Dim AnzTe As Integer
Dim AktTe As Integer
Dim AbTer() As Date
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo4 = FM.repCont4
Set RpCo3 = FM.repCont3

Select Case GlBut
Case RibTab_Abrechnung:
        Set RpSel = RpCo3.SelectedRows
        Set RpCls = RpCo3.Columns
Case RibTab_Rechnungen:
        Set RpSel = RpCo4.SelectedRows
        Set RpCls = RpCo4.Columns
End Select

AnzPo = RpSel.Count

If AnzPo > 0 Then
    Screen.MousePointer = vbHourglass
    DoEvents

    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            RowNr = RpRow.Index
            Select Case GlBut
            Case RibTab_Abrechnung:
                Set RpCol = RpCls.Find(Rec_IDR)
                ReNum = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_ID0)
                PatNr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_RechNr)
                ReStr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_IDKurz)
                PaStr = RpRow.Record(RpCol.ItemIndex).Value
            Case RibTab_Rechnungen:
                Set RpCol = RpCls.Find(Rec_IDR)
                ReNum = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_ID0)
                PatNr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_RechNr)
                ReStr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_IDKurz)
                PaStr = RpRow.Record(RpCol.ItemIndex).Value
            End Select

            Set RS121 = New ADODB.Recordset
            RS121.CursorLocation = adUseClient
            Set RS121 = DBCmRe1("qrySimAbDo1", "@IdxNr", ReNum)
            AnzTe = RS121.RecordCount
            If AnzTe > 0 Then
                AktTe = 1
                ReDim AbTer(AnzTe)
                RS121.MoveFirst
                Do
                AbTer(AktTe) = RS121.Fields("Datum").Value
                AktTe = AktTe + 1
                RS121.MoveNext
                Loop Until RS121.EOF
            End If
            RS121.Close
            Set RS121 = Nothing
            DoEvents
            Set RS122 = New ADODB.Recordset
            RS122.CursorLocation = adUseClient
            Set RS122 = DBCmRe2("qrySimAbDo2", "@IdxNr", "@IdPat", ReNum, PatNr)
            If RS122.RecordCount > 0 Then
                RS122.MoveFirst
                Do
                For AktTe = 1 To AnzTe
                    If AbTer(AktTe) = RS122.Fields("Datum").Value Then
                        DBCmEx2 "qrySimAbDo3", "@IdxNr", "@IdDat", ReNum, AbTer(AktTe)
                        DoEvents
                        SPopu "Doppelter Tag " & AbTer(AktTe), "Doppelter Abrechnungstag " & AbTer(AktTe), IC48_Warning
                    End If
                Next AktTe
                RS122.MoveNext
                Loop Until RS122.EOF
            End If
            RS122.Close
            Set RS122 = Nothing
        End If
    Next RpRow
    
    Screen.MousePointer = vbNormal
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing
Set RpCo4 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReDop " & Err.Number
Resume Next

End Sub
Public Sub S_ReEnt()
On Error GoTo LiErr
'Entriegelt eine Rechnung

Dim ReNum As Long
Dim PaNum As Long
