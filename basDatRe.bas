Public Function S_Vers() As String
On Error GoTo KoErr
'Prüft die Version der Datenbankdatei

Dim VerNr As String
Dim VerTa As Boolean

VerNr = "0"

Set ShmRS = DB1.OpenSchema(adSchemaTables)

Do 'Check if a special table is part of the database. In DAO it was easier todo
If ShmRS.Fields("TABLE_NAME").Value = "Tabelle_AbreOP" Then
    VerTa = True
    Exit Do
End If
ShmRS.MoveNext
Loop Until ShmRS.EOF

If VerTa = True Then
    Set RS141 = New ADODB.Recordset
    With RS141
        .CursorLocation = adUseClient
        .Source = "tblVersion"
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdTableDirect
    End With

    If RS141.RecordCount > 0 Then
        RS141.MoveLast
        VerNr = RS141.Fields("Version").Value
    Else
        VerNr = "000"
    End If
End If

ShmRS.Close
Set ShmRS = Nothing

S_Vers = VerNr

Exit Function

KoErr:
Exit Function

End Function
