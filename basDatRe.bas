                If TmpS8 = vbNullString Then
                    TmpS8 = TmAry(AkBlo)
                Else
                    TmpS8 = TmpS8 & TmAry(AkBlo)
                End If
            Next AkBlo
        Else
            PrBr1.Min = 0
            PrBr1.Max = ArGes
            PrBr2.Min = 0
            PrBr2.Max = AnzBu + 1

            For AkZei = 0 To ArGes 'Zeilen
                PrBr2.Value = AkZei + 1
                For AkSpa = 0 To ArSpa 'Spalten
                    If BuAry(AkSpa, AkZei) <> vbNullString Then
                        Select Case AkSpa
                        Case 0:
                            TmpS8 = TmpS8 & "K" & Format$(BuAry(AkSpa, AkZei), "000000") & Chr$(59)
                        Case 2:
                            If CLng(BuAry(AkSpa, AkZei)) = 1 Then
                                TmpS8 = TmpS8 & "A" & Chr$(59)
                            Else
                                TmpS8 = TmpS8 & "E" & Chr$(59)
                            End If
                        Case 4:
                            TmpS8 = TmpS8 & "I" & Format$(BuAry(AkSpa, AkZei), "000000") & Chr$(59)
                        Case 5:
                            TmpS8 = TmpS8 & "R" & Format$(BuAry(AkSpa, AkZei), "000000") & Chr$(59)
                        Case 10:
                            TmpS8 = TmpS8 & "B" & Format$(BuAry(AkSpa, AkZei), "000000") & Chr$(59)
                        Case 11:
                            If CBool(BuAry(18, AkZei)) = True Then
                                TmpS8 = TmpS8 & "0,00" & Chr$(59)
                            Else
                                If BuAry(AkSpa, AkZei) <> vbNullString Then
                                    If CSng(BuAry(AkSpa, AkZei)) > 0 Then
                                        TmpS8 = TmpS8 & Format$(BuAry(AkSpa, AkZei), "#,##0.00") & Chr$(59)
                                    Else
                                        TmpS8 = TmpS8 & "0,00" & Chr$(59)
                                    End If
                                Else
                                    TmpS8 = TmpS8 & "0,00" & Chr$(59)
                                End If
                            End If
                        Case 12:
                            If CBool(BuAry(18, AkZei)) = True Then
                                TmpS8 = TmpS8 & "0,00" & Chr$(59)
                            Else
                                If BuAry(AkSpa, AkZei) <> vbNullString Then
                                    If CSng(BuAry(AkSpa, AkZei)) > 0 Then
                                        TmpS8 = TmpS8 & Format$(BuAry(AkSpa, AkZei), "#,##0.00") & Chr$(59)
                                    Else
                                        TmpS8 = TmpS8 & "0,00" & Chr$(59)
                                    End If
                                Else
                                    TmpS8 = TmpS8 & "0,00" & Chr$(59)
                                End If
                            End If
                        Case 13:
                            TmpS8 = TmpS8 & Format$(BuAry(AkSpa, AkZei) * 100, "##,##00.00") & "%" & Chr$(59)
                        Case 18:
                            If CBool(BuAry(AkSpa, AkZei)) = True Then
                                TmpS8 = TmpS8 & "Ja" & Chr$(59)
                            Else
                                TmpS8 = TmpS8 & "Nein" & Chr$(59)
                            End If
                        Case Else:
                            TmpS8 = TmpS8 & SUmw(BuAry(AkSpa, AkZei)) & Chr$(59)
                        End Select
                    Else
                        TmpS8 = TmpS8 & Space$(1) & Chr$(59)
                    End If
                Next AkSpa
                If ZeiUm = True Then
                    TmpS8 = TmpS8 & vbCrLf
                Else
                    TmpS8 = TmpS8 & "|"
                End If
                DoEvents
                If TxDum.Text = "B" Then Exit For 'Abbrechen
                PrBr1.Value = AkZei
            Next AkZei
        End If
        
    End If
    RS128.Close
    Set RS128 = Nothing

    DoEvents
    Unload frmStatus
    Set frmStatus = Nothing
    
    DoEvents
    If Len(TmpS8) > 10 Then
        With clFil
            .FilPfa FiNa8
            .StrDa = TmpS8
            RetWe = .FilWrSt
            .StrDa = vbNullString
        End With
    End If

    '--------------------- Fragebögen ---------------------

    If GoBDx = False Then
        Set RS129 = New ADODB.Recordset
        RS129.CursorLocation = adUseClient
        Set RS129 = DBCmRe0("qryPatAnBoN")
        AnzFr = RS129.RecordCount

        If AnzFr > 0 Then
            frmStatus.Show
            DoEvents
            frmStatus.Caption = "Fragebogenexport"
            Set PrBr1 = frmStatus.prbStat1
            Set PrBr2 = frmStatus.prbStat2
            Set TxDum = frmStatus.txtDummy
            
            PrBr1.Min = 0
            PrBr1.Max = AnzFr
            PrBr2.Min = 0
            PrBr2.Max = AnzFr
            TmpS9 = "Patientennummer;Fragebogentext" & vbCrLf

            Do
            BerTx = vbNullString
            BogNr = RS129.Fields("ID5").Value
            PatNr = RS129.Fields("ID0").Value
            BerTx = S_AnTex(BogNr)
            TmpS9 = TmpS9 & Format$(PatNr, "000000") & ";" & BerTx & vbCrLf
            AktZa = AktZa + 1
            If TxDum.Text = "B" Then Exit Do 'Abbrechen
            PrBr1.Value = AktZa
            DoEvents
            RS129.MoveNext
            Loop Until RS129.EOF
        End If
        RS129.Close
        Set RS129 = Nothing

        DoEvents
        Unload frmStatus
        Set frmStatus = Nothing
        
        DoEvents
        If Len(TmpS9) > 10 Then
            With clFil
                .FilPfa FiNa9
                .StrDa = TmpS9
                RetWe = .FilWrSt
                .StrDa = vbNullString
            End With
        End If
    End If

    '------------------------------------------------

    DoEvents
    DBCmEx0 "qrySimPADZu"
    DBCmEx0 "qryAdrMark" 'remarkieren aller noch markierter Adressen
End If

DoEvents
GlNeK = GlKoX 'Protokolleintrag
With GlNeK
    .PatNr = BehNr
    .IdxNr = 0
    .EiDat = Format$(Date, "dd.mm.yyyy")
    .EiZei = TimeValue(Now)
    .EiTyp = 104
    .TeStr = "Exportiert - CSV Datei - (" & AnzPa & " Patienten " & AnzRe & " Rechnungen " & AnzPo & " Positionen " & AnzDi & " Diagnosen " & AnzRz & " Rezepte " & AnzPo & " Posten " & AnzTe & " Termine " & AnzBu & " Buchungen)"
    .ZiStr = Format$(Now, "hh:mm") & " Uhr"
    .NeuEi = True
    .KeiAk = True
    .Mitar = GlMiA(GlSmI, 2)
End With
S_Prot

Set CoDia = Nothing
Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo2 = Nothing

Set clFil = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_AlExT " & Err.Number
Exit Sub

End Sub
Public Function S_BuPr(Optional ByVal RecNr As Long, Optional ByVal TmGui As String) As Integer
On Error GoTo LiErr
'Prüft, ob schon eine Erlösbuchung in der Buchhaltung existiert

Set RS121 = New ADODB.Recordset
RS121.CursorLocation = adUseClient
If RecNr > 0 Then
    Set RS121 = DBCmRe1("qrySimBuRe", "@IdxNr", RecNr)
Else
    Set RS121 = DBCmRe1("qrySimBuGui", "@IdStr", TmGui)
End If

If RS121.RecordCount > 0 Then
    If RS121.Fields("Einnahme").Value <> vbNullString Then
        S_BuPr = 1
    Else
        S_BuPr = 0
    End If
    If RecNr = 0 Then
        If CBool(RS121.Fields("Lock").Value) = True Then
            S_BuPr = 2
        End If
    End If
Else
    S_BuPr = 0
End If

RS121.Close
Set RS121 = Nothing

Exit Function

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_BuPr " & Err.Number
Resume Next

End Function
