Dim AryDe() As String
Dim AryFe() As String
Dim Mld1, Tit1 As String

Dim RpCo1 As XtremeReportControl.ReportControl
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set CoDia = FM.comDialo
Set RpCo1 = FM.repCont1

StMit = GlMiA(GlSmI, 2)

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

Tit1 = "Termineimport"
ZeiUm = CBool(IniGetVal("System", "PADZei"))

With CoDia
    .CancelError = True
    .DialogStyle = 1
    .DefaultExt = "*.smt"
    .Filter = "SimpliMed Termine (*.smt)|*.smt|Alle Dateien (*.*)|*.*"
    .DialogTitle = "Wo befindet sich die Terminedatei?"
    .InitDir = GlIPf
