        Case 2: Set RpItm = RpRec.AddItem("D")
        Case Else: Set RpItm = RpRec.AddItem(vbNullString)
        End Select
    Else
        Set RpItm = RpRec.AddItem(vbNullString)
    End If
    RpItm.Alignment = xtpAlignmentCenter
    Set RpItm = RpRec.AddItem(Format$(RST.Fields("Betrag").Value, GlWa1))
    RpItm.Alignment = xtpAlignmentRight
    Set RpItm = RpRec.AddItem(Format$(RST.Fields("Bezahlt").Value, GlWa1))
    RpItm.Alignment = xtpAlignmentRight
    Set RpItm = RpRec.AddItem(Format$(Diffe, GlWa1))
    RpItm.Alignment = xtpAlignmentRight
    Set RpItm = RpRec.AddItem(RST.Fields("IDKurz").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("Offen").Value)
    RpItm.Alignment = xtpAlignmentRight
    Set RpItm = RpRec.AddItem(Format$(RST.Fields("Laborpreis").Value, GlWa1))
    RpItm.Alignment = xtpAlignmentRight
    Set RpItm = RpRec.AddItem(RST.Fields("Fallig").Value)
    RpItm.Alignment = xtpAlignmentCenter
    Set RpItm = RpRec.AddItem(RST.Fields("Währung").Value)
