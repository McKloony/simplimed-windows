Public Function S_ReNx(Optional ByVal Wartu As Boolean = False) As String
On Error GoTo SuErr
'Ergänz das Feld PLZ bei Rechnungsnummer

Dim NeuDa As Date
Dim GesZa As Long
Dim AktZa As Long
Dim ReNum As String
Dim TmpNr As String
Dim ReStr As String
Dim Lange As Integer
Dim Posit As Integer
Dim TxDum As VB.TextBox

Set RS121 = New ADODB.Recordset
With RS121
    .CursorLocation = adUseClient
    .Source = "qrySimReNuA"
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdTableDirect
End With

GesZa = RS121.RecordCount

If GesZa > 0 Then
    If Wartu = True Then
        Load frmStatus
        FM.Show
        DoEvents
    End If
    Set FM = frmStatus
    Set Lbl01 = FM.lblLab01
    Set PrBr1 = FM.prbStat1
    Set PrBr2 = FM.prbStat2
    Set TxDum = FM.txtDummy
    DoEvents
    PrBr2.Min = 0
    PrBr2.Max = GesZa
    Lbl01.Caption = "Rechnungsnummernprüfung..."
    DoEvents

    Posit = 0
    AktZa = 1
    Do
    If RS121.Fields("Datum").Value <> vbNullString Then
        NeuDa = RS121.Fields("Datum").Value
    Else
        NeuDa = Date
    End If
    If RS121.Fields("RechNr").Value <> vbNullString Then
        ReStr = RS121.Fields("RechNr").Value
        If Left$(ReStr, 1) Like "-" Then
            TmpNr = 0
        Else
            Posit = InStrRev(ReStr, "-", -1, vbTextCompare)
            If Posit > 0 Then
                Lange = Len(ReStr)
                TmpNr = Mid$(ReStr, Posit + 1, Lange - Posit)
                If Len(TmpNr) > 6 Then
                    TmpNr = Right$(TmpNr, 6)
                End If
            Else
                TmpNr = Right$(ReStr, 3)
            End If
        End If
    Else
        TmpNr = Right$(RS121.Fields("ID1").Value, 8)
    End If
    If TmpNr <> vbNullString Then
        ReNum = Format$(TmpNr, "00000000")
        RS121.Fields("PLZ").Value = ReNum
        RS121.Update
    End If
    
    If TxDum.Text = "B" Then Exit Do 'Abbrechen
    PrBr2.Value = AktZa
    DoEvents
    AktZa = AktZa + 1
    RS121.MoveNext
    Loop Until RS121.EOF
    DoEvents
    If Wartu = False Then
        Unload frmStatus
        Set frmStatus = Nothing
    End If
End If

RS121.Close
Set RS121 = Nothing

If ReNum <> vbNullString Then
    S_ReNx = Val(ReNum)
End If

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReNx " & Err.Number
Resume Next

End Function

