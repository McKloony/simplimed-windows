                Case Else:
                    Select Case ReTyp 'alter Rechnungstyp
                    Case "U":
                        SPopu Tit1, Mld1, IC48_Lock 'Gutschrift
                    Case "V": 'Kostenvoranschlag
                        ReStr = S_ReVo(Date, IdTyp, MaNum, MiNum, True)
                        DoEvents
                        Posit = InStrRev(ReStr, "-", -1, 1)
                        If Posit > 0 Then
                            PlStr = Mid$(ReStr, Posit + 1, Len(ReStr) - Posit)
