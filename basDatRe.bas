    If IsDate(CmDat.Text) = True Then
        NeuDa = CDate(CmDat.Text)
    Else
        NeuDa = Date
    End If
Else
    NeuDa = Date
End If

Select Case TyIdx
Case 1: TyStr = "R"
Case 2: TyStr = "V"
Case 3: TyStr = "L"
Case 4: TyStr = "A"
Case 5: TyStr = "U"
Case 6: TyStr = "M"
Case 7: TyStr = "G"
Case 8: TyStr = "I"
Case 9: TyStr = "Y"
