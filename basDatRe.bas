                                    DBCmEx4 "qrySimAdKr3d", "@IdDru", "@IdTyp", "@IdJah", "@IdxNr", -1, TypNr, SuJah, PatNr
                            Case 2: 'Quartal
                                    DBCmEx5 "qrySimAdKr7d", "@IdDru", "@IdTyp", "@IdSta", "@IdEnd", "@IdxNr", -1, 103, DaQu1, DaQu2, PatNr
                            Case 3: 'Monat
