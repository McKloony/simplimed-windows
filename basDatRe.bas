        BuVor = 0
        Mahnb = True
        RowNr = RpRow.Index

        If AktPo <= AnzPo Then
            GloRe(AktPo) = RowNr
        End If

        Set RpCol = RpCls.Find(Rec_ID1)
        ReNum = RpRow.Record(RpCol.ItemIndex).Value
        Set RpCol = RpCls.Find(Rec_ID0)
        PaNum = RpRow.Record(RpCol.ItemIndex).Value
        Set RpCol = RpCls.Find(Rec_IDZ)
        ZaZil = RpRow.Record(RpCol.ItemIndex).Value
        Set RpCol = RpCls.Find(Rec_RechNr)
        ReStr = RpRow.Record(RpCol.ItemIndex).Value
        Set RpCol = RpCls.Find(Rec_IDKurz)
        PatNa = RpRow.Record(RpCol.ItemIndex).Value
        Set RpCol = RpCls.Find(Rec_Datum)
        ReDat = RpRow.Record(RpCol.ItemIndex).Value
        Set RpCol = RpCls.Find(Rec_GuiID)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            TmGui = RpRow.Record(RpCol.ItemIndex).Value
        Else
            TmGui = CreateID("R")
        End If
        Set RpCol = RpCls.Find(Rec_Betrag)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            ReBet = RpRow.Record(RpCol.ItemIndex).Value
        Else
            ReBet = 0
        End If
        Set RpCol = RpCls.Find(Rec_Bezahlt)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            BezBe = RpRow.Record(RpCol.ItemIndex).Value
        Else
            BezBe = 0
        End If
        Set RpCol = RpCls.Find(Rec_Lock)
        If RpRow.Record(RpCol.ItemIndex).Checked = True Then
            ReLok = True
        Else
            ReLok = False
        End If
        Select Case GlBut
        Case RibTab_Abrechnung:
            Set RpCol = RpCls.Find(Rec_Selekt)
            ReAbg = CBool(RpRow.Record(RpCol.ItemIndex).Value)
        Case RibTab_Rechnungen:
            Set RpCol = RpCls.Find(Rec_Selekt)
            If LCase(RpRow.Record(RpCol.ItemIndex).Value) = "ja" Then
                ReAbg = True
            Else
                ReAbg = False
            End If
        End Select
        DoEvents

        TeTit = "Rechnung entriegeln"
        If Year(ReDat) <> Year(Date) Then
            If GlRnm = True Then 'Neustart der Rechnungsnummer am Jahresanfang
                TeMai = "Die Rechnung: " & ReStr & " sollte nicht entriegelt werden"
                TeInh = "Rechnungen aus dem Jahr " & Year(ReDat) & " sollten nicht mehr entriegelt werden, wenn im Jahr " & Year(Date) & " bereits mit einem neuen Rechnungsnummernkreis begonnen wurde."
                TeFus = "Wenn in den Einstellungen der Neustart der Rechnungsnummer am Jahresanfang aktiviert ist, besteht die Gefahr, dass beim erneuten Abschließen dieser Rechnung das Rechnungsdatum an das aktuelle Kalenderjahr angepasst und damit die Rechnungsnummer " & ReStr & " in den aktuellen Rechnungsnummernkreis gerät."
            End If
        Else
            TeMai = "Zur Rechnung: " & ReStr & " wurde bereits eine Einnahme gebucht"
            TeInh = "Durch das Entriegeln dieser Rechnung wird die zugehörige Erlösbuchung automatisch storniert. Soll die Rechnung: " & ReStr & " jetzt entriegelt werden?"
            TeFus = "Eine Rechnung, die bereits beglichen wurde wurde, kann nachträglich nur dann verändert werden, wenn die zugehörigen Einnahmebuchung storniert wurd."
        End If

        For AktZa = 1 To UBound(GlZah)
            If GlZah(AktZa, 0) = ZaZil Then
                Mahnb = CBool(GlZah(AktZa, 3))
                Exit For
            End If
        Next AktZa

        If ReLok = False Then 'Verriegelt
            If ReAbg = True Then 'Abgeschlossen
                If Year(ReDat) <> Year(Date) Then
                    BuVor = 1
                Else
                    If Mahnb = False Then 'Zahlungsziel Betrag dankend erhalten
                        BuVor = S_BuPr(0, TmGui)
                    Else
                        BuVor = S_BuPr(ReNum, vbNullString)
                    End If
                End If
                
                If GlBuL = True Then 'Echtes Löschen erlauben
                    BuVor = 0
                End If

                If BuVor > 0 Then
                    If AnzPo = 1 Then
                        If TeMai <> vbNullString Then
                            SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, False, FM.hwnd
                            If GlMes = 33565 Then
                                BuVor = 3
                            End If
                        Else
                            BuVor = 3
                        End If
                    Else
                        If TeMai <> vbNullString Then
                            SPopu TeTit, TeMai, IC48_Information
                        End If
                        BuVor = 3
                    End If
                    If BuVor = 3 Then
                        DBCmEx2 "qrySimReSto", "@IdSto", "@IdxNr", False, ReNum 'Stornierung rückgängig
                        DoEvents
                        DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", 0, ReNum 'Bezahltbetrag anpassen
                        DoEvents
                        DBCmEx2 "qrySimReMa2", "@PaSel", "@IdxNr", 0, ReNum 'Rechnung entriegeln
                        DoEvents
                        DBCmEx2 "qrySimAbDru", "@IdAbg", "@IdxNr", 0, ReNum 'Leistungen ungedruckt
                        DoEvents
                        If GlBuL = True Then 'echtes Löschen erlauben
                            DBCmEx1 "qrySimBuLoP", "@IdxNr", ReNum 'Buchung löschen
                        Else
                            DBCmEx2 "qrySimBuStr", "@IdSto", "@IdxNr", True, ReNum 'Buchung Stornieren
                        End If
                        DoEvents
                        DBCmEx1 "qrySimOPLoR", "@IdxNr", ReNum 'Posten löschen
                        DoEvents
                        DBCmEx2 "qrySimAbLoT", "@IdTyp", "@ReNum", 6, ReNum 'Anzahlungen entfernen
                        DoEvents
                        DBCmEx2 "qrySimReSm3", "@IdBet", "@IdxNr", 0, ReNum 'Anzahlungen Nullen
                        DoEvents
                        DBCmEx3 "qrySimBaRec", "@IdBez", "@IdSel", "@IdxNr", 0, 0, ReNum 'Bankzuordnung
                        DoEvents
                        S_BuBa ReNum
                        DoEvents
                    End If
                Else
                    DBCmEx2 "qrySimReSto", "@IdSto", "@IdxNr", False, ReNum 'Stornierung rückgängig
                    DoEvents
                    DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", 0, ReNum 'Bezahltbetrag anpassen
                    DoEvents
                    DBCmEx2 "qrySimReMa2", "@PaSel", "@IdxNr", 0, ReNum 'Rechnung entriegeln
                    DoEvents
                    DBCmEx2 "qrySimAbDru", "@IdAbg", "@IdxNr", 0, ReNum 'Leistungen ungedruckt
                    DoEvents
                    DBCmEx1 "qrySimOPLoR", "@IdxNr", ReNum 'Posten löschen
                    DoEvents
                    DBCmEx3 "qrySimBaRec", "@IdBez", "@IdSel", "@IdxNr", 0, 0, ReNum 'Bankzuordnung
                    DoEvents
                    S_BuBa ReNum
                    DoEvents
                End If

                If Mahnb = False Then 'Zahlungsziel Betrag dankend erhalten
                    If GlBuL = True Then 'Echtes Löschen erlauben
                        DBCmEx1 "qrySimBuLoG", "@IdStr", TmGui
                    Else
                        If BuVor = 0 Then
                            DBCmEx2 "qrySimBuStg", "@IdSto", "@IdStr", True, TmGui
                        End If
                    End If
                Else
                    If GlBuL = True Then 'Echtes Löschen erlauben
                        DBCmEx1 "qrySimBuLoP", "@IdxNr", ReNum
                    Else
                        If BuVor = 0 Then
                            DBCmEx2 "qrySimBuStr", "@IdSto", "@IdxNr", True, ReNum
                        End If
                    End If
                End If
                DoEvents

                If BuVor = 0 Then
                    If TmGui <> vbNullString Then
                        DBCmEx1 "qrySimAbLoG", "@IdStr", TmGui
                        DoEvents
                        GlNeK = GlKoX 'Protokolleintrag
                        With GlNeK
                            .PatNr = PaNum
                            .IdxNr = 0
                            .EiDat = Format$(Date, "dd.mm.yyyy")
                            .EiZei = TimeValue(Now)
                            .EiTyp = 104
                            .TeStr = "Rechnung entriegelt - " & ReStr & Chr$(32) & PatNa
                            .ZiStr = Format$(Now, "hh:mm") & " Uhr"
                            .NeuEi = True
                            .KeiAk = True
                            .Mitar = GlMiA(GlSmI, 2)
                        End With
                        S_Prot
                    End If
                End If
            End If
        Else
            Tit1 = "GoBD Verriegelung"
            Mld1 = "Diese Rechnung wurde bereits GoBD verriegelt und kann nicht mehr manipuliert werden"
            SPopu Tit1, Mld1, IC48_Information
        End If
    
        If AnzPo > 1 Then
            If TxDum.Text = "B" Then Exit For 'Abbrechen
            PrBr1.Value = AktPo
        End If
        AktPo = AktPo + 1
        DoEvents
    End If
Next RpRow

If AnzPo > 1 Then
    DoEvents
    Unload frmStatus
    Set frmStatus = Nothing
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing
Set RpCo4 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReEnt " & Err.Number
Resume Next

End Sub

Public Sub S_ReExC(Optional ByVal EmVer As Integer, Optional ByVal NoAbs As Boolean = False)
On Error GoTo LiErr
'Exporiert die Rechnungen CSV

Dim ReDat As Date
Dim ReNum As Long 'Rechnungsnummer
Dim PatNr As Long 'Patientennummer
Dim ManNr As Long
Dim MitNr As Long
Dim RowNr As Long 'Zeilennummer
Dim AnzSe As Long 'Selektierte Rechnungen
Dim AnzPo As Long 'Anzahl Positionen
Dim AnzRe As Long 'Anzahl Rechnungen
Dim BehNr As Long 'Behandlernummer
Dim ArGes As Long
Dim AktZa As Long
Dim AkZei As Long
Dim AkSpa As Long
Dim Lange As Long
Dim ExOrd As String
Dim ReStr As String
Dim DaNam As String 'Dateinamen
Dim DaNaO As String
Dim FilNa As String 'Filename
Dim FiNam As String
Dim DaPfa As String 'Pfadnamen
Dim EmAdr As String 'Emailadresse
Dim EmBet As String 'Emailbetreff
Dim EmTex As String 'Emailtext
Dim AnwNa As String 'Anmwendername
Dim ReLis As String 'Rechnungsliste
Dim TmpS2 As String 'Tempstring
Dim RetWe As Boolean
Dim ZeiUm As Boolean
Dim Umlau As Boolean
Dim Frage As Integer
Dim ArSpa As Integer
Dim AkBlo As Integer
Dim BloZa As Integer
Dim AnzDa As Integer
Dim AktDa As Integer
Dim ReAry As Variant
Dim TmAry() As String
Dim Mld1, Tit1 As String
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Const BlGro = 100

Set FM = frmMain
Set CoDia = FM.comDialo
Set RpCo4 = FM.repCont4
Set RpCo3 = FM.repCont3

Select Case GlBut
Case RibTab_Abrechnung:
    Set RpSel = RpCo3.SelectedRows
    Set RpCls = RpCo3.Columns
Case RibTab_Rechnungen:
    Set RpSel = RpCo4.SelectedRows
    Set RpCls = RpCo4.Columns
End Select

ZeiUm = True
Umlau = CBool(IniGetVal("System", "PADUml"))
Mld1 = "Die Datei existiert bereits, soll diese überschrieben werden?"
Tit1 = "Rechnungsexport"
AnzSe = RpSel.Count

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

If GlRDP = True Then
    If clFil.FilDir(GlIPf) = False Then
        ExOrd = GlDpf & "Import\"
    Else
        ExOrd = GlIPf
    End If
Else
    If clFil.FilDir(GlExO) = False Then
        ExOrd = GlDpf & "Export\"
    Else
        ExOrd = GlExO
    End If
End If
If Right$(ExOrd, 1) <> "\" Then
    ExOrd = ExOrd & "\"
End If

If AnzSe > 0 Then
    ReDim GloRe(AnzSe)
    Select Case GlBut
    Case RibTab_Abrechnung:
        AnzPo = RpCo3.Records.Count
    Case RibTab_Rechnungen:
        AnzPo = RpCo4.Records.Count
    End Select
    
    Set RpRow = RpSel(0)
    Select Case GlBut
    Case RibTab_Abrechnung:
        Set RpCol = RpCls.Find(Rec_IDP)
        BehNr = RpRow.Record(RpCol.ItemIndex).Value
    Case RibTab_Rechnungen:
        Set RpCol = RpCls.Find(Rec_IDP)
        BehNr = RpRow.Record(RpCol.ItemIndex).Value
    End Select
    AnwNa = S_AdIdx(BehNr, "Vorname") & Chr$(32) & S_AdIdx(BehNr, "Name")
    
    AnwNa = SUmw(AnwNa, True, True, True, True)
    AnwNa = Replace(AnwNa, Chr$(32), "_", 1)
    
    DaNam = AnwNa & "_" & Format$(DatePart("d", Date, vbMonday), "00") & Format$(DatePart("m", Date, vbMonday), "00") & DatePart("yyyy", Date, vbMonday) & "_X.csv"
    
    With CoDia
        .CancelError = True
        .DialogStyle = 1
        .DefaultExt = "*.csv"
        .Filter = "Excel-Dateien (*.csv)|*.csv|Alle Dateien (*.*)|*.*"
        .DialogTitle = "Bitte Name und Ordner der Abrechnungsdatei angeben"
        .FileName = ExOrd & DaNam
        .InitDir = ExOrd
        .ShowSave
        FilNa = .FileName
        If .FileTitle = vbNullString Then Exit Sub
    End With
    If Right$(FilNa, 4) <> ".csv" Then FilNa = FilNa & ".csv"

    With clFil
        .FilPfa FilNa
        DaPfa = .DaPfa
        DaNaO = .DaNaO
        If .FilVor(FilNa) = True Then
            Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
            If Frage = 6 Then
                .DaLoe = FilNa & vbNullChar
                .FilLoe
                .DaLoe = FiNam & vbNullChar
                .FilLoe
            Else
                Exit Sub
            End If
        End If
    End With
    
    If FilNa <> vbNullString Then
        DBCmEx0 "qrySimPADZu"
        DBCmEx0 "qryAdrMark" 'remarkieren aller noch markierter Einträge
        DoEvents
        
        If AnzSe = 1 Then
            For Each RpRow In RpSel
                If RpRow.GroupRow = False Then
                    RowNr = RpRow.Index
                    Set RpCol = RpCls.Find(Rec_ID1)
                    ReNum = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Rec_ID0)
                    PatNr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Rec_IDP)
                    ManNr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Rec_IDM)
                    MitNr = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Rec_Datum)
                    ReDat = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Rec_RechNr)
                    ReStr = RpRow.Record(RpCol.ItemIndex).Value
                    DBCmEx2 "qrySimReMa3", "@Druck", "@IdxNr", -1, ReNum
                    DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", -1, ReNum 'Rechung Bezahlt Kennzeichnen
                    DBCmEx2 "qrySimReTyp", "@ReTyp", "@IdxNr", "A", ReNum
                End If
            Next RpRow
        ElseIf AnzSe > 1 Then
            For Each RpRow In RpSel
                If RpRow.GroupRow = False Then
                    RowNr = RpRow.Index
                    Set RpCol = RpCls.Find(Rec_ID1)
                    ReNum = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Rec_ID0)
                    PatNr = RpRow.Record(RpCol.ItemIndex).Value
                    DBCmEx2 "qrySimReMa3", "@Druck", "@IdxNr", -1, ReNum
                End If
            Next RpRow
        End If

        '---
        
        Set RS122 = New ADODB.Recordset 'Rechnungen
        With RS122
            .CursorLocation = adUseClient
            .Source = "qrySimReExp12"
            .ActiveConnection = DB1
            .CursorType = adOpenForwardOnly
            .LockType = adLockReadOnly
            .Open Options:=adCmdTableDirect
        End With
        AnzRe = RS122.RecordCount

        If AnzRe > 0 Then
            frmStatus.Show
            DoEvents
            frmStatus.Caption = "Rechnungsexport"
            Set PrBr1 = frmStatus.prbStat1
            Set PrBr2 = frmStatus.prbStat2
            Set TxDum = frmStatus.txtDummy
        
            ReAry = RS122.GetRows 'Zuweisen der Rechnungen
            DoEvents
                                                
            ArGes = UBound(ReAry, 2)
            ArSpa = UBound(ReAry, 1)
        
            If ArGes > BlGro Then
                BloZa = Fix(ArGes / BlGro) + 1
                ReDim TmAry(BloZa)
                AktZa = 0
                PrBr1.Min = 0
                PrBr1.Max = BlGro
                PrBr2.Min = 0
                PrBr2.Max = BloZa + 1
                
                For AkBlo = 0 To BloZa
                    PrBr2.Value = AkBlo + 1
                    For AkZei = 0 To BlGro  'Zeilen
                        For AkSpa = 0 To ArSpa 'Spalten
                            If AktZa <= ArGes Then
                                If ReAry(AkSpa, AktZa) <> vbNullString Then
                                    If Len(ReAry(AkSpa, AktZa)) > 250 Then
                                        TmAry(AkBlo) = TmAry(AkBlo) & SUmw(Left$(ReAry(AkSpa, AktZa), 250), False, Umlau) & Chr$(59)
                                    Else
                                        TmAry(AkBlo) = TmAry(AkBlo) & SUmw(ReAry(AkSpa, AktZa), False, Umlau) & Chr$(59)
                                    End If
                                Else
                                    TmAry(AkBlo) = TmAry(AkBlo) & Space$(1) & Chr$(59)
                                End If
                            End If
                        Next AkSpa
                        AktZa = AktZa + 1
                        If ZeiUm = True Then
                            TmAry(AkBlo) = TmAry(AkBlo) & vbCrLf
                        Else
                            If TmAry(AkBlo) <> vbNullString Then
                                If Right$(TmAry(AkBlo), 2) <> "||" Then
                                    TmAry(AkBlo) = TmAry(AkBlo) & "|"
                                End If
                            End If
                        End If
                        DoEvents
                        If TxDum.Text = "B" Then Exit For 'Abbrechen
                        PrBr1.Value = AkZei
                    Next AkZei
                    If TmpS2 = vbNullString Then
                        TmpS2 = TmAry(AkBlo)
                    Else
                        TmpS2 = TmpS2 & TmAry(AkBlo)
                    End If
                Next AkBlo
            Else
                PrBr1.Min = 0
                PrBr1.Max = ArGes
                PrBr2.Min = 0
                PrBr2.Max = AnzRe + 1
                
                For AkZei = 0 To ArGes 'Zeilen
                    PrBr2.Value = AkZei + 1
                    For AkSpa = 0 To ArSpa 'Spalten
                        If ReAry(AkSpa, AkZei) <> vbNullString Then
                            If Len(ReAry(AkSpa, AkZei)) > 250 Then
                                TmpS2 = TmpS2 & SUmw(Left$(ReAry(AkSpa, AkZei), 250), False, Umlau) & Chr$(59)
                            Else
                                TmpS2 = TmpS2 & SUmw(ReAry(AkSpa, AkZei), False, Umlau) & Chr$(59)
                            End If
                        Else
                            TmpS2 = TmpS2 & Space$(1) & Chr$(59)
                        End If
                    Next AkSpa
                    If ZeiUm = True Then
                        TmpS2 = TmpS2 & vbCrLf
                    Else
                        If Right$(TmpS2, 2) <> "||" Then
                            TmpS2 = TmpS2 & "|"
                        End If
                    End If
                    DoEvents
                    If TxDum.Text = "B" Then Exit For 'Abbrechen
                    PrBr1.Value = AkZei
                Next AkZei
            End If
                                    
            DoEvents
            With clFil
                .FilPfa FilNa
                .StrDa = TmpS2
                RetWe = .FilWrSt
                .StrDa = vbNullString
            End With
            
            DoEvents
            Unload frmStatus
            Set frmStatus = Nothing
        End If
        RS122.Close
        Set RS122 = Nothing
                
        '---
                
        DoEvents
        DBCmEx0 "qrySimPADZu"
        DoEvents
                
        If EmVer > 0 Then
            EmAdr = S_AdIdx(BehNr, "Telefon5")
            With GlTxV
                .TxStr = GlEmT(1, 3)
                .ReStr = ReStr
                .Datum = ReDat
                .DaStr = ReDat
                .MitNr = MitNr
                .ManNr = ManNr
                .PatNr = PatNr
            End With
            EmBet = SEmTx()
            EmTex = vbCrLf & "Abrechnung vom " & Format$(Date, "dd.mm.yyyy") & vbCrLf & "Anzahl Rechnungen: " & AnzRe & vbCrLf & "Anwender: " & AnwNa & vbCrLf & vbCrLf & ReLis
            SMaNe 0, EmAdr, , EmTex, EmBet, FilNa
        Else
            MsgBox AnzRe & " Rechnungen wurden erfolgreich exportiert", vbInformation, Tit1
        End If
    End If
End If

DoEvents
GlNeK = GlKoX 'Protokolleintrag
With GlNeK
    .PatNr = BehNr
    .IdxNr = 0
    .EiDat = Format$(Date, "dd.mm.yyyy")
    .EiZei = TimeValue(Now)
    .EiTyp = 104
    .TeStr = "Exportiert - CSV Datei - (" & AnzSe & " Positionen)"
    .ZiStr = Format$(Now, "hh:mm") & " Uhr"
    .NeuEi = True
    .KeiAk = True
    .Mitar = GlMiA(GlSmI, 2)
End With
S_Prot

Set CoDia = Nothing
Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing
Set RpCo4 = Nothing

Set clFil = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReExC " & Err.Number
Exit Sub

End Sub
Public Sub S_ReExM()
On Error GoTo LiErr
'Datei für Abrechnungsstelle in mediserv Format

Dim TmpDa As Date
Dim IdxNr As Long
Dim RowNr As Long
Dim Posit As Long
Dim AktRe As Long   'Aktuelle Rechnung
Dim ZeiGe As Long   'Gesamtzahl aller Zeilen
