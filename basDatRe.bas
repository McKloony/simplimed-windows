Dim KoTex As String * 40 'Kommentartext
Dim VolNa As String * 11 'Volumennamen
Dim ReNum As String * 4  'Formatierte Rechnungsnummer
Dim KunNr As String * 6  'Mitgliedsnummer
Dim Gesch As String * 1  'Geschlecht
Dim VeArt As String * 2  'Vertragsart
Dim Ziffe As String * 7  'Ziffer
Dim Aznah As String * 4  'Anzahl
Dim PosKz As String * 1  'Positionskennzeichen
Dim VoZei As String * 1  'Vorzeichen
Dim Fakto As String * 8  'Steigerungsfaktor
Dim Einze As String * 7  'Einzelbetrag
Dim Gesam As String * 7  'Gesamtbetrag
Dim SumHo As String * 8  'Formatierte Honorarsumme
Dim SumGe As String * 8  'Formatierte Gesamtsumme
Dim SumKo As String * 8  'Formatierte bes. Kosten
Dim SuMan As String * 8  'Formatierte Anzahlung
Dim PosDa As String * 8  'Positionsdatum
Dim SumRe As String * 11 'Formatierte Rechnungssumme
Dim VerNr As String * 3  'Taraifnummer
Dim KatNr As String * 3  'Katalognummer
Dim VerSt As String * 94 'Versicherung
Dim PVKen As String * 2
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim ZeTyp As Integer     'Abrechnungszeilentyp
Dim ZwZei As Integer     'Zweite Zeile erforderlich
Dim StaNa As Integer     'Stapelzahl
Dim AnzDa As Integer     'Anzahl gefundener Dateien
Dim LeSta As Integer     'Letze Stapelnummer
Dim AnzAn As Integer     'Anzahl Anzahlungen
Dim StaWe As Integer
Dim AktWe As Integer
Dim AktPo As Integer
Dim Lange As Integer
Dim LeZif As Integer
Dim AktZa As Integer
Dim ReSto As Boolean
Dim ZeiUm As Boolean
Dim Umlau As Boolean
Dim Anlog As Boolean
Dim RetWe As Boolean
Dim DiNam() As String
Dim Frage As Integer
Dim Mld1, Mld2 As String
Dim Mld3, Tit1 As String
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set CoDia = FM.comDialo
Set RpCo4 = FM.repCont4
Set RpCo3 = FM.repCont3

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

Select Case GlBut
Case RibTab_Abrechnung:
    Set RpSel = RpCo3.SelectedRows
    Set RpCls = RpCo3.Columns
    Set RpSel = RpCo3.SelectedRows
Case RibTab_Rechnungen:
    Set RpSel = RpCo4.SelectedRows
    Set RpCls = RpCo4.Columns
    Set RpSel = RpCo4.SelectedRows
End Select

Set RpRow = RpSel(0)
If RpRow.GroupRow = False Then
    Set RpCol = RpCls.Find(Rec_IDP)
    If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
        ManNr = RpRow.Record(RpCol.ItemIndex).Value
    End If
End If

PVKen = "MA"
ZeiGe = 0
AktZa = 0
ReSum = 0
AnzAn = 0
ZeiUm = CBool(IniGetVal("System", "PADZei"))
Umlau = CBool(IniGetVal("System", "PADUml"))
Mld1 = "Die Datei existiert bereits, soll diese wirklich überschrieben werden?"
Mld2 = "Im Mandanteneingabedialog wurde keine gültige PAD Kundennummer erfasst."
Tit1 = "mediserv Export"
Lange = Len(GlEPf)
AnzSe = RpSel.Count

TmpKu = S_AdIdx(ManNr, "Postfach")

If TmpKu <> vbNullString Then
    If TmpKu <> "999999" Then
        If TmpKu <> "0" Then
            If IsNumeric(TmpKu) = True Then
                KunNr = Format$(TmpKu, "000000")
            Else
                KunNr = Left$(TmpKu, 6)
            End If
            DaNam = "PV" & KunNr & ".dat"
        Else
            WindowMess Mld2, Dial3, Tit1, FM.hwnd
            Exit Sub
        End If
    Else
        WindowMess Mld2, Dial3, Tit1, FM.hwnd
        Exit Sub
    End If
Else
    WindowMess Mld2, Dial3, Tit1, FM.hwnd
    Exit Sub
End If

LeSta = Val(S_AdIdx(ManNr, "PrGrup"))
Mld3 = "Die Im Exportordner vorhandene Abrechnungsdatei hat die Stapelnummer: " & Format$(StaNa, "000000") & ". Diese ist größer als die zum Mandanten eingetragene Stapelnummer: " & Format$(LeSta, "000000") & ". Soll nun die größere Stapelnummer: " & Format$(StaNa, "000000") & " verwendet werden?"
DaNam = "MA" & Format$(LeSta + 1, "0000") & ".001"

If AnzSe > 0 Then
    ReDim GloRe(AnzSe)
Else
    Exit Sub
End If

If GlRDP = True Then
    If LCase(GlEPf) = LCase(GlIPf) Then
        ExpOr = GlDpf & "Export\"
    Else
        ExpOr = GlEPf
    End If
Else
    ExpOr = GlEPf
End If

If clFil.FilVor(GlEPf & "MA*.*") = True Then
    AnzDa = clFil.FilLis(GlEPf, "MA*.*", DiNam)
    If AnzDa > 0 Then
        StaNa = Val(Mid$(DiNam(AnzDa), 3, 4)) + 1
    Else
        StaNa = 1
    End If
Else
    StaNa = 1
End If

If StaNa > LeSta Then
    Frage = WindowMess(Mld3, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then
        LeSta = StaNa
    End If
End If

DBCmEx2 "qrySimPAD3", "@StaNr", "@IdxNr", LeSta + 1, ManNr

VolNa = DaNam

With CoDia
    .CancelError = True
    .DialogStyle = 1
    .DefaultExt = "*.*"
    .Filter = "MAD Dateien (*.001)|*.001|Alle Dateien (*.*)|*.*"
    .DialogTitle = "Bitte Name und Ordner der Abrechnungsdatei angeben"
    .FileName = ExpOr & DaNam
    .InitDir = ExpOr
    .ShowSave
    FilNa = .FileName
    If .FileTitle = vbNullString Then
        Set CoDia = Nothing
        Set RpSel = Nothing
        Set RpCls = Nothing
        Set RpCo3 = Nothing
        Set RpCo4 = Nothing
        Set clFil = Nothing
        Exit Sub
    End If
End With
If Right$(FilNa, 4) <> ".001" Then
    FilNa = FilNa & ".001"
End If

With clFil
    If .FilVor(FilNa) = True Then
        Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
        If Frage = 6 Then
            .DaLoe = FilNa & vbNullChar
            .FilLoe
        Else
             Set CoDia = Nothing
            Set RpSel = Nothing
            Set RpCls = Nothing
            Set RpCo3 = Nothing
            Set RpCo4 = Nothing
            Set clFil = Nothing
            Exit Sub
        End If
    End If
End With

If FilNa <> vbNullString Then
    DBCmEx0 "qrySimPADZu"
    DBCmEx0 "qryAdrMark" 'remarkieren aller noch markierter Adressen
    DoEvents
    
    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            RowNr = RpRow.Index
            If AktPo <= RpSel.Count Then
                GloRe(AktPo) = RowNr
            End If

            Set RpCol = RpCls.Find(Rec_ID1)
            IdxNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Betrag)
            ReBet = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Bezahlt)
            BeBet = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Storniert)
            ReSto = CBool(RpRow.Record(RpCol.ItemIndex).Value)
            Set RpCol = RpCls.Find(Rec_Steuer)
            ReStu = CSng(RpRow.Record(RpCol.ItemIndex).Value)
            Set RpCol = RpCls.Find(Rec_IDP)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                ManNr = RpRow.Record(RpCol.ItemIndex).Value
            Else
                ManNr = 0
            End If
            StStr = Format$(ReStu, "00") & "00"

            If ReBet > 0 Then
                If ReSto = False Then
                    DBCmEx2 "qrySimReMa3", "@Druck", "@IdxNr", -1, IdxNr
                    DBCmEx2 "qrySimReOP", "@IdOff", "@IdxNr", -1, IdxNr 'Rechung Bezahlt Kennzeichnen
                    DBCmEx2 "qrySimReTyp", "@ReTyp", "@IdxNr", "A", IdxNr
                    DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", ReBet, IdxNr
                End If
            End If
        End If
    Next RpRow
    
    MeStr = KunNr & PVKen & "0000" & "000" & VolNa & PVKen & KunNr & ".DAT" & Format$(Now, "YYYYMMDD") & Format$(Now, "hhmm") & Format$(LeSta + 1, "0000")

    Set RS125 = New ADODB.Recordset
    With RS125
        .CursorLocation = adUseClient
        .Source = "qrySimPAD1"
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdTableDirect
    End With

    AktWe = 1
    AnzRe = RS125.RecordCount

    If AnzRe > 0 Then
        frmStatus.Show
        DoEvents
        frmStatus.Caption = "PAD/PVS Export"
        Set PrBr1 = frmStatus.prbStat1
        Set PrBr2 = frmStatus.prbStat2
        Set TxDum = frmStatus.txtDummy
        PrBr2.Min = 0
        PrBr2.Max = AnzRe
    
        FoWar = Left$(RS125.Fields("Symbol").Value, 3)
        If FoWar = "€  " Then FoWar = "EUR"
        MeStr = MeStr & FoWar & Space$(71) & vbCrLf
        ZeiGe = ZeiGe + 1
    
        Do 'Rechnungen
        ReZei = 0
        DiaMa = vbNullString
        DiaKa = vbNullString
        AktRe = RS125.Fields("IDR").Value
        ReNum = Format$(Right$(RS125.Fields("RechNr").Value, 4), "0000")
        PatNr = Format$(Right$(RS125.Fields("PatNr").Value, 4), "0000000000")

        If Not IsNull(RS125.Fields("R_Anrede").Value) Then
            If LCase(RS125.Fields("R_Anrede").Value) = "firma" Then
                ReAnr = "I"
            Else
                ReAnr = UCase(Left$(RS125.Fields("R_Anrede").Value, 1))
                Select Case ReAnr
                Case "H":
                Case "F":
                Case "I":
                Case "P":
                Case Else: ReAnr = "O"
                End Select
            End If
        Else
            ReAnr = "O"
        End If
        If Not IsNull(RS125.Fields("Anrede").Value) Then
            If UCase(RS125.Fields("Anrede").Value) = "Firma" Then
                PaAnr = "I"
            Else
                PaAnr = UCase(Left$(RS125.Fields("Anrede").Value, 1))
                Select Case PaAnr
                Case "H":
                Case "F":
                Case "I":
                Case "P":
                Case Else: PaAnr = "O"
                End Select
            End If
        Else
            PaAnr = "O"
        End If
        
        If Not IsNull(RS125.Fields("R_Name").Value) Then
            If RS125.Fields("R_Name").Value <> vbNullString Then
                ReNam = SUmw(Left$(RS125.Fields("R_Name").Value, 40), False, Umlau)
            Else
                ReNam = vbNullString
            End If
            If RS125.Fields("R_Vorname").Value <> vbNullString Then
                ReVor = SUmw(Left$(RS125.Fields("R_Vorname").Value, 40), False, Umlau)
            Else
                ReVor = vbNullString
            End If
            If RS125.Fields("R_Straße").Value <> vbNullString Then
                ReStr = SUmw(Left$(RS125.Fields("R_Straße").Value, 40), False, Umlau)
            Else
                ReStr = vbNullString
            End If
            If RS125.Fields("R_PLZ").Value <> vbNullString Then
                RePLZ = SUmw(Left$(RS125.Fields("R_PLZ").Value, 5), False, Umlau)
            Else
                RePLZ = vbNullString
            End If
            If Not IsNull(RS125.Fields("R_Ort").Value) Then
                ReOrt = SUmw(Left$(RS125.Fields("R_Ort").Value, 35), False, Umlau)
            Else
                ReOrt = vbNullString
            End If
            If Not IsNull(RS125.Fields("R_LK").Value) Then
                ReLan = SUmw(Left$(RS125.Fields("R_LK").Value, 3), False, Umlau)
            Else
                ReLan = "D"
            End If
            If Not IsNull(RS125.Fields("R_Titel").Value) Then
                ReTit = SUmw(Left$(RS125.Fields("R_Titel").Value, 15), False, Umlau)
            Else
                ReTit = vbNullString
            End If
        Else
            If RS125.Fields("Name").Value <> vbNullString Then
                ReNam = SUmw(Left$(RS125.Fields("Name").Value, 40), False, Umlau)
            Else
                ReNam = vbNullString
            End If
            If RS125.Fields("Vorname").Value <> vbNullString Then
                ReVor = SUmw(Left$(RS125.Fields("Vorname").Value, 40), False, Umlau)
            Else
                ReVor = vbNullString
            End If
            If RS125.Fields("Straße").Value <> vbNullString Then
                ReStr = SUmw(Left$(RS125.Fields("Straße").Value, 40), False, Umlau)
            Else
                ReStr = vbNullString
            End If
            If RS125.Fields("Ort").Value <> vbNullString Then
                ReOrt = SUmw(Left$(RS125.Fields("Ort").Value, 35), False, Umlau)
            Else
                ReOrt = vbNullString
            End If
            If RS125.Fields("PLZ").Value <> vbNullString Then
                RePLZ = SUmw(Left$(RS125.Fields("PLZ").Value, 5), False, Umlau)
            Else
                RePLZ = vbNullString
            End If
            If Not IsNull(RS125.Fields("LK").Value) Then
                ReLan = SUmw(Left$(RS125.Fields("LK").Value, 3), False, Umlau)
            Else
                ReLan = "D"
            End If
            If Not IsNull(RS125.Fields("Titel").Value) Then
                ReTit = SUmw(Left$(RS125.Fields("Titel").Value, 15), False, Umlau)
            Else
                ReTit = vbNullString
            End If
        End If
        If RS125.Fields("Name").Value <> vbNullString Then
            PaNam = SUmw(Left$(RS125.Fields("Name").Value, 40), False, Umlau)
        Else
            PaNam = vbNullString
        End If
        If RS125.Fields("Vorname").Value <> vbNullString Then
            PaVor = SUmw(Left$(RS125.Fields("Vorname").Value, 40), False, Umlau)
        Else
            PaVor = vbNullString
        End If
        If Not IsNull(RS125.Fields("LK").Value) Then
            PaLan = SUmw(Left$(RS125.Fields("LK").Value, 3), False, Umlau)
        Else
            PaLan = "D"
        End If
        
        If RS125.Fields("R_Land").Value <> vbNullString Then
            If RS125.Fields("R_PLZ").Value <> vbNullString Then
                If RS125.Fields("R_Ort").Value <> vbNullString Then
                    ReEmp = RS125.Fields("R_Land").Value & " " & RS125.Fields("R_PLZ").Value & " " & RS125.Fields("R_Ort").Value
                Else
                    ReEmp = RS125.Fields("R_Land").Value & " " & RS125.Fields("R_PLZ").Value
                End If
            Else
                If RS125.Fields("R_Ort").Value <> vbNullString Then
                    ReEmp = RS125.Fields("R_Land").Value & " " & RS125.Fields("R_Ort").Value
                Else
                    ReEmp = RS125.Fields("R_Land").Value
                End If
            End If
        Else
            If RS125.Fields("R_PLZ").Value <> vbNullString Then
                If RS125.Fields("R_Ort").Value <> vbNullString Then
                    ReEmp = RS125.Fields("R_PLZ").Value & " " & RS125.Fields("R_Ort").Value
                Else
                    ReEmp = RS125.Fields("R_PLZ").Value
                End If
            Else
                If RS125.Fields("R_Ort").Value <> vbNullString Then
                    ReEmp = RS125.Fields("R_Ort").Value
                Else
                    ReEmp = vbNullString
                End If
            End If
        End If

        If RS125.Fields("Vorname").Value <> vbNullString Then
            If RS125.Fields("Name").Value <> vbNullString Then
                Behan = SUmw(RS125.Fields("Vorname").Value & " " & RS125.Fields("Name").Value, False, Umlau)
            Else
                Behan = SUmw(RS125.Fields("Vorname").Value, False, Umlau)
            End If
        ElseIf RS125.Fields("Name").Value <> vbNullString Then
            Behan = SUmw(RS125.Fields("Name").Value, False, Umlau)
        End If

        Posit = InStr(1, ReLan, "-", 1)
        If Posit > 0 Then ReLan = Mid$(ReLan, 1, Len(ReLan) - Posit)
        Posit = InStr(1, PaLan, "-", 1)
        If Posit > 0 Then PaLan = Mid$(PaLan, 1, Len(PaLan) - Posit)
        
        If Not IsNull(RS125.Fields("Titel").Value) Then
            PaTit = Left$(RS125.Fields("Titel").Value, 15)
        Else
            PaTit = vbNullString
        End If
        
        If Not IsNull(RS125.Fields("R_Geboren").Value) Then
            ReGeb = Format$(RS125.Fields("R_Geboren").Value, "YYYYMMDD")
        Else
            ReGeb = "00000000"
        End If
        
        If Not IsNull(RS125.Fields("Geboren").Value) Then
            PaGeb = Format$(RS125.Fields("Geboren").Value, "YYYYMMDD")
        Else
            PaGeb = "00000000"
        End If

        If RS125.Fields("Geschlecht").Value = "M" Then
            Gesch = "m"
        Else
            Gesch = "w"
        End If
        If IsNull(RS125.Fields("Abteilung").Value) Then
            VeArt = "01"
        Else
            If RS125.Fields("Abteilung").Value <> vbNullString Then
                If IsNumeric(RS125.Fields("Abteilung").Value) Then
                    VeArt = Format$(RS125.Fields("Abteilung").Value, "00")
                Else
                    VeArt = "01"
                End If
            Else
                VeArt = "01"
            End If
        End If
        
        Set RS126 = New ADODB.Recordset
        RS126.CursorLocation = adUseClient
        Set RS126 = DBCmRe1("qrySimPAD2", "@IdxNr", AktRe)
        
        AktPo = 1
        AnzPo = RS126.RecordCount
        If AnzPo > 0 Then
            PrBr1.Min = 0
            PrBr1.Max = AnzPo
            PrBr1.Value = 0

            MeStr = MeStr & KunNr & PVKen & ReNum & "200" & ReAnr & ReNam & ReVor & ReTit & ReGeb & Space$(9) & vbCrLf
            ZeiGe = ZeiGe + 1
            ReZei = ReZei + 1
            MeStr = MeStr & KunNr & PVKen & ReNum & "201" & ReStr & RePLZ & ReOrt & ReLan & Space$(30) & vbCrLf
            ZeiGe = ZeiGe + 1
            ReZei = ReZei + 1
            If ReVor <> PaVor Then
                MeStr = MeStr & KunNr & PVKen & ReNum & "250" & PaAnr & PaNam & PaVor & PaTit & PaGeb & Space$(9) & vbCrLf
                ZeiGe = ZeiGe + 1
                ReZei = ReZei + 1
                MeStr = MeStr & KunNr & PVKen & ReNum & "251" & PaStr & PaPLZ & PaOrt & PaLan & Space$(30) & vbCrLf
                ZeiGe = ZeiGe + 1
                ReZei = ReZei + 1
            End If
            MeStr = MeStr & KunNr & PVKen & ReNum & "300" & Space$(4) & VeArt & "N" & "0000000000000000000000" & Space$(3) & PatNr & "0" & Space$(23) & Space$(47) & vbCrLf
            ZeiGe = ZeiGe + 1
            ReZei = ReZei + 1

            If RS125.Fields("ID3").Value <> vbNullString Then
                KatNr = Format$(RS125.Fields("ID3").Value, "000")
            Else
                KatNr = "000"
            End If
            If RS125.Fields("Tarif").Value <> vbNullString Then
                VerNr = Format$(RS125.Fields("Tarif").Value, "000")
            Else
                VerNr = "000"
            End If
            If RS125.Fields("Versicherung").Value <> vbNullString Then
                If VerNr = "001" Then
                    If RS125.Fields("Versicherer").Value <> vbNullString Then
                        VerSt = " Liquidiert wurde nach " & RS125.Fields("Versicherer").Value
                    Else
                        VerSt = vbNullString
                    End If
                Else
                    VerSt = " Liquidiert wurde nach " & RS125.Fields("Versicherung").Value
                End If
            Else
                If RS125.Fields("Versicherer").Value <> vbNullString Then
                    VerSt = " Liquidiert wurde nach " & RS125.Fields("Versicherer").Value
                Else
                    VerSt = vbNullString
                End If
            End If

            If GlGbK = True Then 'Benannter Gebührenkatalog
                VerSt = SUmw(VerSt, False, Umlau)
                MeStr = MeStr & KunNr & PVKen & ReNum & "500" & KatNr & VerNr & VerSt & Space$(13) & vbCrLf
            Else
                MeStr = MeStr & KunNr & PVKen & ReNum & "500" & Space$(113) & vbCrLf
            End If
            ZeiGe = ZeiGe + 1
            ReZei = ReZei + 1

            If RS125.Fields("Diagnose").Value <> vbNullString Then 'manuelle Diagnosen
                If Len(RS125.Fields("Diagnose").Value) > 0 Then
                    TmpDi = Trim$(RS125.Fields("Diagnose").Value)
                    TmpDi = SNaFi(TmpDi, False, Umlau, True, False)
                    StaWe = 1
                    Do
                    DiaMa = Mid$(TmpDi, StaWe, 50)
                    Lerze = InStrRev(DiaMa, Chr$(32), -1, 1) 'wo ist ein Leerzeichen
                    If Lerze = 1 Then
                        DiaMa = Trim$(Mid$(TmpDi, StaWe, 50))
                        StaWe = StaWe + 50
                    ElseIf Lerze > 1 Then
                        DiaMa = Trim$(Mid$(TmpDi, StaWe, Lerze - 1))
                        StaWe = StaWe + (Lerze - 1)
                    Else
                        StaWe = StaWe + 50
                    End If
                    MeStr = MeStr & KunNr & PVKen & ReNum & "600" & DiaMa & Space$(63) & vbCrLf
                    ZeiGe = ZeiGe + 1
                    ReZei = ReZei + 1
                    Loop Until StaWe >= Len(TmpDi)
                End If
            End If
            
            Set RS128 = New ADODB.Recordset 'Katalogdiagnosen
            RS128.CursorLocation = adUseClient
            If GlDSo = True Then 'Katalogdiagnosen alphabetisch sortieren
                Set RS128 = DBCmRe1("qrySimAbDiag", "@IdxNr", AktRe)
            Else
                Set RS128 = DBCmRe1("qrySimAbDia5", "@IdxNr", AktRe)
            End If
            If RS128.RecordCount > 0 Then
                Do
                If RS128.Fields("IDKurz").Value <> vbNullString Then
                    If RS128.Fields("Datum").Value <> vbNullString Then
                        If GldId = True Then
                            If GlICD = True Then
                                TmpDi = RS128.Fields("Datum").Value & ": " & SUmw(RS128.Fields("IDKurz").Value, False, Umlau) & " (" & Trim$(RS128.Fields("GOID").Value) & ")"
                            Else
                                TmpDi = RS128.Fields("Datum").Value & ": " & SUmw(RS128.Fields("IDKurz").Value, False, Umlau)
                            End If
                        Else
                            If GlICD = True Then
                                TmpDi = SUmw(RS128.Fields("IDKurz").Value, False, Umlau) & " (" & RS128.Fields("GOID").Value & ")"
                            Else
                                TmpDi = SUmw(RS128.Fields("IDKurz").Value, False, Umlau)
                            End If
                        End If
                    Else
                        If GlICD = True Then
                            TmpDi = SUmw(RS128.Fields("IDKurz").Value, False, Umlau) & " (" & RS128.Fields("GOID").Value & ")"
                        Else
                            TmpDi = SUmw(RS128.Fields("IDKurz").Value, False, Umlau)
                        End If
                    End If
                    
                    StaWe = 1
                    Do
                    DiaKa = Mid$(TmpDi, StaWe, 50)
                    Lerze = InStrRev(DiaKa, Chr$(32), -1, 1) 'wo ist ein Leerzeichen
                    If Lerze = 1 Then
                        DiaKa = Trim$(Mid$(TmpDi, StaWe, 50))
                        StaWe = StaWe + 50
                    ElseIf Lerze > 1 Then
                        DiaKa = Trim$(Mid$(TmpDi, StaWe, Lerze - 1))
                        StaWe = StaWe + (Lerze - 1)
                    Else
                        StaWe = StaWe + 50
                    End If
                    MeStr = MeStr & KunNr & PVKen & ReNum & "600" & DiaKa & Space$(63) & vbCrLf
                    ZeiGe = ZeiGe + 1
                    ReZei = ReZei + 1
                    Loop Until StaWe >= Len(TmpDi)

                End If
                RS128.MoveNext
                Loop Until RS128.EOF
            End If
            RS128.Close
            Set RS128 = Nothing
            
            HoSum = 0
            KoSum = 0
            AnSum = 0
            
            Do 'Leistungen
            If RS126.Fields("Text").Value <> vbNullString Then
                If IsDate(RS126.Fields("Datum").Value) = True Then
                    If Round(RS126.Fields("GesBetrag").Value, 2) <> vbNullString Then
