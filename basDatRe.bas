                RowNr = RpRws.Count - 1
            End If
            RpCo6.TopRowIndex = RowFi
            RpRws.Row(0).Selected = False
            RpRws.Row(RowNr).EnsureVisible
            RpRws.Row(RowNr).Selected = True
            If GlFoc = True Then
                Set RpCo6.FocusedRow = RpRws.Row(RowNr)
            End If
        End If
    End If
End If
RS149.Close
Set RS149 = Nothing

SMark

Set RpRws = Nothing
Set RpCo6 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then SErLog Err.Description & " S_VoPo " & Err.Number
Resume Next

End Sub
