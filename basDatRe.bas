            SMaNe 0, EmAdr, , EmTex, EmBet, FiNa1 & ";" & FiNa2 & ";" & FiNa3 & ";" & FiNa4 & ";"
        Else
            MsgBox AnzRe & " Rechnungen wurden erfolgreich exportiert", vbInformation, Tit1
        End If
        
        S_ReExT = True
    End If
End If

