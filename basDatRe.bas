            Set RpCol = RpCls.Find(Rec_ID1)
            ReNum = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Betrag)
            ReBet = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Bezahlt)
            BzBet = RpRow.Record(RpCol.ItemIndex).Value
End Select

Set RS125 = New ADODB.Recordset
RS125.CursorLocation = adUseClient
Set RS125 = DBCmRe1("qrySimReNr", "@IdStr", GlNeR.ReStr)
If RS125.RecordCount > 0 Then
    NeuNr = RS125.Fields("IDR").Value
Else
    NeuNr = 0
End If
RS125.Close
Set RS125 = Nothing

If NeuNr > 0 Then
    DBCmEx2 "qrySimReKo1", "@IdxNr", "@RecNr", NeuNr, ReNum
    DBCmEx2 "qrySimReKo2", "@IdPat", "@IdxNr", GlNeR.PatNr, NeuNr
    DBCmEx2 "qrySimReSm1", "@IdBet", "@IdxNr", ReBet, NeuNr
    DoEvents
    If GlTyp < 2 Then
        SQL1 = "SELECT * FROM dbo.qrySimAbSav WHERE IDR = " & ReNum & " ORDER BY ID3 DESC"
    Else
        SQL1 = "SELECT * FROM qrySimAbSav WHERE [IDR] = " & ReNum & " ORDER BY [ID3] DESC;"
    End If
    Set RS123 = New ADODB.Recordset 'Krenkanblatt
    With RS123
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdText
    End With
    If RS123.RecordCount > 0 Then
        Do
        RS123.Fields("Kommentar2").Value = CreateID("K")
        RS123.MoveNext
        Loop Until RS123.EOF
        RS123.UpdateBatch
    End If
    RS123.Close
    Set RS123 = Nothing
End If

Set RpCls = Nothing
Set RpCo3 = Nothing
Set RpCo4 = Nothing

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReKop " & Err.Number
Resume Next

End Sub
Public Sub S_ReLi()
On Error GoTo LiErr
'Füllt die Tabelle mit Daten

Dim NeuDa As Date
Dim GesZa As Long
Dim ManNr As Long
Dim MitNr As Long
Dim TyStr As String
Dim SuStr As String
Dim BuJah As String
Dim LiIdx As Integer
Dim TyIdx As Integer
