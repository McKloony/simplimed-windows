Public Sub S_RePru(Optional ByVal GeBet As Boolean = False)
On Error GoTo LiErr
'Prüft Preise der Positionen mit Preis der Rechnung

Dim ReNum As Long
Dim RowNr As Long
Dim AnzPo As Long
Dim AktPo As Long
Dim KatNr As Long
Dim PatNr As Long
Dim IdxNr As Long
Dim PaStr As String
Dim SuStr As String
Dim ReStr As String
Dim StrDa As String
Dim GeSum As Double
Dim ReBet As Double
Dim AnSum As Double
Dim NePre As Double
Dim ReRab As Double
Dim RaBet As Double
Dim Frage As Integer
Dim KrTyp As Integer
Dim ReAbg As Boolean
Dim Mld1, Tit1 As String
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo4 = FM.repCont4
Set RpCo3 = FM.repCont3

Select Case GlBut
Case RibTab_Abrechnung:
    Set RpSel = RpCo3.SelectedRows
    Set RpCls = RpCo3.Columns
Case RibTab_Rechnungen:
    Set RpSel = RpCo4.SelectedRows
    Set RpCls = RpCo4.Columns
End Select

AnzPo = RpSel.Count

If AnzPo > 0 Then
    Screen.MousePointer = vbHourglass
    DoEvents

    ReDim GloRe(AnzPo)
    
    If AnzPo > 1 Then
        frmStatus.Show
        DoEvents
        frmStatus.Caption = "Rechnungsprüfung"
        Set PrBr1 = frmStatus.prbStat1
        Set PrBr2 = frmStatus.prbStat2
        Set TxDum = frmStatus.txtDummy
        PrBr1.Min = 0
        PrBr1.Max = AnzPo
    End If

    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            RowNr = RpRow.Index
            GloRe(AktPo) = RowNr
            
            Select Case GlBut
            Case RibTab_Abrechnung:
                Set RpCol = RpCls.Find(Rec_IDR)
                ReNum = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_ID3)
                KatNr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_ID0)
                PatNr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_Betrag)
                ReBet = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_RechNr)
                ReStr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_IDKurz)
                PaStr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_Selekt)
                ReAbg = CBool(RpRow.Record(RpCol.ItemIndex).Value)
                Set RpCol = RpCls.Find(Rec_Rabatt)
                ReRab = RpRow.Record(RpCol.ItemIndex).Value
            Case RibTab_Rechnungen:
                Set RpCol = RpCls.Find(Rec_IDR)
                ReNum = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_ID3)
                KatNr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_ID0)
                PatNr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_Betrag)
                ReBet = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_RechNr)
                ReStr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_IDKurz)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    PaStr = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    PaStr = vbNullString
                End If
                Set RpCol = RpCls.Find(Rec_Rabatt)
                ReRab = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rec_Selekt)
                If LCase(RpRow.Record(RpCol.ItemIndex).Value) = "ja" Then
                    ReAbg = True
                Else
                    ReAbg = False
                End If
            End Select

            If GeBet = True Then
                DBCmEx2 "qrySimReKat", "@IdKat", "@IdxNr", KatNr, PatNr
                DoEvents
                Set RS114 = New ADODB.Recordset 'Offene Rechnungen des Patienten
                RS114.CursorLocation = adUseClient
                Set RS114 = DBCmRe1("qrySimReOf1", "@IdxNr", PatNr)
                If RS114.RecordCount > 0 Then
                    Do
                    ReNum = RS114.Fields("ID1").Value
                    ReBet = RS114.Fields("GesBetrag").Value
                    Set RS115 = New ADODB.Recordset 'Alle Positionen dieser Rechnung
                    RS115.CursorLocation = adUseClient
                    Set RS115 = DBCmRe1("qrySimAbIdx", "@IdxNr", ReNum)
                    If RS115.RecordCount > 0 Then
                        Do
                        If RS115.Fields("GONr").Value <> vbNullString Then
                            IdxNr = RS115.Fields("ID2").Value
                            KrTyp = RS115.Fields("ID1").Value
                            SuStr = RS115.Fields("GONr").Value
                            If KrTyp = 2 Then
                                Set RS116 = New ADODB.Recordset
                                RS116.CursorLocation = adUseClient
                                Set RS116 = DBCmRe2("qryKat01G", "@IdxNr", "@IdStr", KatNr, SuStr)
                                If RS116.RecordCount > 0 Then
                                    NePre = RS116.Fields("Preis1").Value
                                    DBCmEx2 "qrySimAbAnp", "@IdPre", "@IdxNr", NePre, IdxNr
                                End If
                                RS116.Close
                                Set RS116 = Nothing
                            End If
                        End If
                        RS115.MoveNext
                        Loop Until RS115.EOF
                    End If
                    RS115.Close
                    Set RS115 = Nothing
                    DoEvents
                    RS114.MoveNext
                    Loop Until RS114.EOF
                End If
                RS114.Close
                Set RS114 = Nothing
                DoEvents
            End If

            Set RS130 = New ADODB.Recordset
            RS130.CursorLocation = adUseClient
            If GlIgL = True Then 'Keine Preisberechnung bei IgL
                Set RS130 = DBCmRe1("qrySimAbSm1", "@IdxNr", ReNum)
            Else
                Set RS130 = DBCmRe1("qrySimAbSm", "@IdxNr", ReNum)
            End If
            If RS130.RecordCount > 0 Then
                If ReRab > 0 Then
                    RaBet = Format$(RS130("VK").Value * ReRab / 100, GlWa1)
                    GeSum = Format$(RS130("VK").Value - RaBet, GlWa1)
                Else
                    RaBet = 0
                    If RS130("VK").Value <> vbNullString Then
                        If IsNumeric(RS130("VK").Value) = True Then
                            GeSum = Format$(RS130("VK").Value, GlWa1)
                        Else
                            GeSum = 0
                        End If
                    Else
                        GeSum = 0
                    End If
                End If
                If RS130("WV").Value > 0 Then
                    AnSum = Format$(RS130("WV").Value, GlWa1)
                Else
                    AnSum = Format$(0, GlWa1)
                End If
            Else
                GeSum = Format$(0, GlWa1)
                AnSum = Format$(0, GlWa1)
            End If
                
            If GeSum <> ReBet Then
                If ReNum > 0 Then
                    DBCmEx2 "qrySimReSm1", "@IdBet", "@IdxNr", GeSum, ReNum
                    DBCmEx2 "qrySimOPAn3", "@Betra", "@IdxNr", GeSum, ReNum
                    DBCmEx2 "qrySimOPAn4", "@Betra", "@IdxNr", GeSum, ReNum
                    DBCmEx2 "qrySimBuAn", "@Betra", "@IdxNr", GeSum, ReNum
                    DoEvents
                    SPopu "Rechnung Korrigiert " & ReNum, "Rechnungssumme Korrigiert " & ReNum, IC48_Information
                End If
            End If
                                    
            RS130.Close
            Set RS130 = Nothing
            AktPo = AktPo + 1

            If AnzPo > 1 Then
                If TxDum.Text = "B" Then Exit For 'Abbrechen
                PrBr1.Value = AktPo
            End If
            DoEvents
        End If
    Next RpRow

    If GlJet = True Then SDBSav

    DoEvents
    Unload frmStatus
    Set frmStatus = Nothing

    Screen.MousePointer = vbNormal
End If


Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing
Set RpCo4 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_RePru " & Err.Number
Resume Next

End Sub
Private Sub S_ReRec(ByRef RST As ADODB.Recordset)
On Error GoTo LiErr
'Fügt der Rechnungstabelle die Datensätze an

Dim KrDat As Date
Dim ManNr As Long
Dim StrDa As String
Dim Diffe As Double
Dim ReStu As Single
Dim ReSto As Boolean
Dim EinOk As Boolean
Dim RpCo4 As XtremeReportControl.ReportControl

Set FM = frmMain
Set RpCo4 = FM.repCont4
Set RpRcs = RpCo4.Records

Do
If RST.Fields("Storniert").Value <> vbNullString Then
    ReSto = CBool(RST.Fields("Storniert").Value)
Else
    ReSto = False
End If
If RST.Fields("IDP").Value <> vbNullString Then
    ManNr = CLng(RST.Fields("IDP").Value)
Else
    ManNr = GlMan(GlSMa, 2)
End If
If RST.Fields("Steuer").Value <> vbNullString Then
    ReStu = Round(RST.Fields("Steuer").Value, 2)
Else
    ReStu = 0
End If
If RST.Fields("Bezahlt").Value = 0 Then
    Diffe = RST.Fields("Betrag").Value
Else
    If RST.Fields("Bezahlt").Value <> vbNullString Then
        Diffe = RST.Fields("Betrag").Value - RST.Fields("Bezahlt").Value
    Else
        Diffe = RST.Fields("Betrag").Value
    End If
End If
If RST.Fields("Datum").Value <> vbNullString Then
    KrDat = RST.Fields("Datum").Value
Else
    StrDa = Date
End If
StrDa = Left$(KrDat, 10)

If GlSrR = False Then 'Zeige stornierte Rechnungen (Abrechnung)
    If ReSto = False Then
        If GlRst = False Then 'Mandantenbezogene Datenbegrenzung
            EinOk = True
        Else
            If ManNr = GlReM Then 'Standardmandant Mandantenrestriktionen
                EinOk = True
            Else
                If ManNr = 0 Then
                    EinOk = True
                Else
                    EinOk = False
                End If
            End If
        End If
    Else
        EinOk = False
    End If
Else
    If GlRst = False Then 'Mandantenbezogene Datenbegrenzung
        EinOk = True
    Else
        If ManNr = GlReM Then 'Standardmandant Mandantenrestriktionen
            EinOk = True
        Else
            If ManNr = 0 Then
                EinOk = True
            Else
                EinOk = False
            End If
        End If
    End If
End If

If EinOk = True Then
    Set RpRec = RpRcs.Add()
    Set RpItm = RpRec.AddItem(RST.Fields("ID1").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("ID0").Value)
    Set RpItm = RpRec.AddItem(RST.Fields("RechNr").Value)
    If RST.Fields("Selekt").Value = 0 Then
        RpItm.Icon = IC16_Mail_Open
    Else
        RpItm.Icon = IC16_Mail_Close
    End If
    Set RpItm = RpRec.AddItem(CDate(StrDa))
    If RST.Fields("Selekt").Value = 0 Then
        Set RpItm = RpRec.AddItem("Nein")
    Else
        Set RpItm = RpRec.AddItem("Ja")
    End If
    Set RpItm = RpRec.AddItem(RST.Fields("Type").Value)
    RpItm.Alignment = xtpAlignmentCenter
    If RST.Fields("Versand").Value <> vbNullString Then
        Select Case CInt(RST.Fields("Versand").Value)
