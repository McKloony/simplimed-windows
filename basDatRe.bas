Set RS146 = New ADODB.Recordset
RS146.CursorLocation = adUseClient
Select Case GlBut
Case RibTab_Rezeptmodul:
        If GlSrZ = True Then 'Stornierte Rezepte / Belege
            Set RS146 = DBCmRe1("qrySimRzPa2", "@IdxNr", GlAdr)
        Else
            Set RS146 = DBCmRe1("qrySimRzPa1", "@IdxNr", GlAdr)
        End If
Case RibTab_Belegmodul:
        If GlSrZ = True Then 'Stornierte Rezepte / Belege
            Set RS146 = DBCmRe1("qrySimRzPa2", "@IdxNr", GlAdr)
        Else
            Set RS146 = DBCmRe1("qrySimRzPa1", "@IdxNr", GlAdr)
        End If
Case RibTab_Fragebogen:
    Set RS146 = DBCmRe1("qryPatAnBog", "@IdxNr", GlAdr)
Case RibTab_Mahnwesen:
        Set CmCom = CmBrs.FindControl(CmCom, SY_PO_Posten_SuchCombo, , True)
        LiIdx = CmCom.ListIndex
        If LiIdx = 3 Then
            Set CmDat = CmBrs.FindControl(CmDat, SY_SuDat, , True)
            If CmDat.Text <> vbNullString Then
                If IsDate(CmDat.Text) = True Then
                    NeuDa = CDate(CmDat.Text)
                Else
                    NeuDa = Date
                End If
            Else
                NeuDa = Date
            End If
            Set CmCom = CmBrs.FindControl(CmCom, SY_SuJah, , True)
            BuJah = CmCom.Text
            With GlSuM
                .SuIdx = 3
                .SuDat = NeuDa
                .SuJah = BuJah
            End With
            If GlUm3 = True Then
                Set RS146 = DBCmRe1("qrySimOPDat", "@IdDat", GlSuM.SuDat)
            Else
                Set RS146 = DBCmRe1("qrySimOPDat2", "@IdDat", GlSuM.SuDat)
            End If
        ElseIf LiIdx = 4 Then 'Lastschriften
            If GlUm3 = True Then 'Umschalten Postem
                If GlTyp < 2 Then
                    SQL1 = "SELECT * FROM dbo.qrySimOPKto2 ORDER BY IDR, Datum"
                Else
                    SQL1 = "SELECT * FROM qrySimOPKto2 ORDER BY [IDR], [Datum];"
                End If
                Set RS146 = DBCmRe0(SQL1, True)
            Else
                If GlTyp < 2 Then
                    SQL1 = "SELECT * FROM dbo.qrySimOPKto ORDER BY IDR, Datum"
                Else
                    SQL1 = "SELECT * FROM qrySimOPKto ORDER BY [IDR], [Datum];"
                End If
                Set RS146 = DBCmRe0(SQL1, True)
            End If
        ElseIf LiIdx = 6 Then
            Set CmMan = CmBrs.FindControl(CmMan, SY_SuMan, , True)
            ManNr = CmMan.ItemData(CmMan.ListIndex)
            With GlSuM
                .SuIdx = 6
                .SuMan = ManNr
            End With
            If GlUm3 = True Then
                Set RS146 = DBCmRe1("qrySimOPMan", "@IdxNr", GlSuM.SuMan)
            Else
                Set RS146 = DBCmRe1("qrySimOPMan2", "@IdxNr", GlSuM.SuMan)
            End If
        ElseIf LiIdx = 7 Then
            Set CmMit = CmBrs.FindControl(CmMit, SY_SuMit, , True)
            If GlMiV = True Then
                MitNr = CmMit.ItemData(CmMit.ListIndex)
            Else
                MitNr = 0
