                            Case 4: 'Woche
                                    DBCmEx5 "qrySimAdKr5d", "@IdDru", "@IdTyp", "@IdJah", "@IdMon", "@IdxNr", -1, 103, SuJah, SuWek, PatNr
                            Case 5: 'Datum
                                    DBCmEx5 "qrySimAdKr7d", "@IdDru", "@IdTyp", "@IdSta", "@IdEnd", "@IdxNr", -1, 103, StaDa, EndDa, PatNr
                            End Select
                        Else
                            Select Case LiIdx
                            Case 1: 'Jahr
                                    DBCmEx5 "qrySimAdKr3h", "@IdDru", "@IdTyp", "@IdJah", "@IdxNr", "@IdMit", -1, TypNr, SuJah, PatNr, MitNr
                            Case 2: 'Quartal
