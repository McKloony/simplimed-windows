                            Else
                                TmpSt = TmpSt & TmAry(AkBlo)
                            End If
                        Next AkBlo
                    Else
                        PrBr1.Min = 0
                        PrBr1.Max = ArGes

                        For AkZei = 0 To ArGes 'Zeilen
                            TmStr = vbNullString
                            PrBr2.Value = AkZei + 1
                            For AkSpa = 0 To ArSpa 'Spalten
                                If AdrAy(AkSpa, AkZei) <> vbNullString Then
                                    TmStr = AdrAy(AkSpa, AkZei)
                                    TmStr = Replace$(TmStr, Chr$(13) & Chr$(10), Space$(1), 1)
                                    Select Case AkSpa
                                    Case 0:
                                        TmpSt = TmpSt & "P" & Format$(TmStr, "000000") & Chr$(59)
                                    Case Else:
                                        If Len(TmStr) > 250 Then
                                            TmpSt = TmpSt & SNaFi(Left$(TmStr, 250), False, False, True, True) & Chr$(59)
                                        Else
                                            TmpSt = TmpSt & SNaFi(TmStr, False, False, True, True) & Chr$(59)
                                        End If
                                    End Select
                                Else
