            MaFrm = vbNullString
        End If
        If GlThe(AktZa, 1) <> vbNullString Then
            MaVor = GlThe(AktZa, 1)
        Else
            MaVor = vbNullString
        End If
        If GlThe(AktZa, 2) <> vbNullString Then
            MaNam = GlThe(AktZa, 2)
        Else
            MaNam = vbNullString
        End If
        If GlThe(AktZa, 3) <> vbNullString Then
            MaStr = GlThe(AktZa, 3)
        Else
            MaStr = "Straße"
        End If
        If GlThe(AktZa, 4) <> vbNullString Then
            MaPLZ = GlThe(AktZa, 4)
        Else
            MaPLZ = "12345"
        End If
        If GlThe(AktZa, 5) <> vbNullString Then
            MaOrt = GlThe(AktZa, 5)
        Else
            MaOrt = "Ort"
        End If
        If GlThe(AktZa, 18) <> vbNullString Then
            MaIBA = GlThe(AktZa, 18)
        Else
            MaIBA = "DE89370400440532013000"
        End If
        If GlThe(AktZa, 31) <> vbNullString Then
            MaBIC = GlThe(AktZa, 31)
        Else
            MaBIC = "COBADEFFXXX"
        End If
        If GlThe(AktZa, 33) <> vbNullString Then
            MaGID = GlThe(AktZa, 33)
        Else
            MaGID = "DE98ZZZ099999999991"
        End If
        If GlThe(AktZa, 11) <> vbNullString Then
            MaSID = GlThe(AktZa, 11)
        Else
            If GlThe(AktZa, 33) <> vbNullString Then
                MaSID = GlThe(AktZa, 33)
            Else
                MaSID = "DE123456789"
            End If
        End If
        If GlThe(AktZa, 6) <> vbNullString Then
            MaTel = GlThe(AktZa, 6)
        Else
            If GlThe(AktZa, 7) <> vbNullString Then
                MaTel = GlThe(AktZa, 7)
            Else
                MaTel = "1234"
            End If
        End If
        If GlThe(AktZa, 16) <> vbNullString Then
            MaEma = GlThe(AktZa, 16)
        Else
            MaEma = "keine@mailadresse.de"
        End If
        If GlThe(AktZa, 48) <> vbNullString Then
            MaUID = GlThe(AktZa, 48)
        Else
            MaUID = "DE123456789"
        End If
        If MaNam <> vbNullString Then
            If MaVor <> vbNullString Then
                MaKon = MaVor & Space$(1) & MaNam
            Else
                MaKon = MaNam
            End If
        ElseIf MaVor <> vbNullString Then
            MaKon = MaVor
        ElseIf GlThe(AktZa, 13) <> vbNullString Then
            MaKon = GlThe(AktZa, 13)
        Else
            MaKon = "Name"
        End If
        If MaFrm <> vbNullString Then
            If MaNam <> vbNullString Then
                If MaVor <> vbNullString Then
                    MaReg = MaFrm & Space$(1) & MaVor & Space$(1) & MaNam
                Else
                    MaReg = MaFrm & Space$(1) & MaNam
                End If
            Else
                If MaVor <> vbNullString Then
                    MaReg = MaFrm & Space$(1) & MaVor
                Else
                    MaReg = MaFrm
                End If
            End If
        ElseIf MaNam <> vbNullString Then
            If MaVor <> vbNullString Then
                MaReg = MaVor & Space$(1) & MaNam
            Else
                MaReg = MaNam
            End If
        ElseIf MaVor <> vbNullString Then
            MaReg = MaVor
        ElseIf GlThe(AktZa, 13) <> vbNullString Then
            MaReg = GlThe(AktZa, 13)
        End If
        
        If GlMiA(GlSmI, 11) <> vbNullString Then
            EmSig = GlMiA(GlSmI, 11)
        Else
            EmSig = GlMiA(GlSmI, 1)
        End If

        Set RS125 = New ADODB.Recordset
        RS125.CursorLocation = adUseClient
        Set RS125 = DBCmRe1("qryPrSimRe1", "@IdStr", ReNum)

        If RS125.RecordCount > 0 Then
            PaNam = vbNullString
            PaVor = vbNullString
            PaFrm = vbNullString
            PaStr = vbNullString
            PaOrt = vbNullString
            PaPLZ = vbNullString
            EmBrf = vbNullString
            If RS125.Fields("R_Name").Value <> vbNullString Then
                PaNam = RS125.Fields("R_Name").Value
