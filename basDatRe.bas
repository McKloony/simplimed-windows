Private Sub S_RzMe(ByVal PatNr As Long, ByVal RzNum As Long)
On Error GoTo SuErr
'Liest die ICD Diagnosen

Dim LetRe As Long
Dim CoStr As String
Dim KuStr As String
Dim AktZa As Integer
Dim RpCo7 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmKatDL
Set RpCo7 = FM.repCont7
