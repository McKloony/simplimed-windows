Public Sub S_AbTe(ByVal DayFi As Date, ByVal DayLa As Date)
On Error GoTo GrErr
'Markiert die belegten Tage im Kalender

Dim SQL1 As String
Dim PatNr As Long
Dim AnzPo As Long
Dim AktPo As Long
Dim DaSta As String
Dim DaEnd As String
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo3 = FM.repCont3
Set RpCo4 = FM.repCont4

GlTaV = 0

If GlAkt = False Then
    AktPo = 1
    Select Case GlBut
    Case RibTab_Krankenbla:
        PatNr = GlAdr
    Case RibTab_Abrechnung:
        Set RpCls = RpCo3.Columns
        Set RpSel = RpCo3.SelectedRows
        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            If RpRow.GroupRow = False Then
                Set RpCol = RpCls.Find(Rec_ID0)
                PatNr = RpRow.Record(RpCol.ItemIndex).Value
            Else
                PatNr = GlAdr
            End If
        Else
            PatNr = GlAdr
        End If
    Case RibTab_Rechnungen:
        Set RpCls = RpCo4.Columns
        Set RpSel = RpCo4.SelectedRows
        If RpSel.Count > 0 Then
            Set RpRow = RpSel(0)
            If RpRow.GroupRow = False Then
                Set RpCol = RpCls.Find(Rec_ID0)
                PatNr = RpRow.Record(RpCol.ItemIndex).Value
            Else
                PatNr = GlAdr
            End If
        Else
            PatNr = GlAdr
        End If
    End Select
    
    If IsDate(DayFi) = True Then
        DaSta = CDate(DayFi) & " 00:00:00"
        DaEnd = CDate(DayLa) & " 23:59:00"
    Else
        DaSta = Date
        DaEnd = Date
    End If
    
    Set RS133 = New ADODB.Recordset
    RS133.CursorLocation = adUseClient
    Set RS133 = DBCmRe3("qrySimAbDaG", "@IdSta", "@IdEnd", "@IdxNr", DaSta, DaEnd, GlAdr)
    AnzPo = RS133.RecordCount

    If AnzPo > 0 Then
        ReDim GlBet(AnzPo)
        Do
        GlBet(AktPo) = Left$(RS133.Fields("Datum").Value, 10)
        AktPo = AktPo + 1
        RS133.MoveNext
        Loop Until RS133.EOF
        GlTaV = AnzPo 'Behandlungstage vorhanden
    End If
    
    RS133.Close
    Set RS133 = Nothing
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing
Set RpCo4 = Nothing

Exit Sub

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_AbTe " & Err.Number
Resume Next

End Sub

