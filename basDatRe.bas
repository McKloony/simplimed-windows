End If
RS118.Close
Set RS118 = Nothing

S_ReTe = ReNum

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReTe " & Err.Number
Resume Next

End Function
Public Sub S_ReTei()
On Error GoTo SuErr
'Splittet eine Rechnungen in mehrere kleine Rechnungen auf

Dim SQL1 As String
Dim RowNr As Long 'Zeilennummer
Dim ReNum As Long 'Rechnungsnummer
Dim ReNeu As Long 'Neue Rechnungsnummer
Dim PatNr As Long 'Patientenummer
Dim AktRe As Long 'Aktuelle Rechnung
Dim MaNum As Long
Dim MiNum As Long
Dim ReDat As Date 'Rechnungsdatum
Dim ReSum As Single 'Rechnungssumme
Dim GeSum As Single 'Gesamtsumme
Dim SaSum As Single
Dim ReTyp As String
Dim AnzPo As Integer
Dim AnzNe As Integer
Dim AnzGe As Integer
Dim ReIdA() As Long
Dim ReStA() As String
Dim ReStr As String 'Rechungsnummer
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo4 = FM.repCont4
Set RpCo3 = FM.repCont3

Select Case GlBut
Case RibTab_Abrechnung:
    Set RpSel = RpCo3.SelectedRows
    Set RpCls = RpCo3.Columns
Case RibTab_Rechnungen:
    Set RpSel = RpCo4.SelectedRows
    Set RpCls = RpCo4.Columns
End Select

AnzPo = RpSel.Count
If AnzPo > 1 Then
    Mld1 = "Möchten Sie die " & AnzPo & " markierten Rechnungen jetzt in mehrere kleine Rechnungen aufteilen?" & vbCrLf & "Dieser Vorgang kann einige Minuten in Anspruch nehmen."
Else
    Mld1 = "Möchten Sie die markierte Rechnung jetzt in mehrere kleine Rechnungen aufteilen?" & vbCrLf & "Dieser Vorgang kann einige Minuten in Anspruch nehmen."
End If
Tit1 = "Rechnung aufsplitten"

If AnzPo > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then
        
        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                RowNr = RpRow.Index
                Select Case GlBut
                Case RibTab_Abrechnung:
                    Set RpCol = RpCls.Find(Rec_ID1)
                    ReNum = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Rec_Type)
                    ReTyp = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Rec_IDP)
                    If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                        MaNum = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        MaNum = GlMan(GlSMa, 2)
                    End If
                    Set RpCol = RpCls.Find(Rec_IDM)
                    If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                        MiNum = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        MiNum = GlMiA(GlSmI, 2)
                    End If
                Case RibTab_Rechnungen:
                    Set RpCol = RpCls.Find(Rec_ID1)
                    ReNum = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Rec_Type)
                    ReTyp = RpRow.Record(RpCol.ItemIndex).Value
                    Set RpCol = RpCls.Find(Rec_IDP)
                    If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                        MaNum = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        MaNum = GlMan(GlSMa, 2)
                    End If
                    Set RpCol = RpCls.Find(Rec_IDM)
                    If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                        MiNum = RpRow.Record(RpCol.ItemIndex).Value
                    Else
                        MiNum = GlMiA(GlSmI, 2)
                    End If
                End Select

                Set RS120 = New ADODB.Recordset
                RS120.CursorLocation = adUseClient
                Set RS120 = DBCmRe1("qrySimReSm7", "@IdxNr", ReNum)
                PatNr = RS120.Fields("PatNr").Value
                ReDat = RS120.Fields("Datum").Value
                ReSum = RS120.Fields("Gesamt").Value
                RS120.Close
                Set RS120 = Nothing
    
                If ReSum > GlObG Then
                    AnzNe = (ReSum / GlObG) 'Anzahl neuer Rechnungen
                    ReDim ReIdA(AnzNe)
                    ReDim ReStA(AnzNe)
                    For AktRe = 1 To AnzNe
                        ReDat = ReDat + 1
                        ReStr = S_ReVo(Date, ReTyp, MaNum, MiNum, GlReN)
                        ReStA(AktRe) = ReStr
                        ReNeu = K_ReNe(ReStr, ReDat, PatNr, MiNum, ReTyp) 'Neuanlegen
                        ReIdA(AktRe) = ReNeu
                    Next AktRe
                    
                    If GlTyp < 2 Then
                        Select Case GlSoA 'Sortierung Datum
                        Case 1: Select Case GlSoZ 'Eingabesortierung
                                Case 3: SQL1 = "SELECT * FROM dbo.qrySimAbLei4 WHERE IDR = " & ReNum & " ORDER BY Sorter DESC, ID3 DESC" 'Datum absteigend
                                Case 4: SQL1 = "SELECT * FROM dbo.qrySimAbLei2 WHERE IDR = " & ReNum & " ORDER BY Sorter DESC, ID3" 'Datum absteigend
                                End Select
                        Case 2: Select Case GlSoZ
                                Case 3: SQL1 = "SELECT * FROM dbo.qrySimAbLei3 WHERE IDR = " & ReNum & " ORDER BY Sorter, ID3 DESC" 'Datum aufsteigend
                                Case 4: SQL1 = "SELECT * FROM dbo.qrySimAbLei1 WHERE IDR = " & ReNum & " ORDER BY Sorter, ID3" 'Datum aufsteigend
                                End Select
                        End Select
                    Else
                        Select Case GlSoA 'Sortierung Datum
                        Case 1: Select Case GlSoZ 'Eingabesortierung
                                Case 3: SQL1 = "SELECT * FROM qrySimAbLei4 WHERE [IDR] = " & ReNum & " ORDER BY [Sorter] DESC, [ID3] DESC;"  'Datum absteigend
                                Case 4: SQL1 = "SELECT * FROM qrySimAbLei2 WHERE [IDR] = " & ReNum & " ORDER BY [Sorter] DESC, [ID3];" 'Datum absteigend
                                End Select
                        Case 2: Select Case GlSoZ
                                Case 3: SQL1 = "SELECT * FROM qrySimAbLei3 WHERE [IDR] = " & ReNum & " ORDER BY [Sorter], [ID3] DESC;" 'Datum aufsteigend
                                Case 4: SQL1 = "SELECT * FROM qrySimAbLei1 WHERE [IDR] = " & ReNum & " ORDER BY [Sorter], [ID3];" 'Datum aufsteigend
                                End Select
                        End Select
                    End If

                    Set RS126 = New ADODB.Recordset
                    With RS126
                        .CursorLocation = adUseClient
                        .Source = SQL1
                        .ActiveConnection = DB1
                        .CursorType = adOpenDynamic
                        .LockType = adLockOptimistic
                        .Open Options:=adCmdText
                    End With
                    AnzGe = RS126.RecordCount
    
                    If AnzGe > 0 Then
                        AktRe = 1
                        Do
                        If RS126.Fields("GesBetrag").Value <> 0 Then
                            SaSum = SaSum + RS126.Fields("GesBetrag").Value
                        End If
                        If SaSum >= GlObG Then
                            SaSum = 0
                            Exit Do
                        End If
                        RS126.MoveNext
                        Loop Until RS126.EOF
    
                        For AktRe = 1 To AnzNe
                            Do While Not RS126.EOF
                            RS126.Fields("IDR").Value = ReIdA(AktRe)
                            RS126.Fields("RechNr").Value = ReStA(AktRe)
                            If RS126.Fields("GesBetrag").Value <> 0 Then
                                SaSum = SaSum + RS126.Fields("GesBetrag").Value
                            End If
                            If SaSum >= GlObG Then
                                SaSum = 0
                                Exit Do
                            End If
                            RS126.MoveNext
                            Loop
                        Next AktRe
                        RS126.Close
                        Set RS126 = Nothing
                        
                        Set RS130 = New ADODB.Recordset
                        RS130.CursorLocation = adUseClient
                        If GlIgL = True Then 'Keine Preisberechnung bei IgL
                            Set RS130 = DBCmRe1("qrySimAbSm1", "@IdxNr", ReNum)
                        Else
                            Set RS130 = DBCmRe1("qrySimAbSm", "@IdxNr", ReNum)
                        End If
                        ReSum = RS130.Fields("VK").Value
                        RS130.Close
                        Set RS130 = Nothing
                        DBCmEx2 "qrySimReSm1", "@IdBet", "@IdxNr", ReSum, ReNum
                        
                        For AktRe = 1 To AnzNe
                            Set RS130 = New ADODB.Recordset
                            RS130.CursorLocation = adUseClient
                            If GlIgL = True Then 'Keine Preisberechnung bei IgL
                                Set RS130 = DBCmRe1("qrySimAbSm1", "@IdxNr", ReIdA(AktRe))
                            Else
                                Set RS130 = DBCmRe1("qrySimAbSm", "@IdxNr", ReIdA(AktRe))
                            End If
                            If RS130.RecordCount > 0 Then
                                ReSum = RS130.Fields("VK").Value
                                DBCmEx2 "qrySimReSm1", "@IdBet", "@IdxNr", ReSum, ReIdA(AktRe)
                            End If
                            RS130.Close
                            Set RS130 = Nothing
                        Next AktRe
                        
                    End If
                Else
                    Mld1 = "Die Rechnungssumme dieser Rechnung liegt unter der von Ihnen eingestellten Rechnungsobergrenze"
                    WindowMess Mld1, Dial2, Tit1, FM.hwnd
                End If
            End If
        Next RpRow

        Select Case GlBut
        Case RibTab_Abrechnung:
                    Set RpSel = RpCo3.SelectedRows
                    If RpSel.Count > 0 Then
                        Set RpRow = RpSel(0)
                        RowNr = RpRow.Index
                        SUpAb RowNr
                    End If
                    Set RpSel = RpCo4.SelectedRows
                    If RpSel.Count > 0 Then
                        Set RpRow = RpSel(0)
                        RowNr = RpRow.Index
                        SUpRe RowNr
                    End If
        Case RibTab_Rechnungen:
                    Set RpSel = RpCo4.SelectedRows
                    If RpSel.Count > 0 Then
                        Set RpRow = RpSel(0)
                        RowNr = RpRow.Index
                        SUpRe RowNr
                    End If
        End Select
    End If
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing
Set RpCo4 = Nothing

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReTei " & Err.Number
Resume Next

End Sub
