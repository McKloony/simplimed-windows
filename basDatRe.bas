Set RpCol = RpCls.Find(Med_IDD)

With RpCo7
    .EditItem Nothing, Nothing
    If .Records.Count > 0 Then .Records.DeleteAll
    .Populate
End With

RpCol.EditOptions.Constraints.DeleteAll

Set RS122 = New ADODB.Recordset 'Ermitteln der letzten Rechnungsnummer
RS122.CursorLocation = adUseClient
Set RS122 = DBCmRe1("qrySimAbReD", "@IdxNr", PatNr)
If RS122.RecordCount > 0 Then
    LetRe = RS122.Fields("ID1").Value
Else
    LetRe = 0
End If
RS122.Close
Set RS122 = Nothing

Set RS127 = New ADODB.Recordset
RS127.CursorLocation = adUseClient
If GlDSo = True Then
    Set RS127 = DBCmRe1("qrySimAbDiag", "@IdxNr", LetRe)
Else
    Set RS127 = DBCmRe1("qrySimAbDia5", "@IdxNr", LetRe)
End If
If RS127.RecordCount > 0 Then
    Do
    If RS127.Fields("IDKurz").Value <> vbNullString Then
        If GlICD = True Then
            RpCol.EditOptions.Constraints.Add Left$(RS127.Fields("IDKurz").Value, 25) & " (" & RS127.Fields("GOID").Value & ")", RS127.Fields("ID2").Value
        Else
            RpCol.EditOptions.Constraints.Add Left$(RS127.Fields("IDKurz").Value, 25), RS127.Fields("ID2").Value
        End If
    End If
    RS127.MoveNext
    Loop Until RS127.EOF
End If
RS127.Close
Set RS127 = Nothing

Set RS128 = New ADODB.Recordset
RS128.CursorLocation = adUseClient
Set RS128 = DBCmRe1("qrySimAbDiMe", "@IdxNr", RzNum)
If RS128.RecordCount > 0 Then
    Do
    Set RpRec = RpRcs.Add()
    Set RpItm = RpRec.AddItem(RS128.Fields("ID2").Value)
    Set RpItm = RpRec.AddItem(RS128.Fields("ID0").Value)
    Set RpItm = RpRec.AddItem(RS128.Fields("IDR").Value)
    Set RpItm = RpRec.AddItem(RS128.Fields("GOID").Value)
    Set RpItm = RpRec.AddItem(RS128.Fields("IDKurz").Value)
    RpItm.Focusable = False
    Set RpItm = RpRec.AddItem(RS128.Fields("IDD").Value)
    RpItm.Focusable = True
    RS128.MoveNext
    Loop Until RS128.EOF
End If
RS128.Close
Set RS128 = Nothing

RpCo7.Populate

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_RzMe " & Err.Number
Resume Next

End Sub
Public Sub S_RzNe()
On Error GoTo SuErr
'Legt einen neuen Beleg an

Dim IdxNr As Long
Dim RezNr As Long
Dim LeRet As Long
Dim DiaNr As Long
Dim CoStr As String
Dim KuStr As String
Dim TmGui As String
Dim DiStr As String
Dim RzAbs As Boolean

Set FM = frmMain
Set LiVw1 = frmRzNeu.lstView1
Set LiIts = LiVw1.ListItems

If GlNeZ.GuiID <> vbNullString Then
    TmGui = GlNeZ.GuiID
Else
    TmGui = CreateID("Z")
End If
RzAbs = CBool(IniGetVal("System", "RzAbse")) 'Rezeptabsender

If GlNeZ.DiaEi = True Then
    Set RS125 = New ADODB.Recordset
    RS125.CursorLocation = adUseClient
    Set RS125 = DBCmRe1("qrySimReKra", "@IdxNr", GlNeZ.PatNr)
    If RS125.RecordCount > 0 Then
        LeRet = RS125.Fields("ID1").Value
    Else
        LeRet = 0
    End If
    RS125.Close
    Set RS125 = Nothing
    DoEvents
    DiStr = S_DrDi(LeRet, True)
End If

Set RS126 = New ADODB.Recordset
With RS126
    .CursorLocation = adUseClient
    .Source = "qrySimRzNe"
    .ActiveConnection = DB1
    .CursorType = adOpenDynamic
    .LockType = adLockOptimistic
    .Open Options:=adCmdTableDirect
End With

If RS126.Supports(adAddNew) Then
    RS126.AddNew
    RS126.Fields("GuiID").Value = TmGui
    RS126.Fields("ID0").Value = GlNeZ.PatNr
    RS126.Fields("Type").Value = GlNeZ.BelNr
    RS126.Fields("Datum").Value = GlNeZ.BeDat
    RS126.Fields("DatVon").Value = GlNeZ.TmDat
    RS126.Fields("Absender").Value = RzAbs
    If GlNeZ.MaNum > 0 Then RS126.Fields("IDP").Value = GlNeZ.MaNum
    If GlNeZ.MitNr > 0 Then RS126.Fields("IDM").Value = GlNeZ.MitNr
    If GlNeZ.Steue > 0 Then RS126.Fields("GesBrut").Value = GlNeZ.Steue
    If GlNeZ.GesBe > 0 Then RS126.Fields("GesBetrag").Value = GlNeZ.GesBe
    If GlNeZ.KoTex <> vbNullString Then RS126.Fields("Kommentar").Value = GlNeZ.KoTex
    If GlNeZ.DiaEi = True Then
        If GlNeZ.RzTex <> vbNullString Then
            RS126.Fields("Rezepttext").Value = "Diagnose: " & DiStr & vbCrLf & vbCrLf & GlNeZ.RzTex
        Else
            RS126.Fields("Rezepttext").Value = "Diagnose: " & DiStr
        End If
    Else
        If GlNeZ.RzTex <> vbNullString Then
            RS126.Fields("Rezepttext").Value = GlNeZ.RzTex
        End If
    End If
    RS126.Update
End If
RS126.Close
Set RS126 = Nothing
DoEvents

Set RS127 = New ADODB.Recordset
RS127.CursorLocation = adUseClient
Set RS127 = DBCmRe1("qrySimRzGui", "@IdStr", TmGui)
If RS127.RecordCount > 0 Then
    RezNr = RS127.Fields("ID1").Value
Else
    RezNr = 0
End If
RS127.Close
Set RS127 = Nothing
DoEvents

If LiIts.Count > 0 Then
    For Each LiItm In LiIts
        If LiItm.Checked = True Then
            CoStr = LiItm.Text
            KuStr = LiItm.SubItems(1)
            If LiItm.SubItems(2) > 0 Then
                DiaNr = CLng(LiItm.SubItems(2))
            Else
                DiaNr = 0
            End If
            If RezNr > 0 Then
                If DiaNr = 0 Then
                    DBCmEx6 "qrySimAbDiA2", "@PatNr", "@IdxNr", "@IdCod", "@IdStr", "@IdGrp", "@IdRef", GlNeZ.PatNr, RezNr, CoStr, KuStr, 0, 0
                Else
                    DBCmEx7 "qrySimAbDiA3", "@PatNr", "@IdxNr", "@IdCod", "@IdStr", "@IdDia", "@IdGrp", "@IdRef", GlNeZ.PatNr, RezNr, CoStr, KuStr, DiaNr, 0, 0
                End If
            End If
        End If
    Next LiItm
End If

Exit Sub

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_RzNe " & Err.Number
Resume Next

End Sub
