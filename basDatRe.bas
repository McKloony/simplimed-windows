                    DBCmEx2 "qrySimReAk8", "@IdPat", "@IdxNr", PatNr, ReNum
                    DBCmEx2 "qrySimReAk4", "@IdPat", "@IdxNr", PatNr, ReNum
                    DBCmEx2 "qrySimOpAn8", "@IdPat", "@IdxNr", PatNr, ReNum
                    DBCmEx2 "qrySimBuAP", "@IdPat", "@IdxNr", PatNr, ReNum
