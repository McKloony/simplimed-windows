Public Sub S_RzDr(ByVal BelNr As Integer, ByVal PatNr As Long, ByVal ErKId As Long, ByVal KtoNr As Long, KtoSt As String, ByVal GeKId As Long, ByVal GeKNr As Long, ByVal GeKBe As String, ByVal StKID As Long, ByVal StKNr As Long, ByVal StKBe As String, Optional ByVal Gutha As Boolean = False, Optional ByVal Gutsh As Boolean = False)
On Error GoTo LiErr
'Markiert den Beleg als gedruckt

Dim BuDat As Date
Dim RezNr As Long
Dim ReNum As Long
Dim RowNr As Long
Dim ManNr As Long
Dim MitNr As Long
Dim BuBel As Long
Dim BuJah As Long
Dim BetGe As Double
Dim Steue As Single
Dim BelSt As String
Dim PaStr As String
Dim KoStr As String
Dim TmGui As String
Dim KuStr As String
Dim BuTex As String
Dim TSENa As String 'Kassenkennung
Dim TSESt As String
Dim AnzPo As Integer
Dim BuTyp As Integer
Dim Warun As Integer
Dim AktZa As Integer
Dim AktKo As Integer
Dim Gedru As Boolean
Dim NeuBu As Boolean
Dim Kasse As Boolean
Dim Verre As Boolean
Dim TSEBu As Boolean
Dim Gefun As Boolean 'Geldkonto gefunden
Dim Mld1, Tit1 As String
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo5 = FM.repCont5
Set RpCls = RpCo5.Columns
Set RpSel = RpCo5.SelectedRows

AnzPo = RpSel.Count

BelSt = AlgFo(BelNr)

For AktZa = 1 To UBound(GlGeK) 'Geldkonten
    If GlGeK(AktZa, 0) = GeKId Then
        If GlGeK(AktZa, 2) <> vbNullString Then
            Kasse = CBool(GlGeK(AktZa, 5))
            Verre = CBool(GlGeK(AktZa, 7))
            TSENa = CStr(GlGeK(AktZa, 8))
        Else
            Kasse = False
            Verre = False
            TSENa = vbNullString
        End If
        Gefun = True
        Exit For
    End If
Next AktZa

If Gefun = False Then
    S_KoDe GeKId
    With GlKto
        GeKNr = .KtoNr
        GeKBe = .KtBez
        GeKId = .KtBnk
    End With
    For AktZa = 1 To UBound(GlGeK) 'Geldkonten
        If GlGeK(AktZa, 0) = GeKId Then
            Kasse = CBool(GlGeK(AktZa, 5))
            Verre = CBool(GlGeK(AktZa, 7))
            TSENa = CStr(GlGeK(AktZa, 8))
            Exit For
        End If
    Next AktZa
End If

Screen.MousePointer = vbHourglass
DoEvents

If Verre = False Then
    If AnzPo > 0 Then
        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                RowNr = RpRow.Index
                Set RpCol = RpCls.Find(Rzp_ID1)
                RezNr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rzp_Datum)
                BuDat = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rzp_GesBetrag)
                If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                    BetGe = Round(RpRow.Record(RpCol.ItemIndex).Value, 2)
                Else
                    BetGe = 0
                End If
                Set RpCol = RpCls.Find(Rzp_GesBrut)
                If RpRow.Record(RpCol.ItemIndex).Value > 0 Then
                    Steue = Round(RpRow.Record(RpCol.ItemIndex).Value, 2)
                Else
                    Steue = 0
                End If
                Set RpCol = RpCls.Find(Rzp_Name)
                PaStr = RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rzp_Vorname)
                PaStr = PaStr & Chr$(32) & RpRow.Record(RpCol.ItemIndex).Value
                Set RpCol = RpCls.Find(Rzp_Kommentar)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    KoStr = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    KoStr = vbNullString
                End If
                Set RpCol = RpCls.Find(Rzp_Drucken)
                If RpRow.Record(RpCol.ItemIndex).Checked = True Then
                    Gedru = True
                Else
                    Gedru = False
                End If
                Set RpCol = RpCls.Find(Rzp_IDP)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    ManNr = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    ManNr = GlMan(GlSMa, 2)
                End If
                Set RpCol = RpCls.Find(Rzp_IDM)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    MitNr = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    MitNr = GlMiA(GlSmI, 2)
                End If
                Set RpCol = RpCls.Find(Rzp_GuiID)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    TmGui = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    TmGui = vbNullString
                End If
                Set RpCol = RpCls.Find(Rzp_TSEString)
                If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                    TSESt = RpRow.Record(RpCol.ItemIndex).Value
                Else
                    TSESt = vbNullString
                End If
                
                If Gedru = False Then
                    If GlTSe > 0 Then 'TSE Aktiviert
                        If TSESt = vbNullString Then
                            NeuBu = True
                        End If
                    Else
                        NeuBu = True
                    End If
                End If
                                    
                KuStr = BelSt & " ausgedruckt am " & Date
                            
                If Gedru = False Then
                    If NeuBu = True Then
                        If Kasse = True Then
                            If GlTSe > 0 Then 'TSE Aktiviert
                                Select Case GlTSe
                                Case 1: TSEBu = TSESet(BetGe, Steue, TSENa)
                                Case 2: TSEBu = TSEGen(BetGe, Steue, TSENa)
                                End Select
                            End If
                        End If
                    End If

                    If GlTSe > 0 Then 'TSE Aktiviert
                        If Kasse = True Then
                            NeuBu = TSEBu 'WICHTIG!
                            If NeuBu = False Then
                                Mld1 = "Das gewählte Geldkonto ist als Kasse gekennzeichnet, besitzt aber keine TSE Kennung."
                                Tit1 = "Kasse TSE Kennung"
                                WindowMess Mld1, Dial3, Tit1, FM.hwnd
                            End If
                        End If
                    End If
                    DoEvents
    
                    Set RS123 = New ADODB.Recordset
                    RS123.CursorLocation = adUseClient
                    Set RS123 = DBCmRe1("qrySimReAdr", "@IdxNr", PatNr)
                    If RS123.RecordCount > 0 Then
                        DoEvents
                        RS123.MoveLast
                        ReNum = RS123.Fields("IDR").Value
                    Else
                        ReNum = 0
                    End If
                    RS123.Close
                    Set RS123 = Nothing
                    DoEvents
                        
                    If GlRKr = True Then 'Rechnungsvermerk im Krankenblatt
                        DBCmEx7 "qrySimAbAnfu", "@PatNr", "@IdxNr", "@IdRec", "@IdStr", "@IdGui", "@IdDat", "@IdZei", PatNr, 101, RezNr, KuStr, TmGui, Date, TimeValue(Now)
                        DoEvents
                    End If

                    If BetGe > 0 Then
                        If NeuBu = True Then

                            BuTyp = 2 'Einnahme
                            BuJah = Year(BuDat)
                            BuBel = S_BuBel(ManNr, BuJah, GeKId) 'Belegnummer ermitteln
                            DoEvents
                            
                            If Gutsh = True Then
                                BuTex = "Gutschein: " & PaStr & " (B" & Format$(RezNr, "000000") & ")"
                            Else
                                BuTex = "Beleg: (B" & Format$(RezNr, "000000") & ")"
                            End If

                            With GlNuB
                                .BuWär = 1
                                .BuBel = BuBel
                                .BuBet = BetGe
                                .BuDat = BuDat
                                .BuTex = BuTex
                                .ByTyp = BuTyp
                                .GuiID = TmGui
                                .GlkId = GeKId
                                If GlBuc = True Then 'einfache Buchhaltung verwenden
                                    .KtNrS = KtoNr
                                    .KtBeS = KtoSt
                                    .KtNrH = GeKNr
                                    .KtBeH = GeKBe
                                Else
                                    .KtNrS = GeKNr
                                    .KtNrH = KtoNr
                                    .KtBeS = GeKBe
                                    .KtBeH = KtoSt
                                End If
                                .KoTex = KoStr
                                .MaNum = ManNr
                                .MitNr = MitNr
                                If Gutsh = True Then
                                    .PatNr = 0
                                Else
                                    .PatNr = PatNr
                                End If
                                .ReNum = ReNum
                                .ReStr = "B" & Format$(RezNr, "000000")
                                .Steue = Steue
                                If Kasse = True Then
                                    If TSEBu = True Then
                                        .TSEQr = GlTSB.SigQr
                                        .TSESt = GlTSB.SigSt
                                        .TSETz = GlTSB.TraZe
                                        .TSESz = GlTSB.SigZe
                                        .TSELg = GlTSB.ZeLog
                                    End If
                                End If
                            End With
                            S_BuNe
                            DoEvents
                                                        
                            If GlTSe > 0 Then 'TSE Aktiviert
                                If Kasse = True Then
                                    If TSEBu = True Then
                                        DBCmEx2 "qrySimRezMa", "@PaSel", "@IdxNr", -1, RezNr '[Drucken] = -1
                                    End If
                                Else
                                    DBCmEx2 "qrySimRezMa", "@PaSel", "@IdxNr", -1, RezNr '[Drucken] = -1
                                End If
                            Else
                                DBCmEx2 "qrySimRezMa", "@PaSel", "@IdxNr", -1, RezNr '[Drucken] = -1
                            End If
                            DoEvents

                            If Kasse = True Then
                                If TSEBu = True Then
                                    If GlTyp < 2 Then
                                        DBCmEx6 "qrySimRzTSE1", "@SigSt", "@IdStr", "@IdLog", "@IdZah", "@IdSig", "@IdxNr", GlTSB.SigSt, GlTSB.SigQr, GlTSB.ZeLog, GlTSB.TraZe, GlTSB.SigZe, RezNr 'TSE Signatur
                                    End If
                                End If
                            End If

                            If Gutha = True Then
                                S_PaGu GlAdr, BetGe
                            End If
                        End If
                    Else
                        If GlBut = RibTab_Rezeptmodul Then
                            DBCmEx2 "qrySimRezMa", "@PaSel", "@IdxNr", -1, RezNr '[Drucken] = -1
                        End If
                    End If
    
                End If
            End If
        Next RpRow
        
        SUpRz RowNr
    End If
End If

DoEvents
Screen.MousePointer = vbNormal

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo5 = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_RzDr " & Err.Number
Resume Next

End Sub
Public Sub S_RzEn()
On Error GoTo LiErr
'Löscht den Eintrag

Dim SQL1 As String
Dim IdxNr As Long
Dim RzNum As Long
Dim SuStr As String
Dim SuPZN As String
Dim TmStr As String
Dim TxStr As String
Dim Posit As Integer
Dim AnzPo As Integer
Dim Frage As Integer
Dim Mld1, Tit1 As String
Dim RpCo5 As XtremeReportControl.ReportControl
Dim RpCo7 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRws As XtremeReportControl.ReportRows
Dim RpRow As XtremeReportControl.ReportRow

