Private Function S_DaExF(ByVal KntNr As Long) As String
On Error GoTo OpErr
'Sachkontenformatierung

Dim KntSt As String
Dim KoStr As String
Dim Lange As Integer

KoStr = CStr(KntNr)

If KntNr = 0 Then
    If GldKt = True Then 'Sachkontenformatierung
        KoStr = "0000"
    Else
        KoStr = "000000"
    End If
Else
    If GldKt = True Then 'DATEV Sachkontenformatierung
        Lange = Len(KoStr)
        If Lange = 2 Then
            KntSt = KoStr & "00"
        ElseIf Lange = 3 Then
            KntSt = KoStr & "0"
        ElseIf Lange = 4 Then
            KntSt = KoStr
        ElseIf Lange > 4 Then
            KntSt = Left$(KoStr, 4)
        Else
            KntSt = Format$(KntNr, "0000")
        End If
    Else
        Lange = Len(KoStr)
        If Lange = 2 Then
            KntSt = KoStr & "0000"
        ElseIf Lange = 3 Then
            KntSt = KoStr & "000"
        ElseIf Lange = 4 Then
            KntSt = KoStr & "00"
        ElseIf Lange = 5 Then
            KntSt = KoStr & "0"
        ElseIf Lange = 6 Then
            KntSt = KoStr
        ElseIf Lange > 6 Then
            KntSt = Left$(KoStr, 6)
        Else
            KntSt = Format$(KntNr, "000000")
        End If
    End If
End If

S_DaExF = KntSt

Exit Function

OpErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_DaExF " & Err.Number
Resume Next

End Function

