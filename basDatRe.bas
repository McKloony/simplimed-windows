                            End Select
                        End If
                    End If

                End If
            Next RpRow
        End If
        RS123.Close
        Set RS123 = Nothing
    End If
End If

Set RpCls = Nothing
Set RpSel = Nothing
Set RpCo6 = Nothing

DoEvents
