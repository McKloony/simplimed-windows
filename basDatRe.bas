Public Sub S_ReSer(Optional ByVal NeuRe As Boolean = False)
On Error GoTo GrErr
'Erstellt Rechnungen auf Basis von Terminen

Dim TeDat As Date
Dim RowNr As Long
Dim TerNr As Long
Dim MasNr As Long
Dim PatNr As Long
Dim StMit As Long
Dim ReNum As Long
Dim MasTe As Long
Dim AnzPo As Long
Dim AktPo As Long
Dim MaNum As Long
Dim MiNum As Long
Dim TeBet As Double
Dim ReStr As String
Dim ReTyp As String
Dim PatNa As String
Dim ReMel As Boolean
Dim ReAbg As Boolean
Dim Lbl01 As XtremeSuiteControls.Label
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCo7 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmKatRC
Set RpCo4 = frmMain.repCont4
Set RpCo7 = FM.repCont7
Set RpCls = RpCo7.Columns
Set RpSel = RpCo7.SelectedRows

Set clFen = New clsFenster

AnzPo = RpSel.Count

StMit = GlMiA(GlSmI, 2)

Select Case GlReT 'Standardbelegtyp
Case "R": ReTyp = "R"
Case "V": ReTyp = "R"
Case "L": ReTyp = "L"
Case "A": ReTyp = "A"
Case "U": ReTyp = "R"
Case "M": ReTyp = "M"
Case "G": ReTyp = "G"
Case "I": ReTyp = "I"
Case Else: ReTyp = "R"
End Select

Screen.MousePointer = vbHourglass
DoEvents

If AnzPo > 1 Then
    frmStatus.Show
    DoEvents
    frmStatus.Caption = "Rechnungsstatus"
    Set Lbl01 = frmStatus.lblLab01
    Set PrBr1 = frmStatus.prbStat1
    Set PrBr2 = frmStatus.prbStat2
    Set TxDum = frmStatus.txtDummy
    PrBr1.Min = 0
    PrBr1.Max = AnzPo
    Lbl01.Caption = "Bitte warten..."
End If

For Each RpRow In RpSel
    If RpRow.GroupRow = False Then
        RowNr = RpRow.Index
        
        Set RpCol = RpCls.Find(Ter_ID0)
        If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
            PatNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Ter_ID2)
            TerNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Ter_IDP)
            MaNum = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Ter_IDM)
            MiNum = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Ter_MasTer)
            MasNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Ter_VonDat)
            TeDat = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Ter_TerBet)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                TeBet = Round(RpRow.Record(RpCol.ItemIndex).Value, 2)
            Else
                TeBet = 0
            End If
            Set RpCol = RpCls.Find(Ter_Patient)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                PatNa = RpRow.Record(RpCol.ItemIndex).Value
            Else
                PatNa = vbNullString
            End If
            Set RpCol = RpCls.Find(Ter_MasTer)
            If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                MasTe = RpRow.Record(RpCol.ItemIndex).Value
            Else
                MasTe = TerNr
            End If
            Set RpCol = RpCls.Find(Ter_Aufgabe)
            If RpRow.Record(RpCol.ItemIndex).Checked = True Then
                ReAbg = True
            Else
                ReAbg = False
            End If
            Set RpCol = RpCls.Find(Rec_IDO)

            Set RS134 = New ADODB.Recordset 'wurden überhaupt Leistungen zugeordnet?
            RS134.CursorLocation = adUseClient
            Set RS134 = DBCmRe1("qryAnKa1e", "@IdxNr", TerNr)
            If RS134.RecordCount = 0 Then
                ReAbg = True
            End If
            RS134.Close
            Set RS134 = Nothing

            If TeDat <= Date Then
                If ReAbg = False Then
                    If NeuRe = True Then
                        ReStr = S_ReVo(Date, ReTyp, MaNum, StMit, GlReN)
                        ReNum = K_ReNe(ReStr, Date, PatNr, MasTe, ReTyp, MaNum, StMit)
                        DoEvents
                    Else
                        If GlRMa = True Then 'getrennter Mandentenrechnungsnummernkreis
                            ReNum = S_ReOf(PatNr, MaNum, ReTyp) 'ist noch ein unabgeschlossene Rechnung vorhanden?
                        Else
                            ReNum = S_ReOf(PatNr, 0, ReTyp) 'ist noch ein unabgeschlossene Rechnung vorhanden?
                        End If
                        DoEvents
                        If ReNum = 0 Then
                            ReStr = S_ReVo(Date, ReTyp, MaNum, StMit, GlReN)
                            ReNum = K_ReNe(ReStr, Date, PatNr, MasTe, ReTyp, MaNum, StMit)
                            DoEvents
                        End If
                    End If
                    DBCmEx6 "qryAnKa1m", "@IdDat", "@IdRec", "@IdMit", "@IdMan", "@TerNr", "@IdPat", TeDat, ReNum, MiNum, MaNum, TerNr, PatNr 'Anfügen
                    DoEvents
                    DBCmEx2 "qryAnKa1c", "@IdBol", "@IdxNr", -1, TerNr 'Markieren
                    DoEvents
                    DBCmEx2 "qryTerErl", "@IdErl", "@IdxNr", -1, TerNr
                    DoEvents
                    If GlTAk = True Then 'Terminakontozahlungen aktiviert
                        S_PaGu PatNr, , TeBet
                        DoEvents
                    End If
                    DBCmEx2 "qryTerAuf", "@IdAuf", "@IdxNr", -1, TerNr
                    DoEvents
                    S_ReTer ReNum
                Else
                    If GlRMa = True Then 'getrennter Mandentenrechnungsnummernkreis
                        ReNum = S_ReOf(PatNr, MaNum, ReTyp) 'Ist noch ein unabgeschlossene Rechnung vorhanden?
                    Else
                        ReNum = S_ReOf(PatNr, 0, ReTyp) 'Ist noch ein unabgeschlossene Rechnung vorhanden?
                    End If
                    If ReNum = 0 Then
                        DBCmEx2 "qryTerAuf", "@IdAuf", "@IdxNr", -1, TerNr
                    End If
                End If
            Else
                WindowMess "Die Serienrechnung ist noch nicht fällig", Dial2, "Serienrechnung", FM.hwnd
            End If
        End If
    End If

    If AnzPo > 1 Then
        If TxDum.Text = "B" Then Exit For 'Abbrechen
        PrBr1.Value = AktPo
    End If
    AktPo = AktPo + 1
    DoEvents
Next RpRow

DoEvents
clFen.FenDsk 2

Set RpSel = RpCo4.SelectedRows
If RpSel.Count > 0 Then
    Set RpRow = RpSel(0)
    RowNr = RpRow.Index
    SUpRe RowNr
End If

P_TeSpl
P_List "ReSe", 1, 1

clFen.FenDsk 3
Screen.MousePointer = vbNormal

If AnzPo > 1 Then
    DoEvents
    Unload frmStatus
    Set frmStatus = Nothing
End If

Set RpSel = Nothing
Set RpCo7 = Nothing
Set RpCo4 = Nothing

Set clFen = Nothing

Exit Sub

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReSer " & Err.Number
Resume Next

End Sub
Public Function S_ReSm(ByVal ParNr As Long) As Double
On Error GoTo GrErr

Dim ReSum As Double
Dim AnSum As Double
Dim BeSum As Double
Dim OpSum As Double
Dim GesZa As Integer

Set RS120 = New ADODB.Recordset
RS120.CursorLocation = adUseClient
Set RS120 = DBCmRe1("qrySimReSm6", "@IdxNr", ParNr)
GesZa = RS120.RecordCount
If GesZa > 0 Then
    If IsNull(RS120.Fields("Gesamt").Value) = False Then
        ReSum = RS120.Fields("Gesamt").Value
    End If
    If IsNull(RS120.Fields("Anzahlung").Value) = False Then
        AnSum = RS120.Fields("Anzahlung").Value
    End If
    If IsNull(RS120.Fields("Bezahlt").Value) = False Then
        BeSum = RS120.Fields("Bezahlt").Value
    End If
    If (ReSum - BeSum) > 0 Then
        OpSum = ReSum - BeSum
    End If
End If
RS120.Close
Set RS120 = Nothing

S_ReSm = OpSum

Exit Function

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReSm " & Err.Number
Resume Next


End Function
