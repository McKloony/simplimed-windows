Public Function S_DiAr(ByVal PatNr As Long, Optional ByVal ReNum As Long) As Integer
On Error GoTo SuErr
'Lädt die Diagnosen in das Array

Dim LetRe As Long
Dim GesZa As Long

Set RS125 = New ADODB.Recordset
RS125.CursorLocation = adUseClient
If ReNum > 0 Then
    Set RS125 = DBCmRe1("qrySimAbDiag", "@IdxNr", ReNum) 'Rechnungsdiagnosen
    GesZa = RS125.RecordCount
    If GesZa > 0 Then
        DiAry = RS125.GetRows 'Array Füllen
    End If
Else
    Set RS122 = New ADODB.Recordset
    RS122.CursorLocation = adUseClient
    Set RS122 = DBCmRe1("qrySimAbReD", "@IdxNr", PatNr)
    If RS122.RecordCount > 0 Then
        LetRe = RS122.Fields("ID1").Value
    Else
        LetRe = 0
    End If
    RS122.Close
    Set RS122 = Nothing
    If LetRe > 0 Then
        Set RS125 = DBCmRe1("qrySimAbDiag", "@IdxNr", LetRe) 'Rechnungsdiagnosen
        GesZa = RS125.RecordCount
        If GesZa > 0 Then
            DiAry = RS125.GetRows 'Array Füllen
        End If
    Else
        Set RS125 = DBCmRe1("qrySimAbDiPa", "@IdxNr", PatNr) 'Aufnahmediagnosen
        GesZa = RS125.RecordCount
        If GesZa > 0 Then
            DiAry = RS125.GetRows 'Array Füllen
        End If
    End If
End If
RS125.Close
Set RS125 = Nothing

S_DiAr = GesZa

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_DiAr " & Err.Number
Resume Next

End Function
Public Function S_DrDi(ByVal ReNum As Long, Optional ByVal OhDia As Boolean) As String
On Error GoTo SuErr
'Liest die ICD Diagnosen

Dim DiStr As String

Set RS128 = New ADODB.Recordset
RS128.CursorLocation = adUseClient
If GlDSo = True Then 'Katalogdiagnosen alphabetisch sortieren
    Set RS128 = DBCmRe1("qrySimAbDiag", "@IdxNr", ReNum)
Else
    Set RS128 = DBCmRe1("qrySimAbDia5", "@IdxNr", ReNum)
End If
If RS128.RecordCount > 0 Then
    Do
    If RS128.Fields("IDKurz").Value <> vbNullString Then
        If RS128.Fields("Datum").Value <> vbNullString Then
            If OhDia = True Then
                If GlICD = True Then 'ICD mit einfügen
                    If DiStr = vbNullString Then
                        DiStr = RS128.Fields("IDKurz").Value & " (" & Trim$(RS128.Fields("GOID").Value) & ")"
                    Else
                        DiStr = DiStr & "; " & RS128.Fields("IDKurz").Value & " (" & Trim$(RS128.Fields("GOID").Value) & ")"
                    End If
                Else
                    If DiStr = vbNullString Then
                        DiStr = RS128.Fields("IDKurz").Value
                    Else
                        DiStr = DiStr & "; " & RS128.Fields("IDKurz").Value
                    End If
                End If
            Else
                If GldId = True Then 'Diagnosedatumn anzeigen
                    If GlICD = True Then
                        If DiStr = vbNullString Then
                            DiStr = RS128.Fields("Datum").Value & ": " & RS128.Fields("IDKurz").Value & " (" & Trim$(RS128.Fields("GOID").Value) & ")"
                        Else
                            DiStr = DiStr & "; " & RS128.Fields("Datum").Value & ": " & RS128.Fields("IDKurz").Value & " (" & Trim$(RS128.Fields("GOID").Value) & ")"
                        End If
                    Else
                        If DiStr = vbNullString Then
                            DiStr = RS128.Fields("Datum").Value & ": " & RS128.Fields("IDKurz").Value
                        Else
                            DiStr = DiStr & "; " & RS128.Fields("Datum").Value & ": " & RS128.Fields("IDKurz").Value
                        End If
                    End If
                Else
                    If GlICD = True Then
                        If DiStr = vbNullString Then
                            DiStr = RS128.Fields("IDKurz").Value & " (" & Trim$(RS128.Fields("GOID").Value) & ")"
                        Else
                            DiStr = DiStr & "; " & RS128.Fields("IDKurz").Value & " (" & Trim$(RS128.Fields("GOID").Value) & ")"
                        End If
                    Else
                        If DiStr = vbNullString Then
                            DiStr = RS128.Fields("IDKurz").Value
                        Else
                            DiStr = DiStr & "; " & RS128.Fields("IDKurz").Value
                        End If
                    End If
                End If
            End If
        Else
            If GlICD = True Then
                If DiStr = vbNullString Then
                    DiStr = RS128.Fields("IDKurz").Value & " (" & Trim$(RS128.Fields("GOID").Value) & ")"
                Else
                    DiStr = DiStr & "; " & RS128.Fields("IDKurz").Value & " (" & Trim$(RS128.Fields("GOID").Value) & ")"
                End If
            Else
                If DiStr = vbNullString Then
                    DiStr = RS128.Fields("IDKurz").Value
                Else
                    DiStr = DiStr & "; " & RS128.Fields("IDKurz").Value
                End If
            End If
        End If
    End If
    RS128.MoveNext
    Loop Until RS128.EOF
End If
RS128.Close
Set RS128 = Nothing

S_DrDi = DiStr

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_DrDi " & Err.Number
Resume Next

End Function

Public Sub S_GDT(Optional ByVal PaKra As Boolean = False)
On Error GoTo SuErr
'Importriert GDT Dateien

Dim PatNr As Long
Dim Lange As Long   'Länge der Textdatei
Dim Gefun As Long   'Gefundene Position
Dim StaWe As Long   'Startwert der Textsuche
Dim BerAr As Long   'Berichtart
Dim FldKn As Long   'Feldkennung
Dim StMan As Long
Dim StMit As Long
Dim FeInh As String 'Feldinhalt
Dim AkZei As String 'Aktuelles Zeichen
Dim FelWe As String 'Feldwert
Dim SuStr As String 'Patientennummer
Dim IdKur As String 'Aktueller Patient
Dim EiDat As String 'Untersuchungsdatum
Dim PaGeb As String
Dim PaSpr As String
Dim MeStr As String
Dim DaStr As String
Dim DaNam As String
Dim DaPfa As String
Dim ReStr As String
Dim PaNam As String
Dim PaVor As String
Dim PaTit As String
Dim PaGes As String
Dim PaAnr As String
Dim PaGro As String
Dim PaGew As String
Dim FiNam As String
Dim ImDat As String
Dim TmGui As String
Dim FoWär As Integer
Dim Frage As Integer
Dim Mld1, Tit1 As String

Set FM = frmMain
Set CoDia = FM.comDialo

Set clFil = New clsFile
clFil.hwnd = FM.hwnd

StaWe = 1

StMan = GlMan(GlSMa, 2)
StMit = GlMiA(GlSmI, 2)

With CoDia
    .CancelError = True
    .DialogStyle = 1
    .DefaultExt = "*.gdt"
    .Filter = "GDT-Dateien (*.gdt)|*.gdt|Alle Dateien (*.*)|*.*"
    .DialogTitle = "Wo befindet sich die GDT-Datei?"
    .InitDir = GlIPf
    .FileName = vbNullString
    .ShowOpen
    FiNam = .FileName
    If .FileTitle = vbNullString Then
        Set CoDia = Nothing
        Set clFil = Nothing
        Exit Sub
    End If
End With

With clFil
    .FilPfa FiNam
    DaPfa = .DaPfa
End With

If FiNam <> vbNullString Then
    ImDat = clFil.FilReSt
    Lange = Len(ImDat)
    If Lange > 0 Then
        Screen.MousePointer = vbHourglass

        Set RS154 = New ADODB.Recordset
        With RS154
            .CursorLocation = adUseClient
            .Fields.Append "Länge", adChar, 10
            .Fields.Append "Feldkennung", adBigInt
            .Fields.Append "Feldinhalt", adChar, 250
            .Fields.Append "Berichtsart", adBigInt
            If .State = adStateClosed Then .Open
        End With
        If RS154.Supports(adAddNew) Then
            Gefun = InStr(StaWe, ImDat, Chr$(13), 1)
            Do While Gefun <> 0
            AkZei = Mid$(ImDat, StaWe, Gefun - StaWe)
            If AkZei <> vbNullString Then
                StaWe = Gefun + 2
                Gefun = InStr(StaWe, ImDat, Chr$(13), 1)
                FelWe = Trim$(Right$(AkZei, Len(AkZei) - 7))
                If FelWe <> vbNullString Then
                    If GlIFo = "X2" Then FelWe = SZech(FelWe, True)
                    FldKn = CLng(Mid$(AkZei, 4, 4))
                    RS154.AddNew
                    RS154.Fields("Länge").Value = Left$(AkZei, 3)
                    RS154.Fields("Feldkennung").Value = FldKn
                    RS154.Fields("Feldinhalt").Value = FelWe
                    If FldKn = 8000 Then BerAr = Val(Trim$(FelWe))
                    RS154.Fields("Berichtsart").Value = BerAr
                    RS154.Update
                End If
            End If
            Loop
            
            RS154.MoveFirst
            DoEvents
            Do
            SuStr = vbNullString
            MeStr = vbNullString
            FldKn = RS154.Fields("Feldkennung").Value
            FeInh = Trim$(RS154.Fields("Feldinhalt").Value)
            
            If FldKn = 3000 Then 'Patientenkontrolle
                If PaKra = False Then
                    SuStr = FeInh
                    Set RS134 = New ADODB.Recordset 'Ist Patient schon vorhanden?
                    RS134.CursorLocation = adUseClient
                    Set RS134 = DBCmRe1("qrySimAdMan", "@IdStr", SuStr)
                    If RS134.RecordCount = 0 Then
                        Do While FldKn < 4000
                        FldKn = RS154.Fields("Feldkennung").Value
                        FeInh = Trim$(RS154.Fields("Feldinhalt").Value)
                        Select Case FldKn
                        Case 3101: PaNam = FeInh
                        Case 3102: PaVor = FeInh
                        Case 3104: PaTit = FeInh
                        Case 3122: PaGro = FeInh
                        Case 3123: PaGew = FeInh
                        Case 3628: PaSpr = FeInh
                        Case 3103: PaGeb = CDate(Left$(FeInh, 2) & "." & Mid$(FeInh, 3, 2) & "." & Right$(FeInh, 4))
                        Case 3110:
                                If FeInh = 1 Then
                                    PaGes = "M"
                                    PaAnr = "Herrn"
                                Else
                                    PaGes = "W"
                                    PaAnr = "Frau"
                                End If
                        End Select
