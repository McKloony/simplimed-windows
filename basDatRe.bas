                        DBCmEx2 "qrySimReTyp", "@ReTyp", "@IdxNr", IdTyp, ReNum
                        DoEvents
                        DBCmEx2 "qrySimReAuS", "@IdStr", "@IdxNr", AuStr, ReNum
                        DoEvents
                        DBCmEx2 "qrySimReAuN", "@IdNum", "@IdxNr", ReNum, ReNum
                        DoEvents
                        If ReAbg = True Then
                            DoEvents
                            DBCmEx2 "qrySimReMa2", "@PaSel", "@IdxNr", 0, ReNum
                        End If
                        ReAkt = True
