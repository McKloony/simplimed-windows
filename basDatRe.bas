    DaExt = .DaExt
    DaPfa = .DaPfa
End With

'---

Set RS134 = New ADODB.Recordset 'Termine
With RS134
    .CursorLocation = adUseClient
    .Source = "qryTerNeu"
    .ActiveConnection = DB1
    .CursorType = adOpenForwardOnly
    .LockType = adLockReadOnly
    .Open Options:=adCmdTableDirect
End With

Set RS135 = New ADODB.Recordset 'Neues Recordset erstellen Termine
RS135.CursorLocation = adUseClient
For Each FL101 In RS134.Fields
    RS135.Fields.Append FL101.Name, FL101.Type, FL101.DefinedSize
Next FL101
If RS135.State = adStateClosed Then RS135.Open

RS134.Close
Set RS134 = Nothing

'---

frmStatus.Show
DoEvents
frmStatus.Caption = "Stammdatenimport"
Set PrBr1 = frmStatus.prbStat1
Set PrBr2 = frmStatus.prbStat2
Set Lbl01 = frmStatus.lblLab01
Set TxDum = frmStatus.txtDummy

If clFil.FilVor(FiNam) = True Then '[Termine]
    With clFil
        .FilPfa FiNam
        TmpS7 = .FilReSt
    End With

    If Len(TmpS7) > 3 Then
        If ZeiUm = True Then
            AryZe = Split(TmpS7, vbCrLf) 'Zeilen aufsplitten
        Else
            AryZe = Split(TmpS7, "|") 'Zeilen aufsplitten
        End If
        AryDe = Split(AryZe(0), ";") 'Feldnamen aufsplitten
        
        PrBr1.Min = 0
        PrBr1.Max = UBound(AryZe)
        
        For AktZe = 1 To UBound(AryZe) - 1
            If AryZe(AktZe) <> vbNullString Then
                AryFe = Split(AryZe(AktZe), ";") 'Felder aufsplitten
                RS135.AddNew
                For AktFe = 0 To UBound(AryDe) - 1
                    For Each FL101 In RS135.Fields
                        If FL101.Name = AryDe(AktFe) Then
                            If UBound(AryFe) >= AktFe Then
                                If AryFe(AktFe) <> vbNullString Then
                                    If AryFe(AktFe) <> Space$(1) Then
                                        
                                        Select Case FL101.Name
                                        Case "ID2":
                                        Case "VonDat": If IsDate(Left$(AryFe(AktFe), 10)) = True Then RS135.Fields(FL101.Name).Value = CDate(Left$(AryFe(AktFe), 10))
                                        Case "BisDat": If IsDate(Left$(AryFe(AktFe), 10)) = True Then RS135.Fields(FL101.Name).Value = CDate(Left$(AryFe(AktFe), 10))
                                        Case "Datum": If IsDate(Left$(AryFe(AktFe), 10)) = True Then RS135.Fields(FL101.Name).Value = CDate(Left$(AryFe(AktFe), 10))
                                        Case "ZeiVon": If IsDate(Right$(AryFe(AktFe), 8)) = True Then RS135.Fields(FL101.Name).Value = CDate(Right$(AryFe(AktFe), 8))
                                        Case "ZeiBis": If IsDate(Right$(AryFe(AktFe), 8)) = True Then RS135.Fields(FL101.Name).Value = CDate(Right$(AryFe(AktFe), 8))
                                        Case "ZeiVor": If IsDate(Right$(AryFe(AktFe), 8)) = True Then RS135.Fields(FL101.Name).Value = CDate(Right$(AryFe(AktFe), 8))
                                        Case Else:
                                            Select Case FL101.Type
                                            Case adBigInt: RS135.Fields(FL101.Name).Value = CLng(AryFe(AktFe))
                                            Case adBoolean: RS135.Fields(FL101.Name).Value = CBool(AryFe(AktFe))
                                            Case adChar: RS135.Fields(FL101.Name).Value = CStr(AryFe(AktFe))
                                            Case adVarChar: RS135.Fields(FL101.Name).Value = CStr(AryFe(AktFe))
                                            Case adCurrency: RS135.Fields(FL101.Name).Value = CSng(AryFe(AktFe))
                                            Case adDate:
                                                If IsDate(AryFe(AktFe)) = True Then
                                                    RS135.Fields(FL101.Name).Value = CDate(AryFe(AktFe))
                                                Else
                                                    RS135.Fields(FL101.Name).Value = Date
                                                End If
                                            Case adDecimal: RS135.Fields(FL101.Name).Value = CSng(AryFe(AktFe))
                                            Case adDouble: RS135.Fields(FL101.Name).Value = CDbl(AryFe(AktFe))
                                            Case adInteger: If IsNumeric(AryFe(AktFe)) = True Then RS135.Fields(FL101.Name).Value = CLng(AryFe(AktFe))
                                            Case adNumeric: RS135.Fields(FL101.Name).Value = CSng(AryFe(AktFe))
                                            Case adSingle: RS135.Fields(FL101.Name).Value = CSng(Replace(AryFe(AktFe), Chr$(32), Chr$(44), 1, 1))
                                            Case adSmallInt: RS135.Fields(FL101.Name).Value = CInt(AryFe(AktFe))
                                            Case Else: RS135.Fields(FL101.Name).Value = AryFe(AktFe)
                                            End Select
                                        End Select
                                        
                                    End If
                                End If
                            End If
                        End If
                    Next FL101
                Next AktFe
                RS135.Update
            End If
            PrBr1.Value = AktZe
            DoEvents
        Next AktZe
        AnzTe = RS135.RecordCount
        RS135.MoveFirst
    End If
    
    '---
    
    Set RS134 = New ADODB.Recordset 'Termine
    With RS134
        .CursorLocation = adUseClient
        .Source = "qryTerNeu"
        .ActiveConnection = DB1
        .CursorType = adOpenDynamic
        .LockType = adLockOptimistic
        .Open Options:=adCmdTableDirect
    End With

    If AnzTe > 0 Then 'Termine
        PrBr2.Min = 0
        PrBr2.Max = AnzTe
        Do
        If RS135.Fields(2).Value <> vbNullString Then
            RS134.AddNew
            For Each FL101 In RS135.Fields
                If RS135.Fields(FL101.Name).Value <> vbNullString Then
                    If RS135.Fields(FL101.Name).Value <> Space$(1) Then
                        Select Case FL101.Name
                        Case "ID1":
                        Case "IDR": RS134.Fields(FL101.Name).Value = GlRau 'Standardraum
                        Case "IDP": RS134.Fields(FL101.Name).Value = ManNr
                        Case "IDM": RS134.Fields(FL101.Name).Value = MitNr
                        Case "IDKurz": RS134.Fields(FL101.Name).Value = SNaFi(RS135.Fields(FL101.Name).Value, False, True, True)
                        Case "Patient": RS134.Fields(FL101.Name).Value = SNaFi(RS135.Fields(FL101.Name).Value, False, True, True)
                        Case "Kommentar": RS134.Fields(FL101.Name).Value = SNaFi(RS135.Fields(FL101.Name).Value, False, True, True)
                        Case Else: RS134.Fields(FL101.Name).Value = RS135.Fields(FL101.Name).Value
                        End Select
                    End If
                End If
            Next FL101
            RS134.Update
            DoEvents
        End If
        AktTe = AktTe + 1
        Lbl01.Caption = "Bitte warten: " & Format$(AktTe, "000000")
        PrBr2.Value = AktTe
        DoEvents
        RS135.MoveNext
        Loop Until RS135.EOF
    End If
    
     RS134.Close
     Set RS134 = Nothing
     
    If AnzTe > 0 Then RS135.Close
    Set RS135 = Nothing
    
    If AnzTe > 0 Then
        GlNeK = GlKoX 'Protokolleintrag
        With GlNeK
            .PatNr = GlMan(GlSMa, 2)
            .IdxNr = 0
            .EiDat = Format$(Date, "dd.mm.yyyy")
            .EiZei = TimeValue(Now)
            .EiTyp = 104
            .TeStr = "Termine Importiert - (" & AnzTe & " Termine)"
            .ZiStr = Format$(Now, "hh:mm") & " Uhr"
            .NeuEi = True
            .KeiAk = True
            .Mitar = GlMiA(GlSmI, 2)
        End With
        S_Prot
    End If
End If

Unload frmStatus
Set frmStatus = Nothing
DoEvents

SUpTe True

Set CoDia = Nothing
Set RpSel = Nothing
Set RpCo1 = Nothing

Set clFil = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_TeImT " & Err.Number
Exit Sub

End Sub
Public Sub S_Vol(ByVal FeIdx As Integer, ByVal FelNr As Integer)
On Error GoTo FiErr
'Füllt Comboboxen in Adressfilter

Dim AktZa As Integer
Dim FeCmb As XtremeSuiteControls.ComboBox

Set FM = frmAdrFilt
Select Case FelNr
Case 1: Set FeCmb = FM.cmbKr1
Case 2: Set FeCmb = FM.cmbKr2
Case 3: Set FeCmb = FM.cmbKr3
Case 4: Set FeCmb = FM.cmbKr4
Case 5: Set FeCmb = FM.cmbKata1
End Select

Select Case FeIdx
Case 5: 'Briefanrede
        With FeCmb
            .AddItem "Persönliche Briefanrede"
            .ItemData(0) = 1
            .AddItem "Offizielle Briefanrede"
            .ItemData(1) = 2
            .AddItem "Alternative Briefanrede"
            .ItemData(2) = 3
        End With
Case 16: 'Kataloge
        For AktZa = 1 To UBound(GlGKa)
            FeCmb.AddItem GlGKa(AktZa, 1)
            FeCmb.ItemData(AktZa - 1) = GlGKa(AktZa, 0)
        Next AktZa
Case 36: 'Kataloge
        For AktZa = 1 To UBound(GlTar)
            FeCmb.AddItem GlTar(AktZa, 2)
            FeCmb.ItemData(AktZa - 1) = GlTar(AktZa, 0)
        Next AktZa
Case 6: 'Behandler
        AktZa = 0
        Set RS148 = New ADODB.Recordset
        With RS148
            .CursorLocation = adUseClient
            .Source = "qryPatBeh"
            .ActiveConnection = DB1
            .CursorType = adOpenForwardOnly
            .LockType = adLockReadOnly
            .Open Options:=adCmdTableDirect
        End With
        If RS148.AbsolutePosition > adPosBOF Then
            Do Until RS148.EOF
                FeCmb.AddItem RS148.Fields("IDKurz").Value
                FeCmb.ItemData(AktZa) = RS148.Fields("ID0").Value
                RS148.MoveNext
                AktZa = AktZa + 1
            Loop
        End If
        RS148.Close
        Set RS148 = Nothing
Case 35: 'Zahlungsziele
        For AktZa = 1 To UBound(GlZah)
            FeCmb.AddItem GlZah(AktZa, 1)
            FeCmb.ItemData(AktZa - 1) = GlZah(AktZa, 0)
        Next AktZa
Case 34: 'Währungen
    AktZa = 0
    Set RS152 = New ADODB.Recordset
    With RS152
        .CursorLocation = adUseClient
        .Source = "qryPatWar"
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdTableDirect
    End With
    If RS152.AbsolutePosition > adPosBOF Then
        Do Until RS152.EOF
            FeCmb.AddItem RS152.Fields("Währung").Value
            FeCmb.ItemData(AktZa) = RS152.Fields("IDW").Value
            RS152.MoveNext
            AktZa = AktZa + 1
        Loop
    End If
    RS152.Close
    Set RS152 = Nothing
End Select

Exit Sub

FiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_Vol " & Err.Number
Resume Next

End Sub
