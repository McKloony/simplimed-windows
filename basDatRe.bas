                        RS130.CursorLocation = adUseClient
                        Set RS130 = DBCmRe2("qrySimAbDiSu", "@IdxNr", "@IdStr", LetRe, "%" & CoStr & "%")
                        If RS130.RecordCount > 0 Then
                            DiaEi = False
                        Else
