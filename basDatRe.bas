Public Sub S_AbChi(ByVal PaRec As XtremeReportControl.ReportRecord, ByVal IdxNr As Long, ByVal IdTyp As Integer)
On Error GoTo LiErr
'Fügt Rechnungsdetails das Krankenblatt ein

Dim PaDat As Date
Dim GesZa As Long
Dim SQL1 As String
Dim KrTyp As Integer
Dim AktZa As Integer
Dim QurTa As Integer

PaDat = PaRec.Item(Kra_Datum).Value

Select Case IdTyp
Case 101: 'Rezept
    
    Set RS155 = New ADODB.Recordset
    RS155.CursorLocation = adUseClient
    Set RS155 = DBCmRe1("qrySimAbDiMe", "@IdxNr", IdxNr)
    GesZa = RS155.RecordCount

Case 106: 'Rechnung

    If GlTyp < 2 Then
        Select Case GlSoA 'Sortierung Datum
        Case 1: 'Datum Absteigend
            Select Case GlSoZ 'Eingabesortierung
            Case 3: SQL1 = "SELECT * FROM dbo.qrySimAbLei4 WHERE IDR = " & IdxNr & " ORDER BY Sorter DESC, ID3 DESC" 'Sorter absteigend
            Case 4: SQL1 = "SELECT * FROM dbo.qrySimAbLei2 WHERE IDR = " & IdxNr & " ORDER BY Sorter DESC, ID3" 'Sorter aufsteigend
            End Select
        Case 2: 'Datum Aufsteigend
            Select Case GlSoZ
            Case 3: SQL1 = "SELECT * FROM dbo.qrySimAbLei3 WHERE IDR = " & IdxNr & " ORDER BY Sorter, ID3 DESC" 'Sorter absteigend
            Case 4: SQL1 = "SELECT * FROM dbo.qrySimAbLei1 WHERE IDR = " & IdxNr & " ORDER BY Sorter, ID3" 'Sorter aufsteigend
            End Select
        End Select
    Else
        Select Case GlSoA 'Sortierung Datum
        Case 1: 'Datum Absteigend
            Select Case GlSoZ 'Eingabesortierung
            Case 3: SQL1 = "SELECT * FROM qrySimAbLei4 WHERE [IDR] = " & IdxNr & " ORDER BY [Sorter] DESC, [ID3] DESC;" 'Sorter absteigend
            Case 4: SQL1 = "SELECT * FROM qrySimAbLei2 WHERE [IDR] = " & IdxNr & " ORDER BY [Sorter] DESC, [ID3];" 'Sorter aufsteigend
            End Select
        Case 2: 'Datum Aufsteigend
            Select Case GlSoZ
            Case 3: SQL1 = "SELECT * FROM qrySimAbLei3 WHERE [IDR] = " & IdxNr & " ORDER BY [Sorter], [ID3] DESC;" 'Sorter absteigend
            Case 4: SQL1 = "SELECT * FROM qrySimAbLei1 WHERE [IDR] = " & IdxNr & " ORDER BY [Sorter], [ID3];" 'Sorter aufsteigend
            End Select
        End Select
    End If
    
    Set RS155 = New ADODB.Recordset
    With RS155
        .CursorLocation = adUseClient
        .Source = SQL1
        .ActiveConnection = DB1
        .CursorType = adOpenForwardOnly
        .LockType = adLockReadOnly
        .Open Options:=adCmdText
    End With
    GesZa = RS155.RecordCount
    
End Select

If GesZa > 0 Then
    Do
    Select Case IdTyp
    Case 101: 'Rezept
    
        Set RpRec = PaRec.Childs.Add()
        
        Set RpItm = RpRec.AddItem(RS155.Fields("ID2").Value)
        With RpItm
            .Tag = "_ID2"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("ID0").Value)
        With RpItm
            .Tag = "_ID0"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Patient"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("ID2").Value)
        With RpItm
            .Tag = "_ID3"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(4)
        With RpItm 'WICHTIG! Hier Typ zuordnen
            .Tag = vbNullString
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm 'WICHTIG! Hier Typ zuordnen
            .Tag = vbNullString
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_ID4"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(IdxNr)
        With RpItm
            .Tag = "_IDR"
            .Focusable = False
        End With
        If RS155.Fields("Datum").Value <> vbNullString Then
            Set RpItm = RpRec.AddItem(RS155.Fields("Datum").Value)
        Else
            Set RpItm = RpRec.AddItem(PaDat)
        End If
        With RpItm
            .Tag = "_Datum"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Druckdatum"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(4)
        With RpItm
            .Tag = "_Typ"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("GOID").Value)
        With RpItm
            .Tag = "_Ziffer"
            .Focusable = False
        End With
        If RS155.Fields("GOID").Value <> vbNullString Then
            If GlPzn = True Then
                Set RpItm = RpRec.AddItem("(" & RS155.Fields("GOID").Value & ") " & RS155.Fields("IDKurz").Value)
            Else
                Set RpItm = RpRec.AddItem(RS155.Fields("IDKurz").Value)
            End If
        Else
            Set RpItm = RpRec.AddItem(RS155.Fields("IDKurz").Value)
        End If
        With RpItm
            .Tag = "_Bezeichnung"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Anz"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Faktor"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Betrag"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_GesBetrag"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_WVBetrag"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Steuersatz"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Zeit"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Einheit"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Währung"
            .Focusable = False
        End With
        If RS155.Fields("IDD").Value <> vbNullString Then
            Set RpItm = RpRec.AddItem(RS155.Fields("IDD").Value)
        Else
            Set RpItm = RpRec.AddItem(0)
        End If
        With RpItm
            .Tag = "_IDD"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_IDM"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Gedruckt"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Selekt"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Kommentar"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Kommentar2"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Typname"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        Set RpItm = RpRec.AddItem(vbNullString)
        Set RpItm = RpRec.AddItem(vbNullString)
        
    Case 106: 'Rechnung
        
        If RS155.Fields("Datum").Value <> vbNullString Then
            If CDate(RS155.Fields("Datum").Value) >= CDate("01.01." & Year(RS155.Fields("Datum").Value)) And CDate(RS155.Fields("Datum").Value) <= CDate("31.03." & Year(RS155.Fields("Datum").Value)) Then
                QurTa = 1
            ElseIf CDate(RS155.Fields("Datum").Value) >= CDate("01.04." & Year(RS155.Fields("Datum").Value)) And CDate(RS155.Fields("Datum").Value) <= CDate("30.06." & Year(RS155.Fields("Datum").Value)) Then
                QurTa = 2
            ElseIf CDate(RS155.Fields("Datum").Value) >= CDate("01.07." & Year(RS155.Fields("Datum").Value)) And CDate(RS155.Fields("Datum").Value) <= CDate("30.09." & Year(RS155.Fields("Datum").Value)) Then
                QurTa = 3
            ElseIf CDate(RS155.Fields("Datum").Value) >= CDate("01.10." & Year(RS155.Fields("Datum").Value)) And CDate(RS155.Fields("Datum").Value) <= CDate("31.12." & Year(RS155.Fields("Datum").Value)) Then
                QurTa = 4
            Else
                QurTa = 0
            End If
        Else
            QurTa = 0
        End If
        
        KrTyp = RS155.Fields("Typ").Value
        
        Set RpRec = PaRec.Childs.Add()
        
        Set RpItm = RpRec.AddItem(RS155.Fields("ID2").Value)
        With RpItm
            .Tag = "_ID2"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("ID0").Value)
        With RpItm
            .Tag = "_ID0"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Patient"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("ID3").Value)
        With RpItm
            .Tag = "_ID3"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(KrTyp)
        With RpItm 'WICHTIG! Hier Typ zuordnen
            .Tag = vbNullString
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("Provision").Value)
        With RpItm 'WICHTIG! Hier Typ zuordnen
            .Tag = vbNullString
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("ID4").Value)
        With RpItm
            .Tag = "_ID4"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("IDR").Value)
        With RpItm
            .Tag = "_IDR"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("Datum").Value)
        With RpItm
            .Tag = "_Datum"
            .Focusable = False
        End With
        If RS155.Fields("Druckdatum").Value <> vbNullString Then
            Set RpItm = RpRec.AddItem(Format$(TimeValue(RS155.Fields("Druckdatum").Value), "hh:mm"))
        Else
            Set RpItm = RpRec.AddItem(vbNullString)
        End If
        With RpItm
            .Tag = "_Druckdatum"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("Typ").Value)
        With RpItm
            .Tag = "_Typ"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("Ziffer").Value)
        With RpItm
            .Tag = "_Ziffer"
            .Focusable = False
        End With
        If GlZif = True Then
            Set RpItm = RpRec.AddItem(RS155.Fields("Bezeichnung").Value)
        Else
            Set RpItm = RpRec.AddItem("[" & RS155.Fields("Ziffer").Value & "] " & RS155.Fields("Bezeichnung").Value)
        End If
        With RpItm
            .Tag = "_Bezeichnung"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("Anz").Value)
        With RpItm
            .Tag = "_Anz"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(Format$(RS155.Fields("Faktor").Value, GlWa1))
        With RpItm
            .Tag = "_Faktor"
            .Alignment = xtpAlignmentRight
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(Format$(RS155.Fields("Betrag").Value, GlWa1))
        With RpItm
            .Tag = "_Betrag"
            .Alignment = xtpAlignmentRight
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(Format$(RS155.Fields("GesBetrag").Value, GlWa1))
        With RpItm
            .Tag = "_GesBetrag"
            .Focusable = False
            .Alignment = xtpAlignmentRight
        End With
        Set RpItm = RpRec.AddItem(Format$(RS155.Fields("WVBetrag").Value, GlWa1))
        With RpItm
            .Tag = "_WVBetrag"
            .Focusable = False
            .Alignment = xtpAlignmentRight
        End With
        If RS155.Fields("Steuersatz").Value > 0 Then
            If GlStV = True Then
                For AktZa = 1 To UBound(GlStu)
                    If Format$(GlStu(AktZa, 1), GlWa1) = Format$(RS155.Fields("Steuersatz").Value, GlWa1) Then
                        Set RpItm = RpRec.AddItem(CLng(Val(GlStu(AktZa, 0))))
                        RpItm.Alignment = xtpAlignmentRight
                        Exit For
                    End If
                Next AktZa
            End If
        Else
            Set RpItm = RpRec.AddItem(1)
        End If
        With RpItm
            .Tag = "_Steuersatz"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("Zeit").Value)
        With RpItm
            .Tag = "_Zeit"
            .Focusable = False
        End With
        If RS155.Fields("Einheit").Value <> vbNullString Then
            Set RpItm = RpRec.AddItem(RS155.Fields("Einheit").Value)
        Else
            Set RpItm = RpRec.AddItem(Space$(1))
        End If
        With RpItm
            .Tag = "_Einheit"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("Währung").Value)
        With RpItm
            .Tag = "_Währung"
            .Focusable = False
        End With
        If RS155.Fields("IDD").Value <> vbNullString Then
            Set RpItm = RpRec.AddItem(CLng(Val(RS155.Fields("IDD").Value)))
        Else
            Set RpItm = RpRec.AddItem(vbNullString)
        End If
        With RpItm
            .Tag = "_IDD"
            .Focusable = False
        End With
        If RS155.Fields("IDM").Value <> vbNullString Then
            Set RpItm = RpRec.AddItem(CLng(Val(RS155.Fields("IDM").Value)))
        Else
            Set RpItm = RpRec.AddItem(vbNullString)
        End If
        With RpItm
            .Tag = "_IDM"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        If RS155.Fields("Gedruckt").Value = -1 Then
            RpItm.Icon = IC16_Check
        End If
        With RpItm
            .Tag = "_Gedruckt"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("Selekt").Value)
        With RpItm
            .Tag = "_Selekt"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("Kommentar").Value)
        With RpItm
            .Tag = "_Kommentar"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(RS155.Fields("Kommentar2").Value)
        With RpItm
            .Tag = "_Kommentar2"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(vbNullString)
        With RpItm
            .Tag = "_Typname"
            .Focusable = False
        End With
        Set RpItm = RpRec.AddItem(QurTa)
        If RS155.Fields("Datum").Value <> vbNullString Then
            Set RpItm = RpRec.AddItem(Month(DateValue(RS155.Fields("Datum").Value)))
        Else
            Set RpItm = RpRec.AddItem(Month(DateValue(Date)))
        End If
        Set RpItm = RpRec.AddItem(DatePart("ww", RS155.Fields("Datum").Value))
    End Select
    
    RS155.MoveNext
    Loop Until RS155.EOF
End If
RS155.Close
Set RS155 = Nothing

Set RpItm = Nothing

Exit Sub

LiErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_AbChi " & Err.Number
Resume Next

End Sub
Public Sub S_AbDi()
On Error GoTo GrErr
'Entfernt die Diagnosezuordnung

Dim IdxNr As Long
Dim RowNr As Integer
Dim Frage As Integer
Dim Mld1, Tit1 As String

Dim RpCo6 As XtremeReportControl.ReportControl
Dim RpCoK As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns

Set FM = frmMain
Set RpCo6 = FM.repCont6
Set RpCoK = FM.repContK
Select Case GlBut
Case RibTab_Krankenbla:
            Set RpSel = RpCoK.SelectedRows
            Set RpCls = RpCoK.Columns
            Set RpRcs = RpCoK.Records
Case RibTab_Abrechnung:
            Set RpSel = RpCo6.SelectedRows
            Set RpCls = RpCo6.Columns
            Set RpRcs = RpCo6.Records
End Select

Tit1 = "Dianosezuordnung"
Mld1 = "Möchten Sie die Diagnosezuordnung jetzt aufheben?"

If RpSel.Count > 0 Then
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
    If Frage = 6 Then
        Screen.MousePointer = vbHourglass

        For Each RpRow In RpSel
            If RpRow.GroupRow = False Then
                RowNr = RpRow.Index
                Set RpCol = RpCls.Find(Kra_ID2)
                IdxNr = RpRow.Record(RpCol.ItemIndex).Value
                DBCmEx2 "qrySimAbSeDi", "@IdDia", "@IdxNr", 0, IdxNr
            End If
        Next RpRow

        DoEvents
        SUpAb , RowNr
        
        Screen.MousePointer = vbNormal
    End If
End If

Exit Sub

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_AbDi " & Err.Number
Resume Next


End Sub
Public Sub S_AbDo()
On Error GoTo GrErr
'Überprüft ob Behandlungstag doppelt vorhanden ist

Dim ReNum As Long
Dim RecNr As Long
Dim ReStr As String
Dim AnzPo As Integer
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo3 = FM.repCont3

If GlSta = False Then
    If GlAkt = False Then
        Set RpCls = RpCo3.Columns
        Set RpSel = RpCo3.SelectedRows
        If RpSel.Count > 0 Then
        Set RpRow = RpSel(0)
            Set RpCol = RpCls.Find(Rec_IDR)
            ReNum = RpRow.Record(RpCol.ItemIndex).Value
        End If
        Set RS133 = New ADODB.Recordset
        RS133.CursorLocation = adUseClient
        Set RS133 = DBCmRe2("qrySimAbDo4", "@IdxNr", "@IdDat", GlAdr, GlTag(1))
        AnzPo = RS133.RecordCount
        If AnzPo > 0 Then
            Do
            RecNr = RS133.Fields("IDR").Value
            ReStr = RS133.Fields("RechNr").Value
            If ReNum <> RecNr Then
                SPopu GlTag(1) & " bereits abgerechnet", "Der Behandlungstag " & GlTag(1) & " wurde bereits in der Rechnung " & ReStr & " abgerechnet.", IC48_Information
                Exit Do
            End If
            RS133.MoveNext
            Loop Until RS133.EOF
        End If
        RS133.Close
        Set RS133 = Nothing
    End If
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing

Exit Sub

GrErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_AbDo " & Err.Number
Resume Next

End Sub
