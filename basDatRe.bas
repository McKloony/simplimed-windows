Public Sub S_ReLo()
On Error GoTo LoErr
'Rechnungen löschen

Dim ReDat As Date
Dim AnzPo As Long
Dim RowNr As Long
Dim ReNum As Long
Dim PatNr As Long
Dim MaNum As Long
Dim MiNum As Long
Dim AnBet As Single
Dim ReStr As String
Dim ReTyp As String
Dim PlStr As String
Dim PaStr As String
Dim TmGui As String
Dim TeTit As String
Dim TeMai As String
Dim TeInh As String
Dim TeFus As String
Dim ReLok As Boolean
Dim ReAbg As Boolean
Dim BuSto As Boolean
Dim ReSto As Boolean
Dim BuVor As Integer
Dim Frage As Integer
Dim Posit As Integer
Dim Mld1, Mld2 As String
Dim Mld3, Tit1 As String
Dim RpCo3 As XtremeReportControl.ReportControl
Dim RpCo4 As XtremeReportControl.ReportControl
Dim RpCls As XtremeReportControl.ReportColumns
Dim RpRow As XtremeReportControl.ReportRow

Set FM = frmMain
Set RpCo4 = FM.repCont4
Set RpCo3 = FM.repCont3

Select Case GlBut
Case RibTab_Abrechnung:
        Set RpSel = RpCo3.SelectedRows
        Set RpCls = RpCo3.Columns
Case RibTab_Rechnungen:
        Set RpSel = RpCo4.SelectedRows
        Set RpCls = RpCo4.Columns
End Select

Tit1 = "Beleg Stornieren"
AnzPo = RpSel.Count

If GlBuL = True Then 'echtes Löschen erlauben
    If AnzPo > 1 Then
        Mld1 = "Möchten Sie die " & AnzPo & " markierten Einträge wirklich löschen? HINWEIS!! Wenn Sie eine Rechnung löschen, werden alle dazugehörigen Leistungen ebenfalls gelöscht."
    Else
        Mld1 = "Möchten Sie den aktuellen Eintrag wirklich löschen?  HINWEIS!! Wenn Sie eine Rechnung löschen, werden alle dazugehörigen Leistungen ebenfalls gelöscht."
    End If
End If

If GlBuL = False Then 'echtes Löschen erlauben
    Frage = 6
Else
    Frage = WindowMess(Mld1, Dial1, Tit1, FM.hwnd)
End If

If Frage = 6 Then
    For Each RpRow In RpSel
        If RpRow.GroupRow = False Then
            RowNr = RpRow.Index
            BuSto = True 'WICHTIG!

            Set RpCol = RpCls.Find(Rec_ID1)
            ReNum = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_ID0)
            PatNr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_RechNr)
            ReStr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Type)
            ReTyp = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_IDKurz)
            PaStr = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_IDP)
            MaNum = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_IDM)
            MiNum = RpRow.Record(RpCol.ItemIndex).Value
            Set RpCol = RpCls.Find(Rec_Datum)
            ReDat = CDate(RpRow.Record(RpCol.ItemIndex).Value)
            Set RpCol = RpCls.Find(Rec_GuiID)
              If RpRow.Record(RpCol.ItemIndex).Value <> vbNullString Then
                TmGui = RpRow.Record(RpCol.ItemIndex).Value
            Else
                TmGui = CreateID("R")
            End If
            Set RpCol = RpCls.Find(Rec_Storniert)
            ReSto = CBool(RpRow.Record(RpCol.ItemIndex).Value)
            Set RpCol = RpCls.Find(Rec_Selekt)
            Select Case GlBut
            Case RibTab_Abrechnung:
                ReAbg = CBool(RpRow.Record(RpCol.ItemIndex).Value)
            Case RibTab_Rechnungen:
                If LCase(RpRow.Record(RpCol.ItemIndex).Value) = "ja" Then
                    ReAbg = True
                Else
                    ReAbg = False
                End If
            End Select
            Set RpCol = RpCls.Find(Rec_Lock)
            If RpRow.Record(RpCol.ItemIndex).Checked = True Then
                ReLok = True
            Else
                ReLok = False
            End If

            If Len(ReStr) < 5 Then 'Bindestrich
                ReStr = S_ReVo(ReDat, ReTyp, MaNum, MiNum, True)
                DoEvents
                Posit = InStrRev(ReStr, "-", -1, 1)
                If Posit > 0 Then
                    PlStr = Mid$(ReStr, Posit + 1, Len(ReStr) - Posit)
                End If
                DBCmEx2 "qrySimReNu", "@IdStr", "@IdxNr", ReStr, ReNum
                DoEvents
                If PlStr <> vbNullString Then
                    DBCmEx2 "qrySimReNp", "@IdStr", "@IdxNr", Format$(PlStr, "00000000"), ReNum
                End If
            End If
            
            Set RS120 = New ADODB.Recordset 'Anzahlungen vorhanden
            RS120.CursorLocation = adUseClient
            Set RS120 = DBCmRe2("qrySimAbSuT", "@IdTyp", "@IdxNr", 6, ReNum)
            If RS120.RecordCount > 0 Then
                If RS120.Fields("WVBetrag").Value <> vbNullString Then
                    AnBet = RS120.Fields("WVBetrag").Value
                Else
                    AnBet = 0
                End If
            Else
                AnBet = 0
            End If
            RS120.Close
            Set RS120 = Nothing

            If ReLok = True Then 'Festgeschrieben
                BuSto = False
                Tit1 = "Rechnung festgeschrieben"
                Mld3 = "Diese Rechnung wurde bereits festgeschrieben!"
                SPopu Tit1, Mld3, IC48_Information
            End If

            If ReSto = True Then 'Storniert
                If GlBuL = False Then 'echtes Löschen erlauben
                    BuSto = False
                    Tit1 = "Beleg bereits storniert"
                    Mld2 = "Der Beleg " & ReStr & " wurde bereits storniert."
                    SPopu Tit1, Mld2, IC48_Information
                End If
            End If

            If GlBuL = False Then 'echtes Löschen erlauben
                If AnBet > 0 Then 'Anzahlungsbetrag vorhanden
                    TeTit = "Beleg Stornieren"
                    TeMai = "Dieser Beleg sollte nicht storniert werden"
                    TeInh = "Zur Rechnung: " & ReStr & " wurde bereits eine Erlösbuchung generiert. Dieser Beleg sollte daher nicht storniert werden. Soll dieser Beleg dennoch storniert werden?"
                    TeFus = "Belege, zu denen bereits eine Erlösbuchung existiert, sollten nicht storniert werden. Alternativ kann eine Gutschft hinzugefügt werden, um den fehlerhaften Beleg damit zu berichtigen."
                    SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, False, FM.hwnd
                    If GlMes <> 33565 Then
                        BuSto = False
                    End If
                End If
            
                BuVor = S_BuPr(0, TmGui)
                DoEvents
                Select Case BuVor
                Case 1:
                    TeTit = "Rechnung Stornieren"
                    TeMai = "Diese Rechnung sollte nicht storniert werden"
                    TeInh = "Zur Rechnung: " & ReStr & " wurde bereits eine Erlösbuchung generiert. Dieser Beleg sollte daher nicht storniert werden. Soll dieser Beleg dennoch storniert werden?"
                    TeFus = "Rechnungen, zu denen bereits eine Erlösbuchung existiert, sollten nicht storniert werden. Wird dieser Beleg dennoch storniert, wird die zugehörige Erlösbuchung ebenfalls storniert."
                    SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, False, FM.hwnd
                    If GlMes <> 33565 Then
                        BuSto = False
                    End If
                Case 2:
                    BuSto = False
                    TeTit = "Rechnung Stornieren"
                    TeMai = "Diese Rechnung darf nicht storniert werden"
                    TeInh = "Zur Rechnung: " & ReStr & " wurde bereits eine Erlösbuchung generiert und festgeschrieben. Dieser Beleg kann daher nicht storniert werden."
                    TeFus = "Rechnungen, zu denen bereits eine Erlösbuchung existiert und die bereits festgeschrieben wurden, können nicht storniert werden. Legen Sie stattdessen eine Gutschrift an, um die möglicherweise fehlerhafte Rechnung damit zu berichtigen."
                    SMeFr TeTit, TeMai, TeInh, TeFus, False, 0, True, FM.hwnd
                End Select
            End If

            If BuSto = True Then
                If GlBuL = True Then 'echtes Löschen erlauben
                    DBCmEx1 "qrySimBuLoP", "@IdxNr", ReNum 'Buchung Löschen
                    DoEvents
                    DBCmEx1 "qrySimReLo", "@IdxNr", ReNum   'Rechnung Löschen
                Else
                    DBCmEx2 "qrySimBuStr", "@IdSto", "@IdxNr", True, ReNum 'Buchung Stornieren
                    DoEvents
                    DBCmEx2 "qrySimReSto", "@IdSto", "@IdxNr", True, ReNum 'Rechnung Stornieren
                End If
                DoEvents
                DBCmEx1 "qrySimOPLoR", "@IdxNr", ReNum 'Posten löschen
                DoEvents
                DBCmEx2 "qrySimAbLoT", "@IdTyp", "@ReNum", 6, ReNum 'Anzahlungen entfernen
                DoEvents
                DBCmEx2 "qrySimReSm3", "@IdBet", "@IdxNr", 0, ReNum 'Anzahlungen Nullen
                DoEvents
                DBCmEx2 "qrySimReSm5", "@IdBez", "@IdxNr", 0, ReNum 'Bezahltbetrag anpassen
                DoEvents
                If TmGui <> vbNullString Then
                    DBCmEx1 "qrySimAbLoG", "@IdStr", TmGui 'Krankenblattdokumentation entfernen
                    DoEvents
                End If
                DoEvents
                GlNeK = GlKoX 'Protokolleintrag
                With GlNeK
                    .PatNr = PatNr
                    .IdxNr = 0
                    .EiDat = Format$(Date, "dd.mm.yyyy")
                    .EiZei = TimeValue(Now)
                    .EiTyp = 104
                    .TeStr = "Rechnung storniert - " & ReStr & Chr$(32) & PaStr
                    .ZiStr = Format$(Now, "hh:mm") & " Uhr"
                    .NeuEi = True
                    .KeiAk = True
                    .Mitar = GlMiA(GlSmI, 2)
                End With
                S_Prot
            End If
        End If
    Next RpRow
    
    Select Case GlBut
    Case RibTab_Abrechnung:
                Set RpSel = RpCo3.SelectedRows
                If RpSel.Count > 0 Then
                    Set RpRow = RpSel(0)
                    RowNr = RpRow.Index
                    SUpAb RowNr
                End If
                Set RpSel = RpCo4.SelectedRows
                If RpSel.Count > 0 Then
                    Set RpRow = RpSel(0)
                    RowNr = RpRow.Index
                    SUpRe RowNr
                End If
    Case RibTab_Rechnungen:
                Set RpSel = RpCo4.SelectedRows
                If RpSel.Count > 0 Then
                    Set RpRow = RpSel(0)
                    RowNr = RpRow.Index
                    SUpRe RowNr
                End If
    End Select
    If WindowLoad("frmAufga") = True Then
        If GlWaT = RibTab_Wart_Beha Then
            WaSpl RibTab_Wart_Beha
            S_WaLa RibTab_Wart_Beha
        End If
    End If
End If

Set RpSel = Nothing
Set RpCls = Nothing
Set RpCo3 = Nothing
Set RpCo4 = Nothing

Exit Sub

LoErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReLo " & Err.Number
Resume Next

End Sub
Public Function S_ReMx(ByVal ReNum As Long) As String
On Error GoTo SuErr
'Generiert den Datamatixcode für Tarif590

Dim BeDif As Long
Dim GebZa As Long
Dim ZSRZa As Long
Dim PLZZa As Long
Dim GesZa As Long
Dim Ergeb As Long
Dim ZSRSt As String
Dim ZSRNm As String
Dim ReDat As String
Dim ReStr As String
Dim BeDat As String
Dim PLZSt As String
Dim PLZNm As String
Dim TmStr As String
Dim GesBe As Single
Dim AktZa As Integer

Set RS118 = New ADODB.Recordset
RS118.CursorLocation = adUseClient
Set RS118 = DBCmRe1("qryPrSimReT", "@IdxNr", ReNum)
If RS118.RecordCount > 0 Then

    If IsNull(RS118.Fields("ZSR").Value) = False Then
        If RS118.Fields("ZSR").Value <> vbNullString Then
            ZSRSt = RS118.Fields("ZSR").Value
        Else
            ZSRSt = "000000"
        End If
    Else
        ZSRSt = "000000"
    End If
    For AktZa = 1 To Len(ZSRSt) 'Buchstaben rausfiltern
        If IsNumeric(Mid$(ZSRSt, AktZa, 1)) = True Then
            ZSRNm = ZSRNm & Mid$(ZSRSt, AktZa, 1)
        End If
    Next AktZa
    If Len(ZSRNm) > 6 Then
        ZSRZa = Left$(ZSRNm, 6)
    Else
        ZSRZa = ZSRNm
    End If
    
    If IsNull(RS118.Fields("PLZ").Value) = False Then
        If RS118.Fields("PLZ").Value <> vbNullString Then
            PLZSt = RS118.Fields("PLZ").Value
        Else
            PLZSt = "0000"
        End If
    Else
        PLZSt = "0000"
    End If
    For AktZa = 1 To Len(PLZSt) 'Buchstaben rausfiltern
        If IsNumeric(Mid$(PLZSt, AktZa, 1)) = True Then
            PLZNm = PLZNm & Mid$(PLZSt, AktZa, 1)
        End If
    Next AktZa
    If Len(PLZNm) > 4 Then
        PLZZa = Left$(PLZNm, 4)
    Else
        PLZZa = PLZNm
    End If
    
    If IsNull(RS118.Fields("Rechnungsdatum").Value) = False Then
        If RS118.Fields("Rechnungsdatum").Value <> vbNullString Then
            If IsDate(RS118.Fields("Rechnungsdatum").Value) = True Then
                ReDat = RS118.Fields("Rechnungsdatum").Value
            Else
                ReDat = Date
            End If
        Else
            ReDat = Date
        End If
    Else
        ReDat = Date
    End If
    ReStr = Replace(ReDat, ".", vbNullString, 1) & DatePart("h", Now, vbMonday) & "0000"
    
    If IsNull(RS118.Fields("Datum").Value) = False Then
        If RS118.Fields("Datum").Value <> vbNullString Then
            If IsDate(RS118.Fields("Datum").Value) = True Then
                BeDat = RS118.Fields("Datum").Value
            Else
                BeDat = Date
            End If
        Else
            BeDat = Date
        End If
    Else
        BeDat = Date
    End If
    BeDif = DateDiff("d", CDate("01.01.1900"), CDate(BeDat), vbMonday)
     
    If IsNull(RS118.Fields("Geboren").Value) = False Then
        If RS118.Fields("Geboren").Value <> vbNullString Then
            If IsDate(RS118.Fields("Geboren").Value) = True Then
                GebZa = DateDiff("d", CDate("01.01.1900"), CDate(RS118.Fields("Geboren").Value), vbMonday)
            Else
                GebZa = DateDiff("d", CDate("01.01.1900"), CDate(Date), vbMonday)
            End If
        Else
            GebZa = DateDiff("d", CDate("01.01.1900"), CDate(Date), vbMonday)
        End If
    Else
        GebZa = DateDiff("d", CDate("01.01.1900"), CDate(Date), vbMonday)
    End If
    
    If IsNull(RS118.Fields("GesBetrag").Value) = False Then
        If RS118.Fields("GesBetrag").Value <> vbNullString Then
            GesBe = RS118.Fields("GesBetrag").Value
        Else
            GesBe = 0
        End If
    Else
        GesBe = 0
    End If
    GesZa = CLng(Round(GesBe, 0))

    Ergeb = ZSRZa + GebZa + PLZZa + GesZa + BeDif

    TmStr = "/-/#23#" & ReStr & "#" & Ergeb
End If

RS118.Close
Set RS118 = Nothing

S_ReMx = TmStr

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_ReMx " & Err.Number
Resume Next

End Function
Public Sub S_ReNe()
