TmpSt = TmpSt & Chr$(34) & "0" & Chr$(34) & ExSep 'Kennzeichnung_Bankverbindung2
If RST.Fields("Geändert").Value <> vbNullString Then 'Bank2_Gültig_von
    TmpSt = TmpSt & Chr$(34) & Format$(RST.Fields("Geändert").Value, "ddmmyyyy") & Chr$(34) & ExSep
Else
    TmpSt = TmpSt & Chr$(34) & Format$(Date, "ddmmyyyy") & Chr$(34) & ExSep
End If
TmpSt = TmpSt & Chr$(34) & Format$(Date, "ddmmyyyy") & Chr$(34) & ExSep 'Bank2_Gültig_bis

TmpSt = TmpSt & vbCrLf 'Abschließender Zeilenumbruch
DoEvents

S_DaExA = TmpSt

Exit Function

SuErr:
If GlDbg = True Then MsgBox Err.Description, 48, "S_DaExA " & Err.Number
Resume Next

End Function
Public Function S_DaExB(ByRef RST As ADODB.Recordset, ByVal ExTyp As String, Optional ByVal ZeiEx As Boolean) As String
On Error GoTo SuErr

Dim BuDat As Date   'Buchungs-Datum
Dim IdxNr As Long
Dim TmpLo As Long   'Temporäre Variable
Dim PatNr As Long
Dim KtoSo As Long   'SOLL-Konto
Dim KtoHa As Long   'HABEN-Konto
Dim ManNr As Long
Dim MitNr As Long
Dim PidNr As Long
Dim GesSt As String
Dim TmpSt As String 'Temporäre Variable
Dim KtStr As String 'Kontenbezeichnung
Dim ReStr As String * 12
Dim UmStr As String * 12
Dim BuStr As String * 60
Dim BuTex As String
Dim GesBe As String 'Muss immer positiv sein bei DATEV
Dim Steue As String 'Steuersatz
Dim StSch As String 'Steuerschlüssel
Dim BelFe As String * 12
Dim PaStr As String
Dim KSoSt As String
Dim KHaSt As String
Dim Beleg As String
Dim Komme As String
Dim TmSt1 As String
Dim TmSt2 As String
Dim ExSep As String
Dim CSVep As String
Dim Kennz As String 'Soll oder Haben Konto
Dim Koste As String
Dim PaNum As String
Dim DaNam As String
Dim DaExt As String
Dim BuGui As String
Dim BeGui As String
Dim ReStu As Single
Dim BuTyp As Integer
Dim GeKto As Integer
Dim Lange As Integer
Dim AnzNu As Integer
Dim AktZa As Integer
Dim Storn As Boolean
Dim BLock As Boolean
Dim BeVor As Boolean
Dim BeAry() As Variant 'Belegexport

ExSep = Chr$(59) 'DATEV Seperator
CSVep = Chr$(34) & Chr$(59) & Chr$(34)

ReDim BeAry(1)

Do '---------- Begin loop ----------
BeVor = False
DaNam = vbNullString
Beleg = vbNullString
BuGui = vbNullString
BeGui = vbNullString
ReStr = Space$(12)

If IsNull(RST.Fields("Datum").Value) = True Then
    Exit Function
Else
    BuDat = RST.Fields("Datum").Value
End If
If RST.Fields("ID0").Value <> vbNullString Then
    IdxNr = RST.Fields("ID0").Value
Else
    IdxNr = 0
End If
If RST.Fields("IDA").Value <> vbNullString Then
    BuTyp = RST.Fields("IDA").Value
Else
    BuTyp = 0
End If
If RST.Fields("IDB").Value <> vbNullString Then
    GeKto = RST.Fields("IDB").Value
Else
    GeKto = 0
End If
If ZeiEx = True Then
    If RST.Fields("IDT").Value <> vbNullString Then
        ManNr = RST.Fields("IDT").Value
    Else
        ManNr = 0
    End If
    If RST.Fields("IDM").Value <> vbNullString Then
        MitNr = RST.Fields("IDM").Value
    Else
        MitNr = 0
    End If
Else
    If RST.Fields("Mandant").Value <> vbNullString Then
        ManNr = RST.Fields("Mandant").Value
    Else
        ManNr = 0
    End If
    If RST.Fields("Mitarbeiter").Value <> vbNullString Then
        MitNr = RST.Fields("Mitarbeiter").Value
    Else
        MitNr = 0
    End If
End If
If RST.Fields("Steuer").Value <> vbNullString Then
    Steue = CSng(RST.Fields("Steuer").Value)
Else
    Steue = 0
End If
If RST.Fields("Storniert").Value <> vbNullString Then
    Storn = CBool(RST.Fields("Storniert").Value)
Else
    Storn = 0
End If
If RST.Fields("Lock").Value <> vbNullString Then
    BLock = CBool(RST.Fields("Lock").Value)
Else
    BLock = 0
End If
If RST.Fields("Datei").Value <> vbNullString Then
    If Len(RST.Fields("Datei").Value) > 46 Then
        DaNam = RST.Fields("Datei").Value
        DaExt = Right$(DaNam, 4)
        DaNam = Left$(DaNam, 42) & DaExt
    End If
Else
    If ZeiEx = True Then
        If RST.Fields("RechNr").Value <> vbNullString Then
            DaNam = "Rechnung_Beleg_" & RST.Fields("RechNr").Value & ".pdf"
        End If
    Else
        If RST.Fields("Belegzeichen").Value <> vbNullString Then
            DaNam = "Rechnung_Beleg_" & RST.Fields("Belegzeichen").Value & ".pdf"
        End If
    End If
End If

If DaNam <> vbNullString Then
    BuGui = RST.Fields("GuiID").Value
    BeGui = LCase(Mid$(BuGui, 2, 8) & Chr$(45) & Mid$(BuGui, 10, 4) & Chr$(45) & Mid$(BuGui, 14, 4) & Chr$(45) & Mid$(BuGui, 18, 4) & Chr$(45) & Mid$(BuGui, 22, 12))
    For AktZa = 1 To UBound(BeAry)
        If BeAry(AktZa) = DaNam Then
            BeVor = True
            Exit For
        End If
    Next AktZa
    If BeVor = False Then
        BelZa = BelZa + 1
        ReDim Preserve BeAry(BelZa)
        BeAry(BelZa) = DaNam
    End If
End If

If ZeiEx = True Then
    KtStr = RTrim(RST.Fields("IDKurz").Value)
Else
    If GlBuc = True Then 'einfache Buchhaltung verwenden
        KtStr = RTrim(RST.Fields("Sachkontenbezeichnung").Value)
    Else
        KtStr = RTrim(RST.Fields("Sollkontenbezeichnung").Value)
    End If
End If

PatNr = RST.Fields("ID0").Value
TmSt2 = S_AdIdx(PatNr, "Mandant")
DoEvents

If GlDeN = True Then 'DATEV Patientennummer exportieren
    If TmSt2 <> vbNullString Then
        If IsNumeric(TmSt2) = True Then
            PidNr = CLng(TmSt2)
            If GldKt = True Then 'DATEV Schnittstelle Sachkonten vierstellig
                PaNum = Format$(PidNr, "00000")
            Else
                PaNum = Format$(PidNr, "0000000")
            End If
        Else
            If GldKt = True Then 'DATEV Schnittstelle Sachkonten vierstellig
                PaNum = Space$(5)
            Else
                PaNum = Space$(7)
            End If
        End If
    Else
        If GldKt = True Then 'DATEV Schnittstelle Sachkonten vierstellig
            PaNum = Space$(5)
        Else
            PaNum = Space$(7)
        End If
    End If
Else
    If GldKt = True Then
        PaNum = "6" & Format(BuDat, "yy") & Format(BuDat, "mm")
    Else
        PaNum = "6" & Format(BuDat, "yyyy") & Format(BuDat, "mm")
    End If
End If

For AktZa = 1 To UBound(GlThe)
     If ManNr = GlThe(AktZa, 0) Then 'Mandantennummer
        If GlThe(AktZa, 47) <> vbNullString Then
            If Len(GlThe(AktZa, 47)) > 8 Then
                Koste = Left$(GlThe(AktZa, 47), 8)
            Else
                Koste = GlThe(AktZa, 47) 'Kostenstelle
            End If
        Else
            Koste = vbNullString
        End If
        Exit For
    End If
Next AktZa
DoEvents

'Buchungsart ermitteln
If ZeiEx = True Then
    KtoSo = S_DaKoZ(RST.Fields("IDK").Value)
    If GlBuc = True Then 'einfache Buchhaltung verwenden
        KtoHa = S_DaKoK(GeKto)
    Else
        KtoHa = S_DaKoZ(RST.Fields("IDG").Value)
    End If
    
    If GlBuc = True Then 'einfache Buchhaltung verwenden
        Select Case BuTyp
        Case 1: 'Ausgaben
            If GlTSH = True Then
                Kennz = "S"
            Else
                Kennz = "H"
            End If
            If RST.Fields("Ausgabe").Value > 0 Then
                GesBe = Format$(RST.Fields("Ausgabe").Value, GlWa1)
            ElseIf RST.Fields("Einnahme").Value > 0 Then
                GesBe = Format$(RST.Fields("Einnahme").Value, GlWa1)
            Else
                GesBe = Format$(0, GlWa1)
            End If
        Case 2: 'Einnahmen
            If GlTSH = True Then
                Kennz = "H"
            Else
                Kennz = "S"
            End If
            If RST.Fields("Einnahme").Value > 0 Then
                GesBe = Format$(RST.Fields("Einnahme").Value, GlWa1)
            ElseIf RST.Fields("Ausgabe").Value > 0 Then
                GesBe = Format$(RST.Fields("Ausgabe").Value, GlWa1)
            Else
                GesBe = Format$(0, GlWa1)
            End If
        Case Else:
            'Unbekannte Buchungsart - anhand vom Betrag unterscheiden
            If RST.Fields("Einnahme").Value <> vbNullString Then
                If GlTSH = True Then
                    Kennz = "H"
                Else
                    Kennz = "S"
                End If
                If RST.Fields("Einnahme").Value > 0 Then
                    GesBe = Format$(RST.Fields("Einnahme").Value, GlWa1)
                Else
                    GesBe = Format$(0, GlWa1)
                End If
            ElseIf RST.Fields("Ausgabe").Value <> vbNullString Then
                If GlTSH = True Then
                    Kennz = "S"
                Else
                    Kennz = "H"
                End If
                If RST.Fields("Ausgabe").Value > 0 Then
                    GesBe = Format$(RST.Fields("Ausgabe").Value, GlWa1)
                Else
                    GesBe = Format$(0, GlWa1)
                End If
            Else 'Alle Beträge sind 0 -> leere Buchungszeile generieren
                S_DaExB = vbNullString
                Exit Function
            End If
        End Select
    Else
        If GlTSH = True Then
            Kennz = "H"
        Else
            Kennz = "S"
        End If
        If RST.Fields("Einnahme").Value > 0 Then
            GesBe = Format$(RST.Fields("Einnahme").Value, GlWa1)
        Else
            GesBe = Format$(0, GlWa1)
        End If
    End If
Else
    If GlBuc = True Then 'einfache Buchhaltung verwenden
        KtoSo = S_DaKoZ(RST.Fields("Sachkonto").Value)
        KtoHa = S_DaKoK(GeKto)
    Else
        KtoSo = S_DaKoZ(RST.Fields("Sollkonto").Value)
        KtoHa = S_DaKoZ(RST.Fields("Habenkonto").Value)
    End If
    If GlBuc = True Then 'einfache Buchhaltung verwenden
        Select Case BuTyp
        Case 1:
            If GlTSH = True Then
                Kennz = "H"
            Else
                Kennz = "S"
            End If
            If GlBuc = True Then 'einfache Buchhaltung verwenden
                If RST.Fields("Ausgabe").Value > 0 Then
                    GesBe = Format$(RST.Fields("Ausgabe").Value, GlWa1)
                Else
                    GesBe = Format$(0, GlWa1)
                End If
            Else
                If RST.Fields("Brutto").Value > 0 Then
                    GesBe = Format$(RST.Fields("Brutto").Value, GlWa1)
                Else
                    GesBe = Format$(0, GlWa1)
                End If
            End If
        Case 2:
            If GlTSH = True Then
                Kennz = "S"
            Else
                Kennz = "H"
            End If
            If GlBuc = True Then 'einfache Buchhaltung verwenden
                If RST.Fields("Einnahme").Value > 0 Then
                    GesBe = Format$(RST.Fields("Einnahme").Value, GlWa1)
                Else
                    GesBe = Format$(0, GlWa1)
                End If
            Else
                If RST.Fields("Betrag").Value > 0 Then
                    GesBe = Format$(RST.Fields("Betrag").Value, GlWa1)
                Else
                    GesBe = Format$(0, GlWa1)
                End If
            End If
        Case Else:
            ' Unbekannte Buchungsart - anhand vom Betrag unterscheiden
            If RST.Fields("Einnahme").Value <> vbNullString Then
                If GlTSH = True Then
                    Kennz = "S"
                Else
                    Kennz = "H"
                End If
                If GlBuc = True Then 'einfache Buchhaltung verwenden
                    If RST.Fields("Einnahme").Value > 0 Then
                        GesBe = Format$(RST.Fields("Einnahme").Value, GlWa1)
                    Else
                        GesBe = Format$(0, GlWa1)
                    End If
                Else
                    If RST.Fields("Betrag").Value > 0 Then
                        GesBe = Format$(RST.Fields("Betrag").Value, GlWa1)
                    Else
                        GesBe = Format$(0, GlWa1)
                    End If
                End If
            ElseIf RST.Fields("Ausgabe").Value <> vbNullString Then
                If GlTSH = True Then
                    Kennz = "H"
                Else
                    Kennz = "S"
                End If
                If GlBuc = True Then 'einfache Buchhaltung verwenden
                    If RST.Fields("Ausgabe").Value > 0 Then
                        GesBe = Format$(RST.Fields("Ausgabe").Value, GlWa1)
                    Else
                        GesBe = Format$(0, GlWa1)
                    End If
                Else
                    If RST.Fields("Brutto").Value > 0 Then
                        GesBe = Format$(RST.Fields("Brutto").Value, GlWa1)
                    Else
                        GesBe = Format$(0, GlWa1)
                    End If
                End If
            Else 'Alle Beträge sind 0 -> leere Buchungszeile generieren
                S_DaExB = vbNullString
                Exit Function
            End If
        End Select
    Else
        If GlTSH = True Then
            Kennz = "S"
        Else
            Kennz = "H"
        End If
        If GlBuc = True Then 'einfache Buchhaltung verwenden
            If RST.Fields("Einnahme").Value > 0 Then
                GesBe = Format$(RST.Fields("Einnahme").Value, GlWa1)
            Else
                GesBe = Format$(0, GlWa1)
            End If
        Else
            If RST.Fields("Betrag").Value > 0 Then
                GesBe = Format$(RST.Fields("Betrag").Value, GlWa1)
            Else
                GesBe = Format$(0, GlWa1)
            End If
        End If
    End If
End If

If Kennz = "H" Then 'Umsatzsteuer
    Select Case Steue
    Case "0,07": StSch = "02"
    Case "0,09": StSch = "00"
    Case "0,16": StSch = "05"
    Case "0,19": StSch = "03"
    Case "7": StSch = "02"
    Case "9": StSch = "00"
    Case "16": StSch = "05"
    Case "19": StSch = "03"
    Case Else: StSch = Space$(2)
    End Select
Else 'Vorsteuer
    Select Case Steue
    Case "0,07": StSch = "08"
    Case "0,09": StSch = "00"
    Case "0,16": StSch = "07"
    Case "0,19": StSch = "09"
    Case "7": StSch = "08"
    Case "9": StSch = "00"
    Case "16": StSch = "07"
    Case "19": StSch = "09"
    Case Else: StSch = Space$(2)
    End Select
End If

If ZeiEx = True Then
    If RST.Fields("RechNr").Value <> vbNullString Then
        ReStr = Left(RST.Fields("RechNr").Value, 12)
    End If
Else
    If RST.Fields("Belegzeichen").Value <> vbNullString Then
        ReStr = Left(RST.Fields("Belegzeichen").Value, 12)
    End If
End If

If ZeiEx = True Then
    If RST.Fields("Beleg").Value <> vbNullString Then
        If IsNumeric(RST.Fields("Beleg").Value) = True Then
            Beleg = Format$(RST.Fields("Beleg").Value, "00000000")
        End If
    End If
Else
    If RST.Fields("Nummer").Value <> vbNullString Then
        If IsNumeric(RST.Fields("Nummer").Value) = True Then
            Beleg = Format$(RST.Fields("Nummer").Value, "00000000")
        End If
    End If
End If

If RST.Fields("Kommentar").Value <> vbNullString Then
    If IsNumeric(RST.Fields("Kommentar").Value) = True Then
        Komme = Format$(RST.Fields("Kommentar").Value, "00000000")
    End If
End If

GesBe = Replace(GesBe, ".", vbNullString, 1)
DoEvents

KSoSt = S_DaExF(KtoSo)
KHaSt = S_DaExF(KtoHa)

Lange = Len(GesBe)
If Lange < 12 Then
    AnzNu = 12 - Lange
    Select Case AnzNu
    Case 1: GesBe = "0" & GesBe
    Case 2: GesBe = "00" & GesBe
    Case 3: GesBe = "000" & GesBe
    Case 4: GesBe = "0000" & GesBe
    Case 5: GesBe = "00000" & GesBe
    Case 6: GesBe = "000000" & GesBe
    Case 7: GesBe = "0000000" & GesBe
    Case 8: GesBe = "00000000" & GesBe
    Case 9: GesBe = "000000000" & GesBe
    End Select
End If

If Storn = True Then
    BelFe = "[STORNIERT] "
    If ZeiEx = True Then
        If RST.Fields("Patient").Value <> vbNullString Then
            PaStr = RST.Fields("Patient").Value
        Else
            PaStr = vbNullString
        End If
        If RST.Fields("Buchtext").Value <> vbNullString Then
            BuTex = RST.Fields("Buchtext").Value
        Else
            BuTex = vbNullString
        End If
        If GlDaP = True Then 'DATEV Debitorennamen exportieren
            If PaStr <> vbNullString Then
                If BuTex <> vbNullString Then
                    TmSt1 = PaStr & " " & BuTex
                Else
                    TmSt1 = PaStr
                End If
            ElseIf BuTex <> vbNullString Then
                TmSt1 = BuTex
            Else
                TmSt1 = vbNullString
            End If
        Else
            If BuTex <> vbNullString Then
                TmSt1 = BuTex
            Else
                TmSt1 = vbNullString
            End If
        End If
        If RST.Fields("Buchtext").Value <> vbNullString Then
            BuStr = BelFe & Replace(Left(S_DaKoS(TmSt1), 48), ExSep, vbNullString)
        Else
            BuStr = BelFe & Space$(48)
        End If
    Else
        If RST.Fields("Buchungstext").Value <> vbNullString Then
            BuStr = BelFe & Replace(Left(S_DaKoS(RST.Fields("Buchungstext").Value), 48), ExSep, vbNullString)
        Else
            BuStr = BelFe & Space$(48)
        End If
    End If
Else
    BelFe = Space$(12)
    If ZeiEx = True Then
        If RST.Fields("Patient").Value <> vbNullString Then
            PaStr = RST.Fields("Patient").Value
        Else
            PaStr = vbNullString
        End If
        If RST.Fields("Buchtext").Value <> vbNullString Then
            BuTex = RST.Fields("Buchtext").Value
        Else
            BuTex = vbNullString
        End If
        If GlDaP = True Then 'DATEV Debitorennamen exportieren
            If PaStr <> vbNullString Then
                If BuTex <> vbNullString Then
                    TmSt1 = PaStr & " " & BuTex
                Else
                    TmSt1 = PaStr
                End If
            ElseIf BuTex <> vbNullString Then
                TmSt1 = BuTex
            Else
                TmSt1 = vbNullString
            End If
        Else
            If BuTex <> vbNullString Then
                TmSt1 = BuTex
            Else
                TmSt1 = vbNullString
            End If
        End If
        If RST.Fields("Buchtext").Value <> vbNullString Then
            BuStr = Replace(Left(S_DaKoS(TmSt1), 60), ExSep, vbNullString)
        Else
            BuStr = Space$(60)
        End If
    Else
        If RST.Fields("Buchungstext").Value <> vbNullString Then
            BuStr = Replace(Left(S_DaKoS(RST.Fields("Buchungstext").Value), 60), ExSep, vbNullString)
        Else
            BuStr = Space$(60)
        End If
    End If
End If

' Buchungszeile generieren
Select Case ExTyp
Case "csv":
    TmpSt = vbNullString
    TmpSt = TmpSt & GesBe & ExSep  'Umsatz (ohne Soll/Haben-Kz)
    TmpSt = TmpSt & Chr$(34) & Format(Kennz, "0") & Chr$(34) & ExSep   'Soll/Haben-Kennzeichen
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep  'Fremdwährungskennung
    TmpSt = TmpSt & vbNullString & ExSep 'Fremdwährungskurs
    TmpSt = TmpSt & vbNullString & ExSep 'Basisumsatz
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'Fremdwährungskennung
    TmpSt = TmpSt & KSoSt & ExSep 'Sachkonto
    TmpSt = TmpSt & KHaSt & ExSep 'Geldkonto
    TmpSt = TmpSt & Chr$(34) & StSch & Chr$(34) & ExSep 'Steuerschlüssel
    TmpSt = TmpSt & Format(BuDat, "ddmm") & ExSep 'Belegdatum
    TmpSt = TmpSt & Chr$(34) & ReStr & Chr$(34) & ExSep 'DATEV Beleg
    TmpSt = TmpSt & Chr$(34) & BelFe & Chr$(34) & ExSep 'Belegfeld2 (max. 12 Zeichen)
    TmpSt = TmpSt & vbNullString & ExSep 'Skonto
    TmpSt = TmpSt & Chr$(34) & BuStr & Chr$(34) & ExSep 'Buchungstext (max. 60 Zeichen)
    TmpSt = TmpSt & vbNullString & ExSep 'Postensperre
    TmpSt = TmpSt & Chr$(34) & PaNum & Chr$(34) & ExSep 'Adressnummer
    TmpSt = TmpSt & vbNullString & ExSep 'Geschäftspartnerbank
    TmpSt = TmpSt & vbNullString & ExSep 'Sachverhalt
    TmpSt = TmpSt & vbNullString & ExSep 'Zinssperre
    If DaNam <> vbNullString Then
        If BeVor = False Then
            TmpSt = TmpSt & Chr$(34) & "BEDI " & Chr$(34) & BeGui & Chr$(34) & Chr$(34) & ExSep 'Beleglink
        Else
            TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep
        End If
    Else
        TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep
    End If
    TmpSt = TmpSt & Chr$(34) & Format$(ManNr, "000000") & Chr$(34) & ExSep 'Beleginfo1a Mandant
    TmpSt = TmpSt & Chr$(34) & Format$(MitNr, "000000") & Chr$(34) & ExSep 'Beleginfo1a Mitarbeiter
    TmpSt = TmpSt & Chr$(34) & Beleg & Chr$(34) & ExSep  'Beleginfo2a
    TmpSt = TmpSt & Chr$(34) & DaNam & Chr$(34) & ExSep 'Beleginfo2b
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'Beleginfo3a
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'Beleginfo3b
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'Beleginfo4a
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'Beleginfo4b
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'Beleginfo5a
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'Beleginfo5b
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'Beleginfo6a
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'Beleginfo6b
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'Beleginfo7a
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'Beleginfo7b
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'Beleginfo8a
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'Beleginfo8b
    TmpSt = TmpSt & Chr$(34) & Koste & Chr$(34) & ExSep 'Kostenstelle 1
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'Kostenstelle 2
    TmpSt = TmpSt & vbNullString & ExSep 'Kostmenge
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'UStID
    TmpSt = TmpSt & vbNullString & ExSep 'EU-Steuersatz
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'Versteuerungsart
    TmpSt = TmpSt & vbNullString & ExSep 'L+L1
    TmpSt = TmpSt & vbNullString & ExSep 'L+L2
    TmpSt = TmpSt & vbNullString & ExSep 'BU49a
    TmpSt = TmpSt & vbNullString & ExSep 'BU49b
    TmpSt = TmpSt & vbNullString & ExSep 'BU49c
    TmpSt = TmpSt & Chr$(34) & Chr$(34) & ExSep 'Info1a
