            .PatNr = GlMan(GlSMa, 2)
            .IdxNr = 0
            .EiDat = Format$(Date, "dd.mm.yyyy")
            .EiZei = TimeValue(Now)
            .EiTyp = 104
            .ZiStr = Format$(Now, "hh:mm") & " Uhr"
            .NeuEi = True
            .KeiAk = True
            .Mitar = GlMiA(GlSmI, 2)
